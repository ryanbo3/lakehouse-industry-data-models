# RDFS Schema for Business: Telecommunication

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/telecommunication#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Telecommunication ---
ind:Telecommunication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Telecommunication' ;
    rdfs:comment 'Telecommunications is a global industry providing wireless services, broadband, fiber internet, and digital entertainment to billions of consumer and business customers through extensive network infrastructure.' .

# --- Domain Classes ---
ind:Network rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Network' ;
    rdfs:comment 'SSOT for all physical and logical network infrastructure including RAN, transport, core network elements, GPON/FTTH, MPLS, SD-WAN, NFV/SDN nodes, OLT/ONT, DSLAM, BNG, BRAS, POP sites, and spectrum allocation. Governs network topology, capacity, configuration, and element lifecycle managed via Nokia NetAct, Ericsson Network Manager, and NMS/EMS platforms.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Customer' ;
    rdfs:comment 'SSOT for all subscriber identities, account hierarchies, and relationship data across B2C consumers, B2B enterprise accounts, and wholesale clients. Manages customer profiles, contacts, segments, household groupings, NPS/CSAT scores, CLTV segmentation, and CRM interactions managed via Salesforce CRM.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Service' ;
    rdfs:comment 'SSOT for the logical service layer instantiated on network resources — active service instances, provisioning, activation, service configurations, SLA parameters, QoS profiles, VoLTE/IMS service state, eSIM profiles, and CPE assignments. Bridges product catalog to physical network delivery via Oracle OSM and Netcracker OSS.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Product' ;
    rdfs:comment 'SSOT for the commercial product and service catalog defining all offerings including mobile plans, broadband packages, IPTV/OTT bundles, VoIP offerings, enterprise SD-WAN/MPLS products, devices, and promotional offers. Manages product specifications, pricing models, bundles, eligibility, and product lifecycle via Netcracker Product Catalog.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Order' ;
    rdfs:comment 'SSOT for end-to-end order management and fulfillment — new activations, upgrades, downgrades, disconnections, MNP port-in/port-out, and change-of-service requests. Orchestrates order decomposition, workflow coordination, and fulfillment across OSS/BSS systems via Oracle Communications Order and Service Management.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Billing' ;
    rdfs:comment 'SSOT for all customer financial transactions including rating, charging, invoicing, collections, payment processing, prepaid balance management, postpaid billing cycles, disputes, adjustments, dunning, MRR/ARPU reporting, and revenue recognition. Managed via Amdocs Revenue Management and Comverse ONE.' .

ind:Usage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Usage' ;
    rdfs:comment 'SSOT for raw and processed usage event data — CDRs (voice, SMS, data), IPDR streams, DPI session records, roaming TAP/NRTRDE records, and content consumption events. Manages usage collection, mediation, aggregation, and feeds to real-time rating engines and revenue assurance analytics.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'SSOT for physical and logical resource inventory including CPE, SIM/eSIM stock, ONT/OLT hardware, fiber infrastructure, spare parts, IP address pools, MSISDN/DID number ranges, spectrum allocations, and OSP/ISP asset tracking. Managed via Oracle OSM resource inventory and Netcracker.' .

ind:Interconnect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Interconnect' ;
    rdfs:comment 'SSOT for inter-operator settlement and wholesale traffic exchange — IOT tariff tables, TAP file processing, roaming agreements, transit traffic records, peering arrangements, NRTRDE near-real-time roaming data, and financial settlement with domestic and international carriers.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'SSOT for field and technical workforce operations — technician scheduling, dispatch, route optimization, work order execution, skill/certification tracking, and mobile workforce coordination for network installation, maintenance, and repair. Managed via Granite Telecommunications WFM.' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Partner' ;
    rdfs:comment 'SSOT for all third-party partner and vendor relationships — MVNO host agreements, content provider contracts, OTT platform partnerships, roaming partners, equipment vendors, channel partners, dealers, and agents. Manages partner onboarding, SLAs, revenue sharing, and settlement.' .

ind:Assurance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Assurance' ;
    rdfs:comment 'SSOT for network fault management, performance monitoring, revenue assurance, and service quality operations — alarm events, trouble tickets, SLA breach tracking, MTTR/MTBF KPIs, NOC/SOC incident records, fraud detection, leakage detection, and reconciliation. Integrates Nokia NetAct, Ericsson NM, and ServiceNow ITSM.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Sales' ;
    rdfs:comment 'SSOT for commercial sales activities — leads, opportunities, quotes, contracts, channel performance, and dealer/agent management. Supports B2C retail, B2B enterprise, and MVNO wholesale sales pipelines managed via Salesforce CRM opportunity and contract modules.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'SSOT for regulatory and legal compliance obligations — FCC/NTIA/Ofcom/BEREC regulatory filings, lawful intercept (CALEA) records, data privacy consents (GDPR/CCPA), spectrum license compliance, MNP regulatory records, CPNI protection, universal service fund contributions, and ISO/IEC 27001 audit trails.' .

ind:Enterprise rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Telecommunication ;
    rdfs:label 'Enterprise' ;
    rdfs:comment 'SSOT for enterprise/B2B customer segment management — corporate accounts, government contracts, managed services, SD-WAN/MPLS dedicated solutions, unified communications, IoT solutions, enterprise SLAs, enterprise-specific billing, and account management distinct from consumer services.' .

# --- Data Product Classes (Tables) ---
ind:BillingAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Account' ;
    rdfs:comment 'Master record for a customer\'s billing account serving as the financial anchor for all monetary transactions. Captures billing cycle assignment, payment terms, credit class, bill delivery preferences (paper/eBill/app), currency, tax exemption status, dunning profile rules, account-level credit limit, auto-pay configuration, and account status (active, suspended, closed). Links subscriber identity to charges, invoices, payments, and collections. One customer may have multiple billing accounts (split billing). Sourced from Amdocs Revenue Management.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Periodic billing document issued to a customer summarizing all charges, credits, taxes, and fees for a billing cycle. Captures invoice number, bill date, due date, total amount due, previous balance, payments received, current charges, tax breakdown, bill format, delivery channel, and invoice status (draft, issued, paid, disputed, written-off). SSOT for all customer-facing billing statements. Sourced from Amdocs Revenue Management.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual charge or credit line item on a customer invoice. Captures service type, charge description, rated quantity, unit rate, charge amount, tax code, tax amount, discount applied, charge period start/end, and originating CDR or event reference. Enables itemized bill presentation and dispute resolution at the line level. Sourced from Amdocs Revenue Management rating engine.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Record of a financial payment received from or applied to a customer billing account. Captures payment date, amount, payment method (credit card, direct debit, bank transfer, cash, voucher), payment channel (IVR, web, agent, auto-pay), authorization code, transaction reference, applied invoice references, and payment status (pending, cleared, reversed, failed). SSOT for all inbound monetary receipts. Sourced from Amdocs Collections module.' .

ind:RatedEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rated Event' ;
    rdfs:comment 'Processed and priced usage event produced by the real-time or batch rating engine from raw CDRs, IPDRs, or partner usage feeds. Captures event type (voice, SMS, data, roaming, content, IoT), originating network event reference, subscriber MSISDN/IMSI, serving network (home/visited PLMN for roaming), service identifier, rated volume/duration, applied rate plan and tier, charge amount, discount amount, tax amount, rating timestamp, and rating status (rated, re-rated, disputed, written-off). Supports both domestic and roaming usage with inter-operator settlement attributes for visited network events. Bridges raw usage (CDR domain) and financial charges on invoices. Sourced from Amdocs Rating engine and Comverse ONE real-time rating.' .

ind:BillingCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Charge' ;
    rdfs:comment 'Individual monetary charge applied to a billing account outside of usage rating — including recurring monthly fees, one-time activation fees, equipment charges, late payment fees, and manually applied charges. Captures charge type, charge category, amount, tax class, effective date, charge period, originating product/service reference, and charge status. Distinct from rated_event (usage-based) and invoice_line (bill presentation). Sourced from Amdocs Revenue Management.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Credit or debit adjustment applied to a billing account, serving as SSOT for all account balance corrections including internal adjustments and customer-facing credit note documents. Captures adjustment type (credit/debit), document type (internal adjustment or customer-facing credit note), reason code, amount, tax impact, tax reversal amount, credit note number and issue date (when document type is credit note), approving agent, approval date, reference dispute or ticket ID, reference invoice, credited amount breakdown, and adjustment status (pending, approved, applied, reversed, expired). Covers goodwill credits, SLA breach compensation, dispute resolutions, overbilling corrections, returned equipment credits, and service outage compensation. When document type is credit note, serves as the formal financial document issued to the customer. Sourced from Amdocs Revenue Management adjustments module.' .

ind:BillingDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Dispute' ;
    rdfs:comment 'Formal record of a customer-initiated billing dispute against a charge, invoice, or rated event. Captures dispute date, disputed amount, dispute reason, supporting evidence references, assigned resolution agent, resolution date, resolution outcome (upheld, partially upheld, rejected), credit issued, and dispute status lifecycle (open, under review, resolved, escalated). Enables dispute management workflow and regulatory compliance tracking.' .

ind:PrepaidBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Prepaid Balance' ;
    rdfs:comment 'Real-time prepaid account balance record for a subscriber. Captures main monetary balance, dedicated balance buckets (voice minutes, SMS units, data MB/GB, content credits), per-bucket expiry dates, last recharge date/amount/channel, low-balance threshold for notifications, auto-recharge configuration, balance reservation for active sessions, and balance status (active, expired, frozen, migrated-to-postpaid). SSOT for prepaid monetary and unit balances supporting real-time authorization, balance inquiries, and recharge application. Sourced from Comverse ONE Balance Management.' .

ind:Recharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Recharge' ;
    rdfs:comment 'Transactional record of a prepaid top-up or recharge event applied to a subscriber\'s prepaid balance. Captures recharge date and time, recharge amount, recharge channel (voucher, online, agent, USSD, bank transfer), voucher serial number, promotion applied, bonus credited, balance before and after recharge, and transaction status. Sourced from Comverse ONE real-time rating and balance management.' .

ind:RatePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rate Plan' ;
    rdfs:comment 'Master definition of a pricing rate plan used by the rating engine to price usage events and recurring charges. Captures rate plan code, name, applicable service type (voice, data, SMS, roaming, IoT), rate tiers and step thresholds, unit of measure, included allowances and fair-use caps, overage rates, time-of-day and day-of-week modifiers, effective date range, currency, and applicable market segment (consumer, SMB, enterprise, wholesale). Distinct from the commercial product catalog (product domain) — this is the financial pricing engine configuration that translates catalog offers into monetary amounts. Sourced from Amdocs Rating engine.' .

ind:CreditNote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Note' ;
    rdfs:comment 'Formal financial document issued to a customer to credit their account for overbilling, service outages, returned equipment, or dispute resolutions. Captures credit note number, issue date, credited amount, tax reversal amount, reason code, reference invoice, reference dispute or adjustment, and credit note status (issued, applied, expired). Distinct from adjustment (internal) — credit note is a customer-facing financial document.' .

ind:CarrierAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Carrier Agreement' ;
    rdfs:comment 'Master record of bilateral or multilateral commercial agreements between Telecommunication and domestic/international operators covering roaming, wholesale, and MVNO relationships. Captures agreement type (IOT, CAMEL, LTE, 5G NR, MVNO hosting, national roaming, wholesale broadband, capacity resale), counterparty carrier reference, effective dates, covered services (voice, SMS, data, VoLTE, VoNR), discount structures, TAP file exchange obligations, NRTRDE requirements, minimum volume commitments and true-up terms, revenue share terms, SLA references, and agreement status. SSOT for all inter-operator commercial relationship governance.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master registry of all domestic and international carriers, transit operators, MVNOs, and wholesale partners with whom Telecommunication has interconnect, roaming, or settlement relationships. Captures carrier code (TADIG, MCCMNC, carrier ID), carrier name, country, carrier type (MNO, MVNO, transit, IXC, LEC, ISP), regulatory identifiers, NOC contact details, clearinghouse affiliations, and operational status. Central reference entity for all interconnect domain relationships — every agreement, invoice, TAP file, and traffic record references this registry.' .

ind:IotTariff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Iot Tariff' ;
    rdfs:comment 'Inter-Operator Tariff (IOT) rate table defining the wholesale rates charged between operators for roaming voice, SMS, and data services. Captures tariff version, effective period, service type, destination zone, IOT rate, currency, TAP decimal places, and GSMA rate group. Used for TAP file rating and settlement invoice generation. SSOT for IOT pricing.' .

ind:TapFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Tap File' ;
    rdfs:comment 'Transferred Account Procedure (TAP) file header and control record representing a batch of roaming CDRs exchanged between operators via the TAP3 protocol. Captures TAP file sequence number, sender/recipient TADIG codes, file creation timestamp, TAP version, total records, total charge amount, currency, file status (created, sent, acknowledged, rejected, disputed, resubmitted), clearinghouse reference, submission/receipt timestamps, validation error summary, processing outcome, and reconciliation status against clearinghouse statements. SSOT for TAP batch lifecycle management including clearinghouse exchange tracking and error handling.' .

ind:TapRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Tap Record' ;
    rdfs:comment 'Individual roaming usage record (CDR) within a TAP3 file, representing a single billable roaming event (MOC, MTC, GPRS, SMS-MO, SMS-MT) for a visiting subscriber. Captures TAP record sequence, call type, IMSI, MSISDN, visited network TADIG, home network TADIG, service start timestamp, duration/volume, charged amount, IOT rate applied, and record status. Line-item detail supporting TAP file settlement.' .

ind:NrtrdeRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Nrtrde Record' ;
    rdfs:comment 'Near Real-Time Roaming Data Exchange (NRTRDE) event record providing early visibility into roaming usage within 4 hours of service delivery per GSMA BA.40 standard. Captures NRTRDE sequence, IMSI, MSISDN, visited TADIG, home TADIG, service type (voice, SMS, data), usage timestamp, volume/duration, estimated charge, high-usage indicator, and transmission latency. Used by interconnect operations for early revenue assurance on inbound/outbound roaming traffic and for triggering fraud alerts to the assurance domain when thresholds are breached. SSOT for pre-TAP roaming visibility.' .

ind:PeeringArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Peering Arrangement' ;
    rdfs:comment 'Master record of IP peering and voice interconnect peering arrangements with other carriers, ISPs, and content delivery networks. Captures peering type (public IXP, private PNI, settlement-free, paid, partial), peering point location (IXP name, POP, data center), agreed traffic ratios and balance thresholds, bandwidth commitments, BGP session parameters, effective/expiry dates, SLA references, and arrangement status. Distinct from carrier_agreement — peering arrangements are technical/operational agreements governing traffic exchange mechanics, often managed by network operations separately from commercial roaming/wholesale contracts.' .

ind:SettlementInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Settlement Invoice' ;
    rdfs:comment 'Financial settlement invoice raised between Telecommunication and an interconnect carrier for a billing period, covering roaming (TAP), transit, termination, and origination charges. Captures invoice number, billing period, carrier reference, invoice type (payable/receivable), gross amount, disputed amount, net payable, currency, due date, and payment status. SSOT for inter-carrier financial settlement documents.' .

ind:SettlementInvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Settlement Invoice Line' ;
    rdfs:comment 'Line-item detail of a settlement invoice, breaking down charges by service type, traffic category, or TAP file reference. Captures line sequence, service category (voice termination, SMS, data roaming, transit), traffic volume, unit rate, gross charge, discount applied, tax amount, and net charge. Enables granular reconciliation of inter-carrier settlement invoices.' .

ind:SettlementDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Settlement Dispute' ;
    rdfs:comment 'Record of a formal dispute raised against a settlement invoice or TAP file charge between Telecommunication and a carrier. Captures dispute reference, disputed invoice or TAP file, dispute type (rate error, volume discrepancy, duplicate record, missing record), disputed amount, supporting evidence reference, dispute status (open, under review, resolved, escalated), resolution amount, and resolution date.' .

ind:Rate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Wholesale interconnect termination and origination rate schedule defining per-minute or per-event charges for domestic and international voice, SMS, and data traffic exchanged at interconnect points. Captures rate type (termination, origination, transit), destination prefix/number range, peak/off-peak/weekend rate tiers, effective/expiry dates, currency, regulatory reference (FCC access charges, Ofcom FAMR, EU Roam-Like-At-Home caps), and rate status. Distinct from IOT tariffs which cover roaming wholesale rates — this product covers domestic interconnect and international termination rates governed by regulatory frameworks.' .

ind:MnpTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Mnp Transaction' ;
    rdfs:comment 'Mobile Number Portability (MNP) transaction record capturing each port-in or port-out event for a subscriber number between Telecommunication and another operator. Captures MSISDN, donor network TADIG/carrier reference, recipient network reference, port type (port-in/port-out), request timestamp, porting window, completion timestamp, MNP status (pending, validated, completed, rejected, cancelled), rejection reason, regulatory reference number, and routing number update status. SSOT for inter-operator number portability execution within the interconnect domain.' .

ind:Poi rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interconnect ;
    rdfs:label 'Poi' ;
    rdfs:comment 'Point of Interconnect (POI) master record defining the physical or logical handoff points between Telecommunication\'s network and a carrier\'s network. Captures POI ID, POI name, location (city, exchange, data center), interconnect type (TDM, IP/SIP, MPLS), connected carrier reference, trunk group reference, regulatory designation, capacity, and operational status. SSOT for interconnect topology.' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core master record for every end-to-end order in the telecommunications lifecycle — new activations, upgrades, downgrades, disconnections, MNP port-in/port-out, and change-of-service requests. Sourced from Oracle Communications Order and Service Management (OSM). Captures order type, order channel, priority, customer reference, account reference, submitted timestamp, promised completion date, current order state, fallout reason, orchestration workflow instance ID, workflow template, decomposition strategy, SLA type (regulatory, commercial, enterprise), SLA target completion hours, warning threshold hours, breach threshold hours, SLA measurement start/end events, current SLA status (ON_TRACK, AT_RISK, BREACHED), and breach timestamp. This is the SSOT for order identity, lifecycle state, orchestration context, and SLA commitment within the order domain. All SLA monitoring, jeopardy detection, and regulatory compliance measurement derives from this master record\'s SLA attributes.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Line' ;
    rdfs:comment 'Individual line item within a fulfillment order representing a single product or service action (add, remove, modify, suspend, resume). Each line carries the commercial product reference, requested action code, quantity, requested service start date, line-level status, and decomposition state. Supports multi-line orders where a customer simultaneously activates a mobile plan, adds a broadband service, and ports a number in a single order transaction.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Immutable audit trail of every state transition and post-submission amendment for a fulfillment order throughout its lifecycle — from SUBMITTED through VALIDATED, IN_PROGRESS, PENDING_PROVISIONING, COMPLETED, CANCELLED, or FALLOUT. For state transitions: records previous state, new state, transition timestamp, triggering actor (system or user), and reason code. For amendments: records amendment type (appointment change, product selection change, address change, service configuration change), original value, new value, amendment request timestamp, amendment status (PENDING, APPROVED, REJECTED, APPLIED), approving agent reference, impact assessment (SLA reset flag, cost delta), and override justification. This is the SSOT for all order change history — both system-driven state transitions and customer/agent-initiated amendments. Essential for SLA measurement, fallout root-cause analysis, dispute resolution, and regulatory audit trails required by FCC and BEREC.' .

ind:Task rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Task' ;
    rdfs:comment 'Granular decomposed work task generated by OSM order orchestration engine from a specific order line during order decomposition. Represents both the decomposition mapping (tracing commercial order line to lower-level service/resource/network orders) and the atomic fulfillment execution step (HLR/HSS provisioning, IP address assignment, CPE dispatch, GPON ONT activation, number portability submission). Captures parent order line reference, decomposition rule applied, child system target, child order type (service_order, resource_order, network_order), task type, execution sequence, dependency chain, start time, completion time, retry count, task-level status, synchronisation status with downstream systems, creation timestamp, and fallout detail. Provides full decomposition traceability from commercial order line through orchestration logic to network provisioning action — serving as the SSOT for both order decomposition mapping and task execution within this domain.' .

ind:Fallout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fallout' ;
    rdfs:comment 'Operational record capturing every order that has entered a FALLOUT or ERROR state during orchestration. Stores the fallout category (validation failure, provisioning timeout, inventory shortage, downstream system error), affected order and task references, fallout detection timestamp, assigned resolution team, resolution action taken, and re-submission outcome. Drives NOC and BSS operations center workqueues for manual intervention and SLA breach prevention.' .

ind:ProvisioningRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Provisioning Request' ;
    rdfs:comment 'Downstream provisioning instruction record generated by OSM and dispatched to OSS systems (HLR/HSS, UDM, IMS, GPON OLT, IP address management, DSLAM) to activate, modify, or deactivate a service on the network. Captures target system identifier, provisioning action, service parameters payload, dispatch timestamp, acknowledgement timestamp, provisioning outcome (SUCCESS, FAILURE, TIMEOUT), and retry history. Bridges the order domain to the service and network domains.' .

ind:ServiceQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Service Qualification' ;
    rdfs:comment 'Pre-order service qualification check record determining whether a customer address or network location is eligible for a requested service (FTTH, GPON, LTE, 5G NR, ADSL, VDSL). Captures qualification request timestamp, customer address reference, requested service type, qualification outcome (ELIGIBLE, NOT_ELIGIBLE, ELIGIBLE_WITH_CONSTRAINTS), available technology options, maximum achievable bandwidth, estimated installation lead time, and network node reference. Drives product offer eligibility in the sales and ordering flow.' .

ind:Appointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Appointment' ;
    rdfs:comment 'Field technician installation or service appointment record associated with a fulfillment order requiring on-site work — FTTH/GPON installation, CPE swap, ONT replacement, or enterprise circuit commissioning. Captures appointment type, scheduled date and time window, customer address, assigned technician reference (linked to workforce domain), appointment status (SCHEDULED, CONFIRMED, COMPLETED, MISSED, RESCHEDULED), customer confirmation flag, and completion notes. Integrates with Granite Telecommunications WFM for dispatch.' .

ind:Sla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Sla' ;
    rdfs:comment 'SLA commitment record attached to a fulfillment order or order type, defining the contracted or regulatory completion timeframe. Captures SLA type (regulatory, commercial, enterprise), target completion hours, warning threshold hours, breach threshold hours, measurement start event, measurement end event, current SLA status (ON_TRACK, AT_RISK, BREACHED), breach timestamp if applicable, and applicable regulatory body (FCC, Ofcom, BEREC). Enables real-time SLA monitoring and regulatory compliance reporting.' .

ind:Notification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Notification' ;
    rdfs:comment 'Outbound notification record dispatched to customers or internal stakeholders at key order lifecycle milestones — order confirmation, appointment reminder, provisioning completion, port-in execution, and order cancellation. Captures notification type, delivery channel (SMS, email, push, IVR), recipient reference, dispatch timestamp, delivery status (SENT, DELIVERED, FAILED, BOUNCED), template version, and language code. Supports regulatory notification obligations for MNP and service disconnection.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Record of every post-submission modification to a fulfillment order — customer-requested changes to appointment date, product selection, delivery address, or service configuration before order completion. Captures amendment type, amendment request timestamp, original value, new value, amendment status (PENDING, APPROVED, REJECTED, APPLIED), approving agent reference, and impact assessment (SLA reset flag, cost delta). Maintains a complete change history for dispute resolution and audit.' .

ind:OrderCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Charge' ;
    rdfs:comment 'One-time or recurring charge record generated at order completion and passed to the billing domain for invoicing — activation fees, installation charges, CPE purchase or rental fees, early termination fees, and MNP administrative charges. Captures charge type, charge amount, currency, tax category, charge trigger event, billing account reference, charge status (PENDING, BILLED, WAIVED, REVERSED), and waiver reason if applicable. Represents the commercial financial output of the order fulfillment process.' .

ind:CustomerAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Account' ;
    rdfs:comment 'Master record for every customer account in the telecommunications business — B2C consumer, B2B enterprise, and wholesale client. Stores account number, account type (prepaid/postpaid/wholesale), account status (active/suspended/terminated), credit class, credit limit, language preference, preferred contact method, acquisition channel, acquisition date, market segment, account tier, billing cycle, currency, tax exemption flag, regulatory consent flags (GDPR/CCPA), lifecycle timestamps, and full account status transition history (previous status, new status, transition reason, effective date, initiated by). This is the SSOT for subscriber identity, account lifecycle audit trail, and is the anchor entity for the entire customer domain.' .

ind:Subscriber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Subscriber' ;
    rdfs:comment 'Individual subscriber identity record representing a single SIM/line/service user within an account. Captures subscriber number (MSISDN), subscriber type (primary/secondary/add-on), subscriber status, date of birth, nationality, ID document type and number, biometric verification flag, eSIM eligibility, VoLTE capability, roaming profile, preferred language, parental control flag, and association to the parent account. Distinct from account (which is the billing/commercial entity) — a single account may have multiple subscribers. SSOT for individual subscriber identity. Sourced from HSS/UDM and provisioning systems.' .

ind:CustomerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Contact' ;
    rdfs:comment 'Contact person record associated with a customer account — primary account holder, authorized representative, technical contact, billing contact, or emergency contact. Stores full name, title, job title (for B2B), email address, mobile number, alternate phone, preferred contact channel, contact role, do-not-contact flags, marketing opt-in/opt-out, communication language, and verification status. Supports multiple contacts per account with role-based differentiation. SSOT for customer contact identity within the customer domain.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing address records associated with customer accounts and subscribers. Captures address type (service address, billing address, installation address, correspondence address), street line 1 and 2, city, state/province, postal code, country, geocoordinates (latitude/longitude), address validation status, address validation source, GPON/FTTH serviceability flag, broadband coverage tier, and last verified date. Supports multiple addresses per account. Critical for service provisioning, field dispatch, and coverage eligibility checks.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Record of every customer interaction across all touchpoints — inbound/outbound calls, chat sessions, email exchanges, retail store visits, self-service portal sessions, and social media contacts. Stores interaction type, channel (voice/chat/email/store/app/social), direction (inbound/outbound), interaction date and time, duration, agent ID, queue name, topic category, sub-topic, resolution status, FCR flag (First Call Resolution), CSAT score captured at interaction, NPS survey triggered flag, and case reference if escalated. SSOT for customer interaction history across all channels.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Case' ;
    rdfs:comment 'Customer support case record tracking issues, complaints, service requests, retention interventions, and save-desk activities through their full lifecycle. Stores case number, case type (complaint/billing dispute/technical fault/MNP request/general inquiry/save offer/win-back/contract renewal/loyalty reward), priority (P1-P4), status (open/in-progress/pending-customer/resolved/closed), subject, description, resolution notes, SLA breach flag, SLA target date, actual resolution date, escalation flag, escalation level, owning team, linked interaction references. For retention cases: trigger reason (churn intent/contract expiry/competitor offer/high risk score), offer code, offer value, offer accepted flag, outcome (retained/churned/pending), retention cost, contract extension months, and save desk queue. SSOT for all customer service workflow including proactive/reactive retention activity tracking. Distinct from network fault tickets (owned by assurance domain).' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Unified customer consent, privacy preference, and communication preference record capturing all regulatory consent decisions, operational contact governance, and channel routing preferences. Stores consent/preference type (marketing/data processing/third-party sharing/lawful intercept/CPNI/channel opt-in/contact time window/language preference/paper bill/e-bill), status (granted/withdrawn/pending), channel (web/app/store/IVR/paper), effective date, withdrawal date, consent version (policy version), jurisdiction (FCC/GDPR/CCPA/Ofcom), data category covered, retention period, preferred contact channel, preferred contact time window, do-not-disturb schedule, marketing opt-in flags per channel, service notification opt-in flags, and proof reference. SSOT for all customer contact governance — regulatory compliance, privacy preferences, and operational communication routing. Required for FCC, GDPR, CCPA, and Ofcom regulatory obligations.' .

ind:DeviceRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Device Registration' ;
    rdfs:comment 'Record of customer-owned and financed devices registered against a subscriber or account — handsets, tablets, CPE (routers/modems), ONT, and IoT devices. Stores device type, make, model, IMEI/serial number, registration date, device status (active/lost/stolen/replaced), BYOD flag, device financing flag (linked to installment plan), insurance enrollment flag, warranty expiry date, OS version, network capability (4G/5G/VoLTE/WiFi6), SIM slot type, and eSIM profile reference. Distinct from network inventory (operator-owned infrastructure) and inventory domain (stock/warehouse tracking) — this is the customer-premises device registry. Enables IMEI-based fraud detection, stolen device blocking (CEIR/EIR integration), device upgrade targeting, and insurance claim validation.' .

ind:CatalogItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Catalog Item' ;
    rdfs:comment 'Master record for every commercial offering in the Netcracker Product Catalog — mobile plans, broadband packages, IPTV/OTT bundles, VoIP offerings, enterprise SD-WAN/MPLS products, and devices. Captures canonical product definition including product code, category, sub-category, technology type, market segment (B2C, B2B, wholesale, MVNO), product family, launch date, end-of-sale date, and lifecycle status. Includes catalog versioning metadata (version number, approval status, effective date) and lifecycle event audit trail. SSOT for all product definitions.' .

ind:Offering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Offering' ;
    rdfs:comment 'A commercially sellable product offering combining one or more catalog items into a customer-facing package. Represents the marketable unit in BSS/CRM — includes offering name/code, channel availability (retail, online, telesales, dealer, B2B direct, MVNO reseller), geographic availability footprint, eligibility rules summary, contract term options (duration, ETF structure, auto-renewal), effective dates, and offering status. Distinct from catalog_item (technical specification) — an offering is the commercial wrapper presented to customers through specific channels in specific geographies.' .

ind:Bundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle' ;
    rdfs:comment 'Defines composite product bundles that group multiple offerings or catalog items into a single commercial package (e.g., Triple Play: broadband + IPTV + VoIP, or Quad Play: mobile + broadband + IPTV + fixed voice). Captures bundle code, bundle type (fixed, flexible, customizable), minimum/maximum component count, discount applicability, bundle pricing model, and lifecycle dates. Manages the structural definition of bundled products separate from individual component pricing.' .

ind:PricePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Price Plan' ;
    rdfs:comment 'Defines the base pricing model for a catalog item or offering — including recurring charges (MRC), one-time charges (OTC), and usage-based charges. Captures charge type, billing frequency, currency, tax category, price points, tiered/volume pricing structures, and effective date ranges. Supports flat rate, tiered, volume-based, and event-based pricing models. References price_alteration records for discount/surcharge modifications. SSOT for base product pricing definitions and charge structures.' .

ind:PromoOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Promo Offer' ;
    rdfs:comment 'Defines time-limited promotional offers applied to catalog items or bundles — including introductory pricing, free trial periods, bonus data allowances, device subsidies, and retention offers. Captures promo code, promo type (acquisition, retention, win-back, seasonal), discount structure, eligibility criteria (new/existing customer, segment, channel), promo start/end dates, maximum redemption count, and campaign association. Supports both B2C and B2B promotional strategies.' .

ind:Spec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Spec' ;
    rdfs:comment 'Technical specification record for a catalog item defining detailed service characteristics, network requirements, and capability parameters as extensible name-value pairs. Covers all product types: mobile (data allowance, voice minutes, SMS, roaming entitlements, QoS), broadband (speed tiers, technology, latency SLA), IPTV (channels, streams, DVR), SD-WAN/MPLS (bandwidth, SLA tier), and roaming profiles (zone configurations, fair-use limits). Includes usage allowance definitions (allowance type, quantity, reset frequency, overage policy, throttle speed). Aligned with TM Forum SID specification pattern. SSOT for all technical product characteristics.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Defines the eligibility conditions that govern which customers or segments can purchase a specific offering or promotional offer. Captures rule type (customer segment, account type, geographic area, existing product, credit class, contract tenure), rule operator (equals, in, greater_than), rule value, and logical combination (AND/OR). Supports complex eligibility logic for B2C, B2B, MVNO, and wholesale segments. Used by BSS/CRM systems during order capture to validate product eligibility.' .

ind:DeviceModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Device Model' ;
    rdfs:comment 'Master record for handsets, CPE (Customer Premises Equipment), ONT (Optical Network Terminal), routers, set-top boxes, and other devices offered through the product catalog. Captures device model name, manufacturer, device category (smartphone, tablet, CPE, ONT, STB, router), technology support (4G/LTE, 5G NR, Wi-Fi 6, GPON), eSIM capability, operating system, storage/RAM specs, color variants, IMEI range, and device status (available, end-of-life). SSOT for device catalog definitions.' .

ind:Addon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Addon' ;
    rdfs:comment 'Defines optional add-on products that can be attached to a base offering — including data top-ups, international calling packs, premium channel subscriptions, cloud storage upgrades, static IP add-ons, and security packages. Captures add-on code, add-on category, compatible base offerings, pricing model, maximum quantity per subscription, auto-renewal flag, and validity period. Supports both one-time and recurring add-ons across mobile, broadband, and enterprise product lines.' .

ind:Technician rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Technician' ;
    rdfs:comment 'Master record for field and technical workforce personnel with periodic performance evaluation history. Identity and employment: technician ID, name, employment status, home depot/zone assignment, employment type (full-time, contractor, MVNO partner), contact details, hire/termination dates, workforce classification (RAN, FTTH, GPON, CPE, splicing). Performance history: quarterly/annual review records with KPIs (first-time fix rate, MTTR, work orders/day, SLA compliance, CSAT, safety compliance, attendance), review period, reviewer (supervisor), overall rating, individual KPI scores, development goals, acknowledgement status, and improvement plan references. SSOT for individual workforce identity and performance within the workforce domain. Sourced from Granite Telecommunications WFM and SAP S/4HANA HCM.' .

ind:Skill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Skill' ;
    rdfs:comment 'SSOT for the technical skill taxonomy and individual technician skill proficiency holdings. Catalog section: skill code, name, category (RAN, transport, access, CPE, safety), proficiency level definitions (trainee/competent/expert), prerequisite skills, and validity period — e.g., fiber splicing, 5G NR RAN commissioning, GPON/OLT configuration, VoLTE IMS troubleshooting. Technician-skill section: which skills each technician holds, current proficiency level, assessment date, assessor, expiry date, recertification requirements, and active status. Enables skill-based dispatch matching in Granite WFM — ensures only appropriately skilled technicians are assigned to specialized work orders (e.g., only fiber-splicing-expert for trunk splice jobs). Sourced from Granite WFM skills module.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Certification' ;
    rdfs:comment 'SSOT for workforce qualifications, certifications, technician certification holdings, and training activity records. (1) Certification catalog: formal certifications and regulatory qualifications — OSHA safety, BICSI RCDD, Ericsson RAN certified, Nokia NetAct operator, FCC General Radiotelephone Operator License, NATE tower climbing, confined space entry — with issuing body, validity duration, renewal requirements, and regulatory mandate flag. (2) Technician-certification holdings: certificate number, issue date, expiry date, issuing authority, renewal status, compliance flag, and technician reference. (3) Training activities: course completions, delivery method (classroom/e-learning/OJT/vendor-led), provider, completion date, score/grade, pass/fail, CPD hours earned, and link to resulting certification. Supports FCC/OSHA mandatory compliance reporting, technician upskilling tracking for 5G NR and FTTH rollouts, and ensures only qualified technicians are dispatched to regulated work types. Sourced from Granite WFM certification module.' .

ind:Depot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Depot' ;
    rdfs:comment 'Master record for field workforce depots, staging yards, and dispatch centers from which technicians and vehicles are deployed. Captures depot name, full address, geographic coordinates (lat/long), service zone coverage polygon, depot type (central warehouse, satellite yard, NOC-attached dispatch center), capacity metrics (vehicle bays, technician headcount, tool storage), operating hours, weekend/holiday availability, and assigned regional manager. Primary organizational unit for route optimization start/end points and technician home-base assignment in Granite WFM. Links to service_territory for zone coverage mapping.' .

ind:TechnicianSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Technician Schedule' ;
    rdfs:comment 'SSOT for all technician time allocation, availability, and shift management. Encompasses: (1) Shift templates — standard shift patterns (day/evening/on-call/weekend rotation) with start/end times, duration, break rules, overtime eligibility, and applicable days. (2) Individual shift assignments — generated from templates, capturing shift type, assigned territory, depot, status (draft/published/confirmed/cancelled), and schedule change audit trail. (3) Overtime records — planned overtime (pre-approved for outage response, rollout surge) and emergency overtime (unplanned NOC callout), with hours, reason code, approving manager, pay classification (straight-time/time-and-a-half/double-time), and payroll period. (4) Leave/absence blocks — annual leave, sick leave, FMLA, training leave, emergency absence, with request/approval workflow, coverage plan (replacement technician), and impact on scheduled work orders. Includes planned vs. actual hours and payroll period references. Feeds dispatch optimization (Granite WFM) and SAP S/4HANA payroll.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core transactional entity representing field work assignments dispatched to technicians, with activity-level execution detail and materials consumed. Header: work order number, type (install/repair/maintenance/survey), priority (P1–P4), customer reference, network element reference, site address, scheduled window, assigned technician, dispatch/arrival/completion times, resolution code, SLA target and breach flag, escalation flag. Activity lines: individual tasks performed (site survey, cable pull, fiber splice, ONT power-up, signal test, CPE config, safety check, customer sign-off) with sequence, activity type, technician performing, start/end timestamps, outcome (pass/fail/deferred), and notes. Material lines: parts consumed (fiber cable, connectors, ONT units, CPE devices, splice trays, patch panels) with material code, quantity planned vs. used, unit of measure, serial number (for serialized assets), source depot, and cost. SSOT for field work execution, MTTR analysis, first-time-fix tracking, and inventory consumption. Sourced from Oracle Communications OSM and Granite WFM.' .

ind:DispatchEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Dispatch Event' ;
    rdfs:comment 'Transactional record capturing each dispatch action in the field workforce lifecycle — initial dispatch, reassignment, escalation, cancellation, and return-to-depot events. Captures dispatch timestamp, dispatching supervisor/system, technician assigned, prior technician (for reassignments), dispatch channel (mobile app, radio, manual), reason code, and GPS coordinates at dispatch time. Supports NOC dispatch audit trails and SLA breach root-cause analysis.' .

ind:RoutePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Route Plan' ;
    rdfs:comment 'Transactional record of optimized daily route plans generated for technicians by Granite WFM route optimization engine, including ordered stop-level detail. Captures plan date, technician, depot start/end, and for each stop: sequence number, work order reference, site address, GPS coordinates, estimated/actual arrival and departure times, stop status (pending/arrived/completed/skipped), and inter-stop travel time. At plan level captures total estimated travel time, total distance (km/miles), optimization algorithm used (time-window, priority-weighted, fuel-optimized), plan status (draft/active/completed), and actual vs. planned deviation metrics. Supports OPEX reduction through fuel and time efficiency, real-time route tracking, and customer ETA updates.' .

ind:FieldVehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Field Vehicle' ;
    rdfs:comment 'Master record for field service vehicles in the telecom workforce fleet with full assignment history. Vehicle attributes: registration plate, make/model/year, vehicle type (van, bucket truck, cable-laying, fiber splicing unit), assigned depot, fuel type, load capacity, equipment fitted (aerial lift, cable drum, OTDR, fusion splicer), odometer, insurance expiry, maintenance due date, and current status. Assignment history: technician, assignment date/time, return date/time, assignment type (permanent/daily/emergency), odometer at start/end, fuel level at start/end, return condition flag, and depot. Supports fleet dispatch, utilization tracking, fuel cost allocation, vehicle maintenance scheduling, and CAPEX/OPEX asset management. Sourced from Granite WFM fleet module.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Team' ;
    rdfs:comment 'Master record for field workforce teams and crew groupings with full membership roster. Team attributes: team code, name, type (installation crew, maintenance gang, emergency response, specialized squad), lead technician, assigned depot, service territory, headcount, active status, and specialization tags (fiber splicing, 5G NR rollout, GPON activation). Membership roster: each member\'s technician reference, role within team (lead/member/trainee), assignment start/end dates, active flag, and reason for change. Supports dynamic team composition for network rollout projects and emergency response mobilization. Enables team-level dispatch, capacity planning, skill coverage queries, and performance tracking in Granite WFM.' .

ind:Element rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Element' ;
    rdfs:comment 'Unified master record for every physical and logical network element in the operator\'s infrastructure — the Single Source of Truth for all managed network nodes. Covers RAN base stations (eNodeB, gNodeB), core network nodes (MME, AMF, SMF, UPF, IMS P-CSCF/S-CSCF/I-CSCF/HSS), transport nodes (MPLS routers, OTN switches), access nodes (DSLAM, BNG, BRAS, OLT), CPE-side ONT/ONU devices, and virtualized network functions (VNFs: vMME, vSGW, vPGW, vBNG, vFirewall). Tracks element type, subtype, vendor, model, hardware/software version, operational state, administrative state, lifecycle state, geographic location, POP site assignment, rack/slot position, management IP, and NFV-specific attributes (vCPU, vRAM, VNFD, MANO orchestrator) where applicable. Sourced from Nokia NetAct, Ericsson Network Manager, and MANO platforms. This is the foundational master entity — all other network products reference elements via FK.' .

ind:Topology rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Topology' ;
    rdfs:comment 'Represents the logical and physical connectivity graph between network elements — links, segments, and paths that form the network topology. Captures link type (fiber, microwave, copper, Ethernet, MPLS LSP), link capacity (bandwidth in Mbps/Gbps), link distance, latency, protection scheme (1+1, ring, mesh), operational state, and the two endpoint network elements. Supports topology visualization, path computation, and capacity planning for RAN, transport, and core network layers.' .

ind:RanCell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Ran Cell' ;
    rdfs:comment 'Master record for every Radio Access Network (RAN) cell — individual radio cells served by base stations across 2G, 3G, 4G LTE, and 5G NR technologies. Captures cell ID (CGI/NCI), cell name, technology generation (GSM/UMTS/LTE/NR), frequency band, channel number (ARFCN/EARFCN/NR-ARFCN), bandwidth, azimuth, tilt (mechanical and electrical), antenna height, transmit power, cell range, handover parameters, and operational state. Critical for RAN planning, optimization, and coverage management.' .

ind:TransmissionLink rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Transmission Link' ;
    rdfs:comment 'Master record for physical transmission links in the transport network — fiber spans, microwave hops, and leased line circuits connecting network elements. Captures link identifier, link type (fiber/microwave/copper/leased), vendor, capacity (STM-N, OTU-k, Ethernet rate), route distance, fiber type (SMF/MMF), number of fiber pairs, protection type, commissioning date, and operational state. Distinct from logical topology — this represents the physical medium layer (Layer 0/1) managed via NMS/EMS.' .

ind:Capacity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Tracks capacity metrics and utilization thresholds for network elements, links, and cells — the operational capacity management record. Captures resource type (RAN cell, transmission link, MPLS tunnel, BNG port), total capacity (bandwidth/channels/ports), committed capacity, peak utilization percentage, average utilization percentage, congestion threshold, measurement period, and capacity status (under-utilized/normal/congested/critical). Feeds network planning and capacity augmentation decisions. Distinct from performance KPIs — this is the capacity planning master record.' .

ind:ElementConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Element Config' ;
    rdfs:comment 'Configuration management record for network elements — stores both the active configuration baseline AND the transactional history of all configuration changes. Baseline section: configuration version, type (running/startup/candidate), structured parameters (neighbor lists, handover thresholds, QoS policies, routing tables), compliance status. Change history section: change request reference, change type (planned/emergency/automated), parameters modified (before/after values), execution timestamp, operator/automation ID, outcome (success/partial/failed/rolled-back), rollback reference. Aligned with Nokia NetAct Configuration Management and Ericsson Network Manager. Supports configuration audit, drift detection, rollback, change management compliance, and root cause analysis.' .

ind:ConfigChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Config Change' ;
    rdfs:comment 'Transactional record of every configuration change applied to a network element — the configuration change history log aligned with Nokia NetAct and Ericsson Network Manager change management. Captures change request reference, change type (planned/emergency/automated), change description, parameters modified (before/after values), execution timestamp, executed by (operator ID/automation system), change outcome (success/partial/failed/rolled-back), and rollback reference. Supports change management, compliance auditing, and root cause analysis for network incidents.' .

ind:PerformanceCounter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Performance Counter' ;
    rdfs:comment 'Stores periodic network performance measurement records (PM counters) collected from network elements via Nokia NetAct Performance Management and Ericsson Network Manager — the operational performance data record. Captures measurement interval (15-min/1-hour/24-hour), KPI category (RAN: RSRP, SINR, throughput, handover success rate; Transport: packet loss, latency, jitter; Core: session establishment rate, drop rate), raw counter values, derived KPI values, threshold breach flags, and collection timestamp. Distinct from alarm/fault events — this is periodic measurement data.' .

ind:Alarm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Alarm' ;
    rdfs:comment 'Transactional record of network alarms raised by network elements — the fault management alarm record sourced from Nokia NetAct Fault Management and Ericsson Network Manager. Captures alarm ID, alarm type (equipment fault, link down, threshold exceeded, software fault), severity (critical/major/minor/warning), affected network element, affected service impact, alarm source (NMS/EMS/SNMP trap), raise timestamp, clear timestamp, alarm duration, acknowledgement status, and correlation to trouble ticket. Feeds NOC operations and SLA breach detection.' .

ind:PlannedOutage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Planned Outage' ;
    rdfs:comment 'Transactional record of planned maintenance windows and scheduled outages — the maintenance scheduling record for NOC coordination. Captures outage reference, type (maintenance/upgrade/decommission/migration/testing), affected elements and services, planned and actual start/end datetimes, outage reason, responsible team, customer notification status, SLA exclusion flag, rollback plan reference, and outcome. Supports NOC scheduling, SLA exclusion window management, change advisory board (CAB) approvals, and customer impact communication.' .

ind:QosProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Qos Profile' ;
    rdfs:comment 'Reference master for Quality of Service (QoS) profiles and traffic class definitions applied across the network — DSCP markings, traffic shaping parameters, priority queuing configurations, and bearer QoS class identifiers (QCI/5QI for LTE/5G). Captures profile name, QoS class (voice/video/data/best-effort), DSCP value, 5QI/QCI value, guaranteed bit rate (GBR), maximum bit rate (MBR), priority level, packet delay budget, packet error rate, and applicable network domain. Used by RAN, core, and transport layers for consistent end-to-end QoS enforcement.' .

ind:CpeAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cpe Asset' ;
    rdfs:comment 'Master record for Customer Premises Equipment (CPE) assets including routers, modems, set-top boxes, ONTs, and Wi-Fi gateways. Tracks device serial number, MAC address, model, firmware version, ownership type (owned/leased/BYOD), procurement date, warranty expiry, current assignment status, and physical condition. SSOT for all CPE hardware managed via Oracle OSM resource inventory.' .

ind:SimStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Sim Stock' ;
    rdfs:comment 'Master inventory record for all SIM stock units including physical SIM cards (2FF/3FF/4FF) and eSIM profiles managed on the operator\'s SM-DP+ platform. Physical SIM attributes: ICCID, IMSI range, batch number, manufacturer, form factor, warehouse location, and expiry date. eSIM profile attributes: EID (eUICC Identifier), profile ICCID, SM-DP+ profile state (downloaded/enabled/disabled/deleted), activation code, download timestamp, target device model, and profile type (operational/test/bootstrap). Common attributes: profile type (consumer/M2M/IoT), activation status (unallocated/reserved/activated/deactivated), subscriber assignment, and lifecycle timestamps. SSOT for all SIM and eSIM inventory managed per GSMA SGP.22 RSP specification via Netcracker resource inventory and Comverse ONE.' .

ind:OntAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Ont Asset' ;
    rdfs:comment 'Master record for Optical Network Terminal (ONT) hardware assets deployed at customer premises in FTTH/GPON networks. Captures ONT serial number, model, vendor, GPON port assignment, optical power levels, firmware version, installation date, service address, and operational state. Linked to OLT infrastructure and fiber plant records. Managed via Oracle OSM and Netcracker.' .

ind:OltAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Olt Asset' ;
    rdfs:comment 'Master record for Optical Line Terminal (OLT) hardware assets in GPON/FTTH central office and headend locations. Tracks OLT chassis, line card slots, PON port capacity, vendor (Nokia/Huawei/Calix), firmware version, location (POP/CO), power consumption, maximum ONT capacity, current ONT count, and operational status. SSOT for OLT infrastructure inventory.' .

ind:FiberCable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Fiber Cable' ;
    rdfs:comment 'Master record for fiber optic cable segments and conduit/duct infrastructure in the outside plant (OSP). Cable attributes: cable type (single-mode/multi-mode/ribbon), fiber count, sheath type, route length, attenuation measurements, splice point references, and strand-level capacity summary. Conduit/duct attributes: duct ID, material type, inner diameter, route segment, total length, fill ratio, associated cable IDs, installation date, and ownership (owned/leased/municipal). Common attributes: route geometry (GPS coordinates), installation date, deployment method (burial/aerial/conduit), ownership type (owned/leased/IRU/municipal), and route segment identification. SSOT for all physical fiber plant and duct infrastructure inventory supporting OSP capacity planning and fiber rollout project management.' .

ind:IpAddressPool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Ip Address Pool' ;
    rdfs:comment 'Master record for logical network resource pools and their individual assignments. Covers IP address pools (IPv4/IPv6 subnets, CGNAT ranges), VLAN/VXLAN segment pools, and individual resource assignment transactions. Pool-level attributes: CIDR block, VLAN range, encapsulation type (802.1Q/QinQ/VXLAN/EVPN), allocation policy, associated BNG/BRAS or leaf switch, service type segmentation (residential/enterprise/wholesale/management/voice), utilization tracking, and maximum capacity. Assignment-level attributes: assigned IP or VLAN, assignment type (static/dynamic/DHCP), assignment start/end timestamps, lease duration, assigned-to entity (subscriber/CPE/network node), and release reason. SSOT for all logical network resource inventory and assignment lifecycle supporting broadband provisioning, enterprise VPN, IMS voice, and wholesale services. Managed via Netcracker.' .

ind:MsisdnRange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Msisdn Range' ;
    rdfs:comment 'Master record for MSISDN (Mobile Subscriber ISDN Number) and DID (Direct Inward Dialing) number ranges and their individual number assignment transactions. Range-level attributes: start/end number, country code, NDC, range type, regulatory allocation reference, porting eligibility, and available count. Assignment-level attributes: specific number assigned, subscriber reference, assignment date, service type, porting status (MNP port-in/port-out), quarantine release date, deallocation reason, and assignment lifecycle timestamps. SSOT for all number resource inventory, assignment lifecycle, and MNP compliance per ITU-T E.164 and national MNP regulations.' .

ind:AssetLifecycleEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Asset Lifecycle Event' ;
    rdfs:comment 'Transactional record capturing all lifecycle state transitions, audit events, and inventory reconciliation activities for physical inventory assets (CPE, ONT, OLT, network equipment, fiber plant, spare parts). Event types: procurement, deployment, swap, repair, decommission, write-off, physical-audit, cycle-count, and reconciliation. Core attributes: event timestamp, previous/new asset state, triggering work order or order reference, technician, location change. For audit/reconciliation events: audit date, stocking location or asset category audited, auditor name, expected vs actual count, variance quantity, variance reason, and reconciliation action taken (write-off/adjustment/investigation). SSOT for full asset lifecycle audit trail and inventory accuracy reporting per TM Forum eTOM asset management process, SAP S/4HANA asset management, and regulatory compliance requirements.' .

ind:NetworkEquipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Network Equipment' ;
    rdfs:comment 'Master record for core, transport, and access network equipment assets and their hardware model reference catalog. Equipment instance attributes: equipment type, vendor, model, serial number, rack/slot location (FK to rack_slot_port), POP/site (FK to pop_facility), power draw, software version, operational status, and maintenance contract reference. Covers RAN base stations (eNodeB/gNodeB), BNG/BRAS, MPLS routers, SD-WAN edge nodes, IMS/HSS/UDM/PCF nodes, and DSLAM units. Equipment model catalog attributes: model name, manufacturer, equipment category (CPE/ONT/OLT/RAN/transport/core/power), technical specifications (ports, throughput, capacity), supported standards (LTE/5G NR/GPON/XGS-PON/DOCSIS 3.1), physical dimensions, power requirements, MTBF rating, end-of-sale/support/life dates, and approved vendor status. SSOT for non-OLT/ONT network equipment inventory and hardware model catalog. Managed via Ericsson Network Manager and Nokia NetAct.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record of all regulatory submissions made to governing bodies such as FCC, NTIA, Ofcom, BEREC, and ITU. Captures filing type (annual report, spectrum usage, universal service, broadband data collection), submission date, regulatory authority, filing period, status (draft, submitted, accepted, rejected, under review), filing reference number, responsible officer, and associated regulatory obligation. SSOT for all outbound regulatory compliance submissions.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master reference catalog of all regulatory obligations applicable to the telecommunications operator across all jurisdictions. Captures obligation type (spectrum license condition, CALEA mandate, GDPR/CCPA requirement, USF contribution, CPNI protection, MNP rule, net neutrality, E911, roaming, universal service, numbering plan), jurisdiction, effective date, expiry date, enforcement authority, penalty framework, compliance frequency, obligation-specific compliance attributes, and current compliance status. Includes obligation-level tracking for net neutrality traffic management practices, roaming tariff cap compliance, E911 location accuracy requirements, and USF contribution calculations. Serves as the master obligation register driving all compliance activities, calendar deadlines, and regulatory filings across all regulatory frameworks and jurisdictions.' .

ind:LawfulInterceptOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Lawful Intercept Order' ;
    rdfs:comment 'Authoritative record of lawful intercept orders received under CALEA (US), RIPA/IPA (UK), EU Data Retention Directive, and equivalent international mandates, including full delivery lifecycle. Captures court order reference, issuing authority, target identifier (MSISDN, IMSI, IP address, email), intercept type (content, metadata, both), activation/expiry dates, intercept status, handling officer, and chain-of-custody log. Includes all delivery records as line items: delivery timestamp, delivery method (secure FTP, physical media, network handoff via ETSI LI interfaces), data volume, delivery confirmation reference, receiving LEA officer, and delivery status. Strictly access-controlled as restricted data with need-to-know enforcement. SSOT for the complete lawful intercept lifecycle from order receipt through data delivery, confirmation, and closure.' .

ind:PrivacyConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Privacy Consent' ;
    rdfs:comment 'Master record of all privacy governance instruments across the telecommunications operator. Covers: (1) Individual data consents — consent type, channel, version, grant/withdrawal timestamps, legal basis, jurisdiction; (2) Third-party data processing agreements (DPAs), sub-processor agreements, and data sharing agreements — agreement type, counterparty, data categories, processing purposes, retention limits, security obligations, audit rights, effective/expiry dates, DPO sign-off; (3) Privacy Impact Assessments (PIA/DPIA) — processing activity, risk categories, data subjects affected, necessity/proportionality assessment, mitigation measures, DPO review status, supervisory authority consultation requirement. SSOT for all privacy governance across customer touchpoints, vendor relationships, and high-risk processing activities under GDPR, CCPA, and applicable privacy regulations.' .

ind:PrivacyRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Privacy Request' ;
    rdfs:comment 'Transactional record of data subject rights requests received from customers under GDPR (right to access, erasure, portability, rectification, restriction) and CCPA (right to know, delete, opt-out). Captures request type, submission channel, submission timestamp, identity verification status, assigned handler, processing deadline (regulatory SLA), fulfillment status, and closure timestamp. Tracks end-to-end DSR (Data Subject Request) lifecycle.' .

ind:SpectrumLicense rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Spectrum License' ;
    rdfs:comment 'Master record of spectrum licenses held by the telecommunications operator including periodic utilization reporting and regulatory compliance tracking. Captures frequency band, bandwidth (MHz), geographic coverage area, license category (mobile broadband, fixed wireless, satellite, experimental, CBRS/shared), license term, annual fees, renewal status, usage conditions, and granting authority (FCC, Ofcom, NTIA, national regulators). Includes all usage reports as line items: reporting period, measured utilization percentage, interference incidents, compliance status against license conditions, submission date, and regulatory authority acknowledgment. SSOT for spectrum asset compliance, license management, utilization tracking, and regulatory efficiency reporting.' .

ind:MnpCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Mnp Compliance' ;
    rdfs:comment 'Master record tracking Mobile Number Portability (MNP) regulatory compliance for each port-in and port-out transaction. Captures porting request reference, donor/recipient operator, MSISDN, porting completion timestamp, regulatory SLA deadline, SLA breach indicator, rejection reason (if applicable), and regulatory authority notification status. Supports FCC MNP compliance reporting and BEREC number portability obligations.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Master record of compliance audit engagements and resulting certifications held by the telecommunications operator. For audits: captures audit type (ISO 27001 surveillance/recertification, FCC inspection, GDPR supervisory authority audit, SOC 2 examination, PCI-DSS assessment, internal review), auditing body, scope, period, lead auditor, status, and overall outcome. For certifications: captures certification type (ISO/IEC 27001, SOC 2 Type II, PCI-DSS, FCC CPNI annual, GSMA SAS), issuing body, certification scope, issue date, expiry date, renewal status, certificate reference number, and responsible executive signatory. SSOT for the complete audit-to-certification lifecycle including certification renewal tracking.' .

ind:DataBreachIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Breach Incident' ;
    rdfs:comment 'Master record of personal data breach incidents covering the complete lifecycle from detection through regulatory notification, individual notification, and closure. Captures breach type (unauthorized access, accidental disclosure, ransomware, insider threat, third-party breach), affected data categories, estimated affected individual count, detection and containment timestamps, root cause, and remediation plan. Includes all notification records as line items: notification type (supervisory authority, affected individuals, law enforcement), recipient authority or channel, notification timestamp, content summary, regulatory deadline (GDPR 72-hour, CCPA \'without unreasonable delay\', FCC 30-day), on-time indicator, and acknowledgment reference. SSOT for complete data breach lifecycle management including mandatory notification compliance tracking.' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner' ;
    rdfs:comment 'Master registry of all third-party partners in the telecommunications ecosystem — MVNOs, roaming operators, OTT platforms, content providers, equipment vendors, channel partners, and wholesale carriers. SSOT for partner identity, legal entity details, classification type, onboarding status, tier/grade, and relationship metadata. Every other product in this domain references partner_id as the authoritative identity anchor. Aligned with TM Forum SID PartnerRole entity.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Contractual agreements and commercial arrangements between Telecommunication and its partners — MVNO host agreements, roaming bilateral agreements, content licensing contracts, OTT platform partnership agreements, equipment supply contracts, dealer/agent commission agreements, and wholesale carrier agreements. Captures contract terms, effective dates, renewal conditions, and governing regulatory frameworks.' .

ind:MvnoProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Mvno Profile' ;
    rdfs:comment 'Detailed operational and commercial profile for Mobile Virtual Network Operator (MVNO) partners hosted on Telecommunication\'s network infrastructure. Captures MVNO brand identity, subscriber base capacity, spectrum access rights, network access type (full MVNO, light MVNO, branded reseller), HLR/HSS provisioning parameters, APN configurations, and MVNO-specific billing arrangements.' .

ind:RoamingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Roaming Agreement' ;
    rdfs:comment 'Bilateral and multilateral roaming agreements with international and domestic network operators. Captures IOT (Inter-Operator Tariff) rates, TAP (Transferred Account Procedure) file exchange parameters, NRTRDE near-real-time data exchange settings, roaming steering policies, preferred roaming partner designations, fraud prevention thresholds, and GSMA AA.12/AA.13 compliance status.' .

ind:SlaDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Sla Definition' ;
    rdfs:comment 'Service Level Agreement definitions specifying measurable commitments governing partner relationships — uptime percentages, QoS thresholds (latency, jitter, packet loss), MTTR targets, settlement processing deadlines, dispute resolution windows, and penalty/credit calculation formulas. Each definition attaches to one or more partner agreements and serves as the benchmark for partner_sla_measurement evaluation. Aligned with TM Forum SID SLASpecification entity.' .

ind:RevenueSharePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Revenue Share Plan' ;
    rdfs:comment 'Revenue sharing and commission plan definitions for partner commercial arrangements — MVNO wholesale rate plans, content provider revenue split percentages, OTT platform revenue share tiers, dealer/agent commission structures, and wholesale reseller margin schedules. Captures calculation methodology, tiered thresholds, effective periods, and applicable product/service scope.' .

ind:SettlementRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Settlement Run' ;
    rdfs:comment 'Periodic financial settlement execution records between Telecommunication and its partners — MVNO wholesale billing cycles, roaming IOT settlement batches, content revenue share disbursements, and dealer commission payouts. Captures settlement period, run date, total calculated amount, currency, approval status, payment instruction reference, and reconciliation outcome. Serves as the header record for settlement_line detail items.' .

ind:SettlementLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Settlement Line' ;
    rdfs:comment 'Individual line-item detail records within a partner settlement run — per-service, per-product, or per-traffic-category charges and credits. Captures service type, usage volume, rated amount, applicable IOT/wholesale rate, adjustments, and dispute status. Enables granular reconciliation of MVNO wholesale charges, roaming IOT items, and content revenue share line items.' .

ind:OnboardingRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Onboarding Request' ;
    rdfs:comment 'Partner onboarding workflow records tracking end-to-end partner activation — from initial application through KYC/due diligence, credit assessment, contract execution, technical integration testing (API connectivity, TAP file exchange validation), and go-live activation. Captures onboarding stage, assigned owner, documentation checklist, regulatory approval status, and milestone dates. Aligned with TM Forum SID PartyRole lifecycle state management.' .

ind:Dealer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Dealer' ;
    rdfs:comment 'Master registry of all authorized indirect sales channel participants — dealers, retail partners, master agents, sub-agents, and independent sales representatives. SSOT for channel partner identity, trade name, channel type classification (dealer/agent/master_agent/independent_rep), authorized product portfolio, geographic territory, tier/grade, commission structure reference, activation credentials, POS system integration details, hierarchy relationships (master agent → sub-agent), and compliance certification status. Aligned with TM Forum SID PartnerRole specialization for indirect channel management.' .

ind:PartnerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Contact' ;
    rdfs:comment 'Named contact directory for partner organization representatives — account managers, technical integration leads, billing/settlement contacts, legal representatives, and escalation contacts. Captures contact role, communication preferences, organizational unit, and active status. Serves inter-company operational coordination distinct from end-customer CRM contact management.' .

ind:PartnerDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Dispute' ;
    rdfs:comment 'Formal dispute records raised by or against partners regarding settlement amounts, SLA breaches, billing discrepancies, roaming IOT charges, or contractual obligations. Captures dispute type, disputed amount, supporting evidence, resolution workflow stage, assigned owner, escalation path, and final resolution outcome. Supports GSMA dispute resolution procedures (AA.12/AA.14) and internal arbitration workflows.' .

ind:Lead rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Master record for a prospective customer or sales inquiry in the early pipeline stage. Captures lead source (web form, campaign, referral, walk-in, partner), contact details, segment classification (B2C/B2B/MVNO), qualification status (MQL/SQL), assigned sales rep, campaign attribution, lead score, and aging metrics. Sourced from Salesforce CRM Lead Management module. Represents the top-of-funnel entity for all sales pipelines with defined SLA for follow-up.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Core sales opportunity record representing a qualified sales pursuit for a prospect or existing subscriber, serving as the central pipeline entity from qualification through closed-won handoff to order fulfillment. Tracks opportunity stage, estimated contract value, close date, sales channel (retail/telesales/digital/dealer), segment (B2C/B2B/MVNO wholesale), win/loss reason, associated product offerings, and fulfillment handoff details. For enterprise/B2B accounts, includes strategic account planning attributes: growth objectives, whitespace analysis, key stakeholder map, planned upsell/cross-sell initiatives, competitive threats, and target MRR growth. Terminal closed-won state triggers order creation in the order domain. Sourced from Salesforce CRM Opportunity Management module.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Commercial quote issued to a prospect or existing customer detailing proposed telecom services, pricing, discounts, promotional offers, and contract terms with full itemized line-level detail. Tracks quote version, validity period, approval status, total contract value (TCV), monthly recurring revenue (MRR), associated opportunity, and individual line items: product catalog reference, unit price, discount applied, quantity, recurring vs one-time charge classification, promotional code, and bundle composition. Supports B2C retail, B2B enterprise, and MVNO wholesale quoting workflows with complete pricing breakdown at both header and line level.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Individual line item within a commercial quote representing a specific product, service plan, or bundle being offered. Captures product catalog reference, unit price, discount applied, quantity, recurring vs one-time charge classification, and promotional code. Enables itemized pricing breakdown for complex multi-service telecom quotes.' .

ind:SalesContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Contract' ;
    rdfs:comment 'Executed commercial contract between Telecommunication and a customer (B2C, B2B enterprise, or MVNO wholesale) formalizing agreed services, pricing, SLA commitments, contract duration, auto-renewal terms, early termination fee (ETF) schedule, and regulatory compliance clauses. Includes full amendment lifecycle tracking: amendment type (price change, scope change, term extension, service addition/removal), effective dates, approval chain, reason codes, MRR/TCV delta values, and amendment status from request through execution. Distinct from the service agreement in the service domain — this is the commercial/legal sales instrument managed in Salesforce CRM contract module.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Reference master defining all sales channels, their associated territory assignments, and geographic/segment-based territory hierarchies through which Telecommunication acquires customers — retail stores, telesales, online/digital self-serve, dealer/agent, MVNO wholesale, enterprise direct sales, and partner resellers. Captures channel type, channel code, region, territory hierarchy (geographic/vertical/named account), territory code, territory type, assigned sales team, active status, commission structure reference, performance tier classification, territory-to-team assignment rules, segment scope (B2C/B2B/MVNO), and effective date ranges. Supports channel performance management, territory management, and equitable lead/opportunity distribution.' .

ind:CommissionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Commission Plan' ;
    rdfs:comment 'Reference definition of a sales commission or incentive plan applicable to internal sales reps, dealers, or agents. Captures plan name, plan type (flat rate, tiered, residual, SPIFF, MDF), eligible product categories, commission rate schedule by product/plan type, clawback rules (30/60/90-day disconnect), payment frequency, accelerator thresholds, and effective date range. Provides the authoritative commission structure used to calculate earned commissions and supports audit of dealer payments.' .

ind:Target rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Target' ;
    rdfs:comment 'Periodic sales performance target assigned to a sales rep, dealer, team, or channel for a defined measurement period. Captures target type (revenue, activations, ARPU, churn saves, upsell), target value, measurement period (monthly/quarterly), segment scope (B2C/B2B/MVNO), product category scope, and attainment tracking fields. Supports sales performance management and incentive calculation.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Master record for a sales promotion or incentive offer applicable during the sales process — device subsidies, free months, bundle discounts, port-in bonuses, BYOD credits, and enterprise volume discounts — with full redemption transaction tracking. Captures promotion code, type, eligible segments, eligible products, discount value/percentage, start/end dates, redemption limits, stacking rules, and individual redemption records (redemption date, quote/order/contract reference, applied discount value, redemption channel, applying rep/dealer, validation status). Distinct from billing-layer promotions — this is the sales-stage commercial offer. SSOT boundary: sales.promotion owns offers presented during the sales process; product domain owns catalog-level pricing rules and permanent price structures.' .

ind:RetentionOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Retention Offer' ;
    rdfs:comment 'Targeted retention or save offer presented to a subscriber at risk of churn during a save interaction. Captures offer type (loyalty discount, plan upgrade, device upgrade, contract extension), offered value, eligibility criteria, offer validity window, acceptance/rejection outcome, and associated save interaction. Supports churn management and customer retention workflows distinct from new-sales promotions.' .

ind:SvcInstance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Svc Instance' ;
    rdfs:comment 'Core master record for every active or historical logical service instance provisioned for a subscriber — mobile, broadband, FTTH, VoIP, IPTV, IoT/M2M, managed service, or 5G network slice service. SSOT for the instantiated service binding a customer account to a product catalog offering and underlying network resources. Tracks lifecycle state (pending, active, suspended, terminated), activation/deactivation timestamps, service start/end dates, assigned SLA profile, QoS profile reference, technology type, and service class (consumer, enterprise, wholesale/MVNO, IoT). Supports massive-scale IoT/M2M scenarios through bulk instance management patterns. Central entity from which all service-domain transactions and configurations radiate. Does NOT own the customer account (customer domain), the product catalog offering (product domain), or the physical network resources (network/inventory domains) — owns only the logical service instantiation and its lifecycle.' .

ind:ProvisioningOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Provisioning Order' ;
    rdfs:comment 'Transactional record capturing each service provisioning or de-provisioning work order dispatched to OSS/BSS systems (Oracle OSM, Netcracker). Tracks order type (new activation, upgrade, downgrade, suspension, termination, MNP port-in/out, service test/qualification), orchestration state machine, step-level execution status including fallout management (failure step, error code, retry count, resolution action, resolution timestamp), completion timestamp, and originating commercial order reference. One provisioning order may span multiple activation tasks across network domains. Encompasses full fallout lifecycle for NOC operational quality tracking and systemic failure pattern identification. Supports pre-activation service testing and qualification as provisioning step types for enterprise FTTH/MPLS delivery. Does NOT own the commercial order (order domain) — owns only the technical provisioning execution, its outcomes, and failure resolution.' .

ind:ActivationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Activation Event' ;
    rdfs:comment 'Immutable event record capturing the precise moment a service instance transitions to active state on the network. Records activation timestamp, activating network element, provisioning system confirmation reference, VoLTE/IMS registration status at activation, eSIM profile download confirmation, and any fallback or retry attempts. Used for SLA compliance measurement and regulatory reporting of service activation timelines.' .

ind:SvcConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Svc Configuration' ;
    rdfs:comment 'Master record storing the full technical configuration state applied to a service instance at any point in time — including bearer settings, APN bindings, QoS class identifiers, bandwidth profiles, VoLTE/IMS parameters (P-CSCF assignment, HD voice, VoWiFi), eSIM profile state (EID, ICCID, SM-DP+ reference), FTTH ONT bindings (OLT, PON port, T-CONT, GEM port, VLAN), MVNO overrides, roaming zone configuration, codec preferences, and CPE provisioning parameters. Technology-agnostic container supporting all service types through typed configuration attributes. Sourced from Netcracker OSS, Nokia NetAct, HLR/HSS, and OLT EMS.' .

ind:SlaProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Profile' ;
    rdfs:comment 'Reference master defining the SLA parameters associated with a class of service — guaranteed uptime percentage, MTTR targets, latency thresholds, packet loss limits, jitter bounds, and escalation tiers. Distinct from QoS profiles (which are network-layer enforcement parameters). SLA profiles represent the commercial commitment made to the customer. Does NOT own SLA breach detection or credit calculation (assurance and billing domains respectively) — owns only the contractual parameter definition. Managed in Netcracker OSS/BSS product catalog.' .

ind:SvcStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Svc Status History' ;
    rdfs:comment 'Append-only audit log of every lifecycle state transition for a service instance — from pending through active, suspended, and terminated states. Captures previous state, new state, transition timestamp, reason code, initiating actor (customer, CSR, automated system), and source system event reference. Immutable record essential for SLA measurement, regulatory compliance (disconnection timelines), churn analysis, and dispute resolution.' .

ind:NumberAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Number Assignment' ;
    rdfs:comment 'Master record managing the assignment of MSISDN (mobile numbers), DID numbers, and VoIP DIDs to active service instances. Tracks number type (geographic, non-geographic, toll-free, short code), assignment date, porting status (MNP donor/recipient), number reservation state, and regulatory number range ownership. Supports MNP port-in and port-out workflows. Critical for regulatory number inventory reporting to FCC/Ofcom/BEREC. Does NOT own the number pool inventory (inventory domain) — owns only the active assignment binding between a number and a service instance.' .

ind:SvcSuspension rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Svc Suspension' ;
    rdfs:comment 'Transactional record for each service suspension event — voluntary (customer-initiated travel hold) or involuntary (non-payment, fraud, regulatory). Captures suspension type, initiating reason code, suspension start date, expected reinstatement date, actual reinstatement date, and the billing impact flag (whether charges continue during suspension). Supports collections workflow integration with Amdocs Revenue Management and regulatory compliance for involuntary disconnection rules.' .

ind:SvcLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Svc Location' ;
    rdfs:comment 'Master record for the service delivery location associated with a fixed-line or broadband service instance — civic address, geographic coordinates, premises type (residential/commercial/MDU), access technology at that location (FTTH/FTTC/DSL/cable), serviceability status, and the network serving area (NSA) or exchange reference. Distinct from customer billing address — this is the physical location where the service is delivered. Critical for field dispatch, network planning, and regulatory coverage reporting.' .

ind:Cdr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Cdr' ;
    rdfs:comment 'Call Detail Record — the authoritative raw usage event record for voice calls (MO/MT, VoLTE, IMS-based), capturing originating/terminating numbers, call start/end timestamps, duration, call type (local, national, international, roaming), network node identifiers, IMSI, IMEI, cell ID, trunk group, termination cause, and mediation processing status. Sourced from MSC/SSF/IMS-AS and processed through the mediation layer. SSOT for voice CDR data in the Silver layer.' .

ind:SmsRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Sms Record' ;
    rdfs:comment 'Short Message Service usage event record capturing SMS/MMS origination and termination details — MSISDN, SMSC address, message type (MT/MO/P2P/A2P), delivery status, content class, message size, timestamp, network node, roaming indicator, and mediation status. Distinct from voice CDRs due to different rating logic, regulatory reporting (A2P filtering), and spam/fraud patterns.' .

ind:DataSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Data Session' ;
    rdfs:comment 'Packet data session record (PGW/SGW/UPF-generated) capturing subscriber MSISDN/IMSI, APN, session start/end timestamps, uplink/downlink bytes transferred, peak throughput, RAT type (LTE/5G NR/HSPA), QoS class identifier (QCI/5QI), charging characteristics, SGSN/PGW/UPF node IDs, PDN type (IPv4/IPv6), and session termination cause. Primary source for data usage rating and fair-use policy enforcement.' .

ind:MediationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Mediation Event' ;
    rdfs:comment 'Mediation layer processing lifecycle record tracking each raw usage event from network collection through normalization, enrichment, duplicate detection, validation, rejection handling, and delivery to downstream rating engines. Captures source network element, collection timestamp, raw record reference, mediation node ID, processing status (collected, normalized, enriched, validated, rated, rejected, reprocessed), rejection reason code and category (duplicate, missing mandatory field, format error, out-of-sequence, future-dated, unknown subscriber, invalid IMSI), retry count, retry eligibility flag, manual review queue assignment, resolution outcome (auto-corrected, manually resolved, permanently rejected, written off), reprocessing history, and downstream system delivery confirmation with acknowledgement timestamp. This is the single authoritative record for ALL mediation outcomes including rejections — no separate rejection entity exists. Critical for revenue assurance gap detection, mediation SLA monitoring, and regulatory audit trails demonstrating usage processing completeness.' .

ind:Balance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Real-time subscriber usage balance and bundle consumption tracking record — the single authoritative source for current-state balance snapshots AND event-level consumption/deduction history across all bundle types. Tracks voice minutes, SMS units, data bytes (national/roaming/zero-rated), content credits, and add-on bundle balances. Captures balance at period start, consumed units per bundle instance, remaining units, overage flag/units, throttle threshold and status, bundle instance reference, bundle expiry date, last consumption event timestamp, per-event deduction history with full granularity, throttle trigger actions, and bundle lifecycle state. Sourced from real-time charging systems (OCS/Comverse ONE) and batch rating engines. Serves as the authoritative record for real-time balance queries, bundle consumption audit, prepaid top-up reconciliation, historical consumption analysis, and per-bundle allowance tracking. Consolidates both snapshot and transactional consumption views — no separate bundle consumption entity exists.' .

ind:AggregatedUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Aggregated Usage' ;
    rdfs:comment 'Pre-aggregated periodic usage summary at the subscriber-service-period grain (daily, weekly, monthly billing cycle) — total voice minutes, SMS count, data MB consumed (split by RAT type), roaming usage by service, content hours, overage amounts, and peak/off-peak breakdowns. This is the Silver-layer operational aggregation used as direct input to invoice line generation, ARPU/AMPU calculation feeds, fair-use policy threshold evaluation, and regulatory usage reporting. NOT a BI/analytics cube — it is the authoritative operational summary feeding billing and policy systems.' .

ind:Anomaly rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Anomaly' ;
    rdfs:comment 'Operational record of detected usage anomalies flagged during mediation or revenue assurance processing — anomaly type (duplicate CDR, missing sequence, volume spike, zero-duration call, grey route indicator), detection timestamp, affected record reference, severity level, assigned investigation status, and resolution action. Feeds revenue assurance and fraud operations workflows without being an analytics construct.' .

ind:RoamingFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Usage ;
    rdfs:label 'Roaming File' ;
    rdfs:comment 'TAP (Transferred Account Procedure) file-level control record tracking the exchange of roaming usage files between operators via clearing houses (GSMA/Syniverse) — TAP file name, sequence number, sender/recipient TADIG codes, file type (TAP3/RAP), record count, total charged amount, currency, file generation date, transmission status, acknowledgement timestamp, and dispute flag. Parent record for individual roaming_tap_records.' .

ind:AlarmEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Alarm Event' ;
    rdfs:comment 'SSOT for network alarm events ingested from Nokia NetAct and Ericsson Network Manager. Captures real-time fault signals raised by network elements including RAN, transport, core, and GPON/FTTH nodes. Stores alarm severity, alarm type, affected network element, alarm state (raised/cleared/acknowledged), first occurrence timestamp, last occurrence timestamp, probable cause, specific problem code, managed object class, managed object instance, OSS source system, and correlation identifier. Feeds trouble ticket creation workflows in ServiceNow ITSM.' .

ind:TroubleTicket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Trouble Ticket' ;
    rdfs:comment 'SSOT for fault management trouble tickets sourced from ServiceNow ITSM. Represents a formal record of a network or service fault requiring investigation and resolution. Captures ticket number, category (network/service/customer), priority, severity, affected service, affected network element, assigned NOC/SOC group, assignee, open timestamp, acknowledged timestamp, resolved timestamp, closed timestamp, root cause category, resolution description, MTTR (minutes), escalation flag, escalation tier, SLA breach flag, and source alarm correlation IDs. Aligns with eTOM process 1.1.1 Fault Management.' .

ind:NocIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Noc Incident' ;
    rdfs:comment 'NOC/SOC operational incident record representing a declared network or security incident managed by the Network Operations Center or Security Operations Center. Distinct from a trouble ticket in that it represents a broader operational event (e.g., major outage, DDoS attack, fiber cut) that may span multiple trouble tickets and alarms. Captures incident ID, incident type (network/security/power/environmental), severity level, declared timestamp, resolved timestamp, impacted geography, impacted customer count estimate, impacted services list, incident commander, war-room bridge details, post-incident review flag, and RCA document reference.' .

ind:PerformanceMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Performance Measurement' ;
    rdfs:comment 'SSOT for time-series performance measurement records collected at the network-element layer from Nokia NetAct and Ericsson Network Manager across RAN, transport, and core domains. Captures infrastructure-level KPIs: RSRP, SINR, cell throughput, packet loss, latency, link utilization, node availability, and capacity metrics. Each record captures measurement object (cell/link/node/shelf/port), KPI name, measurement interval (15-min/1-hour/24-hour), raw value, threshold value, threshold breach flag, measurement source (OSS/EMS/NMS), collection timestamp, and source system. Serves as the unified network-element measurement store for availability computation, capacity planning, and threshold breach detection. Service-layer and bearer-level QoS measurements are owned by qos_measurement. Aligns with eTOM process 1.1.2 Performance Management.' .

ind:SlaContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Sla Contract' ;
    rdfs:comment 'Master record defining SLA (Service Level Agreement) contracts applicable to customer services or internal network operations. Captures SLA ID, SLA name, SLA type (customer-facing/internal/wholesale), associated product or service class, availability target (%), MTTR target (hours), latency target (ms), packet loss target (%), jitter target (ms), measurement window, penalty clause flag, penalty calculation method, effective date, expiry date, and governing regulatory body reference. Owned by the assurance domain as the authoritative SLA definition used for breach tracking, penalty calculation, and regulatory QoS compliance reporting. Aligns with eTOM process 1.1.3 SLA Management.' .

ind:SlaBreachEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Sla Breach Event' ;
    rdfs:comment 'Transactional record capturing each instance where a service or network KPI breaches a defined SLA threshold. Captures breach event ID, referenced SLA contract, affected service instance, affected customer account, breach type (availability/MTTR/latency/packet-loss), breach start timestamp, breach end timestamp, breach duration (minutes), contracted threshold, actual measured value, breach severity, penalty applicable flag, penalty amount, notification sent flag, and notification timestamp. Critical for revenue assurance penalty calculations and regulatory reporting.' .

ind:FraudCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Fraud Case' ;
    rdfs:comment 'Operational record covering the full fraud management lifecycle from initial detection alert through formal investigation, law enforcement referral, and resolution. Captures fraud case ID, fraud type (SIM-swap/subscription-fraud/bypass-fraud/roaming-fraud/PBX-hacking/wangiri/IRSF/dealer-fraud), detection source, detection rule reference, alert severity, trigger type (velocity/threshold/pattern/blacklist/ML-signal), alert timestamp, affected subscriber, affected service, estimated fraud loss amount, confirmed fraud loss amount, case status (open/under-investigation/suspended/closed-confirmed/closed-false-positive), assigned fraud analyst, investigation notes, evidence references, law enforcement referral flag, referral timestamp, recovery amount, recovery method, and case closure timestamp. Consolidates the detection-to-resolution workflow in a single entity with lifecycle stage tracking. Aligns with eTOM process 1.1.4 Fraud Management.' .

ind:FraudAlert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Fraud Alert' ;
    rdfs:comment 'Real-time or near-real-time alert generated by fraud detection rules or threshold triggers indicating suspicious activity on a subscriber account or network element. Captures alert ID, alert rule name, alert trigger type (velocity/threshold/pattern/blacklist), alert severity, affected subscriber or network element, alert timestamp, alert status (new/acknowledged/escalated/closed/false-positive), linked fraud case ID (if escalated), and analyst notes. Distinct from fraud_case — an alert is the initial signal; a case is the formal investigation record.' .

ind:ProblemRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Problem Record' ;
    rdfs:comment 'ServiceNow ITSM Problem Management record representing the root cause investigation of one or more recurring trouble tickets or incidents. Captures problem ID, problem title, problem category, linked incident/ticket IDs, affected network domain, root cause description, workaround description, permanent fix description, problem status (open/known-error/resolved/closed), priority, assigned problem manager, identified timestamp, resolved timestamp, and known error database (KEDB) flag. Enables proactive fault management and MTBF improvement tracking.' .

ind:OutageRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Outage Record' ;
    rdfs:comment 'Master record of a confirmed network or service outage event with full lifecycle tracking from detection to restoration and regulatory notification. Distinct from noc_incident (which captures the operational response and war-room coordination) — outage_record owns the infrastructure event facts: what failed, when, where, how long, and how many subscribers were impacted. Captures outage ID, outage type (planned/unplanned), outage cause category (hardware/software/power/fiber-cut/weather/human-error/cyber), affected network element or service, affected geography (region/cell/exchange), outage start timestamp, outage end timestamp, outage duration (minutes), impacted subscriber count, impacted service types, restoration method, restoration team, regulatory reportable flag, regulatory body (FCC/Ofcom/BEREC/NTIA), reportable threshold met (subscriber count/duration/service type), regulatory notification status (not-required/draft/submitted/acknowledged/closed), regulatory reference number, notification submission timestamp, compliance officer sign-off, and post-outage review reference.' .

ind:KpiThreshold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Kpi Threshold' ;
    rdfs:comment 'Unified reference master and single source of truth for ALL detection rules, correlation logic, suppression rules, and threshold configurations used across the assurance domain. Encompasses: (1) KPI breach thresholds for performance monitoring (threshold value, direction, measurement window, severity); (2) Alarm correlation and suppression rules from Nokia NetAct/Ericsson NM (trigger alarm type, correlated alarm types, correlation window, root cause determination logic, suppression duration); (3) Fraud detection rules (fraud type targeted, detection method — velocity/threshold/pattern/blacklist/ML-signal, trigger threshold, applicable service type, false positive rate). Captures rule/threshold ID, rule name, rule category (KPI-threshold/alarm-correlation/alarm-suppression/fraud-detection/deduplication), detection logic description, network domain applicability (RAN/transport/core/FTTH), severity classification, rule status (active/inactive/testing), effective date, expiry date, last tuned timestamp, and owning team. Provides the authoritative rules and threshold registry consumed by all assurance monitoring and detection systems.' .

ind:CorporateAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Corporate Account' ;
    rdfs:comment 'Master record for an enterprise/B2B corporate account representing a legal business entity (corporation, government agency, SME) contracting with the telco. Captures legal entity name, registration number, industry vertical, account tier (strategic, key, standard), assigned account manager, credit rating, CLTV, ARPU, contract start/end dates, billing currency, preferred language, account status, and churn risk indicators. SSOT for enterprise customer identity within the B2B segment — all enterprise domain entities reference this as the root account.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child relationships within a corporate account structure, supporting multi-subsidiary, holding company, and government department hierarchies. Captures parent account, child account, hierarchy level, relationship type (subsidiary, division, branch, department), effective dates, and consolidation flags for billing rollup and reporting. Enables enterprise-wide spend visibility and consolidated invoicing across complex B2B organizational structures.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Site' ;
    rdfs:comment 'Physical or logical site/location belonging to a corporate account where services are delivered — office buildings, data centers, branch offices, government facilities, or remote sites. Captures site name, address, site type, geographic coordinates, access instructions, site contact, CPE inventory reference, number of users, bandwidth requirements, and site status. Used for SD-WAN/MPLS topology planning, field dispatch, and SLA zone assignment.' .

ind:ManagedService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Managed Service' ;
    rdfs:comment 'Master record for a managed service instance delivered to a corporate account — SD-WAN, MPLS VPN, UCaaS, IoT connectivity, managed security, or dedicated internet access. Captures service type, tier, contracted bandwidth, QoS class, SLA tier reference, provisioning status, activation date, managed CPE references (linking to inventory domain), NOC monitoring flag, and assigned service delivery manager. Represents the operational service instance distinct from the product catalog definition.' .

ind:EnterpriseContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Enterprise Contract' ;
    rdfs:comment 'Master record for all commercial contracts between the telco and a corporate account. Covers all enterprise agreement types via a type discriminator: master service agreements (MSA), government frameworks (G-Cloud, Crown Commercial Service, GSA Schedule), MVNO host agreements, and wholesale contracts. Captures contract reference, type (commercial, government, wholesale, MVNO), effective/expiry dates, auto-renewal flag, minimum commitment (MRR/ARR), discount schedule reference, penalty clauses, governing law, status, signatory details. For government-type contracts: security clearance requirements, data sovereignty obligations, audit rights, FOIA compliance flag, contract ceiling value, task order structure, procurement vehicle, and agency-specific billing codes. SSOT for all enterprise contractual obligations regardless of customer segment or procurement vehicle.' .

ind:SlaMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Sla Measurement' ;
    rdfs:comment 'Periodic SLA performance measurement for an enterprise managed service against contracted targets. Captures measurement period, service reference, metric type (availability, MTTR, latency, jitter, packet loss), measured value, target value, breach flag, breach duration, credit entitlement, and data source. Feeds breach detection and enterprise customer SLA reporting.' .

ind:SlaBreach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Confirmed SLA breach event triggered when a managed service metric falls below contracted threshold. Captures breach start/end timestamps, duration, affected service, breach type, root cause category, credit amount, notification status, customer acknowledgment, and resolution reference. Drives automated credit issuance and escalation workflows.' .

ind:IotDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Iot Deployment' ;
    rdfs:comment 'Master record for an enterprise IoT solution deployment — tracking the rollout of IoT connectivity services (SIM-based, NB-IoT, LTE-M) for a corporate account\'s use case (fleet tracking, smart metering, industrial automation, asset monitoring). Captures deployment name, IoT use case type, device count, connectivity technology (NB-IoT, LTE-M, 4G), APN configuration, data plan reference, geographic coverage zones, activation status, and managed platform reference.' .

ind:UcSubscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Uc Subscription' ;
    rdfs:comment 'Master record for a Unified Communications (UCaaS) subscription provisioned for a corporate account — covering hosted PBX, VoLTE business lines, video conferencing, collaboration tools, and SIP trunking. Captures subscription reference, UC platform type, number of seats/users, DID number block, SIP trunk capacity, feature pack, call recording flag, integration type (Microsoft Teams, Cisco Webex), provisioning status, and monthly seat charge.' .

ind:SdwanTopology rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Sdwan Topology' ;
    rdfs:comment 'Logical SD-WAN network topology for a corporate account — hub-and-spoke or full-mesh design, site count, underlay transports (MPLS, broadband, LTE backup), overlay routing policy, QoS profile, security policy (firewall, IDS/IPS), vCPE/uCPE device references, and orchestration platform (Cisco Viptela, VMware VeloCloud, Fortinet). Governs traffic engineering, failover behavior, and policy-based routing across enterprise sites.' .

ind:DiscountScheme rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Discount Scheme' ;
    rdfs:comment 'Master definition of a discount scheme applicable to a corporate account or commercial contract — including volume discounts, loyalty discounts, government framework pricing, and strategic account pricing. Captures scheme name, discount type (percentage, fixed amount, tiered), applicable product categories, minimum commitment threshold, discount percentage or amount, effective period, approval authority, and stacking rules with other discounts. Governs enterprise-specific pricing distinct from standard consumer rate plans.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Reference master defining enterprise customer segmentation taxonomy — classifying corporate accounts by size, revenue band, industry vertical, and service eligibility. Segments include Large Enterprise, Mid-Market, Government, SME, MVNO Host, and Wholesale. Drives differentiated pricing, account management models, and go-to-market strategies across the B2B customer base.' .

ind:Dependency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Dependency' ;
    rdfs:comment 'Master record defining parent-child and peer relationships between service instances — modeling bundle compositions (triple-play: broadband + VoIP + IPTV), technology dependencies (VoLTE depends on data bearer), 5G network slice compositions (slice instance depends on underlying connectivity service), wholesale/MVNO virtual service layers (host service → virtual service mapping), and service groupings (multi-SIM family plans). Captures dependency type (composition, prerequisite, peer, slice-component, wholesale-virtual), parent service instance, child service instance, dependency direction, activation sequencing constraint, and impact propagation rule (e.g., if parent suspends, children auto-suspend). Essential for bundle lifecycle management, 5G slice orchestration, MVNO service modeling, impact analysis during service modifications, and correct provisioning sequencing. Does NOT own the commercial bundle definition (product domain) or the network slice template (network domain) — owns only the instantiated runtime dependency graph.' .

ind:Slice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Slice' ;
    rdfs:comment 'Master record for 5G network slices — logical end-to-end network partitions configured to meet specific service requirements (eMBB, URLLC, mMTC). Captures slice identifier (S-NSSAI: SST + SD), slice name, slice type (eMBB/URLLC/mMTC/custom), SLA parameters (latency, throughput, reliability), constituent network functions (AMF, SMF, UPF instances), RAN slice configuration, transport slice configuration, lifecycle state (design/test/active/decommissioned), tenant assignment, and resource isolation level. Critical for 5G SA network operations, enterprise slice-as-a-service offerings, and regulatory reporting on network resource allocation.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'This association product represents the subscription contract between a subscriber and an add-on product. It captures the activation, lifecycle, and billing details specific to each subscriber\'s purchase of an add-on. Each record links one subscriber to one add-on with attributes that exist only in the context of this subscription relationship, including activation dates, expiry, status, pricing, and renewal behavior.. Existence Justification: In telecommunications operations, subscribers purchase and activate multiple add-ons simultaneously (international roaming, data top-ups, premium content, cloud storage), and each add-on product is purchased by thousands of subscribers. The business actively manages these subscriptions as operational entities with lifecycle states, billing cycles, activation/expiry dates, and subscriber-specific pricing. Customer care, billing, and provisioning systems create, update, and deactivate these subscription records as part of daily operations.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master reference table for campaign. Referenced by campaign_id.' .

ind:FraudPattern rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assurance ;
    rdfs:label 'Fraud Pattern' ;
    rdfs:comment 'Master reference table for fraud_pattern. Referenced by fraud_pattern_id.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Master reference table for billing_cycle. Referenced by billing_cycle_id.' .

ind:PaymentArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Arrangement' ;
    rdfs:comment 'Master reference table for payment_arrangement. Referenced by payment_arrangement_id.' .

ind:TopologySiteMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enterprise ;
    rdfs:label 'Topology Site Membership' ;
    rdfs:comment 'This association product represents the Role-based enrollment of an enterprise_site within an sdwan_topology. It captures the operational membership record that governs how a specific site participates in a specific SD-WAN topology — including the site\'s role (hub, spoke, edge), its activation within that topology, its allocated bandwidth slice, and any site-level QoS overrides. Each record links one sdwan_topology to one enterprise_site with attributes that exist only in the context of this site-topology relationship, enabling multi-topology deployments, DR topologies, and phased migrations to be modeled accurately.. Existence Justification: In SD-WAN managed services, a topology is explicitly a multi-site construct — a single topology governs traffic engineering across many enterprise sites simultaneously. Critically, the reverse is also operationally real: an enterprise site can participate in multiple topologies concurrently (e.g., a primary production topology and a DR/failover topology, or during phased migrations where a site is enrolled in both the legacy and new topology). The business actively manages \'site membership\' in a topology as an operational concept — provisioning, activating, and deactivating individual site enrollments with site-specific roles and configurations.' .

ind:CampaignChannelExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign Channel Execution' ;
    rdfs:comment 'This association product represents the Execution relationship between campaign and channel. It captures the operational assignment of a marketing campaign to a specific sales channel, including channel-specific budget allocation, activation dates, and per-channel performance metrics. Each record links one campaign to one channel and carries attributes that exist only in the context of that specific channel\'s execution of that campaign — data that belongs to neither the campaign master nor the channel master alone.. Existence Justification: In telecommunications marketing operations, campaigns are explicitly deployed across multiple sales channels (retail, telesales, digital, dealer/agent, enterprise direct), and each channel simultaneously carries multiple campaigns. Marketing operations teams actively manage which channels execute which campaigns, with separate budget allocations, response rate tracking, and cost-per-acquisition metrics per channel-campaign combination. This is a recognized operational business process — not an analytical correlation — where humans create, update, and deactivate channel-campaign execution records as part of campaign lifecycle management.' .

ind:RanSliceAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Ran Slice Assignment' ;
    rdfs:comment 'This association product represents the operational binding (Role) between a 5G network slice and a RAN cell. It captures the per-cell slice configuration, admission control policy, UE capacity allocation, and lifecycle state of each slice-cell binding as managed by the NSSF and RAN slice management systems per 3GPP TS 28.541. Each record links one network slice to one RAN cell and carries attributes that exist only in the context of this specific binding — they cannot reside on either the slice master or the ran_cell master.. Existence Justification: In 5G network operations, a single network slice (e.g., a URLLC slice for an enterprise customer) is deployed across MULTIPLE RAN cells to provide geographic coverage, and a single RAN cell simultaneously serves MULTIPLE active slices (eMBB, URLLC, mMTC) through RAN slicing. This is a first-class operational concept managed by the NSSF and RAN slice management systems, explicitly defined in 3GPP TS 28.541 as \'RAN Slice Subnet\' management. Telecom operators actively create, modify, and deactivate these slice-cell bindings in their NMS/EMS platforms as part of slice lifecycle management.' .

ind:SliceElementAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Slice Element Assignment' ;
    rdfs:comment 'This association product represents the operational binding (Role/Assignment) between a 5G network slice and a physical or virtual network element. It captures the MANO-managed assignment of network functions and infrastructure elements to specific slices, per 3GPP TS 28.530 Network Slice Subnet Instance to Network Function mapping. Each record links one slice to one element and carries attributes that exist only in the context of this specific binding: the element\'s functional role within the slice, its allocated resource share, its per-slice operational status, and its slice-specific configuration. Network engineers actively create, modify, and decommission these records during slice lifecycle operations.. Existence Justification: In 5G SA (Standalone) networks, a single network slice (identified by S-NSSAI) is composed of multiple physical and virtual network elements (gNodeBs, AMF, SMF, UPF, transport nodes, etc.), and a single network element can participate in multiple slices simultaneously — this is the foundational principle of network slicing per 3GPP TS 28.530. Operators actively manage these slice-to-element bindings in MANO orchestrators (Nokia CloudBand, Ericsson Cloud Manager) as explicit operational records with role, resource allocation percentage, and per-element slice configuration. The business concept \'Slice Element Assignment\' or \'Network Function Slice Binding\' is a recognized operational entity that network engineers create, modify, and decommission as part of slice lifecycle management.' .

ind:BundleComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle Component' ;
    rdfs:comment 'This association product represents the Component role between bundle and offering in the telecommunications product catalog. It captures the explicit business act of including a specific offering as a component within a bundle, with terms governing that inclusion (mandatory vs. optional, quantity, component-level discount, display sequence, and effective dates). Each record links one bundle to one offering and carries attributes that exist only in the context of that specific bundle-offering composition. Product catalog managers create, modify, and retire these records as part of bundle lifecycle management in BSS/product catalog systems such as Netcracker.. Existence Justification: In telecommunications product catalog management, bundles are explicitly composed of multiple offerings (e.g., a Triple Play bundle contains broadband offering + IPTV offering + VoIP offering), and a single offering (e.g., \'Fiber 100Mbps\') can be included in multiple different bundles simultaneously (e.g., both a \'Double Play\' and a \'Triple Play\' bundle). This is a first-class operational business concept — product catalog managers actively create, modify, and retire bundle component records as part of product lifecycle management. The relationship carries its own attributes (mandatory/optional flag, component quantity, component-level discount, sequence, effective dates) that belong neither to the bundle nor the offering alone.' .

# --- Attribute Properties ---
ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the billing account record in the Amdocs Revenue Management system. Serves as the primary key and financial anchor for all monetary transactions, invoices, payments, and collections associated with this account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Foreign key linking to enterprise.corporate_account. Business justification: Enterprise billing accounts are directly owned by a corporate account for consolidated billing, account hierarchy management, and enterprise revenue reporting. A telecom billing analyst expects every ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer (party) who owns this billing account. One customer may have multiple billing accounts to support split billing arrangements across different service lines or business units.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:parentAccountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Billing Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent billing account in a hierarchical account structure. Used for enterprise split billing where a master account consolidates charges from multiple child accounts. Null for standalone accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: MVNO and wholesale customers have billing accounts managed by host operator. Required for MVNO billing, wholesale invoicing, partner revenue tracking, and settlement reconciliation in telecommunicatio' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Descriptive name assigned to the billing account, typically the customer legal name or a business unit label for corporate accounts. Displayed on invoices and used in collections correspondence.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible, human-readable account number assigned by Amdocs Revenue Management and printed on invoices and statements. Used by customers and agents to reference the account in all billing interactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the billing account as managed in Amdocs Revenue Management. Controls whether new charges can be applied, invoices generated, and services provisioned. [ENUM-REF-CANDIDATE: active|suspended|closed|pending|delinquent|write_off — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account by customer segment. Drives applicable rate plans, credit policies, dunning rules, and regulatory treatment. [ENUM-REF-CANDIDATE: residential|small_business|enterprise|wholesale|mvno|government — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpuSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Arpu Segment Code' ;
    rdfs:comment 'Segment classification of the billing account based on Average Revenue Per User (ARPU) banding (e.g., HIGH_VALUE, MID_VALUE, LOW_VALUE). Used for targeted retention campaigns, churn management, and revenue analytics.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment is configured for this billing account. When true, the system initiates payment collection on the due date using the stored payment instrument without manual customer action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Bill Delivery Method' ;
    rdfs:comment 'Preferred channel through which invoices are delivered to the customer. Drives the bill production and distribution workflow in Amdocs Revenue Management. Suppressed is used for internal or wholesale accounts billed via EDI.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Bill Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag specifying the language in which invoices and billing communications are generated for this account (e.g., en-US, es-MX, fr-CA). Supports multilingual billing for diverse customer bases.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Code' ;
    rdfs:comment 'Code identifying the billing cycle assigned to this account in Amdocs Revenue Management (e.g., MONTHLY-01, MONTHLY-15, QUARTERLY). Determines the invoice generation schedule and the period over which charges are accumulated.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedBilling rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing' ;
    rdfs:comment 'Indicates whether this billing account is configured to receive a consolidated invoice aggregating charges from multiple sub-accounts or service lines. Common for enterprise customers with split billing arrangements.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code associated with this billing account for internal financial allocation and OPEX/CAPEX reporting. Relevant for enterprise and wholesale accounts where charges are allocated to specific business units.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the billing account record was first created in Amdocs Revenue Management. Used for account age calculations, onboarding analytics, and audit trail compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditClassCode rdf:type rdf:Property ;
    rdfs:label 'Credit Class Code' ;
    rdfs:comment 'Credit risk classification assigned to the billing account by the credit management system (e.g., GOLD, SILVER, BRONZE, HIGH_RISK). Drives credit limit assignment, deposit requirements, and dunning profile selection in Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding balance permitted on this billing account before service suspension is triggered. Set based on credit class and customer risk profile. Monitored in real time by Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which all charges, invoices, and payments on this billing account are denominated (e.g., USD, EUR, GBP). Critical for multi-currency billing in international operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Outstanding monetary balance on the billing account as of the last billing run or payment posting. Positive value indicates amount owed by the customer; negative value indicates a credit balance. Used for collections prioritization and MRR reporting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Monetary deposit held by the carrier against this billing account as a credit risk mitigation measure. Applied to high-risk credit classes. Refundable upon account closure in good standing per FCC deposit rules.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'Date on which the security deposit was collected from the customer. Used to calculate deposit holding period and determine refund eligibility under FCC regulations.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeInProgress rdf:type rdf:Property ;
    rdfs:label 'Dispute In Progress' ;
    rdfs:comment 'Indicates whether there is an active billing dispute on this account. When true, dunning escalation may be paused per dispute resolution policy. Linked to the dispute management workflow in Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningProfileCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Profile Code' ;
    rdfs:comment 'Code referencing the dunning workflow profile assigned to this billing account in Amdocs Revenue Management. Defines the sequence, timing, and escalation steps (reminder, warning, suspension, collections referral) applied when payment is overdue.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Status' ;
    rdfs:comment 'Current step in the dunning escalation workflow for this billing account. Tracks the collections lifecycle from initial reminder through suspension and potential write-off. Updated by Amdocs Revenue Management collections engine.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date on which the billing account became active and eligible to receive charges. Marks the start of the billing relationship and is used for revenue recognition and contract term calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which the billing account is scheduled to close or was closed. Null for open-ended accounts. Used for contract expiry tracking, churn analysis, and revenue recognition cutoff.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA to which revenue and receivables from this billing account are posted. Ensures accurate financial reporting and audit trail between the BSS billing system and the ERP.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level of this billing account within the enterprise account hierarchy (1 = top-level master account, 2 = sub-account, 3 = sub-sub-account). Supports multi-tier corporate billing structures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceFormatCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Format Code' ;
    rdfs:comment 'Specifies the invoice presentation format assigned to this billing account. Itemized includes per-call detail; summary shows charge categories only; consolidated merges multiple sub-accounts into a single invoice.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date on which the most recent invoice was generated for this billing account. Used to track billing cycle adherence, identify accounts that have not been billed, and support collections workflows.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the billing account record in Amdocs Revenue Management. Used for change data capture (CDC), data lineage tracking, and audit compliance in the Silver layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Monetary value of the most recent payment posted to this billing account. Used alongside last_payment_date to assess partial vs. full payment behavior and inform collections strategy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date on which the most recent payment was posted to this billing account. Used by collections agents to assess payment recency, calculate days since last payment, and prioritize dunning actions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrrAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Amount' ;
    rdfs:comment 'The contracted Monthly Recurring Revenue (MRR) value of this billing account, representing the predictable monthly charge for subscribed services excluding one-time and usage-based charges. Used for revenue forecasting and EBITDA reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total monetary amount past the payment due date on this billing account. Drives dunning escalation, credit limit monitoring, and collections referral decisions in Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Instrument used to settle invoices on this billing account. Determines auto-pay eligibility and dunning escalation paths. [ENUM-REF-CANDIDATE: auto_pay_card|auto_pay_ach|manual_card|manual_ach|check|wire|cash|voucher — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due (e.g., 14, 21, 30). Governs the due date calculation on each invoice and triggers dunning escalation if payment is not received within this window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prepaidPostpaidIndicator rdf:type rdf:Property ;
    rdfs:label 'Prepaid Postpaid Indicator' ;
    rdfs:comment 'Indicates whether this billing account operates on a prepaid (advance payment, Comverse ONE), postpaid (invoice-based, Amdocs Revenue Management), or hybrid charging model. Determines the rating engine and balance management system used.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Code' ;
    rdfs:comment 'Code identifying the revenue recognition treatment applied to charges on this billing account per IFRS 15 / ASC 606 (e.g., STRAIGHT_LINE, USAGE_BASED, MILESTONE). Used by the finance team for accurate revenue reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the originating operational system from which this billing account record was sourced (e.g., AMDOCS_RM, COMVERSE_ONE). Supports data lineage, reconciliation, and multi-system integration in the Databricks Silver layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendLimit rdf:type rdf:Property ;
    rdfs:label 'Spend Limit' ;
    rdfs:comment 'Maximum total spend threshold configured on this billing account for real-time usage control. When the accumulated charges approach this limit, alerts are triggered or services are throttled. Distinct from credit_limit which governs outstanding balance.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether this billing account is exempt from applicable taxes (e.g., government entities, non-profit organizations). When true, the rating and invoicing engine suppresses tax calculation for charges on this account.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate' ;
    rdfs:comment 'Reference number of the tax exemption certificate provided by the customer. Required for audit and regulatory compliance when tax_exempt is true. Stored for verification by the finance and compliance teams.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the invoice record in the billing system. Primary key for the invoice data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: Partner invoices are governed by a specific partner agreement defining payment terms, currency, and settlement rules. Linking invoice to agreement enables agreement-based invoice validation and disput' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Reference to the billing cycle period during which this invoice was generated. Determines the charge period start and end dates for postpaid billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:enterpriseContractId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Contract Id' ;
    rdfs:comment 'Foreign key linking to enterprise.enterprise_contract. Business justification: Enterprise invoices are generated against specific enterprise contracts governing minimum commitments, billing cycles, and penalty clauses. Contract compliance reporting and invoice-to-contract reconc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseContract .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Net total of all billing adjustments, credits, and discounts applied to the invoice. Can be negative (credit to customer) or positive (additional charge). Includes dispute resolutions, goodwill credits, and promotional adjustments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billDate rdf:type rdf:Property ;
    rdfs:label 'Bill Date' ;
    rdfs:comment 'The date on which the invoice was generated and issued to the customer. Represents the principal business event timestamp for the invoice. Used as the reference date for payment due date calculation and revenue recognition.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billFormat rdf:type rdf:Property ;
    rdfs:label 'Bill Format' ;
    rdfs:comment 'The level of detail included in the customer-facing billing statement. Detailed includes full CDR (Call Detail Record) itemization; Summary shows charge categories only; Itemized shows line-item charges without full CDR detail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The last day of the billing cycle period covered by this invoice. Defines the end boundary for all charges, usage, and credits included in the invoice.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The first day of the billing cycle period covered by this invoice. Defines the start boundary for all charges, usage, and credits included in the invoice.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingSegment rdf:type rdf:Property ;
    rdfs:label 'Billing Segment' ;
    rdfs:comment 'Customer segment classification for this invoice, used for segmented revenue reporting, ARPU (Average Revenue Per User) analysis, and MRR (Monthly Recurring Revenue) tracking. MVNO (Mobile Virtual Network Operator) segment covers reseller billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Current Charges Amount' ;
    rdfs:comment 'Total of all new charges incurred during the current billing period before taxes and fees. Includes recurring subscription charges, usage charges, and one-time charges rated by Amdocs Revenue Management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The channel through which the invoice is delivered to the customer. Drives the bill presentment workflow in Amdocs Revenue Management. Email: electronic PDF delivery; Paper: physical mail; Portal: self-service web/app; SMS: summary notification; API: machine-to-machine for enterprise customers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The portion of the total invoice amount that is under active dispute by the customer. May be less than or equal to total_amount_due. Used for revenue assurance reporting and collections hold management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which the customer must settle the invoice to avoid late payment charges or dunning actions. Calculated from bill_date plus the payment terms defined on the billing account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level for overdue invoices, ranging from 0 (not in dunning) to the maximum configured dunning step. Drives automated collections actions in Amdocs Revenue Management including reminder notices, service suspension warnings, and write-off triggers.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feesAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Amount' ;
    rdfs:comment 'Total regulatory fees, administrative fees, and surcharges applied to the invoice that are distinct from taxes. Includes items such as regulatory recovery fees, network access fees, and late payment fees.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice reference number issued to the customer. Printed on the billing statement and used for customer service inquiries and payment references. Sourced from Amdocs Revenue Management invoicing module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Drives collections workflows, dunning processes, and revenue recognition in Amdocs Revenue Management. Valid states: draft (being prepared), issued (sent to customer), paid (fully settled), disputed (customer raised dispute), written_off (deemed uncollectable), cancelled (voided before issuance).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice by its business purpose. Standard: regular periodic billing; Final: issued upon account closure; Interim: mid-cycle billing; Credit Note: net credit to customer; Debit Note: additional charge; Pro Forma: estimate before final billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this invoice is currently under a customer billing dispute. True when a dispute has been raised and is pending resolution. Used to flag invoices for collections hold and dispute management workflows.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaperless rdf:type rdf:Property ;
    rdfs:label 'Is Paperless' ;
    rdfs:comment 'Indicates whether the customer has opted into paperless billing for this invoice. True when delivery_channel is email or portal. Used for sustainability reporting and paper bill fee waiver logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The precise timestamp when the invoice was dispatched to the customer via the configured delivery channel. Distinct from bill_date (the billing date) and created_timestamp (record creation). Used for SLA (Service Level Agreement) compliance on bill delivery timeliness.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latePaymentFee rdf:type rdf:Property ;
    rdfs:label 'Late Payment Fee' ;
    rdfs:comment 'Fee assessed on this invoice for late payment of a prior invoice, per the terms and conditions of the customer\'s service agreement. Included in fees_amount but tracked separately for fee revenue reporting and customer dispute management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes or remarks associated with the invoice, entered by billing operations staff. May include reasons for manual adjustments, special billing arrangements, or customer communication notes. Not displayed on the customer-facing bill.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on this invoice, calculated as total_amount_due minus paid_amount. Used for accounts receivable aging, collections prioritization, and MRR (Monthly Recurring Revenue) reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount paid by the customer against this specific invoice to date. Used to calculate the outstanding balance and determine if the invoice is fully or partially settled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'The timestamp when the invoice was fully settled and transitioned to paid status. Null for unpaid or partially paid invoices. Used for days-sales-outstanding (DSO) calculation and payment behavior analytics.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paperBillFee rdf:type rdf:Property ;
    rdfs:label 'Paper Bill Fee' ;
    rdfs:comment 'Fee charged to the customer for receiving a paper invoice by mail, where applicable. Zero or null for customers enrolled in paperless billing. Supports paperless billing adoption tracking and fee revenue reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentsReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payments Received Amount' ;
    rdfs:comment 'Total payments and credits received from the customer since the last invoice, applied against the previous balance. Reduces the amount owed on the current statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Balance Amount' ;
    rdfs:comment 'Outstanding balance carried forward from the prior billing cycle before any new charges or payments are applied. Represents the opening balance on the current invoice statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The accounting date on which revenue from this invoice is recognized in the general ledger per IFRS 15 / ASC 606 revenue recognition standards. May differ from bill_date for deferred or advance billing scenarios.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceInvoiceRef rdf:type rdf:Property ;
    rdfs:label 'Source Invoice Ref' ;
    rdfs:comment 'The native invoice identifier from the originating source system (Amdocs or Comverse ONE) before transformation into the enterprise data lakehouse. Enables traceability and reconciliation between the Silver Layer and the operational billing system.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record that generated this invoice. Amdocs Revenue Management for postpaid billing; Comverse ONE for prepaid balance settlement invoices; Manual for adjustments entered directly by billing operations teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax charges applied to the invoice including all applicable federal, state, local, and regulatory taxes and surcharges (e.g., USF, E911, sales tax). Calculated by the tax engine within Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'The net total amount the customer must pay, calculated as previous_balance_amount minus payments_received_amount plus current_charges_amount plus adjustments_amount plus tax_amount plus fees_amount. This is the authoritative amount printed on the customer-facing billing statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this invoice record was last modified in the source billing system. Tracks the most recent update for change data capture (CDC) processing in the Databricks Silver Layer pipeline. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual invoice line item within the Amdocs Revenue Management system. Serves as the primary key for the invoice_line data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addonId rdf:type rdf:Property ;
    rdfs:label 'Addon Id' ;
    rdfs:comment 'Foreign key linking to product.addon. Business justification: Invoice lines for addon charges must reference the addon product for addon revenue reporting, attach rate analysis, addon profitability tracking, and product portfolio optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Addon .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Foreign key linking to billing.adjustment. Business justification: An invoice_line can represent a credit or debit adjustment applied to the invoice. Linking invoice_line to its source adjustment enables adjustment-to-invoice-line traceability for audit, dispute reso' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:billingChargeId rdf:type rdf:Property ;
    rdfs:label 'Billing Charge Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_charge. Business justification: An invoice_line is the rendered representation of a billing_charge on an invoice. Linking invoice_line back to its originating billing_charge enables charge-to-invoice traceability, dispute resolution' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCharge .

ind:billingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Id' ;
    rdfs:comment 'Reference to an active or resolved billing dispute record associated with this invoice line item. Populated when a customer has raised a dispute against this specific charge. Enables dispute-to-line traceability for collections and customer service operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Foreign key linking to product.bundle. Business justification: Itemized customer invoices must display bundle-level charges with bundle name and discount breakdown. Telecom billing systems require invoice_line to reference the bundle product for customer-facing b' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:catalogItemId rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Invoice lines must reference the catalog item being billed for revenue recognition by product, regulatory reporting, margin analysis, and product performance dashboards. Essential for commercial produ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:fiberCableId rdf:type rdf:Property ;
    rdfs:label 'Fiber Cable Id' ;
    rdfs:comment 'Foreign key linking to inventory.fiber_cable. Business justification: Wholesale customers are billed for fiber lease by cable segment. Required for wholesale fiber lease billing, dark fiber revenue recognition, and infrastructure monetization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiberCable .

ind:inventoryCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: Invoice lines for equipment rental, installation fees, damage charges, or replacement fees must reference the specific CPE asset (modem, router, set-top box). Required for itemized equipment billing a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:ipAddressPoolId rdf:type rdf:Property ;
    rdfs:label 'Ip Address Pool Id' ;
    rdfs:comment 'Foreign key linking to inventory.ip_address_pool. Business justification: Static IP address assignment is a billable line item for enterprise customers. Linking invoice_line to ip_address_pool enables per-pool revenue tracking, static IP charge validation, and enterprise bi' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:msisdnRangeId rdf:type rdf:Property ;
    rdfs:label 'Msisdn Range Id' ;
    rdfs:comment 'Foreign key linking to inventory.msisdn_range. Business justification: Number porting fees, premium number charges, or vanity number fees must reference the MSISDN range. Required for number-related billing, regulatory fee allocation, and premium number revenue tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsisdnRange .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: Invoice lines should reference the offering sold (commercial package) for sales performance tracking, commission calculation, offer-level revenue reporting, and promotional campaign effectiveness anal' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:ontAssetId rdf:type rdf:Property ;
    rdfs:label 'Ont Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.ont_asset. Business justification: Fiber service invoice lines for ONT installation, rental, or equipment charges must reference the specific ONT. Required for fiber equipment billing, asset tracking, and customer service reconciliatio' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:originalLineInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line item that this adjustment, credit, or reversal line corrects or offsets. Populated only for adjustment and reversal lines to maintain the audit chain between original charges and their corrections. Enables complete billing history reconstruction.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to sales.promotion. Business justification: Promotional discounts are applied at the invoice line level in telecom billing. Linking invoice_line to promotion enables promotion redemption tracking, discount validation, and promotion ROI reportin' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:ratePlanId rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_plan. Business justification: invoice_line has a rating_plan_code string attribute that is a denormalized reference to the rate_plan entity. Normalizing this to a proper FK rate_plan_id -> billing.rate_plan.rate_plan_id enables JO' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatePlan .

ind:ratedEventId rdf:type rdf:Property ;
    rdfs:label 'Rated Event Id' ;
    rdfs:comment 'Foreign key linking to billing.rated_event. Business justification: An invoice_line for usage charges is derived from a rated_event (CDR-based usage). Linking invoice_line to its source rated_event enables end-to-end traceability from raw CDR through rating to invoice' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatedEvent .

ind:simStockId rdf:type rdf:Property ;
    rdfs:label 'Sim Stock Id' ;
    rdfs:comment 'Foreign key linking to inventory.sim_stock. Business justification: Invoice line items for SIM activation fees, SIM replacement charges, and eSIM provisioning fees reference a specific SIM asset. This link enables per-SIM invoice line traceability, SIM cost recovery a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SimStock .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.enterprise_site. Business justification: Enterprise invoice lines must be attributed to specific sites for site-level cost allocation and internal chargeback reporting. Multi-site enterprise customers require per-site invoice line breakdowns' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:specId rdf:type rdf:Property ;
    rdfs:label 'Spec Id' ;
    rdfs:comment 'Reference to the product or service catalog item that generated this charge or credit line. Links to the Netcracker Product Catalog to identify the specific product offering (e.g., 5G NR data plan, VoLTE bundle, FTTH broadband).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Spec .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Reference to the specific service subscription or agreement that originated this charge. Links to the customer\'s active service contract for wireless, broadband, IPTV, or other telecom services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_subscription. Business justification: Invoice lines are generated per addon subscription in telecom. Direct FK to customer_subscription enables subscription-level billing reconciliation, addon charge accuracy audits, and customer self-ser' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:tapRecordId rdf:type rdf:Property ;
    rdfs:label 'Tap Record Id' ;
    rdfs:comment 'Foreign key linking to interconnect.tap_record. Business justification: Retail invoice lines for roaming services must trace to originating TAP records for customer dispute investigation and retail-to-wholesale charge reconciliation—required for proving charge validity to' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapRecord .

ind:transmissionLinkId rdf:type rdf:Property ;
    rdfs:label 'Transmission Link Id' ;
    rdfs:comment 'Foreign key linking to network.transmission_link. Business justification: Circuit invoice auditing: invoice lines for leased-line and circuit services must reference the specific transmission_link to support itemized circuit billing, regulatory circuit cost reporting, and e' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionLink .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any billing adjustment or credit applied to this line item. Examples include billing error corrections, goodwill credits, SLA breach credits, or dispute resolutions. Populated only when charge_type is \'adjustment\' or \'credit\'. Used for revenue assurance and dispute analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdrReference rdf:type rdf:Property ;
    rdfs:label 'Cdr Reference' ;
    rdfs:comment 'The originating CDR (Call Detail Record) or usage event reference identifier that generated this charge line. Links the billed charge back to the raw network usage event for revenue assurance, dispute resolution, and audit purposes. Sourced from the Amdocs mediation layer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'High-level service category to which this charge belongs, enabling revenue segmentation and MRR/ARPU reporting by service type. Maps to the telecom service taxonomy used in Amdocs Revenue Management. [ENUM-REF-CANDIDATE: voice|data|sms|roaming|equipment|interconnect|content|broadband|iptv|other — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Human-readable description of the charge or credit line item as it appears on the customer\'s itemized bill. Examples include \'Monthly 5G Unlimited Plan\', \'International Roaming Data - Zone A\', \'Late Payment Fee\', or \'Loyalty Discount Credit\'. Used for bill presentment and dispute resolution.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Charge Period End' ;
    rdfs:comment 'The end date of the billing period covered by this charge line item. For recurring charges, this is the last day of the service period. For usage charges, this is the end of the usage aggregation window. Used alongside charge_period_start for proration and revenue recognition period allocation.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Charge Period Start' ;
    rdfs:comment 'The start date of the billing period covered by this charge line item. For recurring charges, this is the first day of the service period. For usage charges, this is the start of the usage aggregation window. Essential for proration calculations and dispute resolution.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the charge or credit line item indicating its billing nature. Recurring charges apply each billing cycle (e.g., monthly plan fee), one_time charges are non-recurring (e.g., activation fee), usage charges are consumption-based (e.g., CDR-rated calls/data), adjustments correct prior billing errors, credits reduce the customer\'s balance, and tax lines represent applicable tax amounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The monetary value of any discount applied to this line item, including promotional discounts, loyalty discounts, bundle discounts, or negotiated contract discounts. A positive value reduces the net charge. Sourced from Amdocs Revenue Management discount engine.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'The promotional or contractual discount code applied to this line item. References the specific discount offer or loyalty program that generated the discount_amount. Used for discount effectiveness analysis and revenue leakage detection in revenue assurance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The pre-discount, pre-tax charge amount for this line item, calculated as rated_quantity multiplied by unit_rate for usage charges, or the flat recurring/one-time fee for non-usage charges. Represents the full list price before any adjustments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates whether this charge line has been prorated to reflect a partial billing period. True when the customer activated, deactivated, or changed a service mid-cycle, resulting in a partial-period charge. Used for billing accuracy validation and customer dispute resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this charge is a recurring Monthly Recurring Revenue (MRR) component. True for subscription-based charges that appear each billing cycle (e.g., monthly plan fees, equipment rental). Used for MRR reporting and revenue forecasting.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this line item is subject to taxation. False for tax-exempt charges such as certain government or non-profit customer lines, or for line items that are themselves tax charges. Used by the Amdocs tax engine and for regulatory tax reporting.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent invoice. Used for itemized bill presentation, dispute resolution, and maintaining consistent line ordering across billing cycles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this invoice line item. Active lines are valid billed charges. Disputed lines are under customer dispute investigation. Adjusted lines have been corrected. Cancelled lines have been voided. Reversed lines have been credited back. Written_off lines have been deemed uncollectable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The charge amount after applying discounts but before tax. Calculated as gross_amount minus discount_amount. Represents the taxable base for this line item and is the primary amount used for revenue recognition per IFRS 15.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaidIndicator rdf:type rdf:Property ;
    rdfs:label 'Prepaid Indicator' ;
    rdfs:comment 'Indicates whether this charge line originated from a prepaid account managed by Comverse ONE real-time rating and balance management, as opposed to a postpaid account managed by Amdocs Revenue Management. Drives different revenue recognition and reporting treatment.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the rated_quantity field. Specifies the dimension in which consumption is expressed (e.g., minutes for voice, MB/GB for data, SMS for messaging). Essential for correct interpretation of the rated quantity in billing analytics and dispute resolution. [ENUM-REF-CANDIDATE: minutes|seconds|MB|GB|TB|SMS|units|events|days|months — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rated Quantity' ;
    rdfs:comment 'The metered or rated quantity of consumption that forms the basis for this charge. Represents units consumed such as minutes of voice calls, megabytes of data, number of SMS messages, or number of pay-per-view events. Sourced from the Amdocs rating engine after processing CDRs.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rating Timestamp' ;
    rdfs:comment 'The date and time when the Amdocs rating engine processed and rated this charge. Provides an audit trail for the rating event and is used to reconcile rated charges against CDR processing windows in revenue assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roamingIndicator rdf:type rdf:Property ;
    rdfs:label 'Roaming Indicator' ;
    rdfs:comment 'Indicates whether this charge was incurred while the customer was roaming on a visited network outside their home network. True for roaming charges subject to GSMA TAP/NRTRDE inter-operator settlement and IOT (Inter-Operator Tariff) pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Service Identifier' ;
    rdfs:comment 'The specific service instance identifier associated with this charge, such as the MSISDN (mobile number), IMSI, broadband circuit ID, or IPTV subscriber ID. Enables line-level traceability to the specific service that generated the charge.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineRef rdf:type rdf:Property ;
    rdfs:label 'Source System Line Ref' ;
    rdfs:comment 'The native line item identifier from the originating source system (Amdocs Revenue Management or Comverse ONE) before surrogate key assignment in the Databricks Silver Layer. Enables lineage tracing back to the operational system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction or tax type code applied to this line item, as determined by the Amdocs tax engine. Examples include federal excise tax codes, state sales tax codes, USF (Universal Service Fund) surcharge codes, or VAT codes for international customers. Maps to the applicable tax authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate as a decimal fraction (e.g., 0.0875 for 8.75%) applied to the net_amount to compute the tax_amount for this line item. Sourced from the tax jurisdiction configuration in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The final billed amount for this line item inclusive of all taxes and after all discounts. Calculated as net_amount plus tax_amount. This is the amount that contributes to the invoice total and the customer\'s payable balance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The per-unit price applied to the rated quantity to compute the gross charge amount. Sourced from the Amdocs rating engine\'s tariff tables. For example, the per-minute rate for international calls or the per-GB rate for data overage charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitedNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Visited Network Code' ;
    rdfs:comment 'The Public Land Mobile Network (PLMN) code of the visited operator\'s network where roaming usage was consumed. Composed of MCC (Mobile Country Code) and MNC (Mobile Network Code). Required for GSMA TAP inter-operator settlement and roaming revenue reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment record in the billing system. Primary key for the payment data product. Sourced from Amdocs Collections module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:creditNoteId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_note. Business justification: A payment record can represent the application of a credit note to a customer\'s account balance. Linking payment to the originating credit_note enables credit note redemption tracking and ensures cred' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditNote .

ind:originalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Id' ;
    rdfs:comment 'Reference to the original payment record that this record reverses, refunds, or adjusts. Enables chargeback and reversal lineage tracing. Null for original (non-derived) payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:paymentArrangementId rdf:type rdf:Property ;
    rdfs:label 'Payment Arrangement Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_arrangement. Business justification: A payment can be made as an installment under a payment arrangement (structured repayment plan for overdue accounts). Linking payment to its governing payment_arrangement enables installment tracking,' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentArrangement .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross monetary amount of the payment as submitted by the customer or payment processor, before any adjustments or fees. Expressed in the billing currency. Core field for revenue reconciliation and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The calendar date on which this specific payment application was recorded in the billing system. Belongs to the application event, not to the payment or invoice alone.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle state of this payment application record. Tracks whether the application is pending processing, successfully applied, reversed (e.g., due to payment reversal), or failed.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been successfully applied to outstanding invoice balances or account credits. May differ from payment_amount if partially applied or pending allocation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Alphanumeric authorization or approval code returned by the payment gateway or card network upon successful transaction authorization. Used for dispute resolution, chargeback processing, and reconciliation with payment processors.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number used for direct debit or bank transfer payments. Stored as a masked identifier for verification. Null for non-bank payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'Bank routing number (ABA/ACH in the US) or sort code (UK) or BIC/SWIFT code for international transfers, identifying the financial institution for direct debit and bank transfer payments. Null for non-bank payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company\'s functional (base) currency using the exchange_rate at the time of payment. Used for consolidated financial reporting and revenue recognition in the base currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing cycle period that this payment is intended to cover. Used alongside billing_period_start for MRR attribution and period-based revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing cycle period that this payment is intended to cover. Used for MRR attribution and period-based revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'Last four digits of the payment card number used for the transaction. Stored as a masked identifier for customer service verification and reconciliation. Full card number is never stored per PCI DSS requirements.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Card network brand for credit or debit card payments (e.g., Visa, Mastercard, Amex). Null for non-card payment methods. Used for interchange fee analysis and payment mix reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The customer-facing interface or touchpoint through which the payment was submitted. Distinct from payment_method (instrument). Values: ivr (Interactive Voice Response), web (self-service portal), mobile_app, agent (call centre or retail agent), auto_pay (recurring automated), retail_store, kiosk. Used for channel analytics and cost-to-collect reporting. [ENUM-REF-CANDIDATE: ivr|web|mobile_app|agent|auto_pay|retail_store|kiosk — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied to convert the payment amount from the transaction currency to the billing base currency at the time of payment. Relevant for international customers and roaming settlement. 1.0 for same-currency transactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateway rdf:type rdf:Property ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Name or identifier of the external payment gateway or processor that handled the transaction (e.g., Stripe, Adyen, PayPal, WorldPay, internal BSS gateway). Used for reconciliation, gateway performance monitoring, and fee analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutoPay rdf:type rdf:Property ;
    rdfs:label 'Is Auto Pay' ;
    rdfs:comment 'Indicates whether this payment was collected automatically via a recurring auto-pay mandate (True) or was manually initiated by the customer or agent (False). Used for auto-pay adoption analytics and churn risk modelling.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialPayment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Payment' ;
    rdfs:comment 'Indicates whether this payment covers only a portion of the total outstanding balance (True) or fully settles the billed amount (False). Used in collections and dunning workflows to identify accounts with partial payment arrangements.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Received Amount' ;
    rdfs:comment 'Net amount received after deducting payment processing fees from the gross payment_amount. Represents the actual funds credited to the telco\'s account. Used for cash flow reporting and revenue assurance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The calendar date on which the payment was received or initiated by the customer. This is the principal business event date used for revenue recognition, aging analysis, and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the payment transaction. \'pending\' — received but not yet confirmed; \'cleared\' — funds confirmed; \'reversed\' — payment reversed/chargeback; \'failed\' — transaction declined or errored; \'refunded\' — amount returned to customer; \'disputed\' — under dispute investigation. Drives collections and dunning workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment by its business purpose: standard (regular bill payment), advance (payment before bill issuance), deposit (security deposit), refund (return of funds to customer), reversal (cancellation of a prior payment), adjustment (billing correction). Drives accounting treatment and revenue recognition.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the payment gateway or processor for handling this transaction. Deducted from the gross payment amount to derive net received funds. Used for payment cost analysis and OPEX reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the payment transaction was received and recorded in the Amdocs Collections system. Used for real-time reconciliation and SLA tracking.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this payment transaction. Used by customers and agents to track and reconcile payments. Sourced from Amdocs Collections module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Business reason code or description explaining why a payment was reversed or charged back (e.g., insufficient_funds, duplicate_payment, customer_dispute, fraud, bank_error). Populated only when payment_status is \'reversed\' or \'failed\'.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the payment reversal or chargeback was processed. Null for non-reversed payments. Used for collections workflow timing and dispute SLA tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the payment funds were actually settled and confirmed by the bank or payment processor. May differ from payment_date for card and bank transfer payments due to clearing cycles. Used for cash flow and revenue recognition reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the external payment gateway, bank, or payment processor. Used to cross-reference and reconcile payments with third-party payment systems and bank statements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount not yet allocated to any invoice or charge. Represents an overpayment credit or advance payment held on the billing account pending future allocation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date from which the payment is considered valid for interest and balance calculations. Used in financial accounting and bank reconciliation. May differ from payment_date and settlement_date.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Unique alphanumeric code of the prepaid voucher or gift card redeemed as payment. Applicable only when payment_method is \'voucher\'. Used for voucher reconciliation and prepaid balance management in Comverse ONE.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Agreement Id' ;
    rdfs:comment 'Foreign key linking to interconnect.carrier_agreement. Business justification: Roaming revenue assurance and inter-operator cost attribution require directly linking rated roaming events to the governing carrier agreement. Analysts reconcile retail charges against wholesale agre' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierAgreement .

ind:cdrId rdf:type rdf:Property ;
    rdfs:label 'Cdr Id' ;
    rdfs:comment 'Reference to the originating raw CDR, IPDR, or partner usage feed record from which this rated event was produced. Bridges the CDR domain to the billing/financial domain and enables traceability back to the network event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cdr .

ind:lawfulInterceptOrderId rdf:type rdf:Property ;
    rdfs:label 'Lawful Intercept Order Id' ;
    rdfs:comment 'Foreign key linking to compliance.lawful_intercept_order. Business justification: Rated events (CDRs) are delivered to law enforcement under lawful intercept orders. Real business process: LEA requests require CDR extraction with chain of custody tracking. Compliance teams link del' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LawfulInterceptOrder .

ind:managedServiceId rdf:type rdf:Property ;
    rdfs:label 'Managed Service Id' ;
    rdfs:comment 'Foreign key linking to enterprise.managed_service. Business justification: Usage events (data consumption, API calls, voice minutes) must link to managed service instances for capacity planning, SLA performance measurement, usage-based billing validation, and service-specifi' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedService .

ind:originalRatedEventId rdf:type rdf:Property ;
    rdfs:label 'Original Rated Event Id' ;
    rdfs:comment 'Reference to the original rated event record that this record supersedes or corrects. Populated for re-rated or reversed events to maintain the audit chain. Enables before/after comparison for revenue assurance and dispute resolution.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatedEvent .

ind:prepaidBalanceId rdf:type rdf:Property ;
    rdfs:label 'Prepaid Balance Id' ;
    rdfs:comment 'Foreign key linking to billing.prepaid_balance. Business justification: A rated_event for prepaid subscribers directly consumes from a prepaid_balance. Linking rated_event to the prepaid_balance it debited enables real-time balance deduction traceability and prepaid usage' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrepaidBalance .

ind:ranCellId rdf:type rdf:Property ;
    rdfs:label 'Ran Cell Id' ;
    rdfs:comment 'The network cell or base station identifier (e.g., eNodeB/gNB cell ID) where the subscriber was served during this event. Used for network-level usage analytics, RAN capacity planning, and geographic revenue reporting. Sourced from CDR network element data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RanCell .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Foreign key linking to interconnect.rate. Business justification: The rating engine applies a specific interconnect rate to produce each roaming rated_event charge. Linking rated_event to the exact interconnect.rate record used enables roaming cost reconciliation, r' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:sliceId rdf:type rdf:Property ;
    rdfs:label 'Slice Id' ;
    rdfs:comment 'Foreign key linking to network.slice. Business justification: 5G slice-differentiated charging: rated events for services delivered over a specific network slice must reference that slice for slice-level usage analytics, per-slice revenue reporting, and charging' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Slice .

ind:accessPointName rdf:type rdf:Property ;
    rdfs:label 'Access Point Name' ;
    rdfs:comment 'The APN used by the subscriber for data sessions, identifying the packet data network gateway and service context (e.g., internet, enterprise VPN, IMS). Used for data service classification, QoS policy application, and DPI-based rating.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleConsumed rdf:type rdf:Property ;
    rdfs:label 'Bundle Consumed' ;
    rdfs:comment 'Indicates whether this rated event was charged against an included bundle allowance (True) or rated as an out-of-bundle/overage charge (False). Used to track bundle utilization, identify overage revenue, and support customer usage analytics.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calledPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Called Party Number' ;
    rdfs:comment 'The destination number (B-party) dialed or messaged by the subscriber for voice calls and SMS events. Used for inter-operator settlement, fraud analysis, and regulatory lawful intercept compliance. Classified as confidential PII.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'The gross charge amount applied to this rated event before discounts and taxes, in the billing currency. Computed by the rating engine based on the applicable rate plan tier and rated volume/duration. Core financial field for revenue recognition and invoice line generation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'The reference number of the billing dispute or inter-operator dispute case associated with this rated event, if applicable. Populated when rating_status = \'disputed\'. Links to the dispute management workflow in Amdocs or ServiceNow ITSM for resolution tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDirection rdf:type rdf:Property ;
    rdfs:label 'Event Direction' ;
    rdfs:comment 'Indicates the origination direction of the usage event. MO (Mobile Originated) = subscriber initiated the call/session; MT (Mobile Terminated) = subscriber received the call/session. Relevant for voice and SMS rating and inter-operator settlement.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'The date and time when the usage event concluded (e.g., call release time, data session termination). Used to compute event duration and for billing cycle boundary determination.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Externally-known business identifier assigned by the rating engine or source OSS/BSS system to uniquely identify this rated event within a billing cycle or batch. Used for reconciliation, dispute resolution, and inter-operator settlement references.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'The date and time when the usage event began (e.g., call answer time, data session start, SMS submission time). This is the principal real-world event time used for billing cycle allocation, time-of-day rating, and CDR correlation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the usage event by service type. Drives rating logic selection and reporting segmentation. Examples: voice (MO/MT calls), SMS, data (packet sessions), roaming (visited network), content (OTT/IPTV), IoT (machine-to-machine). [ENUM-REF-CANDIDATE: voice|sms|data|roaming|content|iot|mms|video — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePlmn rdf:type rdf:Property ;
    rdfs:label 'Home Plmn' ;
    rdfs:comment 'The MCC+MNC code identifying the subscriber\'s home network operator (HPLMN). Used to determine domestic vs. roaming status and to apply correct inter-operator tariffs (IOT) for roaming settlement via GSMA TAP/NRTRDE.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imei rdf:type rdf:Property ;
    rdfs:label 'Imei' ;
    rdfs:comment 'The IMEI of the device used during this usage event. Used for device-level analytics, fraud detection (stolen device usage), and regulatory reporting. Classified as confidential device identifier.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsi rdf:type rdf:Property ;
    rdfs:label 'Imsi' ;
    rdfs:comment 'The IMSI uniquely identifying the SIM/subscriber on the network. Used for roaming settlement, fraud detection, and subscriber authentication correlation. Classified as restricted PII as it uniquely identifies a subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interOperatorCharge rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Charge' ;
    rdfs:comment 'The inter-operator tariff (IOT) charge amount payable to or receivable from the visited network operator for roaming events, in the settlement currency. Populated only for roaming events (is_roaming = true). Used for GSMA TAP/NRTRDE wholesale settlement and interconnect accounting.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRoaming rdf:type rdf:Property ;
    rdfs:label 'Is Roaming' ;
    rdfs:comment 'Flag indicating whether this usage event occurred while the subscriber was roaming on a visited network (VPLMN). True = roaming event subject to inter-operator settlement; False = domestic event. Drives roaming-specific rating rules and GSMA TAP/NRTRDE processing.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msisdn rdf:type rdf:Property ;
    rdfs:label 'Msisdn' ;
    rdfs:comment 'The subscriber\'s MSISDN (phone number in E.164 format) associated with this usage event. Primary subscriber identifier for rating, billing, and inter-operator settlement. Classified as restricted PII as it directly identifies an individual subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Amount' ;
    rdfs:comment 'The final net charge amount for this rated event after applying discounts and taxes (charge_amount - discount_amount + tax_amount) in the billing currency. This is the amount posted to the customer invoice and used for revenue recognition and ARPU calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTechnology rdf:type rdf:Property ;
    rdfs:label 'Network Technology' ;
    rdfs:comment 'The radio access or network technology used to deliver the service for this event (e.g., 4G LTE, 5G NR, VoLTE, FTTH/GPON). Used for technology-based revenue analytics, network capacity planning, and QoS reporting. [ENUM-REF-CANDIDATE: 2G|3G|4G_LTE|5G_NR|VoLTE|VoIP|WiFi|FTTH|unknown — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Rated Duration Seconds' ;
    rdfs:comment 'The billable duration of the usage event in seconds as determined by the rating engine after applying rounding rules (e.g., per-second, per-minute rounding). Applicable for voice and video call events. May differ from raw CDR duration due to rating rounding rules.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Rated Unit Count' ;
    rdfs:comment 'The number of billable units consumed in this event as determined by the rating engine. For SMS: number of message segments; for content: number of items; for IoT: number of transactions. Complements rated_duration_seconds and rated_volume_bytes for non-time/non-data event types.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Rated Volume Bytes' ;
    rdfs:comment 'The billable data volume in bytes as determined by the rating engine after applying any volume rounding or threshold rules. Applicable for data, roaming data, and IoT events. Used for bundle consumption tracking and overage charge calculation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingEngine rdf:type rdf:Property ;
    rdfs:label 'Rating Engine' ;
    rdfs:comment 'Identifies the rating system that processed and priced this event. \'amdocs\' = Amdocs Revenue Management batch/real-time rating; \'comverse_one\' = Comverse ONE prepaid real-time rating; \'partner_feed\' = rated by a partner/MVNO; \'manual\' = manually rated adjustment. Used for data lineage and revenue assurance.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMode rdf:type rdf:Property ;
    rdfs:label 'Rating Mode' ;
    rdfs:comment 'Indicates whether this event was rated in real-time (online charging, e.g., Comverse ONE prepaid), batch mode (Amdocs post-processing), or offline (delayed/manual). Affects revenue recognition timing and prepaid balance deduction sequencing.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle state of the rated event within the billing workflow. \'rated\' = successfully priced; \'re_rated\' = repriced after correction; \'disputed\' = under customer or inter-operator dispute; \'written_off\' = revenue written off; \'pending\' = awaiting rating completion; \'rejected\' = failed rating validation. [ENUM-REF-CANDIDATE: rated|re_rated|disputed|written_off|pending|rejected — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTier rdf:type rdf:Property ;
    rdfs:label 'Rating Tier' ;
    rdfs:comment 'The specific pricing tier or band within the rate plan applied to this event (e.g., TIER_1_BUNDLE, TIER_2_OVERAGE, PEAK, OFF_PEAK, ROAM_ZONE_A). Indicates which step of a tiered or time-of-day pricing structure was used. Critical for revenue assurance and rate plan analytics.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reRatingReason rdf:type rdf:Property ;
    rdfs:label 'Re Rating Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why this event was re-rated (e.g., rate plan correction, tariff update, CDR amendment, dispute resolution). Populated only when rating_status = \'re_rated\'. Essential for revenue assurance audit trails.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the roaming event occurred. Populated only when is_roaming = true. Used for roaming revenue reporting, IOT application, and regulatory compliance with visited country regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingPlmn rdf:type rdf:Property ;
    rdfs:label 'Serving Plmn' ;
    rdfs:comment 'The MCC+MNC code of the network that served the subscriber during this event. For domestic events equals the home PLMN; for roaming events identifies the visited network (VPLMN). Critical for inter-operator settlement and roaming IOT application.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapFileReference rdf:type rdf:Property ;
    rdfs:label 'Tap File Reference' ;
    rdfs:comment 'The GSMA TAP3 file identifier referencing the inter-operator roaming data exchange file from which this roaming rated event was sourced. Used for roaming settlement reconciliation, dispute management, and NRTRDE compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to order.amendment. Business justification: Early termination fees, plan change charges, and contract modification fees are triggered by specific order amendments. Telecom billing operations and revenue assurance require charge-to-amendment tra' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:discountSchemeId rdf:type rdf:Property ;
    rdfs:label 'Discount Scheme Id' ;
    rdfs:comment 'Foreign key linking to enterprise.discount_scheme. Business justification: Billing charges reflect applied enterprise discount schemes; tracing each charge to the specific discount_scheme is required for discount audit trails, billing dispute resolution, and contract complia' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiscountScheme .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Reference to the originating order that triggered this charge, such as a new activation, upgrade, or equipment purchase order managed in Oracle Communications Order and Service Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to order.line. Business justification: Activation fees, device installment charges, and one-time order charges must be attributed to the specific order line that triggered them. Telecom billing reconciliation and revenue assurance reports ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:outageRecordId rdf:type rdf:Property ;
    rdfs:label 'Outage Record Id' ;
    rdfs:comment 'Foreign key linking to assurance.outage_record. Business justification: Service credit charges issued due to network outages must reference the outage_record that justified the credit. This supports regulatory compliance reporting, customer dispute resolution, and financi' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutageRecord .

ind:reversalChargeBillingChargeId rdf:type rdf:Property ;
    rdfs:label 'Reversal Charge Billing Charge Id' ;
    rdfs:comment 'Reference to the original charge that this record reverses or credits. Populated only for reversal/credit adjustment charges. Enables audit trail linking of original charge to its reversal for revenue assurance.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCharge .

ind:svcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Svc Instance Id' ;
    rdfs:comment 'Reference to the subscribed product or service instance that originated this charge (e.g., a specific mobile plan, broadband subscription, or equipment). Links charge to the Product and Service Catalog in Netcracker OSS/BSS.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:taskId rdf:type rdf:Property ;
    rdfs:label 'Task Id' ;
    rdfs:comment 'Foreign key linking to order.task. Business justification: Field technician visit tasks generate installation fees, missed appointment charges, and truck-roll charges. Telecom field operations billing requires linking the charge to the specific workforce task' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to workforce.work_order. Business justification: Field service activities (installations, repairs, upgrades) generate billing charges (truck roll fees, labor, materials). Linking billing_charge to work_order enables work-order cost recovery billing,' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status for charges requiring authorization before posting, particularly manual adjustments and credits above threshold amounts. not_required for system-generated charges; pending_approval, approved, or rejected for manual charges requiring supervisor sign-off.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the charge was approved by an authorized agent or supervisor. Null for system-generated charges or those not requiring approval. Supports audit trail and SOX compliance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeNumber rdf:type rdf:Property ;
    rdfs:label 'Charge Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the charge as displayed on customer bills and used in dispute resolution and customer service interactions within Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeSource rdf:type rdf:Property ;
    rdfs:label 'Charge Source' ;
    rdfs:comment 'Originating system that generated or triggered this charge: amdocs (Amdocs Revenue Management automated billing), comverse (Comverse ONE prepaid/real-time charging), manual (agent-applied via CRM), order_management (Oracle OSM order fulfillment), product_catalog (Netcracker catalog-driven), crm (Salesforce CRM agent action).' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle state of the charge within the billing workflow: pending (created, not yet billed), active (approved for billing), invoiced (included on an invoice), disputed (under customer dispute), waived (forgiven without reversal), cancelled (voided before invoicing), reversed (credited back after invoicing). [ENUM-REF-CANDIDATE: pending|active|invoiced|disputed|waived|cancelled|reversed — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dunning Timestamp' ;
    rdfs:comment 'Date and time of the most recent dunning action taken on this charge (e.g., reminder notice sent, suspension warning issued). Null if dunning_level is 0. Used to track collections escalation timeline.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The business date on which the charge becomes effective and is recognized as a financial obligation on the billing account. Used for revenue recognition alignment per IFRS 15 and for billing cycle proration calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External or cross-system reference identifier for this charge, such as a partner billing reference, wholesale interconnect settlement reference (TAP/IOT), or regulatory reporting reference number. Supports reconciliation with partner and regulatory systems.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrrContribution rdf:type rdf:Property ;
    rdfs:label 'Mrr Contribution' ;
    rdfs:comment 'The portion of this charge that contributes to Monthly Recurring Revenue (MRR) calculations. For recurring charges, this equals the normalized monthly gross amount. Zero for one-time charges. Used in MRR/ARPU reporting and revenue forecasting.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment for this charge must be received to avoid late payment penalties and dunning escalation. Derived from the billing cycle due date and any applicable grace period configured in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End date of the billing period covered by this charge. Together with charge_period_start, defines the service period for which the recurring or prorated charge applies. Null for one-time charges with no period.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start date of the billing period covered by this charge. Applicable for recurring charges (e.g., monthly plan fee covering 2024-01-01 to 2024-01-31). Used for proration and revenue period matching.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationFactor rdf:type rdf:Property ;
    rdfs:label 'Proration Factor' ;
    rdfs:comment 'Decimal factor applied to the full-period charge to derive the prorated amount (e.g., 0.516129 for 16 days out of 31). Null when is_prorated is False. Used for revenue assurance validation of prorated charges.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason or trigger for the charge (e.g., NEW_ACTIVATION, PLAN_UPGRADE, EQUIPMENT_PURCHASE, LATE_PAYMENT, MANUAL_CREDIT, PRORATION). Used for revenue assurance analysis and dispute management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemChargeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Charge Code' ;
    rdfs:comment 'The native charge identifier as recorded in the originating operational system (Amdocs Revenue Management or Comverse ONE). Preserved for cross-system reconciliation, data lineage tracing, and support of revenue assurance processes.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClass rdf:type rdf:Property ;
    rdfs:label 'Tax Class' ;
    rdfs:comment 'Tax classification of the charge that determines the applicable tax treatment and rate. Drives the Amdocs tax engine calculation: taxable (standard rate), exempt (no tax), zero_rated (0% VAT/GST), reduced_rate (preferential rate), regulatory_surcharge (FCC/NTIA mandated levies).' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why this charge was waived (charge_status = \'waived\'). Examples: \'Customer goodwill gesture\', \'Service outage credit\', \'Regulatory compliance\'. Required for revenue assurance audit when charges are forgiven.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to assurance.fraud_case. Business justification: Billing adjustments that reverse fraudulent charges must reference the fraud_case that authorized the reversal. Telco fraud management teams require this link for financial reconciliation, fraud loss ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:settlementDisputeId rdf:type rdf:Property ;
    rdfs:label 'Settlement Dispute Id' ;
    rdfs:comment 'Foreign key linking to interconnect.settlement_dispute. Business justification: Billing adjustments for roaming charges must reference wholesale settlement disputes that justified the credit—required for audit trail, revenue assurance, and proving adjustments were based on valida' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementDispute .

ind:slaBreachEventId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Event Id' ;
    rdfs:comment 'Foreign key linking to assurance.sla_breach_event. Business justification: SLA penalty adjustments (credits issued to enterprise customers for SLA breaches) must reference the specific sla_breach_event that triggered them. This is a core telco enterprise billing process for ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreachEvent .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'Business category classifying the nature of the adjustment for reporting, revenue assurance, and analytics purposes. Supports MRR/ARPU impact analysis and churn management reporting. [ENUM-REF-CANDIDATE: goodwill|sla_compensation|dispute_resolution|overbilling_correction|equipment_return|service_outage|promotional|other — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for the adjustment. Used in customer communications, dispute correspondence, and financial reconciliation. Format: ADJ- followed by 10 digits.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment. Pending: awaiting approval. Approved: authorized but not yet applied to the account. Applied: posted to the billing account. Reversed: previously applied adjustment that has been undone. Expired: approved adjustment that was not applied within the validity window.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Indicates whether the adjustment increases (credit) or decreases (debit) the customer\'s account balance. A credit reduces the amount owed; a debit increases it.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the adjustment was posted and applied to the billing account balance. Populated when adjustment_status transitions to \'applied\'.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the adjustment was formally approved by the authorizing agent. Supports approval audit trails and SLA compliance for dispute resolution timelines.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalThresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Breached' ;
    rdfs:comment 'Indicates whether the adjustment amount exceeded the standard agent approval threshold, requiring escalated authorization. Supports revenue assurance controls and fraud prevention.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditNoteIssueDate rdf:type rdf:Property ;
    rdfs:label 'Credit Note Issue Date' ;
    rdfs:comment 'Date on which the credit note was formally issued to the customer. Populated only when document_type is \'credit_note\'. Determines the financial period for revenue recognition and regulatory reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Formal reference number of the customer-facing credit note document. Populated only when document_type is \'credit_note\'. Used in customer communications, accounts receivable reconciliation, and regulatory financial reporting. Format: CN- followed by 10 digits.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditedOnetimeAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Onetime Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to one-time charges such as activation fees, equipment charges, or installation fees.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedRecurringAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Recurring Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to recurring subscription or plan charges (e.g., monthly plan fees, MRR components). Supports MRR impact analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedUsageAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Usage Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to usage charges (e.g., voice, data, SMS). Supports breakdown of credited amounts by charge type for revenue assurance reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classifies the adjustment as either an internal account balance correction (internal_adjustment) or a formal customer-facing financial document (credit_note). When document_type is credit_note, the credit_note_number and credit_note_issue_date fields are populated.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date after which an approved but unapplied adjustment expires and can no longer be applied to the billing account. Supports dunning and collections workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerVisible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Visible' ;
    rdfs:comment 'Indicates whether this adjustment is visible to the customer on their invoice or self-service portal. Internal adjustments may not be customer-facing.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for the adjustment, supplementing the reason_code with contextual details such as the nature of the SLA breach, outage duration, or billing discrepancy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManagerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Manager Approval' ;
    rdfs:comment 'Indicates whether this adjustment requires manager-level approval due to amount thresholds, category sensitivity, or policy rules. Drives approval workflow routing in Amdocs Revenue Management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether this adjustment has been recognized in the financial revenue recognition process under IFRS 15. Supports financial close and revenue assurance reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which a previously applied adjustment was reversed. Populated when adjustment_status transitions to \'reversed\'. Used for revenue assurance and audit trail purposes.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'The native identifier of this adjustment record in the originating source system (e.g., Amdocs internal adjustment ID, Comverse ONE transaction reference). Supports cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReversalAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Reversal Amount' ;
    rdfs:comment 'Amount of tax reversed as part of this adjustment, applicable when the original invoice tax must be partially or fully reversed. Distinct from tax_amount which represents new tax applied to the adjustment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to sales.channel. Business justification: Disputes are raised through specific channels (retail store, online, call center). Channel-level dispute reporting is required for regulatory compliance and channel performance management. billing_dis' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Disputes are raised by specific authorized contacts (account holders, authorized users, corporate account managers). Tracking who raised dispute is critical for authorization validation, communication' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:previousDisputeBillingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Previous Dispute Billing Dispute Id' ;
    rdfs:comment 'Reference to the earlier dispute record if this is a repeat or re-opened dispute. Enables dispute lineage tracking and repeat-dispute root-cause analysis. Nullable for first-time disputes.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: When a billing dispute escalates to a regulatory complaint, the telco must submit a regulatory filing to the authority. billing_dispute.regulatory_complaint_flag and regulatory_reference_number (denor' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Dispute resolution SLAs (sla_due_date, sla_breached on billing_dispute) are mandated by specific regulatory obligations (consumer protection regulations). Compliance teams must report dispute resoluti' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:approvedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Amount' ;
    rdfs:comment 'The monetary credit amount approved and issued to the customer as the resolution outcome. May be less than, equal to, or zero relative to the disputed amount depending on the resolution decision (upheld, partially upheld, rejected).' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Market segment of the customer raising the dispute. Drives SLA targets, resolution authority thresholds, and regulatory reporting categorization. MVNO refers to Mobile Virtual Network Operator partners.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the dispute at creation. Used in customer communications, agent workflows, and regulatory correspondence. Format: DSP- followed by 10 digits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the billing dispute. Drives workflow routing in Amdocs and Salesforce CRM. Valid states: open (newly raised), under_review (agent investigating), escalated (referred to senior team or regulator), resolved (outcome determined), closed (credit/adjustment applied and confirmed), withdrawn (customer retracted the dispute).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the nature of the billing dispute. Drives routing rules and SLA targets. [ENUM-REF-CANDIDATE: charge_error|service_not_received|unauthorized_charge|roaming_dispute|early_termination_fee|late_payment_fee|promotional_credit_missing|other — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the dispute has been escalated beyond the first-line resolution team (e.g., to a senior billing specialist, legal team, or external regulator such as FCC or Ofcom). True = escalated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Tier to which the dispute has been escalated. tier_1: first-line agent; tier_2: senior billing specialist; tier_3: billing management/legal; regulatory: external regulator (FCC, Ofcom, BEREC).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Narrative or coded reason explaining why the dispute was escalated. Populated only when escalation_flag is True. Examples: SLA breach, high-value dispute, regulatory complaint, repeat dispute.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to supporting evidence documents (e.g., CDR extracts, call recordings, usage reports, screenshots) stored in the document management system. Supports dispute investigation and audit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the dispute for workflow queue management. Determined by factors such as disputed amount, customer segment (e.g., enterprise vs. consumer), SLA proximity, and regulatory complaint status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDate rdf:type rdf:Property ;
    rdfs:label 'Raised Date' ;
    rdfs:comment 'Calendar date on which the customer formally raised the billing dispute. Used for SLA measurement, regulatory reporting, and aging analysis. Distinct from the system record creation timestamp.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raised Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the dispute was formally submitted by the customer. Used for exact SLA clock-start calculations and audit trail.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complaint Flag' ;
    rdfs:comment 'Indicates whether the dispute has been formally lodged with or referred to a regulatory body (e.g., FCC, Ofcom, BEREC). True = regulatory complaint filed. Triggers mandatory regulatory reporting workflows.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Dispute Flag' ;
    rdfs:comment 'Indicates whether this dispute is a repeat submission by the same customer for the same or similar charge within a defined lookback window. True = repeat dispute. Used for churn risk analysis and root-cause remediation.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Calendar date on which the dispute was formally resolved and an outcome was communicated to the customer. Used for SLA compliance reporting and regulatory submissions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Agent-authored narrative summarizing the investigation findings, evidence reviewed, and rationale for the resolution outcome. Retained for audit, regulatory inspection, and quality assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final decision on the billing dispute. upheld: full credit issued; partially_upheld: partial credit issued; rejected: no credit, charge stands; withdrawn: customer retracted before resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise date and time at which the dispute resolution was finalized in the system. Used for exact SLA elapsed-time calculations and audit trail integrity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of telecommunications service to which the disputed charge relates. Enables service-level dispute analytics and product-specific resolution routing. [ENUM-REF-CANDIDATE: mobile_voice|mobile_data|fixed_broadband|fiber_ftth|iptv|voip|roaming|sms|mms|wholesale — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the SLA due date without resolution. True = SLA was breached. Used for regulatory compliance reporting and agent performance management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Target date by which the dispute must be resolved per the applicable SLA or regulatory requirement (e.g., FCC mandates, Ofcom billing dispute resolution timelines). Calculated from raised_date plus the applicable SLA window.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricePlanId rdf:type rdf:Property ;
    rdfs:label 'Price Plan Id' ;
    rdfs:comment 'Foreign key linking to product.price_plan. Business justification: Prepaid balances track allowances defined in price plans. Required for balance bucket management, plan change processing, validity period enforcement, and prepaid product analytics. Removes denormaliz' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricePlan .

ind:primaryPrepaidMigrationTargetAccountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Prepaid Migration Target Account Billing Account Id' ;
    rdfs:comment 'Reference to the postpaid billing account to which this prepaid balance was migrated. Populated only when balance_status = \'migrated_to_postpaid\'. Supports prepaid-to-postpaid migration tracking and balance transfer reconciliation.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which this prepaid balance account was first activated. Marks the start of the subscriber\'s prepaid lifecycle. Used for tenure calculation, cohort analysis, and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRechargeAmount rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Amount' ;
    rdfs:comment 'Fixed monetary amount to be automatically recharged when the auto-recharge trigger threshold is reached. Expressed in the account currency. Configured by the subscriber or defaulted by the plan.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRechargeEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Enabled' ;
    rdfs:comment 'Indicates whether the subscriber has configured automatic recharge (top-up) to trigger when the main balance falls below the auto_recharge_trigger_threshold. True = auto-recharge active; False = manual recharge only.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRechargePaymentToken rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Payment Token' ;
    rdfs:comment 'Tokenized reference to the payment instrument (e.g., credit/debit card token, bank account token) used for automatic recharge transactions. The actual card/account details are stored in the payment vault; this token is the PCI-compliant reference. Sourced from Amdocs Revenue Management payment tokenization.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRechargeTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Trigger Threshold' ;
    rdfs:comment 'Monetary balance level at which the auto-recharge process is automatically triggered. When main_balance_amount falls at or below this value and auto_recharge_enabled is True, a recharge of auto_recharge_amount is initiated. Expressed in the account currency.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceFreezeReason rdf:type rdf:Property ;
    rdfs:label 'Balance Freeze Reason' ;
    rdfs:comment 'Reason code explaining why the balance is in \'frozen\' status. Populated only when balance_status = \'frozen\'. Supports compliance audit trails and operational workflows. [ENUM-REF-CANDIDATE: fraud_investigation|regulatory_hold|subscriber_request|legal_order|sim_swap_pending — promote to reference product]' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Balance Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number for this prepaid balance record, as assigned by Comverse ONE Balance Management. Used in customer-facing communications and balance inquiries.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the most recent balance snapshot captured from Comverse ONE Balance Management. Indicates the freshness of the balance data in the Silver Layer. Critical for real-time authorization latency monitoring and data quality SLA tracking.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle state of the prepaid balance account. \'active\' indicates the balance is usable; \'expired\' indicates the validity period has lapsed; \'frozen\' indicates the balance is temporarily locked (e.g., fraud hold); \'migrated_to_postpaid\' indicates the subscriber has converted to a postpaid plan; \'suspended\' indicates service suspension due to non-recharge or regulatory action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceValidityDays rdf:type rdf:Property ;
    rdfs:label 'Balance Validity Days' ;
    rdfs:comment 'Number of days the main balance remains valid from the last recharge date. Determines the main_balance_expiry_date. Defined by the subscriber\'s active prepaid plan or recharge denomination.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Balance Amount' ;
    rdfs:comment 'Monetary value of promotional or bonus credits awarded to the subscriber (e.g., recharge bonuses, loyalty rewards, campaign credits). Typically consumed after the main balance is exhausted. Expressed in the account currency.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Content Credit Balance' ;
    rdfs:comment 'Remaining balance in the subscriber\'s dedicated content credit bucket, used for OTT content, IPTV, or digital entertainment purchases. Expressed in the account currency. Sourced from Comverse ONE Balance Management.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentCreditExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Content Credit Expiry Date' ;
    rdfs:comment 'Date on which the content credit bucket expires. Unused content credits are forfeited after this date.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated mobile data bucket expires. Remaining data allowance is forfeited after this date unless renewed via a recharge or data add-on purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataBucketMb rdf:type rdf:Property ;
    rdfs:label 'Data Bucket Mb' ;
    rdfs:comment 'Remaining dedicated mobile data balance in the subscriber\'s data allowance bucket, expressed in megabytes (MB). Decremented in real-time during data sessions via Comverse ONE online charging and DPI-based usage reporting.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which this prepaid balance account was deactivated (e.g., after grace period expiry, subscriber-initiated cancellation, or regulatory action). Null if the account is still active. Used for churn analysis and MSISDN recycling workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the main balance expiry date during which the subscriber may still receive incoming calls/SMS but cannot initiate outgoing services. After the grace period, the account may be deactivated. Defined by regulatory requirements and plan configuration.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period Expiry Date' ;
    rdfs:comment 'Date on which the grace period ends. After this date, the prepaid account may be deactivated and the MSISDN released for recycling if no recharge is made. Calculated as main_balance_expiry_date + grace_period_days.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iccid rdf:type rdf:Property ;
    rdfs:label 'Iccid' ;
    rdfs:comment 'Unique identifier of the physical SIM or eSIM card associated with this prepaid balance account. Used for SIM swap detection, fraud management, and device-balance association. Follows ITU-T E.118 format.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRechargeAmount rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Amount' ;
    rdfs:comment 'Monetary value of the most recent recharge (top-up) applied to this prepaid account, expressed in the account currency. Used for ARPU calculation, recharge pattern analysis, and revenue reporting.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRechargeChannel rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Channel' ;
    rdfs:comment 'Channel through which the most recent recharge was applied. Supports channel performance analytics and customer journey analysis. [ENUM-REF-CANDIDATE: ussd|ivr|mobile_app|web_portal|retail_store|agent|voucher|bank_transfer — promote to reference product]' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRechargeDate rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Date' ;
    rdfs:comment 'Calendar date of the most recent successful recharge (top-up) applied to this prepaid account. Used for churn analysis, recharge frequency reporting, and dormancy detection.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRechargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) of the most recent successful recharge event applied to this prepaid account. Provides sub-day precision for real-time authorization and fraud detection workflows.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lowBalanceNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Low Balance Notification Enabled' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive low-balance notifications when the main balance falls below the low_balance_threshold. True = notifications enabled; False = notifications disabled.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Low Balance Threshold' ;
    rdfs:comment 'Monetary threshold below which a low-balance notification is triggered to the subscriber (e.g., via SMS, push notification, or USSD). Expressed in the account currency. Configurable per subscriber or plan.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Main Balance Amount' ;
    rdfs:comment 'Current monetary balance available in the subscriber\'s primary prepaid wallet, expressed in the account currency. This is the principal cash-equivalent balance used for general service charges, roaming, and out-of-bundle usage. Sourced from Comverse ONE real-time balance management.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainBalanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Main Balance Expiry Date' ;
    rdfs:comment 'Date on which the main monetary balance expires and becomes unavailable for use if not recharged. After this date, the balance_status transitions to \'expired\'. Critical for low-balance notification and recharge prompting workflows.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rechargeCountCurrentMonth rdf:type rdf:Property ;
    rdfs:label 'Recharge Count Current Month' ;
    rdfs:comment 'Number of successful recharge transactions applied to this prepaid account in the current calendar month. Supports MRR calculation, monthly ARPU reporting, and recharge frequency analytics.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rechargeCountLifetime rdf:type rdf:Property ;
    rdfs:label 'Recharge Count Lifetime' ;
    rdfs:comment 'Total number of successful recharge (top-up) transactions applied to this prepaid account since activation. Used for subscriber loyalty segmentation, ARPU analysis, and churn prediction models.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this prepaid balance record was first created in the Databricks Silver Layer. Supports audit trail, data lineage, and compliance reporting requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this prepaid balance record in the Databricks Silver Layer. Used for change data capture (CDC), incremental processing, and audit trail compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Reserved Balance Amount' ;
    rdfs:comment 'Amount of the main balance currently reserved (locked) for active in-progress sessions (e.g., ongoing voice calls, active data sessions). Prevents double-spending during real-time authorization. Released upon session termination. Sourced from Comverse ONE online charging.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sms Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated SMS units bucket expires. Remaining SMS units are forfeited after this date unless renewed via a recharge or bundle purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsBucketUnits rdf:type rdf:Property ;
    rdfs:label 'Sms Bucket Units' ;
    rdfs:comment 'Remaining dedicated SMS units in the subscriber\'s SMS allowance bucket. Each unit typically represents one standard SMS message. Decremented in real-time via Comverse ONE charging.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Voice Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated voice minutes bucket expires. Remaining voice minutes are forfeited after this date unless renewed via a recharge or bundle purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voiceBucketMinutes rdf:type rdf:Property ;
    rdfs:label 'Voice Bucket Minutes' ;
    rdfs:comment 'Remaining dedicated voice minutes balance in the subscriber\'s voice allowance bucket. Decremented in real-time during voice calls via Comverse ONE real-time rating. Expressed in minutes.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rechargeId rdf:type rdf:Property ;
    rdfs:label 'Recharge Id' ;
    rdfs:comment 'Unique system-generated identifier for each prepaid recharge/top-up transaction record in Comverse ONE. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceId rdf:type rdf:Property ;
    rdfs:label 'Balance Id' ;
    rdfs:comment 'Foreign key linking to usage.usage_balance. Business justification: Recharges can top up usage balances (data/voice bundles) in addition to monetary prepaid_balance. Link required for bundle top-up tracking, bonus allocation, and hybrid prepaid-postpaid scenarios.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Balance .

ind:originalRechargeId rdf:type rdf:Property ;
    rdfs:label 'Original Recharge Id' ;
    rdfs:comment 'Reference to the original recharge transaction that this record reverses or adjusts. Populated only when reversal_flag is True. Enables audit trail linking between original and reversal transactions.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recharge .

ind:balanceAfter rdf:type rdf:Property ;
    rdfs:label 'Balance After' ;
    rdfs:comment 'The subscriber\'s prepaid main balance immediately after this recharge was applied, as recorded by Comverse ONE. Equals balance_before plus net_credited_amount plus bonus_amount. Used for balance audit trails.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceBefore rdf:type rdf:Property ;
    rdfs:label 'Balance Before' ;
    rdfs:comment 'The subscriber\'s prepaid main balance immediately before this recharge was applied, as recorded by Comverse ONE real-time balance management. Used for balance reconciliation and fraud detection.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Balance Expiry Date' ;
    rdfs:comment 'The new expiry date of the subscriber\'s prepaid balance after this recharge was applied. Recharges typically extend the validity period of the prepaid account. Used for balance lifecycle management and subscriber retention analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Additional bonus credit amount awarded to the subscriber\'s balance as part of a promotional offer associated with this recharge. Separate from the net_credited_amount; tracked for promotional liability and revenue assurance.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataBonusMb rdf:type rdf:Property ;
    rdfs:label 'Data Bonus Mb' ;
    rdfs:comment 'Additional data allowance in megabytes (MB) credited to the subscriber\'s data bucket as part of a promotional recharge offer. Null if no data bonus was awarded. Tracked separately from monetary bonus for usage analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized error or failure reason code returned by Comverse ONE or the payment gateway when a recharge transaction fails. Null for successful transactions. Used for failure analysis and NOC troubleshooting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the subscriber\'s home network. Used for international roaming recharge scenarios and regulatory reporting to FCC/ITU/Ofcom.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCreditedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credited Amount' ;
    rdfs:comment 'The net monetary value actually credited to the subscriber\'s prepaid main balance after tax deductions. Equals recharge_amount minus tax_amount. Used for revenue recognition and balance reconciliation.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkNodeCode rdf:type rdf:Property ;
    rdfs:label 'Network Node Code' ;
    rdfs:comment 'Identifier of the network node (e.g., HLR, HSS, or UDM) that processed the recharge authorization and balance update. Used for network-level troubleshooting and capacity planning in NOC operations.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Ms' ;
    rdfs:comment 'Time in milliseconds taken by Comverse ONE to process and complete the recharge transaction from request receipt to balance credit confirmation. Used for SLA monitoring and real-time rating performance analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rechargeDate rdf:type rdf:Property ;
    rdfs:label 'Recharge Date' ;
    rdfs:comment 'Calendar date on which the recharge was applied, derived from recharge_timestamp. Used for daily/monthly MRR reporting, ARPU calculations, and partitioning in the Databricks Silver layer.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rechargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recharge Timestamp' ;
    rdfs:comment 'The exact date and time (in ISO 8601 format with timezone offset) when the recharge event was processed and the subscriber\'s prepaid balance was credited. This is the principal business event timestamp, distinct from record audit timestamps.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rechargeType rdf:type rdf:Property ;
    rdfs:label 'Recharge Type' ;
    rdfs:comment 'Classification of the recharge event by its business nature. Distinguishes standard top-ups from promotional, emergency credit, auto-recharge triggers, or gifted recharges from another subscriber.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this recharge transaction has been reversed or cancelled after initial processing. True = reversed; False = not reversed. Used for revenue assurance and balance reconciliation.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Flag' ;
    rdfs:comment 'Indicates whether the subscriber was roaming on a visited network at the time of the recharge event. True = subscriber was roaming; False = subscriber was on home network. Relevant for NRTRDE/TAP roaming reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsBonusCount rdf:type rdf:Property ;
    rdfs:label 'Sms Bonus Count' ;
    rdfs:comment 'Additional SMS messages credited to the subscriber\'s SMS bucket as part of a promotional recharge offer. Null if no SMS bonus was awarded.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the recharge transaction as processed by Comverse ONE. \'success\' indicates balance was credited; \'failed\' indicates processing error; \'reversed\' indicates a chargeback or correction; \'partial\' indicates partial credit applied.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ussdSessionCode rdf:type rdf:Property ;
    rdfs:label 'Ussd Session Code' ;
    rdfs:comment 'The USSD session identifier from the IMS/HLR for recharges initiated via USSD short codes. Populated only when recharge_channel is \'ussd\'. Supports USSD session tracing and troubleshooting.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityDays rdf:type rdf:Property ;
    rdfs:label 'Validity Days' ;
    rdfs:comment 'Number of days of service validity granted to the subscriber by this recharge event. Determines how long the subscriber can use the credited balance before it expires.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voiceBonusMinutes rdf:type rdf:Property ;
    rdfs:label 'Voice Bonus Minutes' ;
    rdfs:comment 'Additional voice call minutes credited to the subscriber\'s voice bucket as part of a promotional recharge offer. Null if no voice bonus was awarded. Tracked for promotional liability and usage analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Voucher Serial Number' ;
    rdfs:comment 'The unique serial number of the physical or electronic prepaid voucher used for this recharge. Populated only when recharge_channel is \'voucher\'. Used for voucher fraud detection and inventory reconciliation.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffId rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Id' ;
    rdfs:comment 'Foreign key linking to interconnect.iot_tariff. Business justification: Roaming retail rate plans must be reconciled against wholesale IOT tariffs for margin analysis and regulatory compliance. Telecom operators directly map customer-facing rate plans to the IOT tariff th' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IotTariff .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to enterprise.segment. Business justification: Rate plans are designed for specific enterprise segments (SMB, large enterprise, government). rate_plan.market_segment is a denormalized plain-text attribute; replacing it with a proper FK to enterpri' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:activationFee rdf:type rdf:Property ;
    rdfs:label 'Activation Fee' ;
    rdfs:comment 'One-time fee charged at the time of service activation for this rate plan. Denominated in currency_code. A value of 0 indicates no activation fee. Captured as a one-time charge in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The frequency at which the recurring charge is applied and the billing cycle is closed. Drives invoice generation scheduling in Amdocs Revenue Management.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingModel rdf:type rdf:Property ;
    rdfs:label 'Charging Model' ;
    rdfs:comment 'The pricing model applied by the rating engine to calculate charges. \'flat\' = fixed charge regardless of usage; \'tiered\' = stepped rates at volume thresholds; \'volume\' = single rate applied to total volume; \'event_based\' = per-event charge; \'time_based\' = charge per unit of time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Minimum contractual commitment period in months associated with this rate plan (e.g., 12, 24, 36 months). A value of 0 indicates a month-to-month or no-commitment plan. Drives early termination fee (ETF) calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekModifierEnabled rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Modifier Enabled' ;
    rdfs:comment 'Indicates whether this rate plan applies day-of-week pricing modifiers (e.g., weekend discount rates). When TRUE, the rating engine evaluates the CDR date against the configured weekend/weekday windows.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fixed monetary penalty charged to a subscriber who cancels the service before the contract_term_months expires. Denominated in currency_code. A value of 0 indicates no early termination fee. Used in churn management and collections workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The calendar date after which this rate plan is no longer valid for rating new events. Exclusive boundary. NULL indicates an open-ended plan with no scheduled termination. Used for plan deprecation and migration workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The calendar date from which this rate plan becomes active and eligible for rating new subscriptions and usage events. Inclusive boundary. Used for temporal validity checks in the rating engine and revenue recognition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairUseCapMb rdf:type rdf:Property ;
    rdfs:label 'Fair Use Cap Mb' ;
    rdfs:comment 'Maximum data volume in megabytes beyond which the fair-use policy is triggered, resulting in speed throttling or additional charges. Distinct from the included_data_volume_mb allowance — this is the absolute ceiling before network management actions are applied. NULL indicates no fair-use cap.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedDataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Included Data Volume Mb' ;
    rdfs:comment 'Data volume allowance included in the base recurring charge, expressed in megabytes (MB). A value of -1 or NULL indicates unlimited data. The rating engine deducts consumed data against this allowance before applying overage rates or fair-use policy throttling.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedSmsCount rdf:type rdf:Property ;
    rdfs:label 'Included Sms Count' ;
    rdfs:comment 'Number of SMS messages included in the base recurring charge before overage rates apply. A value of -1 or NULL indicates unlimited SMS. Used by the rating engine for SMS CDR allowance tracking.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedVoiceMinutes rdf:type rdf:Property ;
    rdfs:label 'Included Voice Minutes' ;
    rdfs:comment 'Number of voice call minutes included in the rate plan\'s base recurring charge before overage rates apply. A value of -1 or NULL indicates unlimited voice. Used by the rating engine to track allowance consumption against CDRs.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this rate plan is a promotional or limited-time offer. When TRUE, the plan may have an associated promotion expiry date and is tracked separately in ARPU and MRR reporting to distinguish promotional revenue from base revenue.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offPeakRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Off Peak Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate during off-peak hours when time_of_day_modifier_enabled is TRUE. A value of 0.5 means 50% discount during off-peak. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Overage Rate Per Unit' ;
    rdfs:comment 'The per-unit charge applied to usage that exceeds the included allowance. The unit of measure is defined by overage_unit_of_measure. For data, this is typically per MB or per GB; for voice, per minute; for SMS, per message. Denominated in currency_code.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Overage Unit Of Measure' ;
    rdfs:comment 'The unit of measure against which the overage_rate_per_unit is applied. Defines the granularity of overage billing (e.g., per MB for data, per minute for voice, per message for SMS). [ENUM-REF-CANDIDATE: MB|GB|minute|second|message|event|kB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakEndTime rdf:type rdf:Property ;
    rdfs:label 'Peak End Time' ;
    rdfs:comment 'The daily end time (HH:MM, 24-hour format) of the peak pricing window. Used by the rating engine to determine whether a CDR falls within peak or off-peak hours. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peakRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate during peak hours when time_of_day_modifier_enabled is TRUE. A value of 1.0 means no adjustment; 1.5 means 50% premium during peak. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakStartTime rdf:type rdf:Property ;
    rdfs:label 'Peak Start Time' ;
    rdfs:comment 'The daily start time (HH:MM, 24-hour format) of the peak pricing window. Used by the rating engine to determine whether a CDR falls within peak or off-peak hours. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the rate plan within the Amdocs Rating engine. Controls whether the plan is available for new subscriptions and active rating. \'draft\' = under configuration; \'active\' = live for rating; \'suspended\' = temporarily halted; \'deprecated\' = replaced by a newer plan; \'inactive\' = decommissioned.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Billing modality of the rate plan. \'postpaid\' = charges billed after consumption cycle; \'prepaid\' = charges deducted from pre-loaded balance via Comverse ONE real-time rating; \'hybrid\' = mixed prepaid/postpaid; \'wholesale\' = inter-operator or MVNO wholesale pricing; \'mvno\' = Mobile Virtual Network Operator resale pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'The date on which the promotional pricing expires and the standard rate plan pricing takes effect. Applicable only when is_promotional is TRUE. NULL for non-promotional plans.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method used to calculate partial-period charges when a subscription starts or ends mid-billing-cycle. \'daily\' = charge proportional to days active; \'full_period\' = charge full cycle regardless; \'none\' = no proration applied.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanCode rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the rate plan within the Amdocs Rating engine and is referenced by downstream billing, CDR processing, and invoice generation systems. Used as the business key for cross-system reconciliation.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Description' ;
    rdfs:comment 'Detailed narrative description of the rate plan\'s pricing logic, applicable services, and commercial intent. Used by product managers, billing analysts, and regulatory reporting teams to understand the plan\'s scope.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanName rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Name' ;
    rdfs:comment 'Human-readable name of the rate plan as displayed in the Amdocs Rating engine configuration and referenced in billing statements and internal reporting (e.g., \'Unlimited 5G Consumer Postpaid\', \'SMB Data Tier 3\').' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTierCount rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Count' ;
    rdfs:comment 'Number of pricing tiers (step thresholds) defined for this rate plan. A value of 1 indicates flat-rate pricing; values greater than 1 indicate tiered/stepped pricing where different rates apply at different usage volumes. Drives the rating engine\'s tier evaluation logic.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingMethod rdf:type rdf:Property ;
    rdfs:label 'Rating Method' ;
    rdfs:comment 'Indicates whether usage events (CDRs) under this rate plan are rated in real-time (online charging via Comverse ONE for prepaid) or in batch mode (offline charging via Amdocs for postpaid), or a hybrid of both.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Recurring Charge Amount' ;
    rdfs:comment 'The fixed periodic charge applied to a subscription on this rate plan per billing cycle (e.g., monthly base fee). Represents the Monthly Recurring Revenue (MRR) component at the plan level. Denominated in the currency specified by currency_code.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingDataRatePerMb rdf:type rdf:Property ;
    rdfs:label 'Roaming Data Rate Per Mb' ;
    rdfs:comment 'Per-megabyte charge applied to data usage while roaming internationally, denominated in currency_code. Applies when roaming_enabled is TRUE and the subscriber is on a visited network. Used for IOT (Inter-Operator Tariff) reconciliation.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Roaming Enabled' ;
    rdfs:comment 'Indicates whether international roaming usage is permitted and rated under this rate plan. When FALSE, roaming CDRs are blocked or rated at a default barring rate. Relevant for NRTRDE/TAP roaming data exchange compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingVoiceRatePerMin rdf:type rdf:Property ;
    rdfs:label 'Roaming Voice Rate Per Min' ;
    rdfs:comment 'Per-minute charge applied to voice calls while roaming internationally, denominated in currency_code. Applies when roaming_enabled is TRUE. Used for IOT reconciliation and NRTRDE reporting.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxClassCode rdf:type rdf:Property ;
    rdfs:label 'Tax Class Code' ;
    rdfs:comment 'Tax classification code assigned to this rate plan, used by the Amdocs tax engine to determine applicable tax rates (e.g., USF, VAT, GST, E911 surcharges). Maps to the tax jurisdiction configuration in the billing system.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyType rdf:type rdf:Property ;
    rdfs:label 'Technology Type' ;
    rdfs:comment 'The radio access or fixed-line network technology to which this rate plan applies. Used by the rating engine to apply technology-specific pricing tiers (e.g., 5G NR premium data rates vs LTE standard rates). [ENUM-REF-CANDIDATE: 2G|3G|4G_LTE|5G_NR|FTTH|GPON|ADSL|VDSL|WIFI — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRate1 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 1' ;
    rdfs:comment 'Per-unit charge applied to usage within the first pricing tier (from 0 to tier_threshold_1_mb). Denominated in currency_code per overage_unit_of_measure.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRate2 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 2' ;
    rdfs:comment 'Per-unit charge applied to usage within the second pricing tier (from tier_threshold_1_mb to tier_threshold_2_mb). Denominated in currency_code per overage_unit_of_measure. NULL if fewer than 2 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRate3 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 3' ;
    rdfs:comment 'Per-unit charge applied to usage beyond tier_threshold_2_mb (third tier and above). Denominated in currency_code per overage_unit_of_measure. NULL if fewer than 3 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThreshold1Mb rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold 1 Mb' ;
    rdfs:comment 'Usage volume threshold in MB at which the first pricing tier ends and the second tier begins. NULL if the plan has fewer than 2 tiers. Used by the Amdocs rating engine for stepped-rate calculation.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThreshold2Mb rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold 2 Mb' ;
    rdfs:comment 'Usage volume threshold in MB at which the second pricing tier ends and the third tier begins. NULL if the plan has fewer than 3 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeOfDayModifierEnabled rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Modifier Enabled' ;
    rdfs:comment 'Indicates whether this rate plan applies time-of-day pricing modifiers (e.g., peak/off-peak rates). When TRUE, the rating engine evaluates the CDR timestamp against the defined peak/off-peak windows to apply the appropriate rate multiplier.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version counter for this rate plan record. Incremented each time the plan configuration is modified. Supports audit trail, change management, and point-in-time rating reconstruction for dispute resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekendRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Weekend Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate on weekend days (Saturday and Sunday) when day_of_week_modifier_enabled is TRUE. A value of 0.0 means free weekend calls/data. NULL when day-of-week pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOutageId rdf:type rdf:Property ;
    rdfs:label 'Planned Outage Id' ;
    rdfs:comment 'Foreign key linking to network.planned_outage. Business justification: SLA credit note issuance process: credit notes issued for planned maintenance outages must reference the originating planned_outage for SLA exclusion validation and regulatory reporting. credit_note.o' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOutage .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Foreign key linking to enterprise.sla_breach. Business justification: Credit notes in enterprise telecom are frequently issued as direct contractual entitlements from SLA breaches. sla_breach has credit_issued_flag and credit_amount confirming this business process. Aud' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreach .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to order.sla. Business justification: SLA breach credits (service level penalty credits) must reference the specific SLA record that was breached. Telecom regulatory compliance and enterprise contract management require credit note-to-SLA' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:troubleTicketId rdf:type rdf:Property ;
    rdfs:label 'Trouble Ticket Id' ;
    rdfs:comment 'Foreign key linking to assurance.trouble_ticket. Business justification: Credit notes issued for service failures reference originating trouble tickets. Standard customer compensation workflow linking financial credits to documented service issues for audit trail, regulato' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TroubleTicket .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The employee ID or username of the billing manager or finance officer who approved the credit note issuance. Nullable for auto-approved credits. Required for SOX compliance audit trails and segregation of duties controls.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the credit note was approved by the authorized approver. Nullable for auto-approved or pending credits. Used for approval SLA monitoring and SOX audit compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross pre-tax credit amount to be applied to the customer\'s account, expressed in the billing currency. Represents the principal financial value of the credit note before tax reversal. Core component of the MONETARY_TRIPLET for revenue reversal reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'The billing charge category being credited. Identifies whether the credit relates to recurring service charges, usage-based charges (CDR-level), equipment fees, tax adjustments, interconnect/wholesale charges, or roaming charges. Supports revenue assurance and MRR impact analysis.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Note Status' ;
    rdfs:comment 'Current lifecycle state of the credit note. \'issued\' = generated and sent to customer; \'applied\' = fully offset against an invoice or balance; \'partially_applied\' = partially consumed; \'expired\' = validity period lapsed without full application; \'cancelled\' = withdrawn before application; \'voided\' = reversed post-issuance for error correction. [ENUM-REF-CANDIDATE: issued|applied|partially_applied|expired|cancelled|voided — promote to reference product]' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteType rdf:type rdf:Property ;
    rdfs:label 'Credit Note Type' ;
    rdfs:comment 'Classification of the credit note by its business nature. \'financial\' = billing error correction; \'commercial\' = commercial dispute resolution; \'regulatory\' = mandated by FCC/Ofcom/BEREC regulatory ruling; \'goodwill\' = customer retention gesture; \'equipment_return\' = CPE/ONT/OLT equipment return credit.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The timestamp when the credit note document was delivered to the customer via the specified delivery channel. Used for customer communication audit trails and regulatory compliance with billing notification requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Indicates whether this credit note was issued as a result of a regulatory mandate from FCC, Ofcom, BEREC, or other governing body. True = regulatory-mandated credit; False = commercially or operationally initiated. Used for regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The calendar date on which the credit note was formally issued to the customer. This is the principal business event date printed on the credit note document and used for revenue recognition reversal under IFRS 15.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp of the most recent modification to the credit note record. Serves as the RECORD_AUDIT_UPDATED marker for change data capture (CDC) processing in the Databricks Silver Layer and audit compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remainingCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Credit Amount' ;
    rdfs:comment 'The unapplied balance of the credit note (total_credit_amount minus applied_amount). Represents the credit still available for future application. Used for credit liability reporting and customer account balance management.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'The accounting period (YYYY-MM format) in which the revenue reversal from this credit note is recognized under IFRS 15 / ASC 606. Used by SAP S/4HANA Finance for general ledger posting and period-close reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'The native identifier of this credit note in the originating source system (e.g., Amdocs internal credit note ID, Comverse ONE transaction reference). Enables cross-system traceability and reconciliation between the lakehouse Silver Layer and operational BSS/CRM systems.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The geographic tax jurisdiction (e.g., state, country, municipality) applicable to the tax reversal on this credit note. Required for multi-jurisdiction tax compliance reporting to federal, state, and local tax authorities.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total credit amount inclusive of tax reversal (credit_amount + tax_reversal_amount). This is the net financial value credited to the customer\'s account and the figure printed on the customer-facing credit note document.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyCarrierId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Carrier Id' ;
    rdfs:comment 'Reference to the domestic or international operator that is the counterparty to this agreement. Links to the carrier/partner master record in the interconnect domain.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:mvnoProfileId rdf:type rdf:Property ;
    rdfs:label 'Mvno Profile Id' ;
    rdfs:comment 'Foreign key linking to partner.mvno_profile. Business justification: MVNO wholesale access is governed by a carrier agreement between the host MNO and the MVNO. Linking carrier_agreement to mvno_profile enables MVNO wholesale agreement tracking, capacity management, an' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MvnoProfile .

ind:qosProfileId rdf:type rdf:Property ;
    rdfs:label 'Qos Profile Id' ;
    rdfs:comment 'Foreign key linking to network.qos_profile. Business justification: Roaming and interconnect agreements specify QoS requirements (latency, jitter, packet loss) that must be enforced by network QoS profiles. Required for SLA compliance verification and service assuranc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QosProfile .

ind:roamingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Roaming Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.roaming_agreement. Business justification: A carrier_agreement of type roaming references a specific partner roaming_agreement for operational parameters (TAP exchange, NRTRDE, steering policy). Linking enables cross-domain agreement lifecycle' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoamingAgreement .

ind:slaContractId rdf:type rdf:Property ;
    rdfs:label 'Sla Contract Id' ;
    rdfs:comment 'Foreign key linking to assurance.sla_contract. Business justification: Carrier agreements have formal SLA performance obligations (TAP transmission windows, settlement cycles). Linking to assurance.sla_contract enables SLA breach monitoring and penalty enforcement agains' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaContract .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Reference to the Service Level Agreement (SLA) record governing quality of service commitments under this carrier agreement, including network availability, latency, and fault resolution targets.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive commercial name of the carrier agreement (e.g., \'Roaming IOT Agreement – Carrier X 2024\'). Used for display in BSS portals and settlement reports.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the bilateral or multilateral carrier agreement. Used in correspondence, TAP file headers, and inter-operator settlement documents. Maps to the contract reference in Amdocs Revenue Management and Netcracker OSS/BSS.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the carrier agreement. DRAFT = under negotiation; ACTIVE = commercially live and binding; SUSPENDED = temporarily halted by mutual or unilateral action; TERMINATED = permanently ended; EXPIRED = reached end date without renewal; PENDING_APPROVAL = awaiting regulatory or internal sign-off.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carrier agreement by commercial relationship type. IOT = Inter-Operator Tariff roaming; CAMEL = Customised Applications for Mobile networks Enhanced Logic; MVNO_HOSTING = Mobile Virtual Network Operator (MVNO) hosting arrangement; NATIONAL_ROAMING = domestic network sharing; WHOLESALE_BROADBAND = wholesale broadband resale; CAPACITY_RESALE = bandwidth/capacity resale; TRANSIT = transit traffic routing; PEERING = direct traffic exchange. [ENUM-REF-CANDIDATE: IOT|CAMEL|MVNO_HOSTING|NATIONAL_ROAMING|WHOLESALE_BROADBAND|CAPACITY_RESALE|TRANSIT|PEERING — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version number of the agreement document (e.g., \'1.0\', \'2.3\'). Incremented when amendments are executed. Enables tracking of agreement evolution and ensures the correct rate tables are applied for each version period.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments executed against this agreement since its original signing. Provides a quick indicator of agreement complexity and negotiation history.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews upon reaching its effective_until_date without requiring a new signed instrument. True = auto-renews; False = requires explicit renewal action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredServices rdf:type rdf:Property ;
    rdfs:label 'Covered Services' ;
    rdfs:comment 'Comma-separated list of telecommunication services covered under this agreement (e.g., VOICE, SMS, DATA, VOLTE, VONR, MMS, CAMEL_GPRS). Governs which service types are eligible for IOT settlement and TAP file exchange. [ENUM-REF-CANDIDATE: VOICE|SMS|DATA|VOLTE|VONR|MMS|CAMEL_GPRS|USSD — promote to reference product]' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionAddendumFlag rdf:type rdf:Property ;
    rdfs:label 'Data Protection Addendum Flag' ;
    rdfs:comment 'Indicates whether a data protection addendum (DPA) is attached to this agreement, governing the processing of subscriber personal data exchanged between operators in compliance with GDPR or equivalent regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to standard IOT rates when discount_type is PERCENTAGE or VOLUME_TIERED. Expressed as a decimal percentage (e.g., 15.00 = 15%). Null when discount_type is FLAT_RATE or NONE.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Type of discount structure applied to IOT rates under this agreement. FLAT_RATE = fixed per-unit reduction; VOLUME_TIERED = discount scales with traffic volume; PERCENTAGE = percentage reduction off standard IOT; NEGOTIATED_RATE = bespoke bilaterally agreed rate; NONE = standard IOT applies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving financial or operational disputes arising under this agreement. GSMA_MEDIATION refers to the GSMA Billing and Accounting Dispute Resolution process.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Prevention Flag' ;
    rdfs:comment 'Indicates whether this agreement includes specific fraud prevention obligations such as NRTRDE, SIM box detection cooperation, or GSMA Fraud Information Gathering System (FIGS) participation.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountryCode rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern this agreement (e.g., GBR for English law, USA for US law). Relevant for regulatory compliance and dispute resolution.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Interconnect Agreement Ref' ;
    rdfs:comment 'External reference number or document identifier for the physical signed agreement document, as stored in the document management system or SAP S/4HANA contract repository. Enables traceability to the legal instrument.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the agreement was last formally reviewed by the commercial team for rate competitiveness, volume performance, and compliance. Supports the agreement lifecycle management process.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minVolumeCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Min Volume Commitment Units' ;
    rdfs:comment 'Minimum traffic volume committed by one or both parties under this agreement, expressed in the unit defined by min_volume_unit (e.g., minutes, MB, messages). Triggers true-up billing if actual volume falls below this threshold.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Min Volume Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment (min_volume_commitment_units). MINUTES = voice traffic; MEGABYTES/GIGABYTES = data traffic; MESSAGES = SMS/MMS; ERLANGS = traffic intensity for capacity agreements.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkGeneration rdf:type rdf:Property ;
    rdfs:label 'Network Generation' ;
    rdfs:comment 'Radio access network generation(s) covered by this agreement. 2G = GSM/GPRS/EDGE; 3G = UMTS/HSPA; 4G_LTE = Long-Term Evolution (LTE); 5G_NR = 5G New Radio (NR); ALL = all generations. Determines applicable IOT tariff tables and NRTRDE reporting scope.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this agreement. Triggers workflow notifications to the commercial owner and finance team in advance of the review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement. Governs the termination workflow in contract lifecycle management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrtrdeFlag rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Flag' ;
    rdfs:comment 'Indicates whether this agreement requires Near Real-Time Roaming Data Exchange (NRTRDE) reporting per GSMA PRD FS.11. NRTRDE enables fraud detection by providing near-real-time CDR visibility to the home operator.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrtrdeTransmissionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Transmission Window Hours' ;
    rdfs:comment 'Maximum number of hours within which NRTRDE files must be transmitted to the home operator after the roaming CDR is generated. Standard GSMA requirement is 4 hours; some bilateral agreements specify tighter windows.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal cycle when auto_renewal_flag is True. Null when auto-renewal is not applicable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of gross revenue shared with the counterparty operator under MVNO hosting, content, or wholesale broadband agreements. Expressed as a decimal percentage (e.g., 20.00 = 20%). Null for pure IOT/TAP agreements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingDirection rdf:type rdf:Property ;
    rdfs:label 'Roaming Direction' ;
    rdfs:comment 'Direction of roaming traffic covered by this agreement. INBOUND = foreign subscribers roaming on Telecommunication\'s network; OUTBOUND = Telecommunication\'s subscribers roaming on the counterparty\'s network; BILATERAL = both directions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial settlement under this agreement (e.g., USD, EUR, GBP). Governs currency conversion in Amdocs Revenue Management inter-operator billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency at which financial settlement is performed between the parties under this agreement. Governs the billing cycle in Amdocs Revenue Management inter-operator invoicing.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Calendar date on which all parties executed the agreement. May precede the effective_from_date during a transition or notice period. Used for legal and audit trail purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapFileExchangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tap File Exchange Flag' ;
    rdfs:comment 'Indicates whether this agreement mandates Transferred Account Procedure (TAP) file exchange for roaming CDR settlement. True = TAP files must be exchanged per GSMA PRD TD.57 specifications.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapVersion rdf:type rdf:Property ;
    rdfs:label 'Tap Version' ;
    rdfs:comment 'Version of the GSMA Transferred Account Procedure (TAP) standard used for CDR file exchange under this agreement. Governs file format and field mapping in the TAP processing pipeline.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual calendar date on which the agreement was terminated, if applicable. Distinct from effective_until_date which is the planned end; this captures early or unilateral termination events.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trueUpFrequency rdf:type rdf:Property ;
    rdfs:label 'True Up Frequency' ;
    rdfs:comment 'Frequency at which minimum volume commitment true-up calculations are performed. If actual traffic falls below min_volume_commitment_units within the period, a shortfall charge is raised in Amdocs Revenue Management.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Unique surrogate identifier for each carrier record in the interconnect carrier master registry. Primary key for all interconnect domain relationships.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal or trading name of the carrier, transit operator, MVNO, or wholesale partner as registered with the relevant regulatory authority. Used as the primary human-readable identifier across all interconnect domain products.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier relationship. Active indicates live traffic exchange; suspended indicates temporary halt pending dispute or non-payment; terminated indicates the relationship has ended; pending indicates onboarding in progress; inactive indicates dormant with no current traffic.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier by network ownership and service role: MNO (Mobile Network Operator), MVNO (Mobile Virtual Network Operator), transit (transit/wholesale carrier), IXC (Interexchange Carrier), LEC (Local Exchange Carrier), ISP (Internet Service Provider). Drives applicable tariff tables, settlement rules, and regulatory reporting.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Carrier Code' ;
    rdfs:comment 'Carrier identifier assigned by the clearinghouse (e.g., Syniverse or BICS carrier code) used for TAP file routing, NRTRDE submission, and financial settlement matching within the clearinghouse platform.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseName rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Name' ;
    rdfs:comment 'Name of the financial and data clearinghouse through which TAP file exchange and inter-operator financial settlement is processed for this carrier (e.g., HSCSD, Syniverse, BICS). Required for TAP file routing and settlement reconciliation.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialContactEmail rdf:type rdf:Property ;
    rdfs:label 'Commercial Contact Email' ;
    rdfs:comment 'Email address for the carrier\'s commercial or wholesale account management team. Used for agreement negotiations, invoice disputes, and settlement correspondence.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the carrier\'s primary country of registration and network operation. Used for geographic segmentation, IOT tariff lookup, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding settlement balance (in settlement currency) permitted for this carrier before traffic suspension or escalation is triggered. Used for wholesale credit risk management and revenue assurance controls.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Data Roaming Enabled' ;
    rdfs:comment 'Indicates whether GPRS/LTE/5G NR data roaming is active with this carrier. When true, data CDRs from this carrier\'s subscribers are processed through the TAP/NRTRDE pipeline and rated against the applicable IOT data tariff.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc Registration Number' ;
    rdfs:comment 'Ten-digit FCC Registration Number (FRN) assigned to US-based carriers by the Federal Communications Commission. Required for FCC regulatory filings, Form 499 reporting, and USAC fund contributions tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiveGRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Five G Roaming Enabled' ;
    rdfs:comment 'Indicates whether 5G NR (New Radio) roaming is active with this carrier. Requires 5G roaming agreement, SEPP (Security Edge Protection Proxy) interconnect, and N32 interface configuration per 3GPP TS 33.501.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Level' ;
    rdfs:comment 'Fraud risk classification for this carrier based on historical NRTRDE anomalies, grey route incidents, and GSMA FASG (Fraud and Security Group) advisories. Drives real-time fraud monitoring thresholds and NRTRDE file frequency.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectAgreementType rdf:type rdf:Property ;
    rdfs:label 'Interconnect Agreement Type' ;
    rdfs:comment 'Type of interconnect arrangement with this carrier: direct (direct circuit interconnect), transit (traffic routed via a third-party transit carrier), peering (IP or voice peering arrangement), wholesale (wholesale traffic purchase/sale), none (no active interconnect).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffGroup rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Group' ;
    rdfs:comment 'IOT tariff group classification assigned to this carrier, used to look up applicable Inter-Operator Tariff (IOT) rates for roaming settlement. Aligns with GSMA IOT rate tables and bilateral agreement terms. Drives rating of inbound and outbound roaming CDRs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ir21LastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Ir21 Last Updated Date' ;
    rdfs:comment 'Date on which the carrier\'s GSMA IR.21 roaming information profile was last updated in the GSMA RAEX (Roaming Agreement Exchange) system. Stale IR.21 data can cause roaming activation failures.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ir21ProfileVersion rdf:type rdf:Property ;
    rdfs:label 'Ir21 Profile Version' ;
    rdfs:comment 'Version identifier of the carrier\'s GSMA IR.21 roaming information document on file. IR.21 contains network configuration data required for roaming service activation including IMSI ranges, supported services, and signalling parameters.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTapFileReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Tap File Received Date' ;
    rdfs:comment 'Date of the most recently received TAP (Transferred Account Procedure) file from this carrier. Used to monitor TAP file exchange health and detect stale or missing files that may indicate a processing issue or carrier-side problem.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTapFileSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Tap File Sent Date' ;
    rdfs:comment 'Date of the most recently sent TAP file to this carrier. Used to monitor outbound TAP file exchange health and ensure timely delivery within GSMA-mandated submission windows.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lteRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Lte Roaming Enabled' ;
    rdfs:comment 'Indicates whether LTE (4G) data roaming is active with this carrier. Distinct from VoLTE; covers data-only LTE roaming sessions rated and settled via TAP3 or DIAMETER-based online charging.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mcc rdf:type rdf:Property ;
    rdfs:label 'Mcc' ;
    rdfs:comment 'Three-digit ITU-assigned Mobile Country Code (MCC) identifying the country of the carrier\'s home network. Combined with MNC to form the full PLMN identifier used in roaming and signalling.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnc rdf:type rdf:Property ;
    rdfs:label 'Mnc' ;
    rdfs:comment 'Two- or three-digit ITU-assigned Mobile Network Code (MNC) identifying the carrier\'s specific network within its country. Combined with MCC to form the PLMN identifier used in HLR/HSS, roaming agreements, and CDR processing.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocEmail rdf:type rdf:Property ;
    rdfs:label 'Noc Email' ;
    rdfs:comment 'Primary email address for the carrier\'s Network Operations Center (NOC) used for fault escalation, outage notifications, and interconnect incident management. Operational contact for network-layer issues.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocPhone rdf:type rdf:Property ;
    rdfs:label 'Noc Phone' ;
    rdfs:comment '24/7 phone number for the carrier\'s Network Operations Center (NOC) in E.164 international format. Used for real-time fault escalation, SLA breach notification, and interconnect outage coordination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeEnabled rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Enabled' ;
    rdfs:comment 'Indicates whether this carrier participates in NRTRDE (Near Real-Time Roaming Data Exchange) for near-real-time roaming fraud detection and usage monitoring. When true, NRTRDE files must be exchanged within the GSMA-mandated 4-hour window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the carrier was formally onboarded into Telecommunication\'s interconnect systems including OSS/BSS provisioning, TAP file pipeline configuration, and clearinghouse registration. Distinct from relationship_start_date which may precede system activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredInterconnectRoute rdf:type rdf:Property ;
    rdfs:label 'Preferred Interconnect Route' ;
    rdfs:comment 'Preferred routing method for interconnect traffic to/from this carrier: direct (direct circuit), via_transit (through a transit carrier), via_iplc (International Private Leased Circuit), via_mpls (MPLS backbone), via_sdwan (SD-WAN overlay). Used by NOC for traffic engineering.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region grouping for the carrier (e.g., APAC, EMEA, AMER, LATAM). Used for regional traffic analysis, IOT tariff banding, and wholesale reporting. [ENUM-REF-CANDIDATE: APAC|EMEA|AMER|LATAM|MEA|CEUR — promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date on which the commercial and operational relationship with this carrier was or is scheduled to be terminated. Null for active ongoing relationships. Used for agreement expiry tracking and traffic wind-down planning.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the commercial and operational relationship with this carrier was formally established. Marks the beginning of the carrier\'s lifecycle in the interconnect registry and the effective date of the first agreement.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roamingAgreementType rdf:type rdf:Property ;
    rdfs:label 'Roaming Agreement Type' ;
    rdfs:comment 'Type of roaming agreement in place with this carrier: bilateral (direct two-way roaming), multilateral (via GSMA or regional body), MVNO_host (carrier hosts an MVNO), transit_only (transit traffic only, no retail roaming), none (no roaming, interconnect only).' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial settlement with this carrier (e.g., USD, EUR, GBP). Determines the currency in which TAP invoices, IOT charges, and interconnect invoices are denominated and paid.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used trading name of the carrier, used in operational reports, dashboards, and TAP file processing where space is constrained.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA tier assigned to this carrier relationship, determining priority of fault resolution, MTTR targets, and escalation paths. Platinum and gold tiers receive 24/7 NOC support with sub-4-hour MTTR commitments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsInterconnectEnabled rdf:type rdf:Property ;
    rdfs:label 'Sms Interconnect Enabled' ;
    rdfs:comment 'Indicates whether SMS (Short Message Service) interconnect is active with this carrier. Drives SMS CDR routing, A2P/P2P SMS settlement, and grey route detection.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spid rdf:type rdf:Property ;
    rdfs:label 'Spid' ;
    rdfs:comment 'Four-digit Service Provider Identifier (SPID) assigned by the North American Numbering Plan Administrator (NANPA) or local number portability administrator. Used for MNP (Mobile Number Portability) routing and LNP database queries.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tadigCode rdf:type rdf:Property ;
    rdfs:label 'Tadig Code' ;
    rdfs:comment 'Five-character GSMA-assigned TADIG code uniquely identifying the carrier for TAP file exchange and inter-operator roaming settlement. Mandatory for all MNO and MVNO roaming partners. Used as the primary key in TAP file headers and NRTRDE records.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceInterconnectEnabled rdf:type rdf:Property ;
    rdfs:label 'Voice Interconnect Enabled' ;
    rdfs:comment 'Indicates whether voice traffic (PSTN/VoIP/VoLTE) interconnect is active with this carrier. Drives CDR routing, rating, and settlement processing for voice traffic.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volteRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Volte Roaming Enabled' ;
    rdfs:comment 'Indicates whether VoLTE (Voice over LTE) roaming via IMS (IP Multimedia Subsystem) is active with this carrier. Requires bilateral IMS interconnect configuration and specific IR.92/IR.94 profile exchange.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Charging Interval Seconds' ;
    rdfs:comment 'The billing increment in seconds used for voice service IOT charge calculation. For example, a value of 60 means charges are calculated per full minute; a value of 1 means per-second billing. Applicable only for voice service types.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'The GSMA-defined or operator-defined destination zone code to which this IOT rate applies. Zones group countries or network destinations for wholesale tariff banding. Used in TAP file rating to match usage records to the correct IOT rate.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneName rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Name' ;
    rdfs:comment 'Human-readable name of the destination zone (e.g., \'Zone 1 - EU\', \'Zone 2 - Rest of World\'). Used in settlement reports, finance dashboards, and operator billing correspondence.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveRate rdf:type rdf:Property ;
    rdfs:label 'Effective Rate' ;
    rdfs:comment 'The net IOT rate after applying any negotiated discount_percentage to the standard iot_rate. Stored as a pre-computed field to support high-volume TAP file rating performance. Expressed in the tariff currency per rate_unit.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The calendar date on which this IOT tariff version ceases to be applicable. Null indicates an open-ended tariff with no defined expiry. Used to enforce correct rate selection during TAP file rating for a given usage date.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gsmaRateGroup rdf:type rdf:Property ;
    rdfs:label 'Gsma Rate Group' ;
    rdfs:comment 'The GSMA-defined rate group classification for this IOT tariff entry. Rate groups are published in the GSMA IOT rate tables and used to categorise wholesale rates for settlement and benchmarking purposes. Examples: RG1, RG2, RG3 for voice; DG1, DG2 for data.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeNetworkPlmn rdf:type rdf:Property ;
    rdfs:label 'Home Network Plmn' ;
    rdfs:comment 'The GSMA-assigned PLMN code (MCC+MNC) of the home operator network for which this IOT tariff is applicable. Enables multi-PLMN operators to maintain separate IOT rate tables per home network entity.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Initial Duration Seconds' ;
    rdfs:comment 'The initial billing period in seconds for voice calls, which may be charged at a different rate or as a flat fee before the standard per-interval rate applies. Common in IOT tariffs where the first 30 or 60 seconds are charged as a connection fee.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialRate rdf:type rdf:Property ;
    rdfs:label 'Initial Rate' ;
    rdfs:comment 'The IOT rate applied during the initial_duration_seconds period of a voice call, if different from the standard iot_rate. Null if no differentiated initial rate applies. Expressed in the tariff currency.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interOperatorTariffType rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Tariff Type' ;
    rdfs:comment 'Classification of the IOT tariff by commercial arrangement type. \'standard\' for GSMA-published rates, \'preferential\' for bilaterally negotiated lower rates, \'reciprocal\' for symmetric bilateral agreements, \'benchmark\' for reference rates used in dispute resolution.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Iot Publication Date' ;
    rdfs:comment 'The date on which this IOT tariff was officially published by the GSMA or notified by the visited operator. Used for audit trail and to verify compliance with GSMA notification lead-time requirements prior to the effective_from_date.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iotRate rdf:type rdf:Property ;
    rdfs:label 'Iot Rate' ;
    rdfs:comment 'The wholesale IOT rate charged by the visited operator to the home operator for the specified service type and destination zone. Expressed in the currency defined by currency_code. For voice: rate per minute; for SMS: rate per message; for data: rate per kilobyte or megabyte as defined by rate_unit. This is the principal quantitative fact of the IOT tariff record.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'The minimum wholesale charge applicable per usage event under this IOT tariff, expressed in the tariff currency. Ensures a floor charge is applied even for very short calls or minimal data usage. Used in TAP file rating to enforce minimum billing thresholds.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationReference rdf:type rdf:Property ;
    rdfs:label 'Notification Reference' ;
    rdfs:comment 'The reference number or identifier of the official GSMA or bilateral operator notification document that introduced or amended this IOT tariff. Provides an audit trail linking the tariff record to the formal inter-operator communication.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeEligible rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Eligible' ;
    rdfs:comment 'Indicates whether usage records rated under this IOT tariff are subject to NRTRDE near-real-time roaming data exchange reporting to the home operator. True for operators with NRTRDE obligations under GSMA PRD TD.57. Used for fraud detection and real-time roaming cost monitoring.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakIndicator rdf:type rdf:Property ;
    rdfs:label 'Peak Indicator' ;
    rdfs:comment 'Indicates whether this IOT tariff applies to peak, off-peak, or flat (time-independent) usage periods. Some bilateral roaming agreements differentiate IOT rates by time-of-day. \'flat\' indicates no time-of-day differentiation.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the IOT rate. Defines the denominator for the iot_rate value. \'per_minute\' for voice, \'per_message\' for SMS/MMS, \'per_kb\' or \'per_mb\' for data, \'per_event\' for supplementary services. Required for correct TAP file charge calculation.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for operational notes, special conditions, or exceptions associated with this IOT tariff record. Used by the interconnect team to document bilateral negotiation context, GSMA waiver references, or rate dispute notes.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'The rounding method applied to calculated IOT charges during TAP file rating. Governs how fractional charge amounts are rounded to the precision defined by tap_decimal_places. Ensures consistent charge calculation between home and visited operators.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSubtype rdf:type rdf:Property ;
    rdfs:label 'Service Subtype' ;
    rdfs:comment 'Granular classification of the roaming service within the service_type. Examples: MOC (Mobile Originated Call), MTC (Mobile Terminated Call), MO-SMS, MT-SMS, GPRS, VoLTE, 5G NR data. Used for detailed IOT rate differentiation and TAP file reconciliation. [ENUM-REF-CANDIDATE: moc|mtc|mo_sms|mt_sms|gprs|volte|5g_nr|mms_mo|mms_mt|supplementary — promote to reference product]' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native primary key or record identifier of this IOT tariff in the originating operational system (e.g., Amdocs Revenue Management tariff ID, Netcracker OSS catalogue ID). Enables traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Tap Decimal Places' ;
    rdfs:comment 'The number of decimal places used to express the IOT rate in TAP file records, as defined by the GSMA TAP3 specification. Governs the precision of charge amounts encoded in TAP files exchanged between operators. Typically 5 for most currencies.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapFileType rdf:type rdf:Property ;
    rdfs:label 'Tap File Type' ;
    rdfs:comment 'The GSMA file exchange format type for which this IOT tariff is applicable. TAP3 for standard roaming settlement files, NRTRDE for Near Real-Time Roaming Data Exchange files used for fraud detection, RAP for Returned Account Procedure files handling billing disputes.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this IOT tariff entry within the GSMA/operator tariff catalogue. Used as the business key in TAP file references and inter-operator correspondence.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Human-readable descriptive name for the IOT tariff entry, used in settlement reports, operator portals, and finance reconciliation dashboards.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle state of the IOT tariff record. Controls whether the tariff is eligible for use in TAP file rating and settlement invoice generation. \'superseded\' indicates a newer version has replaced this record.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffVersion rdf:type rdf:Property ;
    rdfs:label 'Tariff Version' ;
    rdfs:comment 'Version identifier for the IOT tariff record, enabling tracking of rate changes over time. Incremented each time the tariff is revised. Used to ensure TAP file rating applies the correct rate version.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Indicator' ;
    rdfs:comment 'Indicates whether the IOT rate is inclusive of applicable taxes (True) or exclusive of taxes (False). Relevant for operators in jurisdictions where VAT or GST applies to wholesale roaming charges. Impacts settlement invoice tax treatment.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Visited Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the visited network where the roaming subscriber consumed the service. Used to map usage to the correct IOT tariff zone and for regulatory reporting of international roaming charges.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitedNetworkPlmn rdf:type rdf:Property ;
    rdfs:label 'Visited Network Plmn' ;
    rdfs:comment 'The GSMA-assigned Public Land Mobile Network (PLMN) code (MCC+MNC) of the visited operator network. Used to uniquely identify the roaming partner network for IOT rate lookup and TAP file routing.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapFileId rdf:type rdf:Property ;
    rdfs:label 'Tap File Id' ;
    rdfs:comment 'Unique surrogate identifier for the TAP file record in the interconnect settlement system. Primary key for the tap_file data product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapFile .

ind:senderCarrierId rdf:type rdf:Property ;
    rdfs:label 'Sender Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: TAP file sender is currently denormalized via sender_tadig_code. Normalizing to interconnect_carrier provides authoritative carrier master reference and eliminates redundant country_code. The FK will ' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'The date and time at which the recipient operator or clearinghouse issued a formal acknowledgement (RAP or positive ACK) for this TAP file. Marks the completion of the file exchange lifecycle for settlement purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearinghouseReference rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Reference' ;
    rdfs:comment 'The unique reference number assigned by the inter-operator clearinghouse (e.g., GSMA Clearing House, Syniverse, BICS) upon receipt of this TAP file. Used for end-to-end traceability, dispute resolution, and reconciliation against clearinghouse settlement statements.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPeriodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Period End Timestamp' ;
    rdfs:comment 'The timestamp of the latest CDR event contained within this TAP file, representing the end of the usage data period covered by the batch. Used alongside data_period_start_timestamp for gap detection and completeness validation.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataPeriodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Period Start Timestamp' ;
    rdfs:comment 'The timestamp of the earliest CDR event contained within this TAP file, representing the start of the usage data period covered by the batch. Used for period-based reconciliation, billing cycle alignment, and regulatory reporting.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Creation Timestamp' ;
    rdfs:comment 'The date and time at which the TAP file was generated by the sending operator\'s mediation or billing system (Amdocs Revenue Management). Represents the principal business event time for the file batch. Used for timeliness SLA measurement per GSMA NRTRDE and TAP submission deadlines.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'The physical size of the TAP file in bytes as received from the sender or clearinghouse. Used for transmission integrity checks, storage capacity planning, and anomaly detection (unusually large or small files may indicate encoding errors).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current lifecycle state of the TAP file within the inter-operator settlement workflow. Transitions: created → sent → acknowledged (clean acceptance) or rejected (validation failure) → disputed (commercial challenge) or resubmitted (corrected re-send). Drives settlement reconciliation and SLA monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileType rdf:type rdf:Property ;
    rdfs:label 'File Type' ;
    rdfs:comment 'Classifies the type of inter-operator data exchange file: TAP (standard Transferred Account Procedure batch), NRTRDE (Near Real-Time Roaming Data Exchange for fraud detection), RAP (Returned Account Procedure for rejected records), or STOP (Stop file halting processing). Determines processing pipeline and settlement treatment.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestFile rdf:type rdf:Property ;
    rdfs:label 'Is Test File' ;
    rdfs:comment 'Indicates whether this TAP file is a test/simulation file (True) or a live production file (False) carrying real roaming charges. Test files must be excluded from financial settlement calculations and revenue reporting.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'The predominant radio access network technology type of the CDRs contained in this TAP file (e.g., LTE, 5G NR, VoLTE). Used for technology-segmented roaming analytics, IOT tariff differentiation, and network capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeReference rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Reference' ;
    rdfs:comment 'The reference identifier linking this TAP file to its corresponding NRTRDE near-real-time roaming data exchange record. NRTRDE files are transmitted within 4 hours of call completion for fraud detection; this reference enables correlation between the NRTRDE early notification and the final TAP settlement file.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Sequence Number' ;
    rdfs:comment 'For resubmitted TAP files, the sequence number of the original file that this resubmission replaces. Enables lineage tracing from corrected files back to the original rejected batch. Null for first-time submissions.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingOutcome rdf:type rdf:Property ;
    rdfs:label 'Processing Outcome' ;
    rdfs:comment 'The outcome of the TAP file processing pipeline within the operator\'s BSS/OSS systems (Amdocs Revenue Management, Netcracker OSS/BSS). Indicates whether all CDRs were successfully rated and posted to settlement accounts, partially processed, or failed. Drives exception management workflows.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapReference rdf:type rdf:Property ;
    rdfs:label 'Rap Reference' ;
    rdfs:comment 'The reference number of the RAP (Returned Account Procedure) file generated in response to validation failures in this TAP file. Links the TAP file to its corresponding rejection notification for dispute tracking and resubmission management.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The date and time at which the TAP file was received and acknowledged at the clearinghouse or by the recipient operator. Used to calculate transit latency and confirm delivery within bilateral SLA windows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientCountryCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the recipient operator\'s home country. Used for bilateral traffic analysis, regulatory reporting, and determining applicable IOT tariff zones and settlement currency conventions.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTadigCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Tadig Code' ;
    rdfs:comment 'The five-character TADIG code identifying the receiving (home) network operator to whom this TAP file is addressed. Determines routing through the clearinghouse and the settlement counterparty for IOT charges.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The reconciliation state of this TAP file against the clearinghouse settlement statement. Tracks whether the file\'s declared charges match the clearinghouse-confirmed amounts. Discrepancies trigger revenue assurance investigations. Used for MRR and ARPU reporting accuracy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'The number of times this TAP file has been resubmitted after rejection or dispute. A value greater than zero indicates the file has been corrected and resent. Used for operator performance monitoring and SLA compliance tracking.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The sequential file number assigned by the sending operator to uniquely identify this TAP file within the bilateral exchange. Follows GSMA TAP3 five-digit sequence numbering convention (00001–99999, wrapping). Used for duplicate detection and gap analysis in file receipt tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Statement Reference' ;
    rdfs:comment 'The reference number of the clearinghouse settlement statement that includes charges from this TAP file. Links the TAP file batch to the financial settlement document used for inter-operator payment and accounting entries in SAP S/4HANA.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time at which the TAP file was submitted to the clearinghouse or directly to the recipient operator. Used to measure compliance with GSMA TAP submission timeliness requirements (typically within 36 hours of the last CDR in the file).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCdrCount rdf:type rdf:Property ;
    rdfs:label 'Total Cdr Count' ;
    rdfs:comment 'The total number of Call Detail Records (CDRs) contained within this TAP file as declared in the file header. Used for completeness validation against the actual parsed record count and for settlement volume reporting.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'The gross total Inter-Operator Tariff (IOT) charge amount declared in the TAP file header, representing the sum of all roaming charges for CDRs in this batch. Expressed in the settlement currency. Used as the primary financial control total for clearinghouse reconciliation and operator settlement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'The total number of validation errors identified during TAP file parsing and structural/business rule validation. A non-zero value triggers RAP (Returned Account Procedure) generation. Used for quality monitoring and operator performance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorSummary rdf:type rdf:Property ;
    rdfs:label 'Validation Error Summary' ;
    rdfs:comment 'A structured summary of the validation errors encountered during TAP file processing, including error codes and descriptions as defined in the GSMA TAP3 specification. Supports root cause analysis, operator dispute resolution, and resubmission guidance.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Visited Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: TAP record visited carrier is denormalized via visited_network_tadig and visited_country_code. Normalizing to interconnect_carrier eliminates redundancy and provides authoritative carrier master refer' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:callEventType rdf:type rdf:Property ;
    rdfs:label 'Call Event Type' ;
    rdfs:comment 'Classification of the billable roaming event captured in this TAP record. MOC=Mobile Originated Call, MTC=Mobile Terminated Call, GPRS=data session, SMS_MO/MT=Short Message Service originated/terminated, MMS_MO/MT=Multimedia Message Service. [ENUM-REF-CANDIDATE: MOC|MTC|GPRS|SMS_MO|SMS_MT|MMS_MO|MMS_MT — promote to reference product]' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calledNumber rdf:type rdf:Property ;
    rdfs:label 'Called Number' ;
    rdfs:comment 'E.164 telephone number of the called party (B-number) for MOC voice events. Used for traffic analysis, fraud detection (e.g., IRSF detection), and regulatory reporting. Null for MTC, GPRS, and messaging events.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargedAmount rdf:type rdf:Property ;
    rdfs:label 'Charged Amount' ;
    rdfs:comment 'Gross monetary amount charged to the home network operator for this individual roaming event, expressed in the settlement currency. Calculated by the visited network by applying the applicable IOT rate to the consumed duration or volume.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeDownlinkKb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Downlink Kb' ;
    rdfs:comment 'Volume of data transmitted from the network to the subscriber\'s device (downlink) during a GPRS/data session, measured in kilobytes. Null for non-data call event types.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeUplinkKb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Uplink Kb' ;
    rdfs:comment 'Volume of data transmitted from the subscriber\'s device to the network (uplink) during a GPRS/data session, measured in kilobytes. Null for non-data call event types.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for the called party in MOC voice events. Used for international traffic analysis and IOT tariff zone classification.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of the voice call or data session in seconds as recorded by the visited network. Zero for instantaneous events (SMS/MMS). Used for IOT charge calculation and traffic analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Flag set to True when this TAP record has been identified as potentially fraudulent by the fraud management system (e.g., IRSF, SIM cloning, abnormal roaming patterns). Triggers investigation workflow in the Revenue Assurance domain.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Home Currency Amount' ;
    rdfs:comment 'Charged amount converted to the home network operator\'s functional accounting currency using the exchange_rate. Used for financial reporting, EBITDA calculation, and MRR/revenue recognition in SAP S/4HANA.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeNetworkTadig rdf:type rdf:Property ;
    rdfs:label 'Home Network Tadig' ;
    rdfs:comment '5-character GSMA TADIG code identifying the home network operator (HPMN) to which the roaming subscriber belongs and to whom the TAP file is addressed for settlement.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotRateApplied rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Applied' ;
    rdfs:comment 'The specific IOT unit rate applied by the visited network to calculate the charged amount for this roaming event (e.g., rate per minute for voice, rate per KB for data). Sourced from the applicable IOT tariff table in effect at the time of service.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iotRateUnit rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Unit' ;
    rdfs:comment 'Unit of measure for the IOT rate applied to this roaming event (e.g., PER_MINUTE for voice calls, PER_KB or PER_MB for data sessions, PER_MESSAGE for SMS/MMS).' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Location Area Code' ;
    rdfs:comment 'Location Area Code (LAC) or Tracking Area Code (TAC) identifying the geographic area within the visited network where the roaming subscriber was registered during this event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAccessTechnology rdf:type rdf:Property ;
    rdfs:label 'Network Access Technology' ;
    rdfs:comment 'Radio access technology used by the visiting subscriber during this roaming event (e.g., 2G/GSM, 3G/UMTS, 4G LTE, 5G NR). Relevant for IOT tariff differentiation and network analytics.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Transmission Timestamp' ;
    rdfs:comment 'UTC timestamp when this CDR was transmitted via the NRTRDE mechanism to the home network. Null if nrtrde_flag is False. Used to verify compliance with the GSMA 4-hour NRTRDE transmission SLA.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partialRecordIndicator rdf:type rdf:Property ;
    rdfs:label 'Partial Record Indicator' ;
    rdfs:comment 'Indicates whether this TAP record represents a partial CDR (e.g., a long-duration data session split across multiple records by the visited network). True=partial record requiring reassembly; False=complete single record.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current processing and settlement lifecycle status of this TAP roaming record. ACCEPTED=validated and accepted for settlement; REJECTED=failed TAP validation; DISPUTED=under inter-operator dispute; PENDING=awaiting validation; SETTLED=financially settled.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'GSMA-standard error/rejection code assigned when a TAP record fails validation (record_status = REJECTED). Codes are defined in GSMA TD.57 Annex and indicate the specific validation rule that was violated (e.g., missing mandatory field, invalid IMSI format, timestamp out of range).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingType rdf:type rdf:Property ;
    rdfs:label 'Roaming Type' ;
    rdfs:comment 'Indicates the direction of roaming from the perspective of the home network operator. INBOUND=a subscriber from another network is roaming on our network (we are the VPMN); OUTBOUND=our subscriber is roaming on another network (we are the HPMN).' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment '3GPP teleservice or bearer service code identifying the specific service used during this roaming event (e.g., 11=telephony, 22=SMS, 41=data circuit async). Maps to the TAP3 BasicServiceUsed element.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service End Timestamp' ;
    rdfs:comment 'UTC timestamp marking the exact moment the billable roaming event ended (call release for voice, session close for GPRS). Null for instantaneous events such as SMS/MMS.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Start Timestamp' ;
    rdfs:comment 'UTC timestamp marking the exact moment the billable roaming event began (call answer time for voice, session start for GPRS, message submission for SMS/MMS). Principal business event time per TAP3 specification.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementPeriod rdf:type rdf:Property ;
    rdfs:label 'Settlement Period' ;
    rdfs:comment 'Calendar month (YYYY-MM format) to which this TAP record is assigned for inter-operator financial settlement. Determines the billing cycle for IOT invoice generation between the visited and home network operators.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tap Creation Timestamp' ;
    rdfs:comment 'UTC timestamp when this TAP record was first created and written to the Databricks Silver Layer during TAP file ingestion and parsing. Audit trail for data lineage and SLA monitoring.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tapFileSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tap File Sequence Number' ;
    rdfs:comment 'Sequential file number assigned by the visited network operator to the TAP3 file containing this record. Together with visited_network_tadig and home_network_tadig, uniquely identifies the source TAP file for audit and reconciliation.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Tap Spec Version' ;
    rdfs:comment 'Version of the GSMA TAP3 specification used to encode this roaming record (e.g., TAP3R12). Required for correct parsing, validation, and backward-compatibility handling during TAP file processing.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeRecordId rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each NRTRDE event record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NrtrdeRecord .

ind:privacyConsentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_consent. Business justification: NRTRDE records contain near-real-time subscriber data requiring consent for processing and sharing with roaming partners. Essential for consent validation in real-time data exchange and GDPR complianc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyConsent .

ind:apn rdf:type rdf:Property ;
    rdfs:label 'Apn' ;
    rdfs:comment 'Access Point Name used by the roaming subscriber for the data session, identifying the packet data network gateway and service type (e.g., internet, IMS, enterprise VPN). Applicable for DATA record types. Used for data service classification and IOT tariff selection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Sequence Number' ;
    rdfs:comment 'Sequential number of the NRTRDE transmission batch (file) from the visited operator, used to detect missing batches and ensure complete data receipt. Increments with each new file transmission per GSMA BA.40 batch numbering rules.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Call Duration Seconds' ;
    rdfs:comment 'Duration of the voice call or supplementary service event in seconds, as reported by the visited network. Applicable for VOICE and SUPPLEMENTARY record types. Used for IOT charge calculation and revenue assurance validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Charge Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the estimated IOT charge is denominated (e.g., USD, EUR, GBP). Required for multi-currency settlement reconciliation between international operators.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Variance Amount' ;
    rdfs:comment 'Monetary difference between the estimated IOT charge in this NRTRDE record and the final charge confirmed in the reconciled TAP file. Populated after TAP reconciliation. Positive value indicates NRTRDE overestimated; negative indicates underestimation. Used for revenue assurance leakage analysis.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dialedNumber rdf:type rdf:Property ;
    rdfs:label 'Dialed Number' ;
    rdfs:comment 'The destination number dialed by the roaming subscriber for voice calls (B-party number in E.164 format). Applicable for MOC record types. Used for fraud detection (e.g., premium rate number abuse, international revenue share fraud) and traffic analysis.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Charge Amount' ;
    rdfs:comment 'Estimated wholesale charge for this roaming event calculated by the visited network using the applicable IOT tariff at time of NRTRDE transmission. This is a pre-settlement estimate; the final charge is confirmed in the TAP file. Used for early revenue assurance and cash flow forecasting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date (UTC) on which the roaming service event occurred, derived from service_start_timestamp. Used as a partition key in the Silver layer lakehouse for efficient time-range queries and daily revenue assurance reporting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudAlertIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Indicator' ;
    rdfs:comment 'Flag indicating that this NRTRDE record has triggered a fraud alert to the Revenue Assurance domain based on anomalous usage patterns (e.g., impossible travel, velocity breach, SIM cloning signatures). True = fraud alert raised; False = no alert.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highUsageIndicator rdf:type rdf:Property ;
    rdfs:label 'High Usage Indicator' ;
    rdfs:comment 'Flag set by the visited network indicating that this subscriber\'s cumulative roaming usage has exceeded a predefined high-usage threshold, triggering potential fraud alert or credit limit notification to the home operator per GSMA BA.40 high-usage detection rules.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeTadig rdf:type rdf:Property ;
    rdfs:label 'Home Tadig' ;
    rdfs:comment '5-character GSMA TADIG code identifying the subscriber\'s home network operator. Used to route NRTRDE records to the correct home PLMN for revenue assurance and fraud detection.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeVersion rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Version' ;
    rdfs:comment 'Version of the GSMA BA.40 NRTRDE standard used to generate this record (e.g., 2.0, 3.0). Required for backward-compatible processing as operators may transmit records under different standard versions during migration periods.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current lifecycle state of the NRTRDE record within the interconnect operations processing pipeline. RECEIVED=ingested from visited network; VALIDATED=passed format/content checks; ENRICHED=IOT tariff and agreement data applied; RECONCILED=matched to TAP file; REJECTED=failed validation; DISPUTED=charge under dispute.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Specific CDR record type classifying the direction and nature of the roaming event. MOC=Mobile Originated Call, MTC=Mobile Terminated Call, GPRS=data session, SMS_MO=outbound SMS, SMS_MT=inbound SMS. Aligns with TAP3 record type taxonomy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Indicator' ;
    rdfs:comment 'Flag indicating whether this NRTRDE record was transmitted outside the GSMA BA.40 4-hour SLA window (transmission_latency_minutes > 240). True = SLA breached; False = within SLA. Used for inter-operator SLA performance reporting and penalty calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Name of the NRTRDE transmission file from which this record was extracted, following GSMA BA.40 file naming conventions. Used for batch traceability, reprocessing, and audit trail in the interconnect operations pipeline.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Tap Reconciliation Status' ;
    rdfs:comment 'Status of reconciliation between this NRTRDE pre-TAP record and the corresponding TAP3 billing record. PENDING=TAP file not yet received; MATCHED=successfully reconciled; UNMATCHED=no corresponding TAP record found; PARTIAL=partial match with charge discrepancy. Critical for revenue assurance.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionLatencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Transmission Latency Minutes' ;
    rdfs:comment 'Elapsed time in minutes between service_start_timestamp and transmission_timestamp. Measures compliance with the GSMA BA.40 4-hour (240-minute) near-real-time transmission SLA. Records exceeding 240 minutes are flagged for SLA breach reporting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the NRTRDE record was transmitted by the visited network to the home network. Used to calculate transmission latency against the GSMA BA.40 4-hour SLA requirement from service delivery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peeringArrangementId rdf:type rdf:Property ;
    rdfs:label 'Peering Arrangement Id' ;
    rdfs:comment 'Unique surrogate identifier for the peering arrangement record in the interconnect domain. Primary key for this entity. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeeringArrangement .

ind:networkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: BGP peering sessions run on specific physical routers. Network engineers need to know which inventory.network_equipment asset hosts each peering arrangement for firmware upgrade scheduling, maintenanc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:partnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Partner Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: IP peering arrangements are governed by commercial partner agreements covering liability, dispute resolution, and payment terms. Linking enables peering contract lifecycle management and ensures peeri' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:peerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Peer Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: Peering arrangement peer is currently denormalized via peer_carrier_name. Normalizing to interconnect_carrier provides authoritative carrier master reference with full carrier attributes (TADIG, MCC/M' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:topologyId rdf:type rdf:Property ;
    rdfs:label 'Topology Id' ;
    rdfs:comment 'Foreign key linking to network.topology. Business justification: IP peering sessions map to specific topology entries representing inter-carrier logical links. NOC teams correlate peering arrangement performance (BGP session health, traffic ratios) against topology' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Topology .

ind:arrangementCode rdf:type rdf:Property ;
    rdfs:label 'Arrangement Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the peering arrangement (e.g., PEER-2024-NYC-001). Used in operational communications, NOC dashboards, and inter-carrier correspondence.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Descriptive human-readable name for the peering arrangement (e.g., \'Equinix NY4 Private Peering with AS64512\'). Used in reporting and NOC tooling.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementNotes rdf:type rdf:Property ;
    rdfs:label 'Arrangement Notes' ;
    rdfs:comment 'Free-text operational notes capturing special conditions, negotiation history, technical exceptions, or contextual information about this peering arrangement not captured in structured fields.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle state of the peering arrangement. draft = under negotiation; pending_approval = awaiting internal or regulatory sign-off; active = live and carrying traffic; suspended = temporarily halted; terminated = permanently ended; expired = passed effective end date without renewal.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this peering arrangement automatically renews upon expiry without requiring explicit renegotiation. True = auto-renews; False = requires manual renewal action before expiry_date.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Availability Target Pct' ;
    rdfs:comment 'Agreed minimum uptime percentage for the peering session as specified in the SLA (e.g., 99.9900 = 99.99%). Used for SLA compliance reporting and penalty calculation.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bgpSessionType rdf:type rdf:Property ;
    rdfs:label 'Bgp Session Type' ;
    rdfs:comment 'Type of BGP session established for this peering arrangement. ebgp = External BGP (standard inter-AS peering); ibgp = Internal BGP (used in route-reflector scenarios); ebgp_multihop = eBGP session across multiple IP hops.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Committed Bandwidth Mbps' ;
    rdfs:comment 'Minimum guaranteed bandwidth in megabits per second (Mbps) committed under this peering arrangement. Used for capacity planning, SLA enforcement, and billing in paid peering scenarios.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipVersion rdf:type rdf:Property ;
    rdfs:label 'Ip Version' ;
    rdfs:comment 'IP protocol version(s) supported by this peering session. ipv4 = IPv4 only; ipv6 = IPv6 only; dual_stack = both IPv4 and IPv6 sessions active. Drives network engineering and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ixpName rdf:type rdf:Property ;
    rdfs:label 'Ixp Name' ;
    rdfs:comment 'Name of the Internet Exchange Point (IXP) where public peering occurs (e.g., Equinix IX, DE-CIX, AMS-IX, LINX). Null for private PNI arrangements. Used for peering point inventory and cost allocation.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Latency Target Ms' ;
    rdfs:comment 'Maximum agreed one-way network latency in milliseconds (ms) for traffic traversing this peering arrangement as defined in the SLA. Used for QoS monitoring and SLA breach detection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bandwidth Mbps' ;
    rdfs:comment 'Maximum allowable bandwidth in megabits per second (Mbps) for this peering arrangement before traffic shaping or penalties apply. Defines the upper capacity envelope for the interconnect port.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:md5AuthEnabled rdf:type rdf:Property ;
    rdfs:label 'Md5 Auth Enabled' ;
    rdfs:comment 'Indicates whether MD5 TCP authentication is enabled on the BGP session for this peering arrangement to prevent session hijacking. True = MD5 authentication active; False = no MD5 authentication.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nocContactEmail rdf:type rdf:Property ;
    rdfs:label 'Noc Contact Email' ;
    rdfs:comment 'Email address of the peer carrier\'s Network Operations Center (NOC) for operational escalations, fault notifications, and maintenance coordination. Classified confidential as organizational contact data.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocContactPhone rdf:type rdf:Property ;
    rdfs:label 'Noc Contact Phone' ;
    rdfs:comment 'Phone number of the peer carrier\'s Network Operations Center (NOC) for 24/7 operational escalations and incident coordination. Classified confidential as organizational contact data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ourAsn rdf:type rdf:Property ;
    rdfs:label 'Our Asn' ;
    rdfs:comment 'BGP Autonomous System Number (ASN) of this carrier\'s routing domain used in this peering session. Required when the carrier operates multiple ASNs across different network segments.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ourBgpIpAddress rdf:type rdf:Property ;
    rdfs:label 'Our Bgp Ip Address' ;
    rdfs:comment 'IP address of this carrier\'s BGP router used to establish the peering session with the counterparty. May be IPv4 or IPv6. Classified confidential as it reveals internal network topology.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetLossTargetPct rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Target Pct' ;
    rdfs:comment 'Maximum agreed packet loss percentage for traffic on this peering arrangement as defined in the SLA (e.g., 0.0100 = 0.01%). Used for QoS (Quality of Service) performance monitoring.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peerAsn rdf:type rdf:Property ;
    rdfs:label 'Peer Asn' ;
    rdfs:comment 'BGP Autonomous System Number (ASN) of the peering counterparty as assigned by a Regional Internet Registry (ARIN, RIPE, APNIC). Uniquely identifies the peer\'s routing domain. Range: 1–4294967295 (32-bit ASN per RFC 6793).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peerBgpIpAddress rdf:type rdf:Property ;
    rdfs:label 'Peer Bgp Ip Address' ;
    rdfs:comment 'IP address of the counterparty\'s BGP router used to establish the peering session. May be IPv4 or IPv6. Classified confidential as it reveals network topology details.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringType rdf:type rdf:Property ;
    rdfs:label 'Peering Type' ;
    rdfs:comment 'Classification of the peering arrangement by commercial and technical model. public_ixp = peering via a public Internet Exchange Point; private_pni = Private Network Interconnect (dedicated cross-connect); settlement_free = no financial settlement between parties; paid = one or both parties pay for traffic exchange; partial = selective prefix exchange rather than full table.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portIdentifier rdf:type rdf:Property ;
    rdfs:label 'Port Identifier' ;
    rdfs:comment 'Unique identifier of the physical or logical interconnect port used for this peering arrangement (e.g., switch/port designation from the IXP or PNI cross-connect). Links to network inventory management.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portSpeedGbps rdf:type rdf:Property ;
    rdfs:label 'Port Speed Gbps' ;
    rdfs:comment 'Physical port speed in gigabits per second (Gbps) of the interconnect port used for this peering arrangement (e.g., 1.000, 10.000, 100.000). Used for capacity planning and utilization reporting.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prefixLimit rdf:type rdf:Property ;
    rdfs:label 'Prefix Limit' ;
    rdfs:comment 'Maximum number of BGP route prefixes this carrier will accept from the peer. Exceeding this limit triggers a BGP session reset or route filtering. Critical for route table stability and security.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratioTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Ratio Tolerance Pct' ;
    rdfs:comment 'Allowable percentage deviation from the agreed traffic ratio before the arrangement is considered out of balance and subject to review or financial settlement. Expressed as a percentage (e.g., 20.00 = ±20%).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days before expiry_date that a renewal notice must be issued to the peer carrier. Used to trigger automated renewal workflow alerts in the NOC and commercial teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpkiValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Rpki Validation Enabled' ;
    rdfs:comment 'Indicates whether Resource Public Key Infrastructure (RPKI) route origin validation is enforced on BGP announcements received from this peer. True = RPKI validation active; False = not enforced. Supports FCC routing security mandates.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Minimum number of calendar days\' written notice required to terminate this peering arrangement. Contractual obligation that governs decommissioning timelines.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficDirection rdf:type rdf:Property ;
    rdfs:label 'Traffic Direction' ;
    rdfs:comment 'Indicates whether traffic flows in both directions (bilateral), only from this carrier to the peer (unilateral), or whether the peer provides transit routing (transit). Drives settlement and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficRatioInbound rdf:type rdf:Property ;
    rdfs:label 'Traffic Ratio Inbound' ;
    rdfs:comment 'Agreed inbound traffic ratio component used to calculate the traffic balance ratio (e.g., 1.0 in a 1:1 ratio). Settlement-free peering typically requires ratios within a defined tolerance band (e.g., 1:2 or 2:1).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficRatioOutbound rdf:type rdf:Property ;
    rdfs:label 'Traffic Ratio Outbound' ;
    rdfs:comment 'Agreed outbound traffic ratio component used to calculate the traffic balance ratio (e.g., 2.0 in a 1:2 ratio). Imbalance beyond the agreed threshold may trigger renegotiation or conversion to paid peering.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Settlement Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the inter-carrier settlement invoice record in the Databricks Silver Layer. Primary key for the settlement_invoice data product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementInvoice .

ind:carrierCountryCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the counterparty carrier\'s home country. Used for geographic segmentation of inter-carrier settlement volumes, regulatory reporting, and IOT tariff zone determination.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'The invoice or settlement reference number assigned by the counterparty carrier. Used for cross-referencing and reconciliation between Telecommunication\'s internal invoice number and the carrier\'s own settlement document identifier.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTadigCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Tadig Code' ;
    rdfs:comment 'The GSMA TADIG (Transferred Account Data Interchange Group) five-character code uniquely identifying the counterparty carrier\'s network. Used in TAP file processing, NRTRDE exchange, and inter-operator settlement identification.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text or coded description of the reason for disputing this invoice. Common reasons include tariff misapplication, CDR count discrepancy, TAP file rejection, duplicate billing, or IOT rate disagreement. Populated when dispute_reference is set.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The net_payable_amount converted to Telecommunication\'s functional currency using the exchange_rate. Used for consolidated financial reporting, EBITDA calculation, and revenue assurance analytics.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for Telecommunication\'s functional/reporting currency into which the invoice amounts are converted using exchange_rate. Enables consolidated financial reporting across multi-currency carrier settlements.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The calendar date on which the settlement invoice was formally issued and transmitted to the counterparty carrier. This is the principal business event date for the invoice lifecycle and triggers the payment due date calculation.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iotTariffVersion rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Version' ;
    rdfs:comment 'The version identifier of the Inter-Operator Tariff (IOT) table applied when rating the traffic charges on this invoice. Ensures auditability of the tariff applied and supports dispute resolution when tariff versions change mid-period.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The net amount due for payment after subtracting disputed_amount and applying any approved credits or adjustments from the gross_amount plus tax_amount. This is the actionable settlement figure used for payment processing and financial ledger posting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Flag' ;
    rdfs:comment 'Indicates whether this invoice is subject to bilateral netting against a corresponding payable or receivable invoice with the same carrier for the same billing period. When True, the net_payable_amount reflects the netted position. Supports cash flow optimization in carrier settlement.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Netting Invoice Reference' ;
    rdfs:comment 'The invoice_number of the offsetting invoice used in bilateral netting. Populated only when netting_flag is True. Enables traceability of the netting pair for audit and reconciliation purposes.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Total Data Volume Mb' ;
    rdfs:comment 'Total data volume in megabytes (MB) covered by this settlement invoice. Used for data roaming and interconnect data charge reconciliation. Applicable to roaming TAP, interconnect_data, and wholesale invoice types.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSmsCount rdf:type rdf:Property ;
    rdfs:label 'Total Sms Count' ;
    rdfs:comment 'Total number of SMS messages included in this settlement invoice. Used for SMS interconnect charge reconciliation and IOT tariff validation. Applicable to roaming TAP and SMS termination/origination invoice types.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUsageMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Usage Minutes' ;
    rdfs:comment 'Aggregate voice usage duration in minutes covered by this settlement invoice. Used for traffic volume analysis, IOT tariff validation, and inter-carrier settlement reconciliation. Applicable primarily to voice termination, origination, and roaming invoices.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficType rdf:type rdf:Property ;
    rdfs:label 'Traffic Type' ;
    rdfs:comment 'Categorises the type of inter-carrier traffic covered by this invoice. \'roaming_tap\' covers outbound/inbound roaming settled via Transferred Account Procedure (TAP); \'transit\' covers traffic transiting through Telecommunication\'s network; \'termination\' and \'origination\' cover voice/SMS termination and origination charges; \'interconnect_data\' covers data interconnect; \'wholesale\' covers wholesale capacity arrangements.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Settlement Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each settlement invoice line item within the interconnect domain. Primary key for this entity.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementInvoiceLine .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment applied to this settlement line item following dispute resolution or TAP file error correction. Positive values increase the charge; negative values reduce it.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callEventCount rdf:type rdf:Property ;
    rdfs:label 'Call Event Count' ;
    rdfs:comment 'Number of individual Call Detail Records (CDRs) or usage events aggregated into this settlement line item. Used for reconciliation against TAP file record counts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Charge Amount' ;
    rdfs:comment 'The total gross charge for this settlement line item before any discounts, adjustments, or taxes are applied. Calculated as traffic_volume multiplied by unit_rate.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of this settlement invoice line item, providing additional context about the service, traffic type, or special billing arrangement for reconciliation and audit purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference code for this settlement invoice line, used in dispute correspondence and reconciliation with the counterpart carrier.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeFileReference rdf:type rdf:Property ;
    rdfs:label 'Nrtrde File Reference' ;
    rdfs:comment 'Reference to the NRTRDE file associated with this settlement line, enabling near-real-time roaming fraud detection cross-referencing and reconciliation against TAP-settled charges.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Originating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the originating country for this settlement line item. Used for inbound roaming analysis and bilateral traffic balance reporting.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Partner Operator Code' ;
    rdfs:comment 'GSMA TADIG (Transferred Account Data Interchange Group) code identifying the partner/counterpart operator for this settlement line. Used for carrier identification in TAP file processing and IOT settlement.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Partner Operator Name' ;
    rdfs:comment 'Full legal or trading name of the partner operator (carrier, MVNO, or transit provider) associated with this settlement line item.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the unit_rate. May differ from the settlement_currency_code when rate tables are maintained in SDR (Special Drawing Rights) or a reference currency.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAssuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Flag' ;
    rdfs:comment 'Indicates whether this settlement line item has been flagged by the revenue assurance process for further investigation (e.g., volume anomaly, rate mismatch, missing TAP records).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level classification of the telecommunications service type for this settlement line item. Drives IOT tariff selection and financial reporting by service type. [ENUM-REF-CANDIDATE: voice_termination|sms|data_roaming|transit|mms|supplementary_service|iptv|voip|content — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Service Period End' ;
    rdfs:comment 'The end date of the billing period or traffic window covered by this settlement invoice line item. Together with service_period_start, defines the chargeable period.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Service Period Start' ;
    rdfs:comment 'The start date of the billing period or traffic window covered by this settlement invoice line item. Defines the temporal scope for traffic volume and charge calculation.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tap Sequence Number' ;
    rdfs:comment 'The TAP file sequence number assigned by the sending operator, used to uniquely identify the TAP batch within the GSMA data exchange framework and to detect missing or duplicate TAP files.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficCategory rdf:type rdf:Property ;
    rdfs:label 'Traffic Category' ;
    rdfs:comment 'Classification of the traffic flow direction and type for this settlement line. Distinguishes inbound roaming (MVNO/visited network charges), outbound roaming, transit traffic, and wholesale termination for revenue assurance and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficVolume rdf:type rdf:Property ;
    rdfs:label 'Traffic Volume' ;
    rdfs:comment 'Total quantity of traffic units (calls, messages, data bytes, or events) included in this settlement line item. The unit of measure is defined by traffic_volume_unit.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Traffic Volume Unit' ;
    rdfs:comment 'Unit of measure for the traffic_volume field. Varies by service category: seconds/minutes for voice, messages for SMS/MMS, kilobytes/megabytes/gigabytes for data roaming. [ENUM-REF-CANDIDATE: seconds|minutes|messages|kilobytes|megabytes|gigabytes|events — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedAmount rdf:type rdf:Property ;
    rdfs:label 'Accepted Amount' ;
    rdfs:comment 'Portion of the original invoice or TAP file charge that Telecommunication accepts as valid and agrees to pay. The difference between the invoiced amount and the disputed amount. Part of MONETARY_TRIPLET canonical category (adjustment component).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierResponseDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Response Date' ;
    rdfs:comment 'Date on which the counterparty carrier formally responded to the dispute notification. Used to measure SLA compliance and track negotiation progress.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Carrier Response Notes' ;
    rdfs:comment 'Free-text summary of the carrier\'s formal response to the dispute, including their position, counter-evidence references, and proposed resolution.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteReference rdf:type rdf:Property ;
    rdfs:label 'Credit Note Reference' ;
    rdfs:comment 'Reference number of the credit note issued by the carrier as part of the dispute resolution. Populated when resolution_type is credit_note or partial_credit.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level grouping of the dispute: financial (monetary discrepancy), technical (CDR or TAP file format/content issue), or contractual (disagreement on agreement terms or IOT applicability).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Free-text narrative describing the nature of the dispute, the specific charges contested, and the business justification for the claim. Authored by the settlement analyst at the time of dispute creation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDirection rdf:type rdf:Property ;
    rdfs:label 'Dispute Direction' ;
    rdfs:comment 'Indicates whether Telecommunication is the disputing party (outbound — Telecommunication raises dispute against carrier) or the receiving party (inbound — carrier raises dispute against Telecommunication).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to this dispute at the time of creation. Used in all carrier-to-carrier correspondence and regulatory filings. Format: DSP-YYYY-NNNNNN. Aligns with BUSINESS_IDENTIFIER canonical category.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the disputed amount (e.g., USD, EUR, GBP). Required for multi-currency inter-operator settlement environments. Part of MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedCdrCount rdf:type rdf:Property ;
    rdfs:label 'Disputed Cdr Count' ;
    rdfs:comment 'Number of individual Call Detail Records (CDRs) included in the dispute. Relevant for volume_discrepancy, duplicate_record, and missing_record dispute types.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the dispute was escalated to senior management or a formal inter-carrier arbitration body. Null if the dispute has not been escalated.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interconnectType rdf:type rdf:Property ;
    rdfs:label 'Interconnect Type' ;
    rdfs:comment 'Classification of the interconnect arrangement under which the disputed charges arose: bilateral roaming, transit traffic, peering, wholesale voice, or wholesale data. [ENUM-REF-CANDIDATE: bilateral_roaming|transit|peering|wholesale_voice|wholesale_data — promote to reference product]' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total amount as stated on the original settlement invoice or TAP file that is the subject of this dispute. Provides the baseline for calculating the disputed and accepted portions.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSlaBreached rdf:type rdf:Property ;
    rdfs:label 'Is Sla Breached' ;
    rdfs:comment 'Indicates whether the carrier has failed to respond or resolve the dispute within the contractually agreed SLA timeframe. True when current date exceeds sla_resolution_due_date and dispute_status is not resolved or closed.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'Final agreed monetary amount to be credited, refunded, or adjusted as the outcome of the dispute resolution. Populated only when dispute_status is resolved or closed. Part of MONETARY_TRIPLET canonical category (net total).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Free-text narrative documenting the agreed resolution outcome, including the rationale for the resolution amount and any corrective actions agreed between the carriers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Classification of how the dispute was resolved: credit_note (carrier issues a credit), partial_credit (partial adjustment agreed), full_acceptance (Telecommunication accepts the original charge), withdrawal (dispute withdrawn by Telecommunication), arbitration_award (resolved via formal arbitration).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End' ;
    rdfs:comment 'End date of the billing or settlement period covered by the disputed invoice or TAP file.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start' ;
    rdfs:comment 'Start date of the billing or settlement period covered by the disputed invoice or TAP file. Used to correlate disputes with specific traffic periods and IOT tariff versions.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResolutionDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Due Date' ;
    rdfs:comment 'Contractual deadline by which the dispute must be fully resolved as defined in the inter-operator agreement SLA terms. Used for SLA breach monitoring and escalation triggers.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Date' ;
    rdfs:comment 'Contractual deadline by which the carrier must respond to the dispute as defined in the roaming or interconnect agreement SLA terms.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemDisputeReference rdf:type rdf:Property ;
    rdfs:label 'Source System Dispute Reference' ;
    rdfs:comment 'Native identifier of this dispute record in the originating operational system (e.g., Amdocs case number, Netcracker dispute ID). Enables traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer rate record that replaced this one when rate_status is \'superseded\'. Enables forward navigation of the rate version chain for audit and dispute resolution purposes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Structural basis on which the rate is calculated: flat (single rate regardless of volume), tiered (rate changes at volume thresholds), volume_discount (discounted rate applied retroactively above threshold), or distance_based (rate varies by geographic distance between interconnect points). Determines the rating algorithm applied.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPrefix rdf:type rdf:Property ;
    rdfs:label 'Destination Prefix' ;
    rdfs:comment 'E.164 dialled number prefix or number range (e.g., \'+1202\', \'+44207\') to which this rate applies. Enables prefix-based rate lookup during CDR rating and settlement. May represent a country code, area code, or specific number block.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectPointCode rdf:type rdf:Property ;
    rdfs:label 'Interconnect Point Code' ;
    rdfs:comment 'Code identifying the specific Point of Presence (POP) or interconnect gateway at which traffic is exchanged under this rate. Rates may vary by interconnect point due to transport cost differences. Aligns with network inventory records.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffClass rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Class' ;
    rdfs:comment 'IOT tariff classification code as defined by GSMA inter-operator tariff tables, applicable when this rate is used for roaming wholesale settlement. Maps to the GSMA IOT rate category (e.g., IOT-A, IOT-B, IOT-C) for NRTRDE and TAP file processing.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCallDurationSec rdf:type rdf:Property ;
    rdfs:label 'Minimum Call Duration Sec' ;
    rdfs:comment 'Minimum billable call duration in seconds applied during rating. Calls shorter than this threshold are billed at this minimum (e.g., 30-second minimum billing). Common in wholesale voice interconnect agreements to prevent micro-call gaming.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrtrdeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Applicable Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to NRTRDE (Near Real-Time Roaming Data Exchange) reporting obligations. When true, CDRs rated under this rate must be transmitted to the counterparty within the NRTRDE transmission window for fraud prevention purposes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offPeakRate rdf:type rdf:Property ;
    rdfs:label 'Off Peak Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during off-peak hours (typically evenings and nights on weekdays). Lower than peak rate to reflect reduced network demand. Expressed in settlement currency per billing unit.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakRate rdf:type rdf:Property ;
    rdfs:label 'Peak Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during peak hours (typically business hours on weekdays). Expressed in the settlement currency per billing unit (e.g., per minute for voice, per event for SMS, per MB for data). This is the principal quantitative rate value for the resource.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this rate entry within the wholesale rate schedule. Used in TAP file references and inter-operator billing reconciliation.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Human-readable descriptive name for the rate entry (e.g., \'US Domestic Voice Termination Peak\', \'EU Roam-Like-At-Home SMS\'). Used in rate schedule documentation and commercial negotiations.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle state of the rate record: active (currently in force for rating), pending (approved but not yet effective), superseded (replaced by a newer rate version), expired (past effective period), or withdrawn (cancelled before activation). Controls whether the rate is used in CDR rating and settlement.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate by traffic direction and role: termination (delivering traffic to destination network), origination (collecting traffic from originating network), transit (passing traffic through an intermediate network), transit_international (cross-border transit), or access (local loop access charge). Governs regulatory framework applicability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapRate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Cap Rate' ;
    rdfs:comment 'Maximum rate permitted by the applicable regulatory framework for this service type and destination (e.g., EU RLAH wholesale voice cap of €0.032/min, Ofcom FAMR charge control ceiling). The actual rate must not exceed this cap. Used for compliance validation and regulatory reporting.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingIncrementSec rdf:type rdf:Property ;
    rdfs:label 'Rounding Increment Sec' ;
    rdfs:comment 'Duration increment in seconds to which call durations are rounded up for billing purposes (e.g., 6-second or 60-second rounding). Directly impacts settlement amounts and must align with the counterparty carrier agreement terms.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapRateCategory rdf:type rdf:Property ;
    rdfs:label 'Tap Rate Category' ;
    rdfs:comment 'TAP file rate category code as defined in the GSMA Transferred Account Procedure (TAP3) specification. Maps this rate to the correct TAP record type for inter-operator roaming settlement file generation and validation.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier (e.g., \'America/New_York\', \'Europe/London\') used to interpret peak/off-peak/weekend time boundaries for this rate. Ensures correct tier selection across geographic regions and daylight saving transitions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Unit of measure against which the rate is applied for billing purposes: per_minute or per_second for voice, per_event for SMS/MMS, per_mb/per_kb/per_gb for data. Determines how CDR volumes are multiplied by the rate to produce settlement charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Sequential version number of this rate record, incremented each time the rate is amended. Enables rate history tracking and ensures the correct version is applied to CDRs within a given effective period. Version 1 is the initial rate.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold' ;
    rdfs:comment 'Minimum traffic volume (in the rate_unit) at which a tiered or volume-discount rate becomes applicable. Null for flat-rate structures. Used by the rating engine to select the correct rate tier based on cumulative monthly traffic volumes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weekendRate rdf:type rdf:Property ;
    rdfs:label 'Weekend Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during weekend periods (Saturday and Sunday). May differ from both peak and off-peak weekday rates. Expressed in settlement currency per billing unit.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mnpTransactionId rdf:type rdf:Property ;
    rdfs:label 'Mnp Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each Mobile Number Portability (MNP) transaction record in the interconnect domain. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MnpTransaction .

ind:donorCarrierId rdf:type rdf:Property ;
    rdfs:label 'Donor Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: MNP transaction donor carrier is heavily denormalized with donor_tadig_code, donor_carrier_name, donor_mcc, donor_mnc. Normalizing to interconnect_carrier eliminates all redundancy and provides author' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:hlrInventoryNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Hlr Inventory Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: MNP transactions require HLR/HSS updates on specific physical network equipment. Troubleshooting failed ports and SLA breach analysis require knowing which inventory.network_equipment (HLR/HSS node) p' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:hlrNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Hlr Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Mobile number portability requires HLR/HSS updates to redirect routing. Operations must track which HLR/HSS network element processed each port for audit, troubleshooting, and regulatory compliance. R' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:mnpComplianceId rdf:type rdf:Property ;
    rdfs:label 'Mnp Compliance Id' ;
    rdfs:comment 'Foreign key linking to compliance.mnp_compliance. Business justification: Each porting transaction generates a compliance record tracking SLA adherence, authorization verification, regulatory notification. Essential for porting compliance monitoring, regulatory reporting, a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MnpCompliance .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Port-in MNP transactions are the operational fulfillment of a won sales opportunity (competitor win). Telecom sales operations track port-in completions against opportunities for win-rate reporting, s' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:poiId rdf:type rdf:Property ;
    rdfs:label 'Poi Id' ;
    rdfs:comment 'Foreign key linking to interconnect.poi. Business justification: MNP transactions involve physical or logical interconnect handoff points for number porting. The POI (Point of Interconnect) is the physical/logical boundary where the porting transaction is executed ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Poi .

ind:recipientPartnerId rdf:type rdf:Property ;
    rdfs:label 'Recipient Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Number portability transactions often involve partner networks (MVNOs) as recipient operators. Business process: MNP coordination with partner operators, regulatory compliance reporting, partner opera' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:authorisationCode rdf:type rdf:Property ;
    rdfs:label 'Authorisation Code' ;
    rdfs:comment 'The Port Authorisation Code (PAC) or equivalent subscriber-provided authorisation token used to validate the subscriber\'s consent for the port-out. Mandatory in many regulatory frameworks (e.g., Ofcom PAC regime, FCC subscriber verification). Null for port-in transactions where PAC is consumed by the gaining operator.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchFileReference rdf:type rdf:Property ;
    rdfs:label 'Batch File Reference' ;
    rdfs:comment 'Reference to the batch file or TAP/NRTRDE file submission in which this MNP transaction was included for inter-operator exchange or regulatory reporting. Supports reconciliation with interconnect file processing workflows.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text description of the reason the MNP request was cancelled. Populated only when port_status = \'cancelled\'. Common reasons include subscriber withdrawal, duplicate request cancellation, or operator-initiated cancellation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The actual date and time when the number portability transfer was successfully completed and the MSISDN became active on the recipient network. Null if the port has not yet completed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Status' ;
    rdfs:comment 'Result of the fraud prevention check performed on the MNP request. \'not_checked\' — fraud screening not yet performed; \'passed\' — no fraud indicators detected; \'flagged\' — suspicious activity detected, under review; \'blocked\' — request blocked due to confirmed fraud. Supports GSMA fraud prevention guidelines.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlrHssUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Hlr Hss Update Status' ;
    rdfs:comment 'Status of the HLR (2G/3G) or HSS/UDM (4G/5G) subscriber profile update triggered by the MNP transaction. \'pending\' — update not yet sent; \'completed\' — subscriber profile successfully updated; \'failed\' — update failed, requiring manual intervention.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interOperatorChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Charge Applicable' ;
    rdfs:comment 'Indicates whether an inter-operator charge (IOT) is applicable for this MNP transaction under the governing carrier agreement. True = charge applies and will be raised in settlement; False = no charge applicable (e.g., regulatory zero-rating or waiver).' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npacOrderReference rdf:type rdf:Property ;
    rdfs:label 'Npac Order Reference' ;
    rdfs:comment 'The order identifier assigned by the Number Portability Administration Centre (NPAC) or equivalent national clearinghouse system (e.g., Syniverse, CODA) for this porting transaction. Used for cross-system reconciliation and regulatory audit.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberRangeOwner rdf:type rdf:Property ;
    rdfs:label 'Number Range Owner' ;
    rdfs:comment 'The operator or entity that holds the ITU/national regulatory authority allocation of the number range (NXX or equivalent) containing the ported MSISDN. May differ from the donor operator in MVNO or wholesale scenarios.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Port Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this MNP porting request by the Number Portability Administration Centre (NPAC) or equivalent national clearinghouse. Used for cross-operator tracking and regulatory audit.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portStatus rdf:type rdf:Property ;
    rdfs:label 'Port Status' ;
    rdfs:comment 'Current lifecycle status of the MNP transaction. \'pending\' — request received and awaiting validation; \'validated\' — subscriber eligibility confirmed; \'completed\' — number successfully ported; \'rejected\' — request denied (see rejection_reason); \'cancelled\' — request withdrawn before completion.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portType rdf:type rdf:Property ;
    rdfs:label 'Port Type' ;
    rdfs:comment 'Indicates the direction of the number portability event from Telecommunication\'s perspective. \'port_in\' means the subscriber is moving their number to Telecommunication from another operator (donor). \'port_out\' means the subscriber is leaving Telecommunication to another operator (recipient).' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Porting Duration Hours' ;
    rdfs:comment 'The elapsed time in hours between request_timestamp and completion_timestamp. Used for SLA compliance monitoring against regulatory maximum porting time mandates (e.g., FCC 1-business-day rule, Ofcom 1-working-day rule). Null if port not yet completed.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Porting Window End' ;
    rdfs:comment 'The scheduled end date and time of the porting window. If the port is not completed within this window, the transaction may expire or require rescheduling per regulatory requirements.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Porting Window Start' ;
    rdfs:comment 'The scheduled start date and time of the porting window during which the number transfer is authorised to execute. Regulatory frameworks (e.g., FCC, Ofcom) mandate specific porting windows.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientCarrierName rdf:type rdf:Property ;
    rdfs:label 'Recipient Carrier Name' ;
    rdfs:comment 'Human-readable commercial name of the recipient (gaining) operator. Complements recipient_tadig_code for reporting and business user readability.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'The latest permissible timestamp by which the MNP transaction must be completed under applicable regulatory rules (e.g., FCC 1-business-day, Ofcom 1-working-day). Used for SLA breach detection and regulatory compliance monitoring.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text narrative description of the rejection reason, providing additional context beyond the rejection_reason_code. Populated only when port_status = \'rejected\'. Used for dispute resolution and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The date and time when the MNP porting request was formally submitted by the subscriber or the gaining operator. This is the principal business event timestamp marking the start of the porting lifecycle.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times this MNP transaction has been retried following a failure or rejection. Used for operational monitoring, SLA tracking, and identifying systemic porting issues with specific operators.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The routing number (RN) assigned to the ported MSISDN in the Number Portability database, used by all operators to correctly route calls and SMS to the ported number on the recipient network. Aligned with ITU-T E.164 routing principles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumberUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Number Update Status' ;
    rdfs:comment 'Indicates whether the routing number in the Number Portability database and HLR/HSS/UDM has been successfully updated following port completion. \'pending\' — update queued; \'updated\' — successfully propagated; \'failed\' — update error requiring intervention; \'not_required\' — no routing change needed.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The monetary amount charged or credited between Telecommunication and the counterparty operator for this MNP transaction under the applicable inter-operator tariff (IOT). Expressed in the settlement currency defined in the carrier agreement. Null if inter_operator_charge_applicable = False.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this MNP transaction exceeded the regulatory or contractual maximum porting time SLA. True = SLA breached; False = within SLA. Used for regulatory compliance reporting and inter-operator dispute management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriberConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Subscriber Consent Verified' ;
    rdfs:comment 'Indicates whether the subscriber\'s explicit consent for the number port has been verified and recorded, as required by regulatory frameworks. True = consent confirmed; False = consent not yet verified or verification failed. Critical for regulatory compliance.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceDepotId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: Telecom operations assign each Point of Interconnect to a responsible depot for maintenance dispatch. The depot-to-POI geographic assignment drives which technician crews are dispatched for POI mainte' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:nmsElementId rdf:type rdf:Property ;
    rdfs:label 'Nms Element Id' ;
    rdfs:comment 'Identifier of the corresponding network element in the Network Management System (NMS) — Nokia NetAct or Ericsson Network Manager — that monitors this POI. Enables correlation between the business POI record and real-time network telemetry.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:redundantPoiId rdf:type rdf:Property ;
    rdfs:label 'Redundant Poi Id' ;
    rdfs:comment 'Self-referencing identifier of the backup or redundant POI that provides failover capacity for this POI. Null if no redundant POI is designated. Used in network resilience and failover planning.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Poi .

ind:responsibleTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Responsible Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Telecommunications POIs require assigned technicians for maintenance, fault resolution, capacity upgrades, and emergency response. Business process: POI maintenance scheduling, SLA compliance tracking' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:bandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mbps' ;
    rdfs:comment 'Total provisioned bandwidth capacity at this POI in megabits per second (Mbps). Applicable primarily for IP/SIP, MPLS, and Ethernet interconnect types. Used for traffic engineering and QoS planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clliCode rdf:type rdf:Property ;
    rdfs:label 'Clli Code' ;
    rdfs:comment 'Telcordia/iconectiv Common Language Location Identifier (CLLI) code for the network element or building where this POI is located. Industry-standard 11-character code used in OSS provisioning and regulatory filings.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmdbCiReference rdf:type rdf:Property ;
    rdfs:label 'Cmdb Ci Reference' ;
    rdfs:comment 'ServiceNow CMDB Configuration Item (CI) identifier for this POI. Enables linking the POI business record to ITSM incident, change, and problem management workflows.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name of the data center or colocation facility hosting the POI for IP-based or MPLS interconnects (e.g., \'Equinix NY5\', \'CyrusOne Dallas\'). Applicable for IP/SIP and MPLS interconnect types.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which this POI was or is scheduled to be permanently decommissioned and removed from service. Null if the POI is still active. Used for lifecycle management and capacity reclamation planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeName rdf:type rdf:Property ;
    rdfs:label 'Exchange Name' ;
    rdfs:comment 'Name of the telephone exchange, central office, or network exchange facility where the POI is physically housed (e.g., \'Manhattan Central Office\', \'Chicago Exchange 5\'). Used in OSS topology mapping.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Traffic jurisdiction classification for this POI. INTERSTATE = traffic crossing state lines (FCC jurisdiction); INTRASTATE = within-state traffic (state PUC jurisdiction); INTERNATIONAL = cross-border traffic; LOCAL = local exchange traffic. Determines applicable tariff and regulatory regime.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window' ;
    rdfs:comment 'Scheduled maintenance window for this POI expressed as a cron-style or free-text schedule (e.g., \'SUN 02:00-04:00 UTC\'). Used by NOC for planned outage coordination and change management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocContact rdf:type rdf:Property ;
    rdfs:label 'Noc Contact' ;
    rdfs:comment 'Contact details (name, phone, or email) for the Network Operations Center (NOC) team responsible for monitoring and managing this POI. Used for fault escalation and incident coordination.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle state of the POI. ACTIVE = in-service and carrying traffic; PROVISIONING = being set up; SUSPENDED = temporarily halted; DECOMMISSIONED = permanently retired from service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiCategory rdf:type rdf:Property ;
    rdfs:label 'Poi Category' ;
    rdfs:comment 'Business classification of the POI by traffic scope. DOMESTIC = national carrier interconnect; INTERNATIONAL = cross-border carrier handoff; TRANSIT = pass-through traffic routing; PEERING = bilateral traffic exchange; WHOLESALE = MVNO or reseller interconnect.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiCode rdf:type rdf:Property ;
    rdfs:label 'Poi Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the POI, used in regulatory filings, carrier agreements, and OSS/BSS systems. Unique across all interconnect points. Sourced from Netcracker OSS/BSS Resource Inventory.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiName rdf:type rdf:Property ;
    rdfs:label 'Poi Name' ;
    rdfs:comment 'Human-readable descriptive name for the POI, typically referencing the exchange location or data center (e.g., \'NYC-Manhattan-Equinix-POI-01\'). Used in operational dashboards and carrier communications.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:popCode rdf:type rdf:Property ;
    rdfs:label 'Pop Code' ;
    rdfs:comment 'Code identifying the Point of Presence (POP) network node associated with this POI. A POP is the physical network access location; multiple POIs may share a POP. Used in network topology and routing tables.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStandard rdf:type rdf:Property ;
    rdfs:label 'Protocol Standard' ;
    rdfs:comment 'Signaling or routing protocol standard used at this POI. SIP = Session Initiation Protocol; H.323 = ITU multimedia protocol; SS7 = Signaling System 7 (PSTN); ISUP = ISDN User Part; SIGTRAN = SS7 over IP; BGP = Border Gateway Protocol; LDP = Label Distribution Protocol (MPLS).' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyFlag rdf:type rdf:Property ;
    rdfs:label 'Redundancy Flag' ;
    rdfs:comment 'Indicates whether this POI has a redundant or backup interconnect path configured (True = redundant path exists; False = single path, no redundancy). Critical for SLA risk assessment and network resilience planning.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Regulatory classification of the POI as determined by applicable telecommunications authority (e.g., FCC, Ofcom, BEREC). Determines whether interconnect rates are tariff-regulated or commercially negotiated. Critical for compliance reporting.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityCircuits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Circuits' ;
    rdfs:comment 'Total provisioned circuit capacity at this POI expressed as number of circuits (DS0 equivalents for TDM, or logical channels for IP). Principal quantitative measure of the POI resource. Used for capacity planning and SLA enforcement.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trunkGroupCode rdf:type rdf:Property ;
    rdfs:label 'Trunk Group Code' ;
    rdfs:comment 'Reference to the trunk group associated with this POI. A trunk group is a logical bundle of circuits or channels provisioned at this interconnect point for traffic routing.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usedCapacityCircuits rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Circuits' ;
    rdfs:comment 'Number of circuits currently in active use at this POI. Used to calculate utilization percentage for capacity management, congestion alerting, and expansion planning.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Reference to the physical installation address for orders requiring field work (FTTH, GPON, CPE installation, fixed-line provisioning). Links to the address/location master in the Network or Customer domain. Null for mobile-only orders with no physical installation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit. Business justification: Regulatory and high-value orders (is_regulatory_order=true) are subject to compliance audits. Linking fulfillment_order to the audit record enables auditors to directly reference the order under revie' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:dealerId rdf:type rdf:Property ;
    rdfs:label 'Dealer Id' ;
    rdfs:comment 'Foreign key linking to partner.dealer. Business justification: Dealer-originated orders require direct dealer attribution for commission calculation, quota tracking, and dealer performance measurement - standard telecommunications indirect channel sales process.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealer .

ind:deviceModelId rdf:type rdf:Property ;
    rdfs:label 'Device Model Id' ;
    rdfs:comment 'Foreign key linking to product.device_model. Business justification: Device order fulfillment: when a handset or CPE device is ordered, the fulfillment order must reference the specific device model for logistics, inventory allocation, and device provisioning workflows' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceModel .

ind:iotDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Iot Deployment Id' ;
    rdfs:comment 'Foreign key linking to enterprise.iot_deployment. Business justification: Fulfillment orders for IoT deployment activation, expansion, or decommissioning must reference the IoT deployment at order header level for deployment-level order tracking and project management repor' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IotDeployment .

ind:networkElementId rdf:type rdf:Property ;
    rdfs:label 'Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Orders for broadband/fiber services require assignment to specific network elements (DSLAM, OLT, BRAS) during fulfillment. Critical for network resource allocation, capacity management, and provisioni' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Order-to-cash traceability: a fulfillment order is generated from an accepted quote. Telecom revenue assurance and billing teams require the fulfillment order to reference its originating quote to val' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:revenueSharePlanId rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Plan Id' ;
    rdfs:comment 'Foreign key linking to partner.revenue_share_plan. Business justification: Partner and dealer-originated fulfillment orders are governed by a specific revenue share plan determining commission rates and settlement terms. Telecom operators link orders directly to the applicab' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueSharePlan .

ind:sdwanTopologyId rdf:type rdf:Property ;
    rdfs:label 'Sdwan Topology Id' ;
    rdfs:comment 'Foreign key linking to enterprise.sdwan_topology. Business justification: Fulfillment orders for SD-WAN topology provisioning, site additions, or topology changes must reference the SD-WAN topology. Enables topology-level order history and multi-site rollout project trackin' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdwanTopology .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'The precise date and time when the fulfillment order was actually completed and all downstream provisioning tasks confirmed. Used to calculate actual fulfillment duration, SLA adherence, and MTTR reporting. Null until order reaches COMPLETED status. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The precise date and time when the fulfillment order was cancelled. Null for non-cancelled orders. Used for cancellation rate analytics, churn analysis, and order fallout reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'The outcome of the credit assessment performed during order processing. APPROVED: customer passed credit check. DECLINED: order blocked due to credit failure. WAIVED: credit check bypassed (e.g., existing premium customer). Drives order workflow progression in Oracle Communications OSM.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionStrategy rdf:type rdf:Property ;
    rdfs:label 'Decomposition Strategy' ;
    rdfs:comment 'The strategy used by Oracle Communications OSM to decompose the fulfillment order into sub-orders and tasks for downstream OSS/BSS systems. Drives orchestration efficiency and parallel provisioning capabilities.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalOrderReference rdf:type rdf:Property ;
    rdfs:label 'External Order Reference' ;
    rdfs:comment 'The order reference number from an external or upstream system (e.g., Salesforce CRM opportunity ID, dealer portal order number, B2B customer\'s purchase order number). Enables cross-system order tracing and reconciliation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutCategory rdf:type rdf:Property ;
    rdfs:label 'Fallout Category' ;
    rdfs:comment 'Categorical classification of the order fallout reason, enabling structured reporting and trend analysis on order failure types. Complements fallout_reason with a standardized taxonomy for operational dashboards.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutReason rdf:type rdf:Property ;
    rdfs:label 'Fallout Reason' ;
    rdfs:comment 'Descriptive reason code or message explaining why the fulfillment order failed or was placed on hold during orchestration. Populated by Oracle Communications OSM when order_status transitions to FAILED or ON_HOLD. Critical for fallout management, root cause analysis, and process improvement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Field Work Required' ;
    rdfs:comment 'Indicates whether this fulfillment order requires a field technician dispatch for physical installation or maintenance (e.g., FTTH CPE installation, ONT provisioning). Drives integration with Granite Telecommunications Workforce Management for scheduling and dispatch.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryOrder rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Order' ;
    rdfs:comment 'Indicates whether this fulfillment order is subject to specific regulatory mandates (e.g., FCC MNP porting deadlines, emergency service provisioning, Ofcom consumer protection rules). Regulatory orders receive elevated priority and mandatory compliance reporting.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpRecipientOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Mnp Recipient Operator Code' ;
    rdfs:comment 'For MNP_PORT_OUT orders: the network operator code of the recipient (gaining) operator to whom the mobile number is being ported. Used for inter-operator coordination and MNP regulatory reporting. Null for non-MNP order types.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The sales or service channel through which the fulfillment order was submitted. Used for channel performance analytics, cost-to-serve analysis, and omnichannel reporting. [ENUM-REF-CANDIDATE: ONLINE|RETAIL_STORE|CALL_CENTER|DEALER|SELF_SERVICE|B2B_PORTAL|FIELD_SALES — promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the fulfillment order. Communicated to customers, field technicians, and partner systems. Sourced from Oracle Communications Order and Service Management (OSM) as the canonical order reference number.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Business priority level assigned to the fulfillment order, influencing queue position in orchestration workflows and resource allocation. CRITICAL is reserved for regulatory-mandated orders (e.g., emergency services, MNP regulatory deadlines).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Order Source System' ;
    rdfs:comment 'The originating system or application from which the fulfillment order was submitted. Used for channel attribution, integration troubleshooting, and data lineage tracking. [ENUM-REF-CANDIDATE: OSM|SALESFORCE_CRM|SELF_SERVICE_PORTAL|B2B_PORTAL|DEALER_PORTAL|IVR|RETAIL_POS — promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the fulfillment order within the OSS/BSS orchestration workflow. Drives jeopardy management, SLA monitoring, and customer communication triggers. Sourced from Oracle Communications OSM order state machine.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the fulfillment order by the nature of the service change being requested. Drives orchestration workflow selection, SLA type assignment, and regulatory reporting. [ENUM-REF-CANDIDATE: NEW_ACTIVATION|UPGRADE|DOWNGRADE|DISCONNECTION|MNP_PORT_IN|MNP_PORT_OUT|CHANGE_OF_SERVICE — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Porting Authorization Code' ;
    rdfs:comment 'The Porting Authorization Code provided by the donor operator to authorize the number port. Required for MNP_PORT_IN orders to validate the customer\'s right to port. Null for non-MNP order types.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingNumber rdf:type rdf:Property ;
    rdfs:label 'Porting Number' ;
    rdfs:comment 'The MSISDN (mobile phone number) being ported in MNP_PORT_IN or MNP_PORT_OUT orders. Classified as confidential PII as it directly identifies a subscriber. Null for non-MNP order types. Required for NRTRDE and TAP regulatory reporting.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Promised Completion Date' ;
    rdfs:comment 'The date committed to the customer for order fulfillment completion. Used for SLA breach detection, customer communication, and regulatory compliance reporting. Distinct from SLA target hours — this is the customer-facing commitment date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Code' ;
    rdfs:comment 'The specific regulatory rule, mandate, or case reference code applicable to this fulfillment order when is_regulatory_order is True. Examples: FCC MNP case number, Ofcom compliance reference. Used for regulatory audit trails and compliance reporting.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Threshold Hours' ;
    rdfs:comment 'The number of hours elapsed from SLA measurement start at which the SLA is formally classified as BREACHED. Typically equals sla_target_hours but may differ for grace-period configurations. Triggers regulatory reporting obligations and penalty calculations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Timestamp' ;
    rdfs:comment 'The precise date and time when the fulfillment order SLA was formally breached. Null for orders that have not breached. Used for regulatory reporting, penalty calculation, and SLA performance analytics. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMeasurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement End Event' ;
    rdfs:comment 'The business event that stops the SLA measurement clock for this fulfillment order. Defines what constitutes successful completion for SLA purposes — e.g., SERVICE_ACTIVATED for mobile activations, CPE_INSTALLED for FTTH orders.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMeasurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Start Event' ;
    rdfs:comment 'The business event that triggers the start of SLA measurement clock for this fulfillment order. Varies by order type and SLA type — regulatory MNP orders typically start at ORDER_ACCEPTED, while commercial orders may start at PAYMENT_CONFIRMED.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMeasurementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Start Timestamp' ;
    rdfs:comment 'The precise date and time when the SLA measurement clock started for this fulfillment order, corresponding to the sla_measurement_start_event. Used as the reference point for all SLA elapsed-time calculations and regulatory compliance measurement. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current SLA compliance status of the fulfillment order based on elapsed time versus SLA thresholds. ON_TRACK: within warning threshold. AT_RISK: between warning and breach thresholds. BREACHED: exceeded breach threshold. Primary field for jeopardy detection and regulatory compliance dashboards.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The maximum number of hours within which the fulfillment order must be completed to meet the SLA commitment. Measured from the SLA measurement start event. Used for jeopardy detection and regulatory compliance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA commitment governing this fulfillment order. REGULATORY: mandated by FCC/Ofcom/BEREC regulations (e.g., MNP porting windows). COMMERCIAL: standard commercial SLA per product tier. ENTERPRISE: premium SLA for enterprise/B2B customers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaWarningThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Warning Threshold Hours' ;
    rdfs:comment 'The number of hours elapsed from SLA measurement start at which an AT_RISK warning is triggered for proactive jeopardy management. Must be less than sla_target_hours. Drives automated alerting in NOC and order management dashboards.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The precise date and time when the fulfillment order was submitted by the customer or agent into the order management system. This is the principal business event timestamp and the anchor point for SLA measurement start calculations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowTemplateName rdf:type rdf:Property ;
    rdfs:label 'Workflow Template Name' ;
    rdfs:comment 'The name of the OSM workflow template (order specification) used to orchestrate this fulfillment order. Determines the decomposition strategy, task sequence, and system interactions. Examples: \'MOBILE_NEW_ACTIVATION_V3\', \'FTTH_PROVISIONING_V2\'.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Foreign key linking to product.promo_offer. Business justification: Promotional offer application per order line: each line can have a specific promo applied (e.g., 50% off first 3 months). Direct FK enables promo redemption tracking, budget consumption monitoring, an' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Foreign key linking to sales.quote_line. Business justification: Quote-to-order line traceability: each order line is created from a specific quote line. Telecom commission calculation, revenue assurance, and price variance reporting require matching the delivered ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:svcConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Svc Configuration Id' ;
    rdfs:comment 'Foreign key linking to service.svc_configuration. Business justification: Each order line specifies the service configuration to be applied (bandwidth profile, APN, VoLTE settings). Linking line to svc_configuration enables product configuration traceability per order line,' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcConfiguration .

ind:ucSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Uc Subscription Id' ;
    rdfs:comment 'Foreign key linking to enterprise.uc_subscription. Business justification: Order lines provisioning UC seats (DID numbers, SIP trunks, feature packs) must reference the UC subscription being fulfilled. Enables UC subscription provisioning status tracking and seat count recon' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UcSubscription .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'The fulfillment action to be performed for this line item. Drives order decomposition and workflow routing in Oracle Communications Order and Service Management. ADD = new activation; REMOVE = disconnection; MODIFY = change of service; SUSPEND = temporary suspension; RESUME = reactivation; PORT_IN = Mobile Number Portability (MNP) inbound; PORT_OUT = MNP outbound. [ENUM-REF-CANDIDATE: ADD|REMOVE|MODIFY|SUSPEND|RESUME|PORT_IN|PORT_OUT — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date on which fulfillment of this order line was completed and the service was activated, modified, or disconnected. Compared against committed_delivery_date for SLA performance measurement and MTTR (Mean Time to Repair) analytics.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The sales or service channel through which this order line was initiated (e.g., ONLINE web portal, RETAIL_STORE, CALL_CENTER, DEALER partner, SELF_SERVICE app, B2B_PORTAL). Used for channel performance analytics, commission calculation, and order routing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The date committed to the customer for delivery or activation of the service on this line, as agreed at order capture. Used for SLA (Service Level Agreement) compliance monitoring and breach detection in service fulfillment reporting.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpeSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Cpe Serial Number' ;
    rdfs:comment 'Serial number of the CPE (Customer Premises Equipment) device — such as a router, ONT (Optical Network Terminal), or set-top box — assigned or dispatched as part of this order line. Used for inventory tracking in Netcracker OSS/BSS and field installation management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionState rdf:type rdf:Property ;
    rdfs:label 'Decomposition State' ;
    rdfs:comment 'Indicates the order decomposition processing state for this line within Oracle Communications Order and Service Management. Order decomposition translates a commercial product order line into technical service and resource fulfillment tasks across OSS systems. Critical for orchestration monitoring and fault management.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutDescription rdf:type rdf:Property ;
    rdfs:label 'Fallout Description' ;
    rdfs:comment 'Free-text description providing additional context for the order line fallout or failure, supplementing the fallout_reason_code. Captured by Oracle Communications Order and Service Management workflow engine for manual intervention and customer communication.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fallout Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for order line fallout or failure during fulfillment orchestration (e.g., \'CREDIT_FAIL\', \'INVENTORY_UNAVAILABLE\', \'ADDRESS_NOT_SERVICEABLE\', \'PORTING_REJECTED\'). Used for fallout management, root cause analysis, and process improvement in Oracle Communications Order and Service Management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEsim rdf:type rdf:Property ;
    rdfs:label 'Is Esim' ;
    rdfs:comment 'Indicates whether this order line involves an eSIM (Embedded SIM) provisioning rather than a physical SIM card. When TRUE, triggers eSIM profile download orchestration via GSMA SGP.22 RSP (Remote SIM Provisioning) instead of physical SIM dispatch.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMnpLine rdf:type rdf:Property ;
    rdfs:label 'Is Mnp Line' ;
    rdfs:comment 'Indicates whether this order line involves a Mobile Number Portability (MNP) port-in or port-out transaction. When TRUE, triggers MNP-specific workflow orchestration including donor operator notification and number portability clearinghouse coordination.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this line item within the parent order. Used for ordering, display, and referencing individual lines in multi-line orders (e.g., line 1 = mobile plan, line 2 = broadband, line 3 = MNP port-in). Satisfies TRANSACTION_LINE LINE_SEQUENCE category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mnpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mnp Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the number portability clearinghouse or regulatory body for a PORT_IN or PORT_OUT order line. Used for inter-operator tracking, regulatory compliance reporting to FCC/Ofcom/BEREC, and dispute resolution.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net commercial price for this order line after applying discounts (unit_price × quantity − discount_amount). Represents the agreed charge basis passed to Amdocs Revenue Management for billing. Distinct from tax-inclusive total.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the product or service being ordered on this line (e.g., \'5G Unlimited Plan\', \'FTTH 1Gbps Broadband\', \'VoLTE Add-On\'). Denormalized from the product catalog for operational reporting and customer-facing order confirmations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the product or service being ordered on this line. Drives workflow routing, provisioning system selection, and reporting segmentation. [ENUM-REF-CANDIDATE: MOBILE|BROADBAND|FIXED_LINE|IPTV|VOIP|IOT|ENTERPRISE|ADD_ON — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the product or service being ordered on this line. Typically 1 for most telecom service lines but may be greater for bulk SIM orders, enterprise seat licenses, or CPE equipment orders. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The customer-requested date on which the product or service on this line should become active. Drives service provisioning scheduling in Oracle Communications Order and Service Management and SLA commitment tracking.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresFieldVisit rdf:type rdf:Property ;
    rdfs:label 'Requires Field Visit' ;
    rdfs:comment 'Indicates whether fulfillment of this order line requires a field technician visit (e.g., FTTH installation, CPE installation, ONT splicing). When TRUE, triggers work order creation and field dispatch scheduling in Granite Telecommunications Workforce Management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Commercial price per unit for the product or service on this line at the time of order placement, before discounts and taxes. Represents the catalog or negotiated price used for billing rate plan association in Amdocs Revenue Management. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each order status history record. Primary key of the order_status_history data product. Immutable once assigned.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentId rdf:type rdf:Property ;
    rdfs:label 'Appointment Id' ;
    rdfs:comment 'Reference to the field service appointment associated with this order history record, particularly relevant for APPOINTMENT_CHANGE amendments or transitions triggered by appointment outcomes. Links to Granite Telecommunications Workforce Management scheduling records.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:nocIncidentId rdf:type rdf:Property ;
    rdfs:label 'Noc Incident Id' ;
    rdfs:comment 'Foreign key linking to assurance.noc_incident. Business justification: Order status transitions caused by NOC incidents (e.g., order suspended due to network outage) must reference the incident for SLA suspension justification and regulatory audit trails. status_history ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocIncident .

ind:provisioningOrderId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Order Id' ;
    rdfs:comment 'Reference to the decomposed service order generated from the parent fulfillment order in Oracle Communications Order and Service Management or Netcracker OSS/BSS Suite. Supports traceability between commercial order history and service fulfillment execution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProvisioningOrder .

ind:workflowTaskId rdf:type rdf:Property ;
    rdfs:label 'Workflow Task Id' ;
    rdfs:comment 'Identifier of the specific workflow task or orchestration step within Oracle Communications Order and Service Management that generated this history record. Enables traceability from the history record back to the originating workflow execution for technical root-cause analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:actorSystem rdf:type rdf:Property ;
    rdfs:label 'Actor System' ;
    rdfs:comment 'Name of the OSS/BSS system that originated the transition or amendment event (e.g., Oracle Communications Order and Service Management, Netcracker OSS/BSS Suite, Salesforce CRM, ServiceNow ITSM). Enables source-system traceability for fallout root-cause analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Categorizes the type of actor that triggered the state transition or amendment. SYSTEM indicates an automated OSS/BSS process; AGENT indicates a human CSR or field technician; CUSTOMER indicates a self-service action; SUPERVISOR indicates a management override; AUTOMATED_RULE indicates a policy engine or workflow rule.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'For amendment records, the logical name of the order attribute that was changed (e.g., installation_address, appointment_date, selected_product_id, service_configuration_value). Provides context for interpreting original_value and new_value. Null for state transition records.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amendment Request Timestamp' ;
    rdfs:comment 'Date and time when the amendment was formally requested by the customer or agent. Distinct from transition_timestamp (which records when the event was processed). Used to measure amendment processing lead time and SLA compliance. Null for state transition records. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current processing status of the amendment request. PENDING: awaiting review; APPROVED: authorized but not yet applied to the order; REJECTED: denied by agent or system rule; APPLIED: successfully incorporated into the active order. Null for state transition records.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'For amendment records, classifies the type of post-submission change requested. Null for state transition records. [ENUM-REF-CANDIDATE: APPOINTMENT_CHANGE|PRODUCT_SELECTION_CHANGE|ADDRESS_CHANGE|SERVICE_CONFIGURATION_CHANGE|CONTACT_CHANGE|PAYMENT_METHOD_CHANGE — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costDelta rdf:type rdf:Property ;
    rdfs:label 'Cost Delta' ;
    rdfs:comment 'For amendment records, the incremental cost impact (positive or negative, in the account currency) resulting from the amendment — e.g., a product selection change that increases or decreases the order value. Null for state transition records and zero-cost amendments. Used for revenue assurance and billing reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationInStateSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration In State Seconds' ;
    rdfs:comment 'Number of seconds the order spent in the previous_state before transitioning to new_state. Calculated at ingestion time as the difference between this record\'s transition_timestamp and the prior record\'s transition_timestamp for the same order. Used for SLA bottleneck analysis and process mining.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falloutResolutionCode rdf:type rdf:Property ;
    rdfs:label 'Fallout Resolution Code' ;
    rdfs:comment 'Standardized code indicating how a FALLOUT condition was resolved (e.g., AUTO_RETRY_SUCCESS, MANUAL_INTERVENTION, ORDER_CANCELLED, REROUTED_TO_ALTERNATE_RESOURCE). Populated when transitioning out of FALLOUT state. Null for non-FALLOUT records.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this history record is subject to regulatory reporting obligations (e.g., FCC order completion reporting, BEREC quality-of-service metrics, OFCOM service provisioning KPIs). True flags records that must be included in regulatory submissions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The order lifecycle state entered as a result of this transition. For amendment records, reflects the order state at the time the amendment was recorded. Valid states include SUBMITTED, VALIDATED, IN_PROGRESS, PENDING_PROVISIONING, COMPLETED, CANCELLED, FALLOUT. [ENUM-REF-CANDIDATE: SUBMITTED|VALIDATED|IN_PROGRESS|PENDING_PROVISIONING|COMPLETED|CANCELLED|FALLOUT — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'For amendment records, the proposed or applied new value for the amended field (serialized as string for flexibility across amendment types). Null for state transition records. Paired with original_value to provide a complete before/after audit record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'For amendment records, the value of the amended field before the change was applied (serialized as string for flexibility across amendment types). Null for state transition records. Supports dispute resolution and regulatory audit trails.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether a standard business rule, credit policy, or SLA policy was overridden to process this transition or amendment. When True, override_justification must be populated. Supports compliance monitoring and exception reporting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Free-text justification provided by a supervisor or authorized agent when a standard business rule or SLA policy is overridden to approve an amendment or force a state transition. Required for compliance audit trails when override_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The order lifecycle state immediately before this transition occurred. Null for the initial SUBMITTED state entry. Valid states include SUBMITTED, VALIDATED, IN_PROGRESS, PENDING_PROVISIONING, COMPLETED, CANCELLED, FALLOUT. [ENUM-REF-CANDIDATE: SUBMITTED|VALIDATED|IN_PROGRESS|PENDING_PROVISIONING|COMPLETED|CANCELLED|FALLOUT — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Reset Flag' ;
    rdfs:comment 'Indicates whether this state transition or amendment triggered a reset of the order fulfillment SLA clock. True when the SLA measurement window is restarted (e.g., due to a customer-requested amendment or a FALLOUT recovery). Critical for accurate SLA compliance reporting to FCC and BEREC.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The committed SLA completion deadline applicable at the time of this history record. If sla_reset_flag is True, this reflects the recalculated SLA target post-reset. Enables point-in-time SLA compliance measurement and regulatory reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the state transition or amendment event occurred. This is the principal business event timestamp used for SLA measurement, fallout root-cause analysis, and regulatory audit trails. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: Field dispatch tasks for CPE installation, swap, or fault resolution directly reference the physical CPE asset being worked on. Technicians need direct asset lookup for field operations without traver' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:depotId rdf:type rdf:Property ;
    rdfs:label 'Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: Field-work tasks are dispatched from specific depots managing territory coverage, parts inventory, and technician availability. Critical for logistics planning, resource allocation, and technician dis' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:taskAssignedTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Technician Id' ;
    rdfs:comment 'Reference to the field technician assigned to execute this task in Granite Telecommunications Workforce Management. Populated for CPE dispatch and GPON ONT activation tasks requiring physical field intervention. Drives field dispatch scheduling and route optimisation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:taskTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Task Technician Id' ;
    rdfs:comment 'Reference to the network or physical resource (e.g., GPON ONT, CPE device, IP address, MSISDN, SIM) in the Netcracker resource inventory that this task acts upon. Enables resource-level fulfillment traceability and inventory reconciliation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual date and time at which execution of this task commenced in the downstream target system. Compared against scheduled_start_time to measure scheduling adherence and identify orchestration delays.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationIndicator rdf:type rdf:Property ;
    rdfs:label 'Automation Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this task was executed automatically by the OSM orchestration engine (True) or required manual intervention by an operations team member (False). Key metric for measuring fulfillment automation rates and identifying candidates for further automation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childOrderType rdf:type rdf:Property ;
    rdfs:label 'Child Order Type' ;
    rdfs:comment 'Classifies the type of lower-level order generated by the decomposition of the parent commercial order line. Distinguishes between service-layer orders (service_order), resource-layer orders (resource_order), and network-layer orders (network_order) per TM Forum SID decomposition hierarchy.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childSystemTarget rdf:type rdf:Property ;
    rdfs:label 'Child System Target' ;
    rdfs:comment 'Identifies the downstream OSS/BSS system to which this task is dispatched for execution (e.g., HLR, HSS, GPON-OLT, Amdocs, Netcracker, Ericsson Network Manager). Critical for cross-system orchestration traceability and fallout diagnosis.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childSystemTaskRef rdf:type rdf:Property ;
    rdfs:label 'Child System Task Ref' ;
    rdfs:comment 'The task or work order identifier assigned by the downstream target system (e.g., Ericsson Network Manager work order ID, Netcracker service order number, ServiceNow change request number). Enables cross-system correlation and reconciliation between OSM and downstream fulfillment systems.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTime rdf:type rdf:Property ;
    rdfs:label 'Completion Time' ;
    rdfs:comment 'The date and time at which this task reached a terminal state (completed, failed, or cancelled) in the OSM orchestration engine. Used to calculate task duration, SLA compliance, and MTTR for fulfillment operations.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data governance classification level for this order task record per the enterprise data classification policy. Determines access controls, retention policies, and handling requirements in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Decomposition Rule Version' ;
    rdfs:comment 'Version of the decomposition rule applied at the time this task was generated. Supports impact analysis when orchestration rules are updated and enables reproducibility of order decomposition logic for audit purposes.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyTaskIds rdf:type rdf:Property ;
    rdfs:label 'Dependency Task Ids' ;
    rdfs:comment 'Comma-separated list of order_task_id values that must reach \'completed\' status before this task can begin execution. Captures the dependency chain within the OSM orchestration workflow to enforce correct fulfillment sequencing (e.g., HLR provisioning must complete before VoLTE IMS registration).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueTime rdf:type rdf:Property ;
    rdfs:label 'Due Time' ;
    rdfs:comment 'The SLA-committed deadline by which this task must reach \'completed\' status. Derived from the parent order\'s committed delivery date and the task\'s position in the fulfillment sequence. Breach of this timestamp triggers escalation workflows.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Machine-readable error code returned by the downstream target system upon task execution failure (e.g., HLR error codes, GPON provisioning error codes, HTTP status codes from REST APIs). Distinct from fallout_reason_code which is an OSM-normalised classification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds between actual_start_time and completion_time for this task. Populated upon task completion. Used for provisioning performance benchmarking, SLA analysis, and identification of slow downstream systems contributing to order fulfillment delays.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionSequence rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence' ;
    rdfs:comment 'Numeric ordering position of this task within the overall order fulfillment workflow. Determines the sequence in which tasks are executed relative to sibling tasks on the same order line. Lower values execute first.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falloutDetail rdf:type rdf:Property ;
    rdfs:label 'Fallout Detail' ;
    rdfs:comment 'Free-text description of the error or exception that caused this task to fall out, as returned by the downstream target system or the OSM orchestration engine. Provides diagnostic context for manual resolution by NOC or BSS operations teams.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutIndicator rdf:type rdf:Property ;
    rdfs:label 'Fallout Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this task has entered fallout status requiring manual intervention or escalation. True when the task has exceeded retry limits or encountered an unrecoverable error. Drives fallout management queues in OSM and ServiceNow ITSM.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRetryLimit rdf:type rdf:Property ;
    rdfs:label 'Max Retry Limit' ;
    rdfs:comment 'The maximum number of retry attempts permitted for this task before it is automatically escalated to fallout management. Configured per task type and downstream system target in the OSM orchestration engine.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ontSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ont Serial Number' ;
    rdfs:comment 'Serial number of the Optical Network Terminal (ONT) / Customer Premises Equipment (CPE) being activated or configured by this task. Populated for GPON ONT activation and CPE dispatch tasks. Used for FTTH inventory reconciliation and field technician dispatch coordination.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderActionType rdf:type rdf:Property ;
    rdfs:label 'Order Action Type' ;
    rdfs:comment 'The commercial order action that triggered the creation of this task. Inherited from the parent order line and used to determine the appropriate provisioning logic in the downstream target system. MNP (Mobile Number Portability) port-in/port-out tasks require coordination with GSMA NRTRDE and TAP processes. [ENUM-REF-CANDIDATE: new_activation|upgrade|downgrade|disconnection|mnp_port_in|mnp_port_out|change_of_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The planned date and time at which this task is scheduled to begin execution within the OSM orchestration engine. Used for SLA target calculation, capacity planning, and workforce scheduling in field dispatch scenarios.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Indicates the synchronisation state of this task with the downstream target system. Tracks whether the task execution result has been confirmed and reconciled back to the OSM orchestration engine from the child system (e.g., HLR, GPON-OLT, Netcracker).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this order task as assigned by the OSM orchestration engine (e.g., TSK-2024-00123456). Used in NOC dashboards, trouble tickets, and cross-system correlation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the order task within the OSM orchestration engine. Drives SLA monitoring, fallout management, and retry logic. Valid states: pending (awaiting execution), in_progress (actively executing), completed (successfully fulfilled), failed (execution error), cancelled (task voided), suspended (paused pending dependency resolution).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classifies the atomic fulfillment action this task represents within the OSM orchestration workflow. Drives routing to the appropriate downstream system and execution handler. [ENUM-REF-CANDIDATE: hlr_hss_provisioning|ip_address_assignment|cpe_dispatch|gpon_ont_activation|number_portability_submission|sim_activation|service_configuration|esim_provisioning|voip_registration|ims_registration|mpls_circuit_setup|ran_configuration — promote to reference product]' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutId rdf:type rdf:Property ;
    rdfs:label 'Fallout Id' ;
    rdfs:comment 'Unique surrogate identifier for each order fallout record in the Oracle Communications Order and Service Management (OSM) system. Primary key for the order_fallout data product.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Assigned Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Fallout resolution for field-related failures (site access, equipment issues, address problems) requires direct technician assignment for expedited recovery. Critical for operational escalation tracki' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:problemRecordId rdf:type rdf:Property ;
    rdfs:label 'Problem Record Id' ;
    rdfs:comment 'Foreign key linking to assurance.problem_record. Business justification: Recurring order fallouts linked to known network problems for pattern analysis and permanent fix tracking. Enables proactive resolution of systemic provisioning issues.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProblemRecord .

ind:resolutionTeamId rdf:type rdf:Property ;
    rdfs:label 'Resolution Team Id' ;
    rdfs:comment 'Foreign key linking to workforce.team. Business justification: Fallout records are assigned to workforce teams for resolution. The existing assigned_team column is a plain-text denormalization of workforce.team. Telecom fallout management dashboards and team work' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:affectedServiceType rdf:type rdf:Property ;
    rdfs:label 'Affected Service Type' ;
    rdfs:comment 'The type of telecommunications service affected by the fallout. Used to route fallout cases to the appropriate specialist team and apply service-specific resolution procedures. [ENUM-REF-CANDIDATE: MOBILE|BROADBAND|FIBER|IPTV|VOIP|ENTERPRISE_WAN|WHOLESALE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoResolutionEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Eligible' ;
    rdfs:comment 'Indicates whether this fallout record is eligible for automated resolution without manual agent intervention, based on fallout category, retry history, and configured automation rules.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The precise date and time when the order orchestration engine first detected and recorded the fallout condition. This is the principal business event timestamp for SLA measurement and aging calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Full descriptive error message returned by the failing system at the time of fallout detection. Provides technical context for resolution agents and is used in automated error classification models.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Date and time when this fallout record was most recently escalated to a higher resolution tier. Null if the record has never been escalated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failingSystem rdf:type rdf:Property ;
    rdfs:label 'Failing System' ;
    rdfs:comment 'Name or identifier of the downstream OSS/BSS system that returned the error or failed to respond, causing the order to fall out. Examples: HLR, HSS, PROVISIONING_ENGINE, INVENTORY_MANAGER, CREDIT_SYSTEM, MNP_CLEARINGHOUSE.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failingSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Failing System Transaction Reference' ;
    rdfs:comment 'The transaction or correlation identifier returned by the failing downstream system. Enables cross-system tracing and incident correlation in ServiceNow ITSM and NOC tooling.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutStatus rdf:type rdf:Property ;
    rdfs:label 'Fallout Status' ;
    rdfs:comment 'Current lifecycle state of the fallout record within the NOC/BSS operations workqueue. Drives SLA breach prevention workflows and management dashboards.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retry Timestamp' ;
    rdfs:comment 'Date and time of the most recent automated or manual re-submission attempt for this fallout order. Used to enforce retry interval policies and prevent retry storms.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Retry Allowed' ;
    rdfs:comment 'Maximum number of automated re-submission attempts permitted for this order type before mandatory escalation to manual resolution. Configured per order type and fallout category.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code where the order was being fulfilled. Used for regional fallout rate analysis and to route cases to geographically appropriate field or provisioning teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Free-text description of the corrective action taken by the resolution agent to address the fallout root cause. Captured at resolution time and used for knowledge base and automation training.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code categorizing the resolution action applied to close this fallout. Enables resolution pattern analysis and automation opportunity identification. [ENUM-REF-CANDIDATE: AUTO_RETRY_SUCCESS|MANUAL_CORRECTION|ORDER_CANCELLED|ORDER_MODIFIED|INVENTORY_ALLOCATED|SYSTEM_BYPASS|ESCALATED_TO_VENDOR|CUSTOMER_CONTACTED — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the fallout record was marked as resolved in the operations workqueue. Used to calculate mean time to resolve (MTTR) for fallout SLA reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resubmissionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resubmission Outcome' ;
    rdfs:comment 'Result of the order re-submission attempt after resolution action was applied. Indicates whether the order successfully completed fulfillment, failed again, is awaiting outcome, or was cancelled.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resubmission Timestamp' ;
    rdfs:comment 'Date and time when the order was resubmitted into the orchestration engine after resolution action was applied. Null if the order has not yet been resubmitted.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Structured root cause analysis narrative captured by the resolution agent or automated diagnostic engine. Documents the underlying cause beyond the error code for knowledge management and recurrence prevention.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subCategory rdf:type rdf:Property ;
    rdfs:label 'Sub Category' ;
    rdfs:comment 'Granular sub-classification within the fallout category providing additional specificity for root cause analysis. Examples: ADDRESS_VALIDATION_FAILED under VALIDATION_FAILURE, HLR_TIMEOUT under PROVISIONING_TIMEOUT, SIM_STOCK_DEPLETED under INVENTORY_SHORTAGE.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepName rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Name' ;
    rdfs:comment 'The name of the specific orchestration workflow step or process node within Oracle OSM that was executing when the fallout occurred. Enables precise identification of the failure point in the order decomposition graph.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepSequence rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Sequence' ;
    rdfs:comment 'Numeric sequence position of the failing workflow step within the overall order orchestration process. Used to understand how far into fulfillment the order progressed before failing.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:provisioningRequestId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the provisioning request record in the Silver Layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bandwidthProfileCode rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Profile Code' ;
    rdfs:comment 'Code identifying the bandwidth profile (upstream/downstream speed tier) to be applied to the service. Maps to a predefined bandwidth template in the OLT, DSLAM, or BNG configuration. Examples: 100M_FTTH, 1G_FTTH, 50M_ADSL.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'The date and time (ISO 8601 with timezone offset) when the provisioning instruction was dispatched from Oracle Communications OSM to the target OSS system. Represents the principal real-world business event time. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Human-readable description of the failure reason as returned by the target OSS system or populated by the OSM orchestration layer. Provides operational context for NOC engineers and support teams investigating provisioning failures.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRollbackRequired rdf:type rdf:Property ;
    rdfs:label 'Is Rollback Required' ;
    rdfs:comment 'Indicates whether a rollback of previously applied provisioning changes is required due to a downstream failure in a multi-step orchestration workflow. When TRUE, the OSM compensation workflow is triggered to reverse partial provisioning actions.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpDonorOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Mnp Donor Operator Code' ;
    rdfs:comment 'For Mobile Number Portability (MNP) PORT_IN provisioning actions, the network operator code of the donor (losing) operator from whom the number is being ported. Populated per GSMA PRD IR.26 and national MNP regulatory requirements.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnpPortDate rdf:type rdf:Property ;
    rdfs:label 'Mnp Port Date' ;
    rdfs:comment 'The scheduled or actual date on which the Mobile Number Portability (MNP) port-in or port-out is to be executed. Applicable only when provisioning_action is PORT_IN or PORT_OUT. Governed by national MNP regulatory timelines.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkRegionCode rdf:type rdf:Property ;
    rdfs:label 'Network Region Code' ;
    rdfs:comment 'Code identifying the geographic network region or Point of Presence (POP) within which the provisioning action is being executed. Used for regional capacity planning, NOC routing, and geographic SLA analysis.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this provisioning request, determining queue position and resource allocation in the OSM orchestration engine. CRITICAL: emergency/regulatory-mandated; HIGH: premium customer or SLA-sensitive; MEDIUM: standard commercial; LOW: batch/bulk provisioning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningAction rdf:type rdf:Property ;
    rdfs:label 'Provisioning Action' ;
    rdfs:comment 'The type of provisioning operation to be performed on the target OSS system. ACTIVATE: new service activation; MODIFY: change of service parameters; DEACTIVATE: service disconnection; SUSPEND: temporary service suspension; RESUME: reinstatement after suspension; PORT_IN: Mobile Number Portability (MNP) inbound port; PORT_OUT: MNP outbound port. [ENUM-REF-CANDIDATE: ACTIVATE|MODIFY|DEACTIVATE|SUSPEND|RESUME|PORT_IN|PORT_OUT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningOutcome rdf:type rdf:Property ;
    rdfs:label 'Provisioning Outcome' ;
    rdfs:comment 'Final result of the provisioning execution as reported by the target OSS system. SUCCESS: service fully activated/modified/deactivated as requested; FAILURE: provisioning could not be completed; TIMEOUT: target system did not respond within the configured timeout window; PARTIAL: some but not all service components were provisioned (e.g., multi-component service). Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category for non-monetary transactions.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the provisioning request as generated by Oracle Communications OSM (e.g., PROV-2024-0001234). Used for cross-system traceability across OSS/BSS platforms. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the provisioning request. PENDING: awaiting dispatch; DISPATCHED: sent to target OSS system; IN_PROGRESS: being processed by target system; SUCCESS: provisioning completed successfully; FAILURE: provisioning failed; TIMEOUT: no acknowledgement received within SLA window; CANCELLED: request withdrawn before execution. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: PENDING|DISPATCHED|IN_PROGRESS|SUCCESS|FAILURE|TIMEOUT|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rollback Timestamp' ;
    rdfs:comment 'The date and time when the rollback compensation action was executed for this provisioning request. Populated only when is_rollback_required is TRUE and the rollback has been completed.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledActivationDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Activation Date' ;
    rdfs:comment 'The date on which the service activation or modification is scheduled to take effect, as agreed with the customer or mandated by the order. May differ from dispatch_timestamp for future-dated provisioning requests.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceParametersPayload rdf:type rdf:Property ;
    rdfs:label 'Service Parameters Payload' ;
    rdfs:comment 'Serialized (JSON or XML) payload containing the service-specific configuration parameters dispatched to the target OSS system. For mobile services: MSISDN, IMSI, APN, QoS profile; for FTTH/GPON: ONT serial number, VLAN ID, bandwidth profile; for IMS: SIP URI, codec list. Stored as STRING to accommodate heterogeneous service types.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Seconds' ;
    rdfs:comment 'The contracted Service Level Agreement (SLA) target duration in seconds within which this provisioning request must be completed end-to-end. Used for SLA compliance monitoring and breach detection in NOC dashboards.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSystemCode rdf:type rdf:Property ;
    rdfs:label 'Target System Code' ;
    rdfs:comment 'Code identifying the downstream OSS system to which this provisioning instruction is dispatched. Valid values include: HLR (Home Location Register), HSS (Home Subscriber Server), UDM (Unified Data Management), IMS (IP Multimedia Subsystem), GPON_OLT (Gigabit Passive Optical Network Optical Line Terminal), IPAM (IP Address Management), DSLAM (Digital Subscriber Line Access Multiplexer), RAN (Radio Access Network), PCRF (Policy and Charging Rules Function), PCF (Policy Control Function). [ENUM-REF-CANDIDATE: HLR|HSS|UDM|IMS|GPON_OLT|IPAM|DSLAM|RAN|PCRF|PCF — promote to reference product]' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Target System Instance Reference' ;
    rdfs:comment 'Identifier of the specific system instance or node within the target OSS system (e.g., HSS cluster node ID, OLT shelf/port identifier) to which the provisioning command is routed. Supports multi-node environments and geo-redundant deployments.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanNumber rdf:type rdf:Property ;
    rdfs:label 'Vlan Number' ;
    rdfs:comment 'The Virtual LAN (VLAN) ID assigned to the subscriber\'s service on the GPON OLT or DSLAM for traffic segregation and QoS enforcement. Applicable for FTTH and broadband service provisioning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceQualificationId rdf:type rdf:Property ;
    rdfs:label 'Service Qualification Id' ;
    rdfs:comment 'Unique surrogate identifier for the service qualification record. Primary key for the service_qualification data product in the order domain Silver layer.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oltAssetId rdf:type rdf:Property ;
    rdfs:label 'Olt Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.olt_asset. Business justification: Fiber service qualification checks OLT port capacity and operational status before committing to a fiber service offer. Direct reference to the serving OLT asset is required for capacity management, q' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OltAsset .

ind:productOfferingId rdf:type rdf:Property ;
    rdfs:label 'Product Offering Id' ;
    rdfs:comment 'Reference to the specific product offering in the Netcracker Product Catalog for which eligibility is being assessed. Drives which product offers are surfaced to the sales agent or digital channel upon a positive qualification outcome.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:surveyTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Survey Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: When field_survey_required=true on a service qualification, a technician is dispatched for a pre-sales site survey. Telecom pre-sales operations track which technician conducted the survey to link sur' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line of the customer premises being qualified for service. Captured at qualification time as a point-in-time snapshot to avoid dependency on address master changes post-qualification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line (apartment, suite, floor, unit number) of the customer premises being qualified. Nullable for single-dwelling units.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableTechnologyOptions rdf:type rdf:Property ;
    rdfs:label 'Available Technology Options' ;
    rdfs:comment 'Pipe-delimited list of all access technologies technically available at the qualified address (e.g., \'FTTH|LTE|5G_NR\'). Enables the sales system to present all eligible product offers, not just the primary requested technology. Sourced from Netcracker Resource Inventory network coverage data.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadbandSubsidyEligible rdf:type rdf:Property ;
    rdfs:label 'Broadband Subsidy Eligible' ;
    rdfs:comment 'Indicates whether the service address qualifies for government broadband subsidy programs (e.g., FCC Affordable Connectivity Program (ACP), NTIA BEAD, UK Gigabit Voucher Scheme). Determined based on regulatory_zone_code and address-level coverage data. Relevant for compliance reporting to FCC, NTIA, and Ofcom.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the service installation address. Used for geographic coverage reporting and network rollout planning analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Free-text description of any technical or operational constraints identified during the qualification check when the outcome is ELIGIBLE_WITH_CONSTRAINTS. Examples: \'Maximum speed limited to 100 Mbps due to copper loop length\', \'CPE upgrade required\', \'Shared GPON port — peak-hour congestion possible\'. Null when outcome is ELIGIBLE or NOT_ELIGIBLE.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeRequired rdf:type rdf:Property ;
    rdfs:label 'Cpe Required' ;
    rdfs:comment 'Indicates whether a Customer Premises Equipment (CPE) installation or upgrade is required to deliver the requested service at the qualified address. True: CPE installation/upgrade is mandatory; False: existing CPE is compatible or no CPE is needed.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpeType rdf:type rdf:Property ;
    rdfs:label 'Cpe Type' ;
    rdfs:comment 'Type of CPE required for service delivery at the qualified address. ONT (Optical Network Terminal) for FTTH/GPON; ROUTER for broadband; MODEM for DSL; GATEWAY for combined modem/router; OUTDOOR_UNIT/INDOOR_UNIT for fixed wireless. Null when cpe_required is False.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedInstallationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Installation Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order confirmation to service activation at the qualified address. Derived from field workforce availability (Granite WFM), infrastructure readiness, and network node capacity. Displayed to customers during the ordering flow to set delivery expectations.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Estimated Latency Ms' ;
    rdfs:comment 'Estimated round-trip network latency in milliseconds at the qualified address for the requested service type. Relevant for QoS-sensitive product offers (VoLTE, gaming, enterprise SD-WAN) and SLA eligibility determination.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldSurveyRequired rdf:type rdf:Property ;
    rdfs:label 'Field Survey Required' ;
    rdfs:comment 'Indicates whether a physical field survey by a Telecommunication technician is required before service can be provisioned at this address. True when infrastructure readiness is PARTIAL or NOT_READY, or when the qualification engine cannot determine feasibility remotely. Triggers a field dispatch work order in Granite WFM.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ineligibilityReasonCode rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the address is NOT_ELIGIBLE for the requested service. NO_COVERAGE: outside network footprint; CAPACITY_EXHAUSTED: node at full capacity; INFRASTRUCTURE_NOT_BUILT: planned but not yet deployed; ADDRESS_NOT_FOUND: address could not be geocoded or matched; TECHNICAL_BARRIER: physical impediment; REGULATORY_RESTRICTION: regulatory constraint. Null when outcome is ELIGIBLE or ELIGIBLE_WITH_CONSTRAINTS.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureReadiness rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Readiness' ;
    rdfs:comment 'Indicates the physical network infrastructure readiness at or near the service address. READY: full infrastructure in place; PARTIAL: partial build-out, service possible with constraints; NOT_READY: no infrastructure present; UNDER_CONSTRUCTION: active network build in progress with a planned completion date.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the service installation point. Used for precise network coverage mapping, field dispatch routing via Granite WFM, and FCC broadband location fabric matching.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the service installation point. Used in conjunction with latitude for geospatial coverage analysis and network node proximity calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDownloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Max Download Speed Mbps' ;
    rdfs:comment 'Maximum technically achievable downstream bandwidth in Megabits per second (Mbps) at the qualified address, as determined by the network qualification engine based on distance to node, line quality, and technology capability. Drives product tier eligibility in the sales flow.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxUploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Max Upload Speed Mbps' ;
    rdfs:comment 'Maximum technically achievable upstream bandwidth in Megabits per second (Mbps) at the qualified address. Critical for symmetric service offerings (FTTH/GPON) and business-grade SLA commitments.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mnpApplicable rdf:type rdf:Property ;
    rdfs:label 'Mnp Applicable' ;
    rdfs:comment 'Indicates whether Mobile Number Portability (MNP) is applicable to this service qualification, relevant for mobile service types (LTE, 5G NR) where the customer intends to port an existing number. True triggers MNP eligibility checks in the downstream order flow.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the service installation address. Key dimension for network coverage gap analysis, FCC broadband availability reporting, and NTIA compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationChannel rdf:type rdf:Property ;
    rdfs:label 'Qualification Channel' ;
    rdfs:comment 'The sales or service channel through which the qualification request was initiated. ONLINE: digital self-service portal; RETAIL_STORE: in-store agent; CALL_CENTER: inbound/outbound agent via Salesforce CRM; PARTNER_API: wholesale or MVNO partner API; FIELD_AGENT: mobile field sales; SELF_SERVICE: automated IVR or chatbot.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Completed Timestamp' ;
    rdfs:comment 'The date and time when the qualification check was fully resolved and an outcome was determined. Null if the qualification is still IN_PROGRESS or was CANCELLED before completion.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'The date after which the qualification result is considered stale and must be re-evaluated before an order can be placed. Network conditions, capacity, and infrastructure status can change; this date enforces re-qualification for orders placed after a defined validity window (typically 30–90 days).' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Qualification Outcome' ;
    rdfs:comment 'Business result of the pre-order service qualification check. ELIGIBLE: the address/location can receive the requested service without restriction; NOT_ELIGIBLE: service cannot be delivered to this location; ELIGIBLE_WITH_CONSTRAINTS: service is technically feasible but subject to limitations (e.g., reduced bandwidth, extended lead time, CPE upgrade required).' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the qualification request by Oracle Communications Order and Service Management (OSM). Used by sales agents and customers to track the qualification check.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Request Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone offset) when the qualification request was submitted by the sales or ordering system. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Qualification Source System' ;
    rdfs:comment 'The originating operational system that submitted the qualification request. OSM: Oracle Communications Order and Service Management; SALESFORCE: Salesforce CRM; NETCRACKER: Netcracker OSS/BSS Suite; PARTNER_PORTAL: wholesale/MVNO partner portal; SELF_SERVICE_PORTAL: customer-facing digital portal. Used for data lineage and system-of-record traceability.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle state of the qualification request workflow within Oracle OSM. IN_PROGRESS: check is being executed; COMPLETED: outcome determined; FAILED: system error prevented completion; CANCELLED: request withdrawn before completion.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryZoneCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Zone Code' ;
    rdfs:comment 'Regulatory or geographic zone code assigned to the service address, used to determine applicable regulatory obligations (e.g., FCC Universal Service Fund (USF) eligible area, NTIA BEAD-eligible zone, Ofcom Universal Service Obligation (USO) area, BEREC regulated zone). Drives compliance reporting and subsidy eligibility.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Requalification Required' ;
    rdfs:comment 'Indicates whether this qualification result has been flagged as requiring re-execution before an order can proceed. Set to True when the qualification_expiry_date has passed, when network topology changes have occurred in the serving area, or when the customer requests a different service type.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedServiceType rdf:type rdf:Property ;
    rdfs:label 'Requested Service Type' ;
    rdfs:comment 'The access technology or service type for which eligibility is being assessed. Values align with the network technologies offered by Telecommunication: FTTH (Fiber to the Home), GPON (Gigabit Passive Optical Network), LTE (Long-Term Evolution), 5G NR (5G New Radio), ADSL, VDSL, FTTB (Fiber to the Building), FTTC (Fiber to the Cabinet), FIXED_WIRELESS. [ENUM-REF-CANDIDATE: FTTH|GPON|LTE|5G_NR|ADSL|VDSL|FTTB|FTTC|FIXED_WIRELESS — promote to reference product]' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Measured or predicted radio signal strength in dBm at the qualified address for wireless service types (LTE, 5G NR, Fixed Wireless). Null for wireline technologies. Sourced from Ericsson Network Manager RAN coverage data or Nokia NetAct RF planning tools.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region of the service installation address. Used for regulatory jurisdiction mapping (FCC, NTIA) and regional network coverage analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Survey Scheduled Date' ;
    rdfs:comment 'The calendar date on which the field survey is scheduled to be conducted at the customer premises, when field_survey_required is True. Populated by Granite WFM upon technician dispatch scheduling. Null when no survey is required.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Foreign key linking to workforce.team. Business justification: Complex telecom installations (fiber, enterprise) require crew-based appointments assigned to a team rather than a single technician. Field operations scheduling and team capacity planning require lin' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Reference to the assigned field technician from the workforce domain. Populated by Granite Telecommunications Workforce Management (WFM) during dispatch scheduling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Special instructions for the field technician to gain access to the customer premises (e.g., gate codes, building manager contact, parking instructions, safety requirements). Critical for enterprise and multi-dwelling unit installations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time the field technician arrived at the customer premises. Compared against scheduled_start_time to measure on-time arrival performance and SLA adherence.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'Actual date and time the field technician completed the on-site work and closed the appointment. Used to calculate job duration, MTTR (Mean Time to Repair), and workforce productivity metrics.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual time in minutes taken to complete the on-site work, calculated from actual_arrival_time to actual_completion_time. Used for workforce productivity analysis and future duration estimation model training.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Externally visible, human-readable appointment reference number communicated to the customer and field technician. Follows the format APT-NNNNNNNNNN. Used in customer notifications, WFM dispatch sheets, and trouble ticket references.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle state of the appointment. Drives downstream workflow actions: SCHEDULED (created, not yet confirmed), CONFIRMED (customer acknowledged), COMPLETED (work done), MISSED (technician or customer no-show), RESCHEDULED (new slot assigned), CANCELLED (appointment voided).' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the on-site work to be performed. Drives technician skill matching, equipment pre-staging, and estimated duration in WFM. [ENUM-REF-CANDIDATE: FTTH_INSTALLATION|GPON_INSTALLATION|CPE_SWAP|ONT_REPLACEMENT|ENTERPRISE_CIRCUIT_COMMISSIONING|FAULT_REPAIR|UPGRADE|DOWNGRADE|DISCONNECTION — promote to reference product]' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes entered by the field technician upon appointment completion. Captures work performed, issues encountered, materials used, and any follow-up actions required. Populated when appointment_status is COMPLETED.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationChannel rdf:type rdf:Property ;
    rdfs:label 'Confirmation Channel' ;
    rdfs:comment 'Channel through which the customer confirmed the appointment. Supports omnichannel analytics and confirmation effectiveness reporting. Populated only when customer_confirmed is True.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the customer confirmed the appointment. Populated only when customer_confirmed is True. Used for lead-time analysis and confirmation workflow SLA measurement.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerConfirmed rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmed' ;
    rdfs:comment 'Indicates whether the customer has explicitly confirmed the scheduled appointment. True = confirmed by customer; False = not yet confirmed. Drives automated reminder workflows and no-show risk scoring.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Work Order Number' ;
    rdfs:comment 'External work order reference number generated by Granite Telecommunications WFM upon technician dispatch. Used to cross-reference appointment records with WFM dispatch sheets and field activity logs.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete the on-site work. Derived from appointment type and technology type during WFM scheduling. Used for route optimization and technician capacity planning.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpReason rdf:type rdf:Property ;
    rdfs:label 'Follow Up Reason' ;
    rdfs:comment 'Free-text description of why a follow-up appointment or action is required. Populated only when follow_up_required is True. Used for work order creation and technician briefing.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up appointment or action is required after this appointment. True = follow-up needed (e.g., incomplete installation, pending network provisioning). Triggers creation of a new appointment or trouble ticket.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedReason rdf:type rdf:Property ;
    rdfs:label 'Missed Reason' ;
    rdfs:comment 'Reason code explaining why the appointment was missed. Populated only when appointment_status is MISSED. Used for SLA breach analysis, customer compensation workflows, and workforce accountability reporting.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'Number of times this appointment has been rescheduled. Tracks appointment instability, customer experience impact, and operational efficiency. High reschedule counts may trigger escalation workflows.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Reschedule Reason' ;
    rdfs:comment 'Reason code for the most recent reschedule of this appointment. Populated when appointment_status is RESCHEDULED. Used for root cause analysis and operational improvement. [ENUM-REF-CANDIDATE: CUSTOMER_REQUEST|TECHNICIAN_UNAVAILABLE|WEATHER|EQUIPMENT_NOT_READY|ACCESS_ISSUE|NETWORK_DEPENDENCY|OTHER — promote to reference product]' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Calendar date on which the field technician appointment is scheduled to occur. Used for day-level planning, route optimization, and customer communication.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and time at which the appointment window is scheduled to end. Defines the committed service window communicated to the customer and used for SLA compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaCommitmentMet rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Met' ;
    rdfs:comment 'Indicates whether the appointment was completed within the committed SLA (Service Level Agreement) window. True = SLA met; False = SLA breached. Drives regulatory reporting, customer compensation, and performance dashboards.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Date' ;
    rdfs:comment 'The contractual or regulatory deadline by which the appointment must be completed to satisfy the SLA commitment. Derived from order creation date and applicable SLA tier.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wfmJobReference rdf:type rdf:Property ;
    rdfs:label 'Wfm Job Reference' ;
    rdfs:comment 'Unique job identifier assigned by Granite Telecommunications Workforce Management system for this appointment. Enables bidirectional traceability between the order domain and the WFM dispatch system.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaProfileId rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Id' ;
    rdfs:comment 'Foreign key linking to service.sla_profile. Business justification: An order SLA commitment is governed by the service SLA profile tier (e.g., Gold, Platinum) associated with the ordered service. Linking order.sla to service.sla_profile enables SLA compliance reportin' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaProfile .

ind:breachNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Sent' ;
    rdfs:comment 'Indicates whether a formal breach notification has been dispatched to the customer and/or regulatory authority (True) following a BREACHED status. Required for compliance with FCC, Ofcom, and BEREC breach reporting obligations.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Timestamp' ;
    rdfs:comment 'The date and time at which the breach notification was sent to the customer and/or regulatory authority. Null if no notification has been sent. Used to verify compliance with mandatory notification timeframes.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Hours' ;
    rdfs:comment 'The number of elapsed hours from the measurement start event at which the SLA is formally classified as BREACHED. May equal target_completion_hours or include a grace period defined in the contract or regulatory instrument.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'The exact date and time at which the SLA was formally classified as BREACHED (i.e., elapsed hours exceeded breach_threshold_hours). Null if the SLA has not been breached. Critical for regulatory penalty calculations and breach notification obligations.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Defines how elapsed time is measured for this SLA: CALENDAR_HOURS (24x7 clock), BUSINESS_HOURS (measured only during defined business operating hours), or BUSINESS_DAYS (measured in working days). Determines how target_completion_timestamp is calculated.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockSuspended rdf:type rdf:Property ;
    rdfs:label 'Clock Suspended' ;
    rdfs:comment 'Indicates whether the SLA measurement clock is currently paused (True) due to a customer hold, third-party dependency, or regulatory exclusion event. When True, elapsed_hours accumulation is halted until the clock is resumed.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elapsedHours rdf:type rdf:Property ;
    rdfs:label 'Elapsed Hours' ;
    rdfs:comment 'The number of hours elapsed since the measurement start event as of the last status evaluation. Used for real-time SLA monitoring dashboards and regulatory compliance reporting. Excludes any suspended clock periods.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement End Event' ;
    rdfs:comment 'The business event that stops the SLA clock and marks fulfillment completion. Used to calculate actual elapsed time against the SLA target. [ENUM-REF-CANDIDATE: SERVICE_ACTIVATED|ORDER_COMPLETED|PORT_COMPLETED|FAULT_RESOLVED|CPE_INSTALLED|CUSTOMER_CONFIRMED — promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Event' ;
    rdfs:comment 'The business event that triggers the start of SLA clock measurement. Defines the precise moment from which target completion hours are counted, per regulatory or contractual terms. [ENUM-REF-CANDIDATE: ORDER_SUBMITTED|ORDER_ACCEPTED|PAYMENT_CONFIRMED|SITE_SURVEY_COMPLETE|PORT_REQUEST_SUBMITTED|TECHNICIAN_DISPATCHED — promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the SLA clock started, corresponding to the occurrence of the measurement_start_event. This is the BUSINESS_EVENT_TIMESTAMP for SLA clock initiation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:penaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty or service credit is contractually or regulatorily applicable upon breach of this SLA (True). Drives downstream penalty calculation and credit note generation in Amdocs Revenue Management.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Amount' ;
    rdfs:comment 'The monetary value of the service credit or penalty payable to the customer upon SLA breach, expressed in the billing currency. Null if penalty_applicable is False or if the breach has not yet been assessed. Feeds into Amdocs Revenue Management credit note generation.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The regulatory authority whose rules govern this SLA commitment: FCC (Federal Communications Commission, USA), OFCOM (Office of Communications, UK), BEREC (Body of European Regulators for Electronic Communications), ITU (International Telecommunication Union), ETSI, NTIA, GSMA, or NONE for purely commercial SLAs. [ENUM-REF-CANDIDATE: FCC|OFCOM|BEREC|ITU|ETSI|NTIA|GSMA|NONE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInstrumentReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Instrument Reference' ;
    rdfs:comment 'The specific regulatory rule, order, or directive citation that mandates this SLA (e.g., \'FCC 47 CFR Part 52 Section 52.35\', \'Ofcom General Conditions C5.3\', \'BEREC Guidelines on Switching 2020\'). Enables precise regulatory compliance traceability.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'Functional category of the SLA defining the business process it governs: PROVISIONING (new service activation), REPAIR (fault resolution), PORTABILITY (Mobile Number Portability / MNP), INSTALLATION (physical CPE or FTTH installation), ACTIVATION (service turn-up), or DISCONNECTION (service termination). [ENUM-REF-CANDIDATE: PROVISIONING|REPAIR|PORTABILITY|INSTALLATION|ACTIVATION|DISCONNECTION — promote to reference product if additional categories are required]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'The reason the SLA measurement clock was most recently suspended. Used for regulatory exclusion reporting and dispute resolution. [ENUM-REF-CANDIDATE: CUSTOMER_HOLD|THIRD_PARTY_DEPENDENCY|REGULATORY_EXCLUSION|FORCE_MAJEURE|AWAITING_PAYMENT|SITE_ACCESS_DENIED — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Target Completion Hours' ;
    rdfs:comment 'The contracted or regulatory maximum number of hours within which the order must be fulfilled from the measurement start event. This is the primary SLA commitment value (e.g., 24.00 hours for MNP port-in per FCC rules, 48.00 hours for residential broadband activation).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Completion Timestamp' ;
    rdfs:comment 'The calculated deadline timestamp by which the order must be fulfilled to meet the SLA commitment. Derived from measurement_start_timestamp plus target_completion_hours, adjusted for any calendar or business-hours rules. Stored for direct comparison in monitoring queries.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalSuspendedHours rdf:type rdf:Property ;
    rdfs:label 'Total Suspended Hours' ;
    rdfs:comment 'Cumulative number of hours the SLA clock has been suspended for this record due to customer holds, third-party delays, or regulatory exclusions. Subtracted from gross elapsed time to compute net elapsed hours for compliance reporting.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Hours' ;
    rdfs:comment 'The number of elapsed hours from the measurement start event at which the SLA status transitions to AT_RISK, triggering proactive escalation workflows in Oracle Communications Order and Service Management and ServiceNow ITSM. Typically set as a percentage of target_completion_hours (e.g., 75%).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningTriggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Warning Triggered Timestamp' ;
    rdfs:comment 'The date and time at which the SLA status transitioned to AT_RISK (warning threshold exceeded). Used to measure the effectiveness of proactive escalation workflows and to audit response times.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Unique surrogate identifier for each outbound order notification record dispatched to a customer or internal stakeholder. Primary key of the order_notification data product.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyHash rdf:type rdf:Property ;
    rdfs:label 'Body Hash' ;
    rdfs:comment 'SHA-256 hash of the rendered notification body content at the time of dispatch. Provides tamper-evident audit evidence of the exact message content sent without storing the full message body (which may contain PII).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'The reason code for order cancellation included in ORDER_CANCELLATION notifications (e.g., CUSTOMER_REQUEST, CREDIT_FAIL, DUPLICATE_ORDER, FRAUD_DETECTED). Populated only when notification_type is ORDER_CANCELLATION.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReference rdf:type rdf:Property ;
    rdfs:label 'Consent Reference' ;
    rdfs:comment 'Reference to the customer\'s communication consent record that authorises dispatch of this notification via the selected channel. Required for GDPR Article 6 lawful basis and TCPA compliance for SMS/IVR channels.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when delivery confirmation was received from the messaging gateway or carrier, confirming the notification reached the recipient endpoint. Null if delivery has not yet been confirmed or failed.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current delivery outcome status of the notification as reported by the downstream messaging gateway or carrier. SENT = dispatched to gateway; DELIVERED = confirmed receipt by endpoint; FAILED = gateway rejection; BOUNCED = undeliverable address; PENDING = queued for dispatch.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failed Timestamp' ;
    rdfs:comment 'The date and time when a delivery failure or bounce was reported by the messaging gateway. Populated only when delivery_status is FAILED or BOUNCED. Used to trigger retry logic and escalation workflows.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fallbackChannel rdf:type rdf:Property ;
    rdfs:label 'Fallback Channel' ;
    rdfs:comment 'The alternative delivery channel to be used if the primary delivery_channel fails after exhausting retry attempts (e.g., fall back to SMS if EMAIL bounces). Supports multi-channel notification resilience.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackTriggered rdf:type rdf:Property ;
    rdfs:label 'Fallback Triggered' ;
    rdfs:comment 'Indicates whether the fallback delivery channel was activated for this notification because the primary channel failed. True = fallback was used; False = primary channel was used.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatewayMessageReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Message Reference' ;
    rdfs:comment 'The unique message identifier assigned by the external messaging gateway or carrier (e.g., SMS aggregator message ID, email SMTP message ID, push notification token). Used for delivery receipt correlation and dispute resolution with gateway providers.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayProvider rdf:type rdf:Property ;
    rdfs:label 'Gateway Provider' ;
    rdfs:comment 'The name or identifier of the external messaging gateway or aggregator used to deliver this notification (e.g., Twilio, Syniverse, AWS SNS). Supports vendor performance monitoring and SLA management.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'The IETF BCP 47 language tag identifying the language in which the notification was rendered (e.g., en-US, fr-FR, es-MX). Supports multilingual customer communication obligations and regulatory requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this notification record (e.g., NTF-0012345678). Used in customer-facing correspondence, audit trails, and regulatory evidence for MNP and disconnection notifications.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classifies the business event that triggered this notification. Drives template selection, regulatory logging, and SLA measurement. [ENUM-REF-CANDIDATE: ORDER_CONFIRMATION|APPOINTMENT_REMINDER|PROVISIONING_COMPLETE|PORT_IN_EXECUTION|ORDER_CANCELLATION|DISCONNECTION_NOTICE — promote to reference product]' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the recipient had opted out of this notification type or delivery channel at the time of dispatch. True = opt-out was recorded (notification may have been suppressed or sent as regulatory override). Used for GDPR/TCPA compliance audit.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Port Execution Date' ;
    rdfs:comment 'The date on which the MNP port-in or port-out was executed, as communicated in PORT_IN_EXECUTION notifications. Required for regulatory audit under FCC MNP Order 18-122 and GSMA PRD IR.73.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisioningCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Completion Date' ;
    rdfs:comment 'The date on which service provisioning was completed, as communicated in PROVISIONING_COMPLETE notifications. Sourced from Oracle OSM service fulfillment completion event.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Address' ;
    rdfs:comment 'The actual delivery endpoint used for this notification — phone number (E.164 format for SMS/IVR), email address, push device token, or postal address depending on delivery_channel. Stored as dispatched for audit and re-delivery purposes.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classifies whether the notification was dispatched to an external customer, an internal business stakeholder, a customer service agent, or a field technician. Governs data handling and privacy obligations.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether this notification fulfils a mandatory regulatory obligation (e.g., MNP port-in confirmation, service disconnection advance notice). True = regulatory notification; False = operational/informational notification. Used for compliance reporting to FCC, Ofcom, BEREC.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Dispatch Timestamp' ;
    rdfs:comment 'The planned date and time at which the notification was scheduled to be dispatched. Compared against dispatch_timestamp to measure scheduling accuracy and identify delayed notifications.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The unique event or transaction identifier from the originating source system (OSM, Salesforce, Amdocs) that triggered this notification. Enables end-to-end traceability from the source business event to the dispatched notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'The subject line or title of the notification as rendered and dispatched (e.g., email subject line, SMS header, push notification title). Captured for audit, content review, and regulatory evidence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'The version identifier of the notification template used at the time of dispatch (e.g., v1.0, v2.3). Enables audit of which template content was sent, supporting regulatory compliance and A/B testing analysis.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Amendment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a prior amendment that this record supersedes or is derived from. Supports amendment chains where a rejected amendment is resubmitted with corrections.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this amendment, used in customer communications, agent desktops, and dispute resolution workflows. Format: AMD- followed by 10 digits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Date and time at which the approved amendment was successfully propagated and applied to the underlying fulfillment order in Oracle Communications Order and Service Management. Null until status reaches APPLIED.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this amendment record to the immutable audit log entry in the compliance audit system (e.g., ServiceNow CMDB audit record or enterprise audit repository). Supports regulatory audit and dispute resolution evidence chains.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Required' ;
    rdfs:comment 'Indicates whether this amendment triggers a billing adjustment in Amdocs Revenue Management (e.g., pro-rated credit, revised charge). When True, the billing team must process a corresponding adjustment record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costDeltaCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Delta Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_delta amount (e.g., USD, GBP, EUR). Ensures multi-currency support for international operations.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time at which the customer was notified of the amendment outcome. Null if customer_notified_flag is False. Used for regulatory compliance reporting on customer communication timeliness.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been formally notified of the amendment outcome (approval, rejection, or application). Supports compliance with customer communication obligations and SLA notification requirements.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Notes' ;
    rdfs:comment 'Free-text field capturing the agent\'s or system\'s assessment of the downstream impact of this amendment on network provisioning, billing, scheduling, or third-party dependencies. Used during the approval workflow.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerInitiated rdf:type rdf:Property ;
    rdfs:label 'Is Customer Initiated' ;
    rdfs:comment 'Distinguishes amendments initiated by the customer from those initiated internally by agents or automated systems (e.g., error corrections, product availability changes). Supports root-cause analysis of amendment volumes and customer experience reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Mnp Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment affects a Mobile Number Portability (MNP) port-in or port-out request associated with the parent order. When True, the MNP coordinator must be notified to update the porting window with the donor or recipient operator.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newCommittedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'New Committed Delivery Date' ;
    rdfs:comment 'The revised committed delivery or installation date resulting from this amendment, applicable when the amendment type is APPOINTMENT_RESCHEDULE or when sla_reset_flag is True. Null if the amendment does not affect the delivery date.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCommittedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Original Committed Delivery Date' ;
    rdfs:comment 'The committed delivery or installation date that was in effect on the parent order before this amendment was applied. Preserved for SLA impact analysis and dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this amendment is subject to a regulatory hold (e.g., MNP porting window freeze, FCC-mandated processing pause, Ofcom dispute freeze). When True, the amendment cannot be processed until the hold is lifted.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time at which the amendment was rejected. Null if the amendment was not rejected.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The exact date and time at which the customer or agent submitted the amendment request. This is the principal business event timestamp for the amendment lifecycle and is used for SLA measurement and audit.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingChannel rdf:type rdf:Property ;
    rdfs:label 'Requesting Channel' ;
    rdfs:comment 'The customer interaction channel through which the amendment request was submitted: IVR (Interactive Voice Response), AGENT_ASSISTED (call centre), SELF_SERVICE_WEB, SELF_SERVICE_APP, RETAIL_STORE, CHAT, EMAIL. [ENUM-REF-CANDIDATE: IVR|AGENT_ASSISTED|SELF_SERVICE_WEB|SELF_SERVICE_APP|RETAIL_STORE|CHAT|EMAIL — promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicenowChangeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Servicenow Change Request Reference' ;
    rdfs:comment 'The ServiceNow ITSM Change Request identifier raised to govern the technical configuration changes required to fulfil this amendment. Format: CHG followed by 7 digits. Null if no ITSM change request was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAmendmentRef rdf:type rdf:Property ;
    rdfs:label 'Source System Amendment Ref' ;
    rdfs:comment 'The native amendment or change-request identifier from the originating source system (e.g., Oracle OMS internal amendment ID, Salesforce case number). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChargeId rdf:type rdf:Property ;
    rdfs:label 'Order Charge Id' ;
    rdfs:comment 'Unique identifier for the order charge record. Primary key.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Labor Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Telecom billing includes labor charges (truck roll, installation fees) attributable to a specific technician. Labor cost reconciliation and technician billing productivity reports require linking orde' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:billedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billed Timestamp' ;
    rdfs:comment 'Timestamp when the charge was successfully posted to a customer invoice. Null if charge has not yet been billed or was waived/cancelled.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'System timestamp when this charge record was first created in the order management system. Used for audit trail and charge lifecycle tracking.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalChargeReference rdf:type rdf:Property ;
    rdfs:label 'External Charge Reference' ;
    rdfs:comment 'Charge identifier from the source operational system. Used for cross-system reconciliation and data lineage tracking. Format varies by source system.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system identifier that performed the most recent update to this charge record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationDays rdf:type rdf:Property ;
    rdfs:label 'Proration Days' ;
    rdfs:comment 'Number of days used to calculate prorated charge amount. Null if charge is not prorated.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalDescription rdf:type rdf:Property ;
    rdfs:label 'Reversal Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the charge reversal. Includes investigation findings, customer communication notes, or corrective action details. Null if charge was not reversed.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why a previously billed charge was reversed. BILLING_ERROR for incorrect invoicing, DUPLICATE_CHARGE for double-billing, SERVICE_NOT_DELIVERED for unfulfilled orders, CUSTOMER_DISPUTE for contested charges, SYSTEM_ERROR for technical failures, FRAUD for unauthorized charges, REGULATORY_ADJUSTMENT for compliance corrections. Null if charge was not reversed. [ENUM-REF-CANDIDATE: BILLING_ERROR|DUPLICATE_CHARGE|SERVICE_NOT_DELIVERED|CUSTOMER_DISPUTE|SYSTEM_ERROR|FRAUD|REGULATORY_ADJUSTMENT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment classification for this charge. STANDARD for normal sales tax rate, REDUCED for discounted rate items, EXEMPT for non-taxable services, ZERO_RATED for taxable but 0% rate, TELECOM_SPECIFIC for industry regulatory fees, USF for Universal Service Fund contributions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Business event that caused this charge to be generated. ORDER_COMPLETION for order fulfillment charges, SERVICE_ACTIVATION for go-live fees, INSTALLATION_COMPLETE for field work charges, CONTRACT_SIGNATURE for commitment fees, MNP_PORT_IN for number portability administrative charges, SERVICE_DISCONNECTION for termination fees, CONTRACT_TERMINATION for early exit penalties, PLAN_CHANGE for modification fees, EQUIPMENT_DELIVERY for CPE charges. [ENUM-REF-CANDIDATE: ORDER_COMPLETION|SERVICE_ACTIVATION|INSTALLATION_COMPLETE|CONTRACT_SIGNATURE|MNP_PORT_IN|SERVICE_DISCONNECTION|CONTRACT_TERMINATION|PLAN_CHANGE|EQUIPMENT_DELIVERY — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'User ID or name of the employee who authorized the charge waiver. Used for audit trail and policy compliance verification. Null if charge was not waived.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDescription rdf:type rdf:Property ;
    rdfs:label 'Waiver Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the charge waiver. Includes customer service notes, manager approval justification, or policy reference. Null if charge was not waived.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Standardized code explaining why a charge was waived. CUSTOMER_RETENTION for churn prevention, SERVICE_FAILURE for quality issues, BILLING_ERROR for system mistakes, PROMOTIONAL for marketing campaigns, GOODWILL for customer satisfaction, EXECUTIVE_ESCALATION for senior management decisions, REGULATORY_COMPLIANCE for legal requirements, CONTRACT_NEGOTIATION for commercial agreements. Null if charge was not waived. [ENUM-REF-CANDIDATE: CUSTOMER_RETENTION|SERVICE_FAILURE|BILLING_ERROR|PROMOTIONAL|GOODWILL|EXECUTIVE_ESCALATION|REGULATORY_COMPLIANCE|CONTRACT_NEGOTIATION — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Reference to parent account in hierarchical account structures. Used for enterprise customers with master account and sub-accounts, family plans with primary and secondary accounts, or wholesale relationships with reseller hierarchy. Null for standalone accounts. Enables consolidated billing and hierarchical reporting.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Service tier or loyalty level determining priority support, special offers, and premium features. Higher tiers receive enhanced customer service, exclusive promotions, and preferential treatment. Used for customer retention and lifetime value (CLTV) optimization.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Sales channel through which customer account was originally acquired. Retail store for physical locations; online for web/mobile signup; telesales for inbound/outbound call center; dealer for authorized resellers; partner for co-marketing channels; direct sales for field sales teams; referral for customer referral programs. Used for channel performance analysis and commission attribution. [ENUM-REF-CANDIDATE: retail_store|online|telesales|dealer|partner|direct_sales|referral — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when customer account was first created and customer relationship began. Used for customer tenure analysis, loyalty program eligibility, and customer lifetime value (CLTV) calculations. Critical metric for churn prediction models.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated by this account over the trailing 12 months. Calculated as total revenue divided by number of active months. Expressed in account currency. Key metric for customer value assessment, segmentation, and churn impact analysis. Used for CLTV calculations and retention investment decisions.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment is configured for this account. True means payment method is automatically charged on due date; false requires manual payment. Reduces delinquency rates and improves cash flow predictability.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of month when billing cycle closes and invoice is generated. Value between 1 and 28 to accommodate all months. Determines invoice generation schedule and payment due dates. Critical for revenue recognition and cash flow management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether California resident has exercised right to opt out of personal information sale under CCPA. True means customer opted out; false means no opt-out request. Required for California customers. Restricts data sharing with third parties for marketing purposes.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score indicating likelihood of customer churn within next 90 days. Ranges from 0.00 (lowest risk) to 100.00 (highest risk). Generated by machine learning models analyzing usage patterns, payment behavior, support interactions, NPS scores, and competitive activity. Triggers proactive retention campaigns and win-back offers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Segmentation based on predicted customer lifetime value. High segment represents most valuable customers with strong retention and upsell potential; medium segment shows moderate value; low segment indicates limited revenue potential; new segment for recently acquired customers without history; at risk segment for high-value customers with churn indicators. Drives retention investment prioritization.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditClass rdf:type rdf:Property ;
    rdfs:label 'Credit Class' ;
    rdfs:comment 'Credit risk classification based on credit bureau assessment and payment history. Determines deposit requirements, credit limits, and payment terms. Excellent and good classes receive favorable terms; fair and poor classes may require deposits; no credit check applies to prepaid; secured accounts have collateral.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Most recent Customer Satisfaction score ranging from 1.0 (very dissatisfied) to 5.0 (very satisfied). Typically measured after service interactions, support cases, or billing inquiries. Used for service quality monitoring, agent performance evaluation, and customer experience improvement. Null if not yet surveyed.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the oldest unpaid invoice is overdue. Zero for accounts current on payments; positive values indicate delinquency. Used for aging analysis, dunning process triggers, and credit risk assessment. Null for prepaid accounts or accounts with no outstanding balance.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotCallFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Call Flag' ;
    rdfs:comment 'Indicates whether customer is registered on Do Not Call list or has requested no telemarketing calls. True means no outbound sales calls permitted; false means calls allowed with consent. Compliance with FTC Do Not Call Registry and TCPA regulations. Does not restrict service-related or transactional calls.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether account has been flagged for suspected fraudulent activity. True means fraud investigation in progress or confirmed fraud; false means no fraud indicators. Triggers service suspension, payment holds, and security team review. Used for fraud pattern analysis and prevention.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Calculated fraud risk score ranging from 0.00 (lowest risk) to 100.00 (highest risk). Generated by fraud detection algorithms analyzing payment patterns, usage behavior, identity verification, and historical fraud indicators. Triggers enhanced verification, deposit requirements, or service restrictions for high-risk accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Timestamp when GDPR consent was obtained or last updated. Required for audit trail and consent management. Null if consent not applicable or not obtained. Must be refreshed periodically per GDPR guidelines.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether customer has provided explicit consent for data processing under GDPR regulations. True means valid consent obtained; false means consent not given or withdrawn. Required for EU/EEA customers. Governs marketing communications, data sharing, and analytics usage.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for customer communications, invoices, and support interactions. Examples: en (English), es (Spanish), fr (French), de (German), zh (Chinese). Ensures culturally appropriate customer experience.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether customer has consented to receive marketing communications, promotional offers, and product announcements. True means customer opted in; false means customer declined or opted out. Governs eligibility for marketing campaigns and compliance with CAN-SPAM Act and TCPA regulations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score for this account ranging from -100 to +100. Measures customer loyalty and likelihood to recommend services. Scores 9-10 are promoters; 7-8 are passives; 0-6 are detractors. Used for customer satisfaction tracking, churn prediction, and service improvement initiatives. Null if customer has not been surveyed.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current total amount owed by customer including unpaid invoices, late fees, and adjustments. Positive values indicate customer owes money; negative values indicate credit balance. Expressed in account currency. Zero for prepaid accounts. Used for collections prioritization and credit limit management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether customer has opted for electronic billing instead of paper invoices. True means customer receives invoices via email or web portal only; false means paper invoices are mailed. Supports environmental sustainability initiatives and reduces operational costs (OPEX).' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Customer\'s preferred channel for receiving notifications, billing statements, promotional offers, and service updates. Email for electronic delivery; SMS for text messages; phone for voice calls; mail for postal delivery; mobile app for push notifications; web portal for self-service access.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Account status immediately before the most recent status change. Used for status transition audit trail and lifecycle analysis. Enables tracking of suspension-to-active restorations, termination reversals, and status change patterns. Null for accounts that have never changed status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full legal name of the primary account holder or authorized contact person. Used for identity verification, legal correspondence, and customer service authentication. For business accounts, this is the primary business contact. For consumer accounts, this is the account owner.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Primary Email Address' ;
    rdfs:comment 'Primary email address for account communications, billing notifications, service alerts, and password resets. Must be unique per account for authentication purposes. Used for electronic invoice delivery when paperless billing is enabled.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Number' ;
    rdfs:comment 'Primary contact telephone number in E.164 international format. Used for customer service callbacks, two-factor authentication, SMS notifications, and emergency contact. May be mobile or landline. For mobile accounts, often matches the service MSISDN (Mobile Station International Subscriber Directory Number).' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable deposit held for accounts with credit risk or new customers without credit history. Returned after satisfactory payment history period. Expressed in account currency. Zero or null for accounts not requiring deposits.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAddressSameAsBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Service Address Same As Billing Flag' ;
    rdfs:comment 'Indicates whether service delivery address matches billing address. True for most residential mobile accounts; false for business accounts with separate billing and service locations, or customers with PO Box billing addresses. Determines whether separate service address fields are populated.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeDate rdf:type rdf:Property ;
    rdfs:label 'Status Change Date' ;
    rdfs:comment 'Timestamp of most recent account status change. Used for status duration analysis, SLA compliance tracking, and lifecycle event sequencing. Null for accounts that have never changed status since creation.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangeInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Status Change Initiated By' ;
    rdfs:comment 'Actor or system that triggered the most recent status change. Customer for self-service actions; system for automated processes; agent for customer service actions; billing for payment-related changes; fraud for security actions; credit for credit management; provisioning for technical changes. Used for accountability and process analysis. [ENUM-REF-CANDIDATE: customer|system|agent|billing|fraud|credit|provisioning — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'Free-text explanation for most recent status change. Examples: payment received for suspension-to-active; non-payment for active-to-suspended; customer request for termination; fraud detection for suspension. Used for root cause analysis and process improvement. Null for accounts with no status changes.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subType rdf:type rdf:Property ;
    rdfs:label 'Sub Type' ;
    rdfs:comment 'Secondary classification providing additional segmentation within account type. Individual accounts serve single consumers; family accounts serve household groups; business accounts serve commercial entities; government accounts serve public sector; nonprofit accounts serve charitable organizations; reseller accounts serve distribution partners.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether account is exempt from sales tax, value-added tax (VAT), or other telecommunications taxes. True for government entities, nonprofits, or accounts with valid tax exemption certificates; false for standard taxable accounts. Requires supporting documentation.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Official certificate or registration number proving tax-exempt status. Required for audit compliance when tax exempt flag is true. Issued by relevant tax authority. Null for non-exempt accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Primary reason for account closure. Customer request for voluntary cancellation; non-payment for delinquency; fraud for security violations; relocation for move outside service area; competitor for churn to rival; service quality for dissatisfaction; price for cost concerns; deceased for customer death; duplicate for consolidation. Critical for churn root cause analysis. [ENUM-REF-CANDIDATE: customer_request|non_payment|fraud|relocation|competitor|service_quality|price|deceased|duplicate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether account is designated as VIP requiring special handling. True for high-value customers, executives, celebrities, government officials, or strategic partners. Triggers priority support routing, dedicated account management, and enhanced service level agreements (SLA). Used for customer retention and satisfaction optimization.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Verified Flag' ;
    rdfs:comment 'Indicates whether the subscriber has completed biometric identity verification (fingerprint, facial recognition, etc.).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Predicted total revenue value of the subscriber over their expected lifetime with the company. Used for retention and marketing prioritization.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the subscriber has consented to sharing their data with third parties for analytics or marketing purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSpeedTier rdf:type rdf:Property ;
    rdfs:label 'Data Speed Tier' ;
    rdfs:comment 'Classification of the data speed entitlement for the subscriber based on their service plan and current usage status.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Birth date of the subscriber. Used for age verification, parental controls, and regulatory compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviceImei rdf:type rdf:Property ;
    rdfs:label 'Device Imei' ;
    rdfs:comment 'Unique 15-digit identifier of the mobile device currently associated with the subscriber. Used for device tracking and fraud prevention.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Esim Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for eSIM provisioning based on device capability and service plan.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiveGEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Five G Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber has access to 5G network services based on device capability and service plan.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hotspotEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Hotspot Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to use mobile hotspot/tethering functionality.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Id Document Number' ;
    rdfs:comment 'Unique number of the government-issued identification document. Used for KYC and regulatory compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idDocumentType rdf:type rdf:Property ;
    rdfs:label 'Id Document Type' ;
    rdfs:comment 'Type of government-issued identification document provided by the subscriber during registration.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalDialingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'International Dialing Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to make international calls from the home network.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastNpsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Nps Survey Date' ;
    rdfs:comment 'Date when the subscriber last completed an NPS survey.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSimSwapDate rdf:type rdf:Property ;
    rdfs:label 'Last Sim Swap Date' ;
    rdfs:comment 'Date of the most recent SIM card swap event for the subscriber.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date when the subscriber last used any network service (voice, data, SMS). Used for dormancy detection and churn prediction.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Country of citizenship of the subscriber, represented as ISO 3166-1 alpha-3 code. Used for roaming profile and regulatory compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Flag' ;
    rdfs:comment 'Indicates whether parental control restrictions are applied to the subscriber, typically for minor dependents.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the subscriber\'s preferred language for communication and service delivery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosProfile rdf:type rdf:Property ;
    rdfs:label 'Qos Profile' ;
    rdfs:comment 'Defines the Quality of Service parameters applied to the subscriber\'s traffic, including priority, latency, and throughput guarantees.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Enabled Flag' ;
    rdfs:comment 'Indicates whether roaming services are currently enabled for the subscriber. Can be toggled for fraud prevention or cost control.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingProfile rdf:type rdf:Property ;
    rdfs:label 'Roaming Profile' ;
    rdfs:comment 'Defines the subscriber\'s roaming permissions and geographic scope. Determines which networks the subscriber can access outside the home network.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simSwapCount rdf:type rdf:Property ;
    rdfs:label 'Sim Swap Count' ;
    rdfs:comment 'Total number of times the subscriber has performed a SIM card swap. High frequency may indicate fraud risk.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberStatus rdf:type rdf:Property ;
    rdfs:label 'Subscriber Status' ;
    rdfs:comment 'Current lifecycle status of the subscriber. Active indicates the subscriber can use services; suspended/barred indicates temporary restriction; terminated indicates permanent closure.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberType rdf:type rdf:Property ;
    rdfs:label 'Subscriber Type' ;
    rdfs:comment 'Classification of the subscriber within the account structure. Primary is the main account holder, secondary/add-on are additional lines.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Volte Enabled Flag' ;
    rdfs:comment 'Indicates whether VoLTE service is enabled for the subscriber, allowing voice calls over LTE network.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vowifiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vowifi Enabled Flag' ;
    rdfs:comment 'Indicates whether Voice over Wi-Fi calling is enabled for the subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternatePhone rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone' ;
    rdfs:comment 'An alternate or secondary telephone number for the contact person (landline, office, or additional mobile).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'The level of authorization or permission this contact has to perform actions on the customer account (e.g., make changes, view bills, authorize service orders).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The preferred language for communication with the contact person, specified as a 3-letter ISO 639-2 language code (e.g., ENG for English, SPA for Spanish).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The role or capacity in which this contact person is associated with the customer account. Defines the contact\'s authority and responsibility level.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'The current lifecycle status of the contact record. Indicates whether the contact is actively associated with the customer account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or business unit within the organization where the contact person works. Primarily used for B2B enterprise accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether the contact person has requested not to be contacted for any purpose. True if contact is prohibited, False otherwise.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'The primary email address of the contact person used for electronic communication and correspondence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier for this contact in the source operational system. Used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The facsimile (fax) number of the contact person, if applicable. Used primarily for B2B enterprise communications.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The given name or first name of the contact person.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary or main contact for the customer account. True if primary, False otherwise. Only one contact per account should be marked as primary.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The professional job title or position of the contact person within their organization. Primarily used for Business-to-Business (B2B) enterprise accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The family name or surname of the contact person.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'The date when the contact person provided consent to receive marketing communications. Used for compliance tracking and consent management.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'The date when the contact person withdrew consent or opted out of receiving marketing communications.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'The middle name or initial of the contact person, if applicable.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'The mobile telephone number of the contact person. Primary contact channel for SMS and voice communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'The government-issued national identification number of the contact person (e.g., Social Security Number in USA, National Insurance Number in UK). Used for identity verification and regulatory compliance.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The contact person\'s preferred communication channel for receiving notifications, updates, and correspondence from the telecommunications provider.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToAccountHolder rdf:type rdf:Property ;
    rdfs:label 'Relationship To Account Holder' ;
    rdfs:comment 'Describes the personal or professional relationship of this contact to the primary account holder (e.g., spouse, parent, employee, business partner).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'The honorific or courtesy title of the contact person (e.g., Mr., Mrs., Dr.).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the contact information was last verified or validated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'The verification status of the contact information. Indicates whether the contact details (email, phone) have been validated through verification processes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this address record is currently active and in use. True if active, false if inactive or deprecated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: service address (where service is delivered), billing address (where invoices are sent), installation address (where equipment is installed), correspondence address (general mail), shipping address (equipment delivery), or legal address (registered business location).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadbandCoverageTier rdf:type rdf:Property ;
    rdfs:label 'Broadband Coverage Tier' ;
    rdfs:comment 'Highest tier of broadband technology available at this address: fiber (FTTH/GPON), cable (DOCSIS), DSL (ADSL/VDSL), fixed wireless (LTE/5G), satellite, or no coverage.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Composite data quality score (0-100) reflecting completeness, accuracy, consistency, and timeliness of the address record. Higher scores indicate better data quality.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dwellingType rdf:type rdf:Property ;
    rdfs:label 'Dwelling Type' ;
    rdfs:comment 'Classification of the building or property type at this address: single family home, multi-family building, apartment, condominium, townhouse, commercial property, industrial facility, or mixed-use development. [ENUM-REF-CANDIDATE: single_family|multi_family|apartment|condo|townhouse|commercial|industrial|mixed_use — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Ftth Serviceable Flag' ;
    rdfs:comment 'Indicates whether this address is within the FTTH network footprint and can receive fiber-optic broadband service. True if fiber service is available, false otherwise.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gponServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Gpon Serviceable Flag' ;
    rdfs:comment 'Indicates whether this address is within the GPON network coverage area and can receive gigabit passive optical network service. True if GPON service is available, false otherwise.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash of the complete address components used for deduplication, matching, and privacy-preserving analytics without exposing actual address details.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when this address was last verified or validated for accuracy, either through automated validation service or manual confirmation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and street type (e.g., 123 Main Street).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for apartment number, suite, unit, building, floor, or other location details within the primary address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lteCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Lte Coverage Flag' ;
    rdfs:comment 'Indicates whether this address has LTE (4G) wireless network coverage. True if LTE service is available, false otherwise.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDownloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Download Speed Mbps' ;
    rdfs:comment 'Maximum theoretical download speed in megabits per second available at this address based on network infrastructure and technology tier.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumUploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Upload Speed Mbps' ;
    rdfs:comment 'Maximum theoretical upload speed in megabits per second available at this address based on network infrastructure and technology tier.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mduFlag rdf:type rdf:Property ;
    rdfs:label 'Mdu Flag' ;
    rdfs:comment 'Indicates whether this address is part of a multi-dwelling unit property (apartment building, condo complex, etc.) requiring special provisioning considerations. True if MDU, false if single-unit.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:n5gCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'N5g Coverage Flag' ;
    rdfs:comment 'Indicates whether this address has 5G New Radio wireless network coverage. True if 5G service is available, false otherwise.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary or default address for the associated customer account. True if primary, false if secondary or alternate address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'Fully standardized and formatted address string as returned by the validation service, following postal authority standards. Used for mail delivery and system integration.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Number of individual units or dwellings within the property at this address. Relevant for MDU properties and bulk service opportunities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the validation service or system used to verify the address (e.g., USPS CASS, Google Maps API, Loqate, Melissa Data, internal GIS system).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address: validated (confirmed accurate by validation service), unvalidated (not yet checked), invalid (failed validation), pending (validation in progress), corrected (modified during validation), or partial (some components validated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for the customer interaction record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to sales.campaign. Business justification: Outbound campaign-driven interactions (telemarketing, SMS follow-up calls) must be attributed to the originating campaign for response rate, conversion, and ROI measurement. Telecom campaign managers ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:deviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Device Registration Id' ;
    rdfs:comment 'Foreign key linking to customer.device_registration. Business justification: Interactions can be about device issues (activation help, troubleshooting, IMEI registration). Adding device_registration_id FK links interaction to the specific device being discussed. No redundant c' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:retentionOfferId rdf:type rdf:Property ;
    rdfs:label 'Retention Offer Id' ;
    rdfs:comment 'Foreign key linking to sales.retention_offer. Business justification: Save-desk interactions are the primary channel through which retention offers are presented. Linking customer_interaction to the retention_offer presented during that call enables save-desk performanc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionOffer .

ind:callbackRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Callback Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer requested a callback (True) or not (False).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callbackScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Callback Scheduled Timestamp' ;
    rdfs:comment 'Date and time when a callback was scheduled, in format yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if no callback scheduled.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Email address used by the customer during this interaction. May differ from the primary account email.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Phone number used by the customer during this interaction. May differ from the primary account phone number.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEffortScore rdf:type rdf:Property ;
    rdfs:label 'Customer Effort Score' ;
    rdfs:comment 'Customer Effort Score measuring how easy it was for the customer to resolve their issue, typically on a scale of 1-7. Null if not captured.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of the interaction: inbound (customer-initiated) or outbound (company-initiated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the interaction ended or was closed, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fcrFlag rdf:type rdf:Property ;
    rdfs:label 'Fcr Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer issue was resolved on the first contact without requiring follow-up (True) or not (False). Key KPI for customer service quality.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction: open, in progress, resolved, closed, escalated, or pending customer response.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction purpose: inquiry, complaint, service request, sales, technical support, or billing inquiry.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Triggered Flag' ;
    rdfs:comment 'Boolean flag indicating whether a Net Promoter Score survey was triggered following this interaction (True) or not (False).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'Name of the service queue or routing group to which the interaction was assigned (e.g., Technical Support, Billing, Sales).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingUrl rdf:type rdf:Property ;
    rdfs:label 'Recording Url' ;
    rdfs:comment 'URL or storage path to the interaction recording (voice call recording, chat transcript, email thread). Null if recording not available or not permitted.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Status indicating whether the customer issue was resolved during the interaction: resolved, unresolved, partially resolved, escalated, or pending.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated sentiment analysis score derived from interaction content (voice transcription, chat text, email), ranging from -1.00 (negative) to +1.00 (positive).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the interaction began, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief textual summary of the interaction content, key points discussed, and actions taken. Used for quick reference and reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicCategory rdf:type rdf:Property ;
    rdfs:label 'Topic Category' ;
    rdfs:comment 'High-level category of the interaction topic (e.g., Billing, Network Quality, Service Activation, Account Management).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicSubcategory rdf:type rdf:Property ;
    rdfs:label 'Topic Subcategory' ;
    rdfs:comment 'Detailed subcategory of the interaction topic providing granular classification (e.g., Invoice Dispute, Data Speed Issue, SIM Activation).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Unique identifier for the customer support case. Primary key for the case entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:dataBreachIncidentId rdf:type rdf:Property ;
    rdfs:label 'Data Breach Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_breach_incident. Business justification: When a data breach occurs, customer service cases are opened for affected customers (complaints, compensation claims, notification follow-up). Linking case to data_breach_incident enables the customer' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataBreachIncident .

ind:parentCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Id' ;
    rdfs:comment 'Reference to a parent case if this case is a child or related case, enabling case hierarchy tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_request. Business justification: Customer service cases are routinely opened to manage GDPR/CCPA privacy request fulfillment (data access, deletion, portability). Linking case to privacy_request enables SLA tracking, escalation manag' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:salesContractId rdf:type rdf:Property ;
    rdfs:label 'Sales Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: Contract dispute cases, early termination requests, and SLA breach cases must reference the governing sales contract. Telecom legal and operations teams require this link for contract dispute resoluti' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContract .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date and time when the case was resolved and solution was provided to the customer.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Secondary classification providing additional context for the case type. [ENUM-REF-CANDIDATE: network_coverage|billing_error|service_activation|device_issue|contract_inquiry|data_usage|roaming|porting|upgrade_request|cancellation_request|loyalty_reward|win_back|contract_renewal — promote to reference product]' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Detailed description of the customer issue, complaint, or request as initially reported.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible unique case number used for customer communication and tracking. Format: CASE-xxxxxxxxxx.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the case. Open (newly created), in_progress (being worked), pending_customer (awaiting customer response), resolved (solution provided), closed (completed and verified), cancelled (withdrawn).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case by business purpose: complaint (service quality issue), billing_dispute (invoice or charge dispute), technical_fault (network or service technical issue), mnp_request (Mobile Number Portability request), general_inquiry (information request), save_offer (retention intervention).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date and time when the case was officially closed and marked as complete.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the support team attempted to contact the customer regarding this case.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Extension Months' ;
    rdfs:comment 'For retention cases, the number of months the customer contract was extended as part of the retention offer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date and time when the case was first created in the system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Date and time when the case record was last modified or updated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Flag' ;
    rdfs:comment 'For retention cases, indicates whether the customer accepted the retention offer. True if accepted, False if declined.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerValue rdf:type rdf:Property ;
    rdfs:label 'Offer Value' ;
    rdfs:comment 'For retention cases, the monetary value of the retention offer presented to the customer (discount amount, credit value, waived fees).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Source or trigger that created the case: customer_initiated (customer contacted support), proactive_outreach (company reached out), system_generated (automated alert), escalation (from another case), third_party (partner or regulator).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name or identifier of the support team currently responsible for resolving the case. [ENUM-REF-CANDIDATE: tier1_support|tier2_support|tier3_support|billing_team|technical_team|retention_team|save_desk|mnp_team|vip_support|enterprise_support — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether the case involves regulatory compliance issues or requires regulatory reporting. True if regulatory-related, False otherwise.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times the case has been reopened after initial closure, indicating unresolved issues or customer dissatisfaction.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionCost rdf:type rdf:Property ;
    rdfs:label 'Retention Cost' ;
    rdfs:comment 'For retention cases, the total cost to the business of the retention intervention (discount value, credits, waived fees, incentive costs).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionOutcome rdf:type rdf:Property ;
    rdfs:label 'Retention Outcome' ;
    rdfs:comment 'For retention cases, the final outcome of the retention intervention: retained (customer stayed), churned (customer left), pending (decision not yet made), no_action (customer did not require intervention).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Reason' ;
    rdfs:comment 'For retention cases, the business reason that triggered the save intervention: churn_intent (customer expressed intent to leave), contract_expiry (contract ending soon), competitor_offer (customer received competitive offer), high_risk_score (predictive churn model), usage_decline (significant usage drop), payment_issue (payment problems).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the issue after investigation and resolution. [ENUM-REF-CANDIDATE: network_outage|billing_system_error|provisioning_failure|user_error|device_defect|third_party_issue|process_gap|system_bug|configuration_error|capacity_issue — promote to reference product]' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saveDeskQueue rdf:type rdf:Property ;
    rdfs:label 'Save Desk Queue' ;
    rdfs:comment 'For retention cases, the specific save desk queue or team that handled the retention intervention (high_value, standard, win_back, contract_renewal).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Resolution Hours' ;
    rdfs:comment 'Total elapsed time in hours from case creation to resolution, used for SLA tracking and performance measurement.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique identifier for the consent record. Primary key.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Id' ;
    rdfs:comment 'Reference to a previous consent record that this record supersedes or amends. Used to track consent history and version chains. Null for initial consent records.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'The channel through which the consent was captured: web (online portal), mobile_app (mobile application), retail_store (physical store interaction), ivr (Interactive Voice Response system), paper (physical form), email (email response), or sms (text message confirmation). [ENUM-REF-CANDIDATE: web|mobile_app|retail_store|ivr|paper|email|sms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained: explicit (affirmative action required), implicit (inferred from behavior), opt_in (customer actively chose to consent), opt_out (customer must actively decline), pre_checked (checkbox pre-selected), or unchecked (checkbox not pre-selected). Critical for GDPR compliance as pre-checked boxes do not constitute valid consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current state of the consent: granted (customer has given consent), withdrawn (customer has revoked consent), pending (awaiting customer decision), expired (consent period has lapsed), or revoked (administratively cancelled).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentText rdf:type rdf:Property ;
    rdfs:label 'Consent Text' ;
    rdfs:comment 'The exact text of the consent statement or privacy notice that was presented to the customer at the time of consent capture. Stored for audit and compliance verification. Required to demonstrate informed consent under GDPR Article 13.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being recorded: marketing (promotional communications), data_processing (use of personal data for service delivery), third_party_sharing (sharing data with partners), lawful_intercept (government access compliance), cpni (Customer Proprietary Network Information usage under FCC rules), or channel_opt_in (permission to contact via specific channel).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the privacy policy or terms of service under which this consent was granted. Enables tracking of consent against evolving policy versions for regulatory audit trails.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategory rdf:type rdf:Property ;
    rdfs:label 'Data Category' ;
    rdfs:comment 'The specific category or categories of personal data covered by this consent (e.g., contact information, usage data, location data, payment information, call detail records). Free-text field to accommodate diverse data classification schemes across jurisdictions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'The unique identifier of the device (e.g., mobile device ID, browser fingerprint, IMEI) from which the consent was captured. Used for audit trails and fraud prevention. Considered PII under GDPR and CCPA.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotDisturbSchedule rdf:type rdf:Property ;
    rdfs:label 'Do Not Disturb Schedule' ;
    rdfs:comment 'Specific times or days when the customer does not wish to be contacted (e.g., weekends, evenings, holidays). Free-text to accommodate complex schedules. Supports FCC Telephone Consumer Protection Act (TCPA) compliance and customer experience optimization.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicBillOptIn rdf:type rdf:Property ;
    rdfs:label 'Electronic Bill Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive electronic bills via email or online portal. True = e-bill requested, False = paper bill only. Supports digital transformation and cost reduction initiatives.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date when the consent automatically expires and must be renewed. Null for indefinite consents. Required for time-bound consent management under GDPR and CCPA.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geolocation rdf:type rdf:Property ;
    rdfs:label 'Geolocation' ;
    rdfs:comment 'The geographic coordinates (latitude, longitude) or general location from which the consent was captured. Used to verify jurisdiction and support location-based consent requirements. May be considered PII under GDPR.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the consent was submitted (for web or mobile app channels). Used for fraud detection, audit trails, and geolocation verification. May be considered PII under GDPR.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this consent record is currently active and enforceable. True = active, False = superseded or inactive. Used for operational filtering to identify current consents.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The primary regulatory framework governing this consent: FCC (Federal Communications Commission - US telecom), GDPR (General Data Protection Regulation - EU), CCPA (California Consumer Privacy Act), OFCOM (UK communications regulator), PIPEDA (Canadian privacy law), or LGPD (Brazilian data protection law).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEmailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via email. True = opted in, False = opted out. Required for CAN-SPAM Act and GDPR compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Mail Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via postal mail. True = opted in, False = opted out.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPhoneOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Phone Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via phone call. True = opted in, False = opted out. Required for TCPA and FCC telemarketing rules compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSmsOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Sms Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via SMS text message. True = opted in, False = opted out. Required for TCPA compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paperBillOptIn rdf:type rdf:Property ;
    rdfs:label 'Paper Bill Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive paper bills via postal mail. True = paper bill requested, False = electronic bill only. Impacts billing operations and environmental sustainability initiatives.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactTimeWindow rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time Window' ;
    rdfs:comment 'The time window during which the customer prefers to be contacted, expressed as a time range (e.g., 09:00-17:00, 18:00-21:00). Free-text to accommodate various formats. Used to honor customer communication preferences and improve Customer Satisfaction Score (CSAT).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofReference rdf:type rdf:Property ;
    rdfs:label 'Proof Reference' ;
    rdfs:comment 'Reference identifier or URL to the stored proof of consent (e.g., signed form, recorded call ID, web session ID, email confirmation ID). Required for regulatory audit trails and dispute resolution under GDPR Article 7(1) requirement to demonstrate consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days for which data collected under this consent will be retained. Null indicates indefinite retention subject to other policies. Required for GDPR storage limitation principle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Service Notification Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive service-related notifications (e.g., outage alerts, billing reminders, service updates). True = opted in, False = opted out. Distinct from marketing opt-ins; typically required for operational communications.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartySharingOptIn rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to sharing their personal data with third-party partners or affiliates. True = consented, False = not consented. Required for GDPR Article 6 lawful basis and CCPA right to opt-out of sale.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date when the customer withdrew or revoked consent. Null if consent is still active. Required for GDPR right to withdraw consent tracking.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementDeviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Replacement Device Registration Id' ;
    rdfs:comment 'Reference to the new device registration record if this device was replaced. Null if no replacement occurred.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:byodFlag rdf:type rdf:Property ;
    rdfs:label 'Byod Flag' ;
    rdfs:comment 'Indicates whether the device is customer-owned (BYOD = True) or operator-provided/financed (BYOD = False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceirBlockDate rdf:type rdf:Property ;
    rdfs:label 'Ceir Block Date' ;
    rdfs:comment 'Date when the device was blocked in the CEIR. Null if device is not blocked.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceirBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Ceir Block Flag' ;
    rdfs:comment 'Indicates whether the device IMEI has been blocked in the Central Equipment Identity Register (CEIR) due to theft, loss, or fraud (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system that is the source of record for this device registration (e.g., Salesforce CRM, Netcracker OSS, Oracle Service Management).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationDate rdf:type rdf:Property ;
    rdfs:label 'Deregistration Date' ;
    rdfs:comment 'Date when the device was deregistered or removed from the subscriber account. Null if device is still registered.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deregistrationReason rdf:type rdf:Property ;
    rdfs:label 'Deregistration Reason' ;
    rdfs:comment 'Reason for device deregistration: upgrade to new device, reported lost, reported stolen, damaged beyond repair, sold to another party, service termination, or other. [ENUM-REF-CANDIDATE: upgrade|lost|stolen|damaged|sold|service_termination|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Device Financing Flag' ;
    rdfs:comment 'Indicates whether the device is under an installment financing plan (True) or purchased outright (False). Links to billing installment plan records.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceStatus rdf:type rdf:Property ;
    rdfs:label 'Device Status' ;
    rdfs:comment 'Current lifecycle status of the registered device: active (in use), inactive (not in use), lost (reported lost), stolen (reported stolen and blocked via CEIR), replaced (superseded by new device), or blocked (administratively blocked).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Enrollment Flag' ;
    rdfs:comment 'Indicates whether the device is enrolled in an insurance or protection plan (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number or reference for the device insurance plan, if enrolled. Used for insurance claim validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastNetworkActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Network Activity Timestamp' ;
    rdfs:comment 'Timestamp of the last recorded network activity (data session, voice call, SMS) from this device. Used for device usage analytics and fraud detection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware address of the device network interface, used for CPE provisioning and network access control.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapability4g rdf:type rdf:Property ;
    rdfs:label 'Network Capability 4g' ;
    rdfs:comment 'Indicates whether the device supports 4G LTE connectivity (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkCapability5g rdf:type rdf:Property ;
    rdfs:label 'Network Capability 5g' ;
    rdfs:comment 'Indicates whether the device supports 5G NR connectivity (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osType rdf:type rdf:Property ;
    rdfs:label 'Os Type' ;
    rdfs:comment 'Operating system family running on the device: Android, iOS, Windows, Linux, proprietary (for CPE/ONT), or other.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'Specific version of the operating system installed on the device (e.g., Android 13, iOS 16.5, firmware v2.1.3 for CPE).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySimIccid rdf:type rdf:Property ;
    rdfs:label 'Primary Sim Iccid' ;
    rdfs:comment 'Integrated Circuit Card ID of the primary SIM card associated with this device. 19-20 digit unique identifier for the physical or eSIM card.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date when the device was purchased by the customer, either from the operator or a third party. Used for warranty and upgrade eligibility calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Amount' ;
    rdfs:comment 'Original purchase price of the device in the billing currency. Used for device financing and depreciation calculations.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'Channel through which the device was registered: retail store, online customer portal, mobile app, call center, or authorized dealer.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the device was registered against the subscriber or account in the Customer Relationship Management (CRM) system.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise timestamp when the device registration was recorded in the system, including time zone information.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:residualValueAmount rdf:type rdf:Property ;
    rdfs:label 'Residual Value Amount' ;
    rdfs:comment 'Current estimated residual or trade-in value of the device. Used for upgrade offers and device buyback programs.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number for non-cellular devices such as Customer Premises Equipment (CPE), Optical Network Terminals (ONT), routers, modems, and IoT devices.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simSlotType rdf:type rdf:Property ;
    rdfs:label 'Sim Slot Type' ;
    rdfs:comment 'SIM slot configuration of the device: single SIM, dual SIM (two physical slots), eSIM only (embedded SIM), hybrid (physical + eSIM), or none (for non-cellular devices).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tac rdf:type rdf:Property ;
    rdfs:label 'Tac' ;
    rdfs:comment 'First 8 digits of the IMEI, identifying the device model and manufacturer. Used for device capability lookup in GSMA TAC database.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteCapable rdf:type rdf:Property ;
    rdfs:label 'Volte Capable' ;
    rdfs:comment 'Indicates whether the device supports Voice over LTE (VoLTE) for voice calls over 4G networks (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer or operator warranty for the device expires. Null if no warranty or warranty information unavailable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wifiCapability rdf:type rdf:Property ;
    rdfs:label 'Wifi Capability' ;
    rdfs:comment 'Highest Wi-Fi standard supported by the device: WiFi 4 (802.11n), WiFi 5 (802.11ac), WiFi 6 (802.11ax), WiFi 6E (6 GHz), or none.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard list price for the catalog item before discounts, promotions, or customer-specific adjustments. Currency is USD unless otherwise specified in enterprise configuration.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Cadence at which recurring charges are generated for this catalog item. Drives invoice generation schedule in Amdocs billing system. [ENUM-REF-CANDIDATE: monthly|quarterly|annually|one_time|daily|per_usage|na — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogVersion rdf:type rdf:Property ;
    rdfs:label 'Catalog Version' ;
    rdfs:comment 'Version number of the catalog item definition in Netcracker Product Catalog. Incremented with each approved change to product specifications, pricing, or terms. Format: major.minor.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCount rdf:type rdf:Property ;
    rdfs:label 'Channel Count' ;
    rdfs:comment 'Number of live TV channels included in IPTV and OTT packages. Null for non-content products. Used for content licensing cost allocation and package differentiation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataAllowanceGb rdf:type rdf:Property ;
    rdfs:label 'Data Allowance Gb' ;
    rdfs:comment 'Monthly data usage quota in gigabytes for mobile and broadband products. Null for unlimited plans or non-data products. Used for usage threshold monitoring and overage billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Download Speed Mbps' ;
    rdfs:comment 'Maximum or typical download throughput in Mbps for broadband and mobile data products. Key QoS parameter for customer expectations and SLA commitments.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Business rules defining customer qualification requirements for this catalog item. Examples: credit score thresholds, geographic availability, existing customer status, business registration requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Date when all support and service for this catalog item ceases. All customer subscriptions must be migrated or terminated by this date. Null if not yet scheduled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endOfSaleDate rdf:type rdf:Property ;
    rdfs:label 'End Of Sale Date' ;
    rdfs:comment 'Date after which new orders for this catalog item are no longer accepted. Existing subscriptions may continue. Null if product is still available for sale.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Regions, states, or service areas where this catalog item can be provisioned. Constrained by network infrastructure coverage (RAN, fiber footprint, DSLAM reach). Pipe-separated list of region codes or \'national\' for full coverage.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundled rdf:type rdf:Property ;
    rdfs:label 'Is Bundled' ;
    rdfs:comment 'Indicates whether this catalog item is a composite bundle containing multiple sub-products or services. True for triple-play, quad-play, and enterprise solution bundles.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandalone rdf:type rdf:Property ;
    rdfs:label 'Is Standalone' ;
    rdfs:comment 'Indicates whether this catalog item can be purchased independently or requires a base product. False for add-ons, value-added services, and device accessories.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the catalog item was first made available for sale to customers. Used for product performance analysis and lifecycle tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Target customer segment for the catalog item. Determines pricing strategy, sales channel eligibility, contract terms, and SLA commitments. [ENUM-REF-CANDIDATE: b2c|b2b|wholesale|mvno|government|enterprise_sme|enterprise_large — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time of the most recent update to this catalog item record. Updated with every change to product specifications, pricing, or lifecycle status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Revenue model and charging structure for the catalog item. Determines how billing events are generated and rated in Amdocs Revenue Management. [ENUM-REF-CANDIDATE: recurring|one_time|usage_based|tiered|hybrid|freemium|prepaid|postpaid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Externally-known unique business identifier for the catalog item. Used across all BSS/OSS systems for product identification and ordering. Follows enterprise SKU format.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the catalog item including features, benefits, and technical specifications. Used for customer-facing documentation and sales enablement.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Logical grouping of related catalog items that share common characteristics, pricing models, or go-to-market strategy. Example: \'Unlimited Plans\', \'Fiber Home\', \'Business Connect Suite\'.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this catalog item is a limited-time promotional offer with special pricing or terms. Used for campaign tracking and revenue recognition.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDevice rdf:type rdf:Property ;
    rdfs:label 'Requires Device' ;
    rdfs:comment 'Indicates whether this catalog item requires customer premises equipment (CPE), SIM card, or device to function. True for mobile plans, IPTV services, and broadband requiring ONT/modem.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Distribution channels authorized to sell this catalog item. Pipe-separated list: \'retail_store\', \'online\', \'telesales\', \'partner\', \'enterprise_direct\', \'wholesale\'. Controls product visibility in Salesforce CRM and order capture systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMttrHours rdf:type rdf:Property ;
    rdfs:label 'Sla Mttr Hours' ;
    rdfs:comment 'Maximum time in hours to restore service after a fault for enterprise products with SLA commitments. Null for consumer products. Drives NOC escalation procedures.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Contractually guaranteed network availability percentage for enterprise and wholesale products. Null for consumer products without formal SLA. Used for penalty calculations and service credits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsAllowance rdf:type rdf:Property ;
    rdfs:label 'Sms Allowance' ;
    rdfs:comment 'Monthly SMS message quota included in mobile products. Null for unlimited messaging or non-mobile products. Used for usage tracking and overage billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsEsim rdf:type rdf:Property ;
    rdfs:label 'Supports Esim' ;
    rdfs:comment 'Indicates whether mobile product supports eSIM provisioning for compatible devices. Enables remote SIM activation and multi-profile management.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsMnp rdf:type rdf:Property ;
    rdfs:label 'Supports Mnp' ;
    rdfs:comment 'Indicates whether customers can port their existing phone number when subscribing to this mobile product. Drives MNP transaction workflows and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRoaming rdf:type rdf:Property ;
    rdfs:label 'Supports Roaming' ;
    rdfs:comment 'Indicates whether mobile product includes international or domestic roaming capabilities. Affects CDR rating and interconnect settlement processing.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Upload Speed Mbps' ;
    rdfs:comment 'Maximum or typical upload throughput in Mbps for broadband and mobile data products. Critical for enterprise applications, video conferencing, and cloud services.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceMinutesAllowance rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes Allowance' ;
    rdfs:comment 'Monthly voice call minutes included in mobile and VoIP products. Null for unlimited voice or data-only plans. Used for usage tracking and overage charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseMonthlyPrice rdf:type rdf:Property ;
    rdfs:label 'Base Monthly Price' ;
    rdfs:comment 'Standard monthly recurring charge for this offering before discounts, promotions, or usage charges. Used for MRR forecasting and ARPU calculations. Nullable for one-time or usage-based offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Flag' ;
    rdfs:comment 'Indicates whether this offering is a bundle combining multiple catalog items or services. True = bundle offering, False = standalone offering. Bundles may include discounts vs. individual component pricing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Comma-separated list of sales channels where this offering is available for purchase (e.g., retail, online, telesales, dealer, b2b_direct, mvno_reseller). Drives channel-specific pricing and commission rules.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic positioning statement describing how this offering compares to competitor products in the market. Used for sales enablement and marketing strategy. Business-confidential information.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentEntitlements rdf:type rdf:Property ;
    rdfs:label 'Content Entitlements' ;
    rdfs:comment 'Comma-separated list of included content packages, streaming services, or IPTV/OTT subscriptions bundled with this offering (e.g., premium_sports, hd_channels, streaming_music). Drives content provisioning and DRM policy application.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Credit Class Eligibility' ;
    rdfs:comment 'Minimum credit class required for customer eligibility. Drives deposit requirements, payment terms, and risk-based pricing. All = no credit restrictions.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Device Included Flag' ;
    rdfs:comment 'Indicates whether this offering includes a physical device (e.g., smartphone, router, set-top box, Customer Premises Equipment). True = device included, False = service-only offering.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rules Summary' ;
    rdfs:comment 'High-level summary of customer eligibility criteria for this offering (e.g., credit score requirements, existing customer status, device compatibility, service address qualification). Detailed rules managed in policy engine.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etfStructure rdf:type rdf:Property ;
    rdfs:label 'Etf Structure' ;
    rdfs:comment 'Structure of the Early Termination Fee applied when a customer cancels before contract term completion. Flat = fixed amount, Prorated = decreases over time, Tiered = varies by remaining term, None = no ETF.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoResellerFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Reseller Flag' ;
    rdfs:comment 'Indicates whether this offering is available for resale through MVNO partners. True = MVNO reseller enabled, False = direct sales only. Drives wholesale pricing and interconnect billing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsTargetScore rdf:type rdf:Property ;
    rdfs:label 'Nps Target Score' ;
    rdfs:comment 'Target Net Promoter Score for customer satisfaction tracking specific to this offering. Used for product performance monitoring and churn prediction. Nullable if no specific NPS target is set.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offeringCategory rdf:type rdf:Property ;
    rdfs:label 'Offering Category' ;
    rdfs:comment 'Market segment classification indicating the target customer base for this offering. Drives channel strategy and pricing models.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringCode rdf:type rdf:Property ;
    rdfs:label 'Offering Code' ;
    rdfs:comment 'Externally-known unique business identifier for the offering used in BSS/CRM systems and customer-facing materials. Typically follows a structured format for catalog management.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringDescription rdf:type rdf:Property ;
    rdfs:label 'Offering Description' ;
    rdfs:comment 'Detailed description of the offering including key features, benefits, and value proposition for customer-facing and internal reference.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringName rdf:type rdf:Property ;
    rdfs:label 'Offering Name' ;
    rdfs:comment 'Customer-facing marketing name of the offering as displayed in sales channels, promotional materials, and customer communications.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringType rdf:type rdf:Property ;
    rdfs:label 'Offering Type' ;
    rdfs:comment 'Classification of the offering by product category. Determines the primary service domain and applicable business rules. [ENUM-REF-CANDIDATE: mobile_plan|broadband_package|iptv_bundle|ott_service|voip_offering|enterprise_sdwan|mpls_service|ftth_service|device|accessory|value_added_service|promotional_bundle — promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oneTimeActivationFee rdf:type rdf:Property ;
    rdfs:label 'One Time Activation Fee' ;
    rdfs:comment 'Non-recurring charge applied at service activation or order fulfillment. Includes setup, installation, or provisioning fees. Nullable if no activation fee applies.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Business justification for retiring or obsoleting this offering (e.g., technology sunset, regulatory change, poor market performance, replaced by new offering). Nullable for active offerings. Used for product portfolio analysis.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Included Flag' ;
    rdfs:comment 'Indicates whether international or domestic roaming is included in the offering without additional charges. True = roaming included, False = roaming charged separately. Applicable to mobile offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleCategory rdf:type rdf:Property ;
    rdfs:label 'Bundle Category' ;
    rdfs:comment 'Market segment classification for the bundle. Consumer bundles target residential customers. Business bundles serve SMB and enterprise. Wholesale bundles are for carrier-to-carrier. MVNO (Mobile Virtual Network Operator) bundles support virtual operators. IoT (Internet of Things) bundles serve connected devices. Roaming bundles provide international services.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bundle used in product catalog, ordering, and billing systems. Examples: TRIPLE_PLAY_GOLD, QUAD_PLAY_PREMIUM, MOBILE_FAMILY_PLUS.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed business description of the bundle including key features, benefits, target customer segment, and value proposition. Used for product catalog documentation and sales enablement.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable marketing name of the bundle displayed to customers and used in sales channels. Examples: Triple Play Gold, Quad Play Premium, Family Mobile Plus.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure. Fixed bundles have predefined components that cannot be changed. Flexible bundles allow customer selection from a set of options. Customizable bundles permit component substitution. Dynamic bundles adjust based on usage patterns. Promotional bundles are time-limited offers. Enterprise bundles are tailored for business customers.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Component Substitution Allowed' ;
    rdfs:comment 'Indicates whether customers can substitute bundle components with alternatives of equal or lesser value (True) or if the bundle composition is fixed (False). Used in order configuration and customization workflows.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Downgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can downgrade from this bundle to lower-tier offerings (True) or if downgrade restrictions apply (False). Used in churn prevention and customer retention strategies.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationFee rdf:type rdf:Property ;
    rdfs:label 'Installation Fee' ;
    rdfs:comment 'One-time charge for service installation, activation, and Customer Premises Equipment (CPE) setup. Null if installation is included at no charge. Used in order pricing and revenue recognition.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalRoamingIncluded rdf:type rdf:Property ;
    rdfs:label 'International Roaming Included' ;
    rdfs:comment 'Indicates whether international roaming services are included in the bundle at no additional charge (True) or require separate fees (False). Used for service provisioning and roaming partner settlement.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Component Count' ;
    rdfs:comment 'Maximum number of component products or services that can be included in the bundle. Null indicates no upper limit. Used for bundle configuration validation.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Component Count' ;
    rdfs:comment 'Minimum number of component products or services that must be included in the bundle for it to be valid. Used for bundle eligibility validation during order capture.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Base recurring price of the bundle in the specified currency. For flat-rate bundles this is the total charge. For other pricing models this represents the base component before usage or tiered calculations.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can upgrade from this bundle to higher-tier offerings without penalty (True) or if upgrade restrictions apply (False). Used in customer lifecycle management and upsell campaigns.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPricePlanId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price Plan Id' ;
    rdfs:comment 'Reference to the price plan that replaces this plan when it is retired or obsoleted. Null if no replacement plan exists. Supports migration path tracking.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricePlan .

ind:advancePaymentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Required Flag' ;
    rdfs:comment 'Indicates whether payment must be collected in advance before service activation (true) or billed in arrears after service delivery (false). Common for prepaid vs postpaid models.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Identifier of the user who approved this price plan for activation. Null if not yet approved. Supports audit trail and governance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'The base price amount for this price plan before any discounts, surcharges, or taxes. For flat rate plans this is the fixed charge; for tiered/volume plans this is the starting tier price.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible Flag' ;
    rdfs:comment 'Indicates whether this price plan can be included in product bundles or multi-service packages (true) or must be purchased standalone (false).' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Identifier of the user or system that created this price plan record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedQuantity rdf:type rdf:Property ;
    rdfs:label 'Included Quantity' ;
    rdfs:comment 'The quantity of units included in the base price before overage charges apply. For example, 50GB of data included in a mobile plan. Null if plan does not include a bundled quantity.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Identifier of the user or system that last modified this price plan record. Supports change tracking and accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum charge cap for this price plan within the billing period. Charges will not exceed this amount even if usage or events would normally result in higher charges. Null if no cap applies.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum spending commitment required under this price plan within the billing period. Customer must pay at least this amount regardless of actual usage. Null if no minimum commitment applies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRate rdf:type rdf:Property ;
    rdfs:label 'Overage Rate' ;
    rdfs:comment 'The per-unit charge applied when usage exceeds the included quantity. For example, $0.10 per GB over the included data allowance. Null if no overage charges apply.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePlanCode rdf:type rdf:Property ;
    rdfs:label 'Price Plan Code' ;
    rdfs:comment 'External business identifier for the price plan used in product catalogs and billing systems. Unique code assigned by product management.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePlanDescription rdf:type rdf:Property ;
    rdfs:label 'Price Plan Description' ;
    rdfs:comment 'Detailed description of the price plan including what it covers, applicable services, and any special conditions or restrictions.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePlanName rdf:type rdf:Property ;
    rdfs:label 'Price Plan Name' ;
    rdfs:comment 'Human-readable name of the price plan displayed to customers and used in marketing materials.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelType rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Type' ;
    rdfs:comment 'The pricing structure model applied to this plan. Flat rate for fixed charges, tiered for step-based pricing, volume-based for quantity discounts, usage-based for consumption charges, event-based for transaction charges, or hybrid for combinations.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'The date when promotional pricing or terms expire and standard pricing takes effect. Null for non-promotional plans or promotions without a defined end date.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationPolicy rdf:type rdf:Property ;
    rdfs:label 'Proration Policy' ;
    rdfs:comment 'Policy for prorating charges when service starts or ends mid-billing cycle. Full period charges the entire amount, daily proration calculates based on days used, no proration means no refund or partial charge, custom follows specific business rules.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosTier rdf:type rdf:Property ;
    rdfs:label 'Qos Tier' ;
    rdfs:comment 'The Quality of Service tier associated with this price plan defining network priority, bandwidth guarantees, latency targets, and service level commitments. Premium offers highest priority and guarantees, best effort offers no guarantees.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingGroup rdf:type rdf:Property ;
    rdfs:label 'Rating Group' ;
    rdfs:comment 'Classification group used by the rating engine to apply appropriate charging rules and tariffs. Used in real-time charging systems for CDR (Call Detail Record) processing and usage rating.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the base price amount includes taxes (true) or taxes are added on top (false). Critical for pricing display and billing calculation.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tieredPricingStructure rdf:type rdf:Property ;
    rdfs:label 'Tiered Pricing Structure' ;
    rdfs:comment 'JSON or structured text defining the tier breakpoints and rates for tiered pricing models. Specifies quantity ranges and corresponding unit prices for each tier. Null for non-tiered plans.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit of measurement for usage-based or volume-based pricing (e.g., GB for data, minutes for voice, SMS for messaging, Mbps for bandwidth, each for devices). Null for non-usage-based plans.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this promotional offer is automatically applied to eligible customers without requiring a promo code entry. True if auto-applied, False if customer must enter promo code.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusDataAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Data Amount' ;
    rdfs:comment 'Additional data allowance provided as part of the promotional offer, measured in the unit specified by bonus_data_unit. Applicable for mobile and broadband promotions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusDataUnit rdf:type rdf:Property ;
    rdfs:label 'Bonus Data Unit' ;
    rdfs:comment 'Unit of measure for bonus data amount: GB (gigabytes), MB (megabytes), or TB (terabytes).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for this promotional offer in the currency specified by discount_currency_code. Used to track promotional spending and prevent budget overruns.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetConsumed rdf:type rdf:Property ;
    rdfs:label 'Budget Consumed' ;
    rdfs:comment 'Amount of promotional budget consumed to date through customer redemptions. Updated as offers are redeemed. Used for budget tracking and offer performance monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Discount Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for fixed amount discounts (e.g., USD, EUR, GBP). Null for percentage-based discounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. For percentage discounts, represents the percentage (e.g., 25.00 for 25% off). For fixed amount discounts, represents the currency amount. Interpretation depends on discount_type.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityChannel rdf:type rdf:Property ;
    rdfs:label 'Eligibility Channel' ;
    rdfs:comment 'Sales or service channel(s) through which this offer can be redeemed (e.g., online, retail_store, telesales, partner, mobile_app). Comma-separated list if multiple channels are eligible. Null if no channel restriction.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCustomerType rdf:type rdf:Property ;
    rdfs:label 'Eligibility Customer Type' ;
    rdfs:comment 'Customer type eligible for this promotional offer: new (new customers only), existing (current customers only), churned (win-back for former customers), or all (no customer type restriction).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityGeographicScope rdf:type rdf:Property ;
    rdfs:label 'Eligibility Geographic Scope' ;
    rdfs:comment 'Geographic region(s) where this promotional offer is valid. Can be country codes (ISO 3166-1 alpha-3), state/province codes, or region identifiers. Comma-separated list if multiple regions. Null if no geographic restriction.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityProductCategory rdf:type rdf:Property ;
    rdfs:label 'Eligibility Product Category' ;
    rdfs:comment 'Product category or categories to which this promotional offer applies (e.g., mobile_postpaid, fiber_broadband, iptv, voip, sd_wan). Comma-separated list if applicable to multiple categories. Null if offer applies to all products.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTrialDuration rdf:type rdf:Property ;
    rdfs:label 'Free Trial Duration' ;
    rdfs:comment 'Length of the free trial period measured in the unit specified by free_trial_unit. Applicable for free trial promotional offers.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeTrialUnit rdf:type rdf:Property ;
    rdfs:label 'Free Trial Unit' ;
    rdfs:comment 'Unit of measure for free trial duration: days, months, or billing_cycles.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingMessage rdf:type rdf:Property ;
    rdfs:label 'Marketing Message' ;
    rdfs:comment 'Short marketing message or tagline used to promote this offer in customer-facing materials, advertisements, and digital channels.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Count' ;
    rdfs:comment 'Maximum number of times this promotional offer can be redeemed across all customers. Used to cap total offer usage for budget control. Null if unlimited redemptions allowed.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Period' ;
    rdfs:comment 'Minimum contract commitment period required to qualify for this promotional offer, measured in months. Null if no commitment required.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking used to determine which promotional offer to apply when multiple offers are eligible and stackable_flag is False. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCategory rdf:type rdf:Property ;
    rdfs:label 'Promo Category' ;
    rdfs:comment 'Category of promotional benefit provided: discount (percentage or fixed amount off), free_trial (service at no charge for period), bonus_data (additional data allowance), device_subsidy (reduced device cost), bundle (package deal), or waived_fee (activation/installation fee waived).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Unique alphanumeric code that customers use to redeem the promotional offer. Used in order entry, self-service portals, and customer service systems.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoDescription rdf:type rdf:Property ;
    rdfs:label 'Promo Description' ;
    rdfs:comment 'Detailed description of the promotional offer including terms, benefits, and conditions. Used in marketing materials and customer communications.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoName rdf:type rdf:Property ;
    rdfs:label 'Promo Name' ;
    rdfs:comment 'Marketing name of the promotional offer displayed to customers and used in campaign materials.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoType rdf:type rdf:Property ;
    rdfs:label 'Promo Type' ;
    rdfs:comment 'Classification of the promotional offer based on its strategic purpose: acquisition (new customer), retention (existing customer), win-back (churned customer), seasonal (holiday/event-based), loyalty (reward program), or referral (customer referral incentive).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this promotional offer. Typically 1 for most offers. Null if no per-customer limit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promotional offer can be combined (stacked) with other promotional offers. True if stackable, False if mutually exclusive with other offers.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpuImpact rdf:type rdf:Property ;
    rdfs:label 'Target Arpu Impact' ;
    rdfs:comment 'Projected impact on Average Revenue Per User (ARPU) from this promotional offer, expressed as a currency amount. Negative values indicate expected ARPU reduction during promo period. Used for financial planning and offer ROI analysis.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions governing the promotional offer including restrictions, disclaimers, and fine print. Used for regulatory compliance and customer disclosure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or identifier of the person who created this promotional offer record in the product catalog system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceQuantity rdf:type rdf:Property ;
    rdfs:label 'Allowance Quantity' ;
    rdfs:comment 'Numeric quantity of the usage allowance. Defines the included amount (e.g., 50 GB data, 1000 voice minutes, unlimited). Use -1 or special value for unlimited allowances.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Type of usage allowance for mobile and roaming products. Specifies the consumption category: data, voice minutes, SMS, roaming data, roaming voice, or international minutes. Applicable only to usage allowance specifications.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burstBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Burst Bandwidth Mbps' ;
    rdfs:comment 'Burstable bandwidth in megabits per second for enterprise circuits. Defines the maximum temporary throughput allowed above committed rate (e.g., 100 Mbps committed, 200 Mbps burst).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Name of the technical characteristic being specified. Extensible name-value pair key for product capabilities (e.g., data_allowance_gb, download_speed_mbps, channel_count, sla_uptime_percent).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicValue rdf:type rdf:Property ;
    rdfs:label 'Characteristic Value' ;
    rdfs:comment 'Value of the technical characteristic. Stores the specification parameter value as string to support numeric, boolean, and enumerated values (e.g., 50, unlimited, true, gold_tier).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous video streams allowed for IPTV and OTT services. Defines the multi-device viewing limit (e.g., 2 streams, 4 streams, unlimited).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dvrHours rdf:type rdf:Property ;
    rdfs:label 'Dvr Hours' ;
    rdfs:comment 'Cloud DVR storage capacity in hours of recording for IPTV services. Defines the network-based recording allowance (e.g., 50 hours, 200 hours, unlimited).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fairUseLimitGb rdf:type rdf:Property ;
    rdfs:label 'Fair Use Limit Gb' ;
    rdfs:comment 'Fair use policy limit in gigabytes for unlimited plans. Defines the threshold beyond which network management policies may apply (e.g., deprioritization, throttling). Regulatory compliance for unlimited offerings.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRolloverEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rollover Enabled' ;
    rdfs:comment 'Flag indicating whether unused allowance rolls over to the next billing cycle. True for rollover data plans. False for use-it-or-lose-it allowances.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShared rdf:type rdf:Property ;
    rdfs:label 'Is Shared' ;
    rdfs:comment 'Flag indicating whether the allowance is shared across multiple subscribers or devices. True for family plans and multi-device data pools. False for individual allowances.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnlimited rdf:type rdf:Property ;
    rdfs:label 'Is Unlimited' ;
    rdfs:comment 'Flag indicating whether the allowance is unlimited. True for unlimited data, voice, or SMS plans. False for metered allowances. Drives billing and network management policies.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Maximum network latency in milliseconds guaranteed by the service. Defines the round-trip time SLA for latency-sensitive applications (e.g., 10ms for 5G URLLC, 50ms for broadband).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User or system identifier that last modified the product specification record. Audit trail for specification change accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttrHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Hours' ;
    rdfs:comment 'Guaranteed mean time to repair in hours per SLA. Defines the maximum average time to restore service after a fault (e.g., 4 hours, 8 hours, 24 hours). Applicable to enterprise and premium consumer products.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overagePolicy rdf:type rdf:Property ;
    rdfs:label 'Overage Policy' ;
    rdfs:comment 'Policy applied when usage exceeds allowance. Defines the enforcement action: block (hard cap), throttle (reduce speed), charge (pay-per-use), rollover (carry forward unused), or unlimited (no cap).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosClass rdf:type rdf:Property ;
    rdfs:label 'Qos Class' ;
    rdfs:comment 'Quality of Service tier assigned to the product. Defines the traffic prioritization and performance guarantees: best effort (no guarantee), guaranteed (SLA-backed), premium (high priority), or mission critical (highest priority).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetFrequency rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency' ;
    rdfs:comment 'Frequency at which usage allowances reset. Defines the billing cycle for allowance renewal: monthly (standard), daily (roaming fair-use), weekly, annual, one-time (non-recurring), or never (lifetime).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingDataAllowanceGb rdf:type rdf:Property ;
    rdfs:label 'Roaming Data Allowance Gb' ;
    rdfs:comment 'Data allowance in gigabytes available for roaming usage. Defines the fair-use limit for international data consumption. May differ from domestic allowance.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingZone rdf:type rdf:Property ;
    rdfs:label 'Roaming Zone' ;
    rdfs:comment 'Geographic roaming zone configuration for mobile products. Defines the international roaming coverage area (e.g., Zone 1 Europe, Zone 2 Americas, Global). Maps to carrier roaming agreements.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Guaranteed service availability percentage per SLA. Defines the contractual uptime commitment (e.g., 99.9%, 99.99%, 99.999% for carrier-grade). Applicable to enterprise SD-WAN, MPLS, and premium broadband.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specCategory rdf:type rdf:Property ;
    rdfs:label 'Spec Category' ;
    rdfs:comment 'Functional category of the specification parameter. Groups specifications by purpose: usage allowance, network capability, service feature, QoS parameter, device capability, or pricing rule.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specDescription rdf:type rdf:Property ;
    rdfs:label 'Spec Description' ;
    rdfs:comment 'Detailed description of the product specification. Provides business context and technical details for the characteristic definition. Used for product catalog documentation and customer communication.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name of the product specification. Identifies the technical characteristic being defined (e.g., Data Allowance, Speed Tier, Channel Package).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of the product specification. Defines availability for provisioning: draft (under development), active (available), deprecated (phasing out), retired (no longer available).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specType rdf:type rdf:Property ;
    rdfs:label 'Spec Type' ;
    rdfs:comment 'Category of product specification defining the service domain. Determines which technical parameters are applicable (mobile, broadband, IPTV, VoIP, SD-WAN, MPLS, device, roaming, add-on). [ENUM-REF-CANDIDATE: mobile|broadband|iptv|voip|sdwan|mpls|device|roaming|addon — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Throttle Speed Mbps' ;
    rdfs:comment 'Reduced data speed in megabits per second applied after allowance exhaustion. Applicable when overage_policy is throttle. Defines the post-allowance QoS degradation (e.g., 128 Kbps, 1 Mbps).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueType rdf:type rdf:Property ;
    rdfs:label 'Value Type' ;
    rdfs:comment 'Data type of the characteristic value. Indicates how to interpret the characteristic_value field: numeric (quantities), boolean (flags), string (text), enumeration (predefined list), or range (min-max).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Unique identifier for the eligibility rule. Primary key for the eligibility rule entity.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of sales and service channels where this eligibility rule applies. Examples include retail stores, online web portal, mobile app, telesales, partner channels, enterprise direct sales, Mobile Virtual Network Operator (MVNO) channels. Enables channel-specific eligibility logic for omnichannel product offerings.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Comma-separated list of regulatory or compliance frameworks that this eligibility rule supports or enforces. Examples include Federal Communications Commission (FCC) regulations, General Data Protection Regulation (GDPR), age verification requirements, Know Your Customer (KYC) rules, or industry-specific mandates from International Telecommunication Union (ITU), 3rd Generation Partnership Project (3GPP), or GSM Association (GSMA).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'Defines how often or under what conditions this eligibility rule is evaluated. Real-time evaluation occurs during order capture; periodic evaluation supports batch eligibility checks for existing customers; event-triggered evaluation responds to specific business events such as contract renewal, credit score update, or network upgrade.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'The unique identifier for this eligibility rule in external or upstream systems such as Netcracker Product Catalog, Salesforce CRM, or Oracle Communications Order and Service Management (OSM). Used for cross-system reconciliation, data integration, and troubleshooting.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Comma-separated list of geographic areas (countries, regions, states, postal codes, network coverage zones) where this eligibility rule applies. Uses ISO 3166-1 alpha-3 country codes and internal geographic identifiers. Supports location-based eligibility for Fiber to the Home (FTTH), 5G New Radio (5G NR), and regional promotional offers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this eligibility rule must be satisfied (true) or is optional/advisory (false). Mandatory rules block order submission if not met; optional rules may generate warnings but allow order progression. Supports flexible eligibility frameworks for complex product bundles and promotional offers.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverridable rdf:type rdf:Property ;
    rdfs:label 'Is Overridable' ;
    rdfs:comment 'Indicates whether authorized users (e.g., sales managers, retention specialists) can manually override this eligibility rule during order capture. Supports exception handling for high-value customers, retention scenarios, and special business cases while maintaining audit trail of overrides.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logicalOperator rdf:type rdf:Property ;
    rdfs:label 'Logical Operator' ;
    rdfs:comment 'Defines how this rule combines with other rules in the same eligibility rule set. AND requires all rules to be satisfied; OR requires at least one rule to be satisfied. Used to construct complex multi-condition eligibility expressions for bundled offerings, promotional campaigns, and segment-specific products.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authorization Level' ;
    rdfs:comment 'The minimum user role or authorization level required to override this eligibility rule. Enforces governance and controls around exception handling. Integrates with Customer Relationship Management (CRM) and Identity and Access Management (IAM) systems to validate user permissions during order capture.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Comma-separated list of product categories to which this eligibility rule applies. Examples include mobile plans, broadband packages, Internet Protocol Television (IPTV), Over-The-Top (OTT) bundles, Voice over Internet Protocol (VoIP) offerings, Software-Defined Wide Area Network (SD-WAN), Multiprotocol Label Switching (MPLS), devices, accessories, value-added services. Enables category-level eligibility management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleAttribute rdf:type rdf:Property ;
    rdfs:label 'Rule Attribute' ;
    rdfs:comment 'The specific customer, account, or context attribute that this rule evaluates. Examples include customer segment code, account type identifier, service address postal code, existing subscribed product identifier, credit score class, contract start date, device model identifier, network technology availability (Long-Term Evolution (LTE), 5G New Radio (5G NR)), customer age, or business employee count.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of the eligibility rule, including its purpose, business rationale, and any special conditions or exceptions. Used for documentation, training, and audit purposes within product management and compliance teams.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or label for the eligibility rule, used for identification and reporting purposes within Business Support Systems (BSS) and Customer Relationship Management (CRM) systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOperator rdf:type rdf:Property ;
    rdfs:label 'Rule Operator' ;
    rdfs:comment 'The logical comparison operator used to evaluate the rule condition. Determines how the rule value is compared against customer or account attributes during order capture and service provisioning workflows in Operations Support Systems (OSS) and Business Support Systems (BSS). [ENUM-REF-CANDIDATE: equals|not_equals|in|not_in|greater_than|less_than|greater_than_or_equal|less_than_or_equal|contains|not_contains|between — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSequence rdf:type rdf:Property ;
    rdfs:label 'Rule Sequence' ;
    rdfs:comment 'The execution order or priority of this rule within the eligibility rule set. Lower numbers are evaluated first. Determines the sequence in which rules are applied during product eligibility validation in order management and service activation workflows.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rule Source System' ;
    rdfs:comment 'The source system or module that originated or manages this eligibility rule. Examples include Netcracker Product Catalog, Salesforce CRM, Oracle Communications Order and Service Management (OSM), custom rule engine. Used for data lineage, troubleshooting, and system integration mapping.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'The category or dimension of eligibility being evaluated. Defines the business domain of the rule such as customer segmentation (Business-to-Consumer (B2C), Business-to-Business (B2B), Mobile Virtual Network Operator (MVNO)), account classification, geographic restrictions, product dependencies, credit scoring, contract duration requirements, Customer Premises Equipment (CPE) compatibility, Radio Access Network (RAN) coverage, regulatory age limits, or enterprise size thresholds. [ENUM-REF-CANDIDATE: customer_segment|account_type|geographic_area|existing_product|credit_class|contract_tenure|device_compatibility|network_coverage|age_restriction|business_size — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleValue rdf:type rdf:Property ;
    rdfs:label 'Rule Value' ;
    rdfs:comment 'The target value or set of values against which the customer or account attribute is compared. May contain single values, comma-separated lists, numeric thresholds, geographic codes (ISO 3166-1 alpha-3), product codes, credit class identifiers, or tenure periods in months. Supports complex eligibility logic for multi-segment offerings.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier for this eligibility rule. Supports rule versioning and change management for product catalog governance. Enables tracking of rule evolution over time and rollback capabilities for Business Support Systems (BSS) configuration changes.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of business tags or labels for categorization, search, and filtering of eligibility rules. Examples include promotional campaign identifiers, regulatory compliance markers, product launch wave identifiers, or business initiative codes. Supports flexible taxonomy and metadata management.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryCapacityMah rdf:type rdf:Property ;
    rdfs:label 'Battery Capacity Mah' ;
    rdfs:comment 'Battery capacity in milliampere-hours (mAh) for portable devices. Null for powered CPE (Customer Premises Equipment) and network infrastructure devices.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorVariants rdf:type rdf:Property ;
    rdfs:label 'Color Variants' ;
    rdfs:comment 'Comma-separated list of available color options for the device model (e.g., Black, White, Blue, Titanium). Used for inventory management and customer selection.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of regulatory compliance certifications (e.g., FCC, CE, RoHS, ENERGY STAR, PTCRB). Required for legal sale and operation in different jurisdictions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCategory rdf:type rdf:Property ;
    rdfs:label 'Device Category' ;
    rdfs:comment 'Classification of the device type. CPE (Customer Premises Equipment) includes routers and modems; ONT (Optical Network Terminal) for FTTH (Fiber to the Home); OLT (Optical Line Terminal) for network infrastructure; STB (Set-Top Box) for IPTV (Internet Protocol Television) services. [ENUM-REF-CANDIDATE: smartphone|tablet|feature_phone|cpe_router|cpe_modem|ont|olt|stb|iot_device|wearable — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Device Subcategory' ;
    rdfs:comment 'Detailed subcategory within the device category for finer classification (e.g., flagship smartphone, budget smartphone, Wi-Fi 6 router, GPON ONT, 4K STB).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical dimensions of the device in millimeters, typically formatted as length x width x height (e.g., 146.7 x 71.5 x 7.8 mm). Used for packaging and display specifications.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the device model was discontinued from active sales. Null if still available. Used for inventory planning and customer migration strategies.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayResolution rdf:type rdf:Property ;
    rdfs:label 'Display Resolution' ;
    rdfs:comment 'Screen resolution in pixels (e.g., 1920x1080, 2560x1440, 3840x2160). Relevant for smartphones, tablets, and content consumption quality for IPTV and OTT services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySizeInches rdf:type rdf:Property ;
    rdfs:label 'Display Size Inches' ;
    rdfs:comment 'Screen diagonal size in inches for devices with displays (smartphones, tablets). Null for non-display devices like routers and ONT.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drmSupport rdf:type rdf:Property ;
    rdfs:label 'Drm Support' ;
    rdfs:comment 'Comma-separated list of supported DRM (Digital Rights Management) systems (e.g., Widevine, FairPlay, PlayReady). Required for premium content protection in OTT and IPTV services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualSimSupport rdf:type rdf:Property ;
    rdfs:label 'Dual Sim Support' ;
    rdfs:comment 'Indicates whether the device supports dual SIM functionality, allowing two active subscriptions simultaneously. Important for enterprise customers and international travelers.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date when manufacturer support, software updates, and warranty services end for this device model. Critical for SLA (Service Level Agreement) management and customer communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esimCapable rdf:type rdf:Property ;
    rdfs:label 'Esim Capable' ;
    rdfs:comment 'Indicates whether the device supports eSIM (Embedded SIM) technology, enabling remote SIM provisioning without physical SIM card. Critical for digital service activation and MNP (Mobile Number Portability).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethernetPorts rdf:type rdf:Property ;
    rdfs:label 'Ethernet Ports' ;
    rdfs:comment 'Number of physical Ethernet ports available on CPE devices (routers, modems, ONT). Relevant for enterprise SD-WAN (Software-Defined Wide Area Network) and MPLS (Multiprotocol Label Switching) connectivity.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyBands rdf:type rdf:Property ;
    rdfs:label 'Frequency Bands' ;
    rdfs:comment 'Comma-separated list of supported radio frequency bands for cellular connectivity (e.g., Band 1, Band 3, Band 7, Band 28, n78, n79 for 5G NR). Essential for RAN (Radio Access Network) compatibility and roaming.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled' ;
    rdfs:comment 'Indicates whether the device has GPS (Global Positioning System) or GNSS (Global Navigation Satellite System) capability. Used for location-based services and emergency services (E911).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imeiRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Imei Range End' ;
    rdfs:comment 'Ending IMEI number in the allocated range for this device model. Used with imei_range_start to validate device authenticity and prevent cloning.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imeiRangeStart rdf:type rdf:Property ;
    rdfs:label 'Imei Range Start' ;
    rdfs:comment 'Starting IMEI (International Mobile Equipment Identity) number in the allocated range for this device model. Used for device registration, activation, and fraud prevention in HLR (Home Location Register) and HSS (Home Subscriber Server).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactures the device (e.g., Apple, Samsung, Nokia, Huawei, Cisco, Ericsson).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Commercial marketing name of the device model as presented to customers (e.g., iPhone 14 Pro, Galaxy S23 Ultra, Nokia ONT G-010S-A).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer-assigned model number or SKU (Stock Keeping Unit) used for inventory and catalog management. Unique identifier within manufacturer\'s product line.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfcEnabled rdf:type rdf:Property ;
    rdfs:label 'Nfc Enabled' ;
    rdfs:comment 'Indicates whether the device supports NFC (Near Field Communication) for contactless payments and data exchange. Relevant for mobile payment services and digital wallet integration.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system platform and version running on the device (e.g., iOS 17, Android 14, HarmonyOS, proprietary firmware). Impacts application compatibility and OTT (Over-The-Top) service delivery.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorChipset rdf:type rdf:Property ;
    rdfs:label 'Processor Chipset' ;
    rdfs:comment 'Processor or chipset model powering the device (e.g., Apple A17 Pro, Qualcomm Snapdragon 8 Gen 3, MediaTek Dimensity 9300). Indicates device performance tier.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ramCapacityGb rdf:type rdf:Property ;
    rdfs:label 'Ram Capacity Gb' ;
    rdfs:comment 'RAM memory capacity in gigabytes. Impacts device performance and ability to run advanced applications and services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Manufacturer suggested retail price (MSRP) or standard retail price in the base currency. Used for pricing strategies, promotional offers, and revenue forecasting (ARPU - Average Revenue Per User calculations).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sarValue rdf:type rdf:Property ;
    rdfs:label 'Sar Value' ;
    rdfs:comment 'Specific Absorption Rate (SAR) value in watts per kilogram (W/kg), measuring radio frequency energy absorption. Required for regulatory compliance (FCC, ICNIRP guidelines) for mobile devices.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityGb rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Gb' ;
    rdfs:comment 'Internal storage capacity of the device in gigabytes. Relevant for smartphones, tablets, and STB (Set-Top Box) devices with local recording capability.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Internal code identifying the primary supplier or distributor for this device model. Used for procurement, inventory management, and supply chain tracking in ERP (Enterprise Resource Planning) systems.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacCode rdf:type rdf:Property ;
    rdfs:label 'Tac Code' ;
    rdfs:comment '8-digit Type Allocation Code forming the first 8 digits of the IMEI. Uniquely identifies the device model and manufacturer. Used by network systems for device identification and policy enforcement.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologySupport rdf:type rdf:Property ;
    rdfs:label 'Technology Support' ;
    rdfs:comment 'Comma-separated list of supported network technologies and standards (e.g., 4G LTE, 5G NR, VoLTE, Wi-Fi 6, Wi-Fi 6E, GPON, Bluetooth 5.2). Critical for network compatibility and service provisioning.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usbPorts rdf:type rdf:Property ;
    rdfs:label 'Usb Ports' ;
    rdfs:comment 'Number of USB ports available on the device. Used for charging, data transfer, and peripheral connectivity.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCodecSupport rdf:type rdf:Property ;
    rdfs:label 'Video Codec Support' ;
    rdfs:comment 'Comma-separated list of supported video codecs (e.g., H.264, H.265/HEVC, VP9, AV1). Essential for IPTV, OTT content delivery, and video call quality.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voipCapable rdf:type rdf:Property ;
    rdfs:label 'Voip Capable' ;
    rdfs:comment 'Indicates whether the device supports VoIP (Voice over Internet Protocol) functionality. Critical for IMS (IP Multimedia Subsystem) service delivery and VoLTE (Voice over LTE) compatibility.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Standard manufacturer warranty period in months. Used for service provisioning, insurance offerings, and customer support planning.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterResistanceRating rdf:type rdf:Property ;
    rdfs:label 'Water Resistance Rating' ;
    rdfs:comment 'IP (Ingress Protection) rating for water and dust resistance (e.g., IP67, IP68). Indicates device durability and suitability for outdoor or harsh environments.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGrams rdf:type rdf:Property ;
    rdfs:label 'Weight Grams' ;
    rdfs:comment 'Physical weight of the device in grams. Relevant for logistics, shipping cost calculation, and customer information.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleCost rdf:type rdf:Property ;
    rdfs:label 'Wholesale Cost' ;
    rdfs:comment 'Wholesale acquisition cost from manufacturer or distributor. Used for margin analysis, CAPEX (Capital Expenditure) planning, and profitability calculations (EBITDA - Earnings Before Interest Taxes Depreciation and Amortization).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wifiStandard rdf:type rdf:Property ;
    rdfs:label 'Wifi Standard' ;
    rdfs:comment 'Supported Wi-Fi standard (e.g., Wi-Fi 5 (802.11ac), Wi-Fi 6 (802.11ax), Wi-Fi 6E). Critical for CPE devices and home broadband service quality (QoS - Quality of Service).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseOfferingId rdf:type rdf:Property ;
    rdfs:label 'Base Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: An addon attaches to a base offering (e.g., a data top-up addon is available on the Unlimited Mobile offering). The prefix \'base_\' distinguishes this FK from any future offering references and clarifi' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:activationMethod rdf:type rdf:Property ;
    rdfs:label 'Activation Method' ;
    rdfs:comment 'Method by which the add-on is activated on the customer subscription. Instant: immediate activation; Scheduled: activation at specified date/time; Manual approval: requires CSR or system approval; Provisioning required: requires network provisioning workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonCategory rdf:type rdf:Property ;
    rdfs:label 'Addon Category' ;
    rdfs:comment 'Classification of the add-on product type. Determines the functional category and business rules applicable to the add-on. [ENUM-REF-CANDIDATE: data_topup|voice_pack|sms_pack|international_calling|roaming|premium_content|cloud_storage|security|static_ip|device_insurance — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonCode rdf:type rdf:Property ;
    rdfs:label 'Addon Code' ;
    rdfs:comment 'Unique business identifier code for the add-on product used in product catalog and billing systems. Examples: DATA_5GB, INTL_CALL_100, PREMIUM_SPORTS.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonDescription rdf:type rdf:Property ;
    rdfs:label 'Addon Description' ;
    rdfs:comment 'Detailed business description of the add-on product, including features, benefits, and usage terms. Used for customer-facing documentation and sales materials.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonName rdf:type rdf:Property ;
    rdfs:label 'Addon Name' ;
    rdfs:comment 'Human-readable name of the add-on product displayed to customers and in product catalogs.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonType rdf:type rdf:Property ;
    rdfs:label 'Addon Type' ;
    rdfs:comment 'Billing model type for the add-on. One-time: single charge; Recurring: periodic subscription; Usage-based: pay-per-use; Hybrid: combination of recurring and usage.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationMethod rdf:type rdf:Property ;
    rdfs:label 'Deactivation Method' ;
    rdfs:comment 'Method by which the add-on is deactivated or removed from the customer subscription. Instant: immediate removal; End of period: deactivation at billing cycle end; Manual: requires CSR intervention; Grace period: deactivation after notice period.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalProductCode rdf:type rdf:Property ;
    rdfs:label 'External Product Code' ;
    rdfs:comment 'Identifier for the add-on product in external systems such as partner catalogs, wholesale platforms, or third-party marketplaces. Used for system integration and cross-reference.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQuantityPerSubscription rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Subscription' ;
    rdfs:comment 'Maximum number of instances of this add-on that can be attached to a single customer subscription. Null indicates no limit. Example: customer can purchase up to 5 data top-up add-ons per month.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minQuantityPerSubscription rdf:type rdf:Property ;
    rdfs:label 'Min Quantity Per Subscription' ;
    rdfs:comment 'Minimum number of instances of this add-on required when attached to a subscription. Typically 1 or null. Used for bundled add-ons with minimum purchase requirements.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Unique code identifying the promotional campaign associated with this add-on. Null if not promotional. Used for tracking campaign performance and eligibility validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed Flag' ;
    rdfs:comment 'Indicates whether the add-on charge is prorated when activated or deactivated mid-billing cycle. True: charge is prorated; False: full charge applies regardless of activation date.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaUnit rdf:type rdf:Property ;
    rdfs:label 'Quota Unit' ;
    rdfs:comment 'Unit of measure for the quota value. Defines what the quota_value represents. Examples: GB for data, minutes for voice, SMS for messaging, channels for IPTV. [ENUM-REF-CANDIDATE: GB|MB|minutes|SMS|channels|users|GB_storage|static_IP|incidents — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaValue rdf:type rdf:Property ;
    rdfs:label 'Quota Value' ;
    rdfs:comment 'Numeric value representing the allowance or quota provided by the add-on. Examples: 5 GB data, 100 international minutes, 500 SMS. Used in conjunction with quota_unit.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Accounting rule for revenue recognition of the add-on charges. Immediate: recognize at sale; Deferred: recognize over service period; Prorated: recognize proportionally; Usage-based: recognize as consumed.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Allowed Flag' ;
    rdfs:comment 'Indicates whether unused quota from the current period can roll over to the next period. True: unused quota carries forward; False: quota expires at period end.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Quality of Service (QoS) tier or Service Level Agreement (SLA) class associated with the add-on. Determines priority, support level, and performance guarantees.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief summary of the add-on product for display in mobile apps, web portals, and point-of-sale systems. Typically 1-2 sentences.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Trial Period Days' ;
    rdfs:comment 'Number of days for which the add-on is offered as a free trial before billing begins. Null if no trial period is available. Common values: 7, 14, 30 days.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityPeriodUnit rdf:type rdf:Property ;
    rdfs:label 'Validity Period Unit' ;
    rdfs:comment 'Unit of time for the validity period. Examples: 30 days, 1 month, 1 year. Perpetual indicates no expiration.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Validity Period Value' ;
    rdfs:comment 'Numeric value representing the duration for which the add-on remains active after activation. Used in conjunction with validity_period_unit. Null for perpetual add-ons.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeDepotId rdf:type rdf:Property ;
    rdfs:label 'Home Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: Technician has a home_depot_code (STRING) that denotes their base depot for dispatch and staging. Normalizing this to a FK home_depot_id -> workforce.depot.depot_id eliminates the string code and esta' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:subcontractingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Telecom field workforces routinely include subcontracted technicians from partner companies. Linking technician to the supplying partner is essential for subcontractor billing reconciliation, complian' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:supervisorTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Technician Id' ;
    rdfs:comment 'Identifier of the direct supervisor or field manager responsible for this technician\'s performance management and work assignment.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:attendanceRate rdf:type rdf:Property ;
    rdfs:label 'Attendance Rate' ;
    rdfs:comment 'Percentage of scheduled work days attended. Used for reliability assessment and workforce planning.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date of the most recent background check or security clearance verification. Required for access to customer premises and sensitive network infrastructure.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Aggregate status of required industry certifications (e.g., fiber optic, electrical safety, tower climbing). Drives dispatch eligibility and compliance reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Current Performance Rating' ;
    rdfs:comment 'Most recent overall performance evaluation rating from the latest review cycle. Used for promotion decisions and workforce optimization.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Average customer satisfaction rating (0-100 scale) from post-service surveys. Key indicator of service quality and technician soft skills.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugTestDate rdf:type rdf:Property ;
    rdfs:label 'Drug Test Date' ;
    rdfs:comment 'Date of the most recent drug screening test. Required for safety-sensitive positions and compliance with Department of Transportation (DOT) regulations for commercial drivers.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the designated emergency contact person for field safety incidents and urgent notifications.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the designated emergency contact for field safety incidents and urgent notifications.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment lifecycle status indicating availability for work assignment and dispatch.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment relationship: full-time employee, part-time employee, contractor, Mobile Virtual Network Operator (MVNO) partner technician, or temporary worker.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstTimeFixRate rdf:type rdf:Property ;
    rdfs:label 'First Time Fix Rate' ;
    rdfs:comment 'Percentage of work orders resolved on the first visit without requiring return trips. Key performance indicator (KPI) for technician efficiency and customer satisfaction.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether the technician is currently on a formal performance improvement plan. Used for HR compliance and management escalation.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average time in minutes to complete repair work orders. Critical KPI for workforce productivity and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Score' ;
    rdfs:comment 'Percentage score (0-100) representing adherence to safety protocols, personal protective equipment (PPE) usage, and incident-free work history. Critical for field workforce risk management.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceZone rdf:type rdf:Property ;
    rdfs:label 'Service Zone' ;
    rdfs:comment 'Geographic service zone or territory assignment for dispatch optimization and workload balancing.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Overall technical proficiency level used for work order assignment complexity matching and career progression tracking.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Rate' ;
    rdfs:comment 'Percentage of work orders completed within committed SLA timeframes. Critical for customer satisfaction and penalty avoidance.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolsKitCode rdf:type rdf:Property ;
    rdfs:label 'Tools Kit Code' ;
    rdfs:comment 'Identifier of the standard tools and equipment kit assigned to the technician. Used for inventory tracking and maintenance scheduling.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursYtd rdf:type rdf:Property ;
    rdfs:label 'Training Hours Ytd' ;
    rdfs:comment 'Total training and professional development hours completed in the current calendar year. Used for compliance reporting and skill development tracking.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Union Member Flag' ;
    rdfs:comment 'Indicates whether the technician is a member of a labor union. Affects scheduling rules, overtime policies, and grievance procedures.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Identifier of the company vehicle or fleet unit assigned to this technician for field operations and equipment transport.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrdersPerDay rdf:type rdf:Property ;
    rdfs:label 'Work Orders Per Day' ;
    rdfs:comment 'Average number of work orders completed per working day. Productivity metric used for capacity planning and workload balancing.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceClassification rdf:type rdf:Property ;
    rdfs:label 'Workforce Classification' ;
    rdfs:comment 'Technical specialization area: Radio Access Network (RAN), Fiber to the Home (FTTH), Gigabit Passive Optical Network (GPON), Customer Premises Equipment (CPE), fiber splicing, transport network, core network, or hybrid multi-skill. [ENUM-REF-CANDIDATE: ran|ftth|gpon|cpe|splicing|transport|core|hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillId rdf:type rdf:Property ;
    rdfs:label 'Skill Id' ;
    rdfs:comment 'Unique identifier for the technical skill in the workforce skill taxonomy. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Skill .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the external certification authority or vendor (e.g., Ericsson, Nokia, Fiber Optic Association, OSHA) if certification_required_flag is true.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Official name of the required certification (e.g., Ericsson Certified RAN Expert, Nokia NetAct Administrator, FOA CFOT).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether formal external certification is required to hold this skill (e.g., vendor certification for Ericsson RAN, Nokia NetAct, safety certifications).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchPriorityWeight rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority Weight' ;
    rdfs:comment 'Numeric weight used in Granite WFM dispatch algorithm to prioritize technicians with this skill for matching work orders (higher weight = higher priority).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of equipment or system this skill applies to (e.g., RAN Base Station, OLT, ONT, BNG, BRAS, IMS Core, HSS, CPE Router).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteSkills rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Skills' ;
    rdfs:comment 'Comma-separated list of skill codes that must be held before this skill can be acquired (e.g., basic safety certification required before advanced RAN work).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelCompetentDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Competent Definition' ;
    rdfs:comment 'Definition of competent proficiency level for this skill: ability to perform tasks independently with standard supervision and quality expectations.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelExpertDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Expert Definition' ;
    rdfs:comment 'Definition of expert proficiency level for this skill: advanced capabilities, ability to handle complex scenarios, mentor others, and perform quality assurance.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelTraineeDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Trainee Definition' ;
    rdfs:comment 'Definition of trainee proficiency level for this skill: expected capabilities, supervision requirements, and task limitations.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification events if recertification_required_flag is true.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether periodic recertification or reassessment is mandatory to maintain this skill.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this skill is subject to regulatory compliance requirements (e.g., FCC licensing, OSHA certification, state/local permits).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementSkillCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Skill Code' ;
    rdfs:comment 'Skill code of the replacement skill if this skill has been deprecated or obsoleted (e.g., LTE skill replaced by 5G NR skill).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this skill involves safety-critical work (e.g., tower climbing, high-voltage work, confined space entry) requiring additional safety protocols.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'High-level classification of the skill domain: RAN (Radio Access Network), Transport (MPLS, SD-WAN), Access (FTTH, GPON, DSLAM), Core (IMS, HSS, UDM), CPE (Customer Premises Equipment), Safety, Compliance, or Other. [ENUM-REF-CANDIDATE: RAN|Transport|Access|Core|CPE|Safety|Compliance|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillCode rdf:type rdf:Property ;
    rdfs:label 'Skill Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the skill, used in Granite WFM dispatch matching and work order assignment (e.g., FIBER-SPLICE, 5G-RAN-COMM, GPON-OLT-CFG).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillDescription rdf:type rdf:Property ;
    rdfs:label 'Skill Description' ;
    rdfs:comment 'Detailed description of the skill, including technical scope, typical tasks, and application context (e.g., \'Ability to perform single-mode and multi-mode fiber splicing, OTDR testing, and loss certification for trunk and distribution fiber networks\').' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Human-readable name of the technical skill (e.g., Fiber Splicing, 5G NR RAN Commissioning, GPON OLT Configuration, VoLTE IMS Troubleshooting).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillStatus rdf:type rdf:Property ;
    rdfs:label 'Skill Status' ;
    rdfs:comment 'Current lifecycle status of the skill in the taxonomy: Active (in use), Deprecated (being phased out), Obsolete (no longer used), Planned (future skill).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the skill category (e.g., Fiber Optics, 5G NR, LTE, VoLTE, IPTV, Broadband Gateway).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDomain rdf:type rdf:Property ;
    rdfs:label 'Technology Domain' ;
    rdfs:comment 'Specific technology or standard the skill applies to (e.g., 5G NR, LTE, VoLTE, GPON, FTTH, MPLS, SD-WAN, IMS, NFV, SDN).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Estimated number of training hours required to achieve competent proficiency level for this skill.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Number of months this skill remains valid before recertification or reassessment is required. Null if skill does not expire.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the equipment or software vendor if vendor_specific_flag is true (e.g., Ericsson, Nokia, Huawei, Cisco, Juniper).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Specific Flag' ;
    rdfs:comment 'Indicates whether this skill is specific to a particular equipment vendor (e.g., Ericsson RAN, Nokia NetAct, Huawei Transport) versus vendor-agnostic.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Work Order Type Applicability' ;
    rdfs:comment 'Comma-separated list of work order types this skill is applicable to (e.g., Installation, Maintenance, Repair, Commissioning, Decommissioning, Troubleshooting, Upgrade).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the workforce certification record. Primary key.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatingRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Mandating Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Specific workforce certifications are mandated by regulatory obligations (FCC tower climbing safety certification, state electrical licenses for fiber splicing, OSHA confined space entry certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to the scanned certificate document, digital badge, or credential stored in the document management system. Used for audit and verification purposes.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number or credential identifier issued by the certifying authority. This is the externally-known identifier for this specific certification instance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Level or grade of the certification indicating proficiency or seniority. Examples include Basic, Intermediate, Advanced, Expert, Level 1, Level 2, Journeyman, Master, or vendor-specific tier designations.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the certification is currently in compliance with all regulatory and company requirements. True indicates compliant; False indicates non-compliant (expired, suspended, or missing required renewals).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to obtain or renew the certification, including exam fees, training fees, and administrative costs. Used for workforce development budget tracking and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost amount. Examples include USD, EUR, GBP, CAD.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdHoursEarned rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Earned' ;
    rdfs:comment 'Number of Continuing Professional Development hours or Continuing Education Units (CEUs) earned through the training or certification process. Used for tracking professional development requirements and renewal eligibility.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the organization, regulatory body, or vendor that issued the certification. Examples include OSHA, BICSI, Ericsson, Nokia, FCC, NATE, or internal training departments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized code or abbreviation for the issuing authority. Used for grouping and reporting by certifying body.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal or recertification event. Null if the certification has never been renewed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to maintain active status. Used for proactive renewal tracking and compliance monitoring.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean indicator of whether this certification is mandated by federal, state, or local regulation (e.g., FCC General Radiotelephone Operator License, OSHA safety certifications). True indicates regulatory requirement; False indicates voluntary or company-preferred certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of cost reimbursement to the technician or training provider. Not_applicable indicates company-paid certification; pending indicates reimbursement request submitted; approved indicates reimbursement authorized; reimbursed indicates payment completed; denied indicates reimbursement request rejected.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the authenticity of the certification with the issuing authority. Examples include online registry lookup, phone verification, email confirmation, document review, third-party verification service, or self-attestation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Work Type Eligibility' ;
    rdfs:comment 'Comma-separated list or coded representation of work order types or service categories that this certification qualifies the technician to perform. Examples include tower_climbing, confined_space_entry, fiber_splicing, RAN_installation, 5G_NR_deployment, FTTH_installation. Used for dispatch eligibility and work assignment rules.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotCode rdf:type rdf:Property ;
    rdfs:label 'Depot Code' ;
    rdfs:comment 'Business identifier code for the depot used in workforce management systems and route optimization. Externally-known unique code for operational reference.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'Human-readable name of the depot facility (e.g., \'North Regional Dispatch Center\', \'Downtown Service Yard\').' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Classification of the depot facility based on its operational role and capacity. Central warehouse serves as primary distribution hub, satellite yard provides local staging, NOC (Network Operations Center) dispatch center handles network emergency response, mobile hub supports temporary deployments, regional staging consolidates area operations, field office provides administrative support.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for the depot facility for administrative communication and work order coordination.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Facility Ownership Type' ;
    rdfs:comment 'Classification of how the depot facility is controlled. Owned indicates company property, leased for rental agreement, shared for co-location with partners, temporary for short-term arrangements.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Availability Flag' ;
    rdfs:comment 'Indicates whether the depot operates on public holidays. True if depot maintains operations during holidays, False if closed.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent facility safety or compliance inspection. Used for regulatory compliance tracking and facility maintenance scheduling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the facility lease or rental agreement expires. Used for facility planning and renewal tracking. Null if facility is owned.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nocIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Noc Integration Flag' ;
    rdfs:comment 'Indicates whether this depot is integrated with or co-located with a Network Operations Center for real-time network fault response and emergency dispatch.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the depot on weekdays (Monday-Friday) in format \'HH:MM-HH:MM\' (e.g., \'06:00-18:00\'). Used for dispatch scheduling and technician availability planning.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Operating hours for the depot on weekends (Saturday-Sunday) in format \'HH:MM-HH:MM\'. May differ from weekday hours or be closed.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Flag' ;
    rdfs:comment 'Indicates whether this depot maintains an inventory of network equipment parts and Customer Premises Equipment (CPE) for technician provisioning. True if inventory is stocked, False if technicians source parts elsewhere.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the depot facility for operational coordination and technician communication.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDepotFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Depot Flag' ;
    rdfs:comment 'Indicates whether this is the primary depot for its service territory. True if primary hub, False if satellite or secondary facility.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionalManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Email' ;
    rdfs:comment 'Email address of the regional manager for operational communication and escalation.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerName rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Name' ;
    rdfs:comment 'Full name of the regional manager responsible for overseeing depot operations and workforce coordination.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Phone' ;
    rdfs:comment 'Contact phone number for the regional manager responsible for this depot.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Physical security classification of the depot facility. Standard for basic access control, enhanced for monitored entry, high security for critical infrastructure protection, restricted access for sensitive equipment storage.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceZonePolygon rdf:type rdf:Property ;
    rdfs:label 'Service Zone Polygon' ;
    rdfs:comment 'Geographic boundary polygon defining the service coverage area assigned to this depot, stored as Well-Known Text (WKT) or GeoJSON format. Used for territory assignment and technician dispatch optimization.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianHeadcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Technician Headcount Capacity' ;
    rdfs:comment 'Maximum number of field technicians that can be assigned to and dispatched from this depot as their home base.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Tool Storage Capacity Sqft' ;
    rdfs:comment 'Total tool and equipment storage capacity at the depot measured in square feet. Used for inventory planning and space utilization analysis.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleBayCapacity rdf:type rdf:Property ;
    rdfs:label 'Vehicle Bay Capacity' ;
    rdfs:comment 'Maximum number of service vehicles that can be parked and maintained at the depot facility simultaneously.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekendAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Availability Flag' ;
    rdfs:comment 'Indicates whether the depot operates on weekends. True if depot is open Saturday or Sunday, False if closed all weekend.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wfmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wfm System Code' ;
    rdfs:comment 'External identifier for this depot in the Granite Telecommunications Workforce Management system. Used for system integration and data reconciliation.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianScheduleId rdf:type rdf:Property ;
    rdfs:label 'Technician Schedule Id' ;
    rdfs:comment 'Unique identifier for the technician schedule record. Primary key for the technician_schedule data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicianSchedule .

ind:assignedNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Assigned Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Preventive maintenance schedules assign technicians to specific network elements for routine inspections and maintenance. Enables proactive maintenance planning, ensures critical infrastructure receiv' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:primaryTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Technician Id' ;
    rdfs:comment 'Identifier of the technician to whom this schedule applies. Links to the technician master record in the workforce domain.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:actualOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Overtime Hours' ;
    rdfs:comment 'Actual overtime hours worked during this shift, including both planned and emergency overtime. Captured from time tracking systems and used for payroll processing.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWorkHours rdf:type rdf:Property ;
    rdfs:label 'Actual Work Hours' ;
    rdfs:comment 'Total hours the technician actually worked during this shift, captured from time tracking or mobile workforce systems. Used for payroll and productivity analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total allocated break time within the shift, measured in minutes. Includes lunch breaks and rest periods as per labor regulations and company policy.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when this schedule was cancelled. Populated when a shift is removed due to leave, operational changes, or workforce reallocation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the technician confirmed receipt and acceptance of this schedule assignment. Used to track acknowledgment compliance.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchSystemSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch System Sync Flag' ;
    rdfs:comment 'Indicates whether this schedule record has been successfully synchronized to the Granite Telecommunications WFM dispatch optimization system. Used for integration monitoring.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Leave Approval Date' ;
    rdfs:comment 'Date when the leave request was approved by the manager. Used for audit trail and to measure approval cycle time.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveRequestDate rdf:type rdf:Property ;
    rdfs:label 'Leave Request Date' ;
    rdfs:comment 'Date when the leave request was submitted by the technician. Used to track request-to-approval workflow timing and compliance with notice requirements.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of absence or leave taken during this scheduled period. Null if the technician is working; populated when the schedule represents a leave block. [ENUM-REF-CANDIDATE: annual_leave|sick_leave|fmla|training_leave|emergency_absence|bereavement|jury_duty — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the technician is eligible for overtime compensation during this shift. Determined by labor classification, union rules, and shift type.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimePayClassification rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Classification' ;
    rdfs:comment 'Pay rate multiplier applied to overtime hours. Determined by labor agreements, shift timing (weekday vs weekend vs holiday), and overtime duration.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Overtime Reason Code' ;
    rdfs:comment 'Classification code indicating the business reason for overtime work. Used for cost allocation, workforce planning, and operational analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSystemSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll System Sync Flag' ;
    rdfs:comment 'Indicates whether this schedule record and associated hours have been successfully synchronized to SAP S/4HANA payroll. Used for integration monitoring and payroll reconciliation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Overtime Hours' ;
    rdfs:comment 'Pre-approved overtime hours scheduled for this shift. Typically used for planned network rollout surges, maintenance windows, or outage response preparation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWorkHours rdf:type rdf:Property ;
    rdfs:label 'Planned Work Hours' ;
    rdfs:comment 'Total hours the technician was scheduled to work during this shift, excluding breaks. Used for capacity planning and utilization analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this schedule was published to the technician. Marks the transition from draft to active schedule and starts the confirmation window.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleChangeReason rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Reason' ;
    rdfs:comment 'Free-text description of the reason for any schedule modification after initial publication. Captures business context for audit and operational review.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'The calendar date for which this schedule assignment applies. Represents the business day of the scheduled work.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the schedule assignment. Tracks progression from draft creation through publication, technician confirmation, execution, and completion or cancellation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version number of this schedule record. Incremented each time the schedule is modified, supporting change audit trail and historical analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Total duration of the shift in hours, including break time. Standard shifts are typically 8 or 10 hours; on-call shifts may vary.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The precise date and time when the technician\'s shift ends. Used to calculate shift duration and availability windows.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The precise date and time when the technician\'s shift begins. Used for dispatch optimization and field coordination.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift pattern. Indicates whether the shift is a standard day shift, evening shift, night shift, on-call rotation, weekend rotation, or holiday coverage.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderImpactCount rdf:type rdf:Property ;
    rdfs:label 'Work Order Impact Count' ;
    rdfs:comment 'Number of work orders originally assigned to this technician for this shift that were impacted by leave or schedule changes. Used to assess operational disruption.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmEventId rdf:type rdf:Property ;
    rdfs:label 'Alarm Event Id' ;
    rdfs:comment 'Foreign key linking to assurance.alarm_event. Business justification: Alarm-driven field dispatch: network alarms directly trigger work orders for field remediation without requiring a full NOC incident. Telecom operations teams expect work orders to reference the origi' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlarmEvent .

ind:assignedTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Id' ;
    rdfs:comment 'Reference to the field service team or crew assigned to this work order, used when multiple technicians are required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:parentWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Work Order Id' ;
    rdfs:comment 'Reference to the parent work order if this is a follow-up or child work order, enabling tracking of multi-visit resolution chains.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:routePlanId rdf:type rdf:Property ;
    rdfs:label 'Route Plan Id' ;
    rdfs:comment 'Foreign key linking to workforce.route_plan. Business justification: A work order is a stop on a technician\'s daily route plan. Linking work_order.route_plan_id -> workforce.route_plan.route_plan_id enables route-level analytics (completion rates per route, SLA complia' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutePlan .

ind:spectrumLicenseId rdf:type rdf:Property ;
    rdfs:label 'Spectrum License Id' ;
    rdfs:comment 'Foreign key linking to compliance.spectrum_license. Business justification: Telecom field work orders for antenna commissioning, frequency testing, and spectrum equipment installation must reference the authorizing spectrum license. Regulators require evidence that field work' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpectrumLicense .

ind:svcLocationId rdf:type rdf:Property ;
    rdfs:label 'Svc Location Id' ;
    rdfs:comment 'Foreign key linking to service.svc_location. Business justification: Work orders are dispatched to service locations. Current site_latitude/site_longitude are denormalized from svc_location. Proper FK enables depot-to-location dispatch optimization, serviceability repo' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcLocation .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the technician arrived at the work site, captured via mobile device check-in.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Immediate customer satisfaction rating provided at work completion, typically on a 1-5 scale, used for technician performance evaluation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured' ;
    rdfs:comment 'Boolean indicator whether customer sign-off was obtained via digital signature on the mobile device, confirming work completion and acceptance.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstTimeFixFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Fix Flag' ;
    rdfs:comment 'Boolean indicator whether the work order was completed successfully on the first visit without requiring follow-up, a key operational KPI.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatVisitFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Visit Flag' ;
    rdfs:comment 'Boolean indicator whether this work order is a repeat visit to the same site for the same issue, indicating initial resolution failure.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when the field work is scheduled to begin, used for appointment booking and customer communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalLaborHours rdf:type rdf:Property ;
    rdfs:label 'Total Labor Hours' ;
    rdfs:comment 'Total hours of labor expended on this work order across all technicians and activities, used for cost allocation and productivity analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Total cost of all materials and parts consumed during work order execution, aggregated from material line items.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible business identifier for the work order, used for tracking and reference by field technicians and customers.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order in the field service workflow, from initial creation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|scheduled|dispatched|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order based on the nature of field activity: installation of new service, repair of existing service, preventive maintenance, site survey, network upgrade, or equipment decommissioning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Start Timestamp' ;
    rdfs:comment 'Timestamp when the technician began actual field work activities, distinct from arrival time which may include site assessment.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchEventId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Event Id' ;
    rdfs:comment 'Unique identifier for the dispatch event record. Primary key for the dispatch event transaction.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldVehicleId rdf:type rdf:Property ;
    rdfs:label 'Field Vehicle Id' ;
    rdfs:comment 'Reference to the service vehicle assigned to the technician for this dispatch event. Used for fleet management, route optimization, and asset utilization analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldVehicle .

ind:primaryDispatchTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Dispatch Technician Id' ;
    rdfs:comment 'Reference to the field technician assigned to this dispatch event. Represents the current technician responsible for executing the work order.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:requiredSkillId rdf:type rdf:Property ;
    rdfs:label 'Required Skill Id' ;
    rdfs:comment 'Foreign key linking to workforce.skill. Business justification: dispatch_event has skill_requirement_code (STRING) which is a denormalized reference to the skill taxonomy. Normalizing this to required_skill_id -> workforce.skill.skill_id establishes proper referen' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Skill .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the assigned technician acknowledged receipt of the dispatch instruction via mobile app or other communication channel. Null if not yet acknowledged.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:afterHoursFlag rdf:type rdf:Property ;
    rdfs:label 'After Hours Flag' ;
    rdfs:comment 'Boolean indicator of whether the dispatch occurred outside of standard business hours (evenings, weekends, holidays). True indicates after-hours dispatch, which may incur premium labor costs and affect OPEX (Operational Expenditure) analysis.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether an automated customer notification (SMS, email, or mobile app push) was sent informing the customer of the technician dispatch and estimated arrival time. True indicates notification sent.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchChannel rdf:type rdf:Property ;
    rdfs:label 'Dispatch Channel' ;
    rdfs:comment 'The communication channel or interface through which the dispatch instruction was transmitted to the technician: mobile workforce app, two-way radio, manual entry in WFM (Workforce Management) system, automated WFM routing engine, voice call, or SMS notification.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchLatitude rdf:type rdf:Property ;
    rdfs:label 'Dispatch Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84) of the technician\'s location at the moment of dispatch event creation. Used for route optimization analysis and dispatch efficiency metrics.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchLongitude rdf:type rdf:Property ;
    rdfs:label 'Dispatch Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84) of the technician\'s location at the moment of dispatch event creation. Used for route optimization analysis and dispatch efficiency metrics.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text operational notes entered by the dispatcher or system, providing additional instructions, site access information, safety warnings, or special handling requirements for the technician.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Human-readable business identifier for the dispatch event, used for tracking and audit purposes in field operations and NOC (Network Operations Center) systems.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPriority rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority' ;
    rdfs:comment 'Urgency classification of the dispatch event: critical for network outages affecting multiple customers, high for SLA-sensitive installations, medium for standard service requests, low for routine maintenance.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the dispatch action. For initial dispatch: work order type. For reassignment: reason for reassignment (skill mismatch, technician unavailable, workload balancing). For escalation: complexity escalation, SLA breach risk. For cancellation: customer cancellation, duplicate order, resolved remotely.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispatch Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the dispatch action, supplementing the standardized reason code. Used for root-cause analysis and operational improvement.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Dispatch Source System' ;
    rdfs:comment 'The originating system or module that created the dispatch event: Granite Telecommunications WFM automated routing, manual NOC dispatcher entry, automated OSS (Operations Support Systems) integration, CRM-triggered dispatch, or emergency dispatch system.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch event: pending technician acknowledgment, acknowledged by technician, technician en route to site, technician arrived on site, dispatch completed, dispatch failed, or dispatch cancelled. [ENUM-REF-CANDIDATE: pending|acknowledged|en_route|arrived|completed|failed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchType rdf:type rdf:Property ;
    rdfs:label 'Dispatch Type' ;
    rdfs:comment 'Classification of the dispatch action: initial assignment to technician, reassignment to different technician, escalation to senior technician, cancellation of dispatch, return-to-depot instruction, or emergency dispatch for critical network outages.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchZoneCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Zone Code' ;
    rdfs:comment 'Geographic service zone or territory code where the dispatch event occurs. Used for workload balancing, regional performance analysis, and territory management.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Flag' ;
    rdfs:comment 'Boolean indicator of whether this dispatch is classified as an emergency response (e.g., critical network outage, service-affecting fault, safety hazard). True indicates emergency dispatch requiring immediate response.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enRouteTimestamp rdf:type rdf:Property ;
    rdfs:label 'En Route Timestamp' ;
    rdfs:comment 'Date and time when the technician marked themselves as en route to the target site in the mobile workforce application. Used for real-time tracking and customer ETA updates.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Projected date and time when the technician is expected to arrive at the target site, calculated at dispatch time. Used for customer communication and SLA monitoring.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Calculated travel time in minutes from the technician\'s dispatch location to the target site, based on route optimization algorithms and real-time traffic data at dispatch time.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'Cumulative count of how many times the underlying work order has been reassigned to different technicians. Incremented with each reassignment dispatch event. Used for operational efficiency analysis and first-time-fix rate calculation.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The originally scheduled start time for the work order appointment. Used to measure dispatch timeliness and adherence to customer appointment windows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetArrivalMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Arrival Minutes' ;
    rdfs:comment 'The contractual SLA target for technician arrival time in minutes from dispatch timestamp, based on work order priority and customer service tier. Used for SLA breach detection and root-cause analysis.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSiteLatitude rdf:type rdf:Property ;
    rdfs:label 'Target Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84) of the customer premises or network site where the technician is being dispatched. Used for travel time estimation and route planning.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSiteLongitude rdf:type rdf:Property ;
    rdfs:label 'Target Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84) of the customer premises or network site where the technician is being dispatched. Used for travel time estimation and route planning.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'Actual travel distance covered by the technician in kilometers, captured from GPS tracking or vehicle telematics.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual return time to the depot when the technician completed the route, captured from GPS or mobile app check-out.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Travel Time Minutes' ;
    rdfs:comment 'Actual total travel time in minutes spent by the technician moving between stops, captured from GPS tracking.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWorkTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Work Time Minutes' ;
    rdfs:comment 'Actual total on-site work time in minutes spent by the technician across all stops.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedStops rdf:type rdf:Property ;
    rdfs:label 'Completed Stops' ;
    rdfs:comment 'Number of stops that have been completed by the technician as of the current time.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerEtaNotificationsSent rdf:type rdf:Property ;
    rdfs:label 'Customer Eta Notifications Sent' ;
    rdfs:comment 'Count of customer ETA notifications sent for stops in this route plan, supporting customer experience and SLA compliance.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'Percentage deviation between planned and actual route execution metrics (time, distance, or stops), used for OPEX efficiency tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWorkTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Work Time Minutes' ;
    rdfs:comment 'Total estimated on-site work time in minutes across all stops, based on work order type and historical averages.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelEstimateLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Estimate Liters' ;
    rdfs:comment 'Estimated fuel consumption in liters for the route, calculated based on distance and vehicle fuel efficiency profile.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm' ;
    rdfs:comment 'The route optimization algorithm used by Granite WFM to generate this plan (e.g., time-window constrained, priority-weighted, fuel-optimized).' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Score' ;
    rdfs:comment 'Numerical score (0-100) representing the quality of the route optimization, calculated by the WFM engine based on efficiency metrics.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The calendar date for which this route plan was generated and is scheduled to be executed.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled return time to the depot after completing all stops, as planned by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled departure time from the depot to begin the route, as planned by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeNotes rdf:type rdf:Property ;
    rdfs:label 'Route Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to the route plan, such as road closures, access restrictions, or coordination requirements.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePlanNumber rdf:type rdf:Property ;
    rdfs:label 'Route Plan Number' ;
    rdfs:comment 'Human-readable business identifier for the route plan, typically formatted as RP-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePriority rdf:type rdf:Property ;
    rdfs:label 'Route Priority' ;
    rdfs:comment 'Overall priority level of the route plan, typically derived from the highest priority work order included in the route.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Service Region Code' ;
    rdfs:comment 'Geographic service region code where this route plan operates, used for regional workforce analytics and capacity planning.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skippedStops rdf:type rdf:Property ;
    rdfs:label 'Skipped Stops' ;
    rdfs:comment 'Number of stops that were skipped or not completed during route execution.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the route plan execution met all applicable SLA commitments for customer appointment windows and response times.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total planned travel distance for the entire route in kilometers, calculated by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of stops (work order sites) included in this route plan.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficConditionsConsidered rdf:type rdf:Property ;
    rdfs:label 'Traffic Conditions Considered' ;
    rdfs:comment 'Indicates whether real-time or historical traffic conditions were factored into the route optimization algorithm.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherConditionsConsidered rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions Considered' ;
    rdfs:comment 'Indicates whether weather forecast data was factored into the route planning and time estimates.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Current Technician Id' ;
    rdfs:comment 'Identifier of the technician currently assigned to this vehicle. Null if vehicle is unassigned. Reflects the most recent assignment record.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost paid to acquire the vehicle, including purchase price, taxes, and initial outfitting. Used for asset valuation and ROI analysis.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFuelConsumptionPer100km rdf:type rdf:Property ;
    rdfs:label 'Average Fuel Consumption Per 100km' ;
    rdfs:comment 'Rolling average fuel consumption rate in liters (or kWh for electric) per 100 kilometers. Used for cost forecasting and environmental reporting.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Primary exterior color of the vehicle. Used for visual identification and branding compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentAssignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Assignment Start Timestamp' ;
    rdfs:comment 'Timestamp when the current technician assignment began. Null if vehicle is unassigned. Used for utilization tracking.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentAssignmentType rdf:type rdf:Property ;
    rdfs:label 'Current Assignment Type' ;
    rdfs:comment 'Type of the current assignment. Permanent assignments are long-term; daily and emergency are short-term. Affects dispatch planning.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFitted rdf:type rdf:Property ;
    rdfs:label 'Equipment Fitted' ;
    rdfs:comment 'Comma-separated list of specialized equipment installed on the vehicle (e.g., aerial lift, cable drum, OTDR, fusion splicer, ladder rack). Determines work order eligibility.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel or energy source the vehicle uses. Critical for fuel cost allocation and environmental reporting.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether the vehicle is equipped with active GPS tracking. Used for real-time fleet visibility and route optimization.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight Kg' ;
    rdfs:comment 'Maximum allowable total weight of the vehicle including cargo and passengers. Used for regulatory compliance and route planning.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Due Date' ;
    rdfs:comment 'Date when the next mandatory safety inspection is due. Required for regulatory compliance and dispatch eligibility.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date when the current insurance policy expires. Vehicles cannot be dispatched without valid insurance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the most recent maintenance service was completed. Used to calculate next maintenance interval.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the vehicle lease agreement expires. Null for owned vehicles. Used for fleet renewal planning.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Load Capacity Kg' ;
    rdfs:comment 'Maximum payload capacity of the vehicle in kilograms. Used for equipment assignment and safety compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Due Date' ;
    rdfs:comment 'Date when the next scheduled preventive maintenance is due. Calculated based on odometer and time intervals per manufacturer specifications.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer or brand of the vehicle (e.g., Ford, Chevrolet, Mercedes-Benz).' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific model designation of the vehicle (e.g., Transit, Silverado, Sprinter).' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'Year the vehicle model was manufactured. Used for depreciation calculation and maintenance scheduling.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Current odometer reading in kilometers. Updated at each assignment return. Used for maintenance scheduling and lifecycle management.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the vehicle is owned outright, leased long-term, or rented short-term. Affects CAPEX vs OPEX classification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationPlate rdf:type rdf:Property ;
    rdfs:label 'Registration Plate' ;
    rdfs:comment 'License plate number assigned to the vehicle by the motor vehicle authority. Unique identifier for legal and operational tracking.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Number of passenger seats in the vehicle. Used for crew assignment and safety compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the telematics device installed in the vehicle. Used to link vehicle data with real-time telemetry streams.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Cumulative maintenance and repair costs incurred over the vehicle\'s lifetime. Used for total cost of ownership (TCO) analysis.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Identification Number' ;
    rdfs:comment '17-character unique identifier assigned by the manufacturer. Used for warranty, recall, theft tracking, and asset verification.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Status' ;
    rdfs:comment 'Current operational status of the vehicle. Determines dispatch eligibility and fleet utilization metrics.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Functional classification of the vehicle based on its primary use in field operations. Determines equipment compatibility and dispatch eligibility. [ENUM-REF-CANDIDATE: van|bucket_truck|cable_laying_truck|fiber_splicing_unit|pickup_truck|utility_vehicle|heavy_equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepotId rdf:type rdf:Property ;
    rdfs:label 'Assigned Depot Id' ;
    rdfs:comment 'Reference to the depot or service center where the team is based. Defines the home location for team dispatch and resource allocation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:leadTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Lead Technician Id' ;
    rdfs:comment 'Reference to the technician who serves as the team lead or supervisor. Responsible for team coordination and work order execution oversight.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:averageCompletionRatePct rdf:type rdf:Property ;
    rdfs:label 'Average Completion Rate Pct' ;
    rdfs:comment 'Historical average percentage of work orders completed successfully by the team on first visit. Key Performance Indicator (KPI) for team effectiveness.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Minutes' ;
    rdfs:comment 'Historical average time in minutes from work order dispatch to team arrival at site. Key Performance Indicator (KPI) for team responsiveness.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disbandmentDate rdf:type rdf:Property ;
    rdfs:label 'Disbandment Date' ;
    rdfs:comment 'Date when the team was disbanded or deactivated. Null for active teams. Used for historical workforce analysis.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbandmentReason rdf:type rdf:Property ;
    rdfs:label 'Disbandment Reason' ;
    rdfs:comment 'Business reason for team disbandment. Examples: project_completion, reorganization, budget_reduction, skill_consolidation. Null for active teams.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseCapable rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Capable' ;
    rdfs:comment 'Indicates whether the team is trained and equipped for emergency response and network outage restoration. True if the team can be mobilized for critical incidents.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date when the team was originally formed and activated in the workforce management system. Used for team lifecycle tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headcount rdf:type rdf:Property ;
    rdfs:label 'Headcount' ;
    rdfs:comment 'Current number of active technicians assigned to the team. Used for capacity planning and resource allocation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSafetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Training Date' ;
    rdfs:comment 'Date when the team last completed mandatory safety training. Used for compliance tracking and certification management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'Maximum number of technicians that can be assigned to this team based on operational design and resource constraints.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileEquipped rdf:type rdf:Property ;
    rdfs:label 'Mobile Equipped' ;
    rdfs:comment 'Indicates whether the team has mobile workforce management devices and real-time connectivity for field operations. True if equipped with mobile WFM (Workforce Management) tools.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCertificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Review Date' ;
    rdfs:comment 'Scheduled date for the next team certification review or skills assessment. Used for workforce development planning.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operational Hours End' ;
    rdfs:comment 'Standard daily end time for team operations in HH:MM format (24-hour). Used for dispatch scheduling and route optimization.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Start' ;
    rdfs:comment 'Standard daily start time for team operations in HH:MM format (24-hour). Used for dispatch scheduling and route optimization.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkillCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Skill Category' ;
    rdfs:comment 'Primary technical skill domain of the team. Defines the main area of expertise for work order assignment and capacity planning.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Cumulative count of safety incidents reported for this team. Used for safety performance tracking and compliance reporting.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard work schedule pattern for the team. Defines availability windows for dispatch and work order scheduling.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationTags rdf:type rdf:Property ;
    rdfs:label 'Specialization Tags' ;
    rdfs:comment 'Comma-separated list of technical specializations and certifications held by the team. Examples: fiber_splicing, 5G_NR_rollout, GPON_activation, FTTH_installation, CPE_configuration, OLT_maintenance. Used for skill-based dispatch and work order matching.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Business identifier for the team, used in dispatch systems and field operations. Externally-known unique code for the team.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Human-readable name of the field workforce team or crew.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamStatus rdf:type rdf:Property ;
    rdfs:label 'Team Status' ;
    rdfs:comment 'Current operational status of the team in the workforce management system. Indicates whether the team is available for dispatch and work order assignment.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team based on primary function and specialization. Defines the operational role of the team within the workforce structure. [ENUM-REF-CANDIDATE: installation_crew|maintenance_gang|emergency_response|specialized_squad|fiber_splicing|5g_rollout|gpon_activation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Count' ;
    rdfs:comment 'Number of service vehicles assigned to the team for field operations and equipment transport.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:elementId rdf:type rdf:Property ;
    rdfs:label 'Element Id' ;
    rdfs:comment 'Primary key for element' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:supportAgreementId rdf:type rdf:Property ;
    rdfs:label 'Support Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: Vendor support/maintenance agreement tracking: each network element is covered by a vendor support agreement governing MTTR commitments, spare parts, and on-site response. Linking element to the agree' ;
    rdfs:domain ind:Element ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:vendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Vendor/supplier management: telecom operators track which partner supplied or maintains each network element for procurement, warranty claims, and vendor SLA enforcement. Domain experts universally ex' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:administrativeState rdf:type rdf:Property ;
    rdfs:label 'Administrative State' ;
    rdfs:comment 'Administrative control state of the network element indicating whether it is locked (prevented from use), unlocked (available for use), or in the process of shutting down.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal asset tracking identifier assigned by the telecommunications operator for inventory and asset management purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity value (e.g., Gbps for bandwidth, TPS for transactions per second, Erlang for traffic intensity, subscribers for user capacity).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Numeric capacity rating of the network element representing its maximum throughput, bandwidth, or processing capability.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elementName rdf:type rdf:Property ;
    rdfs:label 'Element Name' ;
    rdfs:comment 'Human-readable name or label assigned to the network element for identification and operational reference.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementType rdf:type rdf:Property ;
    rdfs:label 'Element Type' ;
    rdfs:comment 'High-level classification of the network element indicating its functional category within the telecommunications infrastructure.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsSystem rdf:type rdf:Property ;
    rdfs:label 'Ems System' ;
    rdfs:comment 'Name of the Element Management System platform responsible for element-level configuration and fault management.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Externally-known unique identifier or code for the network element, used across operational systems and documentation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the network element was physically installed at its site location.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current lifecycle stage of the network element from initial planning through active operation to eventual retirement.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementIpAddress rdf:type rdf:Property ;
    rdfs:label 'Management Ip Address' ;
    rdfs:comment 'IP address used for network management access to the element via Network Management System (NMS) or Element Management System (EMS) platforms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manoOrchestrator rdf:type rdf:Property ;
    rdfs:label 'Mano Orchestrator' ;
    rdfs:comment 'Name or identifier of the NFV MANO platform responsible for orchestrating the lifecycle of this virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Hours' ;
    rdfs:comment 'Average time in hours between failures for this network element type, used for reliability planning and maintenance scheduling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date when the next scheduled maintenance activity is planned for the network element.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nfvIndicator rdf:type rdf:Property ;
    rdfs:label 'Nfv Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this network element is a virtualized network function (VNF) running on NFV infrastructure rather than dedicated physical hardware.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nmsSystem rdf:type rdf:Property ;
    rdfs:label 'Nms System' ;
    rdfs:comment 'Name of the Network Management System platform responsible for managing this network element (e.g., Nokia NetAct, Ericsson Network Manager).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalState rdf:type rdf:Property ;
    rdfs:label 'Operational State' ;
    rdfs:comment 'Current operational state of the network element indicating whether it is actively processing traffic, disabled, or in testing mode.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Typical power consumption of the network element in watts, used for energy management and operational expenditure (OPEX) planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackPosition rdf:type rdf:Property ;
    rdfs:label 'Rack Position' ;
    rdfs:comment 'Physical rack identifier and position within the data center or network facility where the element is mounted.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyMode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Mode' ;
    rdfs:comment 'Redundancy configuration mode for the network element indicating how failover and high availability are implemented.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPosition rdf:type rdf:Property ;
    rdfs:label 'Slot Position' ;
    rdfs:comment 'Specific slot or bay position within the rack or chassis where the network element card or module is installed.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed classification of the network element specifying the exact node type (e.g., eNodeB, gNodeB, MME, AMF, SMF, UPF, P-CSCF, S-CSCF, I-CSCF, HSS, MPLS router, OTN switch, DSLAM, BNG, BRAS, OLT, ONT, ONU, vMME, vSGW, vPGW, vBNG, vFirewall).' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContact rdf:type rdf:Property ;
    rdfs:label 'Support Contact' ;
    rdfs:comment 'Primary technical support contact information (email or phone) for vendor support escalation related to this network element.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRatingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Celsius' ;
    rdfs:comment 'Maximum operating temperature rating in degrees Celsius for the network element hardware.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vcpuCount rdf:type rdf:Property ;
    rdfs:label 'Vcpu Count' ;
    rdfs:comment 'Number of virtual CPU cores allocated to the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vnfdIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vnfd Identifier' ;
    rdfs:comment 'Unique identifier for the VNF Descriptor that defines the deployment and operational behavior of the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vramGb rdf:type rdf:Property ;
    rdfs:label 'Vram Gb' ;
    rdfs:comment 'Amount of virtual memory in gigabytes allocated to the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage for the network element expires.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Destination Network Element Id' ;
    rdfs:comment 'Reference to the terminating network element (node) of this topology link. Represents the Z-end of the connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:sourceNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Source Network Element Id' ;
    rdfs:comment 'Reference to the originating network element (node) of this topology link. Represents the A-end of the connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:actualAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Availability Percentage' ;
    rdfs:comment 'Measured availability of the link over a reporting period, expressed as a percentage. Compared against Service Level Agreement (SLA) targets for compliance reporting.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circuitReference rdf:type rdf:Property ;
    rdfs:label 'Circuit Reference' ;
    rdfs:comment 'External circuit identifier assigned by the service provider or carrier for leased or wholesale links. Used for interconnect billing and settlement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationInterfaceName rdf:type rdf:Property ;
    rdfs:label 'Destination Interface Name' ;
    rdfs:comment 'Name or identifier of the physical or logical interface on the destination network element where the link terminates. Used for detailed topology mapping and troubleshooting.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBidirectional rdf:type rdf:Property ;
    rdfs:label 'Is Bidirectional' ;
    rdfs:comment 'Indicates whether the link supports bidirectional traffic flow or is unidirectional. Affects path computation and traffic engineering algorithms.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProtected rdf:type rdf:Property ;
    rdfs:label 'Is Protected' ;
    rdfs:comment 'Indicates whether the link has an active protection scheme configured for redundancy and failover. Critical for Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Indicates whether the link is a virtual or logical connection (e.g., Software-Defined Networking (SDN) or Network Functions Virtualization (NFV) overlay) rather than a physical connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent link failure event. Used for fault management, root cause analysis, and Mean Time Between Failures (MTBF) calculations.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Link Capacity Mbps' ;
    rdfs:comment 'Maximum bandwidth capacity of the link measured in megabits per second. Critical for capacity planning, traffic engineering, and Quality of Service (QoS) management.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkCost rdf:type rdf:Property ;
    rdfs:label 'Link Cost' ;
    rdfs:comment 'Routing protocol cost or metric assigned to the link for path computation algorithms. Used in Open Shortest Path First (OSPF), Intermediate System to Intermediate System (IS-IS), and other routing protocols.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Link Distance Km' ;
    rdfs:comment 'Physical or logical distance of the link in kilometers. Used for latency calculations, signal degradation analysis, and network planning.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkIdentifier rdf:type rdf:Property ;
    rdfs:label 'Link Identifier' ;
    rdfs:comment 'Externally-known unique identifier for the network link, used in network management systems and topology diagrams. Typically follows naming conventions from Nokia NetAct or Ericsson Network Manager.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Link Latency Ms' ;
    rdfs:comment 'Measured or calculated propagation delay across the link in milliseconds. Critical for Service Level Agreement (SLA) compliance and Quality of Service (QoS) assurance.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkName rdf:type rdf:Property ;
    rdfs:label 'Link Name' ;
    rdfs:comment 'Human-readable name or label for the network link, used for identification in network operations and documentation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkType rdf:type rdf:Property ;
    rdfs:label 'Link Type' ;
    rdfs:comment 'Classification of the physical or logical medium used for the network link. Determines transmission characteristics and capacity planning parameters.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mplsLabel rdf:type rdf:Property ;
    rdfs:label 'Mpls Label' ;
    rdfs:comment 'MPLS label assigned to the Label Switched Path (LSP) for this link. Used for traffic engineering and Quality of Service (QoS) in MPLS networks.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkLayer rdf:type rdf:Property ;
    rdfs:label 'Network Layer' ;
    rdfs:comment 'The hierarchical layer of the telecommunications network where this link operates. Used for layer-specific topology analysis and capacity planning.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionScheme rdf:type rdf:Property ;
    rdfs:label 'Protection Scheme' ;
    rdfs:comment 'Redundancy and failover mechanism configured for the link. Defines how the network recovers from link failures to maintain service continuity and meet Service Level Agreement (SLA) requirements.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Availability Percentage' ;
    rdfs:comment 'Contractual availability target for the link expressed as a percentage. Used for Service Level Agreement (SLA) compliance monitoring and reporting.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceInterfaceName rdf:type rdf:Property ;
    rdfs:label 'Source Interface Name' ;
    rdfs:comment 'Name or identifier of the physical or logical interface on the source network element where the link originates. Used for detailed topology mapping and troubleshooting.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyStandard rdf:type rdf:Property ;
    rdfs:label 'Technology Standard' ;
    rdfs:comment 'Industry standard or protocol specification governing the link technology. Examples include IEEE 802.3 for Ethernet, ITU-T G.652 for fiber, or 3GPP specifications for Radio Access Network (RAN) links.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Current bandwidth utilization of the link expressed as a percentage of total capacity. Key Performance Indicator (KPI) for capacity planning and congestion management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antennaHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Antenna Height Meters' ;
    rdfs:comment 'Height of the antenna above ground level in meters. Affects coverage radius and signal propagation characteristics.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:azimuthDegrees rdf:type rdf:Property ;
    rdfs:label 'Azimuth Degrees' ;
    rdfs:comment 'Horizontal direction of the antenna\'s main beam in degrees from true north (0-360). Critical for coverage planning and interference management.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthMhz rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mhz' ;
    rdfs:comment 'The bandwidth of the radio channel in megahertz. Common values include 5, 10, 15, 20 MHz for LTE; up to 100 MHz for 5G NR.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beamformingEnabled rdf:type rdf:Property ;
    rdfs:label 'Beamforming Enabled' ;
    rdfs:comment 'Indicates whether advanced beamforming techniques are enabled. Beamforming directs radio signals toward specific users, improving signal quality and capacity.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierAggregationEnabled rdf:type rdf:Property ;
    rdfs:label 'Carrier Aggregation Enabled' ;
    rdfs:comment 'Indicates whether carrier aggregation is enabled for this cell. CA combines multiple frequency bands to increase throughput in LTE and 5G networks.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Carrier Frequency Mhz' ;
    rdfs:comment 'Center frequency of the carrier in megahertz. The primary operating frequency for the cell\'s radio transmission.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellActivationDate rdf:type rdf:Property ;
    rdfs:label 'Cell Activation Date' ;
    rdfs:comment 'Date when the cell was first activated and began serving traffic. Used for lifecycle tracking and network evolution analysis.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cellCapacityUsers rdf:type rdf:Property ;
    rdfs:label 'Cell Capacity Users' ;
    rdfs:comment 'Maximum number of concurrent users the cell is designed to support. Based on spectrum allocation, technology, and configuration.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Cell Deactivation Date' ;
    rdfs:comment 'Date when the cell was deactivated or decommissioned. Null for active cells. Used for historical analysis and asset lifecycle management.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cellGlobalIdentity rdf:type rdf:Property ;
    rdfs:label 'Cell Global Identity' ;
    rdfs:comment 'Globally unique cell identifier combining MCC, MNC, LAC/TAC, and Cell ID. Format varies by technology: CGI for 2G/3G, ECGI for LTE, NCI for 5G NR. Used for cell identification in handovers and network operations.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellName rdf:type rdf:Property ;
    rdfs:label 'Cell Name' ;
    rdfs:comment 'Human-readable name assigned to the cell for operational identification and network management purposes. Typically includes site identifier and sector information.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellOperationalState rdf:type rdf:Property ;
    rdfs:label 'Cell Operational State' ;
    rdfs:comment 'Current operational status of the cell. Indicates whether the cell is serving traffic, under maintenance, or planned for deployment.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Channel number identifying the specific radio frequency channel. Format varies by technology: ARFCN for GSM/UMTS, EARFCN for LTE, NR-ARFCN for 5G NR.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Classification of the cell\'s primary coverage area: outdoor macro coverage, indoor small cell, or mixed deployment.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentScenario rdf:type rdf:Property ;
    rdfs:label 'Deployment Scenario' ;
    rdfs:comment 'The deployment environment scenario for the cell. Influences planning parameters, capacity expectations, and performance benchmarks.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricalTiltDegrees rdf:type rdf:Property ;
    rdfs:label 'Electrical Tilt Degrees' ;
    rdfs:comment 'Electronic beam steering tilt angle in degrees, adjustable via Remote Electrical Tilt (RET) systems. Enables dynamic coverage optimization.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySavingMode rdf:type rdf:Property ;
    rdfs:label 'Energy Saving Mode' ;
    rdfs:comment 'Energy saving configuration for the cell. Adaptive mode dynamically adjusts power based on traffic load to reduce operational expenditure.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Specific model designation of the base station equipment serving this cell. Used for inventory management and maintenance planning.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'The frequency band designation used by the cell (e.g., Band 1, Band 3, Band 7, n78, n260). Identifies the spectrum allocation for the cell.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverHysteresisDb rdf:type rdf:Property ;
    rdfs:label 'Handover Hysteresis Db' ;
    rdfs:comment 'Hysteresis value in decibels to prevent ping-pong handovers between cells. Stabilizes mobility decisions in border areas.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverMarginDb rdf:type rdf:Property ;
    rdfs:label 'Handover Margin Db' ;
    rdfs:comment 'Signal strength margin in decibels required to trigger handover to neighboring cells. Critical parameter for mobility management and call continuity.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastConfigurationChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Configuration Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent configuration change applied to the cell. Critical for change management and troubleshooting.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadBalancingEnabled rdf:type rdf:Property ;
    rdfs:label 'Load Balancing Enabled' ;
    rdfs:comment 'Indicates whether automatic load balancing is enabled to distribute traffic across neighboring cells during congestion.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumCellRangeMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Cell Range Meters' ;
    rdfs:comment 'Maximum designed coverage radius of the cell in meters. Used for network planning and capacity dimensioning.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mechanicalTiltDegrees rdf:type rdf:Property ;
    rdfs:label 'Mechanical Tilt Degrees' ;
    rdfs:comment 'Physical downward tilt angle of the antenna in degrees. Used to control vertical coverage and reduce interference.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mimoConfiguration rdf:type rdf:Property ;
    rdfs:label 'Mimo Configuration' ;
    rdfs:comment 'MIMO antenna configuration indicating the number of transmit and receive antenna paths. Higher configurations enable greater spectral efficiency and throughput.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCellIdentifier rdf:type rdf:Property ;
    rdfs:label 'Physical Cell Identifier' ;
    rdfs:comment 'Physical layer cell identity used for cell identification during initial access and handover. Range 0-503 for LTE, 0-1007 for 5G NR.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:radioAccessTechnology rdf:type rdf:Property ;
    rdfs:label 'Radio Access Technology' ;
    rdfs:comment 'Specific radio access technology standard implemented by the cell. More granular than technology generation, specifying the exact air interface protocol.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorNumber rdf:type rdf:Property ;
    rdfs:label 'Sector Number' ;
    rdfs:comment 'Identifier for the sector within the base station site. Typically indicates the directional coverage area (e.g., Alpha, Beta, Gamma or 1, 2, 3).' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version of the base station software running on the equipment. Critical for feature availability, performance, and security patching.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyGeneration rdf:type rdf:Property ;
    rdfs:label 'Technology Generation' ;
    rdfs:comment 'The mobile network technology generation of the cell: 2G (GSM/GPRS/EDGE), 3G (UMTS/HSPA), 4G (LTE/LTE-Advanced), or 5G (5G NR).' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToTriggerMs rdf:type rdf:Property ;
    rdfs:label 'Time To Trigger Ms' ;
    rdfs:comment 'Duration in milliseconds that handover conditions must be met before triggering handover. Prevents unnecessary handovers due to temporary signal fluctuations.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Area Code' ;
    rdfs:comment 'Tracking Area Code for LTE/5G or Location Area Code for 2G/3G. Groups cells for mobility management and paging optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitPowerDbm rdf:type rdf:Property ;
    rdfs:label 'Transmit Power Dbm' ;
    rdfs:comment 'Maximum transmit power of the cell in decibels relative to one milliwatt (dBm). Determines signal strength and coverage area.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerEnterpriseSiteId rdf:type rdf:Property ;
    rdfs:label 'Customer Enterprise Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.site. Business justification: Transmission links terminate at enterprise customer sites for dedicated WAN/MPLS connectivity. Core business process: enterprise circuit provisioning and inventory management for point-to-point and MP' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:leaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: Leased transmission link contract management: the existing FK identifies the lease provider partner, but the specific governing agreement (terms, SLA, penalties) must also be linked for billing reconc' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:leaseProviderPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lease Provider Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Transmission links are frequently leased from infrastructure partners (fiber providers, dark fiber lessors). Settlement reconciliation, invoice validation, SLA tracking, and dispute resolution require' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:primaryTransmissionNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Transmission Network Equipment Id' ;
    rdfs:comment 'Identifier of the network element or equipment at the A-end of the transmission link (e.g., OLT, DSLAM, BNG, router).' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:aEndPort rdf:type rdf:Property ;
    rdfs:label 'A End Port' ;
    rdfs:comment 'Port or interface designation on the A-end equipment where the transmission link terminates.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmSeverityThreshold rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity Threshold' ;
    rdfs:comment 'Minimum alarm severity level configured for fault management notifications for this transmission link.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attenuationDb rdf:type rdf:Property ;
    rdfs:label 'Attenuation Db' ;
    rdfs:comment 'Signal attenuation or loss measured in decibels for the transmission link, applicable to fiber and microwave links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the transmission link was commissioned and put into operational service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the transmission link was decommissioned and removed from operational service. Null if still in service.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiberPairCount rdf:type rdf:Property ;
    rdfs:label 'Fiber Pair Count' ;
    rdfs:comment 'Number of fiber pairs (transmit/receive pairs) available in the fiber cable for this link. Null for non-fiber links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiberType rdf:type rdf:Property ;
    rdfs:label 'Fiber Type' ;
    rdfs:comment 'Type of optical fiber used for fiber-based transmission links. Single-Mode Fiber (SMF) for long-distance, Multi-Mode Fiber (MMF) for short-distance. Not applicable for non-fiber links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Route Description' ;
    rdfs:comment 'Textual description of the geographic route or path taken by the transmission link, including key waypoints or conduit paths.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseContractEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease Contract End Date' ;
    rdfs:comment 'End date of the lease contract for leased line circuits. Null for owned infrastructure.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseMonthlyCost rdf:type rdf:Property ;
    rdfs:label 'Lease Monthly Cost' ;
    rdfs:comment 'Monthly recurring cost for leased transmission links. Null for owned infrastructure. Business-confidential financial data.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current operational state of the transmission link in its lifecycle.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nmsObjectReference rdf:type rdf:Property ;
    rdfs:label 'Nms Object Reference' ;
    rdfs:comment 'Unique object identifier or managed object instance ID for this transmission link in the Network Management System (NMS).' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Internal business unit, division, or organizational entity that owns and manages this transmission link asset.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionType rdf:type rdf:Property ;
    rdfs:label 'Protection Type' ;
    rdfs:comment 'Type of redundancy or protection mechanism configured for the transmission link to ensure service continuity.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyGroupCode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Group Code' ;
    rdfs:comment 'Identifier of the redundancy or protection group to which this transmission link belongs, used for coordinated protection switching.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightOfWayType rdf:type rdf:Property ;
    rdfs:label 'Right Of Way Type' ;
    rdfs:comment 'Type of right-of-way or access rights for the physical transmission path (owned land, leased access, easement, public utility corridor). Applicable primarily to fiber and copper links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Route Distance Km' ;
    rdfs:comment 'Physical distance of the transmission link route measured in kilometers.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Percent' ;
    rdfs:comment 'Current utilization percentage of the transmission link capacity, calculated from performance monitoring data.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendor rdf:type rdf:Property ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Manufacturer or vendor of the transmission equipment and infrastructure for this link.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wavelengthCount rdf:type rdf:Property ;
    rdfs:label 'Wavelength Count' ;
    rdfs:comment 'Number of optical wavelengths (lambdas) supported on the fiber link for Dense Wavelength Division Multiplexing (DWDM) systems. Null for non-DWDM links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zEndPort rdf:type rdf:Property ;
    rdfs:label 'Z End Port' ;
    rdfs:comment 'Port or interface designation on the Z-end equipment where the transmission link terminates.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Id' ;
    rdfs:comment 'Primary key for capacity' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCapacity rdf:type rdf:Property ;
    rdfs:label 'Available Capacity' ;
    rdfs:comment 'Remaining capacity available for new service provisioning. Calculated as total capacity minus committed capacity and any reserved buffers.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Average Utilization Percentage' ;
    rdfs:comment 'Mean utilization percentage across the measurement period. Used for trend analysis and capacity planning forecasting.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:busyHourIndicator rdf:type rdf:Property ;
    rdfs:label 'Busy Hour Indicator' ;
    rdfs:comment 'Flag indicating whether this measurement represents the busy hour period. Busy hour metrics are critical for capacity dimensioning and network planning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current operational status of the resource capacity relative to defined thresholds. Drives capacity augmentation and network planning decisions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method by which capacity data was collected or derived. Indicates data quality and reliability characteristics.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCapacity rdf:type rdf:Property ;
    rdfs:label 'Committed Capacity' ;
    rdfs:comment 'Capacity already allocated or reserved for active services and customer commitments. Represents the portion of total capacity currently in use or reserved.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:congestionThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Congestion Threshold Percentage' ;
    rdfs:comment 'Utilization percentage threshold at which the resource is considered congested and requires capacity augmentation. Typically set based on QoS requirements and SLA commitments.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Percentage' ;
    rdfs:comment 'Utilization percentage threshold indicating critical capacity exhaustion requiring immediate intervention. Triggers urgent capacity expansion or traffic engineering actions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system or tool from which capacity measurements were collected. Identifies the authoritative system of record for this capacity data. [ENUM-REF-CANDIDATE: netact|ericsson_nm|nms|ems|oss|manual_survey|capacity_tool — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Projected date when capacity will reach congestion threshold based on current growth trends. Drives capital planning and network expansion timelines.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market area where the network resource is deployed. Used for regional capacity planning and investment prioritization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Growth Rate Percentage' ;
    rdfs:comment 'Observed or projected capacity growth rate percentage per period. Used for trend-based capacity forecasting and investment planning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement End Timestamp' ;
    rdfs:comment 'Ending timestamp of the capacity measurement period. Used with start timestamp to define the observation window for capacity metrics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Minutes' ;
    rdfs:comment 'Duration of the measurement period in minutes. Common intervals include 15, 30, 60 minutes for operational monitoring and daily/weekly for planning.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Peak Utilization Percentage' ;
    rdfs:comment 'Maximum utilization percentage observed during the measurement period. Critical metric for identifying capacity bottlenecks and congestion events.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Planned Upgrade Date' ;
    rdfs:comment 'Scheduled date for capacity augmentation or upgrade activity. Links capacity monitoring to capital project execution.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redundancyConfiguration rdf:type rdf:Property ;
    rdfs:label 'Redundancy Configuration' ;
    rdfs:comment 'Redundancy architecture of the resource. Impacts effective capacity calculations and failure scenario planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationPercentage rdf:type rdf:Property ;
    rdfs:label 'Reservation Percentage' ;
    rdfs:comment 'Percentage of total capacity reserved for network resilience, traffic bursts, and emergency services. Not available for normal service provisioning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Resource Identifier' ;
    rdfs:comment 'Business identifier or name of the specific resource (cell ID, link name, tunnel ID, port designation). Human-readable reference used in network operations.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Classification of the network resource being measured for capacity. Identifies the infrastructure layer and technology domain. [ENUM-REF-CANDIDATE: ran_cell|transmission_link|mpls_tunnel|bng_port|olt_port|bras_port|core_router|dslam_port|fiber_segment|spectrum_block — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Capacity' ;
    rdfs:comment 'Maximum theoretical capacity of the resource. Represents the absolute upper limit for bandwidth, channels, ports, or connections depending on resource type.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementConfigId rdf:type rdf:Property ;
    rdfs:label 'Element Config Id' ;
    rdfs:comment 'Unique identifier for the network element configuration record. Primary key for configuration management tracking across Nokia NetAct and Ericsson Network Manager platforms.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Approved By Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Telecom regulatory compliance and change governance require auditable records of who approved each configuration baseline. The plain-text \'approved_by\' column on element_config is a denormalized techn' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:configVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Config Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Vendor configuration audit trail: element configs track vendor-supplied or vendor-applied configurations. Linking to the partner record enables vendor performance audits, compliance reviews, and accou' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:rollbackReferenceElementConfigId rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference Element Config Id' ;
    rdfs:comment 'Reference to the previous configuration version that was restored during a rollback operation. Enables tracking of configuration reversion history and supports automated rollback procedures.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ElementConfig .

ind:affectedSubscribersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Subscribers Count' ;
    rdfs:comment 'Estimated or actual number of subscribers impacted by this configuration change. Used for impact assessment, prioritization, and customer communication during planned maintenance or incident response.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Date and time when this configuration was moved to archived status. Used for retention policy enforcement and historical analysis. Null for active or staged configurations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationSystem rdf:type rdf:Property ;
    rdfs:label 'Automation System' ;
    rdfs:comment 'Name of the automation platform or orchestration system that executed this configuration change (e.g., Nokia NetAct, Ericsson Network Manager, Ansible, Terraform, NSO). Null if manually executed by operator.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupLocation rdf:type rdf:Property ;
    rdfs:label 'Backup Location' ;
    rdfs:comment 'Storage path or URI where the full configuration backup file is stored. Supports disaster recovery, audit compliance, and rapid restoration. May reference network file system, object storage, or configuration management database.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the configuration change: planned (scheduled maintenance window), emergency (urgent fix outside normal window), automated (system-initiated optimization), rollback (reversion to previous config).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256) of the configuration file to ensure integrity and detect unauthorized modifications. Used for security audit and tamper detection in compliance with security frameworks.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Version' ;
    rdfs:comment 'Version of the compliance policy framework used to validate this configuration. Ensures audit trail of which standards were applied at the time of configuration deployment.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Indicates whether this configuration meets organizational policy standards, security baselines, and regulatory requirements. Non-compliant configurations trigger alerts for remediation. Used for configuration drift detection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Human-readable description of the configuration change purpose, scope, and expected outcome. Includes business justification such as capacity expansion, performance optimization, security hardening, or bug fix.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Additional operational notes, lessons learned, or special considerations related to this configuration. Used for knowledge management and to inform future similar changes.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configParameters rdf:type rdf:Property ;
    rdfs:label 'Config Parameters' ;
    rdfs:comment 'Structured representation of configuration parameters including neighbor cell lists, handover thresholds, QoS (Quality of Service) policies, routing tables, VLAN assignments, MPLS labels, BGP peers, OSPF areas, and vendor-specific settings. Stored as JSON or XML for structured querying.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Config Source System' ;
    rdfs:comment 'Name of the source system or NMS (Network Management System) / EMS (Element Management System) that generated or captured this configuration record (e.g., Nokia NetAct, Ericsson Network Manager, Netcracker OSS).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of this configuration record. Active indicates currently deployed; staged indicates pending activation; archived indicates historical record; superseded indicates replaced by newer version; failed indicates deployment failure.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configType rdf:type rdf:Property ;
    rdfs:label 'Config Type' ;
    rdfs:comment 'Type of configuration record: running (active operational config), startup (boot config), candidate (staged for activation), baseline (approved reference), golden (vendor-certified template).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version identifier for this configuration snapshot. Follows semantic versioning or vendor-specific versioning scheme (e.g., 2.4.1, R15B). Used for configuration baseline tracking and rollback operations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driftDetails rdf:type rdf:Property ;
    rdfs:label 'Drift Details' ;
    rdfs:comment 'Detailed description of configuration drift including specific parameters that differ from baseline, magnitude of deviation, and potential impact on network performance or security. Used for root cause analysis.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driftDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Drift Detected Flag' ;
    rdfs:comment 'Boolean indicator that the running configuration has diverged from the approved baseline configuration. Triggers automated alerts for investigation and remediation to maintain network stability and security posture.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionOutcome rdf:type rdf:Property ;
    rdfs:label 'Execution Outcome' ;
    rdfs:comment 'Result of the configuration deployment attempt: success (fully applied), partial (some parameters applied), failed (deployment unsuccessful), rolled_back (reverted to previous config due to validation failure or service impact).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Precise date and time when this configuration was deployed to the network element. Critical for correlating configuration changes with network performance events, outages, or KPI (Key Performance Indicator) degradation.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why a configuration deployment failed or was rolled back. Includes error codes, validation failures, resource conflicts, or service impact triggers. Used for troubleshooting and process improvement.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Pre-change analysis of potential impact on network services, customer experience, and KPIs. Includes affected services, subscriber count, geographic scope, and risk level. Used for change approval and rollback planning.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocSiteCode rdf:type rdf:Property ;
    rdfs:label 'Noc Site Code' ;
    rdfs:comment 'Code identifying the NOC (Network Operations Center) or regional operations center responsible for managing this network element configuration. Used for operational accountability and escalation routing.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametersModified rdf:type rdf:Property ;
    rdfs:label 'Parameters Modified' ;
    rdfs:comment 'List of specific configuration parameters that were changed in this version, with before and after values. Enables precise change tracking and impact analysis for troubleshooting and audit purposes.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Service Impact Flag' ;
    rdfs:comment 'Boolean indicator that this configuration change caused or is expected to cause service disruption, degradation, or customer impact. Used for SLA tracking, root cause analysis, and change management process improvement.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'List of validation errors or warnings identified during configuration validation. Includes syntax errors, policy violations, resource conflicts, or dependency issues. Used to prevent service-impacting misconfigurations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configChangeId rdf:type rdf:Property ;
    rdfs:label 'Config Change Id' ;
    rdfs:comment 'Unique identifier for the configuration change record. Primary key for the configuration change transaction.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineElementConfigId rdf:type rdf:Property ;
    rdfs:label 'Baseline Element Config Id' ;
    rdfs:comment 'Foreign key linking to network.element_config. Business justification: Configuration changes are applied against a baseline configuration. This FK links each config_change transaction to the element_config baseline it modifies, enabling change impact analysis, rollback p' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ElementConfig .

ind:executedByTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Executed By Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Configuration changes executed by technicians (field or NOC) require audit trail linking change to executor. Regulatory compliance (SOX, telecom audits) and change management processes mandate trackin' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the configuration change execution completed or failed.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the configuration change execution began. This is the principal business event timestamp for the transaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedCustomersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customers Count' ;
    rdfs:comment 'Estimated or actual number of customers whose services were impacted by this configuration change.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServices rdf:type rdf:Property ;
    rdfs:label 'Affected Services' ;
    rdfs:comment 'Comma-separated list of service identifiers or service names that were potentially impacted by this configuration change (e.g., \'VoLTE\', \'IPTV\', \'Broadband\').' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterValue rdf:type rdf:Property ;
    rdfs:label 'After Value' ;
    rdfs:comment 'Configuration parameter value(s) after the change was applied. Supports verification and compliance validation.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupCreated rdf:type rdf:Property ;
    rdfs:label 'Backup Created' ;
    rdfs:comment 'Indicates whether a configuration backup was created before applying this change to enable rollback (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupReference rdf:type rdf:Property ;
    rdfs:label 'Backup Reference' ;
    rdfs:comment 'Identifier or file path of the configuration backup created before this change. Null if no backup was created.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beforeValue rdf:type rdf:Property ;
    rdfs:label 'Before Value' ;
    rdfs:comment 'Configuration parameter value(s) before the change was applied. Supports audit trail and rollback scenarios.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed textual description of the configuration change, including business justification, technical scope, and expected impact.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Additional free-text notes, observations, or comments recorded by the operator or system during or after the configuration change execution.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changePriority rdf:type rdf:Property ;
    rdfs:label 'Change Priority' ;
    rdfs:comment 'Business priority level assigned to the configuration change: low, normal, high, urgent, or critical.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceValidated rdf:type rdf:Property ;
    rdfs:label 'Compliance Validated' ;
    rdfs:comment 'Indicates whether the configuration change has been validated against compliance policies and regulatory requirements (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes of service downtime caused by this configuration change. Zero if no downtime occurred.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executedBySystem rdf:type rdf:Property ;
    rdfs:label 'Executed By System' ;
    rdfs:comment 'Name or identifier of the automation system or orchestration platform that executed the change (e.g., \'Nokia NetAct\', \'Ericsson Network Manager\', \'Ansible Tower\', \'NSO\').' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReference rdf:type rdf:Property ;
    rdfs:label 'Incident Reference' ;
    rdfs:comment 'Reference to the incident ticket (from ServiceNow ITSM or fault management system) that triggered this emergency configuration change. Null for planned changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Noc Notification Sent' ;
    rdfs:comment 'Indicates whether the Network Operations Center was notified about this configuration change (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification of the configuration change based on probability and impact of failure: low, medium, high, or critical.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackReference rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference' ;
    rdfs:comment 'Reference identifier to the rollback change request or transaction that reverted this configuration change. Null if no rollback occurred.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the configuration change was scheduled to complete.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:softwareVersionAfter rdf:type rdf:Property ;
    rdfs:label 'Software Version After' ;
    rdfs:comment 'Software or firmware version of the network element after the configuration change. Relevant for software upgrade changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersionBefore rdf:type rdf:Property ;
    rdfs:label 'Software Version Before' ;
    rdfs:comment 'Software or firmware version of the network element before the configuration change. Relevant for software upgrade changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResult rdf:type rdf:Property ;
    rdfs:label 'Validation Result' ;
    rdfs:comment 'Result of post-change validation tests: passed (all tests successful), failed (validation detected issues), partial (some tests passed), or not_performed.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when post-change validation and verification tests were completed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:performanceCounterId rdf:type rdf:Property ;
    rdfs:label 'Performance Counter Id' ;
    rdfs:comment 'Primary key for performance_counter' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiThresholdId rdf:type rdf:Property ;
    rdfs:label 'Kpi Threshold Id' ;
    rdfs:comment 'Foreign key linking to assurance.kpi_threshold. Business justification: Performance counters are evaluated against KPI thresholds to determine breach conditions. This is the core measurement-to-threshold relationship in telecom NOC operations — every counter value is asse' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiThreshold .

ind:partnerSlaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Partner Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to partner.sla_definition. Business justification: Partner SLA breach detection: performance counters measuring KPIs for MVNO, roaming, and wholesale partners must reference the governing partner SLA definition to automate threshold breach detection a' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'The statistical method used to aggregate multiple raw measurements into the reported counter value. Examples: Sum (total), Average (mean), Minimum, Maximum, Percentile (95th, 99th), Count.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity classification of the threshold breach if one occurred. Aligns with ITU-T X.733 alarm severity levels: Critical (service-affecting), Major (significant degradation), Minor (potential issue), Warning (approaching threshold).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'The operational status of the performance data collection process for this record. Complete (full interval data), Partial (some samples missing), Failed (collection error), Suspect (data integrity concerns).' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The date and time when this performance record was retrieved from the network element and ingested into the performance management system (Nokia NetAct or Ericsson Network Manager).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correlationKey rdf:type rdf:Property ;
    rdfs:label 'Correlation Key' ;
    rdfs:comment 'A unique identifier used to correlate this performance measurement with related network events, alarms, or configuration changes occurring during the same time window. Enables cross-domain root cause analysis.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'The raw performance counter identifier as defined by the network element vendor (Nokia, Ericsson, Huawei). This is the native counter name from the NMS/EMS system before KPI derivation.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterValue rdf:type rdf:Property ;
    rdfs:label 'Counter Value' ;
    rdfs:comment 'The raw numeric value of the performance counter as collected from the network element. This is the unprocessed measurement before any KPI calculation or normalization.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Indicates whether the measured performance level (especially if threshold-breaching) has direct impact on customer-facing service quality. Used to prioritize network optimization and remediation efforts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'The geographic region or market identifier where the measured network element is deployed. Used for regional performance analysis and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Category' ;
    rdfs:comment 'High-level classification of the performance measurement domain: RAN (Radio Access Network), Transport (MPLS/SD-WAN), Core (IMS/EPC/5GC), Access (GPON/FTTH/DSLAM), Backhaul, or Aggregation.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'Specific name of the performance metric being measured. Examples: RSRP (Reference Signal Received Power), SINR (Signal-to-Interference-plus-Noise Ratio), throughput_mbps, handover_success_rate, packet_loss_rate, session_establishment_rate, call_drop_rate, latency_ms, jitter_ms.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiValue rdf:type rdf:Property ;
    rdfs:label 'Kpi Value' ;
    rdfs:comment 'The derived KPI value calculated from one or more raw performance counters. This is the business-meaningful metric used for network performance analysis and SLA monitoring.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time when this performance measurement was collected from the network element. Represents the end of the measurement interval.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Nms System Name' ;
    rdfs:comment 'The name of the Network Management System or Element Management System that collected and reported this performance measurement. Source system for data lineage and reconciliation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'The number of individual measurements or observations aggregated into this performance counter record during the measurement interval. Indicates statistical confidence of the reported value.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Applicable Flag' ;
    rdfs:comment 'Indicates whether this performance measurement is subject to a customer-facing or internal SLA commitment. True means the KPI is contractually committed and impacts SLA compliance reporting.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Flag' ;
    rdfs:comment 'Indicates whether the measured KPI value breached the defined threshold limits (upper or lower) during this measurement interval. True indicates a threshold violation requiring attention.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Limit' ;
    rdfs:comment 'The minimum acceptable value for this KPI as defined in the network performance SLA or operational policy. Values below this threshold trigger performance degradation alerts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Limit' ;
    rdfs:comment 'The maximum acceptable value for this KPI (applicable to metrics where higher values indicate problems, such as packet loss or latency). Values above this threshold trigger performance degradation alerts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmId rdf:type rdf:Property ;
    rdfs:label 'Alarm Id' ;
    rdfs:comment 'Primary key for alarm' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEnterpriseSiteId rdf:type rdf:Property ;
    rdfs:label 'Affected Enterprise Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.site. Business justification: Alarms affecting enterprise sites drive customer impact assessment and notification. Business process: enterprise customer notification, site-level fault correlation, and proactive outage communicatio' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:affectedNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element Id' ;
    rdfs:comment 'Foreign key reference to the network element (RAN node, OLT, BNG, BRAS, router, switch, etc.) that raised the alarm or is affected by the fault condition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:affectedSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Affected Subscriber Id' ;
    rdfs:comment 'Foreign key linking to customer.subscriber. Business justification: NOC subscriber impact analysis: when a VoLTE drop, data session failure, or RAN alarm fires, operators must identify the specific affected subscriber for proactive notification, SLA breach tracking, a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:triggeringConfigChangeId rdf:type rdf:Property ;
    rdfs:label 'Triggering Config Change Id' ;
    rdfs:comment 'Foreign key linking to network.config_change. Business justification: Configuration changes frequently trigger network alarms (service disruption, interface flap, routing instability). The config_change table has incident_reference as a STRING field, but a proper FK fro' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfigChange .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'The username or identifier of the NOC operator or engineer who acknowledged the alarm. Used for accountability and audit trail.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when the alarm was acknowledged by NOC staff. Used to measure response time from alarm raise to acknowledgement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Indicates whether the alarm has been acknowledged by NOC operations staff. Acknowledged alarms are under active investigation or remediation.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedNetworkElementType rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element Type' ;
    rdfs:comment 'Type or category of the affected network element (e.g., eNodeB, OLT, BNG, MPLS router, optical switch, DSLAM). Used for alarm categorization and routing to specialized support teams.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmCount rdf:type rdf:Property ;
    rdfs:label 'Alarm Count' ;
    rdfs:comment 'The number of times this specific alarm condition has been raised (for recurring alarms). A count greater than 1 indicates a flapping or intermittent fault condition.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmDescription rdf:type rdf:Property ;
    rdfs:label 'Alarm Description' ;
    rdfs:comment 'Detailed textual description of the alarm condition, including context, affected components, and potential impact. Sourced from the network element or enriched by the NMS.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmStatus rdf:type rdf:Property ;
    rdfs:label 'Alarm Status' ;
    rdfs:comment 'Current lifecycle status of the alarm indicating whether it is active, has been acknowledged by NOC staff, cleared by the network element, or administratively closed.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmType rdf:type rdf:Property ;
    rdfs:label 'Alarm Type' ;
    rdfs:comment 'Classification of the alarm indicating the nature of the fault or condition that triggered the alarm.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clear Timestamp' ;
    rdfs:comment 'The date and time when the alarm condition was resolved and the alarm was cleared by the network element or management system. Null if the alarm is still active.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Count' ;
    rdfs:comment 'The estimated or actual number of customer subscribers or accounts impacted by this alarm. Used for prioritization and customer communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The total duration in minutes from alarm raise to alarm clear. Used for MTTR (Mean Time to Repair) and SLA breach analysis. Null if the alarm is still active.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'The geographic location or site identifier of the affected network element. Used for dispatch routing and regional impact analysis.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOccurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Occurrence Timestamp' ;
    rdfs:comment 'The timestamp of the most recent occurrence of this alarm condition. Used for tracking recurring or flapping alarms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managedObjectClass rdf:type rdf:Property ;
    rdfs:label 'Managed Object Class' ;
    rdfs:comment 'The class or type of the managed object (network element, interface, card, port) that raised the alarm. Used for alarm filtering and routing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedObjectInstance rdf:type rdf:Property ;
    rdfs:label 'Managed Object Instance' ;
    rdfs:comment 'The specific instance identifier of the managed object that raised the alarm. Typically a distinguished name (DN) or object identifier (OID) from the network management system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDomain rdf:type rdf:Property ;
    rdfs:label 'Network Domain' ;
    rdfs:comment 'The high-level network domain or layer where the alarm originated (e.g., RAN, transport, core, access, edge, backhaul). Used for alarm routing to specialized NOC teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Notification Identifier' ;
    rdfs:comment 'Unique identifier for the alarm notification message as assigned by the originating system. Used for message tracking and deduplication.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probableCause rdf:type rdf:Property ;
    rdfs:label 'Probable Cause' ;
    rdfs:comment 'The probable cause of the alarm as reported by the network element or inferred by the management system. Examples include hardware failure, link failure, threshold breach, configuration error.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raise Timestamp' ;
    rdfs:comment 'The date and time when the alarm condition was first detected and raised by the network element or management system. Used as the start point for alarm duration and MTTR calculations.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAlarmFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Alarm Flag' ;
    rdfs:comment 'Boolean flag indicating whether this alarm has been identified as the root cause alarm in a correlated alarm set. True if this is the root cause; false if it is a secondary or consequential alarm.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Service Impact Level' ;
    rdfs:comment 'Assessment of the impact this alarm has on customer-facing services. Service down indicates complete outage; service degraded indicates reduced quality or capacity; no service impact indicates infrastructure redundancy absorbed the fault.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level of the alarm indicating the urgency and impact of the fault. Critical and major alarms typically require immediate attention and may trigger SLA breach monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachType rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Type' ;
    rdfs:comment 'The type of SLA breach associated with this alarm (e.g., availability breach, MTTR breach, performance degradation). Null if no SLA breach occurred.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceInterface rdf:type rdf:Property ;
    rdfs:label 'Source Interface' ;
    rdfs:comment 'The specific interface, protocol, or API through which the alarm was received (e.g., SNMP v2c, SNMP v3, Netconf, REST API, proprietary northbound interface).' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificProblem rdf:type rdf:Property ;
    rdfs:label 'Specific Problem' ;
    rdfs:comment 'Additional detail or vendor-specific code describing the specific problem or fault condition. Used for detailed diagnostics and vendor escalation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Execution Work Order Id' ;
    rdfs:comment 'Foreign key linking to workforce.work_order. Business justification: Telecom change management (ITIL) requires a work order to execute every planned maintenance outage. Linking planned_outage to its execution work_order enables outage-to-field-activity traceability, po' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:outageAgreementId rdf:type rdf:Property ;
    rdfs:label 'Outage Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: Contractual maintenance window compliance: planned outages on leased or vendor-managed infrastructure must reference the governing partner agreement to validate that the outage falls within contracted' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:outageVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Outage Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Vendor-executed maintenance accountability: planned outages performed by vendor engineers must link to the partner record for SLA exclusion processing, vendor performance tracking, and post-outage aud' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:responsibleTeamId rdf:type rdf:Property ;
    rdfs:label 'Responsible Team Id' ;
    rdfs:comment 'Foreign key linking to workforce.team. Business justification: Planned outages in telecom are executed by field teams, not just a lead technician. Team-level outage assignment drives workload planning, SLA accountability reports, and crew scheduling. The existing' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Estimated number of customers who will experience service impact during the planned outage, used for impact assessment and communication planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServiceIds rdf:type rdf:Property ;
    rdfs:label 'Affected Service Ids' ;
    rdfs:comment 'Comma-separated list of service identifiers that will experience degradation or interruption during the planned outage window.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Backup Verification Status' ;
    rdfs:comment 'Status of pre-outage configuration and data backup verification: verified (backups confirmed), not_verified (pending), not_required (no backup needed), failed (backup verification unsuccessful).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Status' ;
    rdfs:comment 'Status of Change Advisory Board review and approval for the planned outage: pending (awaiting review), approved (authorized to proceed), rejected (denied), not_required (low-risk standard change).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Timestamp' ;
    rdfs:comment 'Date and time when the Change Advisory Board approved the planned outage, establishing authorization to proceed.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Status of customer communication regarding the planned outage: not_sent (pending), scheduled (queued for delivery), sent (delivered), acknowledged (customer confirmed receipt), not_required (no customer impact).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Business impact classification of the planned outage based on customer count, service criticality, and revenue exposure: critical (major service disruption), high (significant impact), medium (moderate impact), low (minor impact), minimal (negligible impact).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Type' ;
    rdfs:comment 'Classification of the maintenance window: standard (regular scheduled window), emergency (urgent unplanned but scheduled), extended (longer than standard duration), recurring (repeating pattern).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Communication channel used to notify customers about the planned outage: email, SMS, customer portal, IVR (interactive voice response), push notification, or none if no notification required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageName rdf:type rdf:Property ;
    rdfs:label 'Outage Name' ;
    rdfs:comment 'Descriptive name or title of the planned outage for identification and reporting purposes.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageOutcome rdf:type rdf:Property ;
    rdfs:label 'Outage Outcome' ;
    rdfs:comment 'Final result of the planned outage execution: successful (all objectives met), partially_successful (some objectives met), failed (objectives not achieved), rolled_back (changes reverted), cancelled (aborted before execution).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageOutcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outage Outcome Notes' ;
    rdfs:comment 'Detailed notes documenting the planned outage execution results, issues encountered, lessons learned, and post-implementation observations.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReason rdf:type rdf:Property ;
    rdfs:label 'Outage Reason' ;
    rdfs:comment 'Detailed business justification and technical rationale for the planned outage, including objectives and expected outcomes.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Outage Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the planned outage, used for NOC coordination and customer communication.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageStatus rdf:type rdf:Property ;
    rdfs:label 'Outage Status' ;
    rdfs:comment 'Current lifecycle state of the planned outage: draft (initial planning), scheduled (time allocated), approved (CAB approved), in_progress (work underway), completed (successfully finished), cancelled (aborted before start), rolled_back (reverted due to issues). [ENUM-REF-CANDIDATE: draft|scheduled|approved|in_progress|completed|cancelled|rolled_back — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageType rdf:type rdf:Property ;
    rdfs:label 'Outage Type' ;
    rdfs:comment 'Classification of the planned outage activity: maintenance (routine upkeep), upgrade (software/hardware enhancement), decommission (element retirement), migration (platform/technology transition), testing (validation/acceptance), or emergency_planned (urgent but scheduled intervention).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'Expected duration of the planned outage maintenance window in minutes, calculated from planned start to planned end.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled date and time when the planned outage maintenance window is expected to conclude, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the planned outage maintenance window is expected to begin, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postOutageValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Post Outage Validation Status' ;
    rdfs:comment 'Status of post-outage testing and validation to confirm services are restored and functioning correctly: passed (validation successful), failed (issues detected), in_progress (testing underway), not_started (pending).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Description of the recurrence schedule for recurring planned outages (e.g., weekly, monthly, quarterly), null for one-time outages.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Level' ;
    rdfs:comment 'Pre-outage risk assessment classification based on complexity, customer impact, and technical risk: low (routine), medium (moderate risk), high (significant risk), critical (high-risk requiring executive approval).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Executed Flag' ;
    rdfs:comment 'Boolean indicator whether the rollback plan was executed during this planned outage (True = rollback performed, False = no rollback needed).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackPlanReference rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan Reference' ;
    rdfs:comment 'Reference identifier or document location for the rollback procedure to be executed if the planned outage encounters critical issues requiring service restoration to previous state.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Exclusion Flag' ;
    rdfs:comment 'Boolean indicator whether this planned outage window is excluded from SLA availability calculations (True = excluded from SLA, False = counted against SLA).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaNotificationLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Notification Lead Time Hours' ;
    rdfs:comment 'Number of hours advance notice provided to customers before the planned outage, used to verify compliance with SLA notification requirements.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorEngineerName rdf:type rdf:Property ;
    rdfs:label 'Vendor Engineer Name' ;
    rdfs:comment 'Name of the vendor engineer or technician supporting the planned outage execution, if vendor support is required.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableNetworkDomain rdf:type rdf:Property ;
    rdfs:label 'Applicable Network Domain' ;
    rdfs:comment 'Network domain where this QoS profile is enforced. RAN for radio access network, Core for packet core (EPC/5GC), Transport for IP/MPLS backhaul, All for end-to-end enforcement.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTechnology rdf:type rdf:Property ;
    rdfs:label 'Applicable Technology' ;
    rdfs:comment 'Network technology or service platform where this QoS profile is applicable. Supports LTE, 5G NR, VoLTE, IMS, MPLS, SD-WAN and other technology-specific QoS implementations.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Arp Priority Level' ;
    rdfs:comment 'Allocation and Retention Priority level (1-15) used for admission control decisions. Lower values indicate higher priority for resource allocation and retention.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averagingWindowMs rdf:type rdf:Property ;
    rdfs:label 'Averaging Window Ms' ;
    rdfs:comment 'Time window in milliseconds over which bit rate guarantees and measurements are averaged for GBR bearers. Used for traffic policing and shaping calculations.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burstSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Burst Size Bytes' ;
    rdfs:comment 'Maximum burst size in bytes allowed for traffic shaping token bucket algorithm. Defines how much traffic can exceed the sustained rate in short bursts.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationTemplate rdf:type rdf:Property ;
    rdfs:label 'Configuration Template' ;
    rdfs:comment 'Reference to the network configuration template or policy map used to implement this QoS profile across network elements (NMS/EMS template identifier).' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congestionNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Congestion Notification Enabled' ;
    rdfs:comment 'Indicates whether Explicit Congestion Notification is enabled for this QoS profile to signal network congestion without dropping packets.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dscpValue rdf:type rdf:Property ;
    rdfs:label 'Dscp Value' ;
    rdfs:comment '6-bit DSCP marking value (0-63) used in IP packet headers for traffic classification and priority treatment in IP transport and MPLS networks.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiveQiValue rdf:type rdf:Property ;
    rdfs:label 'Five Qi Value' ;
    rdfs:comment '5G QoS Identifier scalar value (1-85 standardized, 128-254 operator-specific) that defines QoS characteristics for 5G NR bearers including resource type, priority level, packet delay budget, and packet error rate.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedBitRateDownlinkKbps rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Bit Rate Downlink Kbps' ;
    rdfs:comment 'Minimum downlink bit rate in kbps that the network guarantees to provide for GBR bearers. Null for non-GBR profiles.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedBitRateUplinkKbps rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Bit Rate Uplink Kbps' ;
    rdfs:comment 'Minimum uplink bit rate in kbps that the network guarantees to provide for GBR bearers. Null for non-GBR profiles.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBitRateDownlinkKbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Bit Rate Downlink Kbps' ;
    rdfs:comment 'Maximum downlink bit rate in kbps that the bearer is allowed to utilize. Used for traffic shaping and policing to prevent bandwidth oversubscription.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBitRateUplinkKbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Bit Rate Uplink Kbps' ;
    rdfs:comment 'Maximum uplink bit rate in kbps that the bearer is allowed to utilize. Used for traffic shaping and policing to prevent bandwidth oversubscription.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this QoS profile record for audit trail purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkQosProfileDescription rdf:type rdf:Property ;
    rdfs:label 'Network Qos Profile Description' ;
    rdfs:comment 'Detailed description of the QoS profile including its intended use cases, traffic characteristics, and configuration rationale.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetDelayBudgetMs rdf:type rdf:Property ;
    rdfs:label 'Packet Delay Budget Ms' ;
    rdfs:comment 'Maximum allowable one-way packet delay in milliseconds from UE to gateway for this QoS profile. Critical for real-time services like VoLTE and video conferencing.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetErrorRate rdf:type rdf:Property ;
    rdfs:label 'Packet Error Rate' ;
    rdfs:comment 'Maximum acceptable packet error rate expressed as a decimal fraction (e.g., 0.000001 for 10^-6). Defines the upper bound for packet loss tolerance for this QoS class.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionCapability rdf:type rdf:Property ;
    rdfs:label 'Preemption Capability' ;
    rdfs:comment 'Indicates whether this QoS profile can trigger preemption of lower-priority bearers during resource congestion to establish or maintain its own bearer.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionVulnerability rdf:type rdf:Property ;
    rdfs:label 'Preemption Vulnerability' ;
    rdfs:comment 'Indicates whether bearers using this QoS profile can be preempted by higher-priority bearers during resource congestion.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business code or identifier for the QoS profile used in network configuration and provisioning systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the QoS profile used for identification and configuration purposes across network management systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the QoS profile. Active profiles are in production use, Inactive are disabled, Deprecated are scheduled for removal, Testing are under validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qciValue rdf:type rdf:Property ;
    rdfs:label 'Qci Value' ;
    rdfs:comment 'QoS Class Identifier for LTE networks, a scalar value (1-9 standardized, 128-254 operator-specific) that defines bearer-level QoS characteristics including priority, packet delay budget, and packet error loss rate.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficShapingEnabled rdf:type rdf:Property ;
    rdfs:label 'Traffic Shaping Enabled' ;
    rdfs:comment 'Indicates whether traffic shaping is enabled for this QoS profile to smooth traffic bursts and enforce maximum bit rate limits.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorSpecificParameters rdf:type rdf:Property ;
    rdfs:label 'Vendor Specific Parameters' ;
    rdfs:comment 'JSON or key-value string containing vendor-specific QoS parameters for Nokia, Ericsson, or other equipment vendors that extend standard 3GPP QoS attributes.' ;
    rdfs:domain ind:QosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Installation Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: CPE installation at customer premises is performed by field technicians. Tracking installer supports customer satisfaction analysis, first-time-fix rate calculation, and technician performance evaluat' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:stagingDepotId rdf:type rdf:Property ;
    rdfs:label 'Staging Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: CPE assets are staged at depots before technician pickup and installation, and returned to depots after retrieval. Depot-level CPE inventory tracking is essential for telecom field logistics, stock re' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: CPE devices are procured under specific partner supply agreements governing pricing, warranty terms, and return conditions. Telecom procurement and warranty management processes require linking each C' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the CPE device was assigned to the current subscriber or service.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current assignment and operational status of the CPE device in the inventory lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of CPE device indicating its primary function in the customer network.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware version installed on the CPE device. Critical for security patching and feature management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareVersion rdf:type rdf:Property ;
    rdfs:label 'Hardware Version' ;
    rdfs:comment 'Hardware revision or version of the CPE device as specified by the manufacturer.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is5gCapable rdf:type rdf:Property ;
    rdfs:label 'Is 5g Capable' ;
    rdfs:comment 'Indicates whether the CPE device supports 5G New Radio (NR) connectivity.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWifi6Capable rdf:type rdf:Property ;
    rdfs:label 'Is Wifi6 Capable' ;
    rdfs:comment 'Indicates whether the CPE device supports Wi-Fi 6 (802.11ax) standard.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalCondition rdf:type rdf:Property ;
    rdfs:label 'Physical Condition' ;
    rdfs:comment 'Assessment of the physical condition of the CPE device. Used for redeployment decisions and asset valuation.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCount rdf:type rdf:Property ;
    rdfs:label 'Port Count' ;
    rdfs:comment 'Number of physical Ethernet ports available on the CPE device.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when the CPE device was procured or purchased by the telecommunications company.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number associated with the procurement of this CPE device.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the CPE device was retired from active inventory and marked for disposal or recycling.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the CPE device was returned by the customer to the company inventory.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Username or identifier of the user who last updated this CPE asset record.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer warranty coverage begins for the CPE device.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current status of the manufacturer warranty for the CPE device.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiPassword rdf:type rdf:Property ;
    rdfs:label 'Wifi Password' ;
    rdfs:comment 'Default or configured Wi-Fi password for CPE devices with Wi-Fi capability. Encrypted at rest.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiSsid rdf:type rdf:Property ;
    rdfs:label 'Wifi Ssid' ;
    rdfs:comment 'Default or configured SSID for CPE devices with Wi-Fi capability.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDeviceModelId rdf:type rdf:Property ;
    rdfs:label 'Target Device Model Id' ;
    rdfs:comment 'Foreign key linking to product.device_model. Business justification: eSIM profiles and physical SIMs are pre-configured for specific device models (iPhone 14, Samsung Galaxy S23). Critical for activation workflows, compatibility validation, and inventory allocation in ' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceModel .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Date and time when the SIM stock unit was activated and provisioned for service. Marks the transition to in-service status.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationCode rdf:type rdf:Property ;
    rdfs:label 'Activation Code' ;
    rdfs:comment 'Unique activation code or QR code string used by the end user to download and install the eSIM profile. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle status of the SIM stock unit: unallocated (in warehouse), reserved (allocated to order), activated (in service), suspended (temporarily disabled), deactivated (service terminated), or retired (end of life).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when the SIM stock unit was allocated or reserved for a specific order or subscriber. Marks the transition from unallocated to reserved status.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturing or provisioning batch identifier for grouping SIM cards or eSIM profiles. Used for quality control, recall management, and inventory tracking.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or rack location within the warehouse for physical SIM card storage. Enables precise inventory picking and cycle counting. Null for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Date and time when the SIM stock unit was deactivated and removed from service. Marks the end of the active service lifecycle.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Download Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was downloaded from the SM-DP+ platform to the target device. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eid rdf:type rdf:Property ;
    rdfs:label 'Eid' ;
    rdfs:comment '32-digit unique identifier for the embedded Universal Integrated Circuit Card (eUICC). Only applicable for eSIM profiles. Null for physical SIM cards.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimProfileState rdf:type rdf:Property ;
    rdfs:label 'Esim Profile State' ;
    rdfs:comment 'State of the eSIM profile on the SM-DP+ platform: available (ready for download), downloaded (transferred to device), installed (on eUICC), enabled (active), disabled (inactive), or deleted (removed). Only applicable for eSIM profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form factor of the SIM card: 2FF (Mini-SIM), 3FF (Micro-SIM), 4FF (Nano-SIM), MFF2 (M2M form factor), or embedded (eSIM). Null for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsiRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Imsi Range End' ;
    rdfs:comment 'Ending IMSI number in the range allocated to this SIM stock batch. Defines the upper boundary of the IMSI allocation for inventory management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsiRangeStart rdf:type rdf:Property ;
    rdfs:label 'Imsi Range Start' ;
    rdfs:comment 'Starting IMSI number in the range allocated to this SIM stock batch. 15-digit identifier used for subscriber authentication in mobile networks.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestSim rdf:type rdf:Property ;
    rdfs:label 'Is Test Sim' ;
    rdfs:comment 'Flag indicating whether this SIM stock unit is designated for testing, lab use, or quality assurance purposes. True for test SIMs, false for production SIMs.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiValue rdf:type rdf:Property ;
    rdfs:label 'Ki Value' ;
    rdfs:comment '128-bit secret authentication key stored on the SIM card for network authentication. Highly sensitive cryptographic material. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date when the physical SIM card was manufactured or the eSIM profile was generated on the SM-DP+ platform.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opcValue rdf:type rdf:Property ;
    rdfs:label 'Opc Value' ;
    rdfs:comment '128-bit operator-specific variant of the authentication algorithm configuration. Used in conjunction with Ki for LTE/5G authentication. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pin1 rdf:type rdf:Property ;
    rdfs:label 'Pin1' ;
    rdfs:comment '4-8 digit PIN code for SIM card access control. Required for device unlock and SIM operations. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Business classification of the SIM profile: consumer (handset), M2M (machine-to-machine), IoT (Internet of Things), enterprise (corporate), test (lab/QA), or bootstrap (initial provisioning).' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:puk1 rdf:type rdf:Property ;
    rdfs:label 'Puk1' ;
    rdfs:comment '8-digit PIN Unblocking Key used to reset PIN1 after multiple failed attempts. Critical for customer self-service. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Quality Check Date' ;
    rdfs:comment 'Date when the quality assurance check was completed. Used for compliance tracking and inventory release management.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of the quality assurance check performed on the SIM stock: pending (awaiting inspection), passed (approved for use), failed (rejected), or not_required (no QA needed).' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the SIM stock was received into the warehouse or provisioned on the SM-DP+ platform. Marks the start of inventory availability.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simType rdf:type rdf:Property ;
    rdfs:label 'Sim Type' ;
    rdfs:comment 'Type of SIM card: physical SIM card or eSIM profile. Determines the inventory management and provisioning workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smdpAddress rdf:type rdf:Property ;
    rdfs:label 'Smdp Address' ;
    rdfs:comment 'Fully qualified domain name (FQDN) of the Subscription Manager Data Preparation Plus (SM-DP+) server hosting the eSIM profile. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Per-unit cost of the SIM card or eSIM profile in the operator\'s base currency. Used for inventory valuation and CAPEX tracking.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Name of the configuration profile or template applied to this ONT for service provisioning and feature enablement.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceFromOltMeters rdf:type rdf:Property ;
    rdfs:label 'Distance From Olt Meters' ;
    rdfs:comment 'Physical fiber distance in meters between the OLT and this ONT, calculated from optical signal propagation delay.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gponPortReference rdf:type rdf:Property ;
    rdfs:label 'Gpon Port Reference' ;
    rdfs:comment 'Unique GPON identifier assigned to the ONT for authentication and provisioning in the PON network.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFirmwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Firmware Update Date' ;
    rdfs:comment 'Date when the ONT firmware was last updated or patched.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOnlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Online Timestamp' ;
    rdfs:comment 'Timestamp of the last successful connection and communication between the ONT and OLT.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDownstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Downstream Bandwidth Mbps' ;
    rdfs:comment 'Maximum downstream bandwidth capacity in megabits per second that this ONT device supports.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUpstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Upstream Bandwidth Mbps' ;
    rdfs:comment 'Maximum upstream bandwidth capacity in megabits per second that this ONT device supports.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oltPortNumber rdf:type rdf:Property ;
    rdfs:label 'Olt Port Number' ;
    rdfs:comment 'Physical port identifier on the OLT device where this ONT is connected, typically in shelf/slot/port format.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalPowerRxDbm rdf:type rdf:Property ;
    rdfs:label 'Optical Power Rx Dbm' ;
    rdfs:comment 'Received optical power level at the ONT in decibels relative to one milliwatt (dBm). Critical for signal quality monitoring.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opticalPowerTxDbm rdf:type rdf:Property ;
    rdfs:label 'Optical Power Tx Dbm' ;
    rdfs:comment 'Transmitted optical power level from the ONT in decibels relative to one milliwatt (dBm). Used for upstream signal quality assessment.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebootCount rdf:type rdf:Property ;
    rdfs:label 'Reboot Count' ;
    rdfs:comment 'Total number of times the ONT device has been rebooted since installation. Used for stability analysis.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteManagementEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Management Enabled Flag' ;
    rdfs:comment 'Indicates whether remote management and configuration capabilities are enabled on this ONT device.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Current operating temperature of the ONT device in degrees Celsius, monitored for thermal management.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uptimeHours rdf:type rdf:Property ;
    rdfs:label 'Uptime Hours' ;
    rdfs:comment 'Total number of hours the ONT has been continuously operational since last reboot or power cycle.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voipCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Voip Capability Flag' ;
    rdfs:comment 'Indicates whether the ONT device supports VoIP telephony services with integrated analog telephone adapters.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Warehouse or storage facility location code where the ONT is stored when not deployed. Null if currently deployed.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Wifi Capability Flag' ;
    rdfs:comment 'Indicates whether the ONT device has integrated WiFi capability for wireless connectivity.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: OLT assets have maintenance_contract_code (denormalized text) indicating a partner maintenance agreement exists. Linking to partner.agreement enables maintenance SLA enforcement, contract renewal trac' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:maintenanceSlaContractId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Sla Contract Id' ;
    rdfs:comment 'Foreign key linking to assurance.sla_contract. Business justification: OLT assets are covered by vendor maintenance SLA contracts with MTTR guarantees critical for fiber network reliability. Linking olt_asset to sla_contract supports vendor SLA breach tracking, maintenan' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaContract .

ind:managingDepotId rdf:type rdf:Property ;
    rdfs:label 'Managing Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: OLT assets are managed and maintained from specific regional depots. Telecom network operations require knowing which depot is responsible for OLT maintenance scheduling, spare parts provisioning, and' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:parentOltAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Olt Asset Id' ;
    rdfs:comment 'Reference to the backup or standby OLT asset configured for failover protection of this primary OLT.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OltAsset .

ind:activePonPorts rdf:type rdf:Property ;
    rdfs:label 'Active Pon Ports' ;
    rdfs:comment 'Number of PON ports currently in active operational use serving subscriber ONTs.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chassisType rdf:type rdf:Property ;
    rdfs:label 'Chassis Type' ;
    rdfs:comment 'Physical form factor classification of the OLT chassis hardware.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOntCount rdf:type rdf:Property ;
    rdfs:label 'Current Ont Count' ;
    rdfs:comment 'Current number of ONT devices actively registered and connected to this OLT in the network.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalTemperatureRatingCelsius rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature Rating Celsius' ;
    rdfs:comment 'Rated operating temperature range specification for the OLT hardware in Celsius degrees.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedLineCards rdf:type rdf:Property ;
    rdfs:label 'Installed Line Cards' ;
    rdfs:comment 'Current number of PON line cards physically installed in the OLT chassis slots.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineCardSlots rdf:type rdf:Property ;
    rdfs:label 'Line Card Slots' ;
    rdfs:comment 'Total number of physical slots available in the OLT chassis for installing PON line cards.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxOntCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Ont Capacity' ;
    rdfs:comment 'Maximum theoretical number of ONT devices that can be supported by this OLT based on hardware specifications and port capacity.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average operational time between hardware failures for this OLT, used for reliability and availability planning.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time required to restore the OLT to operational status following a failure event.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snmpCommunityString rdf:type rdf:Property ;
    rdfs:label 'Snmp Community String' ;
    rdfs:comment 'SNMP authentication string used for secure management access to the OLT device via network management systems.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPonPorts rdf:type rdf:Property ;
    rdfs:label 'Total Pon Ports' ;
    rdfs:comment 'Total number of PON ports available on the OLT chassis across all installed line cards for downstream fiber connectivity.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uplinkInterfaceType rdf:type rdf:Property ;
    rdfs:label 'Uplink Interface Type' ;
    rdfs:comment 'Type of network interface used for uplink connectivity from the OLT to the core aggregation or metro network.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkPortCount rdf:type rdf:Property ;
    rdfs:label 'Uplink Port Count' ;
    rdfs:comment 'Number of uplink ports available on the OLT for connectivity to upstream network infrastructure.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Termination Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Fiber cables terminate at network elements (OLT, ODF, DWDM terminal). Logical-to-physical mapping for circuit provisioning, port assignment, and fault isolation requires linking physical fiber to term' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:assignedFiberCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Fiber Count' ;
    rdfs:comment 'Number of fibers currently allocated to active services or reserved for planned deployments. Used for utilization tracking and capacity management.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attenuationDbPerKm rdf:type rdf:Property ;
    rdfs:label 'Attenuation Db Per Km' ;
    rdfs:comment 'Signal loss measurement in decibels per kilometer. Critical QoS metric for network planning and service quality assurance.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableFiberCount rdf:type rdf:Property ;
    rdfs:label 'Available Fiber Count' ;
    rdfs:comment 'Number of unused (dark) fibers available for new service provisioning. Calculated as total fiber count minus assigned fibers. Critical for capacity planning.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cableCode rdf:type rdf:Property ;
    rdfs:label 'Cable Code' ;
    rdfs:comment 'Externally-known unique identifier for the fiber cable segment used in field operations, engineering drawings, and OSP documentation.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cableType rdf:type rdf:Property ;
    rdfs:label 'Cable Type' ;
    rdfs:comment 'Classification of the fiber optic cable based on transmission mode and construction. Single-mode for long-haul, multi-mode for short-distance, ribbon for high-density, hybrid for mixed applications.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conduitFillRatioPercent rdf:type rdf:Property ;
    rdfs:label 'Conduit Fill Ratio Percent' ;
    rdfs:comment 'Percentage of conduit cross-sectional area occupied by cables. Industry best practice limits fill to 60-70% to allow for future expansion and cable movement. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conduitInnerDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Conduit Inner Diameter Mm' ;
    rdfs:comment 'Internal diameter of the conduit in millimeters. Used for calculating fill ratio and determining additional cable placement capacity. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conduitMaterialType rdf:type rdf:Property ;
    rdfs:label 'Conduit Material Type' ;
    rdfs:comment 'Material composition of the conduit housing the fiber cable. HDPE (High-Density Polyethylene) is standard for modern installations. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentMethod rdf:type rdf:Property ;
    rdfs:label 'Deployment Method' ;
    rdfs:comment 'Installation technique used for the fiber cable segment. Determines maintenance procedures, access requirements, and environmental exposure.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endLocationGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'End Location Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cable segment ending point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endLocationGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'End Location Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cable segment ending point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'Classification of the deployment environment affecting cable specifications and maintenance requirements. Coastal zones require corrosion-resistant materials, mountainous terrain affects accessibility.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberCount rdf:type rdf:Property ;
    rdfs:label 'Fiber Count' ;
    rdfs:comment 'Total number of individual optical fibers contained within the cable. Critical for capacity planning and strand-level inventory management.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireRating rdf:type rdf:Property ;
    rdfs:label 'Fire Rating' ;
    rdfs:comment 'Fire safety classification of the cable sheath. OFNR (Optical Fiber Non-conductive Riser), OFNP (Plenum), OFCP (Conductive Plenum), LSZH (Low Smoke Zero Halogen). Required for building code compliance.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Entity responsible for ongoing maintenance and repair of the fiber cable segment. Determines escalation procedures and cost allocation for fault resolution.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s catalog or part number for the specific cable model. Used for procurement, spare parts ordering, and technical specification lookup.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required inspection based on maintenance policies and regulatory requirements. Used for work order planning.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightOfWayPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Right Of Way Permit Number' ;
    rdfs:comment 'Government or municipal permit number authorizing the cable installation in public or private right-of-way. Required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Route Length Meters' ;
    rdfs:comment 'Physical length of the fiber cable segment measured in meters along the deployment route. Used for attenuation calculations and material inventory.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sheathType rdf:type rdf:Property ;
    rdfs:label 'Sheath Type' ;
    rdfs:comment 'Outer protective jacket material of the fiber cable. Determines environmental resistance, fire safety compliance, and installation method suitability.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splicePointCount rdf:type rdf:Property ;
    rdfs:label 'Splice Point Count' ;
    rdfs:comment 'Number of splice enclosures or splice points along this cable segment. Each splice introduces potential signal loss and maintenance access points.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startLocationGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cable segment starting point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cable segment starting point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRatingMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Max Celsius' ;
    rdfs:comment 'Maximum operating temperature in Celsius for the fiber cable. Critical for deployments in extreme climates to ensure signal integrity.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRatingMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Min Celsius' ;
    rdfs:comment 'Minimum operating temperature in Celsius for the fiber cable. Critical for deployments in extreme climates to ensure signal integrity.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPoolIpAddressPoolId rdf:type rdf:Property ;
    rdfs:label 'Parent Pool Ip Address Pool Id' ;
    rdfs:comment 'Reference to parent pool if this is a sub-pool carved from a larger allocation. Enables hierarchical pool management and delegation.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:allocationPolicy rdf:type rdf:Property ;
    rdfs:label 'Allocation Policy' ;
    rdfs:comment 'Strategy for assigning resources from this pool. Sequential for ordered assignment, random for load distribution, least-used for utilization balancing.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Count' ;
    rdfs:comment 'Current number of resources actively assigned from this pool. Updated in near-real-time as assignments and releases occur.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentScope rdf:type rdf:Property ;
    rdfs:label 'Assignment Scope' ;
    rdfs:comment 'Type of entity that resources from this pool are assigned to. Subscriber for end-user accounts, CPE for customer equipment, network node for infrastructure.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCount rdf:type rdf:Property ;
    rdfs:label 'Available Count' ;
    rdfs:comment 'Current number of unassigned resources available for allocation. Calculated as total_capacity minus assigned_count minus reserved_count.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cgnatRatio rdf:type rdf:Property ;
    rdfs:label 'Cgnat Ratio' ;
    rdfs:comment 'Number of subscribers sharing each public IP address in CGNAT pools. Typical ratios range from 16:1 to 256:1 depending on service type and usage patterns.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cidrBlock rdf:type rdf:Property ;
    rdfs:label 'Cidr Block' ;
    rdfs:comment 'CIDR notation for IP address pools (e.g., 10.0.0.0/16 for IPv4, 2001:db8::/32 for IPv6). Null for non-IP resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Financial cost center code for charging pool-related expenses (IP address leasing fees, equipment costs). Used for chargeback and financial reporting.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLeaseDurationHours rdf:type rdf:Property ;
    rdfs:label 'Default Lease Duration Hours' ;
    rdfs:comment 'Default lease duration in hours for dynamic assignments from this pool. Applies to DHCP leases and temporary allocations. Null for static pools.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encapsulationType rdf:type rdf:Property ;
    rdfs:label 'Encapsulation Type' ;
    rdfs:comment 'Network encapsulation protocol used for this resource pool. 802.1Q for single VLAN tagging, QinQ for double tagging, VXLAN for overlay networks, EVPN for BGP-based VPN.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWatermarkThreshold rdf:type rdf:Property ;
    rdfs:label 'High Watermark Threshold' ;
    rdfs:comment 'Utilization percentage threshold that triggers capacity alerts. Typically 80-90% to allow time for pool expansion before depletion.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCgnatEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Cgnat Enabled' ;
    rdfs:comment 'Indicates whether this pool is used for CGNAT (Carrier-Grade NAT) to share public IPs across multiple subscribers. Common for IPv4 conservation.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLawfulInterceptEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Lawful Intercept Enabled' ;
    rdfs:comment 'Indicates whether assignments from this pool are subject to lawful intercept logging and monitoring requirements per regulatory mandates.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicRoutable rdf:type rdf:Property ;
    rdfs:label 'Is Public Routable' ;
    rdfs:comment 'Indicates whether IP addresses in this pool are publicly routable on the internet (true) or private/RFC1918 addresses (false).' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Assignment Timestamp' ;
    rdfs:comment 'Timestamp of the most recent resource assignment from this pool. Used for activity tracking and idle pool identification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Release Timestamp' ;
    rdfs:comment 'Timestamp of the most recent resource release back to this pool. Used for churn analysis and capacity reclamation tracking.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lowWatermarkThreshold rdf:type rdf:Property ;
    rdfs:label 'Low Watermark Threshold' ;
    rdfs:comment 'Utilization percentage threshold below which the pool is considered underutilized. Used for resource optimization and consolidation decisions.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkZone rdf:type rdf:Property ;
    rdfs:label 'Network Zone' ;
    rdfs:comment 'Network architecture layer where this pool is deployed. Core for backbone, edge for distribution, access for last-mile, data center for cloud services. [ENUM-REF-CANDIDATE: core|edge|access|aggregation|metro|data_center|customer_premises — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Unique business identifier or code for the pool, used in operational systems and external references.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name or label for the IP address pool, used for identification and operational reference.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolOwner rdf:type rdf:Property ;
    rdfs:label 'Pool Owner' ;
    rdfs:comment 'Business unit, department, or team responsible for managing this pool. Used for accountability and operational ownership.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the pool. Active pools are available for assignment, depleted pools have no available resources, quarantined pools are temporarily blocked.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory designation for this pool. Lawful intercept pools require logging for law enforcement, emergency services pools have priority routing requirements.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedCount rdf:type rdf:Property ;
    rdfs:label 'Reserved Count' ;
    rdfs:comment 'Number of resources reserved for future use or specific purposes (e.g., network infrastructure, management, emergency services).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingDomain rdf:type rdf:Property ;
    rdfs:label 'Routing Domain' ;
    rdfs:comment 'Routing domain or VRF (Virtual Routing and Forwarding) instance this pool belongs to. Enables network segmentation and multi-tenancy.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Vlan Range End' ;
    rdfs:comment 'Ending VLAN ID for VLAN pool resources. Must be greater than or equal to vlan_range_start. Null for non-VLAN resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vlanRangeStart rdf:type rdf:Property ;
    rdfs:label 'Vlan Range Start' ;
    rdfs:comment 'Starting VLAN ID for VLAN pool resources. Valid range 1-4094 per IEEE 802.1Q. Null for non-VLAN resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hlrNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Hlr Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: msisdn_range.hlr_reference: STRING is a denormalized string reference to the HLR (Home Location Register) or HSS (Home Subscriber Server) network equipment node that routes calls/data for numbers in t' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:allocationAuthority rdf:type rdf:Property ;
    rdfs:label 'Allocation Authority' ;
    rdfs:comment 'Name of the regulatory body or numbering authority that allocated this number range to the operator.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date when this number range was officially allocated to the telecommunications operator by the regulatory authority.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockSize rdf:type rdf:Property ;
    rdfs:label 'Block Size' ;
    rdfs:comment 'Standard block size or increment in which numbers from this range are typically allocated or reserved for operational efficiency.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Per Number' ;
    rdfs:comment 'Regulatory fee or cost per individual number in this range charged by the numbering authority for allocation and maintenance.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endNumber rdf:type rdf:Property ;
    rdfs:label 'End Number' ;
    rdfs:comment 'The last MSISDN or DID number in the allocated range. Must comply with ITU-T E.164 international numbering format.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeallocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Deallocation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent number deallocation or return transaction from a subscriber back to available inventory.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ndc rdf:type rdf:Property ;
    rdfs:label 'Ndc' ;
    rdfs:comment 'National destination code or area code portion of the number range. Used for geographic or network routing within the country.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Network Operator Code' ;
    rdfs:comment 'Code identifying the network operator or Mobile Virtual Network Operator (MVNO) to which this range is assigned.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberFormatMask rdf:type rdf:Property ;
    rdfs:label 'Number Format Mask' ;
    rdfs:comment 'Display format mask or template for presenting numbers from this range to end users in customer-facing systems and billing documents.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Porting Eligible Flag' ;
    rdfs:comment 'Indicates whether numbers in this range are eligible for mobile number portability per national MNP regulations.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantinePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Quarantine Period Days' ;
    rdfs:comment 'Mandatory cooling-off period in days that numbers from this range must remain quarantined after deallocation before becoming available for reassignment per regulatory requirements.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantinedCount rdf:type rdf:Property ;
    rdfs:label 'Quarantined Count' ;
    rdfs:comment 'Count of numbers in quarantine status awaiting release per regulatory cooling-off period after deallocation.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rangeCode rdf:type rdf:Property ;
    rdfs:label 'Range Code' ;
    rdfs:comment 'Business identifier code for the number range allocation. Used for external reference and operational tracking.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeStatus rdf:type rdf:Property ;
    rdfs:label 'Range Status' ;
    rdfs:comment 'Current lifecycle status of the number range indicating its availability and operational state.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeType rdf:type rdf:Property ;
    rdfs:label 'Range Type' ;
    rdfs:comment 'Classification of the number range indicating its purpose and usage category within the telecommunications network.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPrefix rdf:type rdf:Property ;
    rdfs:label 'Routing Prefix' ;
    rdfs:comment 'Network routing prefix used for call routing and signaling for numbers in this range within the telecommunications infrastructure.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text description of any special regulatory conditions, restrictions, or usage requirements imposed on this number range by the numbering authority.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startNumber rdf:type rdf:Property ;
    rdfs:label 'Start Number' ;
    rdfs:comment 'The first MSISDN or DID number in the allocated range. Must comply with ITU-T E.164 international numbering format.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCategory rdf:type rdf:Property ;
    rdfs:label 'Usage Category' ;
    rdfs:comment 'Business classification indicating the intended customer segment or usage purpose for numbers in this range.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the asset lifecycle event record. Primary key.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringAlarmEventId rdf:type rdf:Property ;
    rdfs:label 'Triggering Alarm Event Id' ;
    rdfs:comment 'Foreign key linking to assurance.alarm_event. Business justification: Asset state changes (decommission, replacement, emergency swap) are often triggered by specific alarm events. Linking asset_lifecycle_event to alarm_event supports tracing asset decisions back to the ' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlarmEvent .

ind:actualCount rdf:type rdf:Property ;
    rdfs:label 'Actual Count' ;
    rdfs:comment 'Actual quantity of assets found during the physical audit or cycle count. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this lifecycle event required managerial or system approval before execution (e.g., write-off events typically require approval). True if approval was required, False otherwise.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Category or class of the asset involved in this event (e.g., CPE, ONT, OLT, fiber-cable, spare-part). Used for audit and reporting segmentation. [ENUM-REF-CANDIDATE: CPE|ONT|OLT|fiber-cable|network-equipment|spare-part|SIM|eSIM|test-equipment|tools — promote to reference product]' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Financial impact of this lifecycle event in the base currency (e.g., asset acquisition cost for procurement, write-off amount for decommission, repair cost). Nullable for non-financial events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the lifecycle event (e.g., reason for swap, repair details, audit findings).' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the lifecycle event occurred in the real world (e.g., when the asset was deployed, swapped, or decommissioned). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCount rdf:type rdf:Property ;
    rdfs:label 'Expected Count' ;
    rdfs:comment 'Expected quantity of assets at the audited location or category based on system records. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationAction rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Action' ;
    rdfs:comment 'Action taken to resolve the inventory variance (e.g., write-off for lost assets, adjustment to correct system records, investigation for unresolved discrepancies). Applicable only for reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Unique transaction or event identifier from the source system. Used for traceability and idempotency in data integration.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between expected and actual count (actual_count minus expected_count). Positive indicates surplus, negative indicates shortage. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Root cause or reason for the inventory variance identified during audit or reconciliation. Applicable only for audit and reconciliation events. [ENUM-REF-CANDIDATE: theft|damage|data-entry-error|unreported-deployment|unreported-return|obsolescence|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrativeStatus rdf:type rdf:Property ;
    rdfs:label 'Administrative Status' ;
    rdfs:comment 'Administrative control state indicating whether the equipment is permitted to provide service. UNLOCKED (allowed to operate), LOCKED (administratively disabled), SHUTTING_DOWN (graceful shutdown in progress).' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateControlRequired rdf:type rdf:Property ;
    rdfs:label 'Climate Control Required' ;
    rdfs:comment 'Indicates whether the equipment requires temperature and humidity-controlled environment. True for most indoor equipment, false for outdoor-hardened units.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the physical equipment unit. Used for warranty tracking, maintenance history, and asset identification.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Equipment Subtype' ;
    rdfs:comment 'Detailed equipment classification within the type category. Examples: eNodeB, gNodeB, BNG, BRAS, MPLS_ROUTER, SD_WAN_EDGE, IMS_CSCF, HSS, UDM, PCF, DSLAM, OLT_GPON, OLT_XGS_PON, RECTIFIER, BATTERY_BANK.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareRevision rdf:type rdf:Property ;
    rdfs:label 'Hardware Revision' ;
    rdfs:comment 'Hardware revision or version code assigned by the manufacturer. Used to track component changes and compatibility.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostname rdf:type rdf:Property ;
    rdfs:label 'Hostname' ;
    rdfs:comment 'Fully qualified domain name (FQDN) or hostname assigned to the equipment for network identification and DNS resolution.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPowerDrawWatts rdf:type rdf:Property ;
    rdfs:label 'Max Power Draw Watts' ;
    rdfs:comment 'Maximum power consumption in watts under peak load conditions. Critical for power supply sizing and cooling requirements.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkFunction rdf:type rdf:Property ;
    rdfs:label 'Network Function' ;
    rdfs:comment 'Primary network function or service role performed by the equipment. Examples: PACKET_CORE, VOICE_SWITCHING, BROADBAND_AGGREGATION, RADIO_ACCESS, TRANSPORT_ROUTING, POLICY_CONTROL.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity based on vendor recommendations or organizational policy.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max Celsius' ;
    rdfs:comment 'Maximum ambient temperature in Celsius at which the equipment can operate within specifications. Used for cooling system design.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min Celsius' ;
    rdfs:comment 'Minimum ambient temperature in Celsius at which the equipment can operate within specifications. Critical for outdoor and remote site deployments.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portCapacityGbps rdf:type rdf:Property ;
    rdfs:label 'Port Capacity Gbps' ;
    rdfs:comment 'Aggregate throughput capacity across all ports in gigabits per second (Gbps). Used for capacity planning and traffic engineering.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerDrawWatts rdf:type rdf:Property ;
    rdfs:label 'Power Draw Watts' ;
    rdfs:comment 'Typical power consumption of the equipment in watts under normal operating conditions. Used for power capacity planning and OPEX calculation.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackLocation rdf:type rdf:Property ;
    rdfs:label 'Rack Location' ;
    rdfs:comment 'Physical rack identifier within the site where the equipment is mounted. Format varies by site convention (e.g., R01, RACK-A-12).' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackUnitHeight rdf:type rdf:Property ;
    rdfs:label 'Rack Unit Height' ;
    rdfs:comment 'Number of rack units (RU) occupied by the equipment. Standard values: 1U, 2U, 4U, etc.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackUnitPosition rdf:type rdf:Property ;
    rdfs:label 'Rack Unit Position' ;
    rdfs:comment 'Starting rack unit position (1U = 1.75 inches) from the bottom of the rack where the equipment is mounted. Used for physical space planning and cable management.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyRole rdf:type rdf:Property ;
    rdfs:label 'Redundancy Role' ;
    rdfs:comment 'Role of the equipment in redundancy configuration. PRIMARY (active), SECONDARY (standby backup), STANDALONE (no redundancy), N_PLUS_1 (shared backup for multiple primaries).' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedStandards rdf:type rdf:Property ;
    rdfs:label 'Supported Standards' ;
    rdfs:comment 'Comma-separated list of technology standards and protocols supported by the equipment. Examples: LTE, 5G_NR, GPON, XGS_PON, DOCSIS_3.1, MPLS, SD_WAN, VoLTE, IMS.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Foreign key reference to the original regulatory filing if this record represents an amendment or resubmission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory authority formally acknowledged receipt of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Comment Period End Date' ;
    rdfs:comment 'The deadline for public comments or stakeholder feedback on this filing, if applicable.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Assessment of the regulatory or compliance risk associated with this filing (e.g., potential for penalties, reputational impact).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialTreatmentRequested rdf:type rdf:Property ;
    rdfs:label 'Confidential Treatment Requested' ;
    rdfs:comment 'Indicates whether the filer requested confidential or proprietary treatment for any portion of the submission under applicable rules.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or receipt number issued by the regulatory authority upon successful submission of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of supporting documents or attachments included with this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCounselFirmName rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm Name' ;
    rdfs:comment 'Name of the external law firm or consulting firm that assisted with the filing, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselInvolved rdf:type rdf:Property ;
    rdfs:label 'External Counsel Involved' ;
    rdfs:comment 'Indicates whether external legal counsel or consultants were engaged in the preparation or review of this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed narrative description of the filing content, scope, and purpose. Provides context for the submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'Monetary fee charged by the regulatory authority for processing this filing, in the reporting currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee amount.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFormat rdf:type rdf:Property ;
    rdfs:label 'Filing Format' ;
    rdfs:comment 'The format or medium in which the filing was submitted to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'The ending date of the reporting period covered by this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'The beginning date of the reporting period covered by this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPriority rdf:type rdf:Property ;
    rdfs:label 'Filing Priority' ;
    rdfs:comment 'Internal priority classification for this filing based on business impact, regulatory risk, or strategic importance.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the regulatory authority or internal system for tracking this submission. Business identifier for the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks the submission through its workflow from draft to final disposition.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory submission type. Defines the nature and purpose of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier for the payment of the filing fee.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerDepartment rdf:type rdf:Property ;
    rdfs:label 'Preparer Department' ;
    rdfs:comment 'Business unit or department responsible for preparing the filing (e.g., Regulatory Affairs, Legal, Finance).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Name of the individual or team who prepared the filing content and supporting documentation.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date on which the regulatory authority issued a public notice or published the filing for public comment.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The governing body or regulatory agency to which this filing is submitted. Identifies the jurisdiction and oversight entity. [ENUM-REF-CANDIDATE: FCC|NTIA|Ofcom|BEREC|ITU|GSMA|3GPP|ETSI|state_puc|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation provided by the regulatory authority if the filing was rejected or returned for correction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date on which the regulatory authority completed its review and issued a final determination on the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the internal review and approval of the filing was completed prior to submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual who reviewed and approved the filing for submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the filing was officially submitted to the regulatory authority. Principal business event timestamp for the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPages rdf:type rdf:Property ;
    rdfs:label 'Total Pages' ;
    rdfs:comment 'Total page count across all documents submitted as part of this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enterpriseSegmentId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Segment Id' ;
    rdfs:comment 'Foreign key linking to enterprise.segment. Business justification: Regulatory obligations apply differentially by customer segment (e.g., government vs. commercial enterprise, SMB vs. large enterprise). regulatory_obligation.applicable_customer_segments is a denormal' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:annualComplianceCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Compliance Cost Estimate' ;
    rdfs:comment 'Estimated annual cost in USD to maintain compliance with this obligation, including personnel, systems, external audit fees, and filing costs. Used for compliance budgeting and cost-benefit analysis.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of telecommunications service types to which this obligation applies. Examples: \'mobile_voice,mobile_data\', \'fixed_broadband,fiber\', \'iptv,ott_video\', \'wholesale_interconnect\'. Null if obligation applies to all services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether this obligation requires maintenance of detailed audit trails and evidence of compliance activities. True for obligations subject to regulatory audit or certification (e.g., ISO/IEC 27001, CALEA, GDPR data processing records).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationFeasibility rdf:type rdf:Property ;
    rdfs:label 'Automation Feasibility' ;
    rdfs:comment 'Assessment of the extent to which compliance monitoring, evidence collection, and reporting for this obligation can be automated through systems integration and workflow automation. Drives compliance technology roadmap.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'Required frequency for compliance reporting, monitoring, or certification activities. Determines the cadence of compliance calendar entries and audit schedules. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annual|annual|biennial|event_driven|one_time — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days that compliance evidence, records, and audit trails must be retained to satisfy this obligation. Null if no specific retention period is mandated. Examples: 2555 days (7 years for CALEA), 1825 days (5 years for financial records).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementAuthority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority' ;
    rdfs:comment 'Name of the regulatory body or government agency responsible for enforcing this obligation. Examples: \'Federal Communications Commission (FCC)\', \'European Data Protection Board (EDPB)\', \'Office of Communications (Ofcom)\', \'California Public Utilities Commission (CPUC)\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiry Date' ;
    rdfs:comment 'Date when a granted exemption or waiver expires and full compliance becomes mandatory. Null if no exemption is in effect or exemption is permanent.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Indicates whether the organization has been granted any exemption, waiver, or special dispensation from this obligation by the enforcement authority. Includes rationale and expiry date of exemption if applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference identifier to the internal corporate policy, procedure, or compliance manual that implements this regulatory obligation. Links regulatory requirements to operational controls.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO country code or jurisdiction identifier where this obligation applies. Examples: USA, GBR, EU, USA-CA (California), USA-FCC (Federal). Supports multi-level jurisdictions (federal, state, regional).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Assessment Date' ;
    rdfs:comment 'Date of the most recent compliance assessment, audit, or certification activity for this obligation. Used to track assessment currency and schedule next reviews.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Update Date' ;
    rdfs:comment 'Date when the regulatory text, requirements, or interpretation of this obligation was last amended by the enforcement authority. Triggers compliance impact assessments and process updates.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCitation rdf:type rdf:Property ;
    rdfs:label 'Legal Citation' ;
    rdfs:comment 'Full legal citation or reference to the statute, regulation, or rule that establishes this obligation. Examples: \'47 USC § 1002\', \'GDPR Article 17\', \'FCC Rule 47 CFR § 64.2009\', \'Communications Act 2003 Section 45\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty amount for a single violation of this obligation, in the currency specified. Used for risk quantification and compliance prioritization.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Due Date' ;
    rdfs:comment 'Next scheduled date by which compliance evidence, filing, or certification must be submitted to the enforcement authority. Drives compliance calendar and alert generation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory obligation, used for external reference and reporting. Examples: CALEA-LI-001, GDPR-ART17, USF-CONTRIB-Q1.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Comprehensive description of the regulatory obligation, including specific requirements, scope, applicability conditions, and any special provisions or exemptions.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full descriptive name of the regulatory obligation. Example: \'CALEA Lawful Intercept Capability Maintenance\', \'GDPR Right to Erasure Compliance\', \'Universal Service Fund Quarterly Contribution\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the regulatory obligation by its primary regulatory domain. Determines the compliance framework, reporting requirements, and enforcement mechanisms applicable to this obligation. [ENUM-REF-CANDIDATE: spectrum_license|calea_mandate|gdpr_requirement|ccpa_requirement|usf_contribution|cpni_protection|mnp_rule|net_neutrality|e911_requirement|roaming_regulation|universal_service|numbering_plan — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationUrl rdf:type rdf:Property ;
    rdfs:label 'Obligation Url' ;
    rdfs:comment 'URL link to the official regulatory text, guidance document, or enforcement authority webpage for this obligation. Provides direct access to authoritative source material.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the maximum penalty amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyFramework rdf:type rdf:Property ;
    rdfs:label 'Penalty Framework' ;
    rdfs:comment 'Description of the penalty structure for non-compliance, including monetary fines, sanctions, license revocation, or other enforcement actions. Examples: \'Up to 4% of annual global turnover or €20M (GDPR)\', \'Daily fines up to $100,000 per violation (FCC)\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of this regulatory obligation record. Incremented with each modification to support change tracking and historical analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Reporting Template Reference' ;
    rdfs:comment 'Reference identifier or URL to the official reporting template, form, or submission format required by the enforcement authority. Examples: \'FCC Form 477\', \'BEREC Template NN-2023-01\', \'Ofcom C5 Return\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'Name of the internal business unit, department, or function with primary accountability for ensuring compliance with this obligation. Examples: \'Legal & Regulatory Affairs\', \'Network Operations\', \'Data Privacy Office\', \'Spectrum Management\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Level' ;
    rdfs:comment 'Enterprise risk classification for non-compliance with this obligation. Based on potential financial impact, reputational damage, operational disruption, and regulatory scrutiny. Drives compliance prioritization and resource allocation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Identifier or name of the operational system(s) that provide compliance data for this obligation. Examples: \'Amdocs Billing\', \'Nokia NetAct\', \'Salesforce CRM\', \'ServiceNow ITSM\'. Used for data lineage and integration mapping.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which compliance evidence or filings must be submitted to the enforcement authority. Determines integration requirements and submission workflows.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'The access control classification for this lawful intercept order. NEED_TO_KNOW: only authorized personnel directly involved may access; RESTRICTED_ACCESS: limited to compliance and legal teams; EXECUTIVE_ONLY: requires executive approval for access.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept was activated and data collection began. This may differ from order received timestamp due to technical provisioning lead time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodyLog rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Log' ;
    rdfs:comment 'A structured log or reference to a detailed audit trail documenting every access, handling, and transfer event for this lawful intercept order and its associated data. Ensures legal admissibility and compliance with evidence handling standards.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtOrderReference rdf:type rdf:Property ;
    rdfs:label 'Court Order Reference' ;
    rdfs:comment 'The official reference number or docket number of the court order, warrant, or legal authorization document that mandates this lawful intercept. This is the externally-known business identifier for the order.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDestination rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination' ;
    rdfs:comment 'The destination address, endpoint, or location where intercepted data is delivered. May be an FTP server URL, physical address, IP address of LEA handover interface, or API endpoint.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The primary method by which intercepted data is delivered to the LEA. Options include secure FTP, physical media (encrypted USB, DVD), ETSI LI handover interfaces (HI2 for signaling, HI3 for content), network handoff, or secure API.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'The encryption algorithm and protocol used to secure intercepted data during transmission and storage. Examples: AES-256, TLS 1.3, PGP, or LEA-specified encryption standards.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept order expires and data collection must cease. Nullable for orders without a defined expiration (subject to renewal or explicit termination).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interceptServiceScope rdf:type rdf:Property ;
    rdfs:label 'Intercept Service Scope' ;
    rdfs:comment 'Defines which services are subject to intercept: voice calls, SMS, MMS, data sessions, VoLTE, VoIP, email, or all services. May be a comma-separated list or specific service identifiers.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptStatus rdf:type rdf:Property ;
    rdfs:label 'Intercept Status' ;
    rdfs:comment 'Current lifecycle status of the lawful intercept order. PENDING: received but not yet activated; ACTIVE: currently collecting data; SUSPENDED: temporarily paused; EXPIRED: reached expiry date; TERMINATED: explicitly ended; CLOSED: all deliveries completed and order archived.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptTechnology rdf:type rdf:Property ;
    rdfs:label 'Intercept Technology' ;
    rdfs:comment 'The telecommunications technology or network type on which the intercept is provisioned. Examples: 2G/GSM, 3G/UMTS, 4G/LTE, 5G NR, VoIP/IMS, FTTH, Cable, Satellite. Determines the technical implementation approach.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptType rdf:type rdf:Property ;
    rdfs:label 'Intercept Type' ;
    rdfs:comment 'Specifies the scope of the lawful intercept: content only (voice, video, messaging payload), metadata only (CDR, signaling, session data), or both content and metadata. Determines what data must be captured and delivered.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (country, state, province, or district) under which the lawful intercept order was issued. Examples: USA-Federal, USA-CA, GBR, DEU-Bavaria.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Timestamp' ;
    rdfs:comment 'The date and time of the most recent renewal or extension of this lawful intercept order. Nullable if the order has never been renewed.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaAgencyName rdf:type rdf:Property ;
    rdfs:label 'Lea Agency Name' ;
    rdfs:comment 'The name of the law enforcement agency (LEA) or government authority that is the recipient of the intercepted data. Examples: FBI, DEA, Metropolitan Police, Europol.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaCaseReference rdf:type rdf:Property ;
    rdfs:label 'Lea Case Reference' ;
    rdfs:comment 'The LEA\'s internal case number or investigation reference associated with this lawful intercept order. Used for cross-referencing with law enforcement records.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaContactOfficer rdf:type rdf:Property ;
    rdfs:label 'Lea Contact Officer' ;
    rdfs:comment 'The name of the LEA officer or agent who is the primary contact for this lawful intercept order. This individual receives delivery confirmations and coordinates with the telecommunications provider.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'The status of internal legal review for this lawful intercept order. Telecommunications providers typically conduct legal compliance review before activating an intercept to ensure the order is valid and complete.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Legal Review Timestamp' ;
    rdfs:comment 'The date and time when the internal legal review of this lawful intercept order was completed and the order was approved for activation.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'The name of the legal counsel or compliance officer who reviewed and approved this lawful intercept order for activation. Part of the internal approval chain of custody.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Received Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept order was officially received by the telecommunications provider. This is the principal business event timestamp marking the start of the order lifecycle.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningSystemReference rdf:type rdf:Property ;
    rdfs:label 'Provisioning System Reference' ;
    rdfs:comment 'Reference identifier or ticket number in the telecommunications provider\'s lawful intercept provisioning system (e.g., mediation device, lawful intercept gateway, OSS module) where the technical intercept configuration is managed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'The number of times this lawful intercept order has been renewed or extended by the issuing authority. Tracks the order\'s history and duration of active surveillance.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Target Identifier Type' ;
    rdfs:comment 'The type or format of the target identifier. Indicates whether the target is identified by phone number (MSISDN), subscriber identity (IMSI), device identity (IMEI), IP address, email, account number, or SIP URI. [ENUM-REF-CANDIDATE: MSISDN|IMSI|IMEI|IP_ADDRESS|EMAIL|ACCOUNT_NUMBER|SIP_URI — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationHint rdf:type rdf:Property ;
    rdfs:label 'Target Location Hint' ;
    rdfs:comment 'Optional geographic or network location information provided in the court order to assist in identifying and provisioning the intercept. May include city, region, cell tower ID, or network segment. Not always present.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Termination Timestamp' ;
    rdfs:comment 'The actual date and time when the lawful intercept was terminated, either due to expiry, court order withdrawal, or completion of investigation. Marks the end of the intercept lifecycle.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDataVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Data Volume Bytes' ;
    rdfs:comment 'The cumulative volume of intercepted data (content and/or metadata) collected under this order, measured in bytes. Used for capacity planning, billing (if applicable), and compliance reporting.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Total Delivery Count' ;
    rdfs:comment 'The total number of data delivery events (transmissions, handoffs, or media shipments) that have occurred for this lawful intercept order. Each delivery is typically logged as a separate line item in a related delivery record table.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Granted' ;
    rdfs:comment 'Indicates whether the organization has the right to audit the counterparty\'s data processing activities under this agreement. True if audit rights are granted, false otherwise.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caleaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Calea Compliance Flag' ;
    rdfs:comment 'Indicates whether this consent or processing activity is subject to CALEA lawful intercept requirements. True if CALEA compliance obligations apply, false otherwise. Specific to US telecommunications regulatory compliance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'Category of data processing activity covered by this consent. Values: marketing (promotional communications), analytics (usage analytics), personalization (service personalization), third_party_sharing (data sharing with partners), location_tracking (location data processing), cpni (Customer Proprietary Network Information under FCC rules), lawful_intercept (CALEA compliance), research (research and development). [ENUM-REF-CANDIDATE: marketing|analytics|personalization|third_party_sharing|location_tracking|cpni|lawful_intercept|research — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Document Uri' ;
    rdfs:comment 'URI or file path to the stored consent proof document, signed agreement, or privacy policy version presented to the data subject. Used for audit and regulatory compliance evidence.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the consent record, used for customer inquiries and audit trails.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the third-party organization involved in a Data Processing Agreement, sub-processor agreement, or data sharing agreement. Null for individual data consents. Used for vendor and partner privacy governance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Type of third-party counterparty in the agreement. Values: data_processor (processes data on behalf of controller), sub_processor (sub-contracted processor), joint_controller (joint data controller), data_recipient (receives data for own purposes), mvno (Mobile Virtual Network Operator partner), roaming_partner (roaming agreement partner), content_provider (OTT or IPTV content provider). [ENUM-REF-CANDIDATE: data_processor|sub_processor|joint_controller|data_recipient|mvno|roaming_partner|content_provider — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpniProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Cpni Protection Flag' ;
    rdfs:comment 'Indicates whether this consent record involves Customer Proprietary Network Information protected under FCC CPNI rules (47 CFR 64.2007). True if CPNI protection applies, false otherwise. Specific to US telecommunications regulatory compliance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferMechanism rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism used for cross-border transfer of personal data under GDPR Chapter V. Values: adequacy_decision (EU adequacy decision per Article 45), standard_contractual_clauses (SCCs per Article 46), binding_corporate_rules (BCRs per Article 47), certification (approved certification mechanism), derogation (specific derogation per Article 49), none (no cross-border transfer).' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategories rdf:type rdf:Property ;
    rdfs:label 'Data Categories' ;
    rdfs:comment 'Comma-separated list of personal data categories covered by this consent or agreement (e.g., contact_information, usage_data, location_data, payment_information, call_detail_records, network_performance_data). Aligns with GDPR Article 4 and CCPA definitions.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Affected Count' ;
    rdfs:comment 'Estimated number of data subjects (individuals) whose personal data is affected by the processing activity assessed in the Privacy Impact Assessment or DPIA. Used for proportionality assessment.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dpoApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Dpo Approval Status' ;
    rdfs:comment 'Status of DPO review and approval. Values: approved (DPO approved the record), rejected (DPO rejected the record), pending_review (awaiting DPO review), conditional_approval (approved with conditions or mitigation requirements).' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Date' ;
    rdfs:comment 'Date on which the Data Protection Officer reviewed and approved this consent record, agreement, or privacy impact assessment.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Timestamp' ;
    rdfs:comment 'Date and time when the consent was granted or the agreement was executed. Represents the principal business event timestamp for this record.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Description of technical and organizational measures implemented to mitigate identified privacy risks, including data minimization, pseudonymization, encryption, access controls, and privacy-by-design measures per GDPR Article 25 and Article 32.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is necessary for the stated purpose and whether less intrusive alternatives exist. Required for GDPR Article 35 DPIA necessity and proportionality evaluation.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Description' ;
    rdfs:comment 'Detailed description of the data processing activity assessed in a Privacy Impact Assessment or Data Protection Impact Assessment. Includes systems involved, data flows, and processing operations.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the specific purpose for which personal data is processed under this consent or agreement. Must align with legal basis and be specific, explicit, and legitimate per GDPR Article 5.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is proportionate to the stated purpose and whether the privacy impact is justified by the benefits. Required for GDPR Article 35 DPIA.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategories rdf:type rdf:Property ;
    rdfs:label 'Risk Categories' ;
    rdfs:comment 'Comma-separated list of privacy risk categories identified in the Privacy Impact Assessment or DPIA (e.g., unauthorized_access, data_breach, profiling, automated_decision_making, cross_border_transfer, surveillance_risk). Used for risk management and mitigation planning.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityObligations rdf:type rdf:Property ;
    rdfs:label 'Security Obligations' ;
    rdfs:comment 'Description of technical and organizational security measures required under this agreement or consent, including encryption, access controls, audit logging, and incident response obligations per GDPR Article 32.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted regarding this DPIA or consent matter. Null if no consultation occurred.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required' ;
    rdfs:comment 'Indicates whether consultation with the supervisory authority (e.g., ICO, CNIL, BfDI) is required for this DPIA per GDPR Article 36. True if high residual risk remains after mitigation, false otherwise.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Name' ;
    rdfs:comment 'Name of the supervisory authority consulted or notified regarding this consent, agreement, or DPIA (e.g., ICO - UK, CNIL - France, BfDI - Germany, FCC - USA). Null if no consultation occurred.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when the consent was withdrawn by the data subject or the agreement was terminated. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Date and time when the request was assigned to a handler for processing. Used for queue time analytics.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Assessed complexity of the request based on scope, number of systems involved, and data volume. Used for resource allocation and prioritization.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecordsRetrievedCount rdf:type rdf:Property ;
    rdfs:label 'Data Records Retrieved Count' ;
    rdfs:comment 'Total number of data records retrieved across all systems for this request. Used for scope tracking and audit purposes.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectNotified rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notified' ;
    rdfs:comment 'Indicates whether the data subject has been notified of the outcome of their request. Required for regulatory compliance.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSystemsAccessedCount rdf:type rdf:Property ;
    rdfs:label 'Data Systems Accessed Count' ;
    rdfs:comment 'Number of internal systems queried to fulfill the request. Used for complexity assessment and process improvement.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the request was escalated. Null if not escalated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:extendedSlaDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Sla Deadline' ;
    rdfs:comment 'New deadline if an extension has been granted. Null if no extension was granted.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeChargedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Charged Amount' ;
    rdfs:comment 'Fee charged to the data subject for processing the request, if applicable. GDPR permits fees for manifestly unfounded or excessive requests. CCPA generally prohibits fees. Zero or null if no fee charged.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fee charged. Null if no fee charged.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeJustification rdf:type rdf:Property ;
    rdfs:label 'Fee Justification' ;
    rdfs:comment 'Business and legal justification for charging a fee. Required if fee is charged to demonstrate compliance with manifestly unfounded or excessive criteria.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Detailed status of the fulfillment activities for the request. Tracks progress through data collection, review, packaging, and delivery stages. [ENUM-REF-CANDIDATE: not_started|data_collection_in_progress|data_review_in_progress|data_package_prepared|data_delivered|action_completed|partially_fulfilled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the data subject making the request. Ensures compliance with reasonable verification requirements.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of the identity verification process to confirm the requestor is the legitimate data subject. Critical for preventing fraudulent requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Timestamp' ;
    rdfs:comment 'Date and time when the identity of the data subject was successfully verified. Null if verification is pending or failed.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method used to notify the data subject of the request outcome. Must align with the data subjects preferred communication channel.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when the data subject was notified of the request outcome. Used for compliance audit trail.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when active processing of the request began after identity verification. Used for processing time analytics.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the data protection authority that was notified. Examples: ICO (UK), CNIL (France), California Attorney General. Null if no notification made.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Timestamp' ;
    rdfs:comment 'Date and time when the regulatory authority was notified. Null if no notification made.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Indicates whether the relevant data protection authority was notified about this request. Required for certain high-risk or disputed requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySlaDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Sla Deadline' ;
    rdfs:comment 'Regulatory deadline by which the request must be fulfilled. GDPR: 1 month (extendable to 3 months). CCPA: 45 days (extendable to 90 days). Calculated from submission timestamp.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Rejection Legal Basis' ;
    rdfs:comment 'Specific legal article or section cited as the basis for rejection. Required for regulatory compliance and audit defense.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to the privacy request for tracking and customer communication purposes. Format: DSR-XXXXXXXXXX.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject rights request. GDPR types: access (Article 15), erasure (Article 17), portability (Article 20), rectification (Article 16), restriction (Article 18). CCPA types: opt_out, do_not_sell, consent_withdrawal. [ENUM-REF-CANDIDATE: access|erasure|portability|rectification|restriction|opt_out|do_not_sell|consent_withdrawal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Sla Extension Granted' ;
    rdfs:comment 'Indicates whether a regulatory-permitted extension to the response deadline has been granted due to request complexity or volume.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaExtensionReason rdf:type rdf:Property ;
    rdfs:label 'Sla Extension Reason' ;
    rdfs:comment 'Business justification for granting an SLA extension. Required to be communicated to the data subject per regulatory requirements.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the data subject submitted the privacy request. Used for channel analytics and response routing. [ENUM-REF-CANDIDATE: web_portal|mobile_app|email|phone|postal_mail|in_store|chat — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Amount' ;
    rdfs:comment 'The total cost paid by the operator to acquire this spectrum license, including auction bids, transfer fees, and transaction costs. Expressed in the currency specified by the acquisition cost currency code.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition cost.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'The method by which the operator acquired this spectrum license. Indicates whether it was obtained through auction, direct assignment, purchase, or other means.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'The annual regulatory fee charged by the granting authority for holding this spectrum license. Expressed in the currency specified by the fee currency code.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementActionDescription rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Description' ;
    rdfs:comment 'Textual description of any enforcement actions taken by the regulatory authority, including the nature of the violation and remediation requirements. Null if no enforcement action exists.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether any regulatory enforcement action (warning, fine, suspension) has been taken against this license. True if enforcement action exists, False otherwise.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantingAuthority rdf:type rdf:Property ;
    rdfs:label 'Granting Authority' ;
    rdfs:comment 'The regulatory body or national authority that issued this spectrum license (e.g., FCC, Ofcom, NTIA, BEREC member regulator).' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Granting Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the granting authority operates.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interferenceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Interference Protection Flag' ;
    rdfs:comment 'Indicates whether this license includes regulatory protection from interference by other spectrum users. True if protected, False if shared or unlicensed spectrum.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'The date of the most recent regulatory compliance review or audit for this license. Used to track periodic compliance verification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCategory rdf:type rdf:Property ;
    rdfs:label 'License Category' ;
    rdfs:comment 'Classification of the spectrum license by service type. Determines the permitted use case and operational constraints.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The official license number or call sign assigned by the regulatory authority. This is the externally-known unique identifier for the spectrum license.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the spectrum license. Indicates whether the license is operational, under review, or terminated.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermYears rdf:type rdf:Property ;
    rdfs:label 'License Term Years' ;
    rdfs:comment 'The duration of the license grant in years. Defines the period for which the spectrum rights are valid before renewal is required.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowerFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Lower Frequency Mhz' ;
    rdfs:comment 'The lower bound of the licensed frequency range in megahertz. Defines the start of the spectrum allocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Percentage' ;
    rdfs:comment 'The minimum spectrum utilization percentage required by the regulatory authority to maintain the license in good standing. Failure to meet this threshold may result in penalties or revocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'The scheduled date for the next regulatory compliance review or audit. Null if no review is scheduled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the licensee submitted the renewal application to the regulatory authority. Null if no renewal has been requested.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the license renewal process. Tracks whether renewal is required, applied for, or completed.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The internal department or business unit responsible for managing this spectrum license (e.g., Network Engineering, Regulatory Affairs, Spectrum Management).' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedSpectrumFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Spectrum Flag' ;
    rdfs:comment 'Indicates whether this license operates in a shared spectrum environment (e.g., CBRS, LSA) where multiple operators may use the same frequencies under coordination rules. True if shared, False if exclusive.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether this license may be transferred or sold to another operator subject to regulatory approval. True if transferable, False if non-transferable.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Upper Frequency Mhz' ;
    rdfs:comment 'The upper bound of the licensed frequency range in megahertz. Defines the end of the spectrum allocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageConditions rdf:type rdf:Property ;
    rdfs:label 'Usage Conditions' ;
    rdfs:comment 'Textual description of the regulatory conditions, restrictions, and obligations attached to this license. May include build-out requirements, interference limits, and service quality mandates.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Account Number Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s account number with the donor operator was verified to prevent fraudulent porting.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Method by which customer authorization was obtained (electronic signature, verbal recording, written Letter of Authorization, online consent, in-store verification).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when customer authorization was obtained and verified.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingAddressVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Address Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s billing address was verified as part of the porting authorization process.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes from compliance officers regarding special circumstances, exceptions, or regulatory considerations for this porting transaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of internal compliance review for this porting transaction, particularly for SLA breaches or rejections.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance review was completed.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerAuthorizationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Authorization Verified Flag' ;
    rdfs:comment 'Indicates whether customer authorization for the port was verified according to regulatory requirements (to prevent unauthorized porting/slamming).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when this compliance record is eligible for deletion according to regulatory data retention policies (typically 2-7 years depending on jurisdiction).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Donor Operator Code' ;
    rdfs:comment 'Unique code identifying the telecommunications operator from which the number is being ported (the losing carrier).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorOperatorName rdf:type rdf:Property ;
    rdfs:label 'Donor Operator Name' ;
    rdfs:comment 'Full legal name of the donor telecommunications operator.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberCount rdf:type rdf:Property ;
    rdfs:label 'Number Count' ;
    rdfs:comment 'Total count of numbers included in this porting transaction. Typically 1 for simple ports, multiple for complex or corporate ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Number Range End' ;
    rdfs:comment 'Ending number in a range port (for complex or corporate porting involving multiple consecutive numbers). Null for simple single-number ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Number Range Start' ;
    rdfs:comment 'Starting number in a range port (for complex or corporate porting involving multiple consecutive numbers). Null for simple single-number ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Completion Timestamp' ;
    rdfs:comment 'Date and time when the number porting was successfully completed and the number became active on the recipient operator\'s network.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingDirection rdf:type rdf:Property ;
    rdfs:label 'Porting Direction' ;
    rdfs:comment 'Indicates whether this is a port-in (number coming to this operator) or port-out (number leaving this operator) transaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Porting Reference Number' ;
    rdfs:comment 'Unique regulatory reference number assigned to the porting transaction by the central porting authority or clearinghouse. Used for inter-operator coordination and regulatory tracking.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Request Timestamp' ;
    rdfs:comment 'Date and time when the porting request was officially submitted to the central porting authority or clearinghouse.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingStatus rdf:type rdf:Property ;
    rdfs:label 'Porting Status' ;
    rdfs:comment 'Current status of the porting transaction in the regulatory compliance lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingType rdf:type rdf:Property ;
    rdfs:label 'Porting Type' ;
    rdfs:comment 'Classification of the porting transaction complexity. Simple (single number), complex (multiple numbers), or corporate (enterprise account porting).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Operator Code' ;
    rdfs:comment 'Unique code identifying the telecommunications operator to which the number is being ported (the gaining carrier).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOperatorName rdf:type rdf:Property ;
    rdfs:label 'Recipient Operator Name' ;
    rdfs:comment 'Full legal name of the recipient telecommunications operator.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Status' ;
    rdfs:comment 'Status of notification to the regulatory authority regarding this porting transaction. Some jurisdictions require operators to report porting metrics to regulators.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Date and time when the regulatory authority was notified of this porting transaction or compliance event.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatorySlaDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Sla Deadline Timestamp' ;
    rdfs:comment 'The regulatory deadline by which the porting must be completed to comply with FCC, BEREC, or local regulatory authority SLA requirements (typically 1 business day in the US, varies by jurisdiction).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rejection Flag' ;
    rdfs:comment 'Indicates whether the porting request was rejected by the donor operator or central porting authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachDurationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Duration Hours' ;
    rdfs:comment 'Number of hours by which the porting transaction exceeded the regulatory SLA deadline. Null if no breach occurred.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit fieldwork or on-site activities concluded.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit fieldwork or on-site activities commenced.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope including business units, processes, systems, geographic locations, and standards clauses covered by the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit engagement. Tracks progression from scheduling through completion. [ENUM-REF-CANDIDATE: SCHEDULED|IN_PROGRESS|FIELDWORK_COMPLETE|UNDER_REVIEW|COMPLETED|CANCELLED|DEFERRED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement type. Indicates the regulatory framework, standard, or internal policy being audited. [ENUM-REF-CANDIDATE: ISO_27001_SURVEILLANCE|ISO_27001_RECERTIFICATION|FCC_INSPECTION|GDPR_SUPERVISORY_AUTHORITY_AUDIT|SOC_2_EXAMINATION|PCI_DSS_ASSESSMENT|INTERNAL_REVIEW|3GPP_COMPLIANCE_AUDIT|GSMA_SAS_AUDIT|ETSI_STANDARDS_AUDIT|CALEA_LAWFUL_INTERCEPT_AUDIT|CPNI_PROTECTION_AUDIT|UNIVERSAL_SERVICE_FUND_AUDIT|SPECTRUM_LICENSE_COMPLIANCE_AUDIT|MNP_REGULATORY_AUDIT|OFCOM_COMPLIANCE_REVIEW|BEREC_REGULATORY_AUDIT — promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Name of the organization or regulatory authority conducting the audit (e.g., external certification body, FCC, GDPR supervisory authority, internal audit department).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Auditing Body Accreditation Number' ;
    rdfs:comment 'Official accreditation or registration number of the auditing body, if applicable (e.g., ANAB accreditation number for ISO auditors).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the issued certification expires and requires renewal or recertification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issue Date' ;
    rdfs:comment 'Date when the certification was officially issued by the certifying body.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certification was issued as a result of this audit. True if certification was granted, False otherwise.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Reference Number' ;
    rdfs:comment 'Unique certificate number or reference identifier assigned by the certifying body to the issued certification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRenewalStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Renewal Status' ;
    rdfs:comment 'Current status of the certification renewal process. Tracks whether the certification is active, approaching renewal, or has expired.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope covered by the issued certification, including business units, processes, systems, and geographic locations.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification issued as a result of the audit, if applicable. Identifies the specific standard or framework for which certification was granted. [ENUM-REF-CANDIDATE: ISO_IEC_27001|SOC_2_TYPE_II|PCI_DSS|FCC_CPNI_ANNUAL|GSMA_SAS|ISO_9001|ISO_20000|ISO_22301|ISO_27017|ISO_27018|CALEA_COMPLIANCE|ETSI_CERTIFICATION — promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Deadline date by which corrective actions for identified nonconformities must be completed and submitted for verification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Verified Date' ;
    rdfs:comment 'Date when the auditing body verified that all corrective actions have been satisfactorily implemented.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged to support the audit process. True if external counsel was involved, False otherwise.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalAuditCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Coordinator Email' ;
    rdfs:comment 'Primary email address of the internal audit coordinator for audit logistics and communication.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Coordinator Name' ;
    rdfs:comment 'Full name of the internal employee responsible for coordinating the audit activities and serving as the primary liaison with the auditing body.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformities Count' ;
    rdfs:comment 'Number of major nonconformities identified during the audit. Major nonconformities represent significant failures to meet compliance requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformities Count' ;
    rdfs:comment 'Number of minor nonconformities identified during the audit. Minor nonconformities represent less critical deviations from compliance requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit that do not constitute nonconformities.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall result or conclusion of the audit engagement. Indicates whether the organization met the compliance requirements under review.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the period under audit review. Defines the conclusion of the timeframe for which compliance is being assessed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the period under audit review. Defines the beginning of the timeframe for which compliance is being assessed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the formal audit report was issued to the organization.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleExecutiveEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Email' ;
    rdfs:comment 'Primary email address of the responsible executive officer for compliance communications.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveName rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Name' ;
    rdfs:comment 'Full name of the executive officer responsible for compliance oversight and signatory authority for the audit and certification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Title' ;
    rdfs:comment 'Job title of the responsible executive officer (e.g., Chief Compliance Officer, Chief Information Security Officer, Data Protection Officer).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date for the audit fieldwork or on-site activities to conclude.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Total number of auditors and technical experts assigned to the audit engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDataCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Data Categories' ;
    rdfs:comment 'Comma-separated list of personal data categories affected by the breach (e.g., name, email, phone, address, payment card, CPNI, location data, account credentials).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'Comma-separated list of systems, applications, or infrastructure components affected by the breach (e.g., CRM, billing system, customer portal, database server).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Breach Severity Level' ;
    rdfs:comment 'Assessed severity level of the data breach incident based on data sensitivity, volume, and potential harm (critical, high, medium, low).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the data breach incident (detected, under investigation, contained, notification in progress, closed, escalated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachType rdf:type rdf:Property ;
    rdfs:label 'Breach Type' ;
    rdfs:comment 'Classification of the data breach incident by attack vector or cause (unauthorized access, accidental disclosure, ransomware, insider threat, third-party breach, lost device).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the data breach incident was formally closed after all remediation, notification, and regulatory obligations were completed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedAffectedIndividualsCount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Affected Individuals Count' ;
    rdfs:comment 'Confirmed number of individuals whose personal data was compromised, based on completed forensic investigation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when the data breach incident was successfully contained and the vulnerability or exposure was closed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditMonitoringOffered rdf:type rdf:Property ;
    rdfs:label 'Credit Monitoring Offered' ;
    rdfs:comment 'Indicates whether credit monitoring or identity protection services were offered to affected individuals as part of breach remediation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataExfiltrationConfirmed rdf:type rdf:Property ;
    rdfs:label 'Data Exfiltration Confirmed' ;
    rdfs:comment 'Indicates whether forensic investigation confirmed that personal data was actually exfiltrated or accessed by unauthorized parties (true) or only exposed without confirmed access (false).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the data breach incident was first detected by internal monitoring systems, staff, or external notification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encryptionInPlace rdf:type rdf:Property ;
    rdfs:label 'Encryption In Place' ;
    rdfs:comment 'Indicates whether the affected personal data was encrypted at the time of the breach, which may reduce notification obligations under certain regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAffectedIndividualsCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Affected Individuals Count' ;
    rdfs:comment 'Estimated number of individuals whose personal data was compromised in the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the breach including investigation costs, notification costs, remediation costs, regulatory fines, and potential litigation costs.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalForensicsFirmEngaged rdf:type rdf:Property ;
    rdfs:label 'External Forensics Firm Engaged' ;
    rdfs:comment 'Indicates whether an external cybersecurity or forensics firm was engaged to investigate the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalForensicsFirmName rdf:type rdf:Property ;
    rdfs:label 'External Forensics Firm Name' ;
    rdfs:comment 'Name of the external cybersecurity or forensics firm engaged to investigate the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated financial impact amount.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the data breach incident for tracking and regulatory reporting purposes.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualNotificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Completion Date' ;
    rdfs:comment 'Date when direct notification to all affected individuals was completed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:individualNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Method' ;
    rdfs:comment 'Primary method used to notify affected individuals (email, postal mail, SMS, phone, website notice, substitute notice).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Required' ;
    rdfs:comment 'Indicates whether the breach meets the threshold for mandatory direct notification to affected individuals under applicable data protection regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:individualNotificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Start Date' ;
    rdfs:comment 'Date when direct notification to affected individuals began (via email, postal mail, or other channels).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notification Required' ;
    rdfs:comment 'Indicates whether the breach requires notification to law enforcement agencies based on criminal activity or regulatory requirements.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselEngaged rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Engaged' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged to advise on breach notification obligations and regulatory compliance.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselFirmName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Firm Name' ;
    rdfs:comment 'Name of the external legal counsel firm engaged to advise on the breach response.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationInitiated rdf:type rdf:Property ;
    rdfs:label 'Litigation Initiated' ;
    rdfs:comment 'Indicates whether civil litigation or class action lawsuits were initiated by affected individuals or consumer advocacy groups as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Estimated date and time when the data breach incident actually occurred or began, based on forensic investigation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date when the breach was publicly disclosed through media notification, press release, or regulatory public notice.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether the breach requires public disclosure or media notification due to the number of affected individuals or regulatory requirements.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFineAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fine Amount' ;
    rdfs:comment 'Total amount of regulatory fines or penalties imposed by supervisory authorities as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFineImposed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fine Imposed' ;
    rdfs:comment 'Indicates whether a regulatory fine or penalty was imposed by a supervisory authority as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the breach meets the threshold for mandatory notification to supervisory authorities under applicable data protection regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date when all remediation actions were completed and verified.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Description' ;
    rdfs:comment 'Detailed description of the remediation plan implemented to address the breach, prevent recurrence, and mitigate harm to affected individuals.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Primary root cause category identified through incident investigation (human error, system vulnerability, malicious attack, third-party failure, physical security breach, process failure).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause identified through forensic investigation and incident analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityAcknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Acknowledgment Reference' ;
    rdfs:comment 'Reference number or acknowledgment identifier provided by the supervisory authority upon receipt of the breach notification.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityNotificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Deadline' ;
    rdfs:comment 'Regulatory deadline by which the breach must be notified to the supervisory authority (e.g., GDPR 72-hour deadline from detection, FCC 30-day deadline).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisoryAuthorityNotificationOnTime rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification On Time' ;
    rdfs:comment 'Indicates whether the supervisory authority notification was submitted within the regulatory deadline (true) or was late (false).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Timestamp' ;
    rdfs:comment 'Actual date and time when the breach notification was submitted to the supervisory authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Id' ;
    rdfs:comment 'Reference to the parent partner in a corporate hierarchy. Null for top-level partners. Used to model subsidiary relationships and consolidated reporting.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Scheduled expiration date of the master partner agreement. Null for evergreen agreements. Triggers renewal workflows when approaching.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractRenewalType rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Type' ;
    rdfs:comment 'Renewal mechanism for the partner agreement. Auto-renew contracts extend automatically unless terminated; manual-renew requires explicit action.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the master partner agreement. Marks the beginning of the contractual relationship and SLA obligations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the partner by a recognized credit agency. Used for risk assessment and credit limit determination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name used by the partner in commercial operations. May differ from legal name for branding purposes.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the partner organization headquarters. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the partner headquarters is located. Used for geographic segmentation and regional compliance requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the partner headquarters location. Determines applicable regulatory frameworks and tax treaties.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the partner headquarters address. Used for mail delivery and geographic analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province where the partner headquarters is located. Used for tax jurisdiction determination and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'Standard industry classification code for the partner organization. Typically NAICS or SIC code. Used for market segmentation and competitive analysis.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier for the partner organization. Used for regulatory reporting, financial transactions, and global entity identification.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current stage in the partner onboarding workflow. Tracks progress through documentation, technical integration, compliance verification, and final approval. [ENUM-REF-CANDIDATE: not_started|in_progress|documentation_pending|technical_integration|compliance_review|completed|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountries rdf:type rdf:Property ;
    rdfs:label 'Operating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner has active operations. Used for roaming agreements, content licensing, and multi-jurisdiction compliance.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Externally-known unique business identifier for the partner. Used in contracts, invoices, and inter-operator communications. Typically assigned during onboarding and immutable thereafter.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Full legal name of the partner organization as registered with governing authorities. Used for contracts, regulatory filings, and legal correspondence.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship. Active partners are eligible for transactions and settlements. Suspended or terminated partners are blocked from new business.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Strategic tier or grade assigned to the partner based on revenue contribution, strategic importance, and relationship maturity. Influences SLA commitments, support priority, and commercial terms.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner based on their role in the telecommunications ecosystem. Determines applicable business processes, SLA templates, and revenue-sharing models. [ENUM-REF-CANDIDATE: MVNO|roaming_partner|content_provider|ott_platform|equipment_vendor|channel_partner|dealer|agent|wholesale_carrier|interconnect_carrier|network_vendor|system_integrator — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact. Used for operational communications, SLA notifications, and settlement correspondence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary phone number for the partner contact. Used for urgent escalations and operational coordination. Format follows E.164 international standard.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Internal risk classification assigned to the partner based on financial stability, compliance history, and operational performance. Influences approval workflows and monitoring intensity.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which financial settlements are processed with the partner. Determines invoice generation schedule and payment cycles. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annual|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number for the partner entity. Used for invoicing, tax reporting, and revenue settlement. Format varies by jurisdiction.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the partner organization. Used for due diligence, public information verification, and business intelligence.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Frequency at which compliance or financial audits may be conducted under the agreement terms.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether Telecommunication retains the right to audit partner records, systems, or processes for compliance verification.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years that confidentiality obligations survive agreement termination. Governs data retention and disclosure policies.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSharingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permitted Flag' ;
    rdfs:comment 'Indicates whether customer or operational data sharing is permitted under this agreement. Critical for GDPR and privacy compliance.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving contractual disputes between parties. Determines escalation paths and legal procedures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'URL or file path to the secure repository location where the executed agreement and related documents are stored.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this agreement grants exclusive rights to the partner in a defined territory, product category, or service domain.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the scope of exclusivity granted, including geographic territories, product lines, or customer segments covered.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Fee Amount' ;
    rdfs:comment 'Fixed periodic payment amount for fixed-fee agreements. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of this agreement. Critical for dispute resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Amount' ;
    rdfs:comment 'Minimum insurance coverage amount required from the partner for liability, professional indemnity, or other risk categories.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum to the agreement. Tracks contract evolution and version history.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum aggregate penalty amount that can be assessed in a given period for SLA breaches. Confidential commercial term.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Value of performance bond or bank guarantee required to secure partner obligations. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Applicable regulatory frameworks governing this agreement, such as FCC regulations for MVNO agreements, BEREC guidelines for roaming, or content licensing regulations.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Commercial model governing how revenue or costs are shared between Telecommunication and the partner. Determines settlement calculation methodology.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty assessed for early termination of the agreement. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hostAgreementId rdf:type rdf:Property ;
    rdfs:label 'Host Agreement Id' ;
    rdfs:comment 'Reference to the master host agreement contract governing the MVNO relationship, terms, and commercial arrangements.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:mvnoPartnerId rdf:type rdf:Property ;
    rdfs:label 'Mvno Partner Id' ;
    rdfs:comment 'Reference to the partner entity representing this MVNO in the partner master data.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:apnConfiguration rdf:type rdf:Property ;
    rdfs:label 'Apn Configuration' ;
    rdfs:comment 'JSON or structured text defining the APN settings assigned to this MVNO for data connectivity, including APN names, IP addressing, and QoS parameters.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingArrangementType rdf:type rdf:Property ;
    rdfs:label 'Billing Arrangement Type' ;
    rdfs:comment 'Defines the billing model between host MNO and MVNO: wholesale rated (MNO bills MVNO), retail billed (MNO bills end customers on behalf of MVNO), hybrid, or self-billed (MVNO manages own billing).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing and finance contact at the MVNO for invoicing and settlement matters.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Current Subscriber Count' ;
    rdfs:comment 'Current number of active subscribers provisioned under this MVNO profile.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esimSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Esim Support Enabled' ;
    rdfs:comment 'Indicates whether the MVNO supports eSIM provisioning and management for subscribers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiveGAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Five G Access Enabled' ;
    rdfs:comment 'Indicates whether MVNO subscribers have access to 5G NR network services.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlrProvisioningEnabled rdf:type rdf:Property ;
    rdfs:label 'Hlr Provisioning Enabled' ;
    rdfs:comment 'Indicates whether the MVNO has direct provisioning access to the HLR for subscriber management.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hssProvisioningEnabled rdf:type rdf:Property ;
    rdfs:label 'Hss Provisioning Enabled' ;
    rdfs:comment 'Indicates whether the MVNO has direct provisioning access to the HSS for LTE/IMS subscriber management.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'International Roaming Enabled' ;
    rdfs:comment 'Indicates whether MVNO subscribers are permitted to roam internationally on partner carrier networks.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvnoBrandName rdf:type rdf:Property ;
    rdfs:label 'Mvno Brand Name' ;
    rdfs:comment 'The commercial brand name under which the MVNO operates and markets services to end customers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoCode rdf:type rdf:Property ;
    rdfs:label 'Mvno Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the MVNO for operational identification across network and billing systems.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoLegalName rdf:type rdf:Property ;
    rdfs:label 'Mvno Legal Name' ;
    rdfs:comment 'The legal registered business name of the MVNO entity as per incorporation documents.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoType rdf:type rdf:Property ;
    rdfs:label 'Mvno Type' ;
    rdfs:comment 'Classification of the MVNO business model: full MVNO (owns core network elements), light MVNO (limited infrastructure), branded reseller (pure resale), ESP (Enhanced Service Provider), or MVNE (MVNO Enabler).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAccessType rdf:type rdf:Property ;
    rdfs:label 'Network Access Type' ;
    rdfs:comment 'Level of network infrastructure access granted to the MVNO: full access to RAN and core, RAN sharing only, core network sharing, or pure resale arrangement.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Ms' ;
    rdfs:comment 'Maximum network latency in milliseconds guaranteed under the SLA for data services.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spectrumAccessRights rdf:type rdf:Property ;
    rdfs:label 'Spectrum Access Rights' ;
    rdfs:comment 'Description of spectrum bands and frequencies the MVNO is authorized to utilize (e.g., 700MHz, 1800MHz, 2600MHz, 3.5GHz 5G NR).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCapacityLimit rdf:type rdf:Property ;
    rdfs:label 'Subscriber Capacity Limit' ;
    rdfs:comment 'Maximum number of active subscribers the MVNO is permitted to host on the network infrastructure as per contractual agreement.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the technical operations contact at the MVNO for network and provisioning issues.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteEnabled rdf:type rdf:Property ;
    rdfs:label 'Volte Enabled' ;
    rdfs:comment 'Indicates whether VoLTE voice services are enabled for MVNO subscribers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vowifiEnabled rdf:type rdf:Property ;
    rdfs:label 'Vowifi Enabled' ;
    rdfs:comment 'Indicates whether VoWiFi (Wi-Fi calling) services are enabled for MVNO subscribers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Secure storage location or document management system URL for the signed roaming agreement contract.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCountries rdf:type rdf:Property ;
    rdfs:label 'Coverage Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this roaming agreement provides coverage (e.g., USA,CAN,MEX).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataMbRate rdf:type rdf:Property ;
    rdfs:label 'Data Mb Rate' ;
    rdfs:comment 'Wholesale rate per megabyte of data usage in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Period Days' ;
    rdfs:comment 'Number of days within which settlement disputes must be raised after invoice receipt.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Fraud Monitoring Enabled' ;
    rdfs:comment 'Indicates whether automated fraud detection and prevention mechanisms are active for this roaming agreement.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Fraud Threshold Amount' ;
    rdfs:comment 'Maximum allowed roaming charges per subscriber per day before fraud alerts are triggered and service may be suspended.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsmaAa12Compliant rdf:type rdf:Property ;
    rdfs:label 'Gsma Aa12 Compliant' ;
    rdfs:comment 'Indicates whether the agreement adheres to GSMA AA.12 standard for roaming agreement principles and commercial frameworks.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gsmaAa13Compliant rdf:type rdf:Property ;
    rdfs:label 'Gsma Aa13 Compliant' ;
    rdfs:comment 'Indicates whether the agreement adheres to GSMA AA.13 standard for roaming financial settlement and dispute resolution.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iotRateType rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Type' ;
    rdfs:comment 'Pricing structure for wholesale roaming charges: fixed (flat rate), tiered (volume discounts), volume_based (per unit), time_based (peak/off-peak), or hybrid (combination).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Threshold Amount' ;
    rdfs:comment 'Financial threshold in agreement currency that triggers NRTRDE notification to home network for fraud prevention.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the agreement on behalf of the roaming partner network operator.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Flag' ;
    rdfs:comment 'Indicates whether this partner is designated as a preferred roaming partner for network steering and priority routing.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rapVersion rdf:type rdf:Property ;
    rdfs:label 'Rap Version' ;
    rdfs:comment 'Version of the RAP file format used for dispute resolution and error correction (e.g., RAP3, RAP4).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypesCovered rdf:type rdf:Property ;
    rdfs:label 'Service Types Covered' ;
    rdfs:comment 'Comma-separated list of service types included in the roaming agreement: voice, SMS, data, MMS, VoLTE, video calling, 5G services, etc.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Days' ;
    rdfs:comment 'Number of days after period end by which settlement invoices must be issued and paid.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the agreement on behalf of the home network operator.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Availability Percent' ;
    rdfs:comment 'Minimum network availability percentage guaranteed by the visited network operator (e.g., 99.9%).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCallSuccessRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Call Success Rate Percent' ;
    rdfs:comment 'Minimum call setup success rate percentage guaranteed for roaming voice services.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaDataThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Sla Data Throughput Mbps' ;
    rdfs:comment 'Minimum guaranteed data throughput in megabits per second for roaming data services.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsRate rdf:type rdf:Property ;
    rdfs:label 'Sms Rate' ;
    rdfs:comment 'Wholesale rate per SMS message in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:steeringPolicy rdf:type rdf:Property ;
    rdfs:label 'Steering Policy' ;
    rdfs:comment 'Policy for directing subscribers to this partner network: automatic (default selection), manual (user choice), preferred (priority), cost_based (lowest rate), or quality_based (best QoS).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapFileFrequency rdf:type rdf:Property ;
    rdfs:label 'Tap File Frequency' ;
    rdfs:comment 'Frequency at which TAP files are exchanged between operators for settlement: daily, weekly, monthly, or real_time (near real-time).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyStandards rdf:type rdf:Property ;
    rdfs:label 'Technology Standards' ;
    rdfs:comment 'Comma-separated list of network technology standards covered: 2G, 3G, 4G LTE, 5G NR, VoLTE, IMS, etc.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceMouRate rdf:type rdf:Property ;
    rdfs:label 'Voice Mou Rate' ;
    rdfs:comment 'Wholesale rate per minute for voice calls in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this SLA is subject to regulatory compliance requirements (e.g., FCC-mandated interconnection SLAs, BEREC roaming quality standards). True if compliance reporting is mandatory.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditFormula rdf:type rdf:Property ;
    rdfs:label 'Credit Formula' ;
    rdfs:comment 'Formula or rule for calculating service credits issued to partners when SLA is breached (e.g., \'Pro-rated credit based on downtime duration\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Window Days' ;
    rdfs:comment 'Number of days within which SLA measurement disputes must be raised and resolved.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process when threshold is breached, including notification requirements and resolution timelines.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Value at which SLA breach triggers escalation to senior management or dispute resolution process. Nullable if no escalation defined.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Conditions under which SLA measurements are excluded or suspended (e.g., \'Force majeure events\', \'Planned maintenance windows with 72-hour notice\', \'Partner-caused outages\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Description of how the metric is measured, including data sources, calculation formulas, and exclusions (e.g., \'Calculated from NOC monitoring system, excluding planned maintenance windows\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time window over which SLA compliance is measured and evaluated (e.g., monthly for uptime, per_incident for MTTR, quarterly for settlement processing).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDescription rdf:type rdf:Property ;
    rdfs:label 'Metric Description' ;
    rdfs:comment 'Detailed description of how the metric is measured, calculated, and interpreted for compliance evaluation.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the measurable metric governed by this SLA (e.g., \'Network Uptime Percentage\', \'Average Latency\', \'Settlement Processing Time\', \'Dispute Resolution Time\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'List of roles or contact points to be notified when SLA thresholds are breached (e.g., \'Partner NOC Manager, Account Manager, Escalation Team\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationThreshold rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold' ;
    rdfs:comment 'Value at which proactive notifications are sent to partners warning of potential SLA breach (e.g., 95% when target is 99%).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for penalty cap amount (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyFormula rdf:type rdf:Property ;
    rdfs:label 'Penalty Formula' ;
    rdfs:comment 'Formula or rule for calculating financial penalties when SLA is breached (e.g., \'1% of monthly fee per 0.1% below threshold\', \'Fixed $10,000 per incident exceeding MTTR\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of regulatory requirement or industry standard that mandates or influences this SLA (e.g., \'FCC 47 CFR Part 51\', \'BEREC Roaming Regulation (EU) 2015/2120\', \'TM Forum SID SLASpecification\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'Format and delivery method for SLA performance reports (e.g., \'PDF via email\', \'API endpoint\', \'Partner portal dashboard\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often SLA performance reports are generated and shared with partners (e.g., monthly for uptime reports, real_time for critical QoS metrics).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Description of which services, network elements, or geographic regions this SLA applies to (e.g., \'All LTE RAN sites in Region A\', \'MVNO data services\', \'International roaming partners\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Unique business code or identifier for the SLA definition used in operational systems and reporting (e.g., \'SLA-UPTIME-001\', \'SLA-QOS-GOLD\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition: draft (under negotiation), active (in force), suspended (temporarily inactive), expired (past end date), terminated (cancelled before expiration).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name of the SLA definition (e.g., \'Gold Tier Uptime SLA\', \'MVNO QoS Commitment\', \'Roaming Settlement Processing SLA\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The committed target value for the SLA metric (e.g., 99.95 for uptime percentage, 50 for latency in milliseconds, 5 for MTTR in hours).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The minimum acceptable value before penalties or credits are triggered. May differ from target_value to allow for tolerance bands.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableProductScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Scope' ;
    rdfs:comment 'Defines the scope of products and services to which this revenue share plan applies. Determines which revenue streams are included in the calculation. [ENUM-REF-CANDIDATE: all_products|mobile_services|broadband_services|content_services|iptv_services|ott_services|voice_services|data_services|roaming_services|specific_product_list — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Type' ;
    rdfs:comment 'Specific service types covered by this revenue share plan. Free-text field for detailed service classification (e.g., \'Prepaid Mobile Voice and Data\', \'Premium IPTV Channels\', \'International Roaming Data\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Methodology used to calculate the revenue share or commission. Defines whether the share is a percentage of revenue, a fixed rate per transaction/unit, tiered based on volume thresholds, or a hybrid model.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the master partner agreement or contract under which this revenue share plan is defined. Links to legal contract documentation.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionProcess rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Process' ;
    rdfs:comment 'Description of the process and escalation path for resolving revenue share calculation disputes with the partner. References contract terms.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'Source of foreign exchange rates used for currency conversion in revenue share calculations (e.g., \'Reuters\', \'Bloomberg\', \'Central Bank Daily Rate\').' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Rate Amount' ;
    rdfs:comment 'The fixed monetary amount paid per unit/transaction when calculation_method is fixed-rate based. Null if calculation method is percentage-based or tiered.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Threshold Amount' ;
    rdfs:comment 'Maximum revenue or transaction volume subject to revenue sharing. Used for plans with capped commission structures. Null if no maximum threshold applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Amount' ;
    rdfs:comment 'Minimum revenue or transaction volume required before revenue sharing begins. Used for plans with minimum commitment clauses. Null if no minimum threshold applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the revenue share plan. Used in contracts, invoices, and settlement documents.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the revenue share plan, including scope, applicable services, and commercial terms summary.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the revenue share plan. Describes the commercial arrangement (e.g., \'MVNO Wholesale Rate Plan Q1 2024\', \'OTT Content Revenue Split - Premium Tier\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for revenue share reporting and analytics. May differ from settlement currency_code for multi-currency operations.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTermsDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms Days' ;
    rdfs:comment 'Number of days after the settlement period end date by which payment must be made to the partner. Standard payment terms (e.g., Net 30, Net 45).' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharePercentage rdf:type rdf:Property ;
    rdfs:label 'Share Percentage' ;
    rdfs:comment 'The percentage of revenue allocated to the partner when calculation_method is percentage-based. Expressed as a decimal (e.g., 15.50 for 15.5%). Null if calculation method is fixed rate or tiered.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Accuracy Percentage' ;
    rdfs:comment 'Target accuracy percentage for revenue share calculations as defined in the partner SLA. Used for performance monitoring and dispute resolution.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating the tax treatment applicable to revenue share payments under this plan. Determines withholding tax, VAT, or GST applicability.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Flag' ;
    rdfs:comment 'Indicates whether this revenue share plan uses tiered thresholds for calculation. True if the plan has multiple tiers with different rates/percentages based on volume or revenue thresholds.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Percentage of revenue share payment subject to withholding tax, if applicable. Null if no withholding tax applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRunId rdf:type rdf:Property ;
    rdfs:label 'Settlement Run Id' ;
    rdfs:comment 'Unique identifier for the settlement run execution record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementRun .

ind:settlementAgreementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Id' ;
    rdfs:comment 'Reference to the master partner agreement governing the commercial terms, revenue share percentages, and settlement frequency for this run.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business justification for the adjustment amount, documenting the cause (e.g., prior period correction, billing error, goodwill credit, contractual amendment).' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the partner has formally disputed the settlement run amounts, triggering a dispute resolution workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the settlement dispute was formally resolved, either through agreement, adjustment, or arbitration.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'The total number of detailed settlement line items (charges, credits, adjustments, usage records) included in this settlement run, providing a summary count for reconciliation purposes.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Payment Completion Date' ;
    rdfs:comment 'The actual date on which the payment was successfully transferred to the partner, confirming settlement closure.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Payment Instruction Reference' ;
    rdfs:comment 'External reference number or identifier linking this settlement run to the payment instruction sent to the treasury or accounts payable system (e.g., wire transfer batch ID, ACH transaction reference).' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance Amount' ;
    rdfs:comment 'The monetary difference identified during reconciliation between Telecommunication\'s calculated settlement amount and the partner\'s submitted claim or invoice. Positive values indicate partner over-claim; negative values indicate under-claim.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Execution Timestamp' ;
    rdfs:comment 'The date and time when the settlement calculation engine executed this run, generating the settlement amount and line-item details.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier for the settlement run, typically formatted as a human-readable code (e.g., SETT-2024-Q1-001) used in partner communications and financial reporting.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'The last date of the business period covered by this settlement run, defining the cutoff for transactions, usage events, or sales included in the settlement calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'The first date of the business period covered by this settlement run (e.g., the start of the billing cycle, roaming data exchange window, or commission calculation period).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle state of the settlement run: draft (in preparation), calculated (amounts computed), pending approval (awaiting finance review), approved (ready for payment), rejected (failed validation), payment initiated (sent to treasury), paid (funds transferred), disputed (partner contest), or cancelled (voided). [ENUM-REF-CANDIDATE: draft|calculated|pending_approval|approved|rejected|payment_initiated|paid|disputed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Category of settlement run indicating the nature of the financial arrangement: MVNO wholesale billing, roaming IOT (Inter-Operator Tariff) settlement, content provider revenue share, dealer/agent commission payout, interconnect carrier settlement, or equipment vendor rebate.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settlement Amount' ;
    rdfs:comment 'The aggregate financial amount calculated for this settlement run, representing the net payable or receivable between Telecommunication and the partner. Positive values indicate amounts owed to the partner; negative values indicate amounts owed by the partner.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementLineId rdf:type rdf:Property ;
    rdfs:label 'Settlement Line Id' ;
    rdfs:comment 'Unique identifier for the settlement line item record. Primary key.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementLine .

ind:aggregatedUsageId rdf:type rdf:Property ;
    rdfs:label 'Aggregated Usage Id' ;
    rdfs:comment 'Foreign key linking to usage.aggregated_usage. Business justification: Settlement lines are derived from aggregated usage volumes. Linking settlement_line to aggregated_usage enables wholesale billing teams to trace each settlement line item back to the specific aggregat' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AggregatedUsage .

ind:iotRateId rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Id' ;
    rdfs:comment 'Reference to the specific Inter-Operator Tariff (IOT) rate agreement used for this settlement line. Applicable for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:primarySettlementAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Settlement Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_agreement. Business justification: Settlement lines are governed by specific partner agreements. While settlement_line already links to settlement_run (which links to partner_agreement), direct linkage enables line-level agreement vali' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:cdrCount rdf:type rdf:Property ;
    rdfs:label 'Cdr Count' ;
    rdfs:comment 'Number of Call Detail Records (CDRs) or usage events aggregated into this settlement line item. Provides traceability to source usage data.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date when a dispute was formally raised against this settlement line item.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingNetwork rdf:type rdf:Property ;
    rdfs:label 'Originating Network' ;
    rdfs:comment 'Identifier of the network where the usage or transaction originated. Relevant for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapFileReference rdf:type rdf:Property ;
    rdfs:label 'Rap File Reference' ;
    rdfs:comment 'Reference to the Returned Account Procedure (RAP) file containing acknowledgments or rejections related to this settlement line.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateApplied rdf:type rdf:Property ;
    rdfs:label 'Rate Applied' ;
    rdfs:comment 'Per-unit rate applied to calculate the settlement amount. Represents the wholesale rate, Inter-Operator Tariff (IOT), or revenue share percentage.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminatingNetwork rdf:type rdf:Property ;
    rdfs:label 'Terminating Network' ;
    rdfs:comment 'Identifier of the network where the usage or transaction terminated. Relevant for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDate rdf:type rdf:Property ;
    rdfs:label 'Usage Date' ;
    rdfs:comment 'Specific date when the usage or service transaction occurred. Used for daily granularity in settlement reconciliation.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Unit' ;
    rdfs:comment 'Unit of measurement for the usage volume. Defines whether volume is measured in time, data, count, or other units. [ENUM-REF-CANDIDATE: minutes|seconds|mb|gb|messages|sessions|transactions — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageVolume rdf:type rdf:Property ;
    rdfs:label 'Usage Volume' ;
    rdfs:comment 'Quantity of service usage for this settlement line. Represents minutes, megabytes, messages, or transactions depending on service type.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between calculated settlement amount and partner-reported amount. Positive values indicate amounts owed to us; negative values indicate amounts we owe.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingRequestId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Request Id' ;
    rdfs:comment 'Unique identifier for the partner onboarding request. Primary key for this entity.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiConnectivityValidated rdf:type rdf:Property ;
    rdfs:label 'Api Connectivity Validated' ;
    rdfs:comment 'Indicates whether API connectivity testing has been successfully completed and validated.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or identifier of the business user responsible for managing this onboarding request through completion.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the onboarding request was cancelled by either party before completion.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the partner contract terms become legally effective and binding.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the partner contract was formally executed and signed by all parties.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when the partner contract is scheduled to expire unless renewed.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Status of the partner contract execution process, tracking progression from draft through final execution. [ENUM-REF-CANDIDATE: Not Started|Draft|Under Review|Negotiation|Approved|Executed|Rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Status of the financial credit assessment to evaluate the partner\'s creditworthiness and financial stability.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numerical credit score assigned to the partner based on financial assessment. Used to determine credit terms and risk level.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Documentation Checklist Complete' ;
    rdfs:comment 'Indicates whether all required onboarding documentation has been received and verified as complete.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveActualDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Actual Date' ;
    rdfs:comment 'Actual date when the partner was activated and went live in production systems.' ;
