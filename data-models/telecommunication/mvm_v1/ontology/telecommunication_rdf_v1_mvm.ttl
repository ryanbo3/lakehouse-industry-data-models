    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational state of the dealer relationship within its lifecycle from onboarding through termination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyActivationQuota rdf:type rdf:Property ;
