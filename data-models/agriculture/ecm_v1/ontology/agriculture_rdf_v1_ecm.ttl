    rdfs:comment 'Master reference table for purchasing_org. Referenced by purchasing_org_id.' .

ind:PurchasingGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Master reference table for purchasing_group. Referenced by purchasing_group_id.' .

ind:TransformationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Transformation Event' ;
    rdfs:comment 'Master reference table for transformation_event. Referenced by transformation_event_id.' .

ind:ProductLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Master reference table for product_line. Referenced by product_line_id.' .

ind:SampleSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Sample Site' ;
    rdfs:comment 'Master reference table for sample_site. Referenced by sample_site_id.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Master reference table for inspection_lot. Referenced by inspection_lot_id.' .

ind:TestPanel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Panel' ;
    rdfs:comment 'Master reference table for test_panel. Referenced by test_panel_id.' .

ind:ResearchProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
