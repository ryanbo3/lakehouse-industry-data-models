ind:inputBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Input Batch Number' ;
    rdfs:comment 'The batch or lot number of the input product being transformed, used for traceability.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'The quantity of input product used in the transformation event.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Output Batch Number' ;
    rdfs:comment 'The batch or lot number assigned to the output product, used for traceability and quality control.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'The quantity of output product produced from the transformation event.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Output Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the output quantity.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Reference to the specific production line or equipment used for the transformation.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'The temperature at which the transformation process was conducted, critical for food safety and quality control.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'Unique code used for end-to-end supply chain traceability, linking input sources to output products.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationType rdf:type rdf:Property ;
    rdfs:label 'Transformation Type' ;
    rdfs:comment 'The category of transformation applied to the agricultural product (e.g., milling grain to flour, processing milk to cheese, packaging fresh produce).' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity' ;
    rdfs:comment 'The quantity of material lost or discarded during the transformation process (e.g., chaff, whey, trimmings).' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Waste Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the waste quantity.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'The percentage of input product that was successfully converted to output product, calculated as (output_quantity / input_quantity) * 100.' ;
    rdfs:domain ind:TransformationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentProductLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Product Line Id' ;
    rdfs:comment 'Reference to the parent product line in the product hierarchy, enabling multi-level product line structures.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductLine .

ind:countryOfOriginLabelingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Labeling Required Flag' ;
    rdfs:comment 'Indicates whether products in this line are subject to mandatory Country of Origin Labeling (COOL) requirements under USDA regulations.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'Harmonized Tariff Schedule code for international trade classification and customs processing of products in this line.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when this product line was first introduced to the market.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Unique business code identifying the product line across systems and external partners.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Full business name of the product line as recognized in the market and internal systems.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy Level' ;
    rdfs:comment 'Numeric level in the product classification hierarchy where this product line resides (e.g., 1=Division, 2=Category, 3=Line, 4=Sub-line).' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productManagerName rdf:type rdf:Property ;
    rdfs:label 'Product Manager Name' ;
    rdfs:comment 'Name of the product manager or business owner responsible for this product line.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAvailability rdf:type rdf:Property ;
    rdfs:label 'Seasonal Availability' ;
    rdfs:comment 'Description of seasonal availability pattern for products in this line (e.g., year-round, spring-summer, harvest season only).' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment or sales channel targeted by this product line.' ;
    rdfs:domain ind:ProductLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Full name of the primary contact person responsible for quality sampling and coordination at this site.' ;
    rdfs:domain ind:SampleSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapGmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gap Gmp Compliant' ;
    rdfs:comment 'Indicates whether this sample site is currently compliant with GAP and GMP standards as verified by audit findings.' ;
    rdfs:domain ind:SampleSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Standard operational hours or shift schedule for the sample site indicating when sampling activities can be conducted.' ;
    rdfs:domain ind:SampleSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code corresponding to this sample site for integration with SAP Quality Management (QM) module.' ;
    rdfs:domain ind:SampleSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Reference to the production batch associated with this inspection lot for traceability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Reference to the inspection plan or protocol that defines the testing procedures and acceptance criteria for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Reference to the production order that generated this inspection lot, applicable for finished goods and work-in-process.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:acceptanceQualityLimit rdf:type rdf:Property ;
    rdfs:label 'Acceptance Quality Limit' ;
    rdfs:comment 'Maximum percentage of defects or non-conformances acceptable for the lot to be approved, expressed as a percentage.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions are required based on the inspection findings.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical defects identified that pose safety risks or render the product unusable.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances identified during the inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Timestamp' ;
    rdfs:comment 'Date and time when all inspection activities for this lot were completed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionSeverity rdf:type rdf:Property ;
    rdfs:label 'Inspection Severity' ;
    rdfs:comment 'Severity level of the inspection based on historical quality performance and risk assessment.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Total quantity of material or product in this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Lot Size Unit' ;
    rdfs:comment 'Unit of measure for the lot size quantity.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the inspection lot based on the material or product category being inspected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Major Defect Count' ;
    rdfs:comment 'Number of major defects identified that significantly impact product functionality or quality.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defect Count' ;
    rdfs:comment 'Number of minor defects identified that have minimal impact on product quality or functionality.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the inspection lot is currently under quarantine and restricted from use or shipment.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Explanation for why the inspection lot has been placed under quarantine, including specific quality or safety concerns.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the inspection lot was officially released for use, sale, or further processing following approval.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Size Quantity' ;
    rdfs:comment 'Quantity of material drawn from the lot for inspection and testing purposes.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Size Unit' ;
    rdfs:comment 'Unit of measure for the sample size quantity.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Final disposition decision for the inspected lot determining whether it can be released for use, sale, or further processing.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandardId rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Id' ;
    rdfs:comment 'Identifier of the quality standard or specification this test panel is designed to verify compliance against.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityStandard .

ind:accreditationRequired rdf:type rdf:Property ;
    rdfs:label 'Accreditation Required' ;
    rdfs:comment 'Indicates whether this test panel requires accredited laboratory execution per regulatory or certification requirements.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accreditationStandard rdf:type rdf:Property ;
    rdfs:label 'Accreditation Standard' ;
    rdfs:comment 'The accreditation standard or certification scheme required for this test panel (e.g., ISO/IEC 17025, AOAC, USDA, FDA).' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenTestingIncluded rdf:type rdf:Property ;
    rdfs:label 'Allergen Testing Included' ;
    rdfs:comment 'Indicates whether this test panel includes allergen detection or quantification tests.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableProductCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or commodity types for which this test panel is applicable (e.g., fresh produce, dairy, meat, grains).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerPanel rdf:type rdf:Property ;
    rdfs:label 'Cost Per Panel' ;
    rdfs:comment 'Standard cost to execute this test panel including all individual tests, labor, and materials.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalControlPoint rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point' ;
    rdfs:comment 'Indicates whether this test panel monitors a critical control point in the HACCP food safety plan.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Hazard Analysis Required' ;
    rdfs:comment 'Indicates whether this test panel requires formal hazard analysis and critical control point (HACCP) documentation.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumResidueLimitApplicable rdf:type rdf:Property ;
    rdfs:label 'Maximum Residue Limit Applicable' ;
    rdfs:comment 'Indicates whether this test panel includes maximum residue limit (MRL) testing for pesticides, veterinary drugs, or contaminants.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodReference rdf:type rdf:Property ;
    rdfs:label 'Method Reference' ;
    rdfs:comment 'Reference to the analytical method or standard operating procedure (SOP) document governing this test panel execution.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCategory rdf:type rdf:Property ;
    rdfs:label 'Panel Category' ;
    rdfs:comment 'Business category indicating the purpose of the test panel (routine quality control, regulatory compliance, certification audit, customer complaint investigation, method validation, or research and development).' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the test panel in laboratory and quality systems.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Human-readable name of the test panel describing the suite of tests performed.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the test panel by testing discipline (microbiological, chemical, physical, sensory, nutritional, or allergen testing).' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathogenTestingIncluded rdf:type rdf:Property ;
    rdfs:label 'Pathogen Testing Included' ;
    rdfs:comment 'Indicates whether this test panel includes pathogen detection tests (e.g., Salmonella, E. coli, Listeria).' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Required frequency in months for periodic review and validation of the test panel to ensure continued relevance and accuracy.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeRequired rdf:type rdf:Property ;
    rdfs:label 'Sample Size Required' ;
    rdfs:comment 'Minimum sample size or quantity required to execute the complete test panel.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Sample Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the required sample size (grams, kilograms, milliliters, liters, units, or each).' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCount rdf:type rdf:Property ;
    rdfs:label 'Test Count' ;
    rdfs:comment 'Total number of individual tests included in this test panel.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Standard turnaround time in hours from sample receipt to results reporting for this test panel.' ;
    rdfs:domain ind:TestPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual expenditure incurred for the research project in USD.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total allocated budget for the research project in USD.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of external organization or institution collaborating on the research project.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Collection Frequency' ;
    rdfs:comment 'Frequency at which experimental data and measurements are collected during the trial.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTraitIndicator rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Indicator' ;
    rdfs:comment 'Flag indicating whether the project involves genetically modified organisms or traits.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intellectualPropertyStatus rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Status' ;
    rdfs:comment 'Current intellectual property protection status for innovations developed in this project.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfReplications rdf:type rdf:Property ;
    rdfs:label 'Number Of Replications' ;
    rdfs:comment 'Number of experimental replications or blocks used in the trial design.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTreatments rdf:type rdf:Property ;
    rdfs:label 'Number Of Treatments' ;
    rdfs:comment 'Total number of distinct treatments or experimental conditions being evaluated.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'Official patent number if intellectual property protection has been granted.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionAgricultureTechnology rdf:type rdf:Property ;
    rdfs:label 'Precision Agriculture Technology' ;
    rdfs:comment 'Specific precision agriculture technology or tool being piloted or evaluated in the project.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the research project for tracking and reference purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name or title of the research project.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Citation or reference information for published research findings.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current status of research findings publication in scientific journals or conferences.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Number' ;
    rdfs:comment 'Official submission or permit number assigned by the regulatory authority.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchObjective rdf:type rdf:Property ;
    rdfs:label 'Research Objective' ;
    rdfs:comment 'Detailed description of the primary research objective and hypothesis being tested in this project.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Level' ;
    rdfs:comment 'Overall risk level associated with the research project based on safety, regulatory, and operational factors.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Analysis Method' ;
    rdfs:comment 'Primary statistical analysis methodology or software used for data analysis.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFocus rdf:type rdf:Property ;
    rdfs:label 'Sustainability Focus' ;
    rdfs:comment 'Flag indicating whether the project has a primary focus on sustainable farming practices or environmental impact reduction.' ;
    rdfs:domain ind:ResearchProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bolGenerationRequired rdf:type rdf:Property ;
    rdfs:label 'Bol Generation Required' ;
    rdfs:comment 'Indicates whether Bill of Lading documents must be automatically generated for shipments in this channel. Typically true for wholesale and export channels.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the distribution channel in external systems and business documents. Used in SAP S/4HANA SD module for channel classification.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed business description of the distribution channel, including its purpose, target customers, and operational characteristics.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Email' ;
    rdfs:comment 'Email address of the channel manager for business communication and escalation purposes.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelManagerName rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Name' ;
    rdfs:comment 'Name of the business manager responsible for this distribution channel. Used for accountability and escalation.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Full business name of the distribution channel used for reporting and user interfaces.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the distribution channel in the sales lifecycle. Controls whether new orders can be placed through this channel.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the distribution channel by business model. Determines pricing strategy, contract terms, and fulfillment processes.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Standard commission percentage paid to brokers, distributors, or sales representatives for transactions in this channel. Business-sensitive pricing information.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether customer credit verification is mandatory before order acceptance in this channel. Typically true for wholesale and broker channels.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Crm Integration Enabled' ;
    rdfs:comment 'Indicates whether this channel is integrated with Salesforce CRM for opportunity management and pipeline tracking.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultChannel rdf:type rdf:Property ;
    rdfs:label 'Is Default Channel' ;
    rdfs:comment 'Indicates whether this is the default distribution channel for the sales organization. Used in order entry when no specific channel is selected.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketPricingFeedSource rdf:type rdf:Property ;
    rdfs:label 'Market Pricing Feed Source' ;
    rdfs:comment 'External market data source used for pricing signals in this channel. DTN and WASDE are common sources for agricultural commodity pricing.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required for orders in this channel. Enforced at order entry to maintain channel profitability.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this distribution channel record. Used for audit trail and accountability.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerBrokerNetwork rdf:type rdf:Property ;
    rdfs:label 'Partner Broker Network' ;
    rdfs:comment 'Description of the partner and broker relationships associated with this distribution channel. Used for relationship management and commission tracking.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDefault rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Default' ;
    rdfs:comment 'Standard payment terms applied to transactions in this channel (e.g., Net 30, Net 60, COD, prepayment). Used as default in sales order creation.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdChannelCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Channel Code' ;
    rdfs:comment 'Two-character distribution channel code used in SAP S/4HANA SD module. Used for system integration and data synchronization.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalDemandPattern rdf:type rdf:Property ;
    rdfs:label 'Seasonal Demand Pattern' ;
    rdfs:comment 'Description of the seasonal demand characteristics for this channel (e.g., peak harvest season, holiday demand). Used in sales forecasting and inventory planning.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the transport unit measured in cubic meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the transport unit measured in kilograms.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Code' ;
    rdfs:comment 'Code representing the current physical location or facility where the transport unit is stationed.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodGradeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified Flag' ;
    rdfs:comment 'Indicates whether the transport unit meets food safety certification standards for transporting agricultural products and food.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled Flag' ;
    rdfs:comment 'Indicates whether the transport unit is equipped with GPS tracking capability for real-time location monitoring.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'External height dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Home Location Code' ;
    rdfs:comment 'Code representing the primary or home base location where the transport unit is normally stationed when not in use.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthM rdf:type rdf:Property ;
    rdfs:label 'Length M' ;
    rdfs:comment 'External length dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureYear rdf:type rdf:Property ;
    rdfs:label 'Manufacture Year' ;
    rdfs:comment 'Year in which the transport unit was manufactured.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification indicating the ownership model of the transport unit.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Externally-known unique identifier or registration number for the transport unit (e.g., container number, trailer number, railcar number).' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the transport unit by physical form factor and mode of transport.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthM rdf:type rdf:Property ;
    rdfs:label 'Width M' ;
    rdfs:comment 'External width dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentShipmentId rdf:type rdf:Property ;
    rdfs:label 'Current Shipment Id' ;
    rdfs:comment 'Reference to the active shipment currently using this container. Null when container is available or at facility.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Overall physical condition assessment of the container. Influences maintenance priority, rental rates, and cargo suitability.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCategory rdf:type rdf:Property ;
    rdfs:label 'Container Category' ;
    rdfs:comment 'High-level classification of container by cargo handling characteristics. Determines compatible cargo types and handling equipment requirements.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSize rdf:type rdf:Property ;
    rdfs:label 'Container Size' ;
    rdfs:comment 'Standard container length classification used for capacity planning and transportation scheduling.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Container Type Code' ;
    rdfs:comment 'ISO 6346 four-character code identifying container size and type (e.g., 22G1 for 20ft general purpose, 45R1 for 40ft high cube reefer). Defines physical characteristics and handling requirements.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRentalRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rental Rate' ;
    rdfs:comment 'Daily lease or rental cost for the container in USD. Used for cost allocation and financial planning for leased assets.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified' ;
    rdfs:comment 'Indicates whether the container is certified for transporting food products. Required for FSMA compliance in agricultural supply chains.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Internal Volume Cubic Meters' ;
    rdfs:comment 'Internal cargo capacity in cubic meters. Used for volumetric load planning and freight rate calculations.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Kg' ;
    rdfs:comment 'Maximum permissible gross weight including container and cargo in kilograms. Critical for load planning and regulatory compliance.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum cargo weight capacity in kilograms, calculated as max gross weight minus tare weight. Used for shipment planning and optimization.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerCode rdf:type rdf:Property ;
    rdfs:label 'Owner Code' ;
    rdfs:comment 'Four-letter Bureau International des Containers (BIC) registered owner/operator code. First three letters identify the owner, fourth letter is U for freight containers.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refrigerationCapable rdf:type rdf:Property ;
    rdfs:label 'Refrigeration Capable' ;
    rdfs:comment 'Indicates whether the container is equipped with refrigeration (reefer) capability for cold chain management of temperature-sensitive agricultural products.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature capability in Celsius for refrigerated containers. Ensures proper storage conditions for diverse agricultural products.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature capability in Celsius for refrigerated containers. Critical for cold chain compliance and perishable cargo handling.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonProjectId rdf:type rdf:Property ;
    rdfs:label 'Carbon Project Id' ;
    rdfs:comment 'Primary key for carbon_project' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalityJustification rdf:type rdf:Property ;
    rdfs:label 'Additionality Justification' ;
    rdfs:comment 'Explanation demonstrating that the carbon reductions would not have occurred without the project, meeting additionality requirements.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineScenario rdf:type rdf:Property ;
    rdfs:label 'Baseline Scenario' ;
    rdfs:comment 'Description of the baseline scenario representing the emissions or carbon stock that would occur without the project intervention.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityCoBenefits rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Co Benefits' ;
    rdfs:comment 'Description of additional biodiversity conservation and ecosystem benefits generated by the carbon project beyond carbon sequestration.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferPoolContributionPercent rdf:type rdf:Property ;
    rdfs:label 'Buffer Pool Contribution Percent' ;
    rdfs:comment 'The percentage of generated carbon credits withheld and contributed to a buffer pool to insure against permanence risk.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityCoBenefits rdf:type rdf:Property ;
    rdfs:label 'Community Co Benefits' ;
    rdfs:comment 'Description of social and economic benefits provided to local communities through the carbon project implementation.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditingPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Crediting Period Years' ;
    rdfs:comment 'The duration in years for which the project is eligible to generate verified carbon credits under the certification standard.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAnnualCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Co2e Tonnes' ;
    rdfs:comment 'The projected annual carbon sequestration or emission reduction measured in tonnes of carbon dioxide equivalent.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakageAssessment rdf:type rdf:Property ;
    rdfs:label 'Leakage Assessment' ;
    rdfs:comment 'Assessment of potential emissions increases outside the project boundary caused by project activities, and mitigation measures.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Methodology Version' ;
    rdfs:comment 'Version identifier of the carbon accounting methodology applied to the project for quantification and verification.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Date' ;
    rdfs:comment 'The planned date for the next third-party verification audit to validate carbon credit generation.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permanenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Permanence Risk Rating' ;
    rdfs:comment 'Assessment of the risk that sequestered carbon may be released back into the atmosphere due to natural or human-caused disturbances.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDeveloper rdf:type rdf:Property ;
    rdfs:label 'Project Developer' ;
    rdfs:comment 'The name of the organization or entity responsible for developing and implementing the carbon project.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Project Location Country' ;
    rdfs:comment 'Three-letter ISO country code identifying the country where the carbon project is physically located.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationRegion rdf:type rdf:Property ;
    rdfs:label 'Project Location Region' ;
    rdfs:comment 'The state, province, or administrative region where the carbon project is located within the country.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectOwner rdf:type rdf:Property ;
    rdfs:label 'Project Owner' ;
    rdfs:comment 'The legal owner of the carbon project and holder of the carbon credit rights generated by the project.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryUrl rdf:type rdf:Property ;
    rdfs:label 'Registry Url' ;
    rdfs:comment 'Web address link to the projects public listing in the carbon credit registry for transparency and verification.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment' ;
    rdfs:comment 'Comma-separated list of United Nations Sustainable Development Goal numbers that the project contributes to achieving.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Verified Co2e Tonnes' ;
    rdfs:comment 'The cumulative verified carbon credits issued for the project in tonnes of CO2 equivalent, confirmed through third-party verification.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizationalScopeId rdf:type rdf:Property ;
    rdfs:label 'Organizational Scope Id' ;
    rdfs:comment 'Primary key for organizational_scope' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentScopeId rdf:type rdf:Property ;
    rdfs:label 'Parent Scope Id' ;
    rdfs:comment 'Reference to the parent organizational scope in the hierarchy, enabling nested organizational structures.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganizationalScope .

ind:biodiversityIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Included Flag' ;
    rdfs:comment 'Indicates whether biodiversity impact assessments and metrics are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boundaryDefinition rdf:type rdf:Property ;
    rdfs:label 'Boundary Definition' ;
    rdfs:comment 'Formal definition of the organizational boundary including which operations, facilities, and entities are included or excluded.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessActivities rdf:type rdf:Property ;
    rdfs:label 'Business Activities' ;
    rdfs:comment 'Description of primary business activities conducted within this organizational scope (e.g., crop cultivation, livestock production, processing).' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationPrograms rdf:type rdf:Property ;
    rdfs:label 'Certification Programs' ;
    rdfs:comment 'Voluntary certification programs applicable to this scope (e.g., Organic, Rainforest Alliance, Fair Trade, Regenerative Organic).' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationApproach rdf:type rdf:Property ;
    rdfs:label 'Consolidation Approach' ;
    rdfs:comment 'Method used to consolidate greenhouse gas emissions and sustainability metrics across the organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsReductionTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Emissions Reduction Target Percentage' ;
    rdfs:comment 'Committed percentage reduction in greenhouse gas emissions from baseline year to target year.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equitySharePercentage rdf:type rdf:Property ;
    rdfs:label 'Equity Share Percentage' ;
    rdfs:comment 'Percentage of equity ownership for equity share consolidation approach (0.00 to 100.00).' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAssuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Assurance Required Flag' ;
    rdfs:comment 'Indicates whether sustainability data for this organizational scope requires third-party external assurance or verification.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic regions, countries, or territories covered by this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedFacilitiesCount rdf:type rdf:Property ;
    rdfs:label 'Included Facilities Count' ;
    rdfs:comment 'Number of facilities, farms, or operational sites included within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the primary country of operations within this scope.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1IncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Included Flag' ;
    rdfs:comment 'Indicates whether Scope 1 (direct) greenhouse gas emissions are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope2IncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Included Flag' ;
    rdfs:comment 'Indicates whether Scope 2 (indirect energy) greenhouse gas emissions are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope3IncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Included Flag' ;
    rdfs:comment 'Indicates whether Scope 3 (value chain) greenhouse gas emissions are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeCode rdf:type rdf:Property ;
    rdfs:label 'Scope Code' ;
    rdfs:comment 'Business identifier code for the organizational scope used in reporting and external references.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeName rdf:type rdf:Property ;
    rdfs:label 'Scope Name' ;
    rdfs:comment 'Human-readable name of the organizational scope (e.g., \'Global Operations\', \'North America Region\', \'Dairy Division\').' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Classification of the organizational scope level within the enterprise hierarchy.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilCarbonIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Soil Carbon Included Flag' ;
    rdfs:comment 'Indicates whether soil carbon sequestration and soil health metrics are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetYear rdf:type rdf:Property ;
    rdfs:label 'Target Year' ;
    rdfs:comment 'Target year for achieving sustainability goals and emissions reduction commitments for this scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterStewardshipIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Included Flag' ;
    rdfs:comment 'Indicates whether water consumption and stewardship metrics are tracked within this organizational scope.' ;
    rdfs:domain ind:OrganizationalScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Id' ;
    rdfs:comment 'Primary key for insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyholderAccountId rdf:type rdf:Property ;
    rdfs:label 'Policyholder Account Id' ;
    rdfs:comment 'FK to customer.account' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:acreageReportingDate rdf:type rdf:Property ;
    rdfs:label 'Acreage Reporting Date' ;
    rdfs:comment 'Deadline by which the policyholder must report planted acreage to the insurance carrier. Failure to report by this date may result in coverage denial.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedYieldPerAcre rdf:type rdf:Property ;
    rdfs:label 'Approved Yield Per Acre' ;
    rdfs:comment 'The approved or guaranteed yield per acre established by the insurance carrier based on historical production records. Used as the baseline for calculating coverage and claims.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Coverage Level Percent' ;
    rdfs:comment 'Percentage of the approved yield or revenue that is insured under this policy (e.g., 50%, 65%, 75%, 85%). Higher coverage levels result in higher premiums.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Amount the policyholder must pay out-of-pocket before insurance coverage begins. May be expressed as a dollar amount or percentage of liability.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Harvest Price Per Unit' ;
    rdfs:comment 'The actual commodity price per unit at harvest time. Used in revenue protection policies to determine final claim amounts.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredAcres rdf:type rdf:Property ;
    rdfs:label 'Insured Acres' ;
    rdfs:comment 'Total number of acres covered under this insurance policy. Critical for calculating premiums and claim payouts.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Maximum amount the insurance carrier is liable to pay under this policy in the event of a covered loss. Calculated as insured acres × approved yield × coverage level × projected price.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyTermsDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Terms Document Url' ;
    rdfs:comment 'URL or file path to the full policy terms and conditions document. Provides legal reference for coverage details, exclusions, and claim procedures.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the insurance policy indicating the type of agricultural coverage provided (e.g., crop hail, multi-peril crop insurance, crop revenue, livestock mortality, farm property, equipment).' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventedPlantingCoverage rdf:type rdf:Property ;
    rdfs:label 'Prevented Planting Coverage' ;
    rdfs:comment 'Indicates whether this policy includes coverage for prevented planting due to adverse weather conditions (e.g., excessive rain, flooding, drought) that make planting impossible.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:producerPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Producer Premium Amount' ;
    rdfs:comment 'Net premium amount paid by the producer/policyholder after subsidies and discounts are applied.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionReportingDate rdf:type rdf:Property ;
    rdfs:label 'Production Reporting Date' ;
    rdfs:comment 'Deadline by which the policyholder must report actual production/yield to the insurance carrier for claim settlement purposes.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Projected Price Per Unit' ;
    rdfs:comment 'The projected commodity price per unit (bushel, ton, cwt) established at the beginning of the crop year. Used for revenue-based policies to calculate guaranteed revenue.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalEligible rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible' ;
    rdfs:comment 'Indicates whether this policy is eligible for automatic renewal for the next crop year based on claims history and compliance.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replantCoverage rdf:type rdf:Property ;
    rdfs:label 'Replant Coverage' ;
    rdfs:comment 'Indicates whether this policy includes coverage for replanting costs when crops fail to germinate or are destroyed shortly after planting due to insured causes.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesClosingDate rdf:type rdf:Property ;
    rdfs:label 'Sales Closing Date' ;
    rdfs:comment 'Last date on which a producer can purchase or make changes to this insurance policy for the current crop year.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Subsidy Amount' ;
    rdfs:comment 'Government subsidy amount applied to reduce the policyholder\'s premium cost. Common in federally-supported crop insurance programs.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'Total premium amount charged for this insurance policy before any subsidies or discounts.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingNotes rdf:type rdf:Property ;
    rdfs:label 'Underwriting Notes' ;
    rdfs:comment 'Free-text notes from the underwriter regarding special conditions, risk factors, or considerations for this policy.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStructure rdf:type rdf:Property ;
    rdfs:label 'Unit Structure' ;
    rdfs:comment 'Defines how insured acreage is grouped for coverage purposes. Basic units are by section, optional units by field, enterprise units combine all acreage of a crop, and whole-farm units cover all crops together.' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimId rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Id' ;
    rdfs:comment 'Primary key for insurance_claim' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acresAffected rdf:type rdf:Property ;
    rdfs:label 'Acres Affected' ;
    rdfs:comment 'The total acreage of farmland affected by the loss event. Measured in acres.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Claim Amount' ;
    rdfs:comment 'The final approved claim payout amount after underwriting review and policy coverage calculations. Measured in USD.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Loss Amount' ;
    rdfs:comment 'The loss amount determined by the insurance adjuster after field inspection and evaluation. Measured in USD.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'The coverage level percentage selected by the policyholder under the insurance policy (e.g., 50%, 65%, 75%, 85%). Measured as a percentage.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'The initial estimated monetary value of the loss as reported by the policyholder or agent. Measured in USD.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filedDate rdf:type rdf:Property ;
    rdfs:label 'Filed Date' ;
    rdfs:comment 'The date on which the formal claim documentation was filed with the insurance carrier.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this claim has been flagged for potential fraud investigation. True if flagged, False otherwise.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payout Amount' ;
    rdfs:comment 'The net amount paid to the policyholder after deductibles and adjustments. Measured in USD.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Flag' ;
    rdfs:comment 'Indicates whether this claim is subject to reinsurance arrangements. True if reinsurance applies, False otherwise.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocumentation rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation' ;
    rdfs:comment 'References to supporting documents submitted with the claim (e.g., photos, weather reports, yield records, receipts). Stored as file paths or document identifiers.' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Percentage' ;
    rdfs:comment 'The percentage of expected crop yield lost due to the insured event. Measured as a percentage (0-100).' ;
    rdfs:domain ind:InsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyRating rdf:type rdf:Property ;
    rdfs:label 'Accuracy Rating' ;
    rdfs:comment 'Manufacturer-specified accuracy rating of the sensor expressed as a percentage or tolerance value, indicating the precision of measurements.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Installation Height Meters' ;
    rdfs:comment 'Height in meters above ground level at which the sensor is mounted, relevant for wind speed, temperature, and other measurements that vary with height.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reading Timestamp' ;
    rdfs:comment 'Timestamp of the most recent data reading received from the sensor, used to monitor sensor connectivity and operational status.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Maximum value that the sensor is capable of measuring within its operational specifications.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Minimum value that the sensor is capable of measuring within its operational specifications.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingFrequencySeconds rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Seconds' ;
    rdfs:comment 'Interval in seconds at which the sensor collects and reports measurements. Lower values indicate more frequent data collection.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code or serial number assigned to the sensor device by the manufacturer or deployment system.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorName rdf:type rdf:Property ;
    rdfs:label 'Sensor Name' ;
    rdfs:comment 'Human-readable name or label assigned to the sensor for identification purposes in field operations and monitoring dashboards.' ;
    rdfs:domain ind:Sensor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandardId rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Id' ;
    rdfs:comment 'Primary key for calibration_standard' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyTolerance rdf:type rdf:Property ;
    rdfs:label 'Accuracy Tolerance' ;
    rdfs:comment 'The maximum permissible deviation from the reference value, expressed in the same unit of measure. Defines the acceptable calibration error range.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableSensorTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Sensor Types' ;
    rdfs:comment 'List of sensor types and models that can be calibrated using this standard, such as thermocouples, resistance temperature detectors, capacitive humidity sensors, or tipping bucket rain gauges.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certifying Authority' ;
    rdfs:comment 'The name of the accredited laboratory, national metrology institute, or certification body that issued the calibration certificate for this standard.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'The statistical confidence level associated with the uncertainty value, typically expressed as a percentage such as 95% or 99%.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Name of the person or department responsible for the custody, maintenance, and proper use of this calibration standard.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryStandard rdf:type rdf:Property ;
    rdfs:label 'Is Primary Standard' ;
    rdfs:comment 'Boolean flag indicating whether this is a primary calibration standard with direct traceability to national standards, or a secondary/working standard derived from a primary standard.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementParameter rdf:type rdf:Property ;
    rdfs:label 'Measurement Parameter' ;
    rdfs:comment 'Specific meteorological or environmental parameter that this standard is designed to measure or calibrate, such as air temperature, relative humidity, barometric pressure, or rainfall intensity.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'The scheduled date for the next verification or recalibration of the standard. Used for maintenance planning and compliance tracking.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingRangeMax rdf:type rdf:Property ;
    rdfs:label 'Operating Range Max' ;
    rdfs:comment 'The maximum value of the measurement range over which this calibration standard is valid and accurate, expressed in the unit of measure.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingRangeMin rdf:type rdf:Property ;
    rdfs:label 'Operating Range Min' ;
    rdfs:comment 'The minimum value of the measurement range over which this calibration standard is valid and accurate, expressed in the unit of measure.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Recalibration Interval Days' ;
    rdfs:comment 'The recommended number of days between recalibrations to maintain the standards accuracy and traceability. Typically ranges from 180 to 730 days depending on standard type and usage.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceValue rdf:type rdf:Property ;
    rdfs:label 'Reference Value' ;
    rdfs:comment 'The certified reference value of the calibration standard. This is the known, traceable value against which field sensors and equipment are calibrated.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardType rdf:type rdf:Property ;
    rdfs:label 'Standard Type' ;
    rdfs:comment 'Category of calibration standard indicating which meteorological parameter it is designed to calibrate. Determines applicability to specific sensor types.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for proper storage of the calibration standard when not in use, including temperature range, humidity limits, and protection requirements.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityChain rdf:type rdf:Property ;
    rdfs:label 'Traceability Chain' ;
    rdfs:comment 'Documentation of the unbroken chain of calibrations linking this standard to national or international measurement standards, ensuring metrological traceability.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageInstructions rdf:type rdf:Property ;
    rdfs:label 'Usage Instructions' ;
    rdfs:comment 'Detailed instructions for proper use of the calibration standard in field and laboratory calibration procedures, including setup, stabilization time, and handling precautions.' ;
    rdfs:domain ind:CalibrationStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationNetworkId rdf:type rdf:Property ;
    rdfs:label 'Station Network Id' ;
    rdfs:comment 'Primary key for station_network' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualSubscriptionCost rdf:type rdf:Property ;
    rdfs:label 'Annual Subscription Cost' ;
    rdfs:comment 'Annual cost in USD for accessing data from this commercial weather network. Null for free government or cooperative networks. Used for cost allocation and vendor performance analysis.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for the network\'s data API endpoint. Used by integration services to retrieve weather data programmatically. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Security authentication mechanism required to access the network\'s data feed. API Key for token-based access; OAuth for delegated authorization; Basic Auth for username/password; Certificate for mutual TLS; None for public data sources.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Standard interval in days between equipment calibration cycles for stations in this network. Critical for maintaining measurement accuracy for precision agriculture applications.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageRegion rdf:type rdf:Property ;
    rdfs:label 'Coverage Region' ;
    rdfs:comment 'Geographic region or territory covered by the station network. May be global, national, state-level, or localized to specific agricultural zones.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFeedProtocol rdf:type rdf:Property ;
    rdfs:label 'Data Feed Protocol' ;
    rdfs:comment 'Technical protocol used to receive weather data from the network. API for RESTful services; FTP for batch file transfers; MQTT for IoT sensor streams; HTTP for web services; WebSocket for real-time streaming; proprietary for vendor-specific formats.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFormat rdf:type rdf:Property ;
    rdfs:label 'Data Format' ;
    rdfs:comment 'File or message format used by the network to deliver weather data. JSON and XML for web services; CSV for tabular data; GRIB and NetCDF for gridded meteorological data; Proprietary for vendor-specific formats requiring custom parsers.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLatencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Latency Minutes' ;
    rdfs:comment 'Average time delay between observation collection at the station and data availability in the feed, measured in minutes. Critical for time-sensitive agricultural decisions like spray window timing.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataParametersAvailable rdf:type rdf:Property ;
    rdfs:label 'Data Parameters Available' ;
    rdfs:comment 'Comma-separated list of weather parameters provided by this network (e.g., \'temperature,precipitation,humidity,wind_speed,solar_radiation,soil_moisture,evapotranspiration\'). Defines the analytical capabilities supported by this network.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUpdateFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Update Frequency Minutes' ;
    rdfs:comment 'Frequency at which the network publishes updated weather observations, measured in minutes. Typical values: 5 minutes for real-time IoT sensors, 15 minutes for automated stations, 60 minutes for manual observations.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Web URL pointing to the network\'s technical documentation, API specifications, and data dictionaries. Essential reference for data integration and interpretation.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalDataStartDate rdf:type rdf:Property ;
    rdfs:label 'Historical Data Start Date' ;
    rdfs:comment 'Earliest date for which historical weather observations are available from this network. Important for climate analysis, growing degree day (GDD) calculations, and multi-year trend analysis.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementUnitsSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Units System' ;
    rdfs:comment 'Standard system of measurement used by the network for reporting weather data. Metric uses Celsius, millimeters, meters per second; Imperial uses Fahrenheit, inches, miles per hour; Mixed uses combination based on parameter type.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the weather station network. Used for external references and integrations with DTN, Climate FieldView, and other weather data providers.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Full business name of the weather station network (e.g., \'National Weather Service ASOS\', \'DTN Agricultural Network\', \'Climate FieldView Station Grid\').' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current operational status of the weather station network. Active networks provide real-time data feeds; inactive networks are temporarily offline; suspended networks have data quality issues; decommissioned networks are permanently retired; pilot networks are in testing phase.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Classification of the station network by ownership and operational model. Government networks include NWS, NOAA; commercial includes DTN, Weather Underground; cooperative includes CoCoRaHS; private includes on-farm IoT sensor networks; research includes university agricultural research stations.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorOrganization rdf:type rdf:Property ;
    rdfs:label 'Operator Organization' ;
    rdfs:comment 'Name of the organization that owns and operates the weather station network (e.g., \'National Oceanic and Atmospheric Administration\', \'DTN LLC\', \'Climate Corporation\', \'Iowa State University\').' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Level' ;
    rdfs:comment 'Level of data quality control and validation applied by the network. Basic includes automated range checks; Standard adds cross-validation with nearby stations; Enhanced includes manual review and correction; Research Grade meets scientific publication standards.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityScore rdf:type rdf:Property ;
    rdfs:label 'Reliability Score' ;
    rdfs:comment 'Calculated reliability metric (0-100) based on data availability, uptime, and quality over the past 12 months. Used for vendor performance evaluation and data source prioritization in multi-network environments.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spatialResolutionKm rdf:type rdf:Property ;
    rdfs:label 'Spatial Resolution Km' ;
    rdfs:comment 'Average distance in kilometers between stations in the network, representing the spatial granularity of coverage. Lower values indicate denser station placement and more localized weather data. Critical for field-level precision agriculture.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationCount rdf:type rdf:Property ;
    rdfs:label 'Station Count' ;
    rdfs:comment 'Total number of active weather stations currently operating within this network. Updated periodically as stations are added or decommissioned.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsAlerts rdf:type rdf:Property ;
    rdfs:label 'Supports Alerts' ;
    rdfs:comment 'Indicates whether the network provides automated weather alerts and warnings (e.g., frost alerts, severe weather warnings, spray window notifications). Critical for risk management and operational decision support.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsForecastData rdf:type rdf:Property ;
    rdfs:label 'Supports Forecast Data' ;
    rdfs:comment 'Indicates whether the network provides forecast data in addition to historical and real-time observations. True for networks like DTN and NOAA that include predictive models; False for observation-only networks.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsOfUseUrl rdf:type rdf:Property ;
    rdfs:label 'Terms Of Use Url' ;
    rdfs:comment 'Web URL pointing to the legal terms of use, licensing restrictions, and data redistribution policies for the network\'s data. Critical for compliance with data usage agreements.' ;
    rdfs:domain ind:StationNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Bmp Compliance Status' ;
    rdfs:comment 'Current compliance status with agricultural best management practices for environmental stewardship.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationPlanDate rdf:type rdf:Property ;
    rdfs:label 'Conservation Plan Date' ;
    rdfs:comment 'Date when the current conservation plan was approved or last updated.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conservationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Conservation Plan Status' ;
    rdfs:comment 'Current status of the farm conservation plan required for environmental compliance and best management practices.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cultivatedAcreage rdf:type rdf:Property ;
    rdfs:label 'Cultivated Acreage' ;
    rdfs:comment 'Total acreage actively used for crop cultivation within the farm operation.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the farm operation holds ISO 14001 environmental management system certification.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityType rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Type' ;
    rdfs:comment 'Legal structure under which the farm operation is organized and registered.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCode rdf:type rdf:Property ;
    rdfs:label 'Operation Code' ;
    rdfs:comment 'Externally-known unique business identifier or registration code for the farm operation, often used in regulatory filings and government programs.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionAgricultureEnabled rdf:type rdf:Property ;
    rdfs:label 'Precision Agriculture Enabled' ;
    rdfs:comment 'Indicates whether the farm operation utilizes precision agriculture technologies such as GPS guidance, variable rate application, or yield monitoring.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the farm operation was registered in the system or with regulatory authorities.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtkGpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Rtk Gps Enabled' ;
    rdfs:comment 'Indicates whether the farm operation uses RTK-accurate GPS positioning for field operations and mapping.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryCommodity rdf:type rdf:Property ;
    rdfs:label 'Secondary Commodity' ;
    rdfs:comment 'The secondary agricultural commodity or crop produced by this farm operation, if applicable.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAcreage rdf:type rdf:Property ;
    rdfs:label 'Total Acreage' ;
    rdfs:comment 'Total land area in acres managed by this farm operation, including cultivated, pasture, and non-productive land.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this organizational unit record.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy, enabling multi-level organizational structure representation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of active employees assigned to this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Certification Required Flag' ;
    rdfs:comment 'Indicates whether employees in this organizational unit require GAP certification training for food safety compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:h2aVisaProgramFlag rdf:type rdf:Property ;
    rdfs:label 'H2a Visa Program Flag' ;
    rdfs:comment 'Indicates whether this organizational unit participates in the H-2A temporary agricultural worker visa program, requiring specific compliance tracking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Certification Required Flag' ;
    rdfs:comment 'Indicates whether employees in this organizational unit require HACCP certification for food processing and safety compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Headcount Capacity' ;
    rdfs:comment 'Maximum number of employees or workers that can be assigned to this organizational unit based on operational capacity and workforce planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., \'North Valley Farm Operations\', \'Citrus Processing Plant\', \'Agronomist Services Team\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitShortName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Short Name' ;
    rdfs:comment 'Abbreviated or short name for the organizational unit used in reports and displays.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit by operational function within the agricultural enterprise.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether this organizational unit falls under OSHA safety regulations and requires OSHA compliance tracking and reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideApplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Pesticide Application Flag' ;
    rdfs:comment 'Indicates whether this organizational unit performs pesticide application activities, requiring pesticide applicator license tracking and EPA compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalWorkforceFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Workforce Flag' ;
    rdfs:comment 'Indicates whether this organizational unit employs seasonal or temporary agricultural workers (e.g., harvest crews, planting teams).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activityTypeEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Activity Type Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether activity-based costing is enabled within this controlling area for tracking and allocating resource consumption by activity type.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationCycleEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether automated cost allocation cycles are enabled for this controlling area to distribute overhead and shared service costs across cost centers and profit centers.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetControlEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether budget control and availability checking is enforced within this controlling area to prevent overspending against approved budgets.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts used by this controlling area for general ledger account mapping and financial statement preparation.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentManagementEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Commitment Management Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether commitment tracking is enabled for purchase requisitions and purchase orders within this controlling area for funds reservation and budget consumption analysis.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Four-character code identifying the financial consolidation group to which this controlling area belongs for consolidated financial statement preparation and group reporting.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStandardHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Standard Hierarchy Id' ;
    rdfs:comment 'Reference to the default cost center hierarchy used for organizational reporting and cost rollup within this controlling area.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costOfGoodsSoldVariant rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Variant' ;
    rdfs:comment 'Two-character code defining the cost of goods sold calculation method and allocation rules used within this controlling area for inventory valuation and product costing.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossCompanyCostAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Company Cost Allocation Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this controlling area supports cross-company code cost allocations for shared services and intercompany charge-backs.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYearVariantCode rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant Code' ;
    rdfs:comment 'Two-character code defining the fiscal year calendar structure for this controlling area, including the number of periods, special periods, and year-end closing rules.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliance Standard' ;
    rdfs:comment 'Accounting standard framework applied within this controlling area for financial statement preparation and regulatory reporting compliance.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Order Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether internal order functionality is enabled within this controlling area for project-based cost tracking and capital expenditure management.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who most recently modified this controlling area record.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingConcernCode rdf:type rdf:Property ;
    rdfs:label 'Operating Concern Code' ;
    rdfs:comment 'Four-character code identifying the operating concern (profitability analysis segment) associated with this controlling area for margin analysis and contribution reporting.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandardHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy Id' ;
    rdfs:comment 'Reference to the default profit center hierarchy used for profitability analysis and segment reporting within this controlling area.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this controlling area is subject to Sarbanes-Oxley Act internal control requirements for financial reporting accuracy and audit trail integrity.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalKeyFigureEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Key Figure Enabled Flag' ;
    rdfs:comment 'Boolean indicator specifying whether statistical key figures are enabled for this controlling area to support non-monetary allocation bases such as headcount, square footage, or production volume.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Variance Calculation Method' ;
    rdfs:comment 'Method used to calculate cost variances between planned and actual costs within this controlling area for management reporting and performance analysis.' ;
    rdfs:domain ind:ControllingArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
