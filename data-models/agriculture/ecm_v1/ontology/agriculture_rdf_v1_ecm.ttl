    rdfs:comment 'Approved capital expenditure budget for the fiscal year for asset acquisition and infrastructure investment tracking.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialControllerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Financial Controller Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the financial controller responsible for financial controls and SOX compliance for this business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the primary operating currency of the business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Gl Company Code' ;
    rdfs:comment 'Company code in the general ledger system for financial accounting and statutory reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions involving this business unit require elimination entries during consolidation.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity under which this business unit operates for statutory reporting and compliance.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Amount' ;
    rdfs:comment 'Approved operating expenditure budget for the fiscal year for recurring operational costs and expense management.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBusinessUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Business Unit Id' ;
    rdfs:comment 'Reference to the parent business unit in the organizational hierarchy for consolidation and roll-up reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this business unit is in scope for Sarbanes-Oxley Act compliance and internal control testing.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Primary tax jurisdiction or authority under which the business unit files tax returns and reports taxable income.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'Annual budget amount allocated to this functional area for operational expenses (OPEX) and capital expenses (CAPEX).' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget allocation amount (e.g., USD, EUR, CAD).' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate shared costs and overhead expenses to this functional area for accurate cost of goods sold (COGS) and profitability analysis.' ;
    rdfs:domain ind:FunctionalArea ;
