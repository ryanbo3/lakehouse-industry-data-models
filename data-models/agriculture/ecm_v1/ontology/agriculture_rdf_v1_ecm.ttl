# --- Attribute Properties ---
ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual audit finding record within the compliance domain.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Reference to the internal or external auditor who identified and recorded this finding during the compliance audit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Id' ;
    rdfs:comment 'Reference to the parent compliance audit from which this finding was generated. Links the finding to its originating audit event.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:correctiveActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Id' ;
    rdfs:comment 'Foreign key linking to compliance.corrective_action_plan. Business justification: An audit finding that requires corrective action should reference the formal corrective_action_plan created to address it. audit_finding.corrective_action_required and corrective_action_deadline are s' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveActionPlan .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Reference to the specific farm, facility, warehouse, or operational site where the finding was identified. Enables site-level compliance tracking and geographic risk analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:farmUnitId rdf:type rdf:Property ;
    rdfs:label 'Farm Unit Id' ;
    rdfs:comment 'Foreign key linking to land.farm_unit. Business justification: Audit findings at the farm operation level (organic system plan deficiencies, conservation compliance failures, FSMA audit findings) need farm_unit reference. The existing link is to land.field; farm-' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FarmUnit .

ind:fieldId rdf:type rdf:Property ;
    rdfs:label 'Field Id' ;
    rdfs:comment 'Reference to the specific agricultural field or land parcel associated with the finding, where applicable (e.g., for crop protection nonconformances, PHI violations, or soil management findings). Nullable for findings not tied to a specific field.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Field .

ind:primaryAuditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Employee Id' ;
    rdfs:comment 'Reference to the employee or manager assigned as the accountable owner for resolving this finding and implementing the required corrective action. Drives workflow assignment and escalation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record that this finding is a repeat or continuation of. Populated only when repeat_finding is True, enabling recurrence trend analysis.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:regulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_agency. Business justification: An audit finding references the regulatory body whose standards were assessed. The existing regulatory_body (STRING) is a denormalized agency name; replacing it with a proper FK to regulatory_agency e' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:auditArea rdf:type rdf:Property ;
    rdfs:label 'Audit Area' ;
    rdfs:comment 'The operational area, process, or department within the agricultural enterprise where the finding was identified (e.g., crop protection, post-harvest handling, irrigation management, livestock husbandry, food safety, environmental compliance, worker safety). [ENUM-REF-CANDIDATE: crop_protection|post_harvest|irrigation|livestock|food_safety|environmental|worker_safety|supply_chain|storage|traceability — promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingSource rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Source' ;
    rdfs:comment 'The type of audit or inspection activity that generated this finding, distinguishing between internal audits, external certification audits, regulatory inspections, customer-conducted audits, and self-assessments.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationImpact rdf:type rdf:Property ;
    rdfs:label 'Certification Impact' ;
    rdfs:comment 'The impact of this finding on the agricultural operation\'s certification status under the applicable standard (e.g., GLOBALG.A.P., SQF, BRC, organic certification). Major nonconformances may result in suspension or withdrawal of certification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the finding was formally closed following successful verification of the corrective action. Distinct from verification_date in that closure may require additional approval steps.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional auditor notes, management responses, or contextual information related to the finding that does not fit within the structured fields. Supports comprehensive audit documentation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The required completion date by which the corrective action must be implemented and verified. Typically set by the auditor or certification body based on finding severity and regulatory requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Narrative description of the corrective action plan proposed or implemented to address the root cause of the finding and prevent recurrence. Includes immediate containment actions and systemic preventive measures.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal corrective action plan is required to address this finding. True for major and minor nonconformances; may be False for observations or opportunities for improvement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this audit finding record was first created in the compliance management system. Supports audit trail and data lineage requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Indicates whether the finding relates to an environmental compliance violation or risk, such as pesticide runoff, water quality, soil contamination, or EPA permit conditions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceReviewed rdf:type rdf:Property ;
    rdfs:label 'Evidence Reviewed' ;
    rdfs:comment 'Description of the objective evidence examined by the auditor to substantiate the finding, such as records reviewed, physical observations, interviews conducted, or test results evaluated (e.g., pesticide application logs, COA records, SDS files, field inspection photos).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the nonconformance, observation, or opportunity for improvement identified during the audit. Includes what was found, where it was found, and why it constitutes a finding against the referenced standard or clause.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Human-readable sequential identifier for the finding within its parent audit (e.g., FND-2024-00001). Used for referencing findings in corrective action plans, audit reports, and regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding from identification through verified closure. Drives corrective action workflow and audit readiness dashboards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the audit finding severity and nature. Major nonconformance indicates a critical failure requiring immediate corrective action; minor nonconformance indicates a partial failure; observation is a noted concern not yet a nonconformance; opportunity for improvement is a recommendation without a violation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Food Safety Impact' ;
    rdfs:comment 'Indicates whether the finding has a direct or potential impact on food safety, including HACCP critical control points, MRL exceedances, PHI violations, or FSMA preventive control failures.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapCategory rdf:type rdf:Property ;
    rdfs:label 'Gap Category' ;
    rdfs:comment 'The GAP category or control point area under which the finding is classified, aligned with GLOBALG.A.P. or USDA GAP audit frameworks (e.g., All Farm Base, Crops Base, Produce Handling, Worker Activities, Field Operations). [ENUM-REF-CANDIDATE: all_farm_base|crops_base|produce_handling|worker_activities|field_operations|livestock_base|aquaculture — promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The calendar date on which the finding was identified and recorded during the audit. Represents the principal business event date for this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryClause rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clause' ;
    rdfs:comment 'Specific clause, section, or control point of the regulatory standard or certification scheme that was violated or observed (e.g., GLOBALG.A.P. AF 1.1, FDA 21 CFR Part 112.44, FSMA PCHF 117.135). Enables precise traceability to the regulatory requirement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'The date on which the regulatory authority was formally notified of the finding, where regulatory_notification_required is True. Supports FSMA and FDA mandatory reporting timeline compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the finding requires mandatory notification to a regulatory authority (e.g., FDA, USDA, EPA, FSIS) within a specified timeframe. Triggers regulatory reporting workflow.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatFinding rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified nonconformance or observation from a prior audit cycle. Repeat findings trigger escalated corrective action requirements and may affect certification status.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk severity rating assigned to the finding based on potential impact to food safety, regulatory compliance, environmental harm, or business operations. Informs prioritization of corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Analysis of the underlying root cause of the nonconformance or finding, as determined through investigation. Supports systemic corrective action and recurrence prevention in line with HACCP and food safety management principles.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the internal Standard Operating Procedure (SOP) document that was not followed or that requires updating as a result of this finding. Supports document control and corrective action traceability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Full name of the compliance standard, certification scheme, or regulatory framework under which the finding was raised (e.g., GLOBALG.A.P. IFA v6, SQF Code Edition 9, BRC Global Standard Issue 9, ISO 22000:2018, FSMA Preventive Controls for Human Food).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this audit finding record was last modified, capturing updates to corrective action plans, status changes, or verification outcomes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the corrective action was verified as effectively implemented and the finding was confirmed as closed by the responsible auditor or certification body.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify that the corrective action has been effectively implemented and the finding has been resolved (e.g., document review, physical inspection, laboratory testing, third-party audit).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Worker Safety Impact' ;
    rdfs:comment 'Indicates whether the finding relates to worker health and safety, including REI violations, PPE non-compliance, or OSHA regulatory requirements for agricultural operations.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bioterrorismRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Bioterrorism Registration Id' ;
    rdfs:comment 'Unique surrogate primary key for the FDA Bioterrorism Act facility registration record. Serves as the internal system identifier for this master agreement entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioterrorismRegistration .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: FDA bioterrorism registrations are filed by legal entities (company codes). Agriculture food facilities require registration per legal entity; linking to company_code enables consolidated FDA registra' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:foodSafetyPlanId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Plan Id' ;
    rdfs:comment 'Reference to the associated Food Safety Plan (HACCP/HARPC) maintained for this registered facility. Links the bioterrorism registration to the facility\'s active food safety plan for integrated compliance management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyPlan .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments submitted to the FDA for this facility registration since initial registration. Amendments are required when facility information changes (e.g., facility name, address, food categories, owner/operator). Tracks regulatory change history.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biennialRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Biennial Renewal Date' ;
    rdfs:comment 'The date by which the facility registration must be renewed with the FDA. Under the Bioterrorism Act as amended by FSMA, registrations must be renewed every two years during the October 1 – December 31 window of each even-numbered year.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the FDA facility registration was cancelled, either voluntarily by the facility or by the FDA. A cancelled registration requires re-registration before the facility may resume regulated food operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for capturing additional compliance context, FDA correspondence references, internal audit observations, or operational notes related to this facility registration. Not used for structured data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the FDA facility registration became effective and the facility was authorized to manufacture, process, pack, or hold food for human or animal consumption in the United States.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Email' ;
    rdfs:comment 'Email address of the designated emergency contact for the registered food facility. Used for FDA emergency notifications and compliance communications.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the designated emergency contact person for the registered food facility. This individual is reachable 24/7 for FDA emergency communications related to food safety incidents or bioterrorism threats.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24/7 reachable phone number for the designated emergency contact at the registered food facility. Required by FDA for emergency response coordination under the Bioterrorism Act.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Facility Address Line1' ;
    rdfs:comment 'Primary street address of the registered food facility as submitted to the FDA. Required field in the FDA facility registration form.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCity rdf:type rdf:Property ;
    rdfs:label 'Facility City' ;
    rdfs:comment 'City in which the registered food facility is physically located, as submitted to the FDA.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country in which the registered food facility is physically located. Used to distinguish domestic (USA) from foreign facilities requiring a US Agent.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStateCode rdf:type rdf:Property ;
    rdfs:label 'Facility State Code' ;
    rdfs:comment 'Two-letter US state or territory code for the registered food facility location. Applicable for domestic facilities; null for foreign facilities.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the food facility\'s primary operational function as defined under the FDA Bioterrorism Act registration requirements. Determines the scope of regulatory obligations applicable to the facility. [ENUM-REF-CANDIDATE: manufacturer|processor|packer|holder|importer|distributor|warehouse|repacker|co-manufacturer — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'The official 11-digit registration number assigned by the FDA upon successful submission of the facility registration under the Bioterrorism Act. This is the primary external identifier used in all FDA correspondence and prior notice submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodCategories rdf:type rdf:Property ;
    rdfs:label 'Food Categories' ;
    rdfs:comment 'Comma-separated list of FDA food product categories handled at the facility, as declared in the registration (e.g., \'Grains/Beans/Nuts/Seeds, Fruits/Vegetables, Animal Foods\'). Based on FDA\'s food product category taxonomy used in the registration system.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForeignFacility rdf:type rdf:Property ;
    rdfs:label 'Is Foreign Facility' ;
    rdfs:comment 'Indicates whether this is a foreign food facility (located outside the United States) that manufactures, processes, packs, or holds food for consumption in the US. Foreign facilities are required to designate a US Agent.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment submitted to the FDA for this facility registration. Amendments must be submitted within 60 days of any change in required registration information.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Name' ;
    rdfs:comment 'Legal name of the owner or operator of the registered food facility as declared in the FDA registration. This is the responsible party for regulatory compliance obligations under the Bioterrorism Act.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Notice Required' ;
    rdfs:comment 'Indicates whether this facility is subject to FDA Prior Notice requirements for imported food shipments under the Bioterrorism Act. Typically true for foreign facilities or domestic importers of foreign food.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifiedFacilityExempt rdf:type rdf:Property ;
    rdfs:label 'Qualified Facility Exempt' ;
    rdfs:comment 'Indicates whether this facility qualifies for the very small business (qualified facility) exemption under FSMA, which modifies certain registration and food safety plan requirements. Based on average annual monetary value of food sold.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the FDA facility registration. \'active\' indicates a valid, current registration; \'suspended\' indicates FDA has suspended the registration (facility cannot import/export food); \'cancelled\' indicates voluntary or involuntary cancellation; \'pending\' indicates initial submission awaiting FDA confirmation; \'expired\' indicates the biennial renewal window has lapsed without renewal.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Registration Submission Date' ;
    rdfs:comment 'The date on which the initial FDA facility registration was submitted via the FDA Industry Systems (FIS) portal. Used to track the registration timeline and confirm compliance with pre-operation registration requirements.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the biennial renewal process for this FDA facility registration. \'not_due\' indicates the renewal window has not yet opened; \'submitted\' indicates the renewal has been filed with FDA; \'confirmed\' indicates FDA has confirmed the renewed registration; \'overdue\' indicates the renewal deadline has passed without confirmation; \'waived\' indicates a regulatory exemption applies.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'The date on which the biennial renewal application was submitted to the FDA. Used to confirm timely filing within the October 1 – December 31 renewal window of even-numbered years.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Reference identifier from the originating operational system of record (e.g., SAP S/4HANA QM module compliance record ID, or Granular Farm Management compliance tracking ID) from which this registration record was sourced or synchronized.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the FDA suspended this facility registration. A suspended registration prohibits the facility from importing food into the US and triggers immediate operational and supply chain impacts. Null if registration has never been suspended.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionLiftedDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Lifted Date' ;
    rdfs:comment 'The date on which the FDA lifted the suspension of this facility registration, restoring the facility\'s authorization to operate. Null if the registration has never been suspended or if suspension is still active.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Description of the reason provided by the FDA for suspending the facility registration. Typically references a credible threat of serious adverse health consequences or death to humans or animals. Null if registration has never been suspended.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usAgentEmail rdf:type rdf:Property ;
    rdfs:label 'Us Agent Email' ;
    rdfs:comment 'Email address of the designated US Agent for a foreign food facility. Used for FDA communications and emergency notifications. Required only for foreign facilities.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usAgentName rdf:type rdf:Property ;
    rdfs:label 'Us Agent Name' ;
    rdfs:comment 'Full legal name of the US Agent designated by a foreign food facility as required under the FDA Bioterrorism Act. The US Agent serves as the FDA\'s primary point of contact for the foreign facility. Required only for foreign facilities (is_foreign_facility = true).' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usAgentPhone rdf:type rdf:Property ;
    rdfs:label 'Us Agent Phone' ;
    rdfs:comment 'Phone number of the designated US Agent for a foreign food facility. The US Agent must be reachable by the FDA at all times during business hours. Required only for foreign facilities.' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the lead auditor responsible for conducting and signing off on this compliance audit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousAuditComplianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Compliance Audit Id' ;
    rdfs:comment 'Reference to the immediately preceding compliance audit record for the same facility and regulatory framework, enabling audit cycle continuity tracking and trend analysis of findings over time.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual calendar date on which audit field activities concluded. Used to calculate audit duration and track deviations from the planned schedule.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual calendar date on which audit field activities commenced. May differ from planned_start_date due to scheduling changes or regulatory agency availability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:announced rdf:type rdf:Property ;
    rdfs:label 'Announced' ;
    rdfs:comment 'Indicates whether the audit was announced in advance to the facility (True = announced; False = unannounced). Unannounced audits are required by certain standards (e.g., GLOBALG.A.P. Option 2, BRC unannounced extension) and carry different risk implications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Broad regulatory or programmatic category of the audit, indicating the primary compliance domain assessed (e.g., GAP, GMP, FSMA, EPA_Environmental, Pesticide_Applicator, HACCP, Organic_NOP, GLOBALG.A.P., SQF, BRC). [ENUM-REF-CANDIDATE: GAP|GMP|FSMA|EPA_Environmental|Pesticide_Applicator|HACCP|Organic_NOP|GLOBALG.A.P.|SQF|BRC — promote to reference product]' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this compliance audit (e.g., AUD-2024-000123). Used in correspondence with regulatory bodies, auditing organizations, and internal stakeholders.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Narrative description of the operations, processes, products, geographic areas, and regulatory frameworks included within the boundaries of this audit. Defines what was and was not assessed.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the compliance audit record, tracking progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit by the relationship of the auditing body to the enterprise: internal (first-party), second_party (customer or partner-initiated), third_party (independent certification body), or regulatory (government agency such as USDA, FDA, EPA).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBodyName rdf:type rdf:Property ;
    rdfs:label 'Auditing Body Name' ;
    rdfs:comment 'Name of the organization or agency conducting the audit (e.g., USDA Agricultural Marketing Service, FDA District Office, NSF International, Bureau Veritas, SGS, internal audit department). Captures the entity responsible for the audit findings.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date on which the certification issued as a result of this audit expires and requires renewal through a subsequent audit cycle. Critical for compliance calendar management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Official certificate or registration number issued by the certifying body upon successful audit completion (e.g., GLOBALG.A.P. GGN, SQF certificate number, USDA Organic certificate number). Null if no certificate was issued.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationEligible rdf:type rdf:Property ;
    rdfs:label 'Certification Eligible' ;
    rdfs:comment 'Indicates whether the audit outcome qualifies the facility or operation for certification or re-certification under the assessed regulatory framework or standard (True = eligible; False = not eligible due to findings or score threshold not met).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which the enterprise must submit or implement corrective actions in response to audit findings. Typically specified by the auditing body or regulatory agency in the audit report.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Status' ;
    rdfs:comment 'Current status of the Corrective Action Plan (CAP) submitted in response to audit findings. Tracks the lifecycle from finding issuance through regulatory acceptance and closure.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or major non-conformances identified during the audit that pose immediate food safety, environmental, or regulatory risk. Critical findings typically require immediate corrective action and may result in suspension of certification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Due Date' ;
    rdfs:comment 'Target date by which the follow-up or verification audit must be completed to confirm corrective action effectiveness. Populated only when follow_up_audit_required is True.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up or verification audit is required to confirm that corrective actions have been effectively implemented (True = follow-up required; False = no follow-up required).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorCredential rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Credential' ;
    rdfs:comment 'Professional certification or credential held by the lead auditor relevant to this audit (e.g., PCQI - Preventive Controls Qualified Individual, CPA - Certified Professional Agronomist, ISO 19011 Lead Auditor, REHS - Registered Environmental Health Specialist).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor who conducted and is responsible for the audit. Retained for traceability and regulatory reporting even when the auditor is an external party not in the workforce master.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or observations identified during the audit that require corrective action within a defined timeframe but do not pose immediate risk.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional context, observations, or commentary related to the audit that does not fit into structured fields. May include auditor observations, special circumstances, or management responses.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsCovered rdf:type rdf:Property ;
    rdfs:label 'Operations Covered' ;
    rdfs:comment 'Comma-separated or narrative description of the specific agricultural operations, production lines, or business units included in the audit scope (e.g., field crop production, post-harvest handling, cold storage, livestock operations, feed mill).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall result of the completed compliance audit as determined by the auditing body. Pass indicates full conformance; pass_with_conditions indicates minor non-conformances requiring corrective action; fail indicates major non-conformances; pending_review indicates the outcome has not yet been formally issued.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Numeric compliance score assigned by the auditing body upon completion of the audit, typically expressed as a percentage (0.00–100.00). Used for certification eligibility determination and benchmarking across audit cycles (e.g., SQF score, GLOBALG.A.P. compliance percentage).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled calendar date on which the audit activities are planned to conclude. Used for resource planning and compliance calendar management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled calendar date on which the audit activities are planned to begin. Used for compliance calendar management and audit readiness preparation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAgencyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Case Number' ;
    rdfs:comment 'Official case or inspection number assigned by the regulatory agency (e.g., FDA establishment inspection report number, USDA inspection number, EPA compliance evaluation number). Used for cross-referencing with agency records and regulatory correspondence.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory or certification standard framework assessed during this audit (e.g., FSMA Produce Safety Rule, USDA NOP, EPA FIFRA, GLOBALG.A.P. IFA, SQF Code Edition 9, BRC Global Standard Issue 9, ISO 22000:2018). [ENUM-REF-CANDIDATE: FSMA_Produce_Safety|USDA_NOP|EPA_FIFRA|GLOBALG.A.P._IFA|SQF_Code|BRC_Global|ISO_22000|HACCP — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date on which the formal audit report was officially issued by the auditing body to the enterprise. Triggers corrective action timelines and regulatory response deadlines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document reference number, file path, or URL pointing to the official audit report stored in the document management system. Enables direct retrieval of the full audit report for regulatory review and corrective action planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings (non-conformances, observations, and opportunities for improvement) identified during the audit. Used for KPI tracking and trend analysis across audit cycles.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarEntryId rdf:type rdf:Property ;
    rdfs:label 'Calendar Entry Id' ;
    rdfs:comment 'Unique system-generated identifier for each compliance calendar entry record. Primary key for the compliance_calendar_entry data product.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Reference to the license record that this calendar entry is associated with, such as a pesticide applicator license renewal or food handler certification expiration. Links the calendar entry to the compliance license lifecycle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Reference to the parent compliance obligation that this calendar entry schedules or tracks. Links the calendar entry to the governing regulatory requirement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:parentEntryCalendarEntryId rdf:type rdf:Property ;
    rdfs:label 'Parent Entry Calendar Entry Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the originating compliance calendar entry from which this recurrence instance was generated. Enables series tracking and historical recurrence chain analysis.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalendarEntry .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Reference to the permit record that this calendar entry is associated with, such as a permit renewal deadline or permit condition reporting requirement. Links the calendar entry to the compliance permit lifecycle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryCalendarEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Calendar Employee Id' ;
    rdfs:comment 'Employee or role identifier of the primary person responsible for completing this compliance calendar entry. Links to the workforce or HR system for notification and accountability tracking.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: A regulatory change often triggers new compliance calendar entries (new deadlines, new filing requirements). Linking compliance_calendar_entry to regulatory_change enables tracking which regulatory ch' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: A compliance calendar entry representing a filing deadline should reference the actual regulatory_filing once submitted. This FK links the scheduled obligation (calendar entry) to the fulfillment reco' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the employee or role assigned as the primary owner responsible for completing this compliance calendar entry. Stored for operational display and audit trail purposes.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Title' ;
    rdfs:comment 'Job title or role designation of the assigned owner (e.g., Environmental Compliance Manager, Pesticide Applicator, Food Safety Coordinator). Supports workload planning and role-based compliance reporting.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual calendar date on which the compliance obligation was fulfilled, the filing was submitted, the permit was renewed, or the inspection was completed. Null if not yet completed. Used for on-time compliance rate analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Boolean flag indicating whether the compliance obligation for this calendar entry has been fully completed and documented. True = completed; False = not yet completed. Complements entry_status for quick filtering in compliance dashboards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the jurisdiction of this compliance obligation. Supports cross-border trade compliance and international regulatory reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The principal regulatory deadline by which the compliance obligation must be fulfilled, filed, or renewed. This is the primary scheduling anchor for the compliance calendar entry and drives reminder and escalation workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Externally-visible business identifier for this calendar entry, used in communications with regulatory bodies and internal stakeholders. Follows the format CCE-YYYY-NNNNNN.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the compliance calendar entry. Scheduled: upcoming and not yet started. In_progress: actively being worked on. Completed: obligation fulfilled. Overdue: past due date without completion. Waived: formally exempted by regulatory authority. Cancelled: entry removed from calendar.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTitle rdf:type rdf:Property ;
    rdfs:label 'Entry Title' ;
    rdfs:comment 'Short, descriptive title of the compliance calendar entry (e.g., \'Annual NPDES Permit Renewal\', \'Pesticide Applicator License Renewal - CA\', \'FSMA Preventive Controls Annual Review\'). Used for display in compliance dashboards and calendars.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Categorical classification of the compliance calendar entry indicating the nature of the obligation. Values: filing (regulatory submission), renewal (permit/license renewal), inspection (scheduled regulatory inspection), training (required compliance training), reporting (periodic regulatory report), audit (internal or third-party audit), certification (certification maintenance or recertification). [ENUM-REF-CANDIDATE: filing|renewal|inspection|training|reporting|audit|certification — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which this compliance calendar entry was formally escalated to senior management or the compliance committee. Null if not escalated. Used for escalation response time analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this compliance calendar entry has been escalated to senior management or the compliance committee due to overdue status, high risk, or unresolved issues. True = escalated; False = not escalated.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Penalty Amount' ;
    rdfs:comment 'Estimated financial penalty in USD that could be incurred if this compliance obligation is not fulfilled by the due date. Used for risk quantification and prioritization in compliance workload planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstReminderDate rdf:type rdf:Property ;
    rdfs:label 'First Reminder Date' ;
    rdfs:comment 'Calculated date on which the first automated reminder notification is sent to the assigned owner and escalation contacts. Derived from due_date minus reminder_lead_days but stored for operational scheduling.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction governing this compliance obligation (e.g., Federal, California, Texas, EU, Canada). Supports multi-state and cross-border trade compliance management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceRisk rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Risk' ;
    rdfs:comment 'Categorized consequence or risk type if this compliance obligation is not fulfilled by the due date. Drives escalation and prioritization logic. [ENUM-REF-CANDIDATE: license_suspension|financial_penalty|operational_shutdown|product_recall|warning_letter|none — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationUnit rdf:type rdf:Property ;
    rdfs:label 'Operation Unit' ;
    rdfs:comment 'Specific operational unit or department within the facility responsible for this compliance entry (e.g., Crop Production, Livestock Operations, Food Processing, Warehouse, Transport). Supports departmental compliance reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business-assigned priority level for this compliance calendar entry, reflecting the regulatory risk and operational impact of non-compliance. Critical: immediate legal or operational consequence. High: significant penalty risk. Medium: moderate risk. Low: administrative or informational.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Recurrence End Date' ;
    rdfs:comment 'Date on which the recurrence series for this compliance calendar entry terminates. Null indicates an open-ended recurrence. Used to bound automated calendar generation for time-limited regulatory programs.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Defines how frequently this compliance obligation recurs for automated calendar generation. None: one-time entry. Daily/Weekly/Monthly/Quarterly/Semi_annual/Annual/Biennial: periodic recurrence intervals. Drives automated creation of future calendar entries. [ENUM-REF-CANDIDATE: none|daily|weekly|monthly|quarterly|semi_annual|annual|biennial — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory citation, rule reference, or code section that mandates this compliance obligation (e.g., \'21 CFR Part 117\', \'40 CFR Part 122\', \'7 CFR Part 205\'). Provides legal traceability for audit readiness.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Code' ;
    rdfs:comment 'Standardized code identifying the specific regulatory program or framework this entry belongs to (e.g., FSMA, NPDES, FIFRA, NOP, HACCP, GLOBALG.A.P., SQF, BRC). Enables program-level compliance reporting and filtering.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderLeadDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Days' ;
    rdfs:comment 'Number of calendar days before the due date that automated reminders and notifications should be triggered. Enables proactive deadline management and workload planning. Sourced from compliance obligation default or overridden at entry level.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the compliance filing, renewal, or report was or will be submitted to the regulatory authority. Values: online_portal, email, mail, in_person, fax, edi (Electronic Data Interchange). Supports submission workflow planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory authority upon receipt of the filing, renewal application, or report submission. Used for follow-up and audit trail documentation.' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL pointing to supporting documentation for this compliance calendar entry (e.g., completed filing, renewal application, inspection report, training certificate). Supports audit readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each compliance document record in the master document registry.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:priorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Prior Document Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous version or predecessor document that this record supersedes — enables document version lineage tracking and ensures audit trails link successive versions of permits, plans, and certificates.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level assigned to this compliance document governing access controls and handling requirements — restricted (highly sensitive regulatory or legal documents), confidential (internal business-sensitive), internal (general internal use), or public (publicly available regulatory filings). Aligns with enterprise data governance policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'Broad regulatory domain category grouping the document — e.g., environmental (EPA/NPDES), food safety (FSMA/HACCP), pesticide (EPA/state), organic (USDA NOP), trade (APHIS/CBP), labor (OSHA), animal health (FSIS/APHIS). Supports compliance calendar filtering and domain-level reporting. [ENUM-REF-CANDIDATE: environmental|food_safety|pesticide|organic|trade|labor|financial|animal_health|crop_protection — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The official date printed on or associated with the compliance document — typically the date it was signed, issued, or formally submitted. Distinct from the effective date and expiration date.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to the compliance document — used in regulatory correspondence, audit trails, and document management systems (DMS). Typically follows an enterprise numbering convention such as DOC-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentScope rdf:type rdf:Property ;
    rdfs:label 'Document Scope' ;
    rdfs:comment 'Narrative description of the operational scope covered by this compliance document — e.g., specific crops, livestock species, fields, processing lines, geographic areas, or business units to which the document applies. Supports scoped compliance reporting and audit readiness.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the compliance document — draft (in preparation), active (in force), under_review (pending regulatory or internal review), superseded (replaced by a newer version), expired (past expiration date without renewal), or archived (retained for record-keeping only). Drives audit-readiness dashboards and document retrieval workflows.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the compliance document by its regulatory function — e.g., permit, license, inspection report, corrective action plan (CAP), food safety plan (HACCP/FSMA), organic system plan (NOP), consent order, or regulatory correspondence. [ENUM-REF-CANDIDATE: permit|license|inspection_report|corrective_action_plan|food_safety_plan|organic_system_plan|consent_order|regulatory_correspondence|certificate|audit_report|trade_certificate|sds|coa — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which the compliance document expires and is no longer valid — applicable to permits, licenses, certificates, and food safety plans with defined validity periods. Null for open-ended documents such as consent orders.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The electronic file format of the stored compliance document — e.g., PDF, DOCX, XLSX, XML, TIFF. Supports document retrieval, rendering, and long-term archival format compliance per regulatory retention requirements. [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|XML|CSV|TIFF|JPG|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaReportable rdf:type rdf:Property ;
    rdfs:label 'Fsma Reportable' ;
    rdfs:comment 'Indicates whether this compliance document is required or reportable under the Food Safety Modernization Act (FSMA) — e.g., Preventive Controls plans, Produce Safety Rule records, Foreign Supplier Verification Program (FSVP) documents. Supports FSMA compliance program reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExternalDocument rdf:type rdf:Property ;
    rdfs:label 'Is External Document' ;
    rdfs:comment 'Indicates whether this compliance document was issued by an external regulatory authority (True) or generated internally by the organization (False) — e.g., an EPA permit is external; an internal HACCP food safety plan is internal. Drives access control and distribution rules.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the specific office, department, or certifying body that issued or received this document — e.g., \'USDA Agricultural Marketing Service – National Organic Program\', \'EPA Region 5 Water Division\', \'Illinois Department of Agriculture\'. Complements the regulatory_agency code with the precise issuing entity.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Issuing Contact Email' ;
    rdfs:comment 'Email address of the regulatory agency contact or certifying officer associated with this compliance document — used for regulatory correspondence, renewal notifications, and audit coordination.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingContactName rdf:type rdf:Property ;
    rdfs:label 'Issuing Contact Name' ;
    rdfs:comment 'Name of the regulatory agency contact, inspector, or certifying officer who issued or is the point of contact for this compliance document — used for follow-up correspondence and regulatory relationship management.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the jurisdiction that issued or governs this compliance document — e.g., USA, CAN, MEX, BRA. Supports cross-border trade compliance and international regulatory reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateCode rdf:type rdf:Property ;
    rdfs:label 'Issuing State Code' ;
    rdfs:comment 'Two-letter US state or Canadian province code of the jurisdiction that issued this document — e.g., IL, CA, TX. Applicable for state-level permits, pesticide applicator licenses, and state agriculture department filings.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationLinked rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Linked' ;
    rdfs:comment 'Indicates whether this compliance document is associated with USDA National Organic Program (NOP) certification — e.g., an organic system plan, organic certificate, or NOP inspection report. Supports organic supply chain traceability and certification management.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date on which the organization received this compliance document from the issuing authority — relevant for inbound regulatory correspondence, inspection reports, consent orders, and certificates. Supports response deadline tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The deadline by which a renewal application or updated document must be submitted to the issuing authority to maintain continuous compliance — typically set before the expiration date per regulatory requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresRenewal rdf:type rdf:Property ;
    rdfs:label 'Requires Renewal' ;
    rdfs:comment 'Indicates whether this compliance document requires periodic renewal with the issuing authority (True) — e.g., annual pesticide applicator license renewal, USDA organic certificate renewal — or is a one-time or open-ended document (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleOwnerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Name' ;
    rdfs:comment 'Full name of the internal employee or compliance officer designated as the document owner — retained as a denormalized reference for audit reports and regulatory correspondence where the named responsible party must be identified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The mandatory or recommended retention period in years for this compliance document as required by the applicable regulatory framework — e.g., FSMA requires 2-3 years for food safety records; EPA may require 5+ years for environmental permits. Drives document archival and destruction scheduling.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The physical or digital storage path, URL, or DMS (Document Management System) reference where the compliance document file is stored — e.g., a SharePoint URL, SAP DMS object link, or network file path. Enables direct document retrieval for audits and regulatory inspections.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the organization submitted this compliance document to the regulatory agency — applicable for permit applications, food safety plan submissions, organic system plan filings, and regulatory reports.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title of the compliance document as it appears on the official document face — e.g., \'USDA Organic System Plan 2024\', \'EPA NPDES Permit Renewal Application\', \'HACCP Food Safety Plan – Facility 12\'.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the document following a major.minor versioning scheme (e.g., 1.0, 2.3, 3.0.1). Enables tracking of document revisions over time and ensures the most current version is used in regulatory submissions and audits.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each discrete compliance activity or fulfillment event record in the agricultural operations compliance management system.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Foreign key linking to weather.weather_alert. Business justification: CAFO and NPDES compliance events triggered by weather alerts (e.g., high-wind spray prohibition, freeze events requiring discharge reporting) must reference the triggering weather alert. EPA and state' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Reference to the financial cost center responsible for bearing the costs of this compliance event. Enables compliance cost allocation and financial reporting by business unit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:cropProtectionEventId rdf:type rdf:Property ;
    rdfs:label 'Crop Protection Event Id' ;
    rdfs:comment 'Foreign key linking to crop.protection_event. Business justification: WPS and pesticide compliance inspections are conducted against specific application events. Linking compliance_event to protection_event enables inspectors to pull the application record during the co' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtectionEvent .

ind:fieldCropPlanId rdf:type rdf:Property ;
    rdfs:label 'Field Crop Plan Id' ;
    rdfs:comment 'Foreign key linking to crop.field_crop_plan. Business justification: FSMA produce safety and GlobalG.A.P. compliance inspections are conducted against specific field crop plans. Inspectors review the plan document during the audit event; linking compliance_event to fie' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldCropPlan .

ind:gradingStandardId rdf:type rdf:Property ;
    rdfs:label 'Grading Standard Id' ;
    rdfs:comment 'Foreign key linking to product.grading_standard. Business justification: Compliance events for USDA grading audits and AMS inspections must reference the specific grading standard being evaluated. This enables grading compliance event tracking, outcome scoring against stan' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GradingStandard .

ind:inspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Inspection Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.inspection_record. Business justification: When a compliance event is an inspection activity, it should reference the corresponding inspection_record. compliance_event is a broad transactional record covering all compliance activities; inspect' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRecord .

ind:practiceAdoptionId rdf:type rdf:Property ;
    rdfs:label 'Practice Adoption Id' ;
    rdfs:comment 'Foreign key linking to sustainability.practice_adoption. Business justification: Practice adoption events (cover crop installation, buffer strip establishment) are verified through compliance events (NRCS practice verification visits, conservation program compliance checks). Named' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeAdoption .

ind:precipitationEventId rdf:type rdf:Property ;
    rdfs:label 'Precipitation Event Id' ;
    rdfs:comment 'Foreign key linking to weather.precipitation_event. Business justification: NPDES stormwater and CAFO discharge compliance events are directly triggered by precipitation events exceeding permit thresholds. EPA requires compliance events to document the specific storm event ca' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrecipitationEvent .

ind:productCertificationId rdf:type rdf:Property ;
    rdfs:label 'Product Certification Id' ;
    rdfs:comment 'Foreign key linking to product.certification. Business justification: Compliance events for certification audits, surveillance visits, and renewal inspections must reference the specific product certification being verified. certificate_number and certificate_expiry_dat' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCertification .

ind:complianceProgram rdf:type rdf:Property ;
    rdfs:label 'Compliance Program' ;
    rdfs:comment 'The overarching compliance program or certification scheme under which this event falls (e.g., HACCP, GAP, GMP, FSMA Preventive Controls, National Organic Program, GLOBALG.A.P., SQF, BRC, ISCC). Supports program-level compliance reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to execute this compliance event, including inspection fees, audit fees, certification fees, training costs, and associated labor. Supports compliance OPEX tracking and cost center allocation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFindingCount rdf:type rdf:Property ;
    rdfs:label 'Critical Finding Count' ;
    rdfs:comment 'Number of critical or major non-conformances identified during the compliance event that require immediate corrective action. Critical findings may trigger regulatory reporting obligations or certification suspension.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance activity concluded. Combined with start timestamp to compute event duration for SOP compliance and resource planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The principal real-world date on which the compliance activity was executed or is scheduled to occur (e.g., date of inspection, date of filing submission, date training was delivered). Distinct from record audit timestamps.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the compliance event (e.g., CE-2024-00123), used in regulatory correspondence, audit trails, and cross-system references.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the compliance event, tracking progression from scheduling through execution and closure. Drives compliance calendar management and audit readiness dashboards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the compliance activity performed. Distinguishes between regulatory inspections, government filings, workforce training sessions, internal or third-party audits, certification renewals, and permit applications. [ENUM-REF-CANDIDATE: inspection|filing|training|audit|certification_renewal|permit_application|corrective_action|sampling|testing|reporting — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Document identifier, file path, or system reference pointing to supporting evidence for this compliance event (e.g., COA document ID, inspection report file, training completion certificate, audit report reference). Serves as the primary evidence log for regulatory readiness.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'Total number of non-conformances, deficiencies, or observations identified during the compliance event. Used to assess severity of compliance gaps and prioritize corrective actions.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the external regulatory inspector, third-party auditor, or certifying body representative who conducted the inspection or audit. Captured for regulatory correspondence and audit report traceability.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Name of the regulatory agency, certification body, or third-party audit firm that the inspector or auditor represents (e.g., USDA AMS, NSF International, SGS, Bureau Veritas). Supports vendor and certifier relationship management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this compliance event must be formally reported to a regulatory authority (e.g., FSMA mandatory recall notification, EPA spill reporting, OSHA incident reporting). Triggers regulatory notification workflows.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isThirdPartyAudit rdf:type rdf:Property ;
    rdfs:label 'Is Third Party Audit' ;
    rdfs:comment 'Indicates whether this compliance event was conducted by an independent third-party auditor or certifying body (True) versus an internal self-assessment (False). Distinguishes internal audits from external certification audits for GFSI and GLOBALG.A.P. compliance reporting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Date by which the next required compliance action must be completed. Used in compliance calendar scheduling and regulatory deadline management to prevent lapses in compliance status.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionRequired rdf:type rdf:Property ;
    rdfs:label 'Next Action Required' ;
    rdfs:comment 'Description of the next required compliance activity following this event (e.g., \'Submit corrective action plan within 30 days\', \'Schedule follow-up inspection\', \'Renew pesticide applicator license by expiry date\'). Drives compliance workflow and calendar management.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeScore rdf:type rdf:Property ;
    rdfs:label 'Outcome Score' ;
    rdfs:comment 'Numeric score or percentage assigned to the compliance event outcome where applicable (e.g., audit score of 95.5 out of 100, or SQF score). Enables trend analysis and benchmarking across compliance events.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulatory citation, rule number, or standard reference that this event addresses (e.g., \'21 CFR Part 112\' for FSMA Produce Safety Rule, \'40 CFR Part 152\' for EPA pesticide registration, \'GLOBALG.A.P. IFA v6\'). Enables precise regulatory traceability.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Full name of the individual accountable for executing this compliance event. Retained as a denormalized field for audit trail integrity even if the employee record changes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the scope of this compliance event, including which operations, products, processes, or geographic areas were covered. Provides context for audit reports and regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this compliance event data originated (e.g., SAP S/4HANA QM module for quality inspections, Granular Farm Management for field-level compliance, manual entry for paper-based regulatory filings). Supports data lineage in the Databricks Silver Layer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance activity commenced. Used for duration calculation, scheduling conflict detection, and detailed audit trail reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Compliance obligations carry penalty_amount requiring GL account for financial accrual. Agriculture finance teams accrue potential non-compliance penalties to specific GL accounts for contingent liabi' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:obligatedEntityId rdf:type rdf:Property ;
    rdfs:label 'Obligated Entity Id' ;
    rdfs:comment 'Reference to the farm unit, facility, or legal entity within the enterprise that bears this compliance obligation. Identifies which operational unit must fulfill the duty.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ObligatedEntity .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Reference to the regulatory requirement master record from which this obligation is derived. Links the actionable compliance task back to the governing rule, statute, or standard.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:auditFinding rdf:type rdf:Property ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'The most recent audit finding classification for this compliance obligation, indicating the severity of any identified non-conformance. Drives corrective action planning and regulatory risk reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRef rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Ref' ;
    rdfs:comment 'Reference identifier to the corrective action plan (CAP) or CAPA record initiated in response to a non-conformance finding for this obligation. Links to the enterprise quality management system.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the penalty amount (e.g., USD, EUR, CAD). Supports multi-currency regulatory exposure reporting for international agricultural operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this compliance obligation expires or is no longer applicable. Null for open-ended or perpetual obligations. Used to manage license and permit renewal cycles.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment state of the compliance obligation in its lifecycle. Drives compliance calendar prioritization, escalation triggers, and audit readiness reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recent internal or external audit that reviewed this compliance obligation. Used to assess audit readiness and schedule future audit activities.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFulfilledDate rdf:type rdf:Property ;
    rdfs:label 'Last Fulfilled Date' ;
    rdfs:comment 'The most recent date on which this compliance obligation was successfully fulfilled and documented. Used to calculate compliance currency and trigger recurrence scheduling.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The calculated next occurrence due date for recurring compliance obligations, derived from the recurrence rule and last fulfilled date. Supports forward-looking compliance calendar planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligatedEntityType rdf:type rdf:Property ;
    rdfs:label 'Obligated Entity Type' ;
    rdfs:comment 'Classifies the type of enterprise entity bearing this compliance obligation — whether a farm unit, processing facility, warehouse, legal entity, or specific field. Enables entity-type-specific compliance reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative describing the specific compliance duty, including scope, applicable operations, and any special conditions or exemptions relevant to this obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the compliance obligation. Used in regulatory filings, audit correspondence, and compliance calendars to uniquely reference a specific duty.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Categorical classification of the compliance obligation by its nature and regulatory domain. Drives workflow routing and reporting segmentation. [ENUM-REF-CANDIDATE: license_renewal|permit_filing|regulatory_report|audit_inspection|training_certification|environmental_monitoring|food_safety_record|pesticide_registration|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The maximum or assessed monetary penalty associated with non-fulfillment of this compliance obligation, expressed in the enterprise base currency. Used for financial risk quantification and regulatory exposure reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceRule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rule' ;
    rdfs:comment 'Defines the frequency or trigger condition for this compliance obligation to recur. Drives automated compliance calendar generation and next-due-date calculation (e.g., annual license renewal, quarterly environmental monitoring report, event-triggered HACCP review). [ENUM-REF-CANDIDATE: annual|semi_annual|quarterly|monthly|event_triggered|one_time|biennial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderDaysBeforeDue rdf:type rdf:Property ;
    rdfs:label 'Reminder Days Before Due' ;
    rdfs:comment 'Number of calendar days before the due date that automated compliance reminders should be triggered to the assigned compliance owner. Configures the compliance calendar notification schedule.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the supporting documentation package (e.g., Certificate of Analysis, SDS, COA, audit report, license certificate) stored in the enterprise document management system. Enables audit-ready evidence retrieval.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the regulatory authority representative or internal approver who authorized the waiver of this compliance obligation. Supports audit trail and regulatory correspondence documentation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Documented justification for waiving this compliance obligation, including the regulatory authority approval reference if applicable. Populated only when fulfillment_status is \'waived\'. Required for audit trail integrity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorCapCorrectiveActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Prior Cap Corrective Action Plan Id' ;
    rdfs:comment 'Reference to a previous corrective action plan for the same or related finding, used when this CAP is a recurrence or follow-up to a prior unresolved compliance commitment.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveActionPlan .

ind:regulatoryFindingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_finding. Business justification: A corrective action plan is formally generated in response to a specific regulatory finding. Linking CAP to regulatory_finding establishes the in-domain traceability chain: inspection_record → regulat' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFinding .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date on which all corrective actions were fully implemented and verified as complete. Compared against target_completion_date to assess on-time compliance performance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgment Date' ;
    rdfs:comment 'The date on which the regulatory agency formally acknowledged or accepted the corrective action plan. Marks the start of the implementation monitoring period.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgment Status' ;
    rdfs:comment 'Status of the regulatory agency\'s review and acknowledgment of the submitted corrective action plan. Tracks whether the agency has accepted the CAP, requested additional information, or rejected it.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the regulatory agency inspector, compliance officer, or point of contact responsible for overseeing this corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Due Date' ;
    rdfs:comment 'The regulatory deadline by which the organization must submit the corrective action plan to the agency. Failure to meet this date may result in escalated enforcement action.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the corrective action plan, used in regulatory correspondence and agency submissions. Format: CAP-YYYY-NNNNNN.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capStatus rdf:type rdf:Property ;
    rdfs:label 'Cap Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action plan. Tracks progression from initial drafting through agency acknowledgment and final closure. [ENUM-REF-CANDIDATE: draft|submitted|agency_review|approved|in_progress|closed|rejected — promote to reference product]' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capType rdf:type rdf:Property ;
    rdfs:label 'Cap Type' ;
    rdfs:comment 'Classification of the corrective action plan by the nature of the triggering event. Distinguishes between agency-issued citations, inspection findings, consent agreements, and voluntary commitments. [ENUM-REF-CANDIDATE: regulatory_citation|inspection_finding|agency_order|voluntary_commitment|consent_agreement — promote to reference product]' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Citation Reference Number' ;
    rdfs:comment 'The official citation, notice of violation, or enforcement action reference number issued by the regulatory agency. Used for cross-referencing with agency records and regulatory correspondence.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final closure status of the corrective action plan. A CAP is closed when all corrective actions are verified as effective and the regulatory agency has confirmed resolution of the finding.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Description' ;
    rdfs:comment 'Detailed description of the specific corrective actions defined to address the root cause and remediate the regulatory non-conformance. This is the core commitment made to the regulatory agency.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated total cost to implement all corrective and preventive actions defined in the plan, including labor, materials, equipment modifications, and third-party services. Used for CAPEX/OPEX planning and compliance budget management.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the corrective action plan was formally initiated in response to the regulatory finding or citation. Marks the start of the CAP lifecycle and the compliance response clock.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the corrective action plan record. Supports audit trail requirements and change tracking for regulatory compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preventiveMeasuresDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures Description' ;
    rdfs:comment 'Description of the preventive measures and systemic controls implemented to prevent recurrence of the non-conformance. Distinct from corrective actions which address the immediate finding.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this corrective action plan addresses a recurring non-conformance that has been cited previously. Recurrent findings typically trigger escalated regulatory scrutiny and more stringent corrective action requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Title' ;
    rdfs:comment 'Job title or role of the designated responsible owner, required for regulatory agency submissions and formal CAP documentation.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorical classification of the root cause identified through root cause analysis. Used for trend analysis and systemic improvement tracking across the compliance program. [ENUM-REF-CANDIDATE: process_failure|equipment_failure|human_error|training_gap|supplier_issue|system_gap|environmental — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause analysis conducted to identify the underlying systemic or process failure that led to the regulatory non-conformance. Supports preventive action design and regulatory submission.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the underlying finding or citation that triggered the corrective action plan. Critical findings typically require immediate action and agency notification; minor findings allow extended remediation timelines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedToAgencyDate rdf:type rdf:Property ;
    rdfs:label 'Submitted To Agency Date' ;
    rdfs:comment 'The date on which the corrective action plan was formally submitted to the regulatory agency for review and acknowledgment. Critical for demonstrating timely regulatory response.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The committed target date by which all corrective actions defined in the plan are expected to be fully implemented and verified. This date is typically agreed upon with the regulatory agency.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Verification Completed Date' ;
    rdfs:comment 'The date on which verification activities confirming effective implementation of corrective actions were completed.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'The result of the verification activity confirming whether the corrective actions were effectively implemented and the non-conformance resolved. Drives CAP closure or escalation decisions.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Regulatory classification of the violation or non-conformance that triggered the CAP (e.g., HACCP deviation, pesticide MRL exceedance, GAP non-compliance, food safety, environmental permit, worker safety). [ENUM-REF-CANDIDATE: haccp_deviation|mrl_exceedance|gap_noncompliance|food_safety|environmental_permit|worker_safety|labeling|record_keeping|other — promote to reference product]' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallPlanId rdf:type rdf:Property ;
    rdfs:label 'Recall Plan Id' ;
    rdfs:comment 'Reference to the associated product recall plan document that is incorporated by reference into this food safety plan.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallPlan .

ind:allergenControlRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Required' ;
    rdfs:comment 'Indicates whether allergen preventive controls are required under this food safety plan, based on the presence of major food allergens as defined by FALCPA and FASTER Act.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the Preventive Controls Qualified Individual (PCQI) formally signed off and approved this food safety plan version.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:biologicalHazardIdentified rdf:type rdf:Property ;
    rdfs:label 'Biological Hazard Identified' ;
    rdfs:comment 'Indicates whether the hazard analysis identified one or more biological hazards (e.g., pathogens such as Salmonella, E. coli O157:H7, Listeria monocytogenes) requiring preventive controls.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chemicalHazardIdentified rdf:type rdf:Property ;
    rdfs:label 'Chemical Hazard Identified' ;
    rdfs:comment 'Indicates whether the hazard analysis identified one or more chemical hazards (e.g., pesticide residues exceeding Maximum Residue Limits (MRL), mycotoxins, allergens, cleaning chemical residues) requiring preventive controls.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary of corrective action procedures to be taken when preventive controls are not properly implemented or a deviation occurs, including product disposition and root cause analysis steps.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Registration Number' ;
    rdfs:comment 'FDA-issued food facility registration number for the facility covered by this plan, as required under the Bioterrorism Act and FSMA. Used to link the plan to the registered facility in FDA systems.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Reference Number' ;
    rdfs:comment 'FDA-assigned reference or acknowledgment number for the submitted food safety plan, used for tracking regulatory correspondence and inspection readiness.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Date' ;
    rdfs:comment 'Date on which this food safety plan or associated documentation was formally submitted to the FDA.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Status' ;
    rdfs:comment 'Current status of the food safety plan\'s submission to the FDA. \'not_required\' applies to qualified facility exemptions; \'acknowledged\' indicates FDA receipt confirmation. [ENUM-REF-CANDIDATE: not_required|pending|submitted|acknowledged|under_review|accepted|rejected — promote to reference product]' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertificationScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Scheme' ;
    rdfs:comment 'Global Food Safety Initiative (GFSI)-recognized certification scheme under which the facility is certified, if applicable. This scheme may satisfy or complement FSMA food safety plan requirements. [ENUM-REF-CANDIDATE: SQF|BRC|IFS|FSSC22000|GLOBALG.A.P.|PRIMUS|NONE — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardAnalysisSummary rdf:type rdf:Property ;
    rdfs:label 'Hazard Analysis Summary' ;
    rdfs:comment 'Summary narrative of the hazard analysis conducted for this food safety plan, identifying known or reasonably foreseeable biological, chemical, and physical hazards associated with the food and process.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReanalysisDate rdf:type rdf:Property ;
    rdfs:label 'Last Reanalysis Date' ;
    rdfs:comment 'Date on which the most recent formal reanalysis of this food safety plan was completed, as required by FSMA reanalysis provisions.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringProcedureSummary rdf:type rdf:Property ;
    rdfs:label 'Monitoring Procedure Summary' ;
    rdfs:comment 'Summary description of the monitoring procedures established for preventive controls in this plan, including what is monitored, how, frequency, and responsible personnel.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcqiCredential rdf:type rdf:Property ;
    rdfs:label 'Pcqi Credential' ;
    rdfs:comment 'Credential or training certification held by the PCQI, such as FSPCA Preventive Controls for Human Food training certificate number, demonstrating qualification to prepare the food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcqiName rdf:type rdf:Property ;
    rdfs:label 'Pcqi Name' ;
    rdfs:comment 'Full name of the Preventive Controls Qualified Individual (PCQI) responsible for preparing or overseeing the preparation of this food safety plan, as required by FSMA.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalHazardIdentified rdf:type rdf:Property ;
    rdfs:label 'Physical Hazard Identified' ;
    rdfs:comment 'Indicates whether the hazard analysis identified one or more physical hazards (e.g., metal fragments, glass, stones, bone) requiring preventive controls.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the food safety plan, used in regulatory submissions, audit documentation, and cross-referencing with FDA records. Format: FSP-{FacilityCode}-{Year}.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the food safety plan. \'active\' indicates the plan is in force; \'superseded\' indicates a newer version has replaced it; \'withdrawn\' indicates the plan was retracted prior to activation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Descriptive title of the food safety plan as it appears on the official plan document, typically including the facility name and scope (e.g., \'Grain Processing Facility — PCHF Food Safety Plan\').' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the FSMA food safety plan by regulatory rule: Preventive Controls for Human Food (PCHF) per 21 CFR Part 117, Preventive Controls for Animal Food (PCAF) per 21 CFR Part 507, Produce Safety Rule (PSR) per 21 CFR Part 112, or COMBINED for facilities subject to multiple rules.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the food safety plan document (e.g., 1.0, 2.1). Incremented upon each reanalysis or material revision as required by FSMA reanalysis provisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radiologicalHazardIdentified rdf:type rdf:Property ;
    rdfs:label 'Radiological Hazard Identified' ;
    rdfs:comment 'Indicates whether the hazard analysis identified radiological hazards requiring preventive controls, as recognized under FSMA expanded hazard categories.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reanalysisDueDate rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Due Date' ;
    rdfs:comment 'Scheduled date by which the food safety plan must be reanalyzed per FSMA requirements (at minimum every 3 years, or sooner upon triggering events such as new hazard identification or process change).' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'Number of years that records associated with this food safety plan must be retained per FSMA requirements. Typically 2 years for most records; longer for certain process-related records.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanitationControlRequired rdf:type rdf:Property ;
    rdfs:label 'Sanitation Control Required' ;
    rdfs:comment 'Indicates whether sanitation preventive controls are required under this food safety plan to address environmental pathogens or food contact surface contamination.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyChainControlRequired rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Control Required' ;
    rdfs:comment 'Indicates whether supply chain preventive controls are required under this food safety plan for raw materials or ingredients with hazards controlled upstream by a supplier.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation status of the process preventive controls in this food safety plan, confirming that the controls are capable of effectively controlling the identified hazards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationActivitySummary rdf:type rdf:Property ;
    rdfs:label 'Verification Activity Summary' ;
    rdfs:comment 'Summary of verification activities confirming that preventive controls are consistently implemented and effective, including calibration, product testing, environmental monitoring, and record review schedules.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorInspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Prior Inspection Record Id' ;
    rdfs:comment 'Self-referencing identifier linking this inspection to the preceding inspection record at the same facility, enabling inspection history chain tracking and trend analysis across inspection cycles.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRecord .

ind:correctiveActionSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Submitted Date' ;
    rdfs:comment 'The date on which the facility formally submitted its corrective action plan or response to the inspecting agency. Used to track timeliness of regulatory response and compliance calendar management.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of critical or major deficiencies identified that pose immediate food safety, environmental, or worker safety risk. Critical deficiencies typically require immediate corrective action and may trigger regulatory enforcement or facility suspension.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of regulatory deficiencies, violations, or non-conformances identified during the inspection. Used for risk scoring, trend analysis, and corrective action prioritization.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementActionDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Date' ;
    rdfs:comment 'The date on which the formal enforcement action was issued or initiated by the inspecting agency. Null when enforcement_action_type is \'none\'.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionType rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Type' ;
    rdfs:comment 'Type of formal regulatory enforcement action initiated as a result of the inspection findings. None indicates no enforcement action; escalating severity from warning letter through facility shutdown. [ENUM-REF-CANDIDATE: none|warning_letter|notice_of_violation|consent_order|suspension|recall|shutdown — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Establishment Number' ;
    rdfs:comment 'Official government-assigned establishment or facility registration number (e.g., USDA FSIS grant of inspection number, FDA food facility registration number, EPA facility ID). Used for regulatory cross-referencing and agency reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of the inspection findings, observations, and deficiencies as documented by the inspector. Captures the key compliance issues identified during the inspection for management review and corrective action planning.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Date' ;
    rdfs:comment 'The scheduled or actual date of the follow-up inspection to verify corrective action completion. Null when follow_up_inspection_required is False. Links to a subsequent inspection_record when the follow-up is completed.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required' ;
    rdfs:comment 'Indicates whether the inspecting agency has mandated a follow-up inspection to verify corrective action implementation. Drives compliance calendar scheduling and audit readiness planning.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Verified' ;
    rdfs:comment 'Indicates whether Good Agricultural Practices (GAP) compliance was verified during the inspection. Applicable to farm-level inspections under FSMA Produce Safety Rule and GLOBALG.A.P. certification audits.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpPlanReviewed rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Reviewed' ;
    rdfs:comment 'Indicates whether the facility\'s HACCP plan was reviewed as part of the inspection scope. Relevant for USDA FSIS and FDA food safety inspections at processing facilities.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The calendar date on which the regulatory inspection was conducted at the facility or farm unit. This is the principal real-world event date for the inspection record.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'The precise date and time when the inspection concluded at the facility. Combined with inspection_start_time to calculate total inspection duration for operational planning and compliance analytics.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Internal operational notes and observations recorded by the facility\'s compliance team during or after the inspection. Captures context not included in the official findings summary, such as inspector verbal comments, facility conditions, or management responses.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-assigned unique inspection reference number issued by the inspecting agency (e.g., FSIS establishment inspection number, FDA EIR number, EPA inspection ID). Used for cross-referencing with agency records and regulatory filings.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'The regulatory domain or operational area covered by the inspection. Determines which regulatory framework applies and which compliance areas were evaluated. [ENUM-REF-CANDIDATE: food_safety|environmental|workplace_safety|pesticide_use|animal_welfare|organic_certification|full_facility|partial — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'The precise date and time when the inspection commenced at the facility. Used for duration calculation, shift-level compliance tracking, and operational impact assessment.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection by its trigger or scheduling basis. Routine inspections are scheduled per regulatory calendar; for-cause inspections are triggered by complaints or incidents; follow-up inspections verify corrective action closure; pre-operational inspections occur before facility startup. [ENUM-REF-CANDIDATE: routine|for_cause|follow_up|pre_operational|announced|unannounced — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAgencyDistrict rdf:type rdf:Property ;
    rdfs:label 'Inspector Agency District' ;
    rdfs:comment 'The regional district or field office of the inspecting agency from which the inspector was assigned. Used for jurisdictional tracking, agency relationship management, and regional compliance trend analysis.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Badge Number' ;
    rdfs:comment 'Official government-issued badge or credential number of the inspector. Used to verify inspector identity, validate inspection authority, and cross-reference with agency records.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialReportReference rdf:type rdf:Property ;
    rdfs:label 'Official Report Reference' ;
    rdfs:comment 'The official document reference number or file identifier for the agency-issued inspection report (e.g., FDA Establishment Inspection Report number, USDA NR number, OSHA inspection number). Used for document management and regulatory correspondence tracking.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Compliance Status' ;
    rdfs:comment 'Current lifecycle status of the inspection record from a compliance management perspective. Tracks whether the inspection findings have been resolved, are under appeal, or remain open. Distinct from outcome which reflects the inspector\'s determination at time of inspection.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideRecordsReviewed rdf:type rdf:Property ;
    rdfs:label 'Pesticide Records Reviewed' ;
    rdfs:comment 'Indicates whether pesticide application records, including Pre-Harvest Interval (PHI) compliance, Maximum Residue Limit (MRL) adherence, and EPA-registered product use, were reviewed during the inspection.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterTestingReviewed rdf:type rdf:Property ;
    rdfs:label 'Water Testing Reviewed' ;
    rdfs:comment 'Indicates whether agricultural water testing records and water quality compliance documentation were reviewed during the inspection, as required under FSMA Produce Safety Rule for irrigation and post-harvest water.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Holder Employee Id' ;
    rdfs:comment 'Reference to the internal employee or workforce record for the individual license holder, when the holder is an employee of the organization. Links the license to the SAP SuccessFactors HR record for workforce compliance tracking and CEU monitoring.' ;
    rdfs:domain ind:License ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the license application or renewal application was submitted to the issuing authority. Used to track processing time, identify pending applications, and manage compliance calendar timelines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Application Fee Usd' ;
    rdfs:comment 'Amount paid in US dollars for the license application or renewal fee to the issuing authority. Used for financial tracking, OPEX reporting, and compliance cost management. Recorded in the finance system (Oracle NetSuite AP module) as a regulatory expense.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Bond Amount Usd' ;
    rdfs:comment 'Dollar value of the surety bond required or held in connection with this license. Applicable when bond_required is True. Used for financial risk management and regulatory compliance verification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondRequired rdf:type rdf:Property ;
    rdfs:label 'Bond Required' ;
    rdfs:comment 'Indicates whether a surety bond is required by the issuing authority as a condition of holding this license (e.g., agricultural dealer bonds required by many state agriculture departments). True if a bond is required; False if no bond requirement exists.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceuCompleted rdf:type rdf:Property ;
    rdfs:label 'Ceu Completed' ;
    rdfs:comment 'Total number of Continuing Education Units (CEU) completed by the license holder in the current renewal cycle. Compared against ceu_required to determine compliance status and renewal eligibility.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceuCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Ceu Cycle End Date' ;
    rdfs:comment 'The end date of the current CEU reporting cycle for this license. CEU credits earned after this date apply to the next renewal cycle. Used to accurately track CEU compliance within the correct reporting window.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceuRequired rdf:type rdf:Property ;
    rdfs:label 'Ceu Required' ;
    rdfs:comment 'Total number of Continuing Education Units (CEU) required per renewal cycle to maintain the license in good standing. Used to track CEU compliance progress against the required threshold. Common for CCA credentials, pesticide applicator licenses, and food handler certifications.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceDomainCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Domain Code' ;
    rdfs:comment 'Categorizes the license within the enterprise compliance framework by the primary regulatory domain it governs. Enables domain-specific compliance reporting and audit readiness dashboards across USDA, EPA, FDA, FSIS, and FMCSA regulatory areas. [ENUM-REF-CANDIDATE: crop_protection|livestock|food_safety|transport|environmental|organic|trade — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL pointing to the scanned or digital copy of the license certificate stored in the enterprise document repository. Enables rapid retrieval of license documentation for audits, inspections, and regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementCodes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Codes' ;
    rdfs:comment 'Comma-separated list of endorsement or specialty codes appended to the base license (e.g., CDL endorsements \'H,N,T\' for hazardous materials, tank vehicle, and double/triple trailers; or pesticide applicator specialty endorsements). Captures additional authorized activities beyond the base license scope.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examPassedDate rdf:type rdf:Property ;
    rdfs:label 'Exam Passed Date' ;
    rdfs:comment 'Date on which the license holder passed the qualifying examination required for license issuance. Relevant for licenses requiring a competency exam (e.g., pesticide applicator exam, CCA exam, CDL knowledge test). Null for licenses issued without examination.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'Numeric score achieved by the license holder on the qualifying examination, expressed as a percentage or raw score per the licensing authority\'s scoring system. Used for competency documentation and audit evidence.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'Full legal name of the individual or entity holding the license. For individual licenses (e.g., pesticide applicator, CCA, CDL), this is the person\'s full legal name. For entity licenses (e.g., agricultural dealer), this is the registered business name. Used in regulatory filings and audit documentation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether the issuing authority requires the license holder to maintain liability insurance as a condition of the license (e.g., commercial pesticide applicator liability insurance). True if insurance is required; False otherwise.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the license or credential was originally issued by the licensing authority. Represents the effective start of the license\'s validity period. Used to calculate license age and determine original qualification date.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBodyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Reference Number' ;
    rdfs:comment 'Internal reference or tracking number assigned by the issuing authority\'s system (distinct from the public-facing license_number). Used for correspondence with the licensing body and cross-referencing regulatory databases such as EPA\'s FIFRA licensing registry or state DPR systems.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseCategory rdf:type rdf:Property ;
    rdfs:label 'License Category' ;
    rdfs:comment 'Indicates whether the license is held by an individual person, a business entity, or a facility. Drives downstream compliance workflows — individual licenses track personal qualifications while entity licenses cover organizational authorizations.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license number or credential identifier assigned by the issuing regulatory or licensing authority (e.g., state pesticide applicator license number, CCA credential number, CDL number). This is the externally-known business identifier used in regulatory filings and compliance audits.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle state of the license. Active indicates the license is valid and in good standing. Expired indicates the license has passed its expiration date without renewal. Suspended indicates temporary regulatory hold. Revoked indicates permanent cancellation by the issuing authority. Pending renewal indicates renewal application submitted but not yet approved.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license or professional credential by regulatory category. Examples include pesticide applicator (private), pesticide applicator (commercial), certified crop advisor (CCA), veterinary license, food handler certification, commercial driver license (CDL), agricultural dealer license, and fumigation license. [ENUM-REF-CANDIDATE: pesticide_applicator_private|pesticide_applicator_commercial|certified_crop_advisor|veterinary|food_handler|cdl|agricultural_dealer|fumigation — promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Pesticide Category Code' ;
    rdfs:comment 'EPA or state-assigned pesticide applicator category code that defines the type of pesticide application authorized (e.g., \'1A\' for Agricultural Plant, \'7A\' for Wood Preservation, \'11\' for Aerial Application). Applicable only to pesticide applicator licenses. Null for non-pesticide license types.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDays rdf:type rdf:Property ;
    rdfs:label 'Phi Days' ;
    rdfs:comment 'Pre-Harvest Interval (PHI) in days associated with the pesticide applicator license authorization. Specifies the minimum number of days that must elapse between the last pesticide application and harvest. Applicable to pesticide applicator licenses; null for other license types.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reciprocityStates rdf:type rdf:Property ;
    rdfs:label 'Reciprocity States' ;
    rdfs:comment 'Comma-separated list of US state codes where this license is recognized under reciprocity agreements, allowing the holder to conduct regulated activities without obtaining a separate state license. Relevant for multi-state agricultural operations and commercial pesticide applicators.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiHours rdf:type rdf:Property ;
    rdfs:label 'Rei Hours' ;
    rdfs:comment 'Restricted Entry Interval (REI) in hours associated with the pesticide applicator license authorization. Specifies the minimum time that must pass after a pesticide application before workers may re-enter the treated area without personal protective equipment. Applicable to pesticide applicator licenses; null for other license types.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the license was most recently renewed by the licensing authority. Distinct from issue_date (original issuance) and expiration_date (next expiry). Tracks renewal history for compliance audit purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before the renewal_due_date that the compliance system should trigger an automated renewal reminder notification. Configurable per license type to accommodate varying regulatory lead times (e.g., 90 days for complex pesticide applicator renewals, 30 days for food handler certifications).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingProgramName rdf:type rdf:Property ;
    rdfs:label 'Training Program Name' ;
    rdfs:comment 'Name of the qualifying training program, examination, or certification course completed by the holder to obtain this license (e.g., \'USDA Pesticide Safety Training\', \'ServSafe Food Handler Certification\', \'American Society of Agronomy CCA Exam\'). Supports audit readiness and credential verification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringResultId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Result Id' ;
    rdfs:comment 'Unique system-generated identifier for each environmental monitoring result record. Primary key for the monitoring_result data product.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldSampleId rdf:type rdf:Property ;
    rdfs:label 'Field Sample Id' ;
    rdfs:comment 'The unique identifier assigned to the sample at the time of field collection, recorded on the field sampling log and Chain of Custody form. Enables traceability from field collection through laboratory analysis to compliance reporting.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:labSampleId rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Id' ;
    rdfs:comment 'Foreign key linking to quality.lab_sample. Business justification: Compliance monitoring results (permit condition reporting) are derived from physical lab samples collected and analyzed by the quality lab. Linking monitoring_result to lab_sample enables chain-of-cus' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:laboratoryId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Id' ;
    rdfs:comment 'Reference to the certified analytical laboratory that performed the sample analysis and reported the measured result.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:laboratorySampleId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Sample Id' ;
    rdfs:comment 'The unique sample identifier assigned by the analytical laboratory, as it appears on the Chain of Custody (COC) form and Certificate of Analysis (COA). Used to cross-reference laboratory reports with field sampling records.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:mrlThresholdId rdf:type rdf:Property ;
    rdfs:label 'Mrl Threshold Id' ;
    rdfs:comment 'Foreign key linking to product.mrl_threshold. Business justification: Residue monitoring results must be evaluated against the specific MRL threshold for the active ingredient/commodity combination. This link enables exceedance_flag calculation, regulatory reporting, an' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrlThreshold .

ind:observationId rdf:type rdf:Property ;
    rdfs:label 'Observation Id' ;
    rdfs:comment 'Foreign key linking to weather.observation. Business justification: NPDES discharge monitoring reports require weather conditions at time of sampling to contextualize results (e.g., post-storm runoff, dry-weather baseline). FDA produce safety water testing also requir' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Reference to the specific permit condition or monitoring requirement that this result satisfies. Enables traceability from measurement to regulatory obligation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Foreign key linking to quality.test_result. Business justification: Compliance monitoring results are sourced from quality test results (water quality, discharge parameters). Linking enables automated population of permit compliance reports from quality lab test resul' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:waterRightId rdf:type rdf:Property ;
    rdfs:label 'Water Right Id' ;
    rdfs:comment 'Foreign key linking to land.water_right. Business justification: Water withdrawal monitoring results must be reconciled against permitted water right volumes for annual use reporting. Linking monitoring_result to water_right enables automated exceedance detection a' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterRight .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the laboratory performed the analytical measurement on the collected sample. Used to verify holding time compliance between sample collection and analysis.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalMethodCode rdf:type rdf:Property ;
    rdfs:label 'Analytical Method Code' ;
    rdfs:comment 'Standardized code identifying the EPA-approved or equivalent analytical method used to measure the parameter (e.g., EPA Method 300.0 for anions, SM 4500-NO3 for nitrate, EPA Method 8270D for semivolatiles). Required for regulatory defensibility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalMethodName rdf:type rdf:Property ;
    rdfs:label 'Analytical Method Name' ;
    rdfs:comment 'Descriptive name of the analytical method used (e.g., \'Ion Chromatography\', \'Inductively Coupled Plasma Mass Spectrometry\', \'Colorimetric - Cadmium Reduction\'). Provides human-readable context for the analytical_method_code.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum concentration of a parameter that can be measured and reported with 99% confidence that the value is above zero, as defined by the analytical method. Used to interpret non-detect results and assess method suitability relative to permit limits.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Indicates whether the measured_value exceeds the permit_limit_value for this parameter and limit type. True = exceedance detected, requiring regulatory notification and corrective action. Core compliance indicator for permit condition monitoring.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceMagnitude rdf:type rdf:Property ;
    rdfs:label 'Exceedance Magnitude' ;
    rdfs:comment 'The numeric difference between the measured_value and the permit_limit_value when an exceedance occurs (measured_value minus permit_limit_value). Quantifies the severity of the permit violation for enforcement and corrective action prioritization.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRate rdf:type rdf:Property ;
    rdfs:label 'Flow Rate' ;
    rdfs:comment 'The volumetric flow rate of the discharge or water body at the time of sampling, expressed in the unit specified by the permit (e.g., MGD, GPM, CFS). Required for load calculations (mass per day) and flow-weighted composite sample interpretation.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowUnit rdf:type rdf:Property ;
    rdfs:label 'Flow Unit' ;
    rdfs:comment 'Unit of measure for the discharge flow rate (e.g., MGD = million gallons per day, GPM = gallons per minute, CFS = cubic feet per second). Required for accurate load calculations and DMR reporting.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the sample collection point. Enables GIS-based spatial analysis of monitoring results, watershed mapping, and integration with Esri ArcGIS for environmental monitoring visualization.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the sample collection point. Used with latitude for spatial analysis, watershed delineation, and regulatory mapping of monitoring locations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The quantitative analytical result for the monitored parameter as reported by the laboratory. This is the principal measured outcome of the monitoring event. Null if the result is non-detect (below detection limit).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Classification of the environmental monitoring category for this result. Determines the applicable regulatory framework, permit conditions, and reporting requirements. [ENUM-REF-CANDIDATE: water_quality|air_emissions|soil_nutrient|manure_management|groundwater|stormwater_runoff — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonDetectFlag rdf:type rdf:Property ;
    rdfs:label 'Non Detect Flag' ;
    rdfs:comment 'Indicates whether the parameter was not detected above the reporting detection limit. True = result is reported as non-detect (ND) or less-than value. When True, measured_value is null and the reporting_detection_limit serves as the upper bound.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Standardized regulatory code identifying the specific chemical, biological, or physical parameter measured (e.g., EPA parameter code for Total Nitrogen, Total Phosphorus, BOD5, pH, fecal coliform, nitrates). Aligns with EPA NPDES parameter codes for DMR reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name of the environmental parameter measured (e.g., \'Total Nitrogen\', \'Biochemical Oxygen Demand (BOD5)\', \'pH\', \'Total Suspended Solids\', \'Nitrate-Nitrogen\'). Complements the parameter_code for reporting and analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitType rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Type' ;
    rdfs:comment 'The statistical basis or averaging period for the permit limit against which the measured value is compared (e.g., daily maximum, monthly average, weekly average). Critical for correct compliance determination.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitValue rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Value' ;
    rdfs:comment 'The numeric threshold established in the environmental permit for this parameter at this monitoring location. The measured_value is compared against this limit to determine compliance status and exceedance.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingDetectionLimit rdf:type rdf:Property ;
    rdfs:label 'Reporting Detection Limit' ;
    rdfs:comment 'The practical quantitation limit (PQL) or minimum level (ML) used for regulatory reporting purposes, typically higher than the MDL. Determines whether a result is reported as a numeric value or as a non-detect qualifier.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the regulatory reporting period to which this monitoring result belongs. Together with reporting_period_start, defines the compliance window for DMR and permit condition reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the regulatory reporting period (monthly, quarterly, or annual) to which this monitoring result belongs. Used to aggregate results for Discharge Monitoring Reports (DMR) and other regulatory filings.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultNumber rdf:type rdf:Property ;
    rdfs:label 'Result Number' ;
    rdfs:comment 'Externally-known business identifier for this monitoring result, used in regulatory submissions, laboratory reports, and compliance correspondence. Typically formatted as a combination of permit number, reporting period, and sequence.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultQualifier rdf:type rdf:Property ;
    rdfs:label 'Result Qualifier' ;
    rdfs:comment 'Laboratory data qualifier code indicating special conditions affecting the result interpretation (e.g., U = non-detect, J = estimated value, B = method blank contamination, E = value exceeds calibration range). Standard EPA data qualifier codes. [ENUM-REF-CANDIDATE: U|J|B|E|H|<|> — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current lifecycle status of the monitoring result record, tracking its progression from initial data entry through regulatory submission and acceptance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDate rdf:type rdf:Property ;
    rdfs:label 'Sample Date' ;
    rdfs:comment 'The calendar date on which the environmental sample was physically collected in the field. This is the principal real-world event date for the monitoring result, distinct from laboratory analysis date or record creation date.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sample Location Code' ;
    rdfs:comment 'Permit-defined code or identifier for the specific sampling point or monitoring station where the sample was collected (e.g., outfall 001, well MW-3, field tile drain TD-7). Corresponds to the monitoring location defined in the permit.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Location Description' ;
    rdfs:comment 'Descriptive name or narrative for the sample collection point, providing human-readable context beyond the location code (e.g., \'North field tile drain at county road crossing\', \'Lagoon effluent discharge point\').' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMatrix rdf:type rdf:Property ;
    rdfs:label 'Sample Matrix' ;
    rdfs:comment 'The environmental medium or matrix from which the sample was collected. Determines applicable analytical methods, holding times, and regulatory limits. [ENUM-REF-CANDIDATE: effluent|surface_water|groundwater|soil|air|manure|sediment — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTime rdf:type rdf:Property ;
    rdfs:label 'Sample Time' ;
    rdfs:comment 'Precise date and time at which the environmental sample was collected, including timezone offset. Required for time-sensitive parameters such as dissolved oxygen, temperature, and pH where diurnal variation is significant.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Method by which the sample was collected. Grab samples represent instantaneous conditions; composite samples represent time- or flow-weighted averages. Blanks and duplicates are quality control samples. [ENUM-REF-CANDIDATE: grab|composite_24hr|composite_flow_weighted|field_duplicate|equipment_blank|trip_blank — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerName rdf:type rdf:Property ;
    rdfs:label 'Sampler Name' ;
    rdfs:comment 'Name of the certified individual or technician who collected the environmental sample in the field. Required for Chain of Custody documentation and regulatory defensibility of sampling procedures.' ;
    rdfs:domain ind:MonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the measured_value is expressed (e.g., mg/L, ug/L, CFU/100mL, pH units, lbs/day, ppm, ppb). Must align with the unit specified in the permit condition for direct comparability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Organic Compliance Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each USDA National Organic Program (NOP) compliance activity record. Primary key for this transactional compliance entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganicComplianceRecord .

ind:cropRotationPlanId rdf:type rdf:Property ;
    rdfs:label 'Crop Rotation Plan Id' ;
    rdfs:comment 'Foreign key linking to crop.rotation_plan. Business justification: NOP regulations require certifying agents to review and verify documented crop rotation plans as part of annual organic compliance inspection. Linking organic_compliance_record to rotation_plan enable' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RotationPlan .

ind:growingSeasonId rdf:type rdf:Property ;
    rdfs:label 'Growing Season Id' ;
    rdfs:comment 'Foreign key linking to crop.growing_season. Business justification: NOP annual organic certification renewal and compliance inspections are scoped to a specific crop season. Certifying agents must verify organic practices for the season under review; linking organic_c' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrowingSeason .

ind:organicCertificationId rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Id' ;
    rdfs:comment 'Reference to the organic certification master record (product.organic_certification) that this compliance activity record complements. Establishes the certification context for this ongoing compliance record.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganicCertification .

ind:parcelId rdf:type rdf:Property ;
    rdfs:label 'Parcel Id' ;
    rdfs:comment 'Foreign key linking to land.parcel. Business justification: USDA NOP requires parcel-level documentation for organic certification. Certified acres and transition land acres correspond to parcel legal descriptions. Linking organic_compliance_record to parcel e' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:annualRenewalStatus rdf:type rdf:Property ;
    rdfs:label 'Annual Renewal Status' ;
    rdfs:comment 'Status of the annual organic certification renewal process for the compliance year. Tracks the renewal lifecycle from initial application through certifying agent review to final renewal decision or denial.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferZoneAdequateFlag rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone Adequate Flag' ;
    rdfs:comment 'Indicates whether the buffer zone assessment confirmed that adequate separation exists between certified organic production areas and adjacent non-organic operations to prevent prohibited substance contamination.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bufferZoneAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone Assessment Date' ;
    rdfs:comment 'Date on which the buffer zone between certified organic fields and adjacent conventional or non-organic operations was last formally assessed. Buffer zones protect organic crops from prohibited substance drift and contamination.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bufferZoneNotes rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone Notes' ;
    rdfs:comment 'Narrative notes from the buffer zone assessment, including observations about adjacent land use, drift risk factors, physical barriers, and any recommended corrective measures to maintain organic integrity.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAcres rdf:type rdf:Property ;
    rdfs:label 'Certified Acres' ;
    rdfs:comment 'Total acreage of land under certified organic production covered by this compliance record. Used for USDA NOP reporting, Organic Integrity Database submissions, and yield benchmarking.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifyingAgentName rdf:type rdf:Property ;
    rdfs:label 'Certifying Agent Name' ;
    rdfs:comment 'Name of the USDA-accredited certifying agent organization responsible for certifying and auditing this organic operation. Retained as a denormalized reference for reporting and audit trail purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActivityDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Activity Date' ;
    rdfs:comment 'The principal real-world date on which the compliance activity, assessment, or submission captured in this record occurred. Used as the primary business event date for compliance calendar management.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current lifecycle status of this organic compliance record. \'open\' indicates active monitoring period; \'under_review\' indicates certifying agent review in progress; \'compliant\' indicates all NOP requirements met; \'non_compliant\' indicates a violation identified; \'suspended\' indicates certification suspended pending investigation; \'closed\' indicates record period concluded.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'The calendar year (YYYY) for which this organic compliance record applies. Aligns with the annual certification renewal cycle under the USDA National Organic Program.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmoContaminationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Contamination Risk Flag' ;
    rdfs:comment 'Indicates whether a risk of Genetically Modified Organism (GMO) contamination has been identified for this operation during the compliance period. GMO use is prohibited in certified organic production under USDA NOP.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputMaterialsReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Input Materials Reviewed Flag' ;
    rdfs:comment 'Indicates whether all agricultural inputs (fertilizers, pesticides, soil amendments, livestock feed additives) used during the compliance period have been reviewed and confirmed as compliant with the USDA NOP National List of Allowed and Prohibited Substances.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Result of the most recent on-site inspection by the certifying agent. \'pass\' indicates full compliance; \'pass_with_conditions\' indicates minor deficiencies requiring corrective action; \'fail\' indicates material non-compliance; \'pending_review\' indicates inspection report under certifying agent review.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nopViolationCategory rdf:type rdf:Property ;
    rdfs:label 'Nop Violation Category' ;
    rdfs:comment 'Category of NOP regulatory violation identified during this compliance period, if applicable. Examples include prohibited substance use, recordkeeping deficiency, labeling non-compliance, or OSP deviation. Null when no violation exists. [ENUM-REF-CANDIDATE: prohibited_substance|recordkeeping|labeling|osp_deviation|commingling|buffer_zone|other — promote to reference product]' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nopViolationDescription rdf:type rdf:Property ;
    rdfs:label 'Nop Violation Description' ;
    rdfs:comment 'Detailed narrative description of any NOP regulatory violation identified during this compliance period, including the specific regulation cited, the nature of the non-conformance, and the affected production area or product.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Classification of the certified organic operation type covered by this compliance record. Determines applicable NOP regulatory requirements and inspection protocols.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicIntegrityDbStatus rdf:type rdf:Property ;
    rdfs:label 'Organic Integrity Db Status' ;
    rdfs:comment 'Status of the operation\'s data submission to the USDA Organic Integrity Database (OID). \'pending\' indicates submission not yet made; \'submitted\' indicates data transmitted; \'verified\' indicates USDA confirmation received; \'discrepancy_flagged\' indicates a data mismatch requiring resolution.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicIntegrityDbSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Organic Integrity Db Submission Date' ;
    rdfs:comment 'Date on which the certifying agent submitted or updated the operation\'s certification data to the USDA Organic Integrity Database (OID), the publicly accessible registry of all USDA-certified organic operations.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ospSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Osp Submission Status' ;
    rdfs:comment 'Current submission and review status of the Organic System Plan (OSP) with the certifying agent for this compliance year. Tracks whether the OSP has been drafted, submitted, accepted, returned for revision, or formally approved.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ospUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Osp Update Date' ;
    rdfs:comment 'Date on which the Organic System Plan (OSP) was last updated and submitted to the certifying agent. OSP updates are required whenever there is a change in practices, materials, or operation scope.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ospVersion rdf:type rdf:Property ;
    rdfs:label 'Osp Version' ;
    rdfs:comment 'Version identifier of the Organic System Plan (OSP) in effect at the time of this compliance record. The OSP is the foundational document describing all practices and substances used in the certified organic operation, required under USDA NOP 7 CFR Part 205.201.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Parallel Production Flag' ;
    rdfs:comment 'Indicates whether the operation produces the same crop or product in both certified organic and non-organic (conventional) forms simultaneously. Parallel production requires enhanced split operation controls and documentation to prevent commingling.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedSubstanceDescription rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance Description' ;
    rdfs:comment 'Description of the prohibited substance(s) involved in an incident, including the substance name, application method, and circumstances of use or contamination. Populated only when prohibited_substance_incident_flag is True.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedSubstanceIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance Incident Flag' ;
    rdfs:comment 'Indicates whether a prohibited substance use incident has been identified or reported for this operation during the compliance record period. True triggers mandatory investigation and potential certification suspension under USDA NOP regulations.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedSubstanceInvestigationStatus rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance Investigation Status' ;
    rdfs:comment 'Current status of the investigation into a prohibited substance incident. \'not_applicable\' when no incident exists; \'open\' when investigation initiated; \'in_progress\' when certifying agent review underway; \'resolved\' when investigation concluded; \'escalated\' when referred to USDA NOP for enforcement action.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Externally-known business identifier for this compliance record, formatted as OCR-{YEAR}-{SEQUENCE}. Used in correspondence with certifying agents, USDA Organic Integrity Database submissions, and audit documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordkeepingAuditResult rdf:type rdf:Property ;
    rdfs:label 'Recordkeeping Audit Result' ;
    rdfs:comment 'Result of the certifying agent\'s review of the operation\'s organic recordkeeping system during the compliance period. USDA NOP requires operators to maintain records sufficient to demonstrate compliance for a minimum of five years.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'Date on which the annual organic certification renewal application was submitted to the certifying agent. Required annually to maintain continuous organic certification status under USDA NOP.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Decision Date' ;
    rdfs:comment 'Date on which the certifying agent issued the final renewal decision (approved or denied) for the annual organic certification. Used to track certification continuity and compliance calendar deadlines.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:splitOperationControlsDocumented rdf:type rdf:Property ;
    rdfs:label 'Split Operation Controls Documented' ;
    rdfs:comment 'Indicates whether the required split operation management controls — including physical separation, equipment cleaning procedures, and audit trail documentation — have been formally documented in the Organic System Plan (OSP) for this compliance period.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Split Operation Flag' ;
    rdfs:comment 'Indicates whether this is a split operation — one that produces, prepares, or handles both certified organic and non-certified products. Split operations require documented controls to prevent commingling and prohibited substance contact.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionLandAcres rdf:type rdf:Property ;
    rdfs:label 'Transition Land Acres' ;
    rdfs:comment 'Total acreage currently in the 36-month organic transition period required before land can be certified as organic under USDA NOP. Tracked separately from certified acres to manage transition timelines.' ;
    rdfs:domain ind:OrganicComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'Dollar amount of the surety bond required as a condition of this permit, in USD. Null if no bond is required. Used for financial compliance tracking and insurance management.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cafoAnimalUnitCapacity rdf:type rdf:Property ;
    rdfs:label 'Cafo Animal Unit Capacity' ;
    rdfs:comment 'Maximum number of animal units authorized under a Concentrated Animal Feeding Operation (CAFO) permit. Null for non-CAFO permit types. Used to verify compliance with EPA CAFO regulations and state livestock operation permits.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Summary of key conditions, operational limits, and requirements attached to the permit (e.g., effluent discharge limits in mg/L, maximum application rates for pesticides, monitoring and reporting frequencies, best management practices required). Supports compliance monitoring and audit readiness.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Discharge Limit Unit' ;
    rdfs:comment 'Unit of measure for the permitted discharge or emission limit value (e.g., mg/L for water quality, lbs/day for mass loading, tons/year for air emissions, acre-feet/year for water withdrawal). Null for non-discharge permit types.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeLimitValue rdf:type rdf:Property ;
    rdfs:label 'Discharge Limit Value' ;
    rdfs:comment 'Numeric limit on the quantity or concentration of a regulated substance permitted for discharge or emission under this permit (e.g., maximum effluent concentration in mg/L for NPDES permits, maximum air emission rate in tons/year for air quality permits). Null for non-discharge permit types.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Fee paid to the issuing authority for permit issuance or renewal, in USD. Used for operational expenditure (OPEX) tracking and financial planning in SAP S/4HANA FI/CO modules.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmoRegulated rdf:type rdf:Property ;
    rdfs:label 'Gmo Regulated' ;
    rdfs:comment 'Indicates whether this permit covers or restricts activities involving Genetically Modified Organisms (GMOs), as regulated by USDA APHIS biotechnology regulations. True if GMO-related activities are within scope; False otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceMinimumCoverage rdf:type rdf:Property ;
    rdfs:label 'Insurance Minimum Coverage' ;
    rdfs:comment 'Minimum liability insurance coverage amount required by the permit conditions, in USD. Null if no insurance requirement exists. Supports risk management and compliance verification.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingAuthorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Jurisdiction' ;
    rdfs:comment 'Jurisdictional level of the issuing regulatory authority. Distinguishes between federal (EPA, USDA, FDA), state, county, municipal, or international (e.g., Codex Alimentarius, GLOBALG.A.P.) permits to support multi-level compliance management.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection or compliance audit conducted by the issuing authority for this permit. Used to track inspection history and assess audit readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Result' ;
    rdfs:comment 'Outcome of the most recent regulatory inspection for this permit. \'no_violation\' indicates full compliance; \'minor_violation\' indicates non-critical deficiencies noted; \'major_violation\' indicates significant non-compliance requiring corrective action; \'pending_review\' indicates inspection completed but results not yet finalized.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Required frequency of compliance monitoring and regulatory reporting under this permit (e.g., daily effluent sampling for NPDES, quarterly groundwater monitoring, annual air emissions inventory). Drives compliance calendar scheduling. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annual|annual|event-based — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReportingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reporting Due Date' ;
    rdfs:comment 'Date by which the next compliance report or monitoring data submission is due to the issuing authority under this permit. Supports compliance calendar management and audit readiness.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Externally-issued permit number or license number assigned by the issuing regulatory authority (e.g., EPA NPDES permit number, state pesticide applicator license number, CAFO permit number). This is the official identifier used in regulatory correspondence and filings.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit. \'active\' indicates the permit is valid and in force; \'pending\' indicates application submitted but not yet approved; \'expired\' indicates the permit has passed its expiration date without renewal; \'suspended\' indicates temporarily halted by the issuing authority; \'revoked\' indicates permanently cancelled; \'under_renewal\' indicates renewal application is in progress.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit by regulatory category. Covers EPA NPDES discharge permits, air quality permits, Concentrated Animal Feeding Operation (CAFO) permits, water withdrawal permits, pesticide applicator licenses, state-issued agricultural operating permits, FDA food facility registrations, hazardous waste permits, and stormwater permits. [ENUM-REF-CANDIDATE: NPDES_discharge|air_quality|CAFO|water_withdrawal|pesticide_applicator|agricultural_operating|food_facility_registration|hazardous_waste|stormwater — promote to reference product]' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedActivity rdf:type rdf:Property ;
    rdfs:label 'Permitted Activity' ;
    rdfs:comment 'Narrative description of the specific agricultural or operational activity authorized under this permit (e.g., \'discharge of process wastewater from poultry processing facility\', \'application of restricted-use pesticides on row crops\', \'withdrawal of groundwater for irrigation up to 500 acre-feet per year\'). Defines the legal scope of authorized operations.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideLicenseCategory rdf:type rdf:Property ;
    rdfs:label 'Pesticide License Category' ;
    rdfs:comment 'EPA or state-defined category of pesticide application authorized under a pesticide applicator license (e.g., \'Agricultural Plant\', \'Fumigation\', \'Ornamental and Turf\', \'Right-of-Way\'). Null for non-pesticide permit types. [ENUM-REF-CANDIDATE: agricultural_plant|fumigation|ornamental_turf|right_of_way|aquatic|forest|seed_treatment — promote to reference product]' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationSubmitted rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Submitted' ;
    rdfs:comment 'Indicates whether a renewal application has been formally submitted to the issuing authority prior to the permit expiration date. True if submitted; False if not yet submitted. Supports compliance calendar and renewal workflow management.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDeadline rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline' ;
    rdfs:comment 'The date by which a renewal application must be submitted to the issuing authority to maintain continuous permit coverage without lapse. Typically precedes the expiration date by a regulatory-specified lead time (e.g., 180 days for EPA NPDES permits).' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleContactEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Email' ;
    rdfs:comment 'Email address of the internal employee or designated responsible party accountable for this permit. Used for compliance notifications, renewal reminders, and regulatory correspondence routing.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContactName rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Name' ;
    rdfs:comment 'Full name of the internal employee or designated responsible party accountable for maintaining compliance with this permit and managing regulatory correspondence. Used for audit accountability and regulatory contact management.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of regulatory violations recorded against this permit since issuance. Used for compliance risk scoring, regulatory relationship management, and audit reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterWithdrawalLimitAcreFeet rdf:type rdf:Property ;
    rdfs:label 'Water Withdrawal Limit Acre Feet' ;
    rdfs:comment 'Maximum volume of water authorized for withdrawal under a water withdrawal or irrigation permit, expressed in acre-feet per year. Null for non-water-withdrawal permit types. Supports water resource management and regulatory compliance reporting.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateNormalId rdf:type rdf:Property ;
    rdfs:label 'Climate Normal Id' ;
    rdfs:comment 'Foreign key linking to weather.climate_normal. Business justification: NPDES and water withdrawal permit conditions set discharge/withdrawal limits calibrated against historical climate normals (seasonal precipitation, drought frequency). Environmental compliance officer' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClimateNormal .

ind:outfallId rdf:type rdf:Property ;
    rdfs:label 'Outfall Id' ;
    rdfs:comment 'The regulatory outfall or discharge point identifier as designated in the permit (e.g., \'Outfall 001\', \'Outfall 002\'). Used in electronic discharge monitoring reports (eDMR) and regulatory submissions to identify the specific discharge location.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Outfall .

ind:responsibleFacilityId rdf:type rdf:Property ;
    rdfs:label 'Responsible Facility Id' ;
    rdfs:comment 'Reference to the agricultural facility, operation, or site (e.g., CAFO, processing plant, irrigation district) responsible for monitoring and complying with this permit condition. Links to the facility master record.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:conditionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Condition Effective Date' ;
    rdfs:comment 'The date on which this specific permit condition became legally effective and enforceable. May differ from the parent permit effective date if the condition was added via permit modification.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Condition Expiry Date' ;
    rdfs:comment 'The date on which this permit condition expires or is no longer enforceable. Typically aligns with the parent permit expiration date but may differ for time-limited or phased conditions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Number' ;
    rdfs:comment 'The official alphanumeric condition number as assigned by the regulatory agency within the permit document (e.g., \'Part I.A.1\', \'Condition 3b\'). Used to cross-reference the physical permit document.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Lifecycle status of the permit condition record itself. Active conditions are currently enforceable; superseded conditions have been replaced by a permit modification; waived conditions have been formally exempted by the regulatory agency.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the permit condition by its regulatory function. Effluent limits define numeric discharge thresholds; monitoring frequency specifies how often sampling must occur; reporting requirements define submission deadlines; operational restrictions constrain facility activities; BMP conditions require specific management practices; narrative standards define qualitative requirements.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceCount rdf:type rdf:Property ;
    rdfs:label 'Exceedance Count' ;
    rdfs:comment 'The cumulative number of times this permit condition limit has been exceeded during the current permit term. Tracks violation history for regulatory reporting, enforcement risk assessment, and permit renewal negotiations.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isNumericLimit rdf:type rdf:Property ;
    rdfs:label 'Is Numeric Limit' ;
    rdfs:comment 'Indicates whether this permit condition has a quantitative numeric limit value (True) or is a narrative/qualitative condition without a numeric threshold (False). Determines whether limit_value and limit_unit fields are applicable.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoringDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Date' ;
    rdfs:comment 'The date on which the most recent sampling or monitoring event was conducted for this permit condition. Used to calculate next due date and assess whether monitoring is current.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Date' ;
    rdfs:comment 'The date of the most recent regulatory report submission covering this permit condition. Used to confirm reporting currency and identify overdue submissions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportedValue rdf:type rdf:Property ;
    rdfs:label 'Last Reported Value' ;
    rdfs:comment 'The most recently measured or reported value for the monitored parameter under this condition. Enables quick comparison against the limit value to assess current compliance without querying the monitoring results table.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Specifies the averaging or aggregation period for the numeric limit value (e.g., daily maximum, monthly average, weekly average, instantaneous maximum, annual load). Determines how measured values are compared against the regulatory threshold.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitUnit rdf:type rdf:Property ;
    rdfs:label 'Limit Unit' ;
    rdfs:comment 'The unit of measurement for the limit value (e.g., mg/L, lbs/day, kg/year, CFU/100mL, pH units, MGD — million gallons per day). Must align with the unit used in sampling and reporting to ensure valid compliance comparison.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'The numeric threshold value that must not be exceeded (or must be met) for this permit condition. Represents the regulatory limit for the monitored parameter (e.g., 10.0 mg/L for total nitrogen). Null for non-numeric narrative conditions.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeConditionText rdf:type rdf:Property ;
    rdfs:label 'Narrative Condition Text' ;
    rdfs:comment 'The full text of the permit condition as written in the permit document, particularly for narrative or qualitative conditions that cannot be expressed as a numeric limit. Provides the authoritative regulatory language for compliance interpretation.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMonitoringDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Due Date' ;
    rdfs:comment 'The calculated or scheduled date by which the next monitoring or sampling event must be completed for this condition. Drives compliance calendar scheduling and field operations planning.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDeadlineDay rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Day' ;
    rdfs:comment 'The day of the month by which the monitoring report or discharge monitoring report (DMR) must be submitted to the regulatory agency (e.g., 28 = 28th of the month following the monitoring period). Used to generate compliance calendar alerts.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The required frequency for submitting compliance reports or discharge monitoring reports (DMR) to the regulatory agency. May differ from monitoring frequency (e.g., monitor weekly but report monthly).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingLocation rdf:type rdf:Property ;
    rdfs:label 'Sampling Location' ;
    rdfs:comment 'Description of the designated sampling point or monitoring location as specified in the permit (e.g., \'Outfall 001\', \'Influent to lagoon\', \'Field tile drain at property boundary\'). Corresponds to the outfall or monitoring point identifier in the permit document.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The prescribed analytical or field sampling method required for this condition (e.g., grab sample, 24-hour composite, flow-proportional composite, continuous monitoring). References EPA-approved test methods under 40 CFR Part 136.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The identifier or record reference from the originating operational system of record (e.g., SAP S/4HANA QM module document number, Granular Farm Management compliance record ID) from which this permit condition record was sourced. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Variance Expiry Date' ;
    rdfs:comment 'The date on which any granted variance or compliance schedule for this condition expires, after which the standard limit becomes fully enforceable. Populated only when variance_granted is True.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceGranted rdf:type rdf:Property ;
    rdfs:label 'Variance Granted' ;
    rdfs:comment 'Indicates whether the regulatory agency has granted a formal variance or compliance schedule for this condition, allowing temporary deviation from the standard limit. Variances must be documented for audit purposes.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideUseRecordId rdf:type rdf:Property ;
    rdfs:label 'Pesticide Use Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each pesticide use record (PUR). Serves as the primary key for this regulatory compliance record. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PesticideUseRecord .

ind:agrochemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Agrochemical Product Id' ;
    rdfs:comment 'Foreign key linking to product.agrochemical_product. Business justification: Pesticide use records must reference the registered agrochemical product for MRL compliance verification, PHI/REI enforcement, and state pesticide use reporting. Agriculture regulators require traceab' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgrochemicalProduct .

ind:chemicalComplianceId rdf:type rdf:Property ;
    rdfs:label 'Chemical Compliance Id' ;
    rdfs:comment 'Foreign key linking to procurement.chemical_compliance. Business justification: Pesticide application records must reference the chemical compliance profile (MRL, PHI, REI, restricted-use status) of the product applied. Links application records to procurement\'s chemical_complian' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalCompliance .

ind:fieldParcelId rdf:type rdf:Property ;
    rdfs:label 'Field Parcel Id' ;
    rdfs:comment 'The internal or GIS-based identifier for the field or parcel where the pesticide was applied. Links to the land management system (Esri ArcGIS, Granular, John Deere Operations Center) for spatial compliance reporting and environmental buffer zone verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Foreign key linking to inventory.goods_issue. Business justification: Pesticide use records are created when pesticides are issued from inventory for field application. The goods_issue tracks the inventory dispensing event with phi_compliant and rei_compliant flags. Lin' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:managementZoneId rdf:type rdf:Property ;
    rdfs:label 'Management Zone Id' ;
    rdfs:comment 'Foreign key linking to land.management_zone. Business justification: Variable-rate pesticide applications are tied to management zones. Pesticide use records for precision agriculture must reference the management zone to reconcile application rates with VRA prescripti' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementZone .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to inventory.material_master. Business justification: Pesticide use records reference specific pesticide products tracked in the material master (epa_registration_number, active_ingredient, phi_days, rei_hours). The PUR currently stores pesticide_product' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:researchInputUsageId rdf:type rdf:Property ;
    rdfs:label 'Research Input Usage Id' ;
    rdfs:comment 'Foreign key linking to research.input_usage. Business justification: Research input usage records for pesticide applications are the source events that generate state-mandated pesticide use records. This link enables compliance teams to reconcile regulatory filings aga' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InputUsage .

ind:sprayWindowId rdf:type rdf:Property ;
    rdfs:label 'Spray Window Id' ;
    rdfs:comment 'Foreign key linking to weather.spray_window. Business justification: State pesticide use reporting and EPA records require documenting that application occurred within a compliant spray window (wind, temp, humidity, REI/PHI). Compliance officers and state regulators ex' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SprayWindow .

ind:treatmentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Treatment Application Id' ;
    rdfs:comment 'Foreign key linking to research.treatment_application. Business justification: Each pesticide use record must reference the specific treatment application event in the research trial. This link enables regulatory auditors to verify application rates, timing, equipment, and opera' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentApplication .

ind:treatmentId rdf:type rdf:Property ;
    rdfs:label 'Treatment Id' ;
    rdfs:comment 'Foreign key linking to research.treatment. Business justification: State-mandated pesticide use records must be traceable to the specific research treatment protocol that authorized the application. This link supports PHI/REI compliance verification and EPA/state pes' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Treatment .

ind:trialPlotId rdf:type rdf:Property ;
    rdfs:label 'Trial Plot Id' ;
    rdfs:comment 'Foreign key linking to research.trial_plot. Business justification: State pesticide use records for research trials must identify the specific trial plot treated. This link supports PHI compliance verification (plot-level harvest date tracking), REI enforcement, and r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrialPlot .

ind:vraPrescriptionId rdf:type rdf:Property ;
    rdfs:label 'Vra Prescription Id' ;
    rdfs:comment 'Foreign key linking to crop.vra_prescription. Business justification: State pesticide use reporting and IPM program verification require linking application records to the VRA prescription that authorized variable-rate application. Regulators verify that actual applied ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VraPrescription .

ind:applicationEndTime rdf:type rdf:Property ;
    rdfs:label 'Application End Time' ;
    rdfs:comment 'Precise timestamp when the pesticide application was completed. The REI (Restricted Entry Interval) clock begins at this time. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Application Equipment Type' ;
    rdfs:comment 'Type of equipment used for the pesticide application (e.g., boom sprayer, airblast sprayer, aerial applicator, backpack sprayer, drip system). Relevant for calibration records, drift risk assessment, and equipment compliance documentation.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationMethod rdf:type rdf:Property ;
    rdfs:label 'Application Method' ;
    rdfs:comment 'The method used to apply the pesticide (e.g., ground broadcast, aerial, chemigation, soil injection, spot treatment, band application). Required for PUR submissions and environmental impact assessments. Must be an approved method per the product label.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationRate rdf:type rdf:Property ;
    rdfs:label 'Application Rate' ;
    rdfs:comment 'The quantity of pesticide product applied per unit area (e.g., oz/acre, fl oz/acre, lb/acre, pt/acre) as specified on the label and actually applied. Used to verify label compliance and calculate total quantity applied. Must not exceed label maximum rate.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationRateUnit rdf:type rdf:Property ;
    rdfs:label 'Application Rate Unit' ;
    rdfs:comment 'Unit of measure for the application rate (e.g., oz/acre, fl oz/acre, lb/acre). Must align with the pesticide product label specifications and state PUR reporting requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStartTime rdf:type rdf:Property ;
    rdfs:label 'Application Start Time' ;
    rdfs:comment 'Precise timestamp when the pesticide application began. Used for REI (Restricted Entry Interval) compliance tracking — the REI clock starts at application completion. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicatorCertificationCategory rdf:type rdf:Property ;
    rdfs:label 'Applicator Certification Category' ;
    rdfs:comment 'EPA or state-defined certification category under which the applicator is licensed (e.g., Agricultural Plant, Ornamental and Turf, Right-of-Way, Aquatic). Determines which pesticide use categories the applicator is authorized to perform. [ENUM-REF-CANDIDATE: agricultural_plant|ornamental_turf|right_of_way|aquatic|fumigation|seed_treatment|forest|public_health — promote to reference product]' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicatorName rdf:type rdf:Property ;
    rdfs:label 'Applicator Name' ;
    rdfs:comment 'Full name of the certified or licensed pesticide applicator who performed the application. Required for regulatory PUR submissions and audit readiness. Distinct from the applicator license number.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaTreated rdf:type rdf:Property ;
    rdfs:label 'Area Treated' ;
    rdfs:comment 'Total land area treated during this pesticide application, expressed in acres. Required for PUR submissions and used to verify total quantity applied calculations. May differ from total field area if only a portion was treated.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropGrowthStage rdf:type rdf:Property ;
    rdfs:label 'Crop Growth Stage' ;
    rdfs:comment 'The growth stage of the crop at the time of pesticide application (e.g., V4, R1, pre-emergence, post-emergence, flowering). Critical for PHI compliance calculations and label-compliance verification, as some products have growth-stage restrictions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropTreated rdf:type rdf:Property ;
    rdfs:label 'Crop Treated' ;
    rdfs:comment 'The crop or commodity to which the pesticide was applied (e.g., corn, soybeans, wheat, tomatoes). Must be an approved use site listed on the EPA-registered product label. Required for MRL compliance and state PUR reporting.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideType rdf:type rdf:Property ;
    rdfs:label 'Pesticide Type' ;
    rdfs:comment 'Classification of the pesticide by its primary mode of action or target pest category. Used for IPM (Integrated Pest Management) reporting, environmental compliance, and regulatory categorization.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Compliant Flag' ;
    rdfs:comment 'Indicates whether the pesticide application complies with the Pre-Harvest Interval (PHI) requirement on the product label, based on the application date and planned harvest date. True = PHI compliance confirmed; False = PHI violation detected. Critical for food safety and MRL compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purNumber rdf:type rdf:Property ;
    rdfs:label 'Pur Number' ;
    rdfs:comment 'Externally-known business identifier for this pesticide use record, used in regulatory submissions and audit trails. May be assigned by the state department of agriculture or generated internally per FMIS convention.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the pesticide use record within the regulatory reporting workflow. \'draft\' indicates in-progress entry; \'submitted\' indicates filed with the regulatory authority; \'accepted\' indicates confirmed by the authority; \'rejected\' indicates returned for correction; \'amended\' indicates a corrected resubmission.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rei Compliant Flag' ;
    rdfs:comment 'Indicates whether the REI (Restricted Entry Interval) was observed following this pesticide application. True = REI compliance confirmed (no workers entered the treated area before the REI expired); False = REI violation detected. Critical for worker safety compliance under EPA WPS.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingState rdf:type rdf:Property ;
    rdfs:label 'Reporting State' ;
    rdfs:comment 'Two-letter US state abbreviation for the state in which the pesticide application occurred and to which the PUR must be reported. Determines applicable state-specific reporting requirements and deadlines.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Use Flag' ;
    rdfs:comment 'Indicates whether the pesticide product is classified as a Restricted Use Pesticide (RUP) by the EPA. RUPs may only be purchased and applied by certified applicators. True = RUP; False = general use pesticide. Critical for applicator license validation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateReportingCode rdf:type rdf:Property ;
    rdfs:label 'State Reporting Code' ;
    rdfs:comment 'State-specific code or identifier required for pesticide use reporting to the state department of agriculture (e.g., California DPR county code, Florida DACS site code). Varies by state and is required for state-level PUR submissions.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPest rdf:type rdf:Property ;
    rdfs:label 'Target Pest' ;
    rdfs:comment 'The specific pest, disease, or weed targeted by this pesticide application (e.g., corn rootworm, powdery mildew, Palmer amaranth). Must be an approved use listed on the EPA-registered product label. Required for IPM (Integrated Pest Management) program documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityApplied rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Applied' ;
    rdfs:comment 'Total amount of pesticide product applied during this application event, expressed in the unit defined by total_quantity_unit. Calculated as application rate × area treated. Required for state PUR submissions and inventory reconciliation.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Unit' ;
    rdfs:comment 'Unit of measure for the total quantity of pesticide product applied (e.g., oz, fl oz, lb, gal). Must be consistent with the application rate unit and product label.' ;
    rdfs:domain ind:PesticideUseRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Unique system-generated identifier for the recall event record. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:masterId rdf:type rdf:Property ;
    rdfs:label 'Master Id' ;
    rdfs:comment 'Reference to the master product record for the recalled agricultural commodity, processed food, or livestock product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: A recall event is typically triggered by a quality nonconformance (MRL exceedance, food safety incident, microbial contamination). Compliance officers and quality managers must trace the originating n' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:salesContractId rdf:type rdf:Property ;
    rdfs:label 'Sales Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.contract. Business justification: Recall events affecting contracted supply require contract-level notification, force majeure assessment, and financial impact calculation. Linking recall events to the sales contract enables contract ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:consigneeCount rdf:type rdf:Property ;
    rdfs:label 'Consignee Count' ;
    rdfs:comment 'Total number of consignees (direct customers, distributors, retailers) who received the recalled product and must be notified. Used to track notification completeness and recall effectiveness.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consigneeNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Consignee Notification Status' ;
    rdfs:comment 'Status of direct notification to all consignees (distributors, retailers, food service operators) who received the recalled product. Tracks whether all downstream recipients have been contacted per FDA/FSIS requirements.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date on which the recalled product disposition (destruction, reconditioning, return) was completed and verified.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Geographic scope of product distribution affected by the recall — Nationwide, Regional, State-level, Local, International, or Export Only. Determines the breadth of consumer notification and consignee outreach required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStates rdf:type rdf:Property ;
    rdfs:label 'Distribution States' ;
    rdfs:comment 'Comma-separated list of US state codes (2-letter USPS abbreviations) or country codes (ISO 3166-1 alpha-3) where the recalled product was distributed. Supports targeted consignee notification and regulatory reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date on which the most recent recall effectiveness check was conducted by FDA, FSIS, or the recalling firm.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Result of the FDA/FSIS recall effectiveness check — assessment of whether the recall communication reached all affected consignees and whether recalled product has been removed from commerce. Satisfactory result is required for recall closure.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the recall event in US dollars, including product write-off value, logistics costs, regulatory fees, and operational disruption. Used for financial reporting (GAAP/IFRS), insurance claims, and CAPEX/OPEX impact analysis.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdaNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Fda Notification Date' ;
    rdfs:comment 'Date on which the FDA was formally notified of the recall event. Required for FDA-regulated products under 21 CFR Part 7 and FSMA Section 423 mandatory recall provisions.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Notification Status' ;
    rdfs:comment 'Current status of FDA notification for this recall event — Pending (not yet submitted), Notified (submitted to FDA), Acknowledged (FDA confirmed receipt), or Not Required (product not under FDA jurisdiction).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsisNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Fsis Notification Date' ;
    rdfs:comment 'Date on which USDA FSIS was formally notified of the recall event. Required for meat, poultry, and egg products regulated under FSIS jurisdiction.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsisNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fsis Notification Status' ;
    rdfs:comment 'Current status of USDA FSIS notification for this recall event — Pending, Notified, Acknowledged, or Not Required (product not under FSIS jurisdiction).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed narrative describing the specific hazard or defect that triggered the recall, including pathogen strain, chemical name, allergen type, or foreign material description as applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Category of food safety hazard that prompted the recall — biological (e.g., Salmonella, Listeria), chemical (e.g., pesticide residue exceeding MRL, mycotoxin), physical (e.g., foreign material), allergen (undeclared allergen), or radiological contamination.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingTrigger rdf:type rdf:Property ;
    rdfs:label 'Initiating Trigger' ;
    rdfs:comment 'Root cause or triggering event that initiated the recall — e.g., consumer complaint, laboratory test result (pathogen, pesticide MRL exceedance), regulatory directive, or internal audit finding. [ENUM-REF-CANDIDATE: Consumer Complaint|Laboratory Result|Regulatory Directive|Internal Audit|Supplier Notification|Adverse Event Report|Routine Inspection — promote to reference product]' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed' ;
    rdfs:comment 'Indicates whether a product recall insurance claim has been filed with the insurer for this recall event.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumbers rdf:type rdf:Property ;
    rdfs:label 'Lot Numbers' ;
    rdfs:comment 'Comma-separated list of lot/batch numbers (LOT) subject to this recall. Lot numbers are the primary traceability identifiers linking production batches to distribution records and consumer products.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the recall was formally initiated and first notifications were issued to consignees, distributors, and/or the public. This is the principal business event date for the recall lifecycle.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'Date on which the public press release was issued for this recall event. Null if no press release has been issued.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseIssued rdf:type rdf:Property ;
    rdfs:label 'Press Release Issued' ;
    rdfs:comment 'Indicates whether a public press release has been issued for this recall event. Class I recalls typically require public press releases; Class II and III may or may not depending on regulatory guidance.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'Final disposition method for the recalled product — Destruction (product destroyed under regulatory supervision), Reconditioning (product reworked to meet safety standards), Return to Supplier, Diversion (redirected to non-food use), or Pending (disposition not yet determined).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRecalled rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled' ;
    rdfs:comment 'Total quantity of product subject to recall, expressed in the unit of measure specified in quantity_uom. Includes all affected lots across all distribution channels.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered' ;
    rdfs:comment 'Total quantity of recalled product that has been physically recovered or accounted for through returns, destruction, or reconditioning as of the last effectiveness check. Used to calculate recall effectiveness rate.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the recalled quantity — e.g., LB (pounds), KG (kilograms), MT (metric ton), CWT (hundredweight), BU (bushel), CS (cases), EA (each), GAL (gallons). [ENUM-REF-CANDIDATE: LB|KG|MT|CWT|BU|CS|EA|GAL|L — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA/USDA FSIS classification indicating the health hazard severity: Class I — reasonable probability of serious adverse health consequences or death; Class II — remote probability of adverse health consequences; Class III — unlikely to cause adverse health consequences.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClosureDate rdf:type rdf:Property ;
    rdfs:label 'Recall Closure Date' ;
    rdfs:comment 'Date on which the recall was formally closed by the regulatory authority (FDA or USDA FSIS) following satisfactory effectiveness checks and completion of all required corrective actions.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Externally assigned recall identifier issued by FDA or USDA FSIS (e.g., FDA recall number or FSIS recall case number). Used for cross-referencing with regulatory agency records and public announcements.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event, tracking progression from initiation through effectiveness checks to formal closure or termination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Indicates whether the recall was initiated voluntarily by the firm, mandated by a regulatory authority (FDA/USDA FSIS), or classified as a market withdrawal or stock recovery action.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recalledProductName rdf:type rdf:Property ;
    rdfs:label 'Recalled Product Name' ;
    rdfs:comment 'Commercial name of the product subject to recall as it appears on the product label and in regulatory notifications. May differ from the internal product master name.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCodes rdf:type rdf:Property ;
    rdfs:label 'Upc Codes' ;
    rdfs:comment 'Comma-separated list of Universal Product Codes (UPC) or Price Look-Up (PLU) codes associated with the recalled product SKUs, used for consumer-facing identification and retail point-of-sale removal.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallLotId rdf:type rdf:Property ;
    rdfs:label 'Recall Lot Id' ;
    rdfs:comment 'Unique system-generated identifier for each recall lot association record linking a specific commodity or product lot to an active recall event.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallLot .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Recall lots are distributed to customer accounts (consignee_name is currently denormalized on recall_lot). Linking recall_lot to customer account enables customer notification tracking, recall effecti' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Foreign key linking to product.commodity. Business justification: Recall lots must be linked to the commodity master for USDA/FDA commodity-level recall scope determination, MRL exceedance analysis, and FSMA traceability reporting. commodity_code is a denormalized r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:commodityLotId rdf:type rdf:Property ;
    rdfs:label 'Commodity Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.commodity_lot. Business justification: Recall lots must be precisely linked to inventory commodity lots for lot-level recall execution and effectiveness checks. Currently recall_lot only has lot_number as plain text and stock_position_id. ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityLot .

ind:deliveryLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Id' ;
    rdfs:comment 'Foreign key linking to customer.delivery_location. Business justification: Recalled lots are shipped to specific customer delivery locations. Linking recall_lot to delivery_location enables precise recall effectiveness checks, customer notification at the receiving location ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryLocation .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to sales.order_line. Business justification: Recall lots must identify the specific sales order lines that distributed affected product to customers. recall_lot has po_number and bol_number but no direct order_line_id. This link enables rapid cu' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Reference to the specific inventory position or stock record in the warehouse management system (Manhattan Associates WMS) for this recalled lot, enabling precise stock location and quantity reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading (BOL) number associated with the shipment of this recalled lot. Provides the logistics traceability link between the lot and its transportation record for recall scope determination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'Reference number or document identifier for the Certificate of Analysis (COA) associated with this lot. The COA documents quality test results at time of production or receipt and is critical for root cause analysis during a recall.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country of origin of the recalled lot. Required for Country of Origin Labeling (COOL) compliance and cross-border trade recall notifications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which the customer or consignee who received this recalled lot was formally notified of the recall. Required for FDA/FSIS effectiveness check documentation.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Status of customer or consignee notification for this specific recalled lot. Tracks whether the downstream customer who received this lot has been notified of the recall. Values: not_required, pending, notified, acknowledged, unresponsive.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current disposition status of the recalled lot indicating the physical and regulatory state of the product. Values: quarantined (physically isolated), returned (sent back to supplier/manufacturer), destroyed (disposed of), reconditioned (reworked to meet standards), cleared (confirmed safe and released), pending_review (awaiting disposition decision).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The distribution channel through which this recalled lot was sold or transferred. Determines the notification strategy and regulatory reporting requirements for the recall action.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Status' ;
    rdfs:comment 'Status of the FDA or FSIS effectiveness check for this specific recalled lot. Tracks whether the regulatory agency has verified that the recall notification reached the consignee and that the product has been appropriately handled.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grnNumber rdf:type rdf:Property ;
    rdfs:label 'Grn Number' ;
    rdfs:comment 'Goods Receipt Note (GRN) number from SAP S/4HANA MM documenting the receipt of this lot into inventory. Provides the inbound traceability anchor for recalled lots sourced from external suppliers.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNotes rdf:type rdf:Property ;
    rdfs:label 'Lot Notes' ;
    rdfs:comment 'Free-text field for additional observations, special handling instructions, or regulatory notes specific to this recalled lot. May include reconditioning instructions, destruction method details, or consignee-specific circumstances.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRecoveryConfirmed rdf:type rdf:Property ;
    rdfs:label 'Lot Recovery Confirmed' ;
    rdfs:comment 'Indicates whether the physical recovery or disposition of this recalled lot has been confirmed and verified. True when recovery is complete and documented; False when recovery is still in progress or unconfirmed. Used in FDA/FSIS effectiveness check reporting.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Exceedance Flag' ;
    rdfs:comment 'Indicates whether the recall for this lot was triggered by a Maximum Residue Limit (MRL) exceedance for pesticide active ingredients (AI). True when MRL exceedance is confirmed; False otherwise. Relevant for EPA and FDA pesticide residue compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertified rdf:type rdf:Property ;
    rdfs:label 'Organic Certified' ;
    rdfs:comment 'Indicates whether this recalled lot was certified under the USDA National Organic Program (NOP) at time of production or sale. Relevant for determining applicable organic certification implications and NOP reporting requirements during the recall.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase Order (PO) number under which this lot was procured or sold. Links the recalled lot to procurement or sales transaction records in SAP S/4HANA MM/SD for financial impact assessment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'The date on which the recalled lot was manufactured, processed, or packed. Critical for determining the scope of the recall and identifying other potentially affected lots from the same production run.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Total quantity of product in this lot that is subject to the recall. Expressed in the unit of measure specified in quantity_uom. Used for FDA/FSIS effectiveness check reporting and recovery tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine Date' ;
    rdfs:comment 'Date on which this lot was physically quarantined or placed on hold following identification as part of the recall scope. Establishes the start of the lot-level recall action timeline.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Confirmation Date' ;
    rdfs:comment 'Date on which lot recovery was confirmed and verified by the responsible compliance officer or regulatory authority. Populated when lot_recovery_confirmed is True.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date on which this lot was shipped or transferred to the consignee or distribution point. Used to establish the distribution timeline and scope of the recall for FDA/FSIS traceability reporting.' ;
    rdfs:domain ind:RecallLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse or storage location code (bin, aisle, zone, or cold storage unit) where the recalled lot is physically held. Sourced from Manhattan Associates WMS or SAP MM storage location master. Enables rapid physical quarantine.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'Universal Product Code (UPC) or Global Trade Item Number (GTIN) associated with the recalled lot, used for consumer-facing identification and retail notification during the recall.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyRegulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Regulatory Agency Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent regulatory agency when this agency is a sub-agency or division (e.g., FSIS and APHIS are sub-agencies of USDA). Null for top-level agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:acronym rdf:type rdf:Property ;
    rdfs:label 'Acronym' ;
    rdfs:comment 'Commonly used abbreviation or acronym for the regulatory agency (e.g., USDA, FDA, EPA, FSIS, APHIS, OSHA). Used in compliance records, reports, and cross-referencing across all compliance products.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Full official legal name of the regulatory agency or governing body (e.g., United States Department of Agriculture, Food and Drug Administration).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational status of the regulatory agency record. Indicates whether the agency is actively issuing regulations and conducting oversight relevant to agricultural operations.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency by its organizational nature. Distinguishes between governmental regulatory bodies (USDA, FDA, EPA), third-party certification bodies (SQF, BRC, GLOBALG.A.P.), international standards bodies (Codex Alimentarius, ISO), and industry associations.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Commodity Types' ;
    rdfs:comment 'Comma-separated list of agricultural commodity categories over which this agency has regulatory jurisdiction (e.g., grains, livestock, poultry, produce, dairy, pesticides, fertilizers). Supports scoping of compliance obligations to relevant operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfrTitles rdf:type rdf:Property ;
    rdfs:label 'Cfr Titles' ;
    rdfs:comment 'Comma-separated list of applicable Code of Federal Regulations (CFR) title numbers that this agency administers and enforces relevant to agricultural operations (e.g., \'7,9,21,40\' for USDA/FDA/EPA-related titles). Supports regulatory citation mapping across compliance records.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number assigned to the regulatory agency. Used for federal grant and contract identification, SAM.gov registration verification, and cross-system agency identity resolution.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has direct enforcement authority including the power to issue citations, levy penalties, suspend operations, or initiate legal proceedings against the agricultural enterprise. Distinguishes enforcement agencies from advisory or certification bodies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Program Flag' ;
    rdfs:comment 'Indicates whether this agency administers environmental compliance programs applicable to agricultural operations, including Clean Water Act (NPDES/CAFO permits), Clean Air Act, RCRA hazardous waste, and ISO 14001 environmental management system requirements.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Covered Flag' ;
    rdfs:comment 'Indicates whether this agency administers or enforces requirements under the Food Safety Modernization Act (FSMA). Used to scope FSMA compliance obligations, Preventive Controls, Produce Safety Rule, and FSVP requirements to the correct agency.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has authority to conduct on-site inspections of agricultural facilities, fields, processing plants, or storage operations. Drives inspection scheduling and audit readiness protocols.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalBodyCode rdf:type rdf:Property ;
    rdfs:label 'International Body Code' ;
    rdfs:comment 'Standardized code assigned by an international standards organization or treaty body to identify this agency (e.g., CODEX for Codex Alimentarius Commission, IPPC for International Plant Protection Convention, ISO for International Organization for Standardization). Null for domestic-only agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Level of governmental or regulatory jurisdiction exercised by the agency. Determines the geographic and legal scope of the agency\'s authority over agricultural operations (e.g., federal for USDA/FDA/EPA, state for state departments of agriculture, international for CODEX/IPPC).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the official mailing address for the regulatory agency\'s primary office. Used for formal written correspondence, permit applications, and regulatory filings.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City of the regulatory agency\'s official mailing address.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the regulatory agency\'s official mailing address.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateCode rdf:type rdf:Property ;
    rdfs:label 'Mailing State Code' ;
    rdfs:comment 'Two-letter US state or territory code for the regulatory agency\'s official mailing address.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Program Flag' ;
    rdfs:comment 'Indicates whether this agency administers or accredits organic certification programs under the USDA National Organic Program (NOP). Used to link organic certification compliance obligations and audit requirements to the correct agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAuthorityMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Penalty Authority Max Usd' ;
    rdfs:comment 'Maximum monetary penalty per violation that this agency is authorized to levy against the enterprise under applicable statutes. Used in risk assessment, compliance prioritization, and financial exposure modeling for non-compliance scenarios.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitIssuingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Issuing Authority Flag' ;
    rdfs:comment 'Indicates whether this agency issues permits, licenses, or certifications required for agricultural operations (e.g., pesticide applicator licenses, NPDES discharge permits, organic certification, CAFO permits). Links to compliance.permit and compliance.license products.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Pesticide Program Flag' ;
    rdfs:comment 'Indicates whether this agency administers pesticide registration, Maximum Residue Limit (MRL) enforcement, applicator licensing, or Restricted Entry Interval (REI) / Pre-Harvest Interval (PHI) compliance programs. Relevant for EPA, state departments of agriculture, and APHIS.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Official web portal URL for the regulatory agency where compliance submissions, permit applications, license renewals, and regulatory filings are submitted electronically (e.g., USDA eAuthentication portal, FDA FURLS, EPA CDX).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Official email address for the primary regulatory agency contact. Used for compliance submissions, audit notifications, and regulatory correspondence.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary point of contact at the regulatory agency for the agricultural enterprise\'s compliance team. Used for correspondence, audit scheduling, and regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Official phone number for the primary regulatory agency contact. Used for urgent compliance communications, inspection scheduling, and regulatory inquiries.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Official job title or role of the primary contact at the regulatory agency (e.g., District Compliance Officer, Regional Director, Inspection Supervisor).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNotes rdf:type rdf:Property ;
    rdfs:label 'Record Notes' ;
    rdfs:comment 'Free-text field for compliance team annotations regarding this regulatory agency, including relationship history, special filing instructions, known inspection patterns, or recent regulatory changes affecting the enterprise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'Primary area of regulatory authority exercised by the agency over agricultural enterprise operations. Drives routing of compliance obligations, permits, and licenses to the correct agency. [ENUM-REF-CANDIDATE: food_safety|environmental|labor|trade|animal_health|plant_health|financial|organic_certification|pesticide — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProgramCodes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Codes' ;
    rdfs:comment 'Comma-separated list of specific regulatory program codes or identifiers administered by this agency that are applicable to the enterprise\'s operations (e.g., NOP for National Organic Program, HACCP for Hazard Analysis Critical Control Points, FSMA for Food Safety Modernization Act, GAP for Good Agricultural Practices).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Reporting Submission Method' ;
    rdfs:comment 'Preferred or required method for submitting regulatory reports, filings, and compliance documentation to this agency. Drives workflow configuration in the compliance calendar and submission management processes.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Sam Registration Status' ;
    rdfs:comment 'Registration status of the agency in the US federal System for Award Management (SAM.gov). Relevant for agencies involved in federal grant programs, cooperative agreements, and USDA Farm Service Agency (FSA) program administration.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state or territory code for state-level agencies (e.g., CA for California Department of Food and Agriculture, TX for Texas Department of Agriculture). Null for federal or international agencies.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Affected Jurisdictions' ;
    rdfs:comment 'Comma-separated list of geographic jurisdictions (federal, state, or international) where this regulatory change applies (e.g., \'Federal,CA,TX\' or \'Federal\' or \'EU,USA\'). Supports multi-jurisdiction compliance tracking.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectsCropOperations rdf:type rdf:Property ;
    rdfs:label 'Affects Crop Operations' ;
    rdfs:comment 'Indicates whether this regulatory change impacts crop cultivation, planting, protection, harvesting, or post-harvest handling operations. Used to filter and route changes to the crop management compliance team.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsExportOperations rdf:type rdf:Property ;
    rdfs:label 'Affects Export Operations' ;
    rdfs:comment 'Indicates whether this regulatory change impacts cross-border trade, export documentation, phytosanitary certificates, or international market access requirements. Used to route changes to the trade compliance team.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsLivestockOperations rdf:type rdf:Property ;
    rdfs:label 'Affects Livestock Operations' ;
    rdfs:comment 'Indicates whether this regulatory change impacts livestock breeding, animal husbandry, feed management, or veterinary practices. Used to route changes to the livestock compliance team.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsProcessingOperations rdf:type rdf:Property ;
    rdfs:label 'Affects Processing Operations' ;
    rdfs:comment 'Indicates whether this regulatory change impacts food processing, packaging, labeling, or manufacturing operations. Used to route changes to the food safety and processing compliance team.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or employee identifier of the internal regulatory affairs professional assigned as the primary owner responsible for managing the enterprise response to this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Department' ;
    rdfs:comment 'Business department or functional unit of the assigned regulatory affairs owner (e.g., \'Regulatory Affairs\', \'Food Safety & Quality\', \'Environmental Compliance\', \'Trade Compliance\').' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Reference Number' ;
    rdfs:comment 'Externally-known reference number or docket number assigned by the issuing regulatory body (e.g., Federal Register docket number, EPA rule number, USDA APHIS docket ID). Serves as the primary cross-reference to official regulatory publications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the type of regulatory change being tracked. \'new_rule\' = entirely new regulation; \'amendment\' = modification to existing rule; \'repeal\' = removal of existing rule; \'guidance_update\' = non-binding guidance document update; \'interim_rule\' = temporary rule pending final rulemaking; \'proposed_rule\' = rule open for public comment.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentPeriodDeadline rdf:type rdf:Property ;
    rdfs:label 'Comment Period Deadline' ;
    rdfs:comment 'Deadline date for submitting public comments on a proposed or interim rule. Applicable when change_type is \'proposed_rule\' or \'interim_rule\'. Null for final rules.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The specific date by which the enterprise must achieve full compliance with the regulatory change. May differ from the effective date when phased compliance schedules or small-entity exemptions apply (e.g., FSMA tiered compliance dates).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated compliance cost (e.g., \'USD\', \'EUR\', \'CAD\'). Supports multi-currency reporting for international operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'Estimated total cost (in USD) for the enterprise to achieve compliance with this regulatory change, including capital expenditures (CAPEX), operational expenditures (OPEX), training, consulting, and system modification costs.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalRegisterCitation rdf:type rdf:Property ;
    rdfs:label 'Federal Register Citation' ;
    rdfs:comment 'Official Federal Register or state register citation for the regulatory change publication (e.g., \'88 FR 12345\', \'Vol. 88, No. 45, p. 12345\'). Enables direct traceability to the source regulatory document.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRuleReference rdf:type rdf:Property ;
    rdfs:label 'Fsma Rule Reference' ;
    rdfs:comment 'Specific FSMA rule or subpart reference if this regulatory change is related to the Food Safety Modernization Act framework (e.g., \'Produce Safety Rule\', \'Preventive Controls for Human Food\', \'Foreign Supplier Verification Program\').' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoLabelingImpact rdf:type rdf:Property ;
    rdfs:label 'Gmo Labeling Impact' ;
    rdfs:comment 'Indicates whether this regulatory change affects Genetically Modified Organism (GMO) disclosure or labeling requirements under the National Bioengineered Food Disclosure Standard or equivalent regulations.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Assessed severity of the regulatory change\'s impact on enterprise operations. \'critical\' = immediate operational halt risk or major capital investment required; \'high\' = significant process changes required; \'medium\' = moderate process adjustments; \'low\' = minor documentation or administrative updates.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Summary' ;
    rdfs:comment 'Narrative summary of the assessed business impact of the regulatory change on agricultural operations, including affected processes, required operational changes, estimated compliance costs, and risk exposure if non-compliant.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCommentSubmitted rdf:type rdf:Property ;
    rdfs:label 'Internal Comment Submitted' ;
    rdfs:comment 'Indicates whether the enterprise has submitted formal public comments during the comment period for a proposed or interim rule. Supports tracking of regulatory engagement activities.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlImpact rdf:type rdf:Property ;
    rdfs:label 'Mrl Impact' ;
    rdfs:comment 'Indicates whether this regulatory change modifies Maximum Residue Limits (MRL) for pesticides or other agricultural chemicals on food commodities. Triggers review of pesticide application programs and pre-harvest intervals (PHI).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertificationImpact rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Impact' ;
    rdfs:comment 'Indicates whether this regulatory change affects USDA National Organic Program (NOP) certification requirements, allowed/prohibited substances lists, or organic handling standards.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Amount' ;
    rdfs:comment 'Estimated maximum financial penalty or fine exposure (in the cost_currency) if the enterprise fails to comply with this regulatory change by the compliance deadline. Used for risk quantification and prioritization.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Permit License Required' ;
    rdfs:comment 'Indicates whether this regulatory change requires the enterprise to obtain new permits, licenses, or certifications (e.g., pesticide applicator license, environmental discharge permit, food facility registration update).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiReiImpact rdf:type rdf:Property ;
    rdfs:label 'Phi Rei Impact' ;
    rdfs:comment 'Indicates whether this regulatory change modifies Pre-Harvest Interval (PHI) or Restricted Entry Interval (REI) requirements for pesticide applications. Triggers updates to crop protection schedules and worker safety protocols.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date the regulatory change was officially published in the Federal Register, state register, or equivalent official publication. Marks the start of the compliance awareness timeline.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationCode rdf:type rdf:Property ;
    rdfs:label 'Regulation Code' ;
    rdfs:comment 'Standardized code or citation for the regulation (e.g., CFR title and part reference such as \'21 CFR Part 112\', \'40 CFR Part 180\', \'7 CFR Part 205\'). Used for precise regulatory cross-referencing.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'Official name or title of the regulation, rule, or guidance document being changed or introduced (e.g., \'FSMA Produce Safety Rule\', \'FIFRA Pesticide Registration Amendment\', \'USDA National Organic Program Update\').' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredResponseActions rdf:type rdf:Property ;
    rdfs:label 'Required Response Actions' ;
    rdfs:comment 'Narrative description of the specific internal actions required to achieve compliance with this regulatory change (e.g., SOP updates, training programs, system configuration changes, permit applications, label revisions, capital investments).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Internal deadline by which the enterprise must complete its response actions (e.g., SOP updates, training, system changes). May be set earlier than the regulatory compliance_deadline to allow buffer time for implementation and verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current internal workflow status of the regulatory change review process. Tracks the enterprise\'s progress from initial identification through impact assessment, response planning, implementation, and closure. [ENUM-REF-CANDIDATE: identified|under_review|impact_assessed|response_planned|implemented|closed|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Sop Update Required' ;
    rdfs:comment 'Indicates whether existing Standard Operating Procedures (SOPs) must be revised or new SOPs created to comply with this regulatory change. Triggers document control workflow.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Source Document Url' ;
    rdfs:comment 'URL or hyperlink to the official source document for this regulatory change (e.g., Federal Register online entry, EPA docket, USDA regulatory publication, state agriculture department website). Enables direct access to the authoritative source.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether employee training programs must be developed or updated as part of the compliance response to this regulatory change. Triggers workforce development planning in SAP SuccessFactors.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendedFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory_filing_id that this record amends or supersedes. Populated only when is_amendment is True. Enables a complete amendment chain for audit defense and regulatory correspondence tracking.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the employee who reviewed and approved the filing prior to submission. Enforces segregation of duties required under SOX internal controls and FSMA qualified individual requirements. Links to SAP SuccessFactors workforce records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:carbonFootprintId rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_footprint. Business justification: EPA GHGRP and state GHG regulatory filings are directly sourced from carbon footprint assessments. The regulatory_filing records the submission; carbon_footprint is the underlying assessment. Named pr' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonFootprint .

ind:droughtIndexId rdf:type rdf:Property ;
    rdfs:label 'Drought Index Id' ;
    rdfs:comment 'Foreign key linking to weather.drought_index. Business justification: USDA drought disaster declarations, state water use curtailment filings, and crop insurance certification filings require documented drought index values as supporting evidence. A compliance officer p' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DroughtIndex .

ind:primaryRegulatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor responsible for preparing and compiling the regulatory filing. Links to the workforce management system (SAP SuccessFactors) for accountability and audit trail purposes. Required for FSMA PCQI (Preventive Controls Qualified Individual) traceability.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Number' ;
    rdfs:comment 'Confirmation or acknowledgment number issued by the governing body upon receipt of the filing (e.g., EPA CDX submission confirmation ID, USDA NASS receipt number, FDA ESG acknowledgment code). Serves as proof of receipt and is required for audit defense.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Tracking Number' ;
    rdfs:comment 'Unique tracking or case number assigned by the regulatory agency after review begins, distinct from the initial acknowledgment number. Used to follow up on filing status, respond to agency inquiries, and reference in correspondence (e.g., EPA enforcement case number, FSIS inspection reference).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who approved the regulatory filing for submission. Denormalized for regulatory documentation where the approver\'s name must appear on the filing (e.g., OSHA 300A certifying executive, FSMA food safety plan owner, FSIS HACCP plan responsible official).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Free-text narrative description of the scope, content, and purpose of this regulatory filing. Provides context for compliance staff and auditors beyond the structured classification fields (e.g., \'Annual OSHA 300A summary for grain elevator operations at Ames facility covering calendar year 2024\').' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFrequency rdf:type rdf:Property ;
    rdfs:label 'Filing Frequency' ;
    rdfs:comment 'Recurrence schedule for this type of regulatory filing as mandated by the governing body. Used to auto-generate future filing records in the compliance calendar and to track recurring obligations (e.g., annual OSHA 300 Log, quarterly state pesticide use reports, one-time FSMA food safety plan registration).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Externally-known reference number assigned to this filing, either by the submitting organization or the receiving governing body (e.g., USDA NASS submission ID, EPA Tier II tracking number, FSIS HACCP plan reference). Serves as the primary business identifier for cross-referencing with regulatory agencies.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'End date of the reporting period covered by this regulatory filing (e.g., December 31 for an annual OSHA 300 Log, harvest completion date for USDA NASS crop report). Together with filing_period_start_date defines the full reporting window.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'Start date of the reporting period covered by this regulatory filing (e.g., January 1 for an annual OSHA 300 Log, crop season start for USDA NASS crop report). Defines the temporal scope of the data reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current workflow state of the regulatory filing in its lifecycle. Draft indicates preparation in progress; submitted indicates sent to governing body; accepted indicates approved by agency; rejected indicates returned with deficiencies; under_review indicates agency is evaluating; withdrawn indicates voluntarily recalled by the organization.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory filing by its regulatory program or report category (e.g., USDA NASS Crop Report, EPA Tier II Chemical Inventory, FSIS HACCP Plan Submission, State Pesticide Use Report, FSMA Food Safety Plan, OSHA 300 Log, Phytosanitary Certificate, GLOBALG.A.P. Audit Submission). [ENUM-REF-CANDIDATE: USDA_NASS_CROP_REPORT|EPA_TIER_II|FSIS_HACCP|STATE_PESTICIDE_USE|FSMA_FOOD_SAFETY_PLAN|OSHA_300_LOG|PHYTOSANITARY_CERTIFICATE|GLOBALG.A.P._AUDIT|NOP_ORGANIC_CERT|COOL_REPORT — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing. True when the filing supersedes or corrects an earlier submission to the same governing body for the same period. Used to track filing revision history and regulatory correspondence.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionStateCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Code' ;
    rdfs:comment 'Two-letter US state code for state-level regulatory filings (e.g., IA for Iowa Department of Agriculture pesticide use report, CA for California Department of Food and Agriculture). Null for federal or international filings. Follows USPS state abbreviation standard.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Flag' ;
    rdfs:comment 'Indicates whether this filing carries an elevated risk of regulatory penalty due to late submission, rejection, or identified compliance deficiency. True triggers escalation workflows and legal review. Used in compliance risk dashboards and CAPEX/OPEX planning for potential fines.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Full name of the individual who prepared the regulatory filing. Captured as a denormalized field for audit documentation and regulatory correspondence where the preparer\'s identity must appear on the filing itself (e.g., FSMA food safety plan signatory, OSHA 300A annual summary certifier).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'Calendar or fiscal year to which this regulatory filing applies. Used for year-over-year compliance trend analysis and to organize filings within the compliance calendar (e.g., 2024 OSHA 300 Log, 2024 EPA Tier II report, 2024 USDA NASS crop survey).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryRequirementRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Ref' ;
    rdfs:comment 'Specific regulatory citation, rule, statute, or standard that mandates this filing (e.g., 40 CFR Part 370 for EPA Tier II, 21 CFR Part 117 for FSMA PCQI, 9 CFR Part 417 for FSIS HACCP, 29 CFR 1904 for OSHA 300 Log). Enables traceability from filing to the underlying legal obligation.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Description of the reason provided by the governing body when a filing is rejected or returned for correction. Populated when filing_status is \'rejected\'. Used to drive corrective action workflows and to identify systemic compliance gaps (e.g., missing HACCP critical control point documentation, incomplete pesticide applicator license number).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Deadline by which a corrected or amended filing must be resubmitted to the governing body following a rejection. Populated when filing_status is \'rejected\'. Critical for avoiding enforcement actions, fines, or permit revocations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time at which the filing was electronically or physically submitted to the governing body. Provides audit-grade evidence of timely submission, particularly for electronic portals with time-stamped receipts (e.g., EPA CDX, USDA NASS online portal).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Reference to the parent regulatory inspection record from which this finding was generated. Links the finding to its originating inspection event.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:priorFindingRegulatoryFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Regulatory Finding Id' ;
    rdfs:comment 'Reference to the previous regulatory_finding record that this finding is a recurrence of. Populated when repeat_finding_flag is True, enabling trend analysis and repeat-finding lineage tracking.' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFinding .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the corrective action is past its deadline as of the current date. Calculated field retained in the silver layer for compliance dashboard KPI reporting and escalation workflows. Null if corrective action is not yet due or has been resolved on time.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Functional category classifying the area of non-conformance (e.g., food safety, pesticide application, water quality, record-keeping, labeling, worker safety, environmental compliance, animal welfare, organic certification). [ENUM-REF-CANDIDATE: food_safety|pesticide_application|water_quality|record_keeping|labeling|worker_safety|environmental|animal_welfare|organic_certification|traceability — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCode rdf:type rdf:Property ;
    rdfs:label 'Finding Code' ;
    rdfs:comment 'Standardized regulatory or internal code identifying the specific type of deficiency or non-conformance observed. Sourced from the applicable regulatory agency\'s deficiency code library (e.g., FDA HACCP violation codes, USDA NOP codes, EPA inspection codes).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Timestamp' ;
    rdfs:comment 'Precise date and time when this specific finding was formally identified and recorded during the inspection or audit process.' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Short, human-readable title summarizing the nature of the regulatory finding or deficiency (e.g., \'Inadequate Pesticide Application Records\', \'HACCP Critical Control Point Deviation\').' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified deficiency at the same facility or operation. Repeat findings trigger escalated regulatory scrutiny and are a key KPI for audit readiness programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Actual date on which the corrective action was completed and the finding was resolved by the responsible party. Used to calculate days-to-close and assess timeliness of corrective action.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current workflow state of the finding through its corrective action lifecycle: \'open\' (finding issued, no action taken), \'in_progress\' (corrective action underway), \'resolved\' (corrective action completed by responsible party), \'verified\' (resolution confirmed by inspector or auditor), \'closed\' (formally closed in regulatory system), \'waived\' (formally waived by regulatory authority).' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Risk-based severity level assigned to the finding: \'critical\' (immediate food safety or regulatory risk requiring urgent action), \'major\' (significant non-conformance with regulatory requirements), \'minor\' (low-risk deviation), or \'observation\' (noted for improvement, no formal violation). Aligns with GFSI and GLOBALG.A.P. severity frameworks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardProgram rdf:type rdf:Property ;
    rdfs:label 'Standard Program' ;
    rdfs:comment 'The specific food safety, environmental, or agricultural standard or certification program under which this finding was raised (e.g., HACCP, FSMA Preventive Controls, GLOBALG.A.P., SQF, BRC, NOP Organic, GAP, GMP, ISCC). [ENUM-REF-CANDIDATE: HACCP|FSMA|GLOBALG.A.P.|SQF|BRC|NOP|GAP|GMP|ISCC|ISO_22000 — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Trade Compliance Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each trade compliance record in the system. Primary key for the trade_compliance_record data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeComplianceRecord .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: Certificates of Analysis are mandatory documents for agricultural trade compliance (import/export phytosanitary requirements, MRL compliance, organic certification). Trade compliance officers attach C' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Reference to the complementary customs declaration record in the supply domain. Provides the regulatory compliance dimension alongside the customs filing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsDeclaration .

ind:deforestationRiskId rdf:type rdf:Property ;
    rdfs:label 'Deforestation Risk Id' ;
    rdfs:comment 'Foreign key linking to sustainability.deforestation_risk. Business justification: EUDR trade compliance requires a deforestation risk assessment for each commodity shipment exported to the EU. Trade compliance officers must link each trade record to its supporting deforestation ris' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeforestationRisk .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Export/import trade compliance records (phytosanitary certs, FDA prior notice, APHIS permits) are generated per sales order in ag export operations. Linking enables traceability from commercial order ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:seedLotId rdf:type rdf:Property ;
    rdfs:label 'Seed Lot Id' ;
    rdfs:comment 'Foreign key linking to crop.seed_lot. Business justification: APHIS phytosanitary import permits and CBP entry records for imported seed must reference the specific seed lot. Linking trade_compliance_record to seed_lot enables import compliance traceability, sup' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeedLot .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the associated shipment record in the supply chain domain. Links the compliance record to the physical shipment being regulated.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:aphisPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Number' ;
    rdfs:comment 'USDA APHIS-issued permit number for the import or export of regulated agricultural commodities, plants, animals, or biological materials. Required for APHIS-regulated species and products.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borderEntryDate rdf:type rdf:Property ;
    rdfs:label 'Border Entry Date' ;
    rdfs:comment 'Date on which the shipment arrived at the port of entry or border inspection point. Used to calculate compliance timelines and FDA Prior Notice submission windows.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of regulatory certificate or permit associated with this trade compliance record. Examples include phytosanitary certificate, USDA APHIS export certificate, FDA Prior Notice, CITES permit, health certificate, fumigation certificate, organic certificate, and country-of-origin certificate. [ENUM-REF-CANDIDATE: phytosanitary|aphis_export|fda_prior_notice|cites_permit|health_certificate|fumigation_certificate|organic_certificate|country_of_origin — promote to reference product]' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citesPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Cites Permit Number' ;
    rdfs:comment 'CITES permit number issued for trade in species listed under the Convention on International Trade in Endangered Species of Wild Fauna and Flora. Required for regulated species in agricultural trade (e.g., certain timber, plants, wildlife).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicense rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License' ;
    rdfs:comment 'CBP-issued license number of the customs broker responsible for this trade compliance filing. Required for regulatory accountability and audit trail.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker or freight forwarder engaged to manage the customs clearance and regulatory compliance filing for this shipment.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Declared customs value of the shipment in US dollars, as reported on the customs entry for duty assessment purposes. Used for tariff calculation and trade statistics reporting.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country to which the agricultural commodity is being exported or imported.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePct rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Pct' ;
    rdfs:comment 'Applicable customs duty rate expressed as a percentage of the declared customs value, as determined by the HS code, trade agreement, and country of origin. Used for duty cost calculation and trade agreement benefit tracking.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdaPriorNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Prior Notice Number' ;
    rdfs:comment 'FDA-assigned confirmation number for the Prior Notice filing submitted before importation of food or feed products, as required under FSMA and 21 CFR Part 1. Null for non-food/feed shipments or exports.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed description of the reason for any customs or border inspection hold placed on the shipment. Captures the specific regulatory violation, documentation deficiency, or pest/disease finding that triggered the hold.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date on which a customs or border inspection hold was officially released and the shipment was cleared for entry or export. Null if no hold was placed or if the hold has not yet been resolved.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Type of hold or detention placed on the shipment by a customs or border inspection authority. \'none\' indicates no hold. Used to track compliance issues and resolution timelines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmo rdf:type rdf:Property ;
    rdfs:label 'Is Gmo' ;
    rdfs:comment 'Indicates whether the commodity contains or is derived from genetically modified organisms (GMOs). Relevant for import/export compliance in jurisdictions with GMO labeling or restriction requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicCertified rdf:type rdf:Property ;
    rdfs:label 'Is Organic Certified' ;
    rdfs:comment 'Indicates whether the commodity covered by this trade compliance record is certified organic under the USDA National Organic Program (NOP) or an equivalent foreign organic certification recognized by USDA.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlCompliant rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliant' ;
    rdfs:comment 'Indicates whether the commodity has been verified to comply with the Maximum Residue Limits (MRLs) for pesticide residues as established by the destination country\'s regulatory authority (e.g., EPA, Codex Alimentarius, EU MRL regulations).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the commodity covered by this trade compliance record, expressed in kilograms. Used for customs valuation, duty calculation, and regulatory reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the agricultural commodity was grown, produced, or substantially transformed. Required for Country of Origin Labeling (COOL) compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phytosanitaryCertNumber rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Cert Number' ;
    rdfs:comment 'Official phytosanitary certificate number issued by the national plant protection organization (NPPO) of the exporting country, certifying that plants and plant products meet the phytosanitary requirements of the importing country.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Official CBP or IATA port code identifying the port of entry or exit through which the shipment crosses the border (e.g., \'LAX\', \'2704\' for CBP port codes).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Principal real-world date on which the agricultural commodity was shipped or departed from the origin point. Serves as the primary business event date for this compliance record.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Code' ;
    rdfs:comment 'Code identifying the applicable free trade agreement or preferential trade arrangement governing this shipment (e.g., USMCA, CPTPP, CAFTA-DR). Determines preferential duty rates and certificate-of-origin requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDirection rdf:type rdf:Property ;
    rdfs:label 'Trade Direction' ;
    rdfs:comment 'Indicates whether the shipment is an import into the domestic market, an export to a foreign market, a re-export of previously imported goods, or a transit movement through a country.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationRecordId rdf:type rdf:Property ;
    rdfs:label 'Violation Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each formal regulatory violation record. Primary key for the violation_record data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViolationRecord .

ind:landUseChangeId rdf:type rdf:Property ;
    rdfs:label 'Land Use Change Id' ;
    rdfs:comment 'Foreign key linking to sustainability.land_use_change. Business justification: Unpermitted land use changes (unauthorized wetland conversion, illegal forest clearing) generate regulatory violation records under Clean Water Act Section 404, ESA, and EUDR. Named process: unauthori' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandUseChange .

ind:trialId rdf:type rdf:Property ;
    rdfs:label 'Trial Id' ;
    rdfs:comment 'Foreign key linking to research.trial. Business justification: APHIS/EPA violations arising from GMO containment breaches, pesticide misuse, or protocol deviations in research trials must be traceable to the specific trial. This link supports enforcement action t' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:appealDeadline rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline' ;
    rdfs:comment 'The deadline by which the enterprise must file a formal appeal or contest of the violation with the issuing agency or administrative tribunal. Null if the appeal period has passed or no appeal is applicable. Critical for legal and compliance calendar management.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScheduleDueDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Due Date' ;
    rdfs:comment 'The final deadline by which all compliance schedule milestones must be completed as required by the enforcement action or consent order. Null if no compliance schedule was imposed. Used for compliance calendar management and audit readiness.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScheduleImposed rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Imposed' ;
    rdfs:comment 'Indicates whether a formal compliance schedule was imposed as part of the enforcement action, requiring the enterprise to achieve compliance milestones by specified dates. True if a compliance schedule is in effect; False otherwise.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentOrderReference rdf:type rdf:Property ;
    rdfs:label 'Consent Order Reference' ;
    rdfs:comment 'The reference number or identifier of any consent order, consent decree, or settlement agreement associated with this violation. A consent order is a legally binding agreement between the enterprise and the regulatory agency specifying corrective actions and timelines. Null if no consent order was issued.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contested rdf:type rdf:Property ;
    rdfs:label 'Contested' ;
    rdfs:comment 'Indicates whether the enterprise has formally contested or appealed the violation with the issuing agency or through administrative or judicial proceedings. True if contested; False if accepted. Used for legal case management and regulatory relationship tracking.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'The actual date on which all required corrective actions were completed and verified. Null if corrective actions are still in progress. Used to measure compliance response time and demonstrate regulatory good faith.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Category' ;
    rdfs:comment 'Classification of the environmental medium or resource impacted by the violation (air, water, soil, wildlife, none, or multiple). Used for environmental compliance reporting, EPA program alignment, and sustainability impact assessment.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Final Penalty Amount' ;
    rdfs:comment 'The final agreed or adjudicated monetary penalty amount after negotiation, settlement, consent order, or appeal, expressed in USD. May differ from the proposed penalty amount. Used for financial reporting, OPEX tracking, and regulatory cost analysis.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Food Safety Related' ;
    rdfs:comment 'Indicates whether the violation is related to food safety requirements under FSMA, HACCP, FSIS, or GFSI-recognized standards (SQF, BRC, IFS, GLOBALG.A.P.). True if the violation has food safety implications; False otherwise. Used for FSMA compliance tracking and food safety audit readiness.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Jurisdiction' ;
    rdfs:comment 'Jurisdictional level of the issuing regulatory agency (federal, state, county, or municipal). Determines the applicable legal framework and escalation path for enforcement actions.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Indicates whether internal or external legal counsel has been assigned to manage this violation, enforcement action, or appeal. True if legal counsel is engaged; False otherwise. Used for legal resource planning and case management.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Issued Date' ;
    rdfs:comment 'The date on which the formal Notice of Violation (NOV), citation, or enforcement action was officially issued by the regulatory agency. May differ from the violation date if the agency conducted an investigation prior to issuing the notice.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'The date on which the final penalty payment was made to the regulatory agency. Null if payment has not yet been made. Used for financial reconciliation and compliance documentation.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Status' ;
    rdfs:comment 'Current payment status of the final assessed penalty. Tracks whether the penalty has been paid in full, partially paid, waived by the agency, deferred under a compliance schedule, or remains unpaid. Used for accounts payable reconciliation and regulatory standing reporting.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Penalty Amount' ;
    rdfs:comment 'The initial monetary penalty amount proposed by the regulatory agency at the time of the violation notice or enforcement action, expressed in USD. Represents the agency\'s initial assessment before negotiation, settlement, or appeal. Used for financial exposure tracking and legal strategy.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether the violation or enforcement action requires public disclosure under applicable regulations (e.g., EPA Toxic Release Inventory, USDA public enforcement records, SEC material disclosure requirements for publicly traded entities). True if public disclosure is required; False otherwise.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationCitation rdf:type rdf:Property ;
    rdfs:label 'Regulation Citation' ;
    rdfs:comment 'The specific Code of Federal Regulations (CFR) citation, statute, or regulatory standard that was violated (e.g., 40 CFR Part 122 for NPDES permits, 21 CFR Part 112 for produce safety, 7 CFR Part 205 for organic certification). Enables precise regulatory tracking and legal reference.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationProgram rdf:type rdf:Property ;
    rdfs:label 'Regulation Program' ;
    rdfs:comment 'The regulatory program or framework under which the violation was issued (e.g., FSMA Produce Safety Rule, NPDES Stormwater Program, FIFRA Pesticide Registration, HACCP, NOP Organic Certification, CAFO Permit Program). Supports compliance program-level reporting and trend analysis.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatViolation rdf:type rdf:Property ;
    rdfs:label 'Repeat Violation' ;
    rdfs:comment 'Indicates whether this violation is a repeat occurrence of a previously cited violation at the same facility or operation. True if this is a repeat violation; False if it is a first-time occurrence. Repeat violations typically result in elevated penalties and heightened regulatory scrutiny.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'The date on which the regulatory violation occurred or was observed. This is the principal real-world event date, distinct from the date the notice was issued or the record was created. Used for compliance calendar tracking and statute of limitations calculations.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory violation as documented by the issuing agency or internal compliance team. Includes the specific non-compliant condition, practice, or omission observed. Used for root cause analysis, corrective action planning, and audit documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Externally-assigned unique identifier for the violation as issued by the regulatory agency (e.g., NOV number, citation number, enforcement case number). Used for cross-referencing with agency records and legal correspondence.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the violation record, tracking its progression from issuance through resolution. Valid values: open (newly issued, no action taken), under_review (internal or legal review in progress), contested (formally disputed with the agency), resolved (corrective action accepted by agency), closed (fully resolved and documented), appealed (formal appeal filed).' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Classification of the formal enforcement instrument issued by the regulatory agency. Distinguishes between informal notices (warning letters), administrative citations, consent orders, stop-sale orders, recall orders, and criminal referrals. [ENUM-REF-CANDIDATE: notice_of_violation|citation|warning_letter|consent_order|stop_sale_order|recall_order|administrative_order|criminal_referral|injunction — promote to reference product]' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willfulViolation rdf:type rdf:Property ;
    rdfs:label 'Willful Violation' ;
    rdfs:comment 'Indicates whether the regulatory agency classified the violation as willful or knowing, which triggers higher penalty tiers and potential criminal referral. True if classified as willful; False otherwise. Relevant for OSHA, EPA, and USDA enforcement actions.' ;
    rdfs:domain ind:ViolationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerProtectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Worker Protection Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each EPA Worker Protection Standard (WPS) compliance record. Serves as the primary key for this transactional compliance entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkerProtectionRecord .

ind:annualAuditDate rdf:type rdf:Property ;
    rdfs:label 'Annual Audit Date' ;
    rdfs:comment 'Date on which the annual internal WPS compliance audit was conducted for this farm unit and compliance year. Used to track audit cadence and confirm audit readiness prior to regulatory inspections.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFindingCount rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Count' ;
    rdfs:comment 'Number of compliance findings or deficiencies identified during the annual WPS audit. Used to prioritize corrective actions and track improvement trends across compliance years.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the annual WPS compliance audit. Indicates whether the farm unit passed, passed with findings requiring corrective action, failed, or has a pending audit outcome.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decontaminationSiteCount rdf:type rdf:Property ;
    rdfs:label 'Decontamination Site Count' ;
    rdfs:comment 'Number of decontamination supply stations established and maintained at this farm unit in compliance with WPS distance requirements. Supports verification that adequate coverage exists across all work areas.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decontaminationSuppliesStatus rdf:type rdf:Property ;
    rdfs:label 'Decontamination Supplies Status' ;
    rdfs:comment 'Status confirming that required decontamination supplies (water, soap, single-use towels) are provided at all required locations for agricultural workers and pesticide handlers. WPS mandates decontamination supplies within a specified distance of work areas.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFacilityName rdf:type rdf:Property ;
    rdfs:label 'Emergency Facility Name' ;
    rdfs:comment 'Name of the nearest emergency medical care facility designated for workers and handlers at this farm unit. Required to be posted and communicated under WPS emergency assistance provisions.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFacilityPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Facility Phone' ;
    rdfs:comment 'Phone number of the nearest emergency medical care facility designated for this farm unit. Must be posted at the central display location and communicated to all workers and handlers.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyMedicalCareAccess rdf:type rdf:Property ;
    rdfs:label 'Emergency Medical Care Access' ;
    rdfs:comment 'Indicates whether documentation of emergency medical care access has been established and is available for workers and handlers. WPS requires that the name, address, and phone number of the nearest emergency medical facility be posted and communicated.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Epa Inspection Date' ;
    rdfs:comment 'Date of the most recent EPA or state agriculture department WPS inspection conducted at this farm unit. Used to track regulatory inspection history and compliance standing.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Epa Inspection Result' ;
    rdfs:comment 'Outcome of the most recent EPA or state agriculture department WPS inspection. Indicates whether violations were found, warnings issued, or penalties assessed.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerTrainingCount rdf:type rdf:Property ;
    rdfs:label 'Handler Training Count' ;
    rdfs:comment 'Total number of pesticide handlers who have completed WPS handler-specific safety training for the compliance year. Handlers require additional training beyond standard agricultural worker WPS training.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardInfoPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Info Posting Status' ;
    rdfs:comment 'Status confirming that pesticide application and hazard information is posted at a central location accessible to all workers and handlers. WPS requires posting of application details including product name, EPA registration number, active ingredient, and re-entry information.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Usd' ;
    rdfs:comment 'Total monetary penalty assessed by EPA or state regulatory authority for WPS violations during the compliance year. Expressed in US dollars. Used for financial impact tracking and regulatory risk management.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pesticideApplicationRecordsCurrent rdf:type rdf:Property ;
    rdfs:label 'Pesticide Application Records Current' ;
    rdfs:comment 'Indicates whether pesticide application records are current and maintained as required by WPS. Records must include application details for all restricted-use and general-use pesticides applied at the farm unit.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Phi Compliance Verified' ;
    rdfs:comment 'Indicates whether Pre-Harvest Interval (PHI) requirements for all pesticides applied at this farm unit have been verified and documented. PHI compliance is a critical WPS and food safety obligation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeProvisionStatus rdf:type rdf:Property ;
    rdfs:label 'Ppe Provision Status' ;
    rdfs:comment 'Status confirming that required Personal Protective Equipment (PPE) is provided to all pesticide handlers as specified on pesticide labels and required by WPS. Includes gloves, respirators, protective eyewear, and chemical-resistant clothing as applicable.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this WPS compliance record originated. Supports data lineage tracking and reconciliation across farm management platforms such as Granular Farm Management or SAP S/4HANA QM module.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Rei Compliance Verified' ;
    rdfs:comment 'Indicates whether Restricted Entry Interval (REI) enforcement procedures have been verified as compliant for all pesticide applications at this farm unit. Confirms that workers are excluded from treated areas during the REI period.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reiPostingLocationCount rdf:type rdf:Property ;
    rdfs:label 'Rei Posting Location Count' ;
    rdfs:comment 'Number of treated area entry points where REI notices are posted. Used to verify that all required posting locations are covered across the farm unit.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reiPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Rei Posting Status' ;
    rdfs:comment 'Status confirming that Restricted Entry Interval (REI) notices are posted at all treated area entry points as required by WPS. REI postings must include the product name, EPA registration number, active ingredient, REI duration, and the date and time the REI expires.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Sds Availability Status' ;
    rdfs:comment 'Confirmation status that Safety Data Sheets (SDS) for all pesticides used at this farm unit are accessible to workers and handlers as required by WPS. SDS must be available at a central location during pesticide application and for 30 days after.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sds Location Description' ;
    rdfs:comment 'Description of the physical or digital location where Safety Data Sheets (SDS) are maintained and accessible to workers and handlers on the farm unit. Required for WPS compliance documentation.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'State Agency Notified' ;
    rdfs:comment 'Indicates whether the relevant state department of agriculture has been notified of WPS compliance status or violations as required. Many states have cooperative agreements with EPA for WPS enforcement.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date on which all required WPS training for the compliance year was completed for this farm unit. Used to confirm training was conducted prior to pesticide application activities.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workerTrainingCount rdf:type rdf:Property ;
    rdfs:label 'Worker Training Count' ;
    rdfs:comment 'Total number of agricultural workers who have completed WPS safety training for the compliance year at this farm unit. Used to verify training coverage against total workforce headcount.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wpsCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Wps Coordinator Name' ;
    rdfs:comment 'Full name of the designated WPS compliance coordinator responsible for this farm unit\'s WPS program. Retained for audit documentation and regulatory inspection purposes.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wpsTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Wps Training Status' ;
    rdfs:comment 'Indicates the completion status of EPA-mandated WPS safety training for all agricultural workers and pesticide handlers at this farm unit. WPS requires annual training covering pesticide safety, rights, and protections.' ;
    rdfs:domain ind:WorkerProtectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverCropId rdf:type rdf:Property ;
    rdfs:label 'Cover Crop Id' ;
    rdfs:comment 'Unique system-generated identifier for the cover crop planting record. Primary key for the cover_crop entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverCrop .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Reference to the planting or seeding equipment used to establish the cover crop. Supports equipment utilization tracking, calibration records, and field operation cost allocation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:equipmentFieldOperationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Field Operation Id' ;
    rdfs:comment 'Foreign key linking to equipment.field_operation. Business justification: Cover crop planting and termination are executed as field operations. Linking enables equipment utilization tracking for cover crop activities, NRCS practice implementation documentation, and CSP paym' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentFieldOperation .

ind:grazingHerdId rdf:type rdf:Property ;
    rdfs:label 'Grazing Herd Id' ;
    rdfs:comment 'Foreign key linking to livestock.herd. Business justification: Cover crop grazing management: in integrated crop-livestock operations, cover crops are commonly terminated by grazing. Tracking which herd grazed the cover crop is required for herd nutrition records' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Herd .

ind:primaryCoverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cover Employee Id' ;
    rdfs:comment 'Reference to the agronomist or crop advisor responsible for prescribing and overseeing this cover crop planting program.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rotationPlanId rdf:type rdf:Property ;
    rdfs:label 'Rotation Plan Id' ;
    rdfs:comment 'Reference to the crop rotation plan that prescribes this cover crop planting as part of a multi-season soil health or conservation strategy.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RotationPlan .

ind:stationId rdf:type rdf:Property ;
    rdfs:label 'Station Id' ;
    rdfs:comment 'Reference to the weather station providing meteorological data (temperature, precipitation, ET) for this cover crop planting location. Supports growing degree day calculations and irrigation scheduling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to equipment.work_order. Business justification: Cover crop planting and termination operations require work orders for equipment scheduling and cost tracking. NRCS/CSP practice payment documentation requires linking cover crop field activities to a' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:biomassEstimateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Biomass Estimate Lbs Acre' ;
    rdfs:comment 'Estimated above-ground dry biomass produced by the cover crop at termination, expressed in pounds per acre. Key indicator of soil organic matter contribution, nitrogen cycling potential, and weed suppression effectiveness.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverCropType rdf:type rdf:Property ;
    rdfs:label 'Cover Crop Type' ;
    rdfs:comment 'Functional classification of the cover crop by plant family or agronomic category. Determines nitrogen fixation potential, biomass contribution, and soil health benefit. \'mix\' indicates a multi-species blend.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cspContractNumber rdf:type rdf:Property ;
    rdfs:label 'Csp Contract Number' ;
    rdfs:comment 'USDA Conservation Stewardship Program contract number under which this cover crop planting qualifies for conservation payment. Links field-level practice to federal program financial records.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToTermination rdf:type rdf:Property ;
    rdfs:label 'Days To Termination' ;
    rdfs:comment 'Number of calendar days between the cover crop planting date and the actual termination date. Indicates the length of the cover crop growing window and is used to assess biomass accumulation potential and program compliance.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:establishmentRating rdf:type rdf:Property ;
    rdfs:label 'Establishment Rating' ;
    rdfs:comment 'Field-assessed qualitative rating of cover crop stand establishment success. Evaluated by agronomist or field scout based on germination uniformity, plant density, and canopy coverage. Informs replanting decisions.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaCompliant rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliant' ;
    rdfs:comment 'Indicates whether the cover crop termination timing and method comply with FSMA Produce Safety Rule requirements for application of biological soil amendments. Particularly relevant for fields transitioning to fresh produce crops.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsCoverageGeojson rdf:type rdf:Property ;
    rdfs:label 'Gps Coverage Geojson' ;
    rdfs:comment 'GeoJSON polygon representing the GPS-mapped boundary of the actual cover crop planted area within the field. Supports precision agriculture spatial analysis, as-applied mapping, and NRCS program acreage verification.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Bmp Compliant' ;
    rdfs:comment 'Indicates whether this cover crop planting meets applicable Best Management Practices (BMP) for water quality, nutrient management, and erosion control as defined by state or federal environmental agencies.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndviAtTermination rdf:type rdf:Property ;
    rdfs:label 'Ndvi At Termination' ;
    rdfs:comment 'NDVI (Normalized Difference Vegetation Index) value measured at or near the cover crop termination date. Provides an objective, remote-sensing-based indicator of cover crop biomass and canopy health at termination.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrogenCreditLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Credit Lbs Acre' ;
    rdfs:comment 'Estimated plant-available nitrogen credit in pounds per acre attributed to legume cover crop nitrogen fixation or biomass decomposition. Used to adjust NPK fertilizer application rates for the subsequent cash crop season.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrcsPracticeCode rdf:type rdf:Property ;
    rdfs:label 'Nrcs Practice Code' ;
    rdfs:comment 'USDA Natural Resources Conservation Service conservation practice standard code associated with this cover crop planting (e.g., \'340\' for Cover Crop). Required for EQIP, CSP, and other USDA conservation program payment documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPlantingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Planting Date' ;
    rdfs:comment 'Originally scheduled planting date for the cover crop as defined in the rotation plan or agronomic prescription. Enables variance analysis between planned and actual planting timing.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Planted Area Acres' ;
    rdfs:comment 'Total area in acres on which the cover crop was successfully planted. Used for seed cost accounting, NRCS program payment calculations, and soil health program reporting.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantingDate rdf:type rdf:Property ;
    rdfs:label 'Planting Date' ;
    rdfs:comment 'Actual calendar date on which the cover crop seed was planted or broadcast in the field. Used for growing degree day (GDD) accumulation tracking, establishment assessment, and program compliance verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantingMethod rdf:type rdf:Property ;
    rdfs:label 'Planting Method' ;
    rdfs:comment 'Method used to establish the cover crop. Affects seed-to-soil contact, establishment success rate, and seeding rate requirements. \'interseeding\' refers to planting into a standing cash crop canopy.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantingStatus rdf:type rdf:Property ;
    rdfs:label 'Planting Status' ;
    rdfs:comment 'Current lifecycle status of the cover crop planting record. Tracks progression from planning through establishment and termination. \'failed\' indicates the cover crop did not establish adequately.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribedSeedingRateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Prescribed Seeding Rate Lbs Acre' ;
    rdfs:comment 'Agronomist-prescribed target seeding rate in pounds per acre as specified in the cover crop prescription or rotation plan. Enables variance analysis against actual seeding rate applied.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryGoal rdf:type rdf:Property ;
    rdfs:label 'Primary Goal' ;
    rdfs:comment 'Primary agronomic or conservation objective for planting this cover crop. Drives species selection, seeding rate, and termination timing decisions. Used in NRCS program reporting and CSP payment calculations.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Seed Cost Usd' ;
    rdfs:comment 'Total seed cost in US dollars for this cover crop planting, calculated from seed lot unit cost and quantity used. Used in enterprise budget tracking, NRCS program cost-share calculations, and crop enterprise profitability analysis.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedingRateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Lbs Acre' ;
    rdfs:comment 'Actual seeding rate applied for the cover crop, expressed in pounds of seed per acre. Used to verify compliance with NRCS practice standards, calculate seed costs, and assess establishment adequacy.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilCoverPct rdf:type rdf:Property ;
    rdfs:label 'Soil Cover Pct' ;
    rdfs:comment 'Estimated percentage of soil surface covered by the cover crop canopy or residue at peak growth or at termination. Key metric for erosion control effectiveness and NRCS practice standard compliance verification.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilTemperatureAtPlantingC rdf:type rdf:Property ;
    rdfs:label 'Soil Temperature At Planting C' ;
    rdfs:comment 'Soil temperature in degrees Celsius measured at the time of cover crop planting. Critical for predicting germination success and establishment timing, particularly for cool-season cover crop species.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speciesMixName rdf:type rdf:Property ;
    rdfs:label 'Species Mix Name' ;
    rdfs:comment 'Common name or blend designation of the cover crop species or species mix planted (e.g., \'Winter Rye\', \'Crimson Clover\', \'Cereal Rye + Hairy Vetch Mix\'). Supports soil health program documentation and seed procurement.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesScientificName rdf:type rdf:Property ;
    rdfs:label 'Species Scientific Name' ;
    rdfs:comment 'Botanical (scientific) name of the primary cover crop species or lead species in a mix (e.g., \'Secale cereale\', \'Trifolium incarnatum\'). Required for NRCS program compliance and GLOBALG.A.P. documentation.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the cover crop was terminated (killed or incorporated). Critical for calculating days of cover, biomass accumulation, and ensuring adequate decomposition time before primary crop planting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationMethod rdf:type rdf:Property ;
    rdfs:label 'Termination Method' ;
    rdfs:comment 'Method used to terminate (kill) the cover crop prior to primary crop planting. Affects residue management, soil disturbance, and organic certification compliance. \'roller_crimper\' is preferred in no-till and organic systems.' ;
    rdfs:domain ind:CoverCrop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fertilizationEventId rdf:type rdf:Property ;
    rdfs:label 'Fertilization Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each fertilizer application event record. Serves as the primary key for the fertilization_event data product in the crop domain Silver layer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FertilizationEvent .

ind:inputProductId rdf:type rdf:Property ;
    rdfs:label 'Input Product Id' ;
    rdfs:comment 'Reference to the fertilizer product or material applied during this event. Links to the product/material master containing NPK formulation, active ingredient, and regulatory details.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InputProduct .

ind:landSoilSampleId rdf:type rdf:Property ;
    rdfs:label 'Land Soil Sample Id' ;
    rdfs:comment 'Foreign key linking to land.soil_sample. Business justification: Nutrient management plans and state regulatory compliance require traceability from each fertilization event back to the soil test (COA) that justified the application rate. NRCS and state nutrient ma' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandSoilSample .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Nutrient management audits and FSMA compliance require traceability from fertilizer application events back to the procurement PO and vendor. Replaces denormalized supplier_name. A domain expert expec' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualRate rdf:type rdf:Property ;
    rdfs:label 'Actual Rate' ;
    rdfs:comment 'The actual fertilizer application rate recorded during the field operation, expressed in the unit defined by rate_unit. Sourced from John Deere Operations Center or Trimble Ag as-applied data. Compared against planned_rate for VRA compliance and agronomic audit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application End Timestamp' ;
    rdfs:comment 'Precise date and time when the fertilizer application operation was completed in the field. Used to calculate application duration, equipment OEE, and to confirm REI start time.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Start Timestamp' ;
    rdfs:comment 'Precise date and time when the fertilizer application operation began in the field. Sourced from John Deere Operations Center or Trimble Ag telematics. Used for REI (Restricted Entry Interval) compliance and equipment utilization analysis.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the fertilization event workflow. \'planned\' indicates a scheduled event not yet executed; \'in_progress\' indicates active application; \'completed\' indicates successful execution; \'cancelled\' indicates the event was called off before execution; \'voided\' indicates a data correction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Agronomic timing classification of the fertilizer application relative to the crop growth stage. Distinguishes pre-plant, at-plant, and in-season applications for nutrient management planning and compliance. [ENUM-REF-CANDIDATE: pre_plant|at_plant|side_dress|top_dress|in_season|post_harvest — promote to reference product]' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fertilizerForm rdf:type rdf:Property ;
    rdfs:label 'Fertilizer Form' ;
    rdfs:comment 'Physical form of the fertilizer product applied. Determines equipment requirements, handling procedures, and SDS (Safety Data Sheet) compliance. [ENUM-REF-CANDIDATE: dry_granular|liquid|anhydrous_ammonia|suspension|slow_release|controlled_release — promote to reference product]' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmoDerived rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Derived' ;
    rdfs:comment 'Indicates whether the fertilizer product contains or is derived from GMO (Genetically Modified Organism) sources (e.g., certain biofertilizers). Relevant for organic certification exclusion and international export compliance.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganic rdf:type rdf:Property ;
    rdfs:label 'Is Organic' ;
    rdfs:comment 'Indicates whether the fertilizer product applied is certified organic under the USDA National Organic Program (NOP). True = organic-approved input; False = conventional synthetic fertilizer. Critical for organic certification compliance and audit trails.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVraApplied rdf:type rdf:Property ;
    rdfs:label 'Is Vra Applied' ;
    rdfs:comment 'Indicates whether this fertilization event was executed using Variable Rate Application (VRA) technology, applying different rates across management zones within the field. True = VRA prescription followed; False = flat-rate uniform application.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nitrogenAppliedLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Applied Lbs Acre' ;
    rdfs:comment 'Actual pounds of elemental nitrogen applied per acre during this event, derived from actual_rate and nitrogen_pct. Stored as a raw field value from the source system for EPA nutrient management plan compliance and environmental reporting. Critical KPI for nitrogen use efficiency (NUE) analysis.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrogenPct rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Pct' ;
    rdfs:comment 'Percentage of nitrogen (N) in the NPK formulation of the fertilizer product applied. Used for nutrient budget calculations, soil nitrogen loading analysis, and EPA nutrient management plan compliance.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutrientManagementPlanRef rdf:type rdf:Property ;
    rdfs:label 'Nutrient Management Plan Ref' ;
    rdfs:comment 'Reference number or identifier of the USDA NRCS-approved Nutrient Management Plan (NMP) that governs this fertilization event. Required for USDA conservation program compliance (e.g., EQIP) and EPA nutrient management reporting.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phosphorusPct rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Pct' ;
    rdfs:comment 'Percentage of phosphorus (P2O5) in the NPK formulation of the fertilizer product applied. Used for phosphorus loading calculations, water quality compliance, and soil nutrient balance reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRate rdf:type rdf:Property ;
    rdfs:label 'Planned Rate' ;
    rdfs:comment 'The target or prescribed fertilizer application rate as specified in the agronomic plan or VRA prescription, expressed in the unit defined by rate_unit. Represents the intended nutrient loading before actual application.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumPct rdf:type rdf:Property ;
    rdfs:label 'Potassium Pct' ;
    rdfs:comment 'Percentage of potassium (K2O) in the NPK formulation of the fertilizer product applied. Used for potassium budget calculations and soil fertility management reporting.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for both planned_rate and actual_rate fields. Common units include lbs/acre (CWT-based), gallons/acre for liquid fertilizers, and metric equivalents for international operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rei Expiry Timestamp' ;
    rdfs:comment 'Date and time when the Restricted Entry Interval (REI) expires following the fertilizer application, after which workers may safely re-enter the treated field. Calculated from application_end_timestamp plus the product-specific REI duration. Critical for OSHA and EPA worker safety compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:soilTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Soil Temperature F' ;
    rdfs:comment 'Soil temperature in degrees Fahrenheit at the time of fertilizer application. Critical for nitrogen application timing decisions (e.g., nitrification inhibitor effectiveness, anhydrous ammonia fall application restrictions) and nutrient uptake efficiency.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The native identifier of this fertilization event record in the originating operational system (e.g., John Deere Operations Center task ID, Trimble Ag field activity ID). Enables deduplication and reconciliation between the Silver layer and source systems.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProductApplied rdf:type rdf:Property ;
    rdfs:label 'Total Product Applied' ;
    rdfs:comment 'Total quantity of fertilizer product applied across the entire treated area during this event, expressed in the unit defined by rate_unit. Calculated from actual_rate multiplied by treated_area_acres but stored as a raw field value from the source system for inventory reconciliation and nutrient management reporting.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Treated Area Acres' ;
    rdfs:comment 'The actual field area covered by the fertilizer application, measured in acres. May differ from the total field area if only a portion of the field was treated. Sourced from GPS/RTK boundary data in John Deere Operations Center.' ;
    rdfs:domain ind:FertilizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Observed weather condition at the time of fertilizer application. Relevant for assessing nutrient runoff risk, volatilization potential, and GAP compliance. Recorded by the operator or sourced from field weather station data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Mph' ;
    rdfs:comment 'Wind speed in miles per hour recorded at the time of fertilizer application. Used to assess drift risk for liquid and granular applications and to validate compliance with application label restrictions.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAccountId rdf:type rdf:Property ;
    rdfs:label 'Contract Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Buyer-driven crop specifications: food manufacturers and retailers specify variety, organic certification, GMO status, and GlobalG.A.P. requirements at the field plan level. Linking field_crop_plan to' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:cropEnterpriseBudgetId rdf:type rdf:Property ;
    rdfs:label 'Crop Enterprise Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.crop_enterprise_budget. Business justification: Field crop plans are the operational execution of enterprise budgets. Farm managers link plans to budgets for planned-vs-actual cost tracking and agronomic budget variance reporting — a core farm mana' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CropEnterpriseBudget .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Foreign key linking to sales.demand_forecast. Business justification: S&OP production planning: field crop plans are created in response to sales demand forecasts. Linking enables the S&OP process where agronomists confirm production plans against sales forecasts — a st' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:haccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.haccp_plan. Business justification: Food-grade crop plans must reference the governing HACCP plan for the commodity. FSMA Preventive Controls requires that agronomic plans align with food safety hazard controls. A domain expert would ex' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:plantingWindowId rdf:type rdf:Property ;
    rdfs:label 'Planting Window Id' ;
    rdfs:comment 'Foreign key linking to weather.planting_window. Business justification: Field crop plans set planned_planting_date based on the approved planting window for the field/season. Linking field_crop_plan to planting_window supports agronomic plan traceability, insurance docume' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlantingWindow .

ind:seedVarietyId rdf:type rdf:Property ;
    rdfs:label 'Seed Variety Id' ;
    rdfs:comment 'Reference to the specific crop variety (cultivar) selected for this field and season, including GMO status, maturity rating, and trait profile. Links to the crop variety master in the seed catalog.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeedVariety .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the responsible agronomist formally approved this crop plan for execution. Required for GLOBALG.A.P. and GAP compliance audit documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalgApCertified rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Certified' ;
    rdfs:comment 'Indicates whether this field crop plan is authored and executed under an active GLOBALG.A.P. (Global Good Agricultural Practices) certification scope. Drives audit documentation requirements and customer supply chain eligibility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoTraitUsed rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Used' ;
    rdfs:comment 'Indicates whether the selected crop variety contains one or more GMO (Genetically Modified Organism) traits. Required for USDA APHIS biotech regulatory compliance, COOL (Country of Origin Labeling), and export documentation to GMO-restricted markets.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationSystemType rdf:type rdf:Property ;
    rdfs:label 'Irrigation System Type' ;
    rdfs:comment 'Type of irrigation infrastructure deployed on this field. Determines ET (Evapotranspiration)-based scheduling methodology, water application efficiency, and water allocation compliance reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationTargetDepthInches rdf:type rdf:Property ;
    rdfs:label 'Irrigation Target Depth Inches' ;
    rdfs:comment 'Planned total irrigation water application depth in acre-inches for the season, derived from ET-deficit modeling and soil moisture trigger thresholds. Supports water allocation compliance and USDA NRCS irrigation water management standards.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviBaseline rdf:type rdf:Property ;
    rdfs:label 'Ndvi Baseline' ;
    rdfs:comment 'Pre-season NDVI (Normalized Difference Vegetation Index) baseline value for the field, ranging from -1.0 to 1.0. Used to establish field health benchmarks for in-season monitoring and VRA prescription calibration. Sourced from Esri ArcGIS or Climate FieldView satellite imagery.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutrientSetbackZoneFt rdf:type rdf:Property ;
    rdfs:label 'Nutrient Setback Zone Ft' ;
    rdfs:comment 'Minimum buffer distance in feet from water bodies, drainage ditches, and sensitive areas within which nutrient applications are restricted or prohibited. Defined per EPA nutrient management regulations and state BMP requirements. Captured in Esri ArcGIS environmental layer.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The business date on which this crop plan was formally created and entered into the Farm Management Information System (FMIS). Distinct from system audit timestamps.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Planned Area Acres' ;
    rdfs:comment 'Total field area in acres designated for crop production under this plan. Used for input quantity calculations, yield projections, and USDA FSA acreage reporting. Sourced from Esri ArcGIS field boundary data.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHarvestDate rdf:type rdf:Property ;
    rdfs:label 'Planned Harvest Date' ;
    rdfs:comment 'Target calendar date for harvest operations to commence on this field. Drives downstream supply chain scheduling, storage capacity planning, and logistics coordination via SAP S/4HANA SD and TMS.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rowSpacingInches rdf:type rdf:Property ;
    rdfs:label 'Row Spacing Inches' ;
    rdfs:comment 'Planned distance between crop rows in inches, as specified in the planting prescription. Affects canopy closure, weed suppression, and machinery configuration. Integrated with Trimble Ag Software VRA prescriptions.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilTestDate rdf:type rdf:Property ;
    rdfs:label 'Soil Test Date' ;
    rdfs:comment 'Date on which soil samples were collected for the baseline soil test underpinning this crop plan\'s nutrient management recommendations. Required for GLOBALG.A.P. and EPA nutrient management compliance documentation.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetKRateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Target K Rate Lbs Acre' ;
    rdfs:comment 'Planned potassium (K) fertilizer application rate in pounds per acre, based on soil test K levels and crop removal rates. Part of the NPK nutrient management plan. Influences crop quality, disease resistance, and water use efficiency.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNRateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Target N Rate Lbs Acre' ;
    rdfs:comment 'Planned nitrogen (N) fertilizer application rate in pounds per acre, derived from soil test results and yield goal. Core component of the NPK (Nitrogen Phosphorus Potassium) nutrient management plan. Must comply with EPA nutrient management regulations and state BMP requirements.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPRateLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Target P Rate Lbs Acre' ;
    rdfs:comment 'Planned phosphorus (P) fertilizer application rate in pounds per acre, based on soil test P levels and crop removal rates. Part of the NPK nutrient management plan. Subject to EPA and state environmental setback zone restrictions.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPlantPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Plant Population' ;
    rdfs:comment 'Planned seeding rate expressed as seeds per acre. Drives seed quantity procurement, VRA prescription generation, and yield modeling. Sourced from Trimble Ag Software and Climate FieldView planting prescriptions.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tillageMethod rdf:type rdf:Property ;
    rdfs:label 'Tillage Method' ;
    rdfs:comment 'Planned soil tillage approach for land preparation prior to planting. Influences soil health, erosion risk, fuel consumption, and BMP compliance. Captured in Trimble Ag Software field planning module.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAllocationLimitAcreFt rdf:type rdf:Property ;
    rdfs:label 'Water Allocation Limit Acre Ft' ;
    rdfs:comment 'Maximum permitted water volume in acre-feet that may be applied to this field during the season, as defined by water rights permits or irrigation district allocations. Enforced for regulatory compliance with state water authorities.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldTargetBuAcre rdf:type rdf:Property ;
    rdfs:label 'Yield Target Bu Acre' ;
    rdfs:comment 'Expected crop yield expressed in BU (Bushels) per acre for the planned field and season. Serves as the primary agronomic performance benchmark for YPM (Yield Per Acre Metric) reporting and WASDE comparison. Null if crop is measured in MT or CWT.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldTargetMtHectare rdf:type rdf:Property ;
    rdfs:label 'Yield Target Mt Hectare' ;
    rdfs:comment 'Expected crop yield expressed in MT (Metric Tons) per hectare, used for international reporting and crops not measured in bushels. Complements BU/acre target for global supply chain and export documentation.' ;
    rdfs:domain ind:FieldCropPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateRiskIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Indicator Id' ;
    rdfs:comment 'Foreign key linking to weather.climate_risk_indicator. Business justification: Growing season planning incorporates climate risk assessments (drought, frost, heat stress) for enterprise budgeting, crop insurance decisions, and WASDE outlook alignment. Linking growing_season to c' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClimateRiskIndicator .

ind:doubleCropParentSeasonId rdf:type rdf:Property ;
    rdfs:label 'Double Crop Parent Season Id' ;
    rdfs:comment 'For double-crop seasons, references the parent (primary) growing season that precedes this season on the same land area. Enables sequential crop tracking for double-crop rotations common in southern US (e.g., winter wheat followed by soybean). Null for primary or single-crop seasons.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrowingSeason .

ind:enterpriseBudgetId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Budget Id' ;
    rdfs:comment 'Reference to the financial crop enterprise budget associated with this growing season in Granular Farm Management or SAP S/4HANA CO (Controlling). Links agronomic season records to CAPEX/OPEX planning, COGS (Cost of Goods Sold) tracking, and ROI (Return on Investment) analysis at the season level.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.audit. Business justification: GAP and GlobalG.A.P. audits are scoped to a specific growing season. Certification management and audit scheduling require linking each season to its audit record. growing_season.gap_certification_sta' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:qualityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_certification. Business justification: Organic and GAP certifications are issued per season. growing_season.organic_certificate_number is a denormalized reference to the quality_certification record. Normalizing this FK supports certificat' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCertification .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Foreign key linking to weather.weather_zone. Business justification: Growing seasons are planned within climate/weather zones determining GDD targets, frost-free days, and irrigation requirements. climate_zone_code is a denormalized text reference to weather_zone. Prop' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:actualYieldBuAcre rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Bu Acre' ;
    rdfs:comment 'Realized yield for this growing season expressed in BU (Bushels) per acre, captured from harvest data in Climate FieldView or John Deere Operations Center yield monitors. Compared against target_yield_bu_acre for performance analysis. Used in USDA NASS yield surveys, crop insurance settlement, and FMIS season benchmarking.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropInsuranceCoverageType rdf:type rdf:Property ;
    rdfs:label 'Crop Insurance Coverage Type' ;
    rdfs:comment 'Type of USDA RMA crop insurance or farm program coverage elected for this growing season. APH = Actual Production History, RP = Revenue Protection, RP_HPE = Revenue Protection with Harvest Price Exclusion, YP = Yield Protection, ARC = Agriculture Risk Coverage, PLC = Price Loss Coverage. Determines indemnity calculation methodology and premium rates.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropYear rdf:type rdf:Property ;
    rdfs:label 'Crop Year' ;
    rdfs:comment 'The marketing or production year associated with this growing season, expressed as a four-digit calendar year (e.g., 2024). Used for WASDE (World Agricultural Supply and Demand Estimates) alignment, USDA FSA program reporting, and financial crop enterprise budget year-over-year comparisons.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Flag' ;
    rdfs:comment 'Indicates whether this growing season\'s production activities are documented and compliant with FSMA (Food Safety Modernization Act) Produce Safety Rule requirements, including water testing, worker hygiene, and equipment sanitation records. Mandatory for covered produce operations under FDA jurisdiction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Certification Status' ;
    rdfs:comment 'Current GAP (Good Agricultural Practices) certification status for this growing season. Indicates whether the production practices meet USDA GAP audit standards, GLOBALG.A.P. certification requirements, or buyer-mandated food safety standards (SQF, BRC, IFS). Required for retail and food manufacturer customer contracts.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gddTarget rdf:type rdf:Property ;
    rdfs:label 'Gdd Target' ;
    rdfs:comment 'Target cumulative GDD (Growing Degree Days) required for the primary crop variety to reach maturity during this growing season. Used to project harvest timing, align PHI (Pre-Harvest Interval) compliance windows, and calibrate ET (Evapotranspiration)-based irrigation scheduling. Sourced from seed company variety data and NOAA climate records.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipmProgramCode rdf:type rdf:Property ;
    rdfs:label 'Ipm Program Code' ;
    rdfs:comment 'Reference code identifying the IPM (Integrated Pest Management) program or protocol applied during this growing season. Links to the crop protection plan governing pesticide applications, REI (Restricted Entry Interval) compliance, MRL (Maximum Residue Limit) monitoring, and EPA pesticide registration requirements. Aligns with Trimble Ag Software scouting protocols.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationMethod rdf:type rdf:Property ;
    rdfs:label 'Irrigation Method' ;
    rdfs:comment 'Primary irrigation system used during this growing season. Determines ET (Evapotranspiration)-based water scheduling approach, water use efficiency reporting, and compliance with state water rights regulations. \'rainfed\' indicates no supplemental irrigation. Integrated with IoT (Internet of Things) soil moisture sensors and FMIS irrigation scheduling modules.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndviBaselineScore rdf:type rdf:Property ;
    rdfs:label 'Ndvi Baseline Score' ;
    rdfs:comment 'NDVI (Normalized Difference Vegetation Index) baseline score established at the start of the growing season, ranging from -1.0 to 1.0. Derived from satellite or drone imagery processed through Esri ArcGIS or Climate FieldView. Used as the reference benchmark for in-season crop health monitoring, stress detection, and VRA (Variable Rate Application) prescription adjustments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the growing season, used across FMIS systems such as Climate FieldView and Granular Farm Management for cross-system reference. Example: \'SPRING-2024-CORN\', \'FALL-2024-SOY\'. Aligns with SAP S/4HANA PP production order season coding conventions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable descriptive name for the growing season, combining season type, year, and primary crop for operational clarity. Example: \'Spring 2024 Corn\', \'Fall 2024 Soybean\', \'Double-Crop 2024 Winter Wheat\'. Used in reporting dashboards and FMIS displays.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle state of the growing season. \'planned\' indicates agronomic planning is underway but field operations have not commenced. \'active\' indicates planting through harvest operations are in progress. \'completed\' indicates harvest and post-harvest handling are finalized. \'cancelled\' indicates the season was abandoned (e.g., due to extreme weather or market conditions). \'suspended\' indicates temporary halt due to regulatory or operational constraints.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the growing season by its agronomic timing and production strategy. \'double_crop\' supports sequential planting common in southern US and tropical operations. \'cover_crop\' denotes non-cash-crop seasons for soil health management per BMP (Best Management Practices). Drives planting window scheduling and FMIS season templates.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCropVariety rdf:type rdf:Property ;
    rdfs:label 'Target Crop Variety' ;
    rdfs:comment 'Specific variety or hybrid designation of the primary crop planned for this season (e.g., \'DKC62-08RIB\', \'AG36X6\'). Drives seed procurement, VRA (Variable Rate Application) prescriptions, and yield benchmarking by variety. Aligns with seed catalog codes in SAP S/4HANA MM and Trimble Ag Software variety trials.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetYieldBuAcre rdf:type rdf:Property ;
    rdfs:label 'Target Yield Bu Acre' ;
    rdfs:comment 'Agronomically planned yield target for this growing season expressed in BU (Bushels) per acre, representing the YPM (Yield Per Acre Metric) goal. Established during crop planning based on historical yield data, soil productivity ratings, and variety performance benchmarks. Used as the baseline for financial crop enterprise budgets and crop insurance APH (Actual Production History).' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Total Actual Area Acres' ;
    rdfs:comment 'Total land area actually planted during this growing season, expressed in acres. May differ from planned area due to weather delays, equipment failures, or agronomic decisions. Captured from John Deere Operations Center planting telematics and Climate FieldView as-planted maps. Used for yield calculation (YPM) and insurance reporting.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Total Planned Area Acres' ;
    rdfs:comment 'Total land area planned for production under this growing season, expressed in acres. Aggregated from associated field zone assignments. Used for input planning (seed, fertilizer, crop protection), equipment scheduling, and financial crop enterprise budget calculations in Granular Farm Management. Aligns with FSA farm records.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalYieldMt rdf:type rdf:Property ;
    rdfs:label 'Total Yield Mt' ;
    rdfs:comment 'Total harvested production volume for the growing season expressed in MT (Metric Tons), converted from bushel-based yield for international trade, export documentation, and supply chain logistics. Used in BOL (Bill of Lading) preparation, CIF/FOB export contracts, and WASDE supply estimates.' ;
    rdfs:domain ind:GrowingSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestEventId rdf:type rdf:Property ;
    rdfs:label 'Harvest Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each harvest event record. Primary key for the harvest_event data product in the crop domain Silver layer.' ;
    rdfs:domain ind:HarvestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewId rdf:type rdf:Property ;
    rdfs:label 'Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: Harvest crew tracking: harvest operations are crew-based in large-scale agriculture. Linking harvest_event to crew enables piece-rate payroll calculation, H2A compliance verification during harvest, a' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:inventoryGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inventory Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to inventory.goods_receipt. Business justification: When harvested grain is delivered to storage, a goods receipt is created. Linking harvest_event to goods_receipt supports the farm-to-warehouse receiving process and enables reconciliation of harveste' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryGoodsReceipt .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Reference to the grain bin, elevator, or storage facility where harvested commodity was delivered. Supports inventory management, traceability, and WMS integration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:weatherObservationId rdf:type rdf:Property ;
    rdfs:label 'Weather Observation Id' ;
    rdfs:comment 'Foreign key linking to weather.observation. Business justification: Harvest events record weather_condition as denormalized text. Linking to the actual weather observation supports grain quality traceability (moisture, temperature at harvest), insurance documentation,' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:weightTicketId rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Id' ;
    rdfs:comment 'Foreign key linking to invoice.weight_ticket. Business justification: Grain delivery traceability: each harvest event (combine load) produces a weight ticket at point of delivery. This FK links the operational harvest record to the commercial scale ticket used for invoi' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeightTicket .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Reference to the final reconciled yield record associated with this harvest event. Establishes the link between the operational harvest transaction and the authoritative yield data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldRecord .

ind:damagedKernelsPct rdf:type rdf:Property ;
    rdfs:label 'Damaged Kernels Pct' ;
    rdfs:comment 'Percentage of damaged, heat-damaged, or diseased kernels in the harvested grain sample. Impacts grain grade, price dockage, and storage risk assessment.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foreignMaterialPct rdf:type rdf:Property ;
    rdfs:label 'Foreign Material Pct' ;
    rdfs:comment 'Percentage of foreign material (non-grain matter) present in the harvested sample. Used for grain grading, dockage calculation, and quality compliance per USDA GIPSA standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightBu rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Bu' ;
    rdfs:comment 'Total gross weight of harvested grain or commodity measured in bushels (BU) at the time of harvest, prior to moisture adjustment or dockage. Primary yield quantity metric for grain crops.' ;
    rdfs:domain ind:HarvestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightMt rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Mt' ;
    rdfs:comment 'Total gross weight of harvested commodity in metric tons (MT), supporting international trade reporting, export documentation, and CIF/FOB calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestDate rdf:type rdf:Property ;
    rdfs:label 'Harvest Date' ;
    rdfs:comment 'Calendar date on which the harvest operation was performed. Used for PHI compliance verification, crop insurance reporting, and seasonal analytics. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:harvestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Harvest End Timestamp' ;
    rdfs:comment 'Precise date and time when the harvest operation was completed on the field. Combined with start timestamp to compute actual harvest duration for OEE and productivity analysis.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:harvestLossPct rdf:type rdf:Property ;
    rdfs:label 'Harvest Loss Pct' ;
    rdfs:comment 'Estimated percentage of harvestable yield lost during the harvest operation due to equipment settings, crop conditions, or field factors. Used for equipment calibration and operational efficiency improvement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestMethod rdf:type rdf:Property ;
    rdfs:label 'Harvest Method' ;
    rdfs:comment 'Method or equipment type used to harvest the crop. Influences post-harvest handling procedures, grain quality outcomes, and harvest loss estimates.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harvestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Harvest Start Timestamp' ;
    rdfs:comment 'Precise date and time when the harvest operation commenced on the field. Used for equipment utilization analysis, OEE calculation, and operator time tracking.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:harvestedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Harvested Area Acres' ;
    rdfs:comment 'Total field area harvested during this event, measured in acres. Used for yield-per-acre calculations, crop insurance reporting, and FSA acreage certification.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moisturePctAtHarvest rdf:type rdf:Property ;
    rdfs:label 'Moisture Pct At Harvest' ;
    rdfs:comment 'Grain moisture content percentage measured at the time of harvest. Critical for determining drying requirements, storage eligibility, and moisture-adjusted yield calculations. Industry standard for corn is 15.5%, soybeans 13%.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviAtHarvest rdf:type rdf:Property ;
    rdfs:label 'Ndvi At Harvest' ;
    rdfs:comment 'NDVI value captured from satellite or drone imagery at or near the time of harvest. Used to correlate canopy health with final yield outcomes and validate remote sensing models.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Standard Moisture Pct' ;
    rdfs:comment 'Industry-standard moisture percentage used as the basis for moisture-adjusted yield calculations and grain pricing (e.g., 15.5% for corn, 13.0% for soybeans per USDA GIPSA standards).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testWeightLbsPerBu rdf:type rdf:Property ;
    rdfs:label 'Test Weight Lbs Per Bu' ;
    rdfs:comment 'Grain density measurement expressed as pounds per bushel (lbs/bu), indicating grain quality and maturity. Used for grade determination and price dockage calculations per USDA GIPSA standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrigationEventId rdf:type rdf:Property ;
    rdfs:label 'Irrigation Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each irrigation application event record in the crop domain. Serves as the primary key for this transactional entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrrigationEvent .

ind:irrigationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Irrigation Schedule Id' ;
    rdfs:comment 'Identifier of the variable rate application (VRA) prescription or irrigation schedule from Trimble Ag Software or Climate FieldView that directed this irrigation event. Enables planned vs. actual analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrrigationSchedule .

ind:irrigationZoneId rdf:type rdf:Property ;
    rdfs:label 'Irrigation Zone Id' ;
    rdfs:comment 'Foreign key linking to land.irrigation_zone. Business justification: Irrigation events are executed within irrigation zones that define system type, permitted volume, and water right. Water right compliance reporting requires tracking volume applied per zone against pe' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrrigationZone .

ind:pumpStationId rdf:type rdf:Property ;
    rdfs:label 'Pump Station Id' ;
    rdfs:comment 'Reference to the pump station or irrigation infrastructure unit that delivered water for this event, supporting equipment utilization and maintenance tracking.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual elapsed time of the irrigation event in minutes, derived from start and end timestamps or IoT sensor telemetry. Used for operational efficiency analysis and equipment OEE calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationRateInchesPerHour rdf:type rdf:Property ;
    rdfs:label 'Application Rate Inches Per Hour' ;
    rdfs:comment 'Rate at which water was applied during this irrigation event, measured in inches per hour. Used to assess runoff risk, soil infiltration compliance, and equipment calibration validation per USDA NRCS guidelines.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Originating system or method by which this irrigation event record was captured. Supports data lineage, quality assessment, and FMIS integration traceability in the Silver Layer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionUniformityPct rdf:type rdf:Property ;
    rdfs:label 'Distribution Uniformity Pct' ;
    rdfs:comment 'Coefficient of distribution uniformity (DU%) for this irrigation event, measuring how evenly water was applied across the field or zone. Key BMP metric for irrigation system performance and GLOBALG.A.P. compliance.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyCostUsd rdf:type rdf:Property ;
    rdfs:label 'Energy Cost Usd' ;
    rdfs:comment 'Estimated or actual energy cost in US dollars for pumping water during this irrigation event. Used for OPEX analysis, energy efficiency benchmarking, and sustainability reporting.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etTriggerValueInches rdf:type rdf:Property ;
    rdfs:label 'Et Trigger Value Inches' ;
    rdfs:comment 'Evapotranspiration (ET) deficit value in inches that triggered this irrigation event, as calculated from weather station data or crop model. Core metric for ET-driven irrigation scheduling and water use efficiency reporting.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Gpm' ;
    rdfs:comment 'Measured flow rate of water delivery in gallons per minute (GPM) during this irrigation event. Used for pump performance analysis, water meter reconciliation, and system efficiency reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isScheduled rdf:type rdf:Property ;
    rdfs:label 'Is Scheduled' ;
    rdfs:comment 'Indicates whether this irrigation event was executed as part of a pre-planned schedule (True) or was an unplanned/emergency application (False). Used for schedule adherence reporting and agronomic audit trails.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'Scheduled duration of the irrigation event in minutes as defined in the irrigation prescription or FMIS schedule. Used for variance analysis against actual duration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Psi' ;
    rdfs:comment 'Operating pressure of the irrigation system in pounds per square inch (PSI) during this event. Used for equipment performance monitoring, uniformity assessment, and maintenance scheduling.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rainfallSinceLastEventInches rdf:type rdf:Property ;
    rdfs:label 'Rainfall Since Last Event Inches' ;
    rdfs:comment 'Total precipitation in inches recorded between the previous irrigation event and this one. Used to adjust effective irrigation need, validate ET-based scheduling decisions, and support water use efficiency reporting.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoisturePctAfter rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Pct After' ;
    rdfs:comment 'Volumetric soil moisture content (%) recorded by IoT sensors following irrigation application. Used to assess irrigation effectiveness, field capacity attainment, and over-irrigation risk.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoisturePctBefore rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Pct Before' ;
    rdfs:comment 'Volumetric soil moisture content (%) recorded by IoT sensors immediately prior to irrigation application. Used to validate ET-based trigger thresholds and assess irrigation necessity per BMP standards.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoistureSensorDepthCm rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Sensor Depth Cm' ;
    rdfs:comment 'Depth in centimeters at which the soil moisture sensor reading was taken. Required for agronomic interpretation of moisture data and root zone analysis.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeAppliedAcreInches rdf:type rdf:Property ;
    rdfs:label 'Volume Applied Acre Inches' ;
    rdfs:comment 'Total volume of water applied during this irrigation event, measured in acre-inches. Primary quantitative outcome for water use reporting, ET-based scheduling validation, and BMP compliance under USDA NRCS standards.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeAppliedGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Applied Gallons' ;
    rdfs:comment 'Total volume of water applied during this irrigation event, expressed in US gallons. Supports pump station metering reconciliation, water rights reporting, and utility billing where applicable.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterCostUsd rdf:type rdf:Property ;
    rdfs:label 'Water Cost Usd' ;
    rdfs:comment 'Estimated or actual cost of water applied during this irrigation event in US dollars, based on metered usage rates, well pumping costs, or municipal water tariffs. Supports COGS allocation and OPEX reporting.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSourceName rdf:type rdf:Property ;
    rdfs:label 'Water Source Name' ;
    rdfs:comment 'Descriptive name or identifier of the specific water source used (e.g., well name, canal name, reservoir name, municipal supply ID). Supports water rights tracking and regulatory reporting.' ;
    rdfs:domain ind:IrrigationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Classification of the water source used for this irrigation event. Required for water rights compliance, environmental reporting, and BMP documentation under USDA and EPA frameworks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossEventId rdf:type rdf:Property ;
    rdfs:label 'Loss Event Id' ;
    rdfs:comment 'Primary key for loss_event' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerAccountId rdf:type rdf:Property ;
    rdfs:label 'Buyer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Supply contract management: crop loss events (weather, pest, disease) trigger force majeure notifications and supply shortfall alerts to contracted buyers. Linking loss_event to the buyer account enab' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:faultId rdf:type rdf:Property ;
    rdfs:label 'Fault Id' ;
    rdfs:comment 'Foreign key linking to equipment.equipment_fault. Business justification: Crop losses caused by equipment failures (combine fire, planter skip, sprayer malfunction) must link to the causative equipment fault for insurance claim documentation, root cause analysis, and warran' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fault .

ind:frostAlertId rdf:type rdf:Property ;
    rdfs:label 'Frost Alert Id' ;
    rdfs:comment 'Foreign key linking to weather.frost_alert. Business justification: Frost is a primary crop loss cause with dedicated RMA insurance reporting requirements. Linking loss_event directly to frost_alert supports frost-specific indemnity claims, adjuster documentation, and' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrostAlert .

ind:governmentProgramId rdf:type rdf:Property ;
    rdfs:label 'Government Program Id' ;
    rdfs:comment 'Foreign key linking to finance.government_program. Business justification: Crop loss events trigger USDA government program claims (NAP, WHIP+, crop insurance indemnity). The loss_event carries insurance_policy_number as a denormalized attribute; a proper FK to government_pr' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernmentProgram .

ind:livestockDamageHerdId rdf:type rdf:Property ;
    rdfs:label 'Livestock Damage Herd Id' ;
    rdfs:comment 'Foreign key linking to livestock.herd. Business justification: Crop damage attribution: crop loss events caused by livestock (fence failure, overgrazing, trespass) require identifying the responsible herd for crop insurance claims, internal liability reporting, a' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Herd .

ind:adjusterInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Adjuster Inspection Date' ;
    rdfs:comment 'The date on which the licensed crop insurance adjuster conducted the field inspection to assess the loss event. Required for USDA RMA claim documentation and loss adjustment timeline compliance.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjusterReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjuster Reference Number' ;
    rdfs:comment 'The adjuster\'s internal reference or case number assigned during the field inspection and loss assessment process. Used for cross-referencing adjuster reports with the insurance claim file.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Affected Area Acres' ;
    rdfs:comment 'Total acreage of the field or portion thereof affected by the crop loss event, measured in acres. Used for indemnity calculation and USDA RMA claim documentation. Aligns with FSA CLU (Common Land Unit) acreage records.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used to assess and quantify the crop loss or damage. Determines the evidentiary basis for the insurance claim and agronomic documentation. [ENUM-REF-CANDIDATE: visual_inspection|drone_survey|adjuster_inspection|satellite_imagery|yield_monitor|lab_sample — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedIndemnityUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Indemnity Usd' ;
    rdfs:comment 'The estimated indemnity payment amount in US dollars calculated based on the assessed yield loss, insured price, and policy coverage level. Preliminary figure prior to final indemnity determination.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldBuAcre rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Bu Acre' ;
    rdfs:comment 'The approved actual production history (APH) or expected yield in bushels per acre for the insured unit at the time of the loss event. Baseline for indemnity calculation under MPCI policy.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalIndemnityUsd rdf:type rdf:Property ;
    rdfs:label 'Final Indemnity Usd' ;
    rdfs:comment 'The final approved indemnity payment amount in US dollars as determined by the approved insurance provider (AIP) and USDA RMA following completion of the loss adjustment process. Used for financial loss reporting and SAP FI/CO posting.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisPolygonReference rdf:type rdf:Property ;
    rdfs:label 'Gis Polygon Reference' ;
    rdfs:comment 'Reference identifier for the GIS polygon or spatial feature in Esri ArcGIS representing the precise geographic boundary of the affected area within the field. Enables spatial analysis and precision agriculture integration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Indemnity Determination Date' ;
    rdfs:comment 'The date on which the final indemnity amount was officially determined and approved by the insurance provider and USDA RMA. Triggers financial posting in SAP FI and revenue recognition under GAAP/IFRS.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'The unique claim number assigned by the approved insurance provider (AIP) or USDA RMA upon formal submission of the loss event claim. Used for claim tracking and ADM system integration.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCause rdf:type rdf:Property ;
    rdfs:label 'Loss Cause' ;
    rdfs:comment 'Primary cause or peril responsible for the crop loss or damage event. Determines applicable insurance coverage type and USDA RMA cause-of-loss code. [ENUM-REF-CANDIDATE: hail|drought|flood|frost|pest|disease|wind|fire|excess_moisture|prevented_planting — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCauseDetail rdf:type rdf:Property ;
    rdfs:label 'Loss Cause Detail' ;
    rdfs:comment 'Detailed narrative description of the specific cause of loss, providing additional context beyond the primary cause code (e.g., \'Late-season frost event on 2024-04-15, temperatures dropped to -3°C for 4 hours\'). Supports adjuster documentation and RMA claim narrative.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDate rdf:type rdf:Property ;
    rdfs:label 'Loss Date' ;
    rdfs:comment 'The calendar date on which the crop loss or damage event occurred or was first observed. This is the principal real-world event date used for insurance claim eligibility and PHI/REI compliance verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossDescription rdf:type rdf:Property ;
    rdfs:label 'Loss Description' ;
    rdfs:comment 'Full narrative description of the crop loss event including observed damage symptoms, affected crop growth stage, and initial field conditions. Used for agronomic risk management and insurance documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossSeverity rdf:type rdf:Property ;
    rdfs:label 'Loss Severity' ;
    rdfs:comment 'Categorical severity classification of the crop loss event based on the assessed yield loss percentage. Used for prioritization of adjuster resources, financial risk reporting, and agronomic risk management KPI tracking.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndviAtLoss rdf:type rdf:Property ;
    rdfs:label 'Ndvi At Loss' ;
    rdfs:comment 'NDVI value recorded for the affected field area at or near the time of the loss event, derived from satellite or drone imagery. Provides objective remote-sensing evidence of crop health degradation for insurance and agronomic documentation.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phiCompliant rdf:type rdf:Property ;
    rdfs:label 'Phi Compliant' ;
    rdfs:comment 'Indicates whether the crop loss event and any associated pesticide applications were compliant with the Pre-Harvest Interval (PHI) requirements at the time of loss. Critical for food safety and MRL compliance documentation under FSMA and EPA regulations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCoverageType rdf:type rdf:Property ;
    rdfs:label 'Policy Coverage Type' ;
    rdfs:comment 'Type of crop insurance policy coverage applicable to this loss event. Determines the indemnity calculation methodology and USDA RMA reporting requirements.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventedPlantingFlag rdf:type rdf:Property ;
    rdfs:label 'Prevented Planting Flag' ;
    rdfs:comment 'Indicates whether the loss event qualifies as a prevented planting claim under USDA RMA MPCI policy, where the insured was unable to plant the insured crop by the final planting date due to an insured cause of loss.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replantingRecommended rdf:type rdf:Property ;
    rdfs:label 'Replanting Recommended' ;
    rdfs:comment 'Indicates whether the agronomist or loss adjuster has recommended replanting of the affected area following the loss event. Triggers replanting payment eligibility assessment under MPCI policy.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the crop loss event was formally reported to the crop insurance agent or USDA RMA. Critical for claim filing deadline compliance under MPCI policy terms.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rmaAdmSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Rma Adm Submission Date' ;
    rdfs:comment 'The date on which the loss event claim data was electronically submitted to the USDA Risk Management Agency (RMA) Actuarial Data Master (ADM) system for official claim processing and reinsurance reporting.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFieldAcres rdf:type rdf:Property ;
    rdfs:label 'Total Field Acres' ;
    rdfs:comment 'Total insured acreage of the field at the time of the loss event. Used to calculate the percentage of field affected and to validate affected_area_acres against the insured unit.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossBuAcre rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Bu Acre' ;
    rdfs:comment 'Estimated yield loss expressed in bushels per acre (BU/acre) resulting from the crop loss event. Primary quantitative metric for MPCI indemnity calculation and agronomic impact assessment. Aligns with YPM reporting standards.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossPct rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Pct' ;
    rdfs:comment 'Estimated yield loss expressed as a percentage of the expected yield for the affected area. Used for crop-hail policy claims and comparative loss analysis across fields and seasons.' ;
    rdfs:domain ind:LossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantingEventId rdf:type rdf:Property ;
    rdfs:label 'Planting Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each planting event record in the Silver layer lakehouse. Primary key for the planting_event data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlantingEvent .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Foreign key linking to weather.forecast. Business justification: Planting decisions are authorized based on weather forecasts (frost risk, soil temperature outlook). Linking planting_event to the forecast used supports agronomic decision audit trails and crop insur' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:soilProfileId rdf:type rdf:Property ;
    rdfs:label 'Soil Profile Id' ;
    rdfs:comment 'Foreign key linking to land.soil_profile. Business justification: Planting decisions (depth, seeding rate, row spacing) are operationally driven by soil profile data (texture, drainage class, depth-to-restrictive-layer). Agronomists reference the soil profile when e' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoilProfile .

ind:airTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Air Temperature C' ;
    rdfs:comment 'Ambient air temperature at the time of planting, expressed in degrees Celsius. Used alongside soil temperature for planting condition assessment and growing degree day (GDD) baseline calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaPlantedAcres rdf:type rdf:Property ;
    rdfs:label 'Area Planted Acres' ;
    rdfs:comment 'Total field area covered by this planting event, measured in acres as GPS-tracked by John Deere Operations Center. Used for seed usage reconciliation, cost allocation, and yield per acre (YPM) calculations.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapCompliant rdf:type rdf:Property ;
    rdfs:label 'Gap Compliant' ;
    rdfs:comment 'Indicates whether this planting event was executed in full compliance with Good Agricultural Practices (GAP) standards, including seed traceability, equipment calibration records, and operator certification. Required for GLOBALG.A.P. and GFSI audit readiness.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hybridCode rdf:type rdf:Property ;
    rdfs:label 'Hybrid Code' ;
    rdfs:comment 'Seed company\'s commercial hybrid or variety code as labeled on the seed bag (e.g., \'DKC62-08RIB\'). Distinct from the internal crop_variety_id — this is the supplier-assigned commercial identifier used for agronomic benchmarking and seed procurement.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantingDepthCm rdf:type rdf:Property ;
    rdfs:label 'Planting Depth Cm' ;
    rdfs:comment 'Actual seed placement depth below soil surface in centimeters, as recorded by the planter monitor. Critical for germination uniformity and stand establishment. Sourced from John Deere Operations Center.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planting End Timestamp' ;
    rdfs:comment 'Precise date and time when the planting operation was completed or stopped, sourced from John Deere Operations Center machine telemetry. Used with start timestamp to compute field operation duration.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plantingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planting Start Timestamp' ;
    rdfs:comment 'Precise date and time when the planting operation commenced, sourced from John Deere Operations Center machine telemetry. Used for operational duration analysis and OEE calculations.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rowSpacingCm rdf:type rdf:Property ;
    rdfs:label 'Row Spacing Cm' ;
    rdfs:comment 'Actual row spacing achieved during planting, measured in centimeters. Affects canopy closure, weed suppression, and yield potential. Sourced from planter configuration data in John Deere Operations Center.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedTreatment rdf:type rdf:Property ;
    rdfs:label 'Seed Treatment' ;
    rdfs:comment 'Description of any chemical or biological seed treatments applied prior to planting (e.g., fungicide, insecticide, inoculant). Required for PHI/REI compliance tracking and EPA pesticide use reporting. Sourced from seed bag label or agronomist records.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingRateActual rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Actual' ;
    rdfs:comment 'Actual average seeding rate achieved during the planting operation, expressed in seeds per acre. Sourced from John Deere Operations Center planter monitor data. Compared against the prescribed VRA seeding rate for agronomic performance analysis.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedingRatePrescribed rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Prescribed' ;
    rdfs:comment 'Target seeding rate specified in the VRA (Variable Rate Application) prescription for this field zone, expressed in seeds per acre. Sourced from Trimble Ag Software prescription maps.' ;
    rdfs:domain ind:PlantingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Pct' ;
    rdfs:comment 'Volumetric soil moisture content at the time of planting, expressed as a percentage. Influences seed-to-soil contact quality and germination success. Sourced from soil moisture sensors or field scouting records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Soil Temperature C' ;
    rdfs:comment 'Soil temperature at seed depth measured at the time of planting, expressed in degrees Celsius. Key agronomic indicator for germination risk assessment and planting timing decisions. Sourced from in-cab sensors or field weather stations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protectionEventId rdf:type rdf:Property ;
    rdfs:label 'Protection Event Id' ;
    rdfs:comment 'Primary key for protection_event' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicatorWorkforceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Applicator Workforce Certification Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_certification. Business justification: WPS/EPA regulatory compliance: EPA and Worker Protection Standard regulations require the pesticide applicator\'s license to be verified and recorded for each application event. protection_event has de' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceCertification .

ind:cropId rdf:type rdf:Property ;
    rdfs:label 'Crop Id' ;
    rdfs:comment 'Reference to the crop variety or commodity being protected during this application event. Used to validate Pre-Harvest Interval (PHI) compliance and Maximum Residue Limit (MRL) thresholds for the specific crop.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crop .

ind:primaryProtectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Protection Employee Id' ;
    rdfs:comment 'Reference to the certified pesticide application operator or licensed agronomist who performed or supervised the crop protection event. Used for operator certification compliance tracking.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeIngredient rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient' ;
    rdfs:comment 'The chemical active ingredient (AI) in the applied pesticide product, as declared on the EPA-registered label. Used for MRL (Maximum Residue Limit) verification, Codex Alimentarius compliance, and IPM program tracking. May contain multiple AIs separated by semicolons.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agronomistSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Agronomist Signoff Date' ;
    rdfs:comment 'Date on which the responsible agronomist reviewed and approved this crop protection event record. Mandatory for GLOBALG.A.P. CB 7.6 pesticide application record completeness and FSMA audit trail. Null indicates pending agronomist review.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestHarvestDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Harvest Date' ;
    rdfs:comment 'Calculated earliest date on which the treated crop may be harvested in compliance with the PHI (Pre-Harvest Interval). Computed as application_date + phi_days_required. Enforced in harvest scheduling to prevent MRL violations and FSMA non-compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Number' ;
    rdfs:comment 'EPA registration number of the pesticide product applied, as printed on the product label. Mandatory for FIFRA compliance recordkeeping. Format: registrant-product[-state suffix]. Must match the EPA-registered label used at time of application.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsCoveragePolygon rdf:type rdf:Property ;
    rdfs:label 'Gps Coverage Polygon' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the GPS-tracked coverage polygon for this application event, as recorded by John Deere Operations Center or Trimble RTK positioning. Enables GIS-based spatial analysis in Esri ArcGIS for drift buffer compliance and field coverage verification.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipmJustified rdf:type rdf:Property ;
    rdfs:label 'Ipm Justified' ;
    rdfs:comment 'Indicates whether this crop protection application was justified by an IPM (Integrated Pest Management) scouting threshold or economic injury level assessment, rather than a calendar-based schedule. True = IPM threshold-triggered; False = preventive/calendar application. Required for GLOBALG.A.P. IPM program compliance.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Phi Compliance Status' ;
    rdfs:comment 'Compliance determination for the PHI requirement relative to the planned harvest date. \'compliant\' = harvest date is after earliest_harvest_date; \'non_compliant\' = harvest scheduled before PHI expiry; \'pending\' = harvest date not yet confirmed; \'waived\' = regulatory exemption applied.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDaysRequired rdf:type rdf:Property ;
    rdfs:label 'Phi Days Required' ;
    rdfs:comment 'Number of days that must elapse between the last application of this crop protection product and the earliest permissible harvest date, as specified on the EPA-registered label. Core compliance field for FSMA, GLOBALG.A.P., and MRL verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reiClearanceDatetime rdf:type rdf:Property ;
    rdfs:label 'Rei Clearance Datetime' ;
    rdfs:comment 'Calculated datetime after which workers may safely re-enter the treated field, computed as application_start_time + rei_hours_required. Posted at field entry points per EPA Worker Protection Standard. Critical for OSHA and EPA WPS compliance.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reiComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rei Compliance Status' ;
    rdfs:comment 'Compliance determination for the REI requirement. \'compliant\' = no worker re-entry before rei_clearance_datetime; \'non_compliant\' = documented early re-entry violation; \'pending\' = REI period still active; \'waived\' = PPE exception per label.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Rei Hours Required' ;
    rdfs:comment 'Number of hours that workers must stay out of the treated field following application, as specified on the EPA-registered label under the Worker Protection Standard (WPS). Decimal to support half-hour increments (e.g., 4.0, 12.0, 24.0, 48.0 hours).' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relativeHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Relative Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage at the time of application. Low humidity increases evaporation and drift risk for certain pesticide formulations. Required for label compliance documentation and GLOBALG.A.P. application condition records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Ambient air temperature in degrees Celsius at the time of application. High temperatures can increase volatilization and drift risk. Some EPA labels restrict application above threshold temperatures. Sourced from field weather station or Climate FieldView weather data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAreaTreatedHa rdf:type rdf:Property ;
    rdfs:label 'Total Area Treated Ha' ;
    rdfs:comment 'Total field area covered by this crop protection application event, measured in hectares. Derived from GPS-tracked equipment coverage via John Deere Operations Center or Trimble RTK positioning. Used for total product quantity reconciliation and EPA pesticide use reporting.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductUsed rdf:type rdf:Property ;
    rdfs:label 'Total Product Used' ;
    rdfs:comment 'Total quantity of crop protection product consumed in this application event (application_rate × total_area_treated). Expressed in the same unit as application_rate_unit. Used for inventory depletion in SAP S/4HANA MM and EPA pesticide use reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterVolumeRate rdf:type rdf:Property ;
    rdfs:label 'Water Volume Rate' ;
    rdfs:comment 'Volume of water carrier used per acre in the spray mixture (gallons/acre or L/ha). Critical for spray efficacy, equipment calibration validation, and label compliance. Sourced from sprayer controller data in John Deere Operations Center or Trimble Ag.' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Compass direction of wind at time of application (8-point compass rose). Used for pesticide drift risk assessment, buffer zone compliance, and neighbor notification requirements under EPA label conditions. [ENUM-REF-CANDIDATE: N|NE|E|SE|S|SW|W|NW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProtectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRotationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rotation Employee Id' ;
    rdfs:comment 'Reference to the certified agronomist or crop advisor responsible for designing and maintaining this rotation plan, used for GAP accountability and NRCS documentation.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRotationSeedVarietyId rdf:type rdf:Property ;
    rdfs:label 'Primary Rotation Seed Variety Id' ;
    rdfs:comment 'Reference to the crop variety planned for the second season/year of the rotation cycle. Supports multi-year rotation sequencing in Granular Farm Management.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeedVariety .

ind:coverCropIncluded rdf:type rdf:Property ;
    rdfs:label 'Cover Crop Included' ;
    rdfs:comment 'Indicates whether one or more cover crop phases are included in this rotation plan. True = cover crops are part of the rotation sequence; False = no cover crop phases planned. Relevant for NRCS CSP cover crop practice eligibility.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverCropSpecies rdf:type rdf:Property ;
    rdfs:label 'Cover Crop Species' ;
    rdfs:comment 'Comma-separated list of cover crop species included in the rotation (e.g., \'Winter Rye, Hairy Vetch, Crimson Clover\'). Supports NRCS CSP practice documentation and soil health certification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverCropTerminationMethod rdf:type rdf:Property ;
    rdfs:label 'Cover Crop Termination Method' ;
    rdfs:comment 'Method used to terminate cover crops prior to cash crop planting. Impacts soil disturbance, residue management, and organic certification compliance. [ENUM-REF-CANDIDATE: herbicide|tillage|roller_crimper|frost|mowing|grazing — promote to reference product if additional methods required]' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCycleYear rdf:type rdf:Property ;
    rdfs:label 'Current Cycle Year' ;
    rdfs:comment 'The current year position within the rotation cycle (e.g., 1, 2, or 3 for a 3-year rotation). Tracks where the field is in the rotation sequence for operational scheduling and compliance reporting.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this rotation plan expires or the final rotation cycle concludes. Nullable for open-ended plans. Used for NRCS CSP contract period management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date on which this rotation plan becomes binding and the first rotation cycle begins. Used for NRCS CSP compliance period tracking and Granular Farm Management scheduling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date of the most recent agronomic review of this rotation plan. Annual reviews are required for NRCS CSP compliance and GLOBALG.A.P. certification maintenance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive human-readable name for the rotation plan (e.g., \'Corn-Soybean-Wheat 3-Year Rotation - North Fields\'), used for identification in Granular Farm Management and agronomist reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAgronomicGoal rdf:type rdf:Property ;
    rdfs:label 'Primary Agronomic Goal' ;
    rdfs:comment 'The principal agronomic objective driving this rotation plan design (e.g., \'Soil organic matter improvement\', \'Soybean cyst nematode suppression\', \'Nitrogen fixation via legume phase\', \'Weed resistance management\'). Supports NRCS CSP documentation and GAP rationale.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationCycleYears rdf:type rdf:Property ;
    rdfs:label 'Rotation Cycle Years' ;
    rdfs:comment 'Total number of years in one complete rotation cycle (e.g., 2 for corn-soybean, 3 for corn-soybean-wheat). Defines the repeating sequence length for soil health and pest cycle management.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rotationType rdf:type rdf:Property ;
    rdfs:label 'Rotation Type' ;
    rdfs:comment 'Classification of the rotation plan type. \'simple\' = two-crop alternation; \'complex\' = three or more crops; \'cover_crop\' = includes dedicated cover crop phases; \'organic\' = certified organic rotation; \'conventional\' = standard agrochemical-supported rotation.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilHealthScore rdf:type rdf:Property ;
    rdfs:label 'Soil Health Score' ;
    rdfs:comment 'Baseline composite soil health score for the field at the time of plan creation, derived from soil organic matter (OM), biological activity, and physical structure assessments. Supports NRCS CSP soil health practice documentation.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilOmPct rdf:type rdf:Property ;
    rdfs:label 'Soil Om Pct' ;
    rdfs:comment 'Baseline soil organic matter (OM) percentage at plan initiation, expressed as a percentage of dry soil weight. Key indicator for rotation plan design and NRCS CSP soil health improvement targets.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOmPct rdf:type rdf:Property ;
    rdfs:label 'Target Om Pct' ;
    rdfs:comment 'Target soil organic matter (OM) percentage to be achieved by the end of the rotation plan period. Defines the agronomic improvement goal and supports NRCS CSP outcome measurement.' ;
    rdfs:domain ind:RotationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tillageSystem rdf:type rdf:Property ;
    rdfs:label 'Tillage System' ;
    rdfs:comment 'Tillage system applied across this rotation plan, governing soil disturbance practices. Influences soil organic matter (OM) accumulation, erosion risk, and NRCS conservation compliance scoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoutingObservationId rdf:type rdf:Property ;
    rdfs:label 'Scouting Observation Id' ;
    rdfs:comment 'Unique system-generated identifier for each field scouting observation record. Serves as the primary key for the scouting_observation data product within the crop domain.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScoutingObservation .

ind:primaryScoutingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Scouting Employee Id' ;
    rdfs:comment 'Reference to the agronomist, crop scout, or remote sensing operator who conducted or submitted the observation. Links to the workforce domain employee or contractor record.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Due Date' ;
    rdfs:comment 'Target date by which the recommended follow-up action should be completed. Calculated considering PHI (Pre-Harvest Interval), REI (Restricted Entry Interval), and crop growth stage urgency. Used for workflow scheduling in SAP S/4HANA PP.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anomalyDetected rdf:type rdf:Property ;
    rdfs:label 'Anomaly Detected' ;
    rdfs:comment 'Indicates whether an anomaly was detected in the vegetation index or field condition relative to the seasonal baseline or surrounding field zones. True triggers priority review and potential VRA prescription adjustment.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bbchGrowthStageCode rdf:type rdf:Property ;
    rdfs:label 'Bbch Growth Stage Code' ;
    rdfs:comment 'Crop growth stage at the time of observation expressed using the BBCH (Biologische Bundesanstalt, Bundessortenamt und CHemische Industrie) decimal scale (00–99). Critical for PHI and REI compliance calculations and timing of crop protection applications.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy M' ;
    rdfs:comment 'Estimated horizontal positional accuracy of the GPS coordinates in meters at the time of observation. RTK-corrected readings typically achieve sub-0.05m accuracy; standard GPS may be 3–5m. Used to qualify spatial data reliability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imageryDate rdf:type rdf:Property ;
    rdfs:label 'Imagery Date' ;
    rdfs:comment 'Date on which the remote sensing imagery used for this observation was captured. May differ from observation_timestamp if imagery was analyzed retrospectively. Used for temporal alignment in seasonal vegetation health comparisons.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidencePct rdf:type rdf:Property ;
    rdfs:label 'Incidence Pct' ;
    rdfs:comment 'Percentage of sampled plants or area units showing presence of the observed pest, disease, or weed (0.00–100.00). Quantitative measure used alongside pressure rating for economic threshold analysis and IPM action decisions.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviBaselineDelta rdf:type rdf:Property ;
    rdfs:label 'Ndvi Baseline Delta' ;
    rdfs:comment 'Difference between the current NDVI value and the seasonal historical baseline NDVI for the same field zone and growth stage. Positive values indicate improvement; negative values indicate decline relative to baseline.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviValue rdf:type rdf:Property ;
    rdfs:label 'Ndvi Value' ;
    rdfs:comment 'Normalized Difference Vegetation Index value ranging from -1.0000 to 1.0000 derived from remote sensing imagery. Values above 0.6 indicate healthy dense vegetation; values below 0.3 indicate stressed or sparse vegetation. Null for in-person observations without sensor data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutrientDeficiencyType rdf:type rdf:Property ;
    rdfs:label 'Nutrient Deficiency Type' ;
    rdfs:comment 'Type of nutrient deficiency symptom observed on the crop. Applicable when observation_category is \'nutrient_deficiency\'. Aligned with NPK (Nitrogen, Phosphorus, Potassium) and micronutrient classification. [ENUM-REF-CANDIDATE: nitrogen|phosphorus|potassium|sulfur|iron|zinc|manganese|boron — promote to reference product]' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCategory rdf:type rdf:Property ;
    rdfs:label 'Observation Category' ;
    rdfs:comment 'Primary classification of what was observed during the scouting event. Segments observations for IPM reporting, crop protection event triggers, and VRA prescription generation. [ENUM-REF-CANDIDATE: pest|disease|weed|nutrient_deficiency|crop_health|vegetation_index|soil_condition|irrigation_stress — promote to reference product]' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationMethod rdf:type rdf:Property ;
    rdfs:label 'Observation Method' ;
    rdfs:comment 'Discriminator indicating how the scouting observation was collected: in-person field walk, satellite remote sensing, drone/UAV aerial imagery, manned aerial survey, or IoT sensor reading. Drives downstream processing logic and data quality rules.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Number' ;
    rdfs:comment 'Externally-known business identifier for the scouting observation, formatted as SCO-{YEAR}-{SEQUENCE}. Used for cross-referencing with Trimble Ag Software, Climate FieldView, and SAP S/4HANA PP crop protection events.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current lifecycle state of the scouting observation record, from initial field capture through agronomist review, action assignment, and closure. Drives workflow routing in Trimble Ag Software and SAP S/4HANA PP.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The precise date and time when the scouting observation was made in the field or when remote sensing imagery was captured. Principal real-world event time used for IPM decision timing and PHI/REI compliance tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observerNotes rdf:type rdf:Property ;
    rdfs:label 'Observer Notes' ;
    rdfs:comment 'Free-text field notes recorded by the agronomist or scout during the observation. Captures qualitative context, unusual conditions, or supplementary observations not captured in structured fields. Stored for audit and agronomic review.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestCommonName rdf:type rdf:Property ;
    rdfs:label 'Pest Common Name' ;
    rdfs:comment 'Common name of the pest, disease, or weed species identified during the scouting observation (e.g., \'Corn Rootworm\', \'Soybean Rust\', \'Waterhemp\'). Complements the scientific code for field-user readability.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestOrganismCode rdf:type rdf:Property ;
    rdfs:label 'Pest Organism Code' ;
    rdfs:comment 'Standardized scientific or EPPO (European and Mediterranean Plant Protection Organization) code identifying the pest species, disease pathogen, or weed species observed. Null when observation category is not pest, disease, or weed.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Reference Url' ;
    rdfs:comment 'URL or file path reference to photographic evidence captured during the scouting observation. Photos are stored in the enterprise document management system and linked here for audit trail and agronomist review purposes.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRating rdf:type rdf:Property ;
    rdfs:label 'Pressure Rating' ;
    rdfs:comment 'Qualitative rating of pest or disease pressure intensity observed in the field, ranging from none to severe. Used as the primary IPM decision trigger for crop protection event initiation and economic threshold comparison.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the scouting observation indicating urgency of follow-up action. Critical and high priorities trigger immediate crop protection event creation or VRA prescription review in the FMIS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended agronomic action based on the scouting observation findings. Drives downstream workflow creation in SAP S/4HANA PP for crop protection events or Trimble Ag Software for VRA prescriptions. [ENUM-REF-CANDIDATE: no_action|monitor|apply_crop_protection|adjust_irrigation|apply_fertilizer|vra_prescription|escalate_agronomist — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the scouting observation was reviewed and validated by the responsible agronomist or supervisor. Part of the IPM audit trail required by GLOBALG.A.P. and FSMA compliance frameworks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Number of individual plant samples, transects, or observation points assessed during the scouting event. Provides statistical context for incidence and severity ratings and supports data quality validation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoutedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Scouted Area Ha' ;
    rdfs:comment 'Total area of the field covered by this scouting observation, expressed in hectares. Used to calculate observation density, extrapolate field-wide pest pressure, and determine VRA prescription zone boundaries.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorPlatform rdf:type rdf:Property ;
    rdfs:label 'Sensor Platform' ;
    rdfs:comment 'The sensor or imaging platform used to capture remote sensing data for this observation (e.g., satellite, drone/UAV, manned aerial, ground-based IoT sensor, handheld device). Null for purely in-person observations without sensor data.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Qualitative rating of the severity of damage or infection on affected plants, distinct from incidence (which measures spread). Severity measures the degree of impact on individual plants. Used in conjunction with incidence_pct for full IPM assessment.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegetationHealthClass rdf:type rdf:Property ;
    rdfs:label 'Vegetation Health Class' ;
    rdfs:comment 'Classified vegetation health category derived from NDVI or other spectral indices. Used for field-level health mapping, anomaly detection, and seasonal baseline comparison in Climate FieldView and Esri ArcGIS.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weedDensityPerSqm rdf:type rdf:Property ;
    rdfs:label 'Weed Density Per Sqm' ;
    rdfs:comment 'Count of weed plants per square meter observed in the scouted area. Applicable when observation_category is \'weed\'. Used to determine economic threshold for herbicide application and VRA prescription generation.' ;
    rdfs:domain ind:ScoutingObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the seed supplier or vendor who provided this seed lot. Links to the supplier master for procurement traceability and vendor performance management. Maps to SAP S/4HANA MM vendor master (LFA1).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:certificationClass rdf:type rdf:Property ;
    rdfs:label 'Certification Class' ;
    rdfs:comment 'AOSCA-defined seed certification class indicating the generation and purity level of the seed lot. \'breeder\' = source seed from plant breeder; \'foundation\' = first generation from breeder seed; \'registered\' = second generation; \'certified\' = third generation approved for commercial use; \'uncertified\' = not certified.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropSpecies rdf:type rdf:Property ;
    rdfs:label 'Crop Species' ;
    rdfs:comment 'Botanical or common species name of the crop seed in this lot (e.g., \'Zea mays\' for corn, \'Glycine max\' for soybean, \'Triticum aestivum\' for wheat). Used for regulatory reporting, crop rotation planning, and USDA compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:germinationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Germination Expiry Date' ;
    rdfs:comment 'Date after which the germination rate certification is no longer valid and retesting is required per USDA Federal Seed Act regulations. Drives lot status transitions to \'expired\' and triggers procurement or retesting workflows.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:germinationRatePct rdf:type rdf:Property ;
    rdfs:label 'Germination Rate Pct' ;
    rdfs:comment 'Percentage of seeds in this lot that germinated under standard test conditions, as reported on the seed tag or Certificate of Analysis (COA). Expressed as a percentage (0.00–100.00). Critical for seeding rate calculations, yield forecasting (YPM), and USDA Federal Seed Act minimum germination standards compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:germinationTestDate rdf:type rdf:Property ;
    rdfs:label 'Germination Test Date' ;
    rdfs:comment 'Date on which the germination test was conducted for this seed lot, as reported on the seed tag or COA (Certificate of Analysis). Used to determine germination validity period and compliance with USDA Federal Seed Act labeling requirements.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmoTraitStack rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Stack' ;
    rdfs:comment 'Identifier or description of the GMO (Genetically Modified Organism) trait stack present in this seed lot (e.g., \'RR2Y/YGCB\', \'Roundup Ready 2 Yield + YieldGard Corn Borer\'). NULL if non-GMO. Required for USDA APHIS biotech regulatory compliance, COOL labeling, and customer GMO disclosure requirements.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Externally-known alphanumeric lot number (LOT) assigned by the seed supplier or internal seed processing facility. Used for seed traceability from procurement through planting to harvest, and for FSMA seed traceability compliance. Maps to SAP S/4HANA MM batch number (CHARG) and Granular Farm Management lot tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the seed lot. \'available\' = in storage and ready for use; \'reserved\' = allocated to a planting plan; \'planted\' = fully consumed in field operations; \'depleted\' = quantity exhausted; \'quarantined\' = held pending quality or regulatory review; \'expired\' = past germination validity date.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Pct' ;
    rdfs:comment 'Moisture content of the seed lot expressed as a percentage at time of testing or receipt. Critical for safe storage, preventing mold and mycotoxin development, and maintaining germination viability. Monitored per USDA grain storage standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noxiousWeedFree rdf:type rdf:Property ;
    rdfs:label 'Noxious Weed Free' ;
    rdfs:comment 'Indicates whether this seed lot has been certified as free of noxious weed seeds as defined by USDA Federal Seed Act and applicable state seed laws. True = certified noxious weed free; False = noxious weed seeds detected or certification not obtained. Required for interstate commerce compliance.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purityPct rdf:type rdf:Property ;
    rdfs:label 'Purity Pct' ;
    rdfs:comment 'Percentage of pure seed (by weight) in this lot as determined by seed analysis, excluding inert matter, other crop seed, and weed seed. Expressed as a percentage (0.00–100.00). Required for USDA Federal Seed Act labeling compliance and AOSCA certification standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRemaining rdf:type rdf:Property ;
    rdfs:label 'Quantity Remaining' ;
    rdfs:comment 'Current remaining quantity of seed in this lot available for planting, expressed in the unit_of_measure. Updated as seed is allocated to planting operations. Supports inventory planning, seeding rate calculations, and procurement replenishment decisions.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnits rdf:type rdf:Property ;
    rdfs:label 'Quantity Units' ;
    rdfs:comment 'Total quantity of seed in this lot expressed in the applicable unit of measure (seeds, bags, CWT, or BU as defined in unit_of_measure). Tracks available inventory for planting planning, procurement, and WMS (Warehouse Management System) inventory control in Manhattan Associates WMS.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which this seed lot was physically received at the storage facility. Marks the start of the lot\'s custody chain for FSMA traceability, FIFO inventory management, and storage duration tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relativeMaturityDays rdf:type rdf:Property ;
    rdfs:label 'Relative Maturity Days' ;
    rdfs:comment 'Relative maturity rating of the crop variety in this seed lot, expressed in days or heat units (e.g., 95-day corn, 3.8 maturity group soybean). Critical for crop planning, harvest scheduling, and matching variety to growing season length in the FMIS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seedOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Seed Origin Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where this seed lot was produced or conditioned. Required for USDA Country of Origin Labeling (COOL) compliance, import/export documentation, and APHIS phytosanitary certification.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedRatePerAcre rdf:type rdf:Property ;
    rdfs:label 'Seed Rate Per Acre' ;
    rdfs:comment 'Supplier-recommended seeding rate for this seed lot expressed in seeds or units per acre. Used in VRA (Variable Rate Application) prescription generation in Trimble Ag Software and Climate FieldView, and for planting plan calculations in FMIS.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedTreatmentProduct rdf:type rdf:Property ;
    rdfs:label 'Seed Treatment Product' ;
    rdfs:comment 'Commercial name of the seed treatment product applied to this lot (e.g., \'Cruiser Maxx\', \'Poncho/VOTiVO\', \'Apron XL\'). Required for EPA FIFRA compliance, SDS (Safety Data Sheet) reference, and agronomic record-keeping under GAP standards.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedTreatmentType rdf:type rdf:Property ;
    rdfs:label 'Seed Treatment Type' ;
    rdfs:comment 'Type of chemical or biological coating applied to the seed lot prior to packaging. \'fungicide\' = fungicide-only coating; \'insecticide\' = insecticide-only coating; \'fungicide_insecticide\' = combined coating; \'biological\' = biological agent coating; \'untreated\' = no treatment applied. Required for EPA pesticide registration compliance, REI (Restricted Entry Interval) tracking, and PHI (Pre-Harvest Interval) management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWeightLbsBu rdf:type rdf:Property ;
    rdfs:label 'Test Weight Lbs Bu' ;
    rdfs:comment 'Test weight of the seed lot expressed in pounds per bushel (BU), indicating seed density and quality. Used for quality grading, storage planning, and yield estimation. Aligns with USDA grain grading standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thousandSeedWeightG rdf:type rdf:Property ;
    rdfs:label 'Thousand Seed Weight G' ;
    rdfs:comment 'Weight of 1,000 seeds in grams (TSW), used to calculate seeding rates by weight, estimate seed counts per bag, and assess seed size uniformity. Standard agronomic quality metric used in FMIS and precision planting systems.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentActiveIngredient rdf:type rdf:Property ;
    rdfs:label 'Treatment Active Ingredient' ;
    rdfs:comment 'Active Ingredient (AI) of the seed treatment applied to this lot (e.g., \'thiamethoxam\', \'fludioxonil\', \'metalaxyl\'). Required for EPA FIFRA compliance, MRL (Maximum Residue Limit) tracking, and food safety regulatory reporting.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Date' ;
    rdfs:comment 'Date on which the seed treatment was applied to this lot. Used to calculate treatment age, validate treatment efficacy windows, and support EPA FIFRA compliance and PHI/REI tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Procurement cost per unit of measure for this seed lot (in USD), as recorded at time of purchase. Used for COGS (Cost of Goods Sold) calculation, crop enterprise budgeting, CAPEX/OPEX reporting, and financial planning in SAP S/4HANA CO and Granular Farm Management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vigorScore rdf:type rdf:Property ;
    rdfs:label 'Vigor Score' ;
    rdfs:comment 'Seed vigor test score indicating the potential for rapid, uniform emergence under field stress conditions, expressed as a percentage or index (0.00–100.00). Complements germination rate for predicting field performance. Tested per AOSA/ISTA vigor testing protocols.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weedSeedPct rdf:type rdf:Property ;
    rdfs:label 'Weed Seed Pct' ;
    rdfs:comment 'Percentage of weed seed (by weight) found in this seed lot during purity analysis. Must meet USDA Federal Seed Act and state seed law maximum thresholds. High weed seed content may trigger quarantine or rejection.' ;
    rdfs:domain ind:SeedLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precisionDeviceId rdf:type rdf:Property ;
    rdfs:label 'Precision Device Id' ;
    rdfs:comment 'Foreign key linking to equipment.precision_device. Business justification: VRA prescriptions are executed by specific variable-rate controllers or section control devices. Linking identifies the executing device to verify calibration compliance before prescription execution ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrecisionDevice .

ind:supersededByVraPrescriptionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Vra Prescription Id' ;
    rdfs:comment 'Reference to the newer VRA prescription that replaced this one when prescription_status is \'superseded\'. Enables forward-chaining of prescription revision history for agronomic audit and compliance documentation.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VraPrescription .

ind:zoneMapId rdf:type rdf:Property ;
    rdfs:label 'Zone Map Id' ;
    rdfs:comment 'Reference to the management zone map used to delineate spatially variable application zones within the field. Zone maps are derived from soil sampling, NDVI imagery, yield history, or EC surveys.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ZoneMap .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the agronomist or authorized reviewer formally approved this VRA prescription for field use. Required for GAP compliance documentation and regulatory audit readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controllerUploadStatus rdf:type rdf:Property ;
    rdfs:label 'Controller Upload Status' ;
    rdfs:comment 'Status of the VRA prescription file upload to the RTK-enabled equipment controller (e.g., John Deere Operations Center, Trimble display). \'pending\' = awaiting upload; \'uploaded\' = file transferred; \'confirmed\' = controller acknowledged receipt; \'failed\' = upload error requiring retry.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerUploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Controller Upload Timestamp' ;
    rdfs:comment 'Date and time when the VRA prescription file was successfully uploaded to the field equipment controller. Used for operational sequencing, equipment readiness verification, and audit trail documentation.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Primary type of agronomic data used to inform zone delineation and rate assignment for this VRA prescription. Indicates the scientific basis of the prescription for agronomic review and regulatory documentation. [ENUM-REF-CANDIDATE: soil_sampling|yield_history|ndvi_imagery|ec_survey|scouting|multi_source — promote to reference product if additional source types are needed]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultRate rdf:type rdf:Property ;
    rdfs:label 'Default Rate' ;
    rdfs:comment 'Baseline or average application rate for the entire field, expressed in the prescription\'s rate_unit. Used as a fallback rate for zones without specific assignments and as a benchmark for VRA cost-benefit analysis.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputType rdf:type rdf:Property ;
    rdfs:label 'Input Type' ;
    rdfs:comment 'Classification of the agricultural input covered by this VRA prescription. Determines the applicable regulatory framework (EPA for crop protection, USDA for fertilizer/seed) and links to the correct application event type (planting_event, fertilization_event, or protection_event).' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipmStrategyFlag rdf:type rdf:Property ;
    rdfs:label 'Ipm Strategy Flag' ;
    rdfs:comment 'Indicates whether this VRA prescription was developed as part of a formal Integrated Pest Management (IPM) program, where application rates are informed by economic thresholds and scouting data rather than calendar-based schedules. Required for EPA IPM compliance documentation and GLOBALG.A.P. certification.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmoInput rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Input' ;
    rdfs:comment 'Indicates whether the input product specified in this VRA prescription is a Genetically Modified Organism (GMO) seed or GMO-derived product. Required for USDA APHIS biotech crop reporting, non-GMO certification programs, and COOL labeling compliance.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Organic Compliant' ;
    rdfs:comment 'Indicates whether the input product and application method specified in this VRA prescription comply with USDA National Organic Program (NOP) standards. Required for certified organic operations and organic transition documentation.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRate rdf:type rdf:Property ;
    rdfs:label 'Max Rate' ;
    rdfs:comment 'Highest prescribed application rate across all management zones in this VRA prescription, expressed in rate_unit. Used for equipment controller calibration, input cost ceiling estimation, and regulatory compliance with label maximum rates.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRate rdf:type rdf:Property ;
    rdfs:label 'Min Rate' ;
    rdfs:comment 'Lowest prescribed application rate across all management zones in this VRA prescription, expressed in rate_unit. Used for equipment controller calibration, input cost floor estimation, and environmental compliance (MRL, runoff risk).' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkTargetRatio rdf:type rdf:Property ;
    rdfs:label 'Npk Target Ratio' ;
    rdfs:comment 'Target Nitrogen-Phosphorus-Potassium (NPK) ratio for fertilizer VRA prescriptions, expressed in the standard N-P-K format (e.g., \'46-0-0\' for urea, \'10-34-0\' for liquid starter). Null for non-fertilizer prescriptions. Used for nutrient management plan compliance and soil health tracking.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Prescription File Format' ;
    rdfs:comment 'File format of the VRA prescription map exported for equipment controller upload. Common formats include ESRI Shapefile, ISO-XML (ISOBUS standard), GeoTIFF, and proprietary formats for Trimble, Climate FieldView, and John Deere Operations Center.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionName rdf:type rdf:Property ;
    rdfs:label 'Prescription Name' ;
    rdfs:comment 'Human-readable descriptive name for the VRA prescription, typically including field name, input type, and season (e.g., \'North 40 - Nitrogen VRA - Spring 2024\'). Used for identification in Trimble Ag Software and Climate FieldView dashboards.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Prescription Number' ;
    rdfs:comment 'Externally-known business identifier for the VRA prescription, used in Trimble Ag Software and Climate FieldView for cross-system reference, field documentation, and equipment controller upload tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Prescription Status' ;
    rdfs:comment 'Current lifecycle status of the VRA prescription. \'draft\' = under development; \'approved\' = agronomist-signed off; \'uploaded\' = sent to equipment controller; \'applied\' = field application completed; \'cancelled\' = voided before use; \'superseded\' = replaced by a revised prescription.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetApplicationEndDate rdf:type rdf:Property ;
    rdfs:label 'Target Application End Date' ;
    rdfs:comment 'Latest date within the agronomically recommended application window for this VRA prescription. Prescriptions applied after this date may be flagged for agronomic review and compliance documentation.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetApplicationStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Application Start Date' ;
    rdfs:comment 'Earliest date within the agronomically recommended application window for this VRA prescription. Used for field scheduling, equipment dispatch planning, and PHI/REI compliance verification.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFieldAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Total Field Area Acres' ;
    rdfs:comment 'Total area of the field covered by this VRA prescription, measured in acres. Used to calculate total input quantity required, procurement planning, and cost-per-acre analysis.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInputQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Input Quantity' ;
    rdfs:comment 'Total quantity of the agricultural input required to execute this VRA prescription across all zones, expressed in rate_unit denominator (e.g., total lbs, total gallons). Used for procurement planning, inventory reservation, and input cost estimation.' ;
    rdfs:domain ind:VraPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of this VRA prescription, incremented each time the prescription is revised and re-approved. Enables version history tracking and ensures equipment operators apply the most current prescription.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCount rdf:type rdf:Property ;
    rdfs:label 'Zone Count' ;
    rdfs:comment 'Number of distinct management zones defined within this VRA prescription. Indicates the spatial complexity of the prescription and correlates with the degree of input variability across the field.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityHedgeId rdf:type rdf:Property ;
    rdfs:label 'Commodity Hedge Id' ;
    rdfs:comment 'Foreign key linking to finance.commodity_hedge. Business justification: Harvested yield quantities are used to settle commodity hedge positions and test hedge effectiveness under ASC 815/IFRS 9. Finance teams link actual production records to hedge instruments to calculat' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityHedge .

ind:aphYieldBuPerAcre rdf:type rdf:Property ;
    rdfs:label 'Aph Yield Bu Per Acre' ;
    rdfs:comment 'Actual Production History (APH) yield in bushels per acre as reported to USDA RMA for crop insurance purposes. May differ from yield_per_acre due to RMA-specific calculation rules (e.g., prevented planting adjustments, yield substitutions).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Crop Insurance Policy Number' ;
    rdfs:comment 'USDA Risk Management Agency (RMA) crop insurance policy number associated with this field-season production. Required for Actual Production History (APH) documentation and indemnity claim filing under USDA RMA programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Status' ;
    rdfs:comment 'GMO identity status of the harvested crop. Determines segregation requirements, storage bin assignment, and market channel eligibility. Critical for COOL (Country of Origin Labeling), export documentation, and identity-preserved grain premiums.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harvestStatus rdf:type rdf:Property ;
    rdfs:label 'Harvest Status' ;
    rdfs:comment 'Current lifecycle status of the yield record. \'draft\' indicates data is being captured; \'in_progress\' indicates active harvest pass; \'completed\' indicates finalized and reconciled; \'cancelled\' indicates voided record; \'pending_review\' indicates awaiting quality or agronomic sign-off.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureAdjustedProductionBu rdf:type rdf:Property ;
    rdfs:label 'Moisture Adjusted Production Bu' ;
    rdfs:comment 'Total production adjusted to standard moisture basis in bushels. Calculated as: total_production_bu × ((100 - moisture_pct_at_harvest) / (100 - standard_moisture_pct)). Used for grain settlement, sales contract fulfillment, and financial crop enterprise accounting.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductionBu rdf:type rdf:Property ;
    rdfs:label 'Total Production Bu' ;
    rdfs:comment 'Total gross grain production in bushels (BU) recorded for this harvest pass at as-harvested moisture. Primary production quantity used for grain receipt (GRN) creation, sales contract fulfillment, and crop insurance documentation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductionMt rdf:type rdf:Property ;
    rdfs:label 'Total Production Mt' ;
    rdfs:comment 'Total gross grain production converted to metric tons (MT) for international trade, export documentation, and financial reporting under IFRS. Derived from total_production_bu using commodity-specific conversion factors.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPerAcre rdf:type rdf:Property ;
    rdfs:label 'Yield Per Acre' ;
    rdfs:comment 'Actual harvested yield expressed as bushels per acre (BU/acre) for this harvest pass. Core agronomic performance metric (YPM) used for benchmarking against field crop plan targets, historical averages, and regional USDA NASS yield data.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldTargetBuPerAcre rdf:type rdf:Property ;
    rdfs:label 'Yield Target Bu Per Acre' ;
    rdfs:comment 'Planned yield target in bushels per acre (BU/acre) from the associated crop plan for this field-season-variety combination. Used to compute yield variance and performance against plan for financial crop enterprise accounting.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVarianceBuPerAcre rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Bu Per Acre' ;
    rdfs:comment 'Difference between actual yield_per_acre and yield_target_bu_per_acre. Positive value indicates above-plan performance; negative value indicates shortfall. Used for financial crop enterprise accounting, crop insurance (USDA RMA APH), and agronomic benchmarking.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Every Agriculture account requires an assigned account manager employee for territory management, commission calculations, renewal tracking, and customer relationship reporting. This fundamental CRM-H' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent account record for B2B enterprise account hierarchy management. Enables roll-up reporting across subsidiary accounts, divisions, or buying groups within a corporate family.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to invoice.payment_term. Business justification: Account-level payment terms drive all invoicing and credit decisions in agriculture. Replacing denormalized payment_terms_code with a FK to payment_term enforces referential integrity, supports credit' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: FK linking account to its primary customer segment classification. Accounts are classified by segment for pricing, service tier, and sales strategy. The segment product defines all classification sche' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the customer account. Controls whether the account is eligible for order processing, credit extension, and CRM engagement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier assigned to the customer account based on revenue contribution, volume, and relationship importance. Drives service level agreements, pricing tiers, and sales resource allocation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the customer account by business model and relationship type. Drives pricing, credit, and service tier logic. [ENUM-REF-CANDIDATE: B2B_enterprise|B2C_individual|cooperative|distributor|wholesaler|retailer|food_manufacturer|direct_consumer — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Estimated or reported annual revenue of the customer organization, expressed in the account\'s billing currency. Used for account tiering, credit risk assessment, and strategic segmentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the customer\'s official billing address (street number and name). Used for invoice generation, tax jurisdiction determination, and regulatory reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the customer\'s billing address. Used for tax jurisdiction assignment, regional analytics, and logistics planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the customer\'s billing address (e.g., USA, CAN, MEX). Used for COOL (Country of Origin Labeling) compliance, export controls, and international tax reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer\'s billing address. Used for tax rate lookup, geographic segmentation, and delivery zone assignment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province component of the customer\'s billing address. Used for sales tax determination, USDA/FDA jurisdictional compliance, and regional reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Compliance Flag' ;
    rdfs:comment 'Indicates whether this customer account requires Country of Origin Labeling (COOL) compliance on all product shipments and documentation, per USDA Agricultural Marketing Act requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance approved for this customer account, expressed in the account\'s billing currency. Enforced during sales order processing in SAP S/4HANA SD.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or third-party credit rating assigned to the customer account, reflecting creditworthiness and payment risk. Used by finance to set credit limits and payment terms. Examples: AAA, AA, A, BBB, BB, B, CCC.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP S/4HANA distribution channel code indicating how products are sold and delivered to this customer (e.g., direct sales, wholesale, retail, e-commerce). Drives pricing and fulfillment logic.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees at the customer organization. Used for account sizing, market segmentation, and sales resource prioritization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaRegisteredFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Registered Facility Flag' ;
    rdfs:comment 'Indicates whether the customer\'s receiving facility is registered under the FDA Food Safety Modernization Act (FSMA), which is required for certain food product shipments and traceability compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoPreference rdf:type rdf:Property ;
    rdfs:label 'Gmo Preference' ;
    rdfs:comment 'Customer\'s stated preference regarding Genetically Modified Organism (GMO) content in purchased agricultural products. Drives product eligibility filtering and supply chain segregation requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level of this account within the B2B enterprise account hierarchy (e.g., 1 = ultimate parent, 2 = regional subsidiary, 3 = local buying unit). Supports hierarchical roll-up analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'North American Industry Classification System (NAICS) or Standard Industrial Classification (SIC) code describing the customer\'s primary industry segment (e.g., food manufacturing, wholesale trade, retail grocery). Supports market segmentation and analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the customer account as filed with the relevant government authority (e.g., food manufacturer, distributor, cooperative, or individual consumer). Used for contracts, invoicing, and regulatory compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Required' ;
    rdfs:comment 'Indicates whether this customer account requires USDA National Organic Program (NOP) certified products for all or part of their purchases. Triggers organic supply chain routing and COA documentation requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary business email address for the customer account, used for order confirmations, invoices, compliance notifications, and CRM communications.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary business telephone number for the customer account, including country code. Used for order management, logistics coordination, and customer service.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP S/4HANA Sales Organization code representing the organizational unit responsible for selling to this customer. Determines pricing, billing, and distribution channel assignments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Unique account identifier from Salesforce CRM, used to synchronize customer relationship data, sales pipeline, and partner management activities between the CRM and the enterprise data platform.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'Customer master record number assigned in SAP S/4HANA SD module. Used as the cross-reference key for order management, billing, and accounts receivable reconciliation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Federal or state tax identification number (EIN, TIN, or VAT number) for the customer entity. Required for tax reporting, invoicing compliance, and USDA/FDA regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name used commercially by the customer, which may differ from the registered legal name. Supports sales and marketing operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each inter-account relationship record within the customer network hierarchy. Primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Id' ;
    rdfs:comment 'Reference to the account that occupies the subordinate or child position in this relationship record (e.g., regional subsidiary, cooperative member, buying group affiliate, toll processor, or franchisee). Paired with parent_account_id to define the directed relationship.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Reference to the internal employee or sales representative designated as the accountable relationship manager for this inter-account link. Supports CRM pipeline management, account review scheduling, and escalation routing in Salesforce CRM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:buyingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Buying Group Code' ;
    rdfs:comment 'Identifier for the buying group or purchasing alliance to which this relationship belongs. Applicable when relationship_type is \'buying_group\'. Used for aggregated volume discount calculation, group pricing tier assignment, and consolidated purchase order management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether this relationship participates in enterprise-wide credit limit and volume discount aggregation (True). When True, the child account\'s credit exposure and purchase volumes are rolled up to the parent account for consolidated limit management and tiered pricing eligibility across the agricultural commodity trading network.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractualBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Contractual Basis Flag' ;
    rdfs:comment 'Indicates whether this inter-account relationship is underpinned by a formal executed contract (True) or is an informal/operational affiliation without a binding legal agreement (False). Critical for credit limit consolidation eligibility and volume discount aggregation authorization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolPreference rdf:type rdf:Property ;
    rdfs:label 'Cool Preference' ;
    rdfs:comment 'Indicates the Country of Origin Labeling (COOL) preference for this account relationship. \'required\' means COOL documentation is contractually mandated for all shipments; \'preferred\' means requested but not contractually binding; \'not_required\' means no COOL documentation needed. Supports USDA COOL compliance under the Agricultural Marketing Act.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperativeMembershipNumber rdf:type rdf:Property ;
    rdfs:label 'Cooperative Membership Number' ;
    rdfs:comment 'Formal membership identifier assigned by the cooperative organization to the member account. Applicable when relationship_type is \'cooperative_member\'. Used for grain marketing cooperative patronage tracking, equity allocation, and USDA cooperative reporting under the Agricultural Marketing Act.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitConsolidated rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Consolidated' ;
    rdfs:comment 'The enterprise-wide consolidated credit limit amount (in base currency) applicable to this relationship node when consolidation_flag is True. Represents the maximum aggregate credit exposure permitted across the parent-child account group for agricultural commodity trading and supply chain transactions.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the consolidated credit limit amount (e.g., \'USD\', \'EUR\', \'CAD\'). Required for multi-currency agricultural commodity trading operations.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Formal agreement number for franchise network relationships. Applicable when relationship_type is \'franchise\'. Used for franchise royalty tracking, territory management, and compliance monitoring under franchise disclosure regulations.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Required' ;
    rdfs:comment 'Indicates whether the child account in this relationship is required to hold a valid GFSI-recognized food safety certification (e.g., SQF, BRC, IFS, GLOBALG.A.P.) as a condition of the relationship. Used for supplier and co-packer qualification management and food safety compliance monitoring.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalgApMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Member Flag' ;
    rdfs:comment 'Indicates whether the child account holds active GLOBALG.A.P. (Global Good Agricultural Practices) certification or membership. Relevant for cooperative member and co-packer relationships where GAP certification is a qualification criterion for agricultural commodity supply chain participation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the ultimate global parent down to the child account in this relationship (e.g., \'/1001/1045/1089\'). Enables efficient subtree queries for network-level analysis of customer interdependencies in agricultural commodity trading without recursive joins.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent periodic review of this inter-account relationship by the relationship manager or account governance team. Used for relationship health monitoring and scheduling of next review cycles.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this inter-account relationship. Drives CRM task generation and relationship manager workflow in Salesforce CRM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the parent account in the child account for parent_subsidiary relationship types. Expressed as a decimal percentage (e.g., 51.00 for 51%). Used for financial consolidation reporting under IFRS 10 Consolidated Financial Statements and GAAP ASC 810.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRelationshipFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Flag' ;
    rdfs:comment 'Indicates whether this is the primary or dominant relationship for the child account when multiple parent relationships exist (True). Ensures unambiguous hierarchy resolution for credit consolidation, volume discount roll-up, and single-path reporting in multi-affiliation scenarios such as cooperative members who also belong to buying groups.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipCategory rdf:type rdf:Property ;
    rdfs:label 'Relationship Category' ;
    rdfs:comment 'Broad categorical grouping of the relationship for analytics and reporting segmentation. Distinguishes B2B enterprise corporate hierarchies from cooperative grain marketing networks, buying group affiliations, co-packer/toll processing partnerships, and distribution network linkages.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Externally-known alphanumeric business code uniquely identifying this relationship record within the CRM and ERP systems (e.g., Salesforce Account Relationship ID or SAP SD Partner Function Code). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates the directionality of the relationship between the two account parties. \'parent_to_child\' denotes a vertical downward link (e.g., global parent to regional subsidiary), \'child_to_parent\' denotes an upward reference, and \'lateral\' denotes a peer-to-peer affiliation (e.g., co-packer partnership, buying group membership at the same tier).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipName rdf:type rdf:Property ;
    rdfs:label 'Relationship Name' ;
    rdfs:comment 'Human-readable descriptive label for this inter-account relationship (e.g., \'AgriCorp Global — Midwest Grain Cooperative Membership\', \'FreshPack Co-Packer Agreement\'). Used in CRM displays, reporting dashboards, and relationship manager communications.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartReason rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Reason' ;
    rdfs:comment 'Business reason or event that initiated this inter-account relationship. Used for relationship lifecycle analytics, M&A integration tracking, and cooperative membership growth reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the inter-account relationship record. \'active\' indicates the relationship is in force; \'pending\' indicates awaiting approval or contract execution; \'suspended\' indicates temporarily halted; \'terminated\' indicates permanently ended.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Categorical classification of the inter-account relationship. Drives business rules for credit consolidation, volume discount aggregation, and reporting roll-ups. [ENUM-REF-CANDIDATE: parent_subsidiary|cooperative_member|buying_group|co_packer|toll_processing|broker_buyer|franchise|distributor_affiliate — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Relationship Code' ;
    rdfs:comment 'External system identifier for this relationship record as assigned by Salesforce CRM (15 or 18-character Salesforce ID). Used for bi-directional synchronization between the lakehouse silver layer and the Salesforce CRM operational system of record.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPartnerFunctionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Partner Function Code' ;
    rdfs:comment 'SAP S/4HANA SD partner function code that classifies the role of the child account in relation to the parent within SAP (e.g., \'AG\' for sold-to party, \'WE\' for ship-to party, \'RE\' for bill-to party, \'RG\' for payer). Enables ERP-aligned relationship classification for order processing and invoicing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business reason for the termination or expiry of this inter-account relationship. Populated when relationship_status is \'terminated\'. Used for churn analysis, cooperative exit tracking, and M&A divestiture reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Sales territory or geographic region code associated with this account relationship. Used for territory-based sales reporting, relationship manager assignment, and regional agricultural market analysis aligned with USDA Agricultural Statistics Districts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountTier rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier' ;
    rdfs:comment 'Pricing tier assigned to this relationship node for consolidated volume discount eligibility. Aggregated purchase volumes across the parent-child account group determine tier qualification. Used in SAP S/4HANA SD condition records for automatic pricing determination on agricultural commodity sales orders.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Account Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for each account-to-account relationship record in the customer domain. Primary key for the account_relationship data product.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Account Id' ;
    rdfs:comment 'Identifier of the originating or initiating account party in the relationship (e.g., the cooperative, buying group, or broker initiating the affiliation). Represents side A of the lateral relationship.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:targetAccountId rdf:type rdf:Property ;
    rdfs:label 'Target Account Id' ;
    rdfs:comment 'Identifier of the receiving or counterpart account party in the relationship (e.g., the grain elevator, food manufacturer, or retailer on the receiving end). Represents side B of the lateral relationship.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:annualVolumeCommitmentMt rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment Mt' ;
    rdfs:comment 'Contractually committed annual commodity volume in Metric Tons (MT) that the source account agrees to supply or the target account agrees to purchase within this relationship. Supports WASDE-aligned supply planning and cooperative grain pool management.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Broker License Number' ;
    rdfs:comment 'Regulatory license number of the agricultural commodity broker when relationship_type is broker_buyer. Required for compliance with USDA Packers and Stockyards Act and grain broker licensing regulations.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackerFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packer Flag' ;
    rdfs:comment 'Indicates whether the target account acts as a co-packer (True) for the source account, manufacturing or packaging agricultural products under the source accounts brand or specifications. Supports FSMA supplier verification and GFSI audit tracking.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'External contract or agreement number associated with this relationship when contractual_basis_flag is True. Links to the master contract document in SAP S/4HANA or Oracle NetSuite for audit and compliance purposes.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Compliance Required Flag' ;
    rdfs:comment 'Indicates whether Country of Origin Labeling (COOL) compliance documentation is required for commodity transactions within this relationship. Applicable to covered commodities under USDA AMS COOL regulations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditExposureLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Limit' ;
    rdfs:comment 'Maximum aggregate credit exposure permitted across both accounts within this relationship, expressed in the base currency. Used for combined credit risk management in SAP S/4HANA FI-AR and Oracle NetSuite AR modules.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the relationship carries an exclusivity clause (True), preventing either party from entering into equivalent relationships with competing accounts within the defined commodity and geographic scope.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaVerifiedSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Verified Supplier Flag' ;
    rdfs:comment 'Indicates whether the target account has been verified as a qualified supplier under FSMA Foreign Supplier Verification Program (FSVP) or Preventive Controls supplier verification requirements applicable to this relationship.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScopeCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or region code defining the geographic territory within which this account relationship is operative. Supports COOL (Country of Origin Labeling) compliance and territorial sales analysis.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Certified Flag' ;
    rdfs:comment 'Indicates whether the target account holds a valid GLOBALG.A.P. (Global Good Agricultural Practices) certification relevant to this relationship. Supports buyer certification requirements and supply chain compliance audits.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether the relationship involves certified organic commodity transactions (True), requiring both parties to maintain USDA National Organic Program (NOP) certification. Drives organic supply chain segregation and audit trail requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Flag' ;
    rdfs:comment 'Designates the target account as a preferred or strategic partner (True) for the source account. Influences pricing tiers, allocation priority during commodity shortages, and CRM opportunity scoring in Salesforce.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingArrangementType rdf:type rdf:Property ;
    rdfs:label 'Pricing Arrangement Type' ;
    rdfs:comment 'Type of pricing mechanism governing commodity transactions within this relationship. Fixed pricing locks a rate; basis pricing ties to a futures market spread; spot uses current market price; formula uses a defined calculation; negotiated is case-by-case.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNotes rdf:type rdf:Property ;
    rdfs:label 'Relationship Notes' ;
    rdfs:comment 'Free-text field for capturing qualitative context, special terms, operational nuances, or historical background relevant to this account relationship. Used by relationship managers for CRM narrative and account planning in Salesforce.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollProcessingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Toll Processing Agreement Flag' ;
    rdfs:comment 'Indicates whether this relationship involves a toll processing arrangement (True), where one party processes agricultural commodities owned by the other party for a fee. Relevant for grain milling, oilseed crushing, and feed manufacturing partnerships.' ;
    rdfs:domain ind:AccountRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for the annual_volume_commitment field. Standard agricultural units include Metric Ton (MT), Bushel (BU), Hundredweight (CWT), Pound (LB), and Kilogram (KG). Aligns with SAP S/4HANA MM unit of measure configuration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique system-generated identifier for each address record associated with a customer account or contact. Serves as the primary key for the address entity in the customer domain Silver layer.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Reference to the individual contact person this address is associated with, when the address belongs to a specific contact rather than the overall account. Nullable for account-level addresses.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'Identifies the operational system of record from which this address was originally sourced or last updated. Supports data lineage tracking and conflict resolution during master data management synchronization across Salesforce CRM, SAP S/4HANA, Oracle NetSuite, and Granular Farm Management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the functional purpose of the address. \'billing\' is the invoicing address; \'shipping\' is the delivery destination; \'registered\' is the legal business registration address; \'farm_gate\' is a pickup point at the farm; \'cold_storage\' is a refrigerated facility address; \'mailing\' is for general correspondence. [ENUM-REF-CANDIDATE: billing|shipping|registered|farm_gate|cold_storage|mailing|warehouse|processing_plant — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City, town, municipality, or locality name of the address. For rural agricultural addresses, may reference the nearest incorporated municipality.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolCountryCode rdf:type rdf:Property ;
    rdfs:label 'Cool Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code designating the country of origin for COOL (Country of Origin Labeling) compliance purposes. May differ from the physical address country for re-export or processing facility scenarios. Mandatory for USDA COOL compliance on covered commodities including beef, pork, lamb, chicken, fish, shellfish, perishable agricultural commodities, peanuts, pecans, ginseng, and macadamia nuts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name of the address. Critical for USDA Farm Service Agency (FSA) county-level agricultural program eligibility, crop insurance administration, and state agricultural reporting. Also used for EPA and APHIS county-level regulatory compliance tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text field for special delivery instructions specific to this address. Includes gate access codes, dock numbers, receiving hours, refrigeration requirements for cold chain deliveries, and farm-specific access directions not captured in structured address fields. Sourced from Manhattan Associates WMS and TMS delivery notes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotShip rdf:type rdf:Property ;
    rdfs:label 'Do Not Ship' ;
    rdfs:comment 'Indicates that shipments must not be dispatched to this address. May be set due to regulatory restrictions, customer request, failed delivery history, or compliance holds. Enforced during order fulfillment in Manhattan Associates WMS and SAP S/4HANA SD.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this address record is valid and effective for business use. Supports time-bounded address management for seasonal farm gate locations, temporary cold storage facilities, and lease-based distribution points.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this address record is no longer valid for business use. Nullable for indefinitely active addresses. Used to manage seasonal farm gate closures, facility relocations, and lease expirations for distribution network addresses.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fipsCode rdf:type rdf:Property ;
    rdfs:label 'Fips Code' ;
    rdfs:comment 'Five-digit FIPS (Federal Information Processing Standards) county code assigned by the U.S. Census Bureau. Used for USDA program administration, FSA county office routing, crop insurance mapping, and federal agricultural subsidy eligibility determination.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the latitude/longitude geocoding result from Esri ArcGIS. \'rooftop\' indicates exact parcel-level match; \'range_interpolated\' is street-level interpolation; \'geometric_center\' is centroid of a polygon; \'approximate\' is postal code or city centroid; \'unverified\' means coordinates have not been validated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) — a 13-digit identifier uniquely identifying this physical location in the global supply chain. Used for EDI transactions, traceability in food supply chains, GLOBALG.A.P. location registration, and GS1-compliant logistics documentation including BOL and ASN.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this address record is currently active and usable for business operations. Inactive addresses are retained for historical audit and traceability but excluded from operational address selection for orders, invoices, and shipments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary address for the customer account or contact. Only one address per customer per address type should be flagged as primary. Used to determine the default address for billing, shipping, or correspondence when multiple addresses exist.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'Indicates whether this is a residential address as opposed to a commercial or agricultural business address. Affects carrier surcharge calculations, delivery scheduling windows, and B2C vs B2B routing logic for direct-to-consumer agricultural product deliveries.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'Primary street address line including street number and street name. For farm gate addresses, may include rural route or farm road designation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Secondary address line for suite, unit, building, floor, dock number, or additional location detail. Commonly used for distribution center dock numbers or warehouse unit identifiers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line3' ;
    rdfs:comment 'Tertiary address line for additional location detail such as industrial park name, complex name, or rural delivery instructions. Used primarily for international addresses requiring additional lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingDockAvailable rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Available' ;
    rdfs:comment 'Indicates whether a loading dock is available at this address for freight deliveries. Critical for logistics planning of bulk agricultural inputs (fertilizers, seeds, pesticides) and large-volume produce shipments requiring dock-height unloading.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'ZIP code or postal code for the address. Supports USPS ZIP+4 format for domestic addresses and international postal code formats. Used for delivery routing, sales territory assignment, and COOL (Country of Origin Labeling) compliance zone mapping.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refrigerationAvailable rdf:type rdf:Property ;
    rdfs:label 'Refrigeration Available' ;
    rdfs:comment 'Indicates whether refrigerated or cold storage receiving capability is available at this address. Essential for cold chain compliance when delivering perishable agricultural commodities, fresh produce, dairy, and meat products per FSMA and HACCP requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAddressCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Address Code' ;
    rdfs:comment 'External identifier for this address record in Salesforce CRM. Enables bidirectional synchronization between the Databricks Silver layer and Salesforce for sales pipeline management, partner relationship tracking, and customer account maintenance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAddressCode rdf:type rdf:Property ;
    rdfs:label 'Sap Address Code' ;
    rdfs:comment 'External identifier for this address record in SAP S/4HANA Business Partner (BP) address management. Used for reconciliation between the enterprise ERP and the lakehouse Silver layer for billing, shipping, and procurement address data.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, territory, or administrative region of the address. Stored as ISO 3166-2 subdivision code (e.g., \'US-IA\' for Iowa, \'CA-ON\' for Ontario). Critical for USDA state-level agricultural reporting and regulatory compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., \'America/Chicago\', \'America/Los_Angeles\'). Used for scheduling delivery windows, coordinating harvest pickup times, and aligning order cutoff times across multi-timezone distribution networks.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against postal authority databases or geocoding services. Used to schedule re-validation cycles and assess address data freshness for logistics and compliance purposes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Unique system-generated identifier for the customer service and support case record. Primary key for the case data product within the customer domain.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to invoice.invoice. Business justification: Quality complaint and FSMA traceability cases in agriculture must be tied to the originating invoice for credit memo issuance, regulatory audit, and SLA tracking. Agriculture domain experts expect eve' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:assignedOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Case management in Agriculture (food safety complaints, MRL exceedances, FSMA traceability) requires tracking which employee owns each case for SLA reporting, workload management, and regulatory audit' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:environmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_incident. Business justification: Customer cases flagged with mrl_exceedance_flag or regulatory_notification_flag are frequently triggered by farm-level environmental incidents (pesticide drift, contamination). Linking case to environ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalIncident .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'The quantity of product or commodity affected by the issue described in this case, expressed in the unit of measure specified in affected_quantity_uom. Used for impact assessment, credit calculation, and regulatory reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Uom' ;
    rdfs:comment 'Unit of measure for the affected_quantity field. Uses standard agricultural units including Metric Ton (MT), Bushel (BU), Hundredweight (CWT), Kilogram (KG), Pound (LB), Case (CS), or Each (EA). [ENUM-REF-CANDIDATE: MT|BU|CWT|KG|LB|CS|EA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The Bill of Lading (BOL) number for the shipment referenced in this case, used for delivery issue cases and FSMA traceability requests to trace the supply chain movement of the affected commodity lot.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Detailed narrative description of the customer issue, complaint, or inquiry as reported by the customer. Captures the full context of the case including symptoms, affected products, and customer impact.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the case, used in customer communications, audit trails, and GFSI audit readiness documentation. Typically formatted as CASE- followed by a numeric sequence.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle state of the customer service case, tracking progression from initial submission through resolution and closure. Supports SLA monitoring and GFSI audit readiness.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the nature of the customer service case. Distinguishes quality disputes, delivery issues, Certificate of Analysis (COA) discrepancies, Maximum Residue Limit (MRL) exceedance claims, Food Safety Modernization Act (FSMA) traceability requests, complaints, and general inquiries. [ENUM-REF-CANDIDATE: quality_dispute|delivery_issue|coa_discrepancy|mrl_exceedance|fsma_traceability|complaint|general_inquiry — promote to reference product]' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the customer case was formally closed or resolved. Used to calculate total case duration and SLA compliance metrics.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The customer\'s own internal reference number or complaint ID for this case, as provided by the customer (food manufacturer, distributor, or retailer). Enables cross-referencing with the customer\'s own complaint management system.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedTo rdf:type rdf:Property ;
    rdfs:label 'Escalated To' ;
    rdfs:comment 'Name or identifier of the manager, specialist team, or regulatory body to whom the case has been escalated, if applicable. Relevant for HACCP corrective action escalations and MRL regulatory notifications.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTraceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Flag' ;
    rdfs:comment 'Indicates whether this case involves an FSMA traceability request requiring lot-level supply chain tracing per the FSMA Food Traceability Rule (Section 204). Triggers enhanced documentation and response protocols.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiAuditRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Audit Relevant Flag' ;
    rdfs:comment 'Indicates whether this case is relevant for inclusion in GFSI audit documentation and customer complaint trend analysis. True for cases involving food safety, quality, or regulatory compliance issues that must be reported during GFSI certification audits.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCorrectiveActionFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Corrective Action Flag' ;
    rdfs:comment 'Indicates whether this case has triggered a formal HACCP corrective action record in the quality management system. True when the case involves a food safety hazard requiring documented corrective action per HACCP protocols.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when the customer case was officially opened and entered into the system. This is the principal business event timestamp for SLA calculation and regulatory traceability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originChannel rdf:type rdf:Property ;
    rdfs:label 'Origin Channel' ;
    rdfs:comment 'The communication channel through which the customer submitted the case (e.g., email, phone, web portal, EDI). Supports channel analytics and customer experience reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The customer\'s Purchase Order (PO) number associated with the transaction or shipment referenced in this case. Links the case to the commercial transaction for dispute resolution and credit processing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notified' ;
    rdfs:comment 'Identifies the specific regulatory authority notified in connection with this case when regulatory_notification_flag is True. Supports compliance audit trails and regulatory reporting. [ENUM-REF-CANDIDATE: FDA|USDA|EPA|FSIS|APHIS|OSHA|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether a regulatory authority (FDA, USDA, EPA, FSIS, or APHIS) has been notified about this case. Required for food safety incidents, MRL exceedances, and FSMA mandatory reporting events.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the corrective action taken and resolution provided to the customer, including any product replacements, credits, process changes, or regulatory notifications made.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorical classification of how the case was resolved (e.g., product replacement, credit memo issued, corrective action implemented, regulatory escalation). Supports resolution trend analytics and GFSI audit reporting. [ENUM-REF-CANDIDATE: replacement|credit_memo|refund|corrective_action|information_provided|no_action|escalated_to_regulator — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetail rdf:type rdf:Property ;
    rdfs:label 'Root Cause Detail' ;
    rdfs:comment 'Free-text narrative providing detailed explanation of the identified root cause, including contributing factors, investigation findings, and supporting evidence. Complements the root_cause_category with granular context.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCaseCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Code' ;
    rdfs:comment 'The native Salesforce CRM case record identifier (15 or 18 character Salesforce ID) for this case. Enables bidirectional integration between the lakehouse silver layer and Salesforce CRM for sales pipeline and partner management.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Number' ;
    rdfs:comment 'The SAP S/4HANA Quality Management (QM) module notification number linked to this case when a formal quality notification has been raised. Supports cross-system traceability between customer-facing cases and internal QM processes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'The actual number of hours taken to resolve this case from opening to closure. Compared against sla_target_hours to determine SLA compliance and populate the sla_breach_flag.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this case breached the agreed Service Level Agreement (SLA) response or resolution time. True when the case was not resolved within the contracted SLA window. Supports KPI reporting and customer satisfaction management.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contracted SLA target resolution time in hours for this case, determined by case priority and customer account tier. Used to calculate SLA compliance and breach status.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief, human-readable title or subject line summarizing the nature of the customer case, used for quick identification in case lists and dashboards.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRecordId rdf:type rdf:Property ;
    rdfs:label 'Certification Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer certification record in the Agriculture data lakehouse. Primary key for the certification_record product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificationRecord .

ind:internalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal review of buyer certification records (GlobalG.A.P., organic, FSMA) in Agriculture requires a traceable link to the reviewing employee for audit trails, regulatory compliance documentation, a' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sustainabilityAuditId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Audit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_audit. Business justification: Customer certification records are issued as outcomes of sustainability audits. Linking certification_record to the sustainability_audit that produced or verified it provides a complete audit trail re' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainabilityAudit .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date on which the most recent certification audit or inspection was conducted by the certifying body. Supports audit scheduling, compliance monitoring, and GFSI-aligned supplier qualification reviews.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Grade or rating assigned by the certifying body following the most recent audit (e.g., A, B, C for SQF; Excellent, Good, Acceptable for BRC). Determines preferential pricing tiers and GFSI supply chain qualification levels.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numeric score achieved during the most recent certification audit, expressed as a percentage or points total per the certifying body\'s scoring methodology. Supports quantitative supplier performance benchmarking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Ref' ;
    rdfs:comment 'Reference path or URI to the scanned certificate document stored in the enterprise document management system or data lake. Enables direct access to the original certificate for audit, trade, and compliance verification purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Textual description of the products, processes, sites, or activities covered by the certification (e.g., \'Fresh fruit and vegetable packing and storage\', \'Poultry processing and cold chain\'). Critical for MRL verification and COOL compliance scoping.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification record. Drives trade eligibility decisions, MRL verification workflows, and GFSI-aligned supply chain qualification gates. Active certifications are required for preferential pricing and COOL compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Classification of the food safety, sustainability, or agricultural certification held by the customer account. Determines trade eligibility and preferential pricing applicability. [ENUM-REF-CANDIDATE: GLOBALG.A.P.|SQF|BRC|IFS|USDA_ORGANIC_NOP|FSMA|ISO_22000|ISCC|FAIR_TRADE_USA|HACCP|ISO_14001|OTHER — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedSiteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Certified Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the certified site\'s location. Required for COOL (Country of Origin Labeling) compliance, import/export eligibility, and MRL jurisdiction determination.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Eligible Flag' ;
    rdfs:comment 'Indicates whether this certification record satisfies COOL (Country of Origin Labeling) requirements for the certified commodity and site. True = COOL eligible; False = not eligible. Drives COOL compliance reporting and trade documentation.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fsma Registration Number' ;
    rdfs:comment 'FDA facility registration number issued under the Food Safety Modernization Act (FSMA). Required for FSMA-registered food facilities and used to verify buyer compliance with FDA import and supply chain requirements.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApOption rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Option' ;
    rdfs:comment 'GLOBALG.A.P. certification option applicable to this record: Option 1 (individual producer), Option 2 (producer group), Group, or Multisite. Relevant only for GLOBALG.A.P. certification type; null for other certification types.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Internal Review Date' ;
    rdfs:comment 'Date on which the internal quality or compliance team completed their review of this certification record. Part of the internal audit trail for GFSI, FSMA, and SOX compliance.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Review Flag' ;
    rdfs:comment 'Indicates whether this certification record has been reviewed and approved by the internal quality or compliance team. True = internally reviewed and approved; False = pending internal review. Supports internal QA workflow management.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformance Count' ;
    rdfs:comment 'Number of major non-conformances identified during the most recent certification audit. Major non-conformances may result in certification suspension and are a critical input to buyer risk management and GFSI qualification decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrlComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s certification scope has been verified as compliant with applicable Maximum Residue Limits (MRL) for the relevant commodity and destination market. True = MRL compliance confirmed; False = not yet verified or non-compliant.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next certification audit or surveillance visit. Used for proactive compliance management and supply chain qualification planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count' ;
    rdfs:comment 'Total number of non-conformances (major and minor) identified during the most recent certification audit. Used for supplier risk scoring and GFSI-aligned supply chain qualification assessments.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicOperationType rdf:type rdf:Property ;
    rdfs:label 'Organic Operation Type' ;
    rdfs:comment 'Type of organic operation certified under the USDA National Organic Program (NOP): producer, handler, processor, retailer, or broker. Applicable only for USDA Organic NOP certification type.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialPricingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Preferential Pricing Eligible Flag' ;
    rdfs:comment 'Indicates whether this certification qualifies the customer account for preferential pricing tiers in the sales and distribution process. True = eligible for preferential pricing; False = standard pricing applies. Integrates with SAP S/4HANA SD pricing conditions.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceCertRecordCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Cert Record Code' ;
    rdfs:comment 'Unique identifier of the corresponding certification record in Salesforce CRM. Enables bidirectional synchronization between the Agriculture data lakehouse and Salesforce for sales pipeline and partner management workflows.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorCertCode rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Cert Code' ;
    rdfs:comment 'SAP S/4HANA QM module vendor certification code associated with this certification record. Used for quality management integration, goods receipt inspection, and procurement qualification in SAP.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Eligibility Flag' ;
    rdfs:comment 'Indicates whether the customer account is currently eligible to trade based on the active status of this certification. True = trade eligible; False = trade blocked pending certification renewal or remediation. Used in order management and supply chain qualification gates.' ;
    rdfs:domain ind:CertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each consent record. Primary key for the consent_record data product within the customer domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Foreign key linking to customer.preference. Business justification: Consent records govern the legal basis for acting on customer preferences — e.g., a marketing opt-in consent record authorizes the corresponding communication preference, or a COOL data processing con' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:privacyNoticeId rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Id' ;
    rdfs:comment 'Reference to the specific privacy notice or consent notice document that was presented to the data subject at the time of consent collection. Links to the privacy notice repository for audit and compliance purposes.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyNotice .

ind:ccpaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable Flag' ;
    rdfs:comment 'Indicates whether the California Consumer Privacy Act (CCPA) applies to this consent record (True), based on the data subject being a California resident. Relevant for US domestic agricultural operations serving California-based food manufacturers and consumers.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The specific communication channel for which consent is being granted or managed. Distinct from collection_method — this represents the channel the data subject is consenting TO receive communications through (e.g., email marketing, SMS alerts for crop advisory, postal mail for regulatory notices).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The mechanism through which consent was collected from the data subject. Includes digital web forms (e.g., Salesforce CRM portal), signed physical or electronic documents, verbal consent with a recording reference, email confirmation links, API-based integrations, or paper-based forms used in field operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The exact date and timestamp when the data subject granted consent. This is the principal business event timestamp for the consent lifecycle and is critical for GDPR audit trails and consent validity calculations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent record. \'granted\' indicates active consent; \'withdrawn\' indicates the data subject has revoked consent; \'pending\' indicates consent request sent but not yet responded to; \'expired\' indicates consent has lapsed past its validity period; \'refused\' indicates the data subject explicitly declined.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent being recorded. Covers marketing email communications, SMS marketing, data sharing with logistics partners (e.g., TMS/WMS providers), agronomic advisory communications, third-party analytics sharing, and customer profiling activities. [ENUM-REF-CANDIDATE: marketing_email|marketing_sms|data_sharing_logistics|agronomic_advisory|third_party_analytics|profiling — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent notice or privacy policy under which consent was collected (e.g., v1.0, v2.3). Enables tracking of consent obtained under different versions of privacy notices, which is critical when privacy policy updates require re-consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Preference Flag' ;
    rdfs:comment 'Indicates whether the customer has provided consent for sharing Country of Origin Labeling (COOL) data with downstream supply chain partners (True). Relevant for agricultural commodity traceability and compliance with USDA COOL regulations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'The number of days for which personal data processed under this consent will be retained after consent withdrawal or expiry. Supports GDPR Article 5(1)(e) storage limitation compliance and automated data deletion workflows.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectType rdf:type rdf:Property ;
    rdfs:label 'Data Subject Type' ;
    rdfs:comment 'Classification of the data subject whose consent is being recorded. Distinguishes between individual B2C consumers, B2B business contacts (food manufacturers, distributors, retailers), employees, supplier contacts, and cooperative members — each subject to different regulatory obligations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether a double opt-in confirmation process was completed (True), where the data subject confirmed their consent via a secondary verification step (e.g., email confirmation link). Double opt-in provides stronger evidence of consent validity for marketing communications.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The date and timestamp when the data subject completed the double opt-in confirmation step. Null if double opt-in was not required or not yet completed. Provides audit evidence for the confirmation event.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether GDPR applies to this consent record (True) based on the data subject\'s jurisdiction and the nature of data processing. Critical for international agricultural trade operations where EU/EEA customers are involved.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device from which consent was submitted via a web form or digital channel. Captured as evidence of consent origin for GDPR audit purposes. May be considered PII in certain jurisdictions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under which personal data is processed as defined by GDPR Article 6. For international agricultural trade operations, this determines whether processing relies on explicit consent, contractual necessity (e.g., FSMA traceability obligations), legal obligation (e.g., USDA/FDA reporting), or legitimate interest.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Indicates whether the consent was obtained through an affirmative opt-in action (True) versus a pre-ticked box or implied consent mechanism (False). GDPR requires explicit opt-in for consent to be valid; this flag supports compliance validation and audit.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Free-text description of the specific data processing purpose for which consent was obtained. Provides granular detail beyond the consent_type classification, such as \'Sharing harvest yield data with logistics partner for route optimization\' or \'Sending weekly agronomic advisory newsletters on IPM practices\'.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingReference rdf:type rdf:Property ;
    rdfs:label 'Recording Reference' ;
    rdfs:comment 'Reference identifier for the audio recording or call log where verbal consent was captured. Applicable when collection_method is \'verbal_recording\'. Links to the call recording system for audit retrieval. Null for non-verbal consent collection methods.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Sent Flag' ;
    rdfs:comment 'Indicates whether a consent renewal reminder communication has been sent to the data subject prior to expiry (True) or not yet sent (False). Supports consent lifecycle management workflows.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires active renewal before the expiry_date (True) or is open-ended without a renewal requirement (False). Drives automated consent renewal workflows and customer communications in Salesforce CRM.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceConsentCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Consent Code' ;
    rdfs:comment 'External identifier for this consent record in Salesforce CRM, which serves as the operational system of record for customer management and sales pipeline. Enables bidirectional synchronization between the Databricks Silver Layer and Salesforce for consent status updates.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCategory rdf:type rdf:Property ;
    rdfs:label 'Third Party Category' ;
    rdfs:comment 'Category of the third party involved in data sharing under this consent. Supports GDPR Article 13 disclosure requirements and enables analytics on consent patterns by partner type across the agricultural supply chain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of the third-party organization with whom data will be shared under this consent, if applicable. Relevant for consents covering data sharing with logistics partners (TMS/WMS providers), agronomic advisory services, or market data providers (e.g., DTN). Null for consents that do not involve third-party data sharing.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string captured at the time of digital consent submission. Provides technical evidence of the device and browser environment used during consent collection, supporting GDPR accountability requirements.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date and timestamp when the data subject withdrew their previously granted consent. Null if consent has not been withdrawn. Upon withdrawal, all downstream data processing activities relying on this consent must cease per GDPR Article 7(3).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'The mechanism through which the data subject withdrew their consent. GDPR Article 7(3) requires that withdrawal be as easy as giving consent. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text or categorized reason provided by the data subject for withdrawing consent. Supports customer relationship management, compliance reporting, and analysis of consent withdrawal patterns to improve data practices.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Foreign key linking to customer.lead. Business justification: When a lead converts, a contact record is created. Tracking the originating lead_id on the contact provides full conversion lineage traceability — essential for CRM analytics (lead source attribution,' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s manager or superior within the same customer organization. Enables organizational hierarchy mapping for enterprise B2B accounts (e.g., a buying agent reporting to a procurement director).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountRole rdf:type rdf:Property ;
    rdfs:label 'Account Role' ;
    rdfs:comment 'The contact\'s functional role within the sales and account management process. Supports Salesforce CRM opportunity management and stakeholder mapping for complex B2B agricultural supply chain deals.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. \'active\' indicates an engaged contact; \'inactive\' indicates a former contact no longer at the organization; \'pending\' indicates awaiting verification; \'do_not_contact\' indicates opt-out or legal restriction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s functional role in the business relationship. \'primary\' is the main account contact; \'technical\' covers agronomists and food safety officers; \'billing\' covers accounts payable; \'regulatory\' covers FSMA/HACCP compliance officers. [ENUM-REF-CANDIDATE: primary|secondary|technical|billing|regulatory|emergency — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional area of the contact within their company (e.g., Procurement, Food Safety, Quality Assurance, Logistics, Agronomy, Finance). Supports targeted communication and segmentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has requested to not be contacted by phone. Enforces compliance with telemarketing regulations and respects contact communication preferences. True = do not call.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used for order confirmations, compliance notifications, FSMA correspondence, and marketing communications subject to GDPR consent.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailBounced rdf:type rdf:Property ;
    rdfs:label 'Email Bounced' ;
    rdfs:comment 'Indicates whether the contact\'s email address has produced a hard bounce, rendering it undeliverable. Used to suppress invalid email addresses from marketing and transactional communications and trigger data quality remediation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailBouncedDate rdf:type rdf:Property ;
    rdfs:label 'Email Bounced Date' ;
    rdfs:comment 'Date on which the contact\'s email address first produced a hard bounce. Used to track data quality degradation over time and prioritize contact record remediation efforts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given (first) name of the individual contact person. Used for personalized communication and CRM correspondence.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Basis' ;
    rdfs:comment 'The GDPR lawful basis under which this contact\'s personal data is processed. Required for all contacts associated with EU/international operations. \'consent\' requires explicit opt-in; \'contract\' applies to contacts involved in active supply agreements; \'legitimate_interest\' applies to B2B prospecting.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds purchasing or contractual decision-making authority at the customer organization. Used by sales teams to prioritize engagement and route proposals through Salesforce CRM opportunity management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFsmaPointOfContact rdf:type rdf:Property ;
    rdfs:label 'Is Fsma Point Of Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated FSMA point of contact at the customer organization. FSMA Section 204 requires traceability recordkeeping contacts to be identified for food safety compliance and regulatory communications with the FDA.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHaccpCoordinator rdf:type rdf:Property ;
    rdfs:label 'Is Haccp Coordinator' ;
    rdfs:comment 'Indicates whether this contact serves as the HACCP coordinator at the customer organization. HACCP coordinators are responsible for food safety plan oversight and are key contacts for quality assurance, audit communications, and corrective action notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary/main point of contact for the associated customer account. Only one contact per customer account should be flagged as primary. Used for default routing of account communications and escalations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact at their organization (e.g., Procurement Manager, Food Safety Officer, Agronomist, Buying Agent, Quality Assurance Director). Used for routing communications and identifying decision-making authority.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) representing the contact\'s preferred language for communications (e.g., en-US, es-MX, fr-FR, pt-BR). Supports multilingual correspondence for global food manufacturer and distributor contacts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, task) associated with this contact in Salesforce CRM. Used to identify dormant contacts, measure engagement health, and trigger re-engagement workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family (last) name of the individual contact person. Combined with first_name to form the full display name for reporting and correspondence.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'The originating channel or event through which this contact was first acquired or identified. Used for marketing attribution, ROI analysis of lead generation programs, and sales pipeline reporting in Salesforce CRM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contact\'s LinkedIn professional profile. Used by sales and account management teams for relationship intelligence, prospecting, and partner engagement via Salesforce CRM integration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the contact has provided explicit consent to receive marketing communications (newsletters, product promotions, agricultural insights). Required under GDPR for international operations and CAN-SPAM for US contacts. True = opted in; False = opted out or no consent given.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Date on which the contact provided explicit marketing consent. Required for GDPR audit trail demonstrating lawful basis for processing personal data for marketing purposes.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'Date on which the contact withdrew marketing consent or requested opt-out. Triggers suppression from all marketing campaigns. Required for GDPR compliance and CAN-SPAM unsubscribe processing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number of the contact in E.164 international format. Used for SMS alerts, two-factor authentication, and field-level communications with agronomists or logistics coordinators.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number of the contact in E.164 international format. Used for urgent supply chain communications, food safety alerts, and account management calls.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred channel for receiving business communications. Drives outreach strategy for sales, compliance notifications, and marketing campaigns. Aligns with GDPR consent management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'External identifier for this contact record in Salesforce CRM, used for bidirectional synchronization between the lakehouse silver layer and the CRM system of record for sales pipeline and partner management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the contact (e.g., Mr., Ms., Dr.). Used in formal correspondence, contract documents, and regulatory communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s location (e.g., America/Chicago, Europe/London). Used to schedule communications, meetings, and automated alerts at appropriate local times for global agricultural supply chain partners.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Cool Preference Id' ;
    rdfs:comment 'Unique system-generated identifier for the COOL preference and compliance record. Primary key for this entity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoolPreference .

ind:acceptableOriginCountries rdf:type rdf:Property ;
    rdfs:label 'Acceptable Origin Countries' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes representing countries of origin that this customer accepts for the specified commodity (e.g., \'USA|CAN|MEX\'). Used to validate inbound commodity sourcing against customer COOL requirements.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'The agreed or required frequency at which COOL compliance audits are conducted for this customer account and commodity type. Drives scheduling of COOL compliance review activities.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must accompany commodity shipments to this customer, confirming origin-specific quality and safety parameters. True = COA required; False = not required.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTier rdf:type rdf:Property ;
    rdfs:label 'Compliance Tier' ;
    rdfs:comment 'The level of COOL compliance rigor required by or agreed with this customer. \'standard\' meets baseline USDA COOL requirements; \'enhanced\' includes additional supplier documentation; \'full_traceability\' requires end-to-end farm-to-retail origin traceability per FSMA Traceability Rule.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolNotes rdf:type rdf:Property ;
    rdfs:label 'Cool Notes' ;
    rdfs:comment 'Free-text field for capturing additional COOL preference details, customer-specific labeling instructions, special regulatory conditions, or compliance exceptions that are not captured by structured fields.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolProgramType rdf:type rdf:Property ;
    rdfs:label 'Cool Program Type' ;
    rdfs:comment 'Classifies whether COOL compliance for this customer and commodity is mandatory under USDA regulations, voluntary, applicable only for export markets, or exempt under retail exemption provisions. Drives compliance workflow routing.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cool Reference Number' ;
    rdfs:comment 'The externally-known or customer-assigned reference number for this COOL preference agreement or compliance record. Used for cross-referencing with customer procurement systems, Salesforce CRM records, or USDA audit documentation.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolViolationCount rdf:type rdf:Property ;
    rdfs:label 'Cool Violation Count' ;
    rdfs:comment 'The cumulative number of COOL compliance violations recorded against this customer preference record since its effective date. Used for risk scoring, escalation triggers, and regulatory reporting to USDA AMS.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires formal COOL documentation (e.g., supplier affidavits, certificates of origin, or audit-ready records) to accompany commodity shipments. True = documentation is mandatory; False = documentation is optional or not required.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalgApComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires that origin suppliers hold GLOBALG.A.P. certification as a condition of COOL compliance. True = GLOBALG.A.P. certification required from origin suppliers; False = not required.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoLabelingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Labeling Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires Genetically Modified Organism (GMO) disclosure labeling in addition to COOL labeling for the specified commodity. True = GMO labeling is required; False = not required. Supports USDA National Bioengineered Food Disclosure Standard compliance.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Label Language Code' ;
    rdfs:comment 'The ISO 639-1 language code (optionally with ISO 3166-1 region subtag) specifying the language in which COOL labels must be printed for this customer (e.g., \'en\', \'es\', \'fr-CA\'). Supports bilingual or multilingual labeling requirements for export or cross-border distribution.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPlacementRequirement rdf:type rdf:Property ;
    rdfs:label 'Label Placement Requirement' ;
    rdfs:comment 'Specifies where on the product packaging the COOL label must appear per this customer\'s requirements. \'principal_display_panel\' is the most prominent face; \'information_panel\' is the secondary panel; \'any_panel\' allows flexibility; \'customer_specified\' requires reference to customer SOP documentation.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingFormat rdf:type rdf:Property ;
    rdfs:label 'Labeling Format' ;
    rdfs:comment 'The preferred COOL labeling format for this customer and commodity. \'full_origin\' indicates a single country of origin; \'mixed_origin\' indicates multiple countries; \'derived_from\' is used for processed commodities; \'product_of\' denotes full production in one country; \'born_raised_slaughtered\' applies to muscle cut beef and pork per USDA COOL rules.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'The date on which the most recent COOL compliance review was completed for this customer and commodity. Used to calculate next review due date and to support USDA audit readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'The date of the most recent COOL compliance violation recorded for this customer and commodity. Null if no violations have occurred. Supports regulatory risk management and customer compliance scoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrlComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires that commodities from all listed origin countries comply with Maximum Residue Limit (MRL) standards as set by the EPA and Codex Alimentarius. True = MRL compliance documentation required; False = not required.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'The scheduled date by which the next COOL compliance review must be completed for this customer and commodity. Derived from last_compliance_review_date and audit_frequency but stored explicitly for operational scheduling and alerting.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organicOriginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Origin Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires that the commodity\'s country of origin also holds USDA National Organic Program (NOP) certification or equivalent organic certification. True = organic-certified origin required; False = not required.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of this COOL preference record. \'active\' indicates the record is in force; \'pending_review\' indicates it is under compliance review; \'suspended\' indicates a temporary hold pending regulatory clarification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Preferred Origin Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s single most preferred country of origin for the specified commodity when a preference ranking is required (e.g., \'USA\' for domestically sourced product).' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether USDA or other regulatory bodies must be formally notified in the event of a COOL compliance breach for this customer and commodity. True = regulatory notification is mandatory; False = internal resolution only.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedOriginCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Origin Countries' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes representing countries of origin that this customer explicitly prohibits for the specified commodity. Supports compliance screening and order validation workflows.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Record Code' ;
    rdfs:comment 'The corresponding record identifier in Salesforce CRM for this COOL preference record, enabling bidirectional synchronization between the lakehouse and the CRM system of record for customer relationship management.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierAffidavitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Affidavit Required Flag' ;
    rdfs:comment 'Indicates whether this customer requires a signed supplier affidavit attesting to the country of origin for each commodity lot delivered. True = affidavit required per shipment or lot; False = not required. Supports USDA COOL audit trail requirements.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traceabilitySystemCode rdf:type rdf:Property ;
    rdfs:label 'Traceability System Code' ;
    rdfs:comment 'Code identifying the traceability system or standard used to track origin for this customer\'s commodity (e.g., \'RFID\', \'GS1_EPCIS\', \'FMIS\', \'MANUAL\'). Supports FSMA Section 204 traceability lot code requirements and integration with Manhattan Associates WMS and SAP S/4HANA QM.' ;
    rdfs:domain ind:CoolPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Agriculture lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'Foreign key linking to customer.onboarding. Business justification: Credit profiles are typically created or first assessed during the customer onboarding process. The onboarding record has credit_assessment_status and credit_assessment_date fields, indicating a direc' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Onboarding .

ind:reconciliationGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: In SAP AR subledger design, each customer credit profile is linked to a reconciliation GL account (AR trade receivables). Agriculture finance teams require this link for AR aging reports, period-close' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit capacity available to the customer, calculated as credit_limit minus outstanding_balance minus any open sales order exposure. Stored as a snapshot value refreshed by the AR integration pipeline. Negative values indicate the customer has exceeded their credit limit.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAnalystNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Analyst Notes' ;
    rdfs:comment 'Free-text notes entered by the credit analyst documenting the rationale for credit decisions, observations from customer financial reviews, special conditions, or escalation context. Supports audit trail and credit committee review processes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date on which the credit hold was placed on the customer account. Populated when credit_hold_flag is True. Used to track hold duration and escalation timelines.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer account is currently placed on credit hold, blocking new sales order processing and shipment release. When True, all outbound order fulfillment is suspended pending credit resolution. Corresponds to SAP S/4HANA credit block indicator (VBAK-CMGST / KNKK-CTLPC).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the customer account is on credit hold. Populated when credit_hold_flag is True. \'compliance_hold\' covers FSMA, GLOBALG.A.P., or regulatory non-compliance scenarios that trigger a commercial hold. [ENUM-REF-CANDIDATE: overdue_balance|credit_limit_exceeded|payment_default|legal_dispute|manual_hold|compliance_hold — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Release Date' ;
    rdfs:comment 'Date on which the most recent credit hold was released and normal trading resumed. Null if the account is currently on hold or has never been held. Used for hold duration analysis and collections performance reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Indicates whether the customer account is covered by a trade credit insurance policy, which mitigates the company\'s exposure to non-payment risk. When True, the insured credit limit and policy details should be referenced in the credit analyst notes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Reference number of the trade credit insurance policy covering this customer account. Populated only when credit_insurance_flag is True. Used for claims processing and insurer reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Effective Date' ;
    rdfs:comment 'Date from which the current credit limit became effective. Enables historical tracking of credit limit changes and supports audit trail requirements for credit management governance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Expiry Date' ;
    rdfs:comment 'Date on which the current approved credit limit expires and requires renewal or re-approval. Null indicates an open-ended credit limit with no scheduled expiry. Used to trigger credit renewal workflows.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Scheduled or next-due date for the periodic credit review of this customer account. Credit analysts use this date to trigger reassessment of credit limits, ratings, and payment terms. Typically set annually or triggered by payment events.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Category' ;
    rdfs:comment 'Aggregated credit risk classification for the customer account, derived from internal rating, DSO, payment history, and external rating inputs. Used for portfolio-level credit risk reporting, provisioning under IFRS 9 Expected Credit Loss, and prioritization of credit analyst workload.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCountOpen rdf:type rdf:Property ;
    rdfs:label 'Dispute Count Open' ;
    rdfs:comment 'Number of currently open invoice disputes raised by or against the customer. Elevated dispute counts may indicate billing issues, quality disputes (e.g., COA failures, MRL exceedances), or credit risk signals. Sourced from SAP S/4HANA FI-AR dispute management or Oracle NetSuite AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsoDays rdf:type rdf:Property ;
    rdfs:label 'Dso Days' ;
    rdfs:comment 'Days Sales Outstanding — the average number of days the customer takes to pay invoices, calculated over the trailing measurement period. A key accounts receivable efficiency and credit risk KPI. Sourced from SAP S/4HANA FI-AR aging analysis or Oracle NetSuite AR reports. High DSO values may trigger credit review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoMeasurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dso Measurement Period Days' ;
    rdfs:comment 'The rolling lookback period in calendar days over which the DSO metric was calculated (e.g., 90, 180, 365). Provides context for interpreting the dso_days value and ensures consistent comparison across customers.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'Credit rating or score sourced from an external credit bureau or agency such as Dun & Bradstreet (D&B PAYDEX score), Experian Business, or Equifax Commercial. Stored as a free-form string to accommodate varying agency rating scales. Supplements the internal rating for credit limit decisions and risk classification.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingAgency rdf:type rdf:Property ;
    rdfs:label 'External Rating Agency' ;
    rdfs:comment 'Name of the third-party credit bureau or rating agency that provided the external_credit_rating. Enables traceability and comparison across multiple agency sources when multiple ratings are maintained. [ENUM-REF-CANDIDATE: Dun & Bradstreet|Experian|Equifax|Moody\'s|S&P|Fitch|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'Internally assigned credit risk rating for the customer, reflecting the company\'s own assessment of payment reliability and financial health. Rating scale: A1 (lowest risk) through D (highest risk / default). Assigned by the credit analyst and reviewed periodically. Used for credit limit setting and risk-based pricing decisions. [ENUM-REF-CANDIDATE: A1|A2|A3|B1|B2|B3|C1|C2|D — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Monetary value of the most recent payment received from the customer, in the account base currency. Provides context alongside last_payment_date for assessing payment behavior and partial payment patterns.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the customer against an outstanding invoice or account balance. Sourced from SAP S/4HANA FI-AR clearing records or Oracle NetSuite AR payment history. Used in DSO calculation and payment behavior analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netsuiteCustomerInternalCode rdf:type rdf:Property ;
    rdfs:label 'Netsuite Customer Internal Code' ;
    rdfs:comment 'The internal customer ID as maintained in Oracle NetSuite AR, used for cross-system reconciliation of credit exposure data between SAP S/4HANA and NetSuite for customers managed in both systems.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openSalesOrderExposure rdf:type rdf:Property ;
    rdfs:label 'Open Sales Order Exposure' ;
    rdfs:comment 'Total value of open, unshipped, or unbilled sales orders currently outstanding for the customer. Included in credit exposure calculations alongside the AR balance to determine true credit utilization. Sourced from SAP S/4HANA SD open order value (VBAK/VBAP).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current total open accounts receivable balance for the customer, including all unpaid invoices and debit memos. Sourced from SAP S/4HANA FI-AR open item management or Oracle NetSuite AR. Used to calculate available credit and Days Sales Outstanding (DSO).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that have passed their due date and remain unpaid, in the account base currency. A key indicator of collection risk. Sourced from SAP S/4HANA FI-AR aging buckets or Oracle NetSuite AR aging report.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueDaysBucket rdf:type rdf:Property ;
    rdfs:label 'Overdue Days Bucket' ;
    rdfs:comment 'Aging bucket classification for the customer\'s overdue balance, aligned with standard AR aging analysis periods: current (not yet due), 1–30 days, 31–60 days, 61–90 days, 91–120 days, over 120 days. Drives collections prioritization and IFRS 9 provisioning stage assignment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBehaviorScore rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the customer\'s historical payment behavior, derived from on-time payment rate, average days late, and dispute frequency. Higher scores indicate better payment discipline. Used to calibrate internal credit ratings and credit limit decisions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms code assigned to this customer credit profile, governing invoice due dates and early payment discount eligibility (e.g., NET30, NET60, NET90, COD, CIA, 2/10NET30). Sourced from SAP S/4HANA payment terms configuration (T052). Drives accounts receivable aging and cash flow forecasting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the credit profile. \'active\' indicates normal trading; \'suspended\' indicates a temporary hold; \'under_review\' indicates a scheduled or triggered credit review is in progress; \'pending_approval\' indicates a new or revised profile awaiting credit committee sign-off; \'closed\' indicates the profile has been deactivated.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'The customer credit account number as maintained in SAP S/4HANA FI/AR credit management (KNKK table / FD32 transaction). Used for system-of-record traceability and reconciliation between the lakehouse silver layer and SAP.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerPool rdf:type rdf:Property ;
    rdfs:label 'Account Manager Pool' ;
    rdfs:comment 'Name or code of the designated account manager team or pool responsible for accounts in this segment (e.g., Enterprise Ag Sales Team, Export Markets Group, Cooperative Relations Team). Used for Salesforce CRM territory assignment and SAP SuccessFactors workforce planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agronomicServiceTier rdf:type rdf:Property ;
    rdfs:label 'Agronomic Service Tier' ;
    rdfs:comment 'Level of agronomic advisory and technical support services allocated to accounts in this segment. PREMIUM = dedicated agronomist, field visits, VRA prescriptions; STANDARD = shared agronomist pool, periodic consultations; BASIC = self-service digital tools only; NONE = no agronomic services provided.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which customer accounts are assigned to this segment. MANUAL = assigned by account manager or sales operations; RULE_BASED = automatically assigned based on defined criteria (revenue band, geography, certification); ML_SCORED = assigned via machine learning scoring model based on behavioral and transactional data.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEligible rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligible' ;
    rdfs:comment 'Indicates whether accounts assigned to this segment are eligible for Salesforce CRM marketing campaigns and targeted outreach programs. True = eligible for campaign inclusion; False = excluded from campaign targeting (e.g., inactive or archived segments).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolLabelingRequired rdf:type rdf:Property ;
    rdfs:label 'Cool Labeling Required' ;
    rdfs:comment 'Indicates whether COOL (Country of Origin Labeling) documentation and labeling compliance is required for products supplied to accounts in this segment. Mandatory for retail and export segments under USDA COOL regulations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Default credit limit in USD applied to accounts assigned to this segment. Used as the baseline credit exposure threshold in SAP S/4HANA FI credit management (FD32) and Oracle NetSuite AR. Individual account credit limits may override this segment-level default.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment as recorded in Salesforce CRM. Enables bidirectional synchronization between the Agriculture data platform (Silver Layer) and Salesforce CRM for pipeline targeting and account management. Null if not yet synchronized.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Required' ;
    rdfs:comment 'Indicates whether FSMA (Food Safety Modernization Act) compliance documentation is required from customer accounts in this segment. Relevant for food manufacturer and distributor segments subject to FDA FSMA Produce Safety Rule and Preventive Controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic market scope defining where this segment applies (e.g., domestic US, North America, LATAM Export, EU Export, Global). Supports Salesforce CRM regional campaign targeting and COOL (Country of Origin Labeling) compliance tracking for export segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApCertRequired rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Cert Required' ;
    rdfs:comment 'Indicates whether GLOBALG.A.P. (Global Good Agricultural Practices) certification is a mandatory requirement for customer accounts assigned to this segment. True = certification required for onboarding and retention; False = certification not mandated.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Default International Commercial Terms (Incoterms 2020) applicable to sales transactions for accounts in this segment. Governs risk transfer and freight responsibility. Particularly relevant for export distributor segments. Drives SAP SD delivery and billing document configuration. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSegmentScore rdf:type rdf:Property ;
    rdfs:label 'Max Segment Score' ;
    rdfs:comment 'Maximum ML-derived or rule-based score threshold (0.00–100.00) defining the upper bound for account assignment to this segment. Null indicates no upper bound (e.g., top-tier strategic segment). Used with min_segment_score to define the qualifying score range.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSegmentScore rdf:type rdf:Property ;
    rdfs:label 'Min Segment Score' ;
    rdfs:comment 'Minimum ML-derived or rule-based score threshold (0.00–100.00) required for a customer account to qualify for assignment to this segment. Used in conjunction with max_segment_score to define the score band for this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the ML scoring model used when assignment_method is ML_SCORED. Enables reproducibility, model governance, and audit traceability for AI-driven segment assignments. Null when assignment_method is MANUAL or RULE_BASED.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertRequired rdf:type rdf:Property ;
    rdfs:label 'Organic Cert Required' ;
    rdfs:comment 'Indicates whether USDA National Organic Program (NOP) certification is required for accounts in this segment. Applies to organic produce buyers and specialty food manufacturers requiring certified organic supply.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTierCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Code' ;
    rdfs:comment 'SAP SD pricing condition tier code applicable to all accounts assigned to this segment (e.g., PT-GOLD, PT-SILVER, PT-STANDARD). Drives price list determination, volume discount schedules, and contract pricing in SAP S/4HANA SD module.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max Usd' ;
    rdfs:comment 'Maximum annual revenue threshold (in USD) for a customer account to qualify for this segment. Null indicates no upper bound (e.g., for the highest-tier strategic segment). Used in conjunction with revenue_band_min_usd for rule-based segment assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min Usd' ;
    rdfs:comment 'Minimum annual revenue threshold (in USD) for a customer account to qualify for this segment. Used as a rule-based assignment criterion alongside revenue_band_max_usd. Supports SAP SD pricing tier determination and Salesforce CRM pipeline segmentation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which segment criteria, account assignments, and scoring thresholds are reviewed and recalibrated by the sales operations or data governance team. Supports proactive segment management and CRM pipeline accuracy.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Group' ;
    rdfs:comment 'SAP S/4HANA SD module customer group code (field: KDGRP) mapped to this segment. Drives pricing condition determination, output determination, and account assignment in SAP SD. Aligns segment definitions with SAP master data for seamless ERP integration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the segment (e.g., LFM-001, REG-COOP, EXP-DIST). Used as the business key in Salesforce CRM campaign targeting and SAP SD pricing condition determination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative describing the business characteristics, target profile, and strategic purpose of this customer segment. Supports sales team onboarding and CRM campaign briefing.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the market segment (e.g., Large Food Manufacturer, Regional Cooperative, Direct Farm Consumer, Export Distributor). Used in Salesforce CRM pipeline targeting and reporting dashboards.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. Active segments are available for account assignment and CRM campaign targeting. Draft segments are under review. Archived segments are retained for historical analysis only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Strategic importance tier assigned to the segment, driving service level, account manager allocation, and agronomic support intensity. STRATEGIC = top-tier enterprise accounts; PREFERRED = high-value recurring buyers; STANDARD = general commercial accounts; EMERGING = growth-stage prospects; INACTIVE = dormant segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Broad classification of the segment by commercial relationship model: B2B (business-to-business food manufacturers, distributors, wholesalers), B2C (direct farm consumers), B2G (government/institutional buyers), COOPERATIVE (agricultural cooperatives), EXPORT (international export distributors).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sqfCertRequired rdf:type rdf:Property ;
    rdfs:label 'Sqf Cert Required' ;
    rdfs:comment 'Indicates whether SQF (Safe Quality Food) certification is a mandatory requirement for customer accounts in this segment. Applies primarily to food manufacturer and distributor segments. True = SQF certification required; False = not required.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentMt rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Mt' ;
    rdfs:comment 'Minimum annual purchase volume commitment in Metric Tons (MT) expected from accounts in this segment. Used to qualify accounts for segment-specific pricing tiers and contract terms. Null if no volume commitment is required for this segment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingContactId rdf:type rdf:Property ;
    rdfs:label 'Receiving Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Each delivery location in agriculture (grain elevator, cold storage, processing facility) has a designated receiving contact responsible for coordinating deliveries, signing bills of lading, and manag' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:sustainabilityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_certification. Business justification: Receiving facilities must hold active sustainability certifications (organic handler, GFSI, GlobalG.A.P.) to accept certified commodities. Linking delivery_location to sustainability_certification ena' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainabilityCertification .

ind:appointmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Appointment Required Flag' ;
    rdfs:comment 'Indicates whether a scheduled delivery appointment is required before a carrier can deliver to this location. When true, the TMS must generate an appointment request prior to dispatch.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bolDeliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Bol Delivery Instructions' ;
    rdfs:comment 'Free-text delivery instructions printed on the Bill of Lading (BOL) for this location, such as gate access codes, dock assignment rules, required check-in procedures, or special unloading requirements. Critical for carrier compliance at receiving.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockCount rdf:type rdf:Property ;
    rdfs:label 'Dock Count' ;
    rdfs:comment 'Total number of loading and unloading dock doors available at this receiving location. Used for capacity planning, appointment scheduling, and throughput analysis in the WMS.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaFacilityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fsma Facility Registration Number' ;
    rdfs:comment 'FDA-issued facility registration number under the Food Safety Modernization Act (FSMA) for food facilities that manufacture, process, pack, or hold food for human or animal consumption. Required for FSMA traceability compliance and Prior Notice submissions.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Accepted Flag' ;
    rdfs:comment 'Indicates whether this delivery location is authorized and equipped to receive hazardous materials such as agricultural chemicals, pesticides, or fertilizers regulated under EPA and DOT standards.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Short alphanumeric business identifier for the delivery location used in ERP, WMS, and TMS systems for routing and order fulfillment. Corresponds to the SAP S/4HANA SD ship-to party code.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name for the delivery and receiving location, such as \'Chicago Cold Storage Dock 3\', \'Midwest Grain Elevator — Receiving\', or \'Plant A Food Manufacturing Dock\'. Used in shipping documents and BOL instructions.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the delivery location. Inactive or suspended locations must not be used for new shipment routing. Pending approval locations are awaiting compliance verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Operational classification of the receiving facility. Determines applicable compliance requirements, commodity acceptance rules, and logistics handling procedures. [ENUM-REF-CANDIDATE: grain_elevator|cold_storage|food_manufacturing_plant|distribution_center|retail_hub|cooperative_facility|farm_direct — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that this location can maintain for cold chain storage. Used alongside min_temperature_c to define the acceptable temperature range for perishable commodity receiving.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Weight Kg' ;
    rdfs:comment 'Maximum gross vehicle weight in kilograms that the facility\'s access roads, docks, or receiving infrastructure can accommodate. Used by TMS to validate carrier vehicle selection and prevent infrastructure damage.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that this location can maintain for cold chain storage. Applicable only when temperature_controlled_flag is true. Used to validate commodity compatibility for perishable shipments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingDays rdf:type rdf:Property ;
    rdfs:label 'Receiving Days' ;
    rdfs:comment 'Days of the week on which this location accepts deliveries, expressed as a comma-separated list (e.g., \'MON,TUE,WED,THU,FRI\'). Used for carrier scheduling and delivery appointment planning.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingHoursClose rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours Close' ;
    rdfs:comment 'Scheduled closing time for receiving operations at this location in HH:MM (24-hour) format. Deliveries arriving after this time may be refused or require special arrangement.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingHoursOpen rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours Open' ;
    rdfs:comment 'Scheduled opening time for receiving operations at this location in HH:MM (24-hour) format. Used by TMS and carrier scheduling to ensure deliveries are dispatched within the facility\'s operating window.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Location Code' ;
    rdfs:comment 'Salesforce CRM record ID for this delivery location as stored in the Salesforce account or contact hierarchy. Enables bidirectional synchronization between the CRM sales pipeline and the operational delivery location master.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapShipToPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Ship To Party Number' ;
    rdfs:comment 'SAP S/4HANA SD module ship-to party number corresponding to this delivery location. Used for ERP order-to-cash integration, delivery document creation, and outbound shipment processing.' ;
    rdfs:domain ind:DeliveryLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this delivery location has temperature-controlled receiving and storage capability for perishable commodities such as fresh produce, dairy, or meat. Required for cold chain compliance and HACCP documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Establishment Number' ;
    rdfs:comment 'USDA Food Safety and Inspection Service (FSIS) establishment number assigned to meat, poultry, or egg product processing facilities. Required for FSIS-regulated shipments and must appear on shipping labels and BOL documents.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedAccountId rdf:type rdf:Property ;
    rdfs:label 'Converted Account Id' ;
    rdfs:comment 'Identifier of the customer account created when this lead was successfully converted. Populated only when lead_status = \'converted\'. Enables traceability from prospect to paying customer for pipeline attribution and ROI analysis.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:leadAssignedSalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Assigned Sales Rep Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Employee Id' ;
    rdfs:comment 'Identifier of the internal sales representative responsible for pursuing and qualifying this lead. References the workforce/employee domain for rep profile and territory assignment.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: FK linking lead to target customer segment. Leads are qualified and classified by which customer segment they would belong to if converted (e.g., \'Large Food Manufacturer\', \'Organic Retailer\'). This e' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:annualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Usd' ;
    rdfs:comment 'Estimated or reported annual revenue of the prospect organization in US dollars. Used for lead scoring, customer segmentation, and prioritization of enterprise vs. mid-market vs. SMB prospects.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Comma-separated list of food safety or sustainability certifications the prospect requires from suppliers (e.g., GLOBALG.A.P., SQF, BRC, USDA Organic, FSMA, HACCP, ISO 22000). Critical for qualification and supply chain matching.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal or trade name of the prospective organization (e.g., food manufacturer, distributor, cooperative, wholesaler, retailer) being pursued as a potential customer.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name of the primary contact person at the prospective organization, as captured at the point of lead acquisition.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name (surname) of the primary contact person at the prospective organization, as captured at the point of lead acquisition.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Title' ;
    rdfs:comment 'Professional job title or role of the primary contact at the prospect organization (e.g., Procurement Manager, Head of Agronomy, VP Supply Chain).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date on which the lead was formally converted to a customer account. Populated only when lead_status = \'converted\'. Used to calculate lead-to-customer conversion cycle time and sales pipeline velocity metrics.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code explaining why a lead was disqualified from the sales pipeline. Populated only when lead_status = \'disqualified\'. Used for pipeline quality analysis and lead source effectiveness reporting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Volume' ;
    rdfs:comment 'Prospect\'s estimated annual purchase volume expressed in the unit of measure specified in volume_uom. Used for lead scoring, sales prioritization, and revenue forecasting. Sourced from prospect self-disclosure or market intelligence.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Sales representative\'s estimated date by which this lead is expected to convert to a qualified opportunity or customer account. Used for pipeline forecasting and sales cycle management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstContactDate rdf:type rdf:Property ;
    rdfs:label 'First Contact Date' ;
    rdfs:comment 'Date on which the first outreach or contact attempt was made to the prospect by the assigned sales representative. Used to measure response time and sales activity compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broad geographic region where the prospect operates (e.g., Midwest, Southeast, Great Plains, Pacific Northwest). Used for regional market analysis and USDA agricultural district alignment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Qualitative grade assigned to the lead based on fit with ideal customer profile (A = best fit, D = poor fit). Complements the numeric lead_score with a categorical assessment used by sales management for pipeline prioritization.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle stage of the lead within the agricultural sales pipeline. \'new\' = freshly captured; \'contacted\' = initial outreach made; \'qualified\' = meets purchase criteria; \'converted\' = activated as paying customer account; \'disqualified\' = not a viable prospect.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Terms' ;
    rdfs:comment 'Prospect\'s preferred commercial delivery terms for agricultural commodity shipments. FOB = Free On Board, CIF = Cost Insurance and Freight, DAP = Delivered at Place, EXW = Ex Works. Informs logistics and pricing negotiations.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospective customer by business model and role in the agricultural supply chain. Determines the appropriate sales approach, pricing tier, and contract structure. [ENUM-REF-CANDIDATE: food_manufacturer|distributor|wholesaler|retailer|cooperative|direct_consumer|processor — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes captured by the sales representative during the lead qualification process, documenting key findings, prospect requirements, competitive landscape, and next steps.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or market-based sales territory to which this lead is assigned (e.g., \'Midwest Grain Belt\', \'Southeast Produce\', \'Pacific Northwest\'). Used for territory performance reporting and rep workload balancing.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceLeadCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Lead Code' ;
    rdfs:comment 'External lead identifier assigned by Salesforce CRM, used to cross-reference and synchronize lead records between the lakehouse and the Salesforce sales pipeline system.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score (typically 0–100) representing the lead\'s likelihood to convert to a paying customer, calculated by Salesforce CRM based on engagement signals, firmographic data, commodity interest alignment, and estimated purchase volume.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Specific event, campaign, or program name that generated the lead (e.g., \'Commodity Classic 2024\', \'World Ag Expo 2024\', \'USDA MAP Grant Campaign Q1\'). Provides granular attribution beyond the lead_source category.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'Reference identifier of the originating Salesforce CRM opportunity that was converted to trigger this onboarding workflow. Enables traceability from sales pipeline to customer activation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'Actual date on which the customer account was fully activated and cleared for first commodity shipment. Populated upon completion of all onboarding stages. Compared against target_go_live_date to measure onboarding cycle time performance.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit' ;
    rdfs:comment 'Credit limit (in the account\'s operating currency) approved for the customer during the onboarding credit assessment. Feeds into SAP S/4HANA FI credit management configuration for the customer master. Sensitive financial data.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Functional team currently responsible for the active onboarding stage. Enables workload routing and escalation management across Customer Success, Credit Risk, Legal, IT/EDI, Sales, Compliance, and Finance teams. [ENUM-REF-CANDIDATE: customer_success|credit_risk|legal|it_edi|sales|compliance|finance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIssueCategory rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Category' ;
    rdfs:comment 'Categorical classification of the blocking issue type, enabling reporting on root causes of onboarding delays. Used for process improvement analytics and SLA breach analysis. [ENUM-REF-CANDIDATE: documentation|credit|legal|it_system|compliance|customer_response|internal_approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Description' ;
    rdfs:comment 'Free-text description of the current blocking issue preventing the onboarding workflow from advancing. Populated when onboarding_status is \'blocked\'. Examples include: missing KYC documentation, failed credit assessment, unsigned contract, FSMA registration not found.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Date' ;
    rdfs:comment 'Date on which all required customer certifications were verified as current and valid. Null if certification verification has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Flag' ;
    rdfs:comment 'Indicates whether all required customer certifications (e.g., GLOBALG.A.P. buyer certification, organic certification, SQF, BRC, GFSI) have been verified and are current. Certification verification is required before commodity shipment for regulated product categories.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractExecutedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Executed Date' ;
    rdfs:comment 'Date on which the master supply agreement or customer contract was fully executed by both parties. Null if contract has not yet been executed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Executed Flag' ;
    rdfs:comment 'Indicates whether the master supply agreement or customer contract has been fully executed (signed by both parties). Contract execution is a prerequisite for SAP customer master creation and first commodity shipment.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolPreferenceCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Preference Captured Flag' ;
    rdfs:comment 'Indicates whether the customer\'s Country of Origin Labeling (COOL) preferences have been captured and recorded. COOL preference capture is a mandatory onboarding step for agricultural commodity customers under USDA COOL regulations (7 CFR Part 60/65).' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolPreferenceDate rdf:type rdf:Property ;
    rdfs:label 'Cool Preference Date' ;
    rdfs:comment 'Date on which the customer\'s COOL preferences were formally captured and recorded. Null if COOL preference capture has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Date' ;
    rdfs:comment 'Date on which the credit risk assessment was completed. Null if credit assessment has not yet been performed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Outcome of the credit risk assessment for the new customer account. \'approved\' enables standard credit terms; \'conditionally_approved\' may require prepayment or reduced credit limit; \'declined\' blocks commodity shipment on credit terms.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediSetupCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Completed Flag' ;
    rdfs:comment 'Indicates whether the Electronic Data Interchange (EDI) integration between the customer\'s systems and the company\'s SAP S/4HANA SD module has been configured and tested. EDI setup enables automated purchase order and invoice exchange.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediSetupDate rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Date' ;
    rdfs:comment 'Date on which the EDI integration was successfully configured and tested. Null if EDI setup has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstOrderReadyFlag rdf:type rdf:Property ;
    rdfs:label 'First Order Ready Flag' ;
    rdfs:comment 'Indicates whether all onboarding stages have been completed and the customer account is cleared for first commodity shipment. This is the final gate flag that enables Sales Order (SO) creation in SAP S/4HANA SD.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaFacilityVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Facility Verified Date' ;
    rdfs:comment 'Date on which the customer\'s FSMA facility registration was verified. Null if FSMA verification has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaFacilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Facility Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s facility has been verified as registered with the FDA under the Food Safety Modernization Act (FSMA). FSMA facility verification is mandatory before any food commodity can be shipped to the customer\'s facility.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Date' ;
    rdfs:comment 'Date on which the KYC verification was completed and approved. Null if KYC has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether the Know Your Customer (KYC) identity and business verification step has been completed for this customer. KYC verification confirms legal entity status, ownership structure, and regulatory standing before credit and contract steps proceed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadConversionDate rdf:type rdf:Property ;
    rdfs:label 'Lead Conversion Date' ;
    rdfs:comment 'Date on which the sales lead or prospect was formally converted to a customer account, triggering the onboarding workflow. Sourced from Salesforce CRM opportunity close date.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Number' ;
    rdfs:comment 'Externally-visible business identifier for the onboarding case, used in communications with the customer and internal teams. Format: ONB-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle state of the onboarding workflow. \'in_progress\' indicates active processing; \'blocked\' indicates a blocking issue is preventing advancement; \'completed\' indicates all steps are done and the customer is activated; \'cancelled\' indicates the process was terminated; \'on_hold\' indicates temporarily paused pending external input.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding workflow indicating whether this is a brand-new customer activation, a reactivation of a dormant account, an upgrade to a higher account tier, addition of a subsidiary under an existing parent, or onboarding of a channel partner.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceActivatedDate rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activated Date' ;
    rdfs:comment 'Date on which the Salesforce CRM account was activated. Null if Salesforce activation has not yet been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceActivatedFlag rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activated Flag' ;
    rdfs:comment 'Indicates whether the customer account has been activated in Salesforce CRM, enabling sales pipeline management, partner relationship tracking, and customer communication workflows.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapCustomerMasterCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Master Created Flag' ;
    rdfs:comment 'Indicates whether the customer master record has been created in SAP S/4HANA SD module. SAP customer master creation is required before any sales orders or commodity shipments can be processed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapCustomerMasterDate rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Master Date' ;
    rdfs:comment 'Date on which the customer master record was created in SAP S/4HANA. Null if SAP master has not yet been created.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapSalesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Org Code' ;
    rdfs:comment 'SAP S/4HANA Sales Organization code under which the customer master will be created. Determines pricing procedures, distribution channels, and division assignments for the customer in SAP SD.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current active stage in the end-to-end onboarding workflow. Stages progress from lead conversion through Know Your Customer (KYC) verification, credit assessment, contract execution, Electronic Data Interchange (EDI) setup, SAP S/4HANA customer master creation, Salesforce account activation, Country of Origin Labeling (COOL) preference capture, certification verification, and finally first order readiness. [ENUM-REF-CANDIDATE: lead_conversion|kyc_verification|credit_assessment|contract_execution|edi_setup|sap_master_creation|salesforce_activation|cool_preference_capture|certification_verification|first_order_readiness — promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'Planned date by which the customer onboarding should be fully completed and the account activated for first commodity shipment. Used for SLA tracking and resource planning.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bagWeightKg rdf:type rdf:Property ;
    rdfs:label 'Bag Weight Kg' ;
    rdfs:comment 'The preferred individual bag weight in kilograms when the customer\'s packaging format is bagged. Used to configure pick-and-pack operations and label generation in the warehouse.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must accompany every shipment to this customer. When True, the COA document is generated and attached to the shipment record prior to dispatch.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The customer\'s preferred language for all business communications, documents, and correspondence, expressed as an IETF BCP 47 language tag (e.g., en-US, es-MX, fr-FR). Governs document generation and CRM communication templates.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolAcceptedOrigins rdf:type rdf:Property ;
    rdfs:label 'Cool Accepted Origins' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes representing origin countries acceptable to this customer under COOL requirements (e.g., USA|CAN|MEX). Orders sourced from countries not on this list require customer approval.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolAuditFrequency rdf:type rdf:Property ;
    rdfs:label 'Cool Audit Frequency' ;
    rdfs:comment 'The agreed frequency at which COOL compliance audits are conducted for this customer\'s account. Drives scheduling of COOL compliance review activities and documentation requests.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolDocumentationRequired rdf:type rdf:Property ;
    rdfs:label 'Cool Documentation Required' ;
    rdfs:comment 'Indicates whether this customer requires formal COOL documentation (e.g., origin certificates, supply chain affidavits) to accompany each shipment. When True, documentation must be generated and attached to the Bill of Lading (BOL).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolLabelFormat rdf:type rdf:Property ;
    rdfs:label 'Cool Label Format' ;
    rdfs:comment 'The COOL labeling format required by the customer: full_origin (single country of origin declared), mixed_origin (multiple countries declared), or derived_from (product derived from a covered commodity). Governs label generation and COOL audit documentation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Cool Last Review Date' ;
    rdfs:comment 'The date on which the most recent COOL compliance review was completed for this customer. Used to calculate next review due date and track regulatory compliance cadence.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coolRequired rdf:type rdf:Property ;
    rdfs:label 'Cool Required' ;
    rdfs:comment 'Indicates whether this customer requires Country of Origin Labeling (COOL) compliance on all commodity shipments. When True, origin tracking, labeling, and audit requirements are enforced per USDA COOL regulations.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolRestrictedOrigins rdf:type rdf:Property ;
    rdfs:label 'Cool Restricted Origins' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes representing origin countries explicitly prohibited for this customer under COOL preferences. Triggers order hold and compliance alert when restricted origin is detected.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryIncoterm rdf:type rdf:Property ;
    rdfs:label 'Delivery Incoterm' ;
    rdfs:comment 'The International Commercial Terms (Incoterms) preferred by the customer for delivery. FOB (Free On Board) and CIF (Cost Insurance and Freight) are the most common in agricultural commodity trade.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'The latest time of day (HH:MM, 24-hour format) at which the customer accepts deliveries at their receiving facility. Used in conjunction with delivery_window_start to define the acceptable delivery window.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'The earliest time of day (HH:MM, 24-hour format) at which the customer accepts deliveries at their receiving facility. Used to schedule outbound logistics and carrier dispatch.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The ANSI X12 or EDIFACT EDI transaction set code used for electronic invoice and order exchange with this customer (e.g., 810 for invoice, 850 for purchase order). Applicable only when invoice_delivery_method is EDI.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTolerance rdf:type rdf:Property ;
    rdfs:label 'Gmo Tolerance' ;
    rdfs:comment 'Indicates whether the customer accepts Genetically Modified Organism (GMO) commodities. When False, only non-GMO verified product may be allocated to this customer\'s orders.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'The customer\'s preferred method for receiving invoices: Electronic Data Interchange (EDI), email, self-service portal, or paper. Drives invoice generation and dispatch configuration in SAP S/4HANA FI and Oracle NetSuite AR modules.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The minimum number of calendar days of advance notice required by the customer before a delivery can be scheduled. Used in order promising and logistics planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'The minimum commodity quantity (expressed in the customer\'s preferred order unit of measure) that must be included in a single Sales Order (SO) for this customer. Enforced during order entry in SAP S/4HANA SD.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUom rdf:type rdf:Property ;
    rdfs:label 'Order Uom' ;
    rdfs:comment 'The customer\'s preferred unit of measure for commodity orders: Metric Ton (MT), Bushel (BU), Hundredweight (CWT), pound (LB), kilogram (KG), or short ton (TON). Governs order entry and weight ticket generation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicPreference rdf:type rdf:Property ;
    rdfs:label 'Organic Preference' ;
    rdfs:comment 'Indicates whether the customer requires USDA Certified Organic product, conventional product, or accepts either. Drives sourcing, labeling, and National Organic Program (NOP) compliance requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingFormat rdf:type rdf:Property ;
    rdfs:label 'Packaging Format' ;
    rdfs:comment 'The customer\'s preferred physical packaging format for commodity delivery. Drives warehouse task configuration in Manhattan Associates WMS and order fulfillment planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The customer\'s preferred payment instrument for settling invoices. Governs payment processing configuration in Oracle NetSuite AR and SAP S/4HANA FI modules.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'High-level category of the preference record, enabling segmentation and filtering across commodity, packaging, delivery, Country of Origin Labeling (COOL), certification, communication, invoice, and payment preference categories. [ENUM-REF-CANDIDATE: commodity|packaging|delivery|cool|certification|communication|invoice|payment — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'The customer\'s preferred freight carrier or logistics provider for outbound shipments. Used to configure Transportation Management System (TMS) routing and Bill of Lading (BOL) generation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingRequired rdf:type rdf:Property ;
    rdfs:label 'Sampling Required' ;
    rdfs:comment 'Indicates whether the customer requires a pre-shipment commodity sample and Certificate of Analysis (COA) approval before each shipment is dispatched. When True, a quality hold is applied until COA is approved.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any customer-specific handling, storage, or transportation instructions that must be observed during order fulfillment and delivery (e.g., temperature-controlled transport, allergen segregation requirements).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Agricultural assets (tractors, harvesters, implements) are acquired via CAPEX purchase orders. Linking asset to its acquisition PO enables fixed asset lifecycle traceability from procurement through d' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:assetCategoryId rdf:type rdf:Property ;
    rdfs:label 'Asset Category Id' ;
    rdfs:comment 'Foreign key reference to the asset class/category reference product defining the equipment classification hierarchy (e.g., tractor, combine harvester, planter, sprayer, irrigation system, precision agriculture hardware).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCategory .

ind:capitalProjectId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Id' ;
    rdfs:comment 'Foreign key linking to finance.capital_project. Business justification: Equipment acquisitions in agriculture are funded through approved CAPEX projects (e.g., combine fleet renewal, precision ag hardware rollout). Linking asset to its funding capital_project enables CAPE' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Farm equipment (tractors, combines, irrigation systems) are capitalized on the fixed asset register. This link enables asset register reconciliation, depreciation tracking (MACRS/Section 179), and GAA' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Equipment assets are deployed within defined sales territories in large-scale ag operations. Territory-based equipment capacity planning and custom hire sales reporting require knowing which assets ar' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or total capitalized cost of the asset at acquisition, representing the Capital Expenditure (CAPEX) investment. Includes purchase price, freight, installation, and commissioning costs. Denominated in USD. Sourced from SAP S/4HANA FI/AM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the asset was acquired (purchased, leased, or transferred into the fleet). Marks the start of the asset lifecycle for depreciation, warranty, and compliance tracking. Sourced from SAP S/4HANA FI/AM module.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable descriptive name or designation for the asset (e.g., \'John Deere 8R 410 Tractor - North Field Unit 3\'). Used for operational identification and reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the asset was formally placed into service and became operational. May differ from acquisition date if installation, calibration, or certification was required prior to first use. Triggers start of depreciation in SAP S/4HANA.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA Controlling (CO) module cost center code to which the asset\'s Operational Expenditure (OPEX) and depreciation charges are allocated. Enables farm-level and department-level cost reporting and EBITDA analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current net book value of the asset after accumulated depreciation, calculated as acquisition cost minus total accumulated depreciation to date. Used for financial reporting, insurance valuation, and disposal decisions. Denominated in USD.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the asset was formally retired from service and decommissioned. Marks the end of the operational lifecycle for depreciation cessation, disposal processing, and regulatory reporting. Null if asset is still active.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate periodic depreciation of the asset. Straight-line spreads cost evenly; declining balance accelerates early depreciation; units of production ties depreciation to actual usage hours. Configured in SAP S/4HANA FI/AM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'Cumulative total engine or operating hours recorded on the asset since manufacture or last major overhaul. Primary usage metric for maintenance scheduling (e.g., 250-hour, 500-hour service intervals), depreciation under units-of-production method, and Overall Equipment Effectiveness (OEE) calculation. Sourced from John Deere Operations Center telematics.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enginePowerKw rdf:type rdf:Property ;
    rdfs:label 'Engine Power Kw' ;
    rdfs:comment 'Rated engine power output of the asset in kilowatts (kW) as specified by the manufacturer. Used for equipment capability matching to field operations, fuel consumption benchmarking, and EPA emissions classification.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel or energy source used by the asset. Relevant for fuel cost allocation, emissions reporting (EPA Tier 4 Final compliance), and sustainability tracking under ISCC and ISO 14001 environmental management standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsRtkEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Rtk Enabled' ;
    rdfs:comment 'Indicates whether the asset is equipped with a Global Positioning System (GPS) / Real-Time Kinematic (RTK) positioning receiver for precision agriculture operations including Variable Rate Application (VRA), auto-steer, and field mapping. True = RTK-capable; False = no precision positioning hardware.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date on which the current insurance policy for the asset expires. Triggers renewal workflow to ensure continuous coverage and compliance with financing covenants and regulatory requirements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number of the insurance policy covering this asset against loss, damage, or liability. Used for claims processing, risk management reporting, and compliance with lender insurance requirements for financed equipment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the asset per ISO 55000 asset management framework. Drives maintenance scheduling, capital planning, and disposal workflows. [ENUM-REF-CANDIDATE: acquisition|commissioning|operational|standby|maintenance|decommissioned|disposed — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) of the asset (e.g., John Deere, Case IH, AGCO, Kubota, Trimble). Used for vendor management, parts sourcing, and warranty claims.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer model designation of the asset (e.g., \'8R 410\', \'X9 1100\', \'R4045\'). Combined with make and year to uniquely identify the equipment specification for parts compatibility and performance benchmarking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'Manufacturer model year of the asset (e.g., 2022). Used for depreciation scheduling, technology generation classification, and compliance with emissions standards (EPA Tier 4 Final).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Service Date' ;
    rdfs:comment 'Date on which the next preventive maintenance (PM) service is scheduled for the asset based on the Computerized Maintenance Management System (CMMS) schedule. Derived from last service date plus service interval. Sourced from SAP S/4HANA PM module maintenance plans.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Cumulative distance traveled by the asset in kilometers, applicable to self-propelled vehicles (tractors, combines, sprayers, transport vehicles). Used for road-transport maintenance scheduling and fleet management. Sourced from John Deere Operations Center or vehicle ECU. Null for stationary or non-motorized equipment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational readiness status of the asset indicating whether it is available for field deployment. Active = deployed and operational; Standby = available but not deployed; Under Repair = in maintenance; Out of Service = unavailable; Decommissioned = retired from service.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of the asset\'s ownership or financing arrangement. Owned = outright purchase (CAPEX); Leased = finance or operating lease (OPEX/IFRS 16); Rented = short-term hire; Contract Hire = long-term managed service. Drives financial treatment under GAAP/IFRS 16.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the asset master record was first created in the system. Supports audit trail requirements, data lineage tracking, and SOX financial reporting controls. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when the asset master record was most recently modified. Supports change tracking, audit trail requirements, and Silver Layer incremental load processing in the Databricks Lakehouse. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date on which the current government or regulatory registration for the asset expires. Triggers renewal workflow to maintain legal compliance for road use and regulatory inspections.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Government or regulatory authority registration number for the asset where required (e.g., state DMV registration for road-going vehicles, USDA/APHIS equipment registration). Null for non-registered implements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual or salvage value of the asset at the end of its useful life. Used as the basis for depreciation calculations under straight-line and declining balance methods. Denominated in USD.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the equipment unit. Used for warranty tracking, recall management, and manufacturer service records. Key identifier in John Deere Operations Center.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tag rdf:type rdf:Property ;
    rdfs:label 'Tag' ;
    rdfs:comment 'Internally assigned physical asset tag or barcode label affixed to the equipment for inventory tracking and identification during audits and maintenance. Aligns with SAP S/4HANA PM asset tag field.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the telematics device or machine connectivity unit installed on the asset and registered in the John Deere Operations Center platform. Enables real-time GPS tracking, remote diagnostics, fuel consumption monitoring, and field data synchronization.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Estimated useful economic life of the asset in years, used as the basis for straight-line depreciation calculations and capital replacement planning. Defined at acquisition per GAAP/IFRS guidelines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vin rdf:type rdf:Property ;
    rdfs:label 'Vin' ;
    rdfs:comment '17-character Vehicle Identification Number assigned to motorized agricultural vehicles (tractors, combines, self-propelled sprayers) per ISO 3779 standard. Null for non-motorized implements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vraControllerEnabled rdf:type rdf:Property ;
    rdfs:label 'Vra Controller Enabled' ;
    rdfs:comment 'Indicates whether the asset is equipped with a Variable Rate Application (VRA) controller enabling prescription-based variable rate seeding, fertilization, or chemical application. Supports precision agriculture workflows in Trimble Ag Software and Climate FieldView.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer or dealer warranty for the asset expires. Used to trigger preventive maintenance scheduling under warranty terms and to determine whether repair costs are chargeable to the vendor or internal Operational Expenditure (OPEX) budget.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment asset assignment record in the Silver Layer lakehouse. Primary key for the asset_assignment data product.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAssignment .

ind:customHireAccountId rdf:type rdf:Property ;
    rdfs:label 'Custom Hire Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Custom hire service management: asset assignments for custom hire operations must reference the customer account for service scheduling, billing, and performance reporting. \'custom_hire_customer_ref\' ' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Reference to the primary operator (employee or contractor) responsible for operating the assigned equipment asset during the assignment period. Sourced from SAP SuccessFactors workforce records.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryAssetPrecisionDeviceId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Precision Device Id' ;
    rdfs:comment 'The identifier of the RTK GPS receiver unit installed on the equipment asset during this assignment. Enables sub-inch positioning accuracy for precision planting, VRA, and field mapping operations.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrecisionDevice .

ind:actualAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Actual Area Hectares' ;
    rdfs:comment 'The actual land area in hectares covered by the equipment asset during the assignment period, sourced from GPS/RTK telematics data in John Deere Operations Center or Trimble Ag Software.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The actual calendar date on which the equipment asset was physically returned or released from the assignment. May differ from the planned end_date due to operational delays or early completion.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Utilization Hours' ;
    rdfs:comment 'The actual number of engine/operational hours the equipment asset accumulated during the assignment period, sourced from John Deere Operations Center telematics. Used for OEE calculation and OPEX cost allocation.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedToEntityType rdf:type rdf:Property ;
    rdfs:label 'Assigned To Entity Type' ;
    rdfs:comment 'Discriminator indicating the type of business entity to which the equipment asset is assigned. Determines which reference ID (field_id, farm_unit_id, operator_id, crop_enterprise_id) is the primary assignment target.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for operational notes, special instructions, or contextual information related to the equipment assignment (e.g., specific field conditions, equipment configuration requirements, custom hire terms).' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for the equipment assignment record, following the format ASGN-YYYY-NNNNNN. Used for cross-referencing with John Deere Operations Center, SAP PM, and Granular Farm Management systems.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPurpose rdf:type rdf:Property ;
    rdfs:label 'Assignment Purpose' ;
    rdfs:comment 'The operational purpose or activity for which the equipment asset is assigned. Supports fleet scheduling, utilization analysis, and OPEX allocation by agricultural activity. [ENUM-REF-CANDIDATE: planting|tillage|spraying|harvesting|irrigation|transport|custom_hire|maintenance_support|other — promote to reference product]' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the equipment asset assignment. \'planned\' indicates a future assignment; \'active\' indicates the asset is currently deployed; \'suspended\' indicates a temporary pause; \'completed\' indicates the assignment period has ended; \'cancelled\' indicates the assignment was voided.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customHireFlag rdf:type rdf:Property ;
    rdfs:label 'Custom Hire Flag' ;
    rdfs:comment 'Indicates whether this equipment assignment is a custom hire arrangement (True) where the equipment is operated for a third-party customer or contracted service, or an internal farm operation (False). Affects billing and revenue recognition.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The calendar date on which the equipment asset assignment is scheduled to end or was actually completed. Null for open-ended assignments. Used for fleet availability planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'The SAP PM functional location code representing the physical or logical location where the equipment asset is deployed during the assignment (e.g., farm site, field block, irrigation zone). Supports maintenance planning and asset hierarchy.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Flag' ;
    rdfs:comment 'Indicates whether this equipment assignment is conducted in compliance with Good Agricultural Practices (GAP) standards, including equipment calibration, chemical application records, and operator hygiene requirements.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:growingSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Growing Season Code' ;
    rdfs:comment 'The agricultural growing season identifier associated with this assignment (e.g., 2024-spring, 2024-fall). Enables seasonal fleet utilization analysis and crop enterprise cost allocation aligned with FMIS planning cycles.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The internal charge-out or cost allocation rate per operational hour for the equipment asset during this assignment. Used for OPEX cost allocation to crop enterprises and custom hire billing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenancePlantCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plant Code' ;
    rdfs:comment 'The SAP PM maintenance plant code identifying the organizational unit responsible for maintaining the equipment asset during this assignment period. Used for PM work order routing and spare parts procurement.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseVerified rdf:type rdf:Property ;
    rdfs:label 'Operator License Verified' ;
    rdfs:comment 'Indicates whether the primary operator\'s equipment operating license and certifications have been verified as current and valid for the assigned equipment type prior to assignment activation. Supports OSHA compliance.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Planned Area Hectares' ;
    rdfs:comment 'The planned land area in hectares that the equipment asset is expected to cover during the assignment (e.g., acres to be planted, sprayed, or harvested). Supports YPM and operational efficiency analysis.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Utilization Hours' ;
    rdfs:comment 'The planned or budgeted number of engine/operational hours the equipment asset is expected to accumulate during the assignment period. Used for CAPEX/OPEX cost allocation and fleet scheduling.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precisionAgHardwareFlag rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Hardware Flag' ;
    rdfs:comment 'Indicates whether the assigned equipment asset is equipped with precision agriculture hardware (True), such as GPS/RTK receivers, VRA controllers, or NDVI sensors, relevant for variable rate application prescriptions.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyInductionCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Induction Completed' ;
    rdfs:comment 'Indicates whether the assigned operator has completed the required safety induction and equipment-specific SOP training prior to commencing the assignment. Required for OSHA and GLOBALG.A.P. compliance.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The calendar date on which the equipment asset assignment becomes effective and the asset is deployed to the assigned entity. Used for fleet scheduling and seasonal planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAssignmentCost rdf:type rdf:Property ;
    rdfs:label 'Total Assignment Cost' ;
    rdfs:comment 'The total OPEX cost incurred for this equipment assignment, calculated as actual utilization hours multiplied by the hourly rate plus any additional direct costs. Used for crop enterprise cost allocation and EBITDA reporting.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The SAP PS Work Breakdown Structure element code associated with this assignment for project-based CAPEX cost tracking (e.g., equipment deployment for a new irrigation project or precision ag hardware rollout).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryAssetCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Asset Category Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent category in the equipment classification hierarchy, enabling parent-child rollup reporting for CAPEX/OPEX budgeting and fleet planning. Null for top-level (root) categories.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCategory .

ind:assetTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Prefix' ;
    rdfs:comment 'Standardized alphabetic prefix used when generating asset tag numbers for individual assets registered under this category (e.g., \'TRC\' for tractors, \'CMB\' for combines, \'SPR\' for sprayers). Ensures consistent asset identification across the enterprise fleet registry.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Availability Target Pct' ;
    rdfs:comment 'Target equipment availability rate (uptime as a percentage of scheduled operating time) for assets in this category, forming the availability component of the OEE calculation. Used in preventive maintenance scheduling and fleet planning to set maintenance frequency targets.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexBudgetAccountCode rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA FI/CO to which capital expenditure for assets in this category is posted. Enables CAPEX budget tracking and variance reporting by equipment category. Aligned with GAAP/IFRS financial reporting chart of accounts.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the equipment category within the enterprise taxonomy (e.g., TILL-001, PLANT-002, SPRAY-003). Used as the business key in SAP S/4HANA PM asset class configuration and cross-system integration with John Deere Operations Center fleet telematics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed narrative description of the equipment category, including its primary agricultural function, typical use cases, and operational context (e.g., tillage, planting, crop protection, harvesting, irrigation, livestock handling, precision ag hardware, transport fleet).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the equipment category (e.g., \'Row Crop Tractor\', \'Combine Harvester\', \'Center Pivot Irrigation System\', \'Precision Ag RTK Receiver\'). Used in CAPEX/OPEX budgeting reports, fleet planning dashboards, and maintenance scheduling interfaces.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the asset category record. \'active\' indicates the category is in use for asset registration and fleet planning; \'deprecated\' indicates the category has been superseded and no new assets should be assigned; \'under_review\' indicates pending taxonomy governance approval.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Operational class of the equipment category aligned with core agricultural business processes (e.g., tillage, planting, spraying, harvesting, irrigation). Maps directly to John Deere Operations Center equipment class codes and SAP S/4HANA PM functional location structure. [ENUM-REF-CANDIDATE: tillage|planting|spraying|harvesting|irrigation|fertilization|precision_ag|livestock|transport|general_purpose — promote to reference product]' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDomain rdf:type rdf:Property ;
    rdfs:label 'Equipment Domain' ;
    rdfs:comment 'High-level domain classification grouping equipment categories into major operational areas of the agricultural enterprise. Drives top-level CAPEX/OPEX budget segmentation and OEE (Overall Equipment Effectiveness) benchmarking by domain. [ENUM-REF-CANDIDATE: field_equipment|precision_ag_hardware|irrigation_systems|livestock_handling|transport_fleet|storage_infrastructure|power_units|other — promote to reference product if domain list expands beyond 8 values]' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Equipment Type' ;
    rdfs:comment 'Equipment type classification code as defined by GLOBALG.A.P. (Global Good Agricultural Practices) certification standards. Required for GLOBALG.A.P. audit documentation to demonstrate that equipment used in certified operations meets GAP (Good Agricultural Practices) requirements.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTelematicsCapable rdf:type rdf:Property ;
    rdfs:label 'Gps Telematics Capable' ;
    rdfs:comment 'Indicates whether assets in this category are equipped with or compatible with GPS/telematics hardware for real-time location tracking and operational data collection via John Deere Operations Center or equivalent fleet telematics platforms. True = telematics integration is standard for this category.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Required frequency in calendar months between mandatory regulatory inspections for assets in this category (e.g., 12 months for annual EPA sprayer calibration, 6 months for OSHA-mandated safety checks). Null if inspection_required is False.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionGoverningBody rdf:type rdf:Property ;
    rdfs:label 'Inspection Governing Body' ;
    rdfs:comment 'Name of the regulatory authority or standards body responsible for mandating inspections for assets in this category (e.g., EPA, OSHA, USDA APHIS, FDA, state department of agriculture). Supports compliance tracking and audit documentation.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether assets in this category are subject to mandatory regulatory inspection requirements (e.g., EPA pesticide application equipment calibration, OSHA safety inspections for operator-driven equipment, USDA/APHIS compliance checks for livestock handling equipment). True = regulatory inspection is required.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jdOpsCenterCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Jd Ops Center Category Code' ;
    rdfs:comment 'Equipment category code as defined in John Deere Operations Center fleet telematics platform. Used for cross-system data reconciliation between the enterprise asset taxonomy and John Deere precision agriculture fleet management data feeds.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeBenchmarkTargetPct rdf:type rdf:Property ;
    rdfs:label 'Oee Benchmark Target Pct' ;
    rdfs:comment 'Industry benchmark target for Overall Equipment Effectiveness (OEE) expressed as a percentage (0–100) for assets in this category. Used as the KPI baseline for fleet performance monitoring in John Deere Operations Center and operational reporting dashboards. OEE = Availability × Performance × Quality.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Operator License Required' ;
    rdfs:comment 'Indicates whether operating assets in this category requires a specific operator license, certification, or training qualification (e.g., CDL for transport vehicles, pesticide applicator license for sprayers, OSHA-mandated forklift certification for material handling equipment). Supports workforce compliance management in SAP SuccessFactors.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexBudgetAccountCode rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA FI/CO to which operational and maintenance expenditure for assets in this category is posted. Supports OPEX budget tracking, maintenance cost analysis, and EBITDA reporting by equipment category.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideApplicatorCertRequired rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator Cert Required' ;
    rdfs:comment 'Indicates whether operating assets in this category requires a valid EPA-certified pesticide applicator license (e.g., self-propelled sprayers, aerial application equipment). Supports IPM (Integrated Pest Management) compliance and EPA regulatory audit readiness.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Days' ;
    rdfs:comment 'Calendar-day interval between scheduled preventive maintenance events for assets in this category, used when calendar-based (rather than usage-based) PM scheduling is applicable (e.g., annual inspections, seasonal service). Complements pm_interval_hours for dual-trigger PM strategies.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Hours' ;
    rdfs:comment 'Standard operating hours interval between scheduled preventive maintenance (PM) events for assets in this category (e.g., 250 hours for tractor engine service). Used to auto-generate PM work orders in SAP S/4HANA PM/CMMS and John Deere Operations Center maintenance scheduling.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerRatingHp rdf:type rdf:Property ;
    rdfs:label 'Power Rating Hp' ;
    rdfs:comment 'Typical or standard power rating in horsepower (HP) for assets in this category, representing the principal quantitative performance characteristic. Used for equipment matching (tractor-implement compatibility), fleet specification planning, and fuel consumption benchmarking.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precisionAgCompatible rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Compatible' ;
    rdfs:comment 'Indicates whether assets in this category support precision agriculture hardware integration, including RTK (Real-Time Kinematic) GPS receivers, VRA (Variable Rate Application) controllers, NDVI sensors, or FMIS (Farm Management Information System) data connectivity. Supports precision ag fleet planning.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salvageValuePct rdf:type rdf:Property ;
    rdfs:label 'Salvage Value Pct' ;
    rdfs:comment 'Estimated residual (salvage) value at end of useful life expressed as a percentage of original acquisition cost, used in depreciation base calculation for assets in this category. Supports CAPEX planning and asset disposal valuation in SAP S/4HANA FI-AA.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetClassCode rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Class Code' ;
    rdfs:comment 'Corresponding asset class code in SAP S/4HANA FI-AA (Fixed Asset Accounting) module that maps to this equipment category. Enables direct integration between the equipment taxonomy and SAP financial asset accounting for depreciation, CAPEX tracking, and balance sheet reporting.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric display sort order for presenting asset categories in user interfaces, reports, and dropdown lists within the equipment domain. Allows business-defined ordering independent of alphabetical or ID-based sequencing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDepreciationLifeYears rdf:type rdf:Property ;
    rdfs:label 'Standard Depreciation Life Years' ;
    rdfs:comment 'Standard useful economic life in years assigned to all assets within this category for CAPEX depreciation scheduling and financial reporting. Used in SAP S/4HANA FI/CO asset accounting to default depreciation key and useful life at asset creation. Aligned with GAAP/IFRS IAS 16 useful life estimation.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraControllerCompatible rdf:type rdf:Property ;
    rdfs:label 'Vra Controller Compatible' ;
    rdfs:comment 'Indicates whether assets in this category are compatible with VRA (Variable Rate Application) controllers for precision input management (seed, fertilizer, pesticide). Supports VRA prescription execution tracking in Trimble Ag Software and Climate FieldView.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightClass rdf:type rdf:Property ;
    rdfs:label 'Weight Class' ;
    rdfs:comment 'Standardized weight class of assets in this category, used for transport logistics planning, road permit requirements, soil compaction risk assessment, and field access restrictions. Aligns with USDA and DOT weight classification standards for agricultural equipment.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetInspectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Inspection Id' ;
    rdfs:comment 'Unique system-generated identifier for each asset inspection record. Primary key for the asset_inspection data product within the equipment domain.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Id' ;
    rdfs:comment 'Reference to the standardized inspection checklist template used for this inspection. Templates are defined per inspection type and asset category, ensuring consistent evaluation criteria across all inspections of the same type.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklistTemplate .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to quality.corrective_action. Business justification: Equipment inspections finding deficiencies on food-contact or CCP equipment generate quality CAPAs under FSMA prerequisite programs. Linking asset_inspection to the resulting corrective_action support' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_plan. Business justification: Scheduled asset inspections in agricultural equipment management are typically triggered by preventive maintenance plans (e.g., a 500-hour PM plan includes a safety inspection checklist). asset_inspec' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:primaryAssetWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Work Order Id' ;
    rdfs:comment 'Reference to the maintenance work order associated with this inspection, if the inspection was triggered by or resulted in a corrective or preventive maintenance work order in the CMMS.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assetGroundedFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Grounded Flag' ;
    rdfs:comment 'Indicates whether the asset has been taken out of service (grounded) as a result of this inspection. A True value means the asset must not be operated until corrective actions are completed and a re-inspection passes.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetHoursAtInspection rdf:type rdf:Property ;
    rdfs:label 'Asset Hours At Inspection' ;
    rdfs:comment 'The cumulative engine or operating hours recorded on the asset at the time of inspection, as read from the telematics system (John Deere Operations Center) or hour meter. Critical for hour-based maintenance interval tracking per ISO 55000 and OEM service schedules.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checklistItemCount rdf:type rdf:Property ;
    rdfs:label 'Checklist Item Count' ;
    rdfs:comment 'Total number of individual checklist items evaluated during the inspection. Provides a completeness indicator and supports audit verification that all required inspection points were assessed.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Flag' ;
    rdfs:comment 'Indicates whether one or more critical safety or regulatory deficiencies were identified during the inspection. A True value typically triggers immediate asset grounding, mandatory corrective action, and escalation to the safety or compliance officer.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Narrative description of all deficiencies, non-conformances, or safety hazards identified during the inspection. Captures the nature, location, and severity of each issue found. Used for corrective action planning and regulatory reporting.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Dot Compliance Verified' ;
    rdfs:comment 'Indicates whether DOT roadworthiness and transport safety requirements were specifically verified as part of this inspection, applicable to road-mobile agricultural equipment and transport vehicles.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Verified' ;
    rdfs:comment 'Indicates whether EPA environmental compliance requirements (e.g., engine emissions, fuel system integrity, chemical containment) were specifically verified as part of this inspection.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection End Timestamp' ;
    rdfs:comment 'The precise date and time when the inspector completed all checklist evaluations and closed the inspection. Used for duration calculation and audit trail purposes.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'The physical location or functional location code where the inspection was conducted, such as a farm field identifier, workshop bay, or GPS-referenced field location. Aligns with SAP PM functional location hierarchy and Esri ArcGIS field mapping.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'The primary method used to conduct the inspection. Visual inspections rely on direct observation; operational tests involve running the equipment through functional checks; instrument measurement uses calibrated tools (e.g., emissions analyser, torque wrench); document review verifies maintenance records and certifications; combined uses multiple methods.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Timestamp' ;
    rdfs:comment 'The precise date and time when the inspector began conducting the inspection. Used for duration calculation and audit trail purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection record. Scheduled indicates the inspection is planned but not yet started; in_progress indicates the inspector is actively conducting the inspection; completed indicates all checklist items have been evaluated and the record is closed; cancelled indicates the inspection was voided; pending_reinspection indicates deficiencies were found requiring a follow-up inspection.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'The professional certification or licence number of the inspector who conducted the inspection, as issued by the relevant regulatory or professional body. Required for regulatory audit trails to verify inspector qualification.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorType rdf:type rdf:Property ;
    rdfs:label 'Inspector Type' ;
    rdfs:comment 'Classification of the inspector who conducted the inspection. Internal indicates a company-employed technician or safety officer; third_party indicates an independent certified inspector engaged by the company; regulatory_authority indicates an inspector from a government body such as OSHA, EPA, or DOT.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Items Failed Count' ;
    rdfs:comment 'Number of individual checklist items that received a fail evaluation during the inspection. A non-zero value triggers deficiency documentation and corrective action requirements.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsPassedCount rdf:type rdf:Property ;
    rdfs:label 'Items Passed Count' ;
    rdfs:comment 'Number of individual checklist items that received a pass evaluation during the inspection. Used in conjunction with checklist_item_count and items_failed_count to assess inspection completeness and asset condition.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inspection Date' ;
    rdfs:comment 'The calculated or manually assigned date for the next scheduled inspection of this asset, based on regulatory intervals, OEM recommendations, or the preventive maintenance plan. Drives the forward maintenance calendar.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Verified' ;
    rdfs:comment 'Indicates whether OSHA occupational safety requirements were specifically verified as part of this inspection. Supports OSHA compliance reporting and audit readiness under 29 CFR 1910 and 29 CFR 1928 (agricultural operations).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'The aggregate pass/fail determination for the entire inspection. Pass indicates all checklist items met required standards; fail indicates one or more critical items did not meet standards; conditional_pass indicates minor deficiencies noted but asset is operationally cleared with corrective actions required; incomplete indicates the inspection was not fully executed.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCertificateIssued rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certificate Issued' ;
    rdfs:comment 'Indicates whether a regulatory compliance certificate (e.g., OSHA safety certificate, DOT roadworthiness certificate, EPA emissions certificate) was issued as a result of this inspection passing.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Due Date' ;
    rdfs:comment 'The date by which a follow-up re-inspection must be completed to verify that corrective actions have been implemented and deficiencies resolved. Mandatory when overall_result is fail or conditional_pass.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The planned calendar date on which the inspection was scheduled to occur, as defined in the preventive maintenance plan or regulatory compliance calendar.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationEventId rdf:type rdf:Property ;
    rdfs:label 'Calibration Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each calibration event record. Primary key for the calibration_event data product within the equipment domain.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationVendorId rdf:type rdf:Property ;
    rdfs:label 'Calibration Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Precision device calibration events in agriculture are frequently performed by external certified calibration service vendors. Linking calibration_event to the service vendor enables vendor qualificat' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:adjustmentDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Description' ;
    rdfs:comment 'Narrative description of the specific adjustment performed on the device during calibration, including parameter changes, offset corrections, or hardware modifications applied.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMade rdf:type rdf:Property ;
    rdfs:label 'Adjustment Made' ;
    rdfs:comment 'Indicates whether a physical or software adjustment was applied to the device during the calibration event (True = adjustment made; False = no adjustment required, device was within tolerance).' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The actual calendar date on which the calibration activity was performed. This is the principal business event date for the calibration record.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationEndTime rdf:type rdf:Property ;
    rdfs:label 'Calibration End Time' ;
    rdfs:comment 'Precise date and time when the calibration procedure was completed or terminated, enabling duration tracking and technician productivity analysis.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'The prescribed number of days between calibration events for this device type, as defined by OEM specifications, regulatory requirements, or internal quality standards. Used to calculate next_calibration_due_date.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'The procedural approach used to perform the calibration, distinguishing between field-based tests, laboratory procedures, OEM manufacturer procedures, third-party certified calibration, or automated self-check routines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandard rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard' ;
    rdfs:comment 'The reference standard, certified instrument, or traceable measurement benchmark used to perform the calibration (e.g., NIST-traceable reference, OEM factory standard, ISO 17025 accredited lab standard). Ensures traceability of measurement accuracy.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStartTime rdf:type rdf:Property ;
    rdfs:label 'Calibration Start Time' ;
    rdfs:comment 'Precise date and time when the calibration procedure commenced, used for duration calculation and audit trail purposes.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current lifecycle state of the calibration event, tracking workflow from scheduling through completion or failure. [ENUM-REF-CANDIDATE: scheduled|in_progress|completed|failed|cancelled|overdue — promote to reference product if additional states are required]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Classification of the calibration activity performed, identifying the specific precision agriculture device category being calibrated. Supports GPS/RTK accuracy checks, flow meter calibration, yield monitor calibration, sprayer nozzle checks, and soil sensor calibration. [ENUM-REF-CANDIDATE: gps_accuracy_check|flow_meter|yield_monitor|sprayer_nozzle|rtk_base_station|soil_sensor|ec_sensor|ph_sensor — promote to reference product]' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'The date on which the calibration certificate was formally issued, which may differ from the calibration date if certificate processing involves a review period.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmmsNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Cmms Notification Number' ;
    rdfs:comment 'The SAP PM notification number associated with this calibration event, providing traceability back to the CMMS system of record for maintenance history and cost allocation.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationValue rdf:type rdf:Property ;
    rdfs:label 'Deviation Value' ;
    rdfs:comment 'The calculated absolute difference between the post-calibration reading and the reference standard reading, indicating residual measurement error after calibration adjustment.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number of the precision agriculture device or sensor being calibrated, used for asset tracking, warranty management, and OEM service records.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of the precision agriculture device or sensor being calibrated, providing classification context for analytics and maintenance planning. [ENUM-REF-CANDIDATE: gps_receiver|rtk_receiver|flow_meter|yield_monitor|sprayer_controller|soil_sensor|weather_sensor|vra_controller|nozzle_assembly — promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'The actual labor cost incurred for performing the calibration event, expressed in the operational currency. Contributes to OPEX tracking and equipment total cost of ownership analysis.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Description of the physical location where the calibration was performed (e.g., field workshop, equipment yard, certified calibration lab, in-field during operation). Supports audit trail and logistics planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure applicable to the pre-calibration, post-calibration, and reference standard readings (e.g., gal/min for flow meters, bu/ac for yield monitors, meters for GPS accuracy, mS/cm for EC sensors, pH units).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'The scheduled date by which the next calibration of this device must be completed to maintain measurement accuracy compliance. Drives preventive maintenance scheduling and CMMS work order generation.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'The actual cost of any replacement parts or consumables used during the calibration event, expressed in the operational currency. Contributes to OPEX and parts inventory cost tracking.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'The outcome determination of the calibration event: pass (within tolerance), fail (outside tolerance), or conditional_pass (within tolerance with noted conditions). Drives device release for field operations or quarantine for repair.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postCalibrationReading rdf:type rdf:Property ;
    rdfs:label 'Post Calibration Reading' ;
    rdfs:comment 'The measured value recorded from the device or sensor immediately after the calibration adjustment was applied. Compared against the reference standard to confirm calibration success.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preCalibrationReading rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Reading' ;
    rdfs:comment 'The measured value recorded from the device or sensor immediately before the calibration adjustment was applied. Used to quantify measurement drift and justify calibration necessity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceStandardReading rdf:type rdf:Property ;
    rdfs:label 'Reference Standard Reading' ;
    rdfs:comment 'The known, certified value from the calibration reference standard against which pre- and post-calibration readings are compared. Establishes the target accuracy benchmark.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this calibration event was performed to satisfy a specific regulatory or certification requirement (True = regulatory-driven calibration; False = routine preventive calibration). Supports FSMA, EPA, and GLOBALG.A.P. compliance reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Reference' ;
    rdfs:comment 'Specific regulatory citation, certification standard, or compliance framework requirement that mandated this calibration event (e.g., FSMA Produce Safety Rule Section 112.50, GLOBALG.A.P. AF 7.1, EPA 40 CFR Part 170 REI compliance).' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceValue rdf:type rdf:Property ;
    rdfs:label 'Tolerance Value' ;
    rdfs:comment 'The maximum allowable deviation between the device reading and the reference standard for the calibration to be considered passing. Defines the acceptable accuracy threshold for the device type.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraPrescriptionImpact rdf:type rdf:Property ;
    rdfs:label 'Vra Prescription Impact' ;
    rdfs:comment 'Indicates whether the calibration result affects active Variable Rate Application (VRA) prescriptions. When True, downstream VRA prescription records must be reviewed for accuracy impact before field application.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsReadingId rdf:type rdf:Property ;
    rdfs:label 'Telematics Reading Id' ;
    rdfs:comment 'Foreign key linking to equipment.telematics_reading. Business justification: An equipment fault detected via telematics should reference the specific telematics_reading record that triggered the DTC/fault detection. equipment_fault already has telematics_device_id (→ precision' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelematicsReading .

ind:acresLost rdf:type rdf:Property ;
    rdfs:label 'Acres Lost' ;
    rdfs:comment 'Estimated number of acres that could not be worked due to equipment downtime from this fault. Quantifies the production impact in the primary agricultural unit of measure. Used for OPEX impact analysis, crop planning adjustments, and insurance claims. Expressed in acres (US standard).' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRepairCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost Usd' ;
    rdfs:comment 'Actual total cost in US dollars incurred to repair the fault, as confirmed upon SAP PM work order settlement. Includes labor hours, spare parts consumed, and external contractor charges. Used for OPEX reporting, cost center allocation, and maintenance budget variance analysis per GAAP/IFRS.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective maintenance action performed to resolve the fault, as recorded in the SAP PM work order completion. Includes parts replaced, adjustments made, software updates applied, or temporary workarounds implemented. Essential for maintenance history and warranty claims.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Method by which the fault was first detected. Telematics = automatically detected via John Deere Operations Center or onboard ECU; Operator_Report = reported by equipment operator; Inspection = identified during scheduled preventive maintenance inspection; Sensor_Alert = triggered by IoT sensor threshold breach; Third_Party = reported by external service provider.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'The precise date and time when the fault was first detected, either by telematics system or reported by the operator. This is the principal real-world business event timestamp (BUSINESS_EVENT_TIMESTAMP). Used as the start reference for downtime duration calculations and OEE availability metrics.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration of equipment downtime in minutes, calculated from downtime_start_timestamp to downtime_end_timestamp. Stored as a business field (not a real-time derived metric) once the fault is closed. Core input for OEE (Overall Equipment Effectiveness) availability calculations and reliability-centered maintenance (RCM) analysis.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Date and time when the equipment was returned to operational service following corrective action. Null if the fault is still open or equipment has not yet been restored. Used with downtime_start_timestamp to calculate total downtime duration for OEE availability metrics.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Date and time when the equipment became operationally unavailable due to the fault. May differ from detection_timestamp if the equipment continued limited operation after fault detection. Used directly in OEE availability calculations and production impact assessments.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dtcCode rdf:type rdf:Property ;
    rdfs:label 'Dtc Code' ;
    rdfs:comment 'Standardized Diagnostic Trouble Code (DTC) as transmitted by the equipment\'s onboard telematics system (John Deere Operations Center, SAE J1939 protocol). Identifies the specific electronic control unit (ECU) fault condition. Used for automated fault classification and RCM analysis.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHoursAtFault rdf:type rdf:Property ;
    rdfs:label 'Engine Hours At Fault' ;
    rdfs:comment 'Total cumulative engine hours recorded on the equipment at the time the fault occurred, as reported by the telematics system. Critical for condition-based maintenance (CBM) analysis, warranty validation, and mean time between failures (MTBF) calculations.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the agricultural equipment type that experienced the fault. Enables fault trend analysis by equipment category and supports fleet-level OEE benchmarking. [ENUM-REF-CANDIDATE: tractor|combine|planter|sprayer|irrigation_system|harvester|tillage|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRepairCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost Usd' ;
    rdfs:comment 'Estimated total cost in US dollars to repair the fault, including labor, parts, and external service charges. Populated at fault creation for budget planning; updated with actuals upon work order completion. Supports OPEX cost allocation and maintenance budget management per GAAP/IFRS financial reporting.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCategory rdf:type rdf:Property ;
    rdfs:label 'Fault Category' ;
    rdfs:comment 'High-level classification of the fault type used for reliability-centered maintenance (RCM) analysis and spare parts planning. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|software|structural|operator_error|unknown — promote to reference product]' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Human-readable description of the equipment fault, breakdown, or abnormal condition. May be auto-populated from DTC lookup table or manually entered by the operator/technician. Provides context for maintenance planning and root cause analysis.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultNumber rdf:type rdf:Property ;
    rdfs:label 'Fault Number' ;
    rdfs:comment 'Externally-known business identifier for the fault record, used in maintenance work orders, operator reports, and SAP PM notifications. Format: EF-{YYYY}-{NNNNNN}. Serves as the human-readable reference across SAP S/4HANA PM, John Deere Operations Center, and field communications.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultStatus rdf:type rdf:Property ;
    rdfs:label 'Fault Status' ;
    rdfs:comment 'Current lifecycle status of the fault record from initial detection through resolution and closure. Drives workflow routing in SAP PM and maintenance scheduling. Open = detected, not yet actioned; In_Progress = corrective action underway; Resolved = fix applied; Closed = verified and closed; Recurring = fault has reoccurred after prior resolution.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'GPS latitude coordinate (decimal degrees, WGS84) of the equipment\'s location at the time of fault detection, as recorded by the onboard GPS/RTK receiver. Enables geospatial fault mapping in Esri ArcGIS and field-level downtime analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'GPS longitude coordinate (decimal degrees, WGS84) of the equipment\'s location at the time of fault detection, as recorded by the onboard GPS/RTK receiver. Used with gps_latitude for geospatial fault mapping and field-level impact analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether the fault poses a safety risk to the equipment operator or bystanders. Safety-critical faults trigger mandatory OSHA incident reporting workflows and immediate equipment lockout/tagout (LOTO) procedures. True = safety risk present; False = no immediate safety concern.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'Indicates whether this fault has been submitted or is eligible for a manufacturer warranty claim. True = warranty claim initiated or applicable; False = out-of-warranty or not eligible. Supports CAPEX/OPEX cost recovery tracking and vendor performance management.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceTeam rdf:type rdf:Property ;
    rdfs:label 'Maintenance Team' ;
    rdfs:comment 'Name or code of the maintenance team or work center responsible for resolving this fault, as assigned in SAP PM. Examples: internal_fleet_team, dealer_service, oem_field_technician. Supports workload balancing and maintenance team performance KPI reporting.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerKmAtFault rdf:type rdf:Property ;
    rdfs:label 'Odometer Km At Fault' ;
    rdfs:comment 'Total cumulative distance in kilometers recorded on the equipment odometer at the time of fault, as reported by telematics. Applicable to mobile equipment (tractors, combines, sprayers). Used alongside engine hours for condition-based maintenance scheduling and warranty claims.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Recurrence Count' ;
    rdfs:comment 'Number of times this same fault (same DTC code or fault category on the same asset) has recurred within the current operating season. A value greater than 1 indicates a recurring fault pattern requiring escalated RCM investigation. Supports chronic failure identification and maintenance strategy optimization.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the fault was confirmed as resolved and the equipment returned to full operational service. Distinct from downtime_end_timestamp (which marks when equipment restarted) — resolution_timestamp marks formal closure confirmation in SAP PM. Used for mean time to repair (MTTR) calculations.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized root cause classification code assigned after fault investigation, aligned with SAP PM cause catalog and ISO 14224 failure taxonomy. Examples: wear_and_tear, improper_maintenance, manufacturing_defect, operator_misuse, environmental_damage, age_related_failure. Used for RCM analysis and preventive maintenance optimization. [ENUM-REF-CANDIDATE: wear_and_tear|improper_maintenance|manufacturing_defect|operator_misuse|environmental_damage|age_related_failure|unknown — promote to reference product]' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactBu rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Bu' ;
    rdfs:comment 'Estimated yield loss in bushels (BU) attributable to the equipment downtime caused by this fault. Calculated based on acres lost and expected yield per acre (YPM). Supports crop loss reporting, insurance claims, and financial impact assessment. BU (Bushel) is the standard grain yield unit per USDA WASDE reporting.' ;
    rdfs:domain ind:Fault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to invoice.invoice_line. Business justification: Custom hire field operations (spraying, harvesting, tillage) performed for third parties are billed line-by-line on AR invoices. Agriculture custom hire billing requires linking each invoiced line to ' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:conservationPracticeId rdf:type rdf:Property ;
    rdfs:label 'Conservation Practice Id' ;
    rdfs:comment 'Foreign key linking to land.conservation_practice. Business justification: Field operations implementing conservation practices (cover crop seeding, contour tillage, filter strip maintenance) must be linked to the NRCS conservation_practice record for cost-share payment docu' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConservationPractice .

ind:inputCatalogId rdf:type rdf:Property ;
    rdfs:label 'Input Catalog Id' ;
    rdfs:comment 'Foreign key linking to procurement.input_catalog. Business justification: Field operations apply inputs defined in the input_catalog (PHI, REI, MRL, EPA registration). Linking field_operation to input_catalog enables real-time compliance verification of application rates ag' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InputCatalog .

ind:primaryEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Asset Id' ;
    rdfs:comment 'Reference to the primary equipment asset (tractor, combine, sprayer, planter, irrigation system) used in this operation. Links to the equipment asset master for OEE tracking and CAPEX/OPEX cost allocation per ISO 55000.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:usePlanId rdf:type rdf:Property ;
    rdfs:label 'Use Plan Id' ;
    rdfs:comment 'Foreign key linking to land.land_use_plan. Business justification: Field operations are executed against an approved land use plan (planned commodity, tillage system, crop restrictions). Linking operations to the plan enables plan-vs-actual execution tracking, FSA co' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsePlan .

ind:workforceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Workforce Certification Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_certification. Business justification: EPA WPS and state pesticide laws require pesticide application field operations to be performed by a licensed applicator. Linking to the specific workforce_certification record enables automated licen' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceCertification .

ind:applicationRateUom rdf:type rdf:Property ;
    rdfs:label 'Application Rate Uom' ;
    rdfs:comment 'Unit of measure for the application_rate field. Ensures dimensional consistency across operations involving different product types (seeds, liquids, granulars). Required for MRL compliance calculations and FSMA records. [ENUM-REF-CANDIDATE: oz/acre|lbs/acre|gal/acre|seeds/acre|kg/ha|L/ha|mt/acre — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaCoveredAcres rdf:type rdf:Property ;
    rdfs:label 'Area Covered Acres' ;
    rdfs:comment 'Total field area covered during the operation, measured in acres. Sourced from GPS track data (John Deere Operations Center / Trimble RTK). Used for application rate normalization, cost-per-acre analysis, and USDA FSA reporting.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours Used' ;
    rdfs:comment 'Total machine hours logged by the primary asset during this operation, sourced from John Deere Operations Center engine hour meter. Used for preventive maintenance scheduling (PM triggers), OEE calculation, and CAPEX depreciation tracking.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumedGal rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Gal' ;
    rdfs:comment 'Total fuel consumed by the equipment during the operation, in US gallons. Sourced from John Deere Operations Center telematics. Used for OPEX cost allocation, carbon footprint reporting (ISCC), and equipment efficiency benchmarking.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackFileRef rdf:type rdf:Property ;
    rdfs:label 'Gps Track File Ref' ;
    rdfs:comment 'File path or URI reference to the GPS/RTK track file recorded during the operation (Trimble .agdata, Climate FieldView .shp, or John Deere Operations Center export). Supports precision agriculture audit trails, pass efficiency calculation, and Esri ArcGIS spatial analysis.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndviReference rdf:type rdf:Property ;
    rdfs:label 'Ndvi Reference' ;
    rdfs:comment 'NDVI value of the field at the time of operation, sourced from satellite or drone imagery (Esri ArcGIS / Climate FieldView). Used to correlate operation timing with crop health status and validate VRA prescription zones.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationDate rdf:type rdf:Property ;
    rdfs:label 'Operation Date' ;
    rdfs:comment 'Calendar date on which the field operation was performed. Used for day-level scheduling, PHI/REI compliance countdown, weather correlation, and FSMA as-applied record dating.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationNotes rdf:type rdf:Property ;
    rdfs:label 'Operation Notes' ;
    rdfs:comment 'Free-text field for operator or agronomist observations recorded during or after the field operation (e.g., equipment issues, unusual field conditions, pest observations). Supports scouting follow-up and SOP deviation documentation.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Externally-known business identifier for the field operation, sourced from John Deere Operations Center or Trimble Ag Software. Used for cross-system traceability and FSMA audit trail references. Format: FOP-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle state of the field operation. Drives operational dashboards, work order closure in SAP PM, and FSMA as-applied record completeness checks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Pass Efficiency Pct' ;
    rdfs:comment 'Ratio of effective area covered to total area traversed, expressed as a percentage. Measures overlap and skip rates from GPS track analysis. Key precision agriculture KPI for equipment calibration and operator performance.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reiCompliant rdf:type rdf:Property ;
    rdfs:label 'Rei Compliant' ;
    rdfs:comment 'Indicates whether the Restricted Entry Interval was enforced after pesticide application, preventing unauthorized field re-entry. Required for OSHA worker protection standard compliance and EPA FIFRA label adherence.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speedAvgMph rdf:type rdf:Property ;
    rdfs:label 'Speed Avg Mph' ;
    rdfs:comment 'Average ground speed of the equipment during the operation in miles per hour, derived from John Deere Operations Center telematics. Used to assess application uniformity, operator compliance with label speed requirements, and equipment performance benchmarking.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprayWindowCompliant rdf:type rdf:Property ;
    rdfs:label 'Spray Window Compliant' ;
    rdfs:comment 'Indicates whether the operation was conducted within the approved spray window conditions (wind speed, temperature, inversion risk) as defined by EPA label requirements and IPM protocols. Populated for spraying operations; null for non-spray operations.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Target Area Acres' ;
    rdfs:comment 'Planned area to be covered as specified in the field operation work order or crop plan. Compared against area_covered_acres to compute pass efficiency and identify coverage gaps.' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductUom rdf:type rdf:Property ;
    rdfs:label 'Total Product Uom' ;
    rdfs:comment 'Unit of measure for total_product_used. Aligns with the product label unit and SAP MM material master UOM for inventory reconciliation and FSMA lot traceability. [ENUM-REF-CANDIDATE: oz|lbs|gal|seeds|kg|L|mt|bu — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_contract. Business justification: Preventive maintenance plans in agriculture are often governed by OEM dealer service contracts or extended warranty agreements. Linking maintenance_plan to vendor_contract enables contract-driven PM s' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Reference to the SAP PM work center (maintenance shop, field service team, or external contractor) responsible for executing this maintenance plan. Drives labor cost allocation and scheduling.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the maintenance manager or engineer who formally approved this maintenance plan for use. Required for regulatory compliance documentation under OSHA and EPA frameworks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoWoGeneration rdf:type rdf:Property ;
    rdfs:label 'Auto Wo Generation' ;
    rdfs:comment 'Indicates whether this maintenance plan is configured to automatically generate work orders in SAP PM when the maintenance cycle due date or usage threshold is reached. When False, work orders must be created manually.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmmsPlanReference rdf:type rdf:Property ;
    rdfs:label 'Cmms Plan Reference' ;
    rdfs:comment 'External reference identifier linking this plan to the corresponding maintenance plan record in the CMMS (Computerized Maintenance Management System), such as SAP PM maintenance plan number or John Deere Operations Center service plan ID. Enables cross-system traceability.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Required' ;
    rdfs:comment 'Indicates whether this maintenance plan includes tasks subject to EPA regulatory requirements (e.g., sprayer calibration for pesticide application equipment, emissions checks, fluid disposal). Triggers environmental compliance documentation.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated total labor cost to execute one cycle of this maintenance plan, in the base currency. Calculated from estimated_labor_hours and applicable labor rates. Supports OPEX cost allocation.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Total standard labor hours required to complete all tasks in this maintenance plan. Aggregated from individual task labor hour estimates. Used for workforce planning and OPEX budgeting.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'Date the most recent maintenance cycle was completed and signed off. Used to calculate next_due_date and track compliance with PM schedules.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCompletedHours rdf:type rdf:Property ;
    rdfs:label 'Last Completed Hours' ;
    rdfs:comment 'Engine/operating hour meter reading at the time the most recent maintenance cycle was completed. Sourced from John Deere Operations Center telematics. Used for usage-based interval tracking.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCycleUnit rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cycle Unit' ;
    rdfs:comment 'Unit of measure for the maintenance cycle interval. \'hours\' refers to engine/operating hours from John Deere Operations Center telematics; \'acres\'/\'hectares\' refer to field coverage metrics; calendar units support time-based strategies. [ENUM-REF-CANDIDATE: hours|days|weeks|months|years|acres|hectares|kilometers — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCycleValue rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cycle Value' ;
    rdfs:comment 'Numeric interval defining how frequently the maintenance plan recurs. Interpreted in conjunction with maintenance_cycle_unit (e.g., 250 engine hours, 12 months, 500 acres). Sourced from OEM specifications and SAP PM maintenance strategy.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Hours' ;
    rdfs:comment 'Engine/operating hour threshold at which the next maintenance cycle is due. Calculated as last_completed_hours plus the usage-based cycle interval. Sourced from John Deere Operations Center telematics data.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemServiceBulletin rdf:type rdf:Property ;
    rdfs:label 'Oem Service Bulletin' ;
    rdfs:comment 'Original Equipment Manufacturer (OEM) service bulletin or technical service document number that this maintenance plan is based on or references (e.g., John Deere Technical Manual TM-XXXX). Ensures alignment with manufacturer specifications.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Required' ;
    rdfs:comment 'Indicates whether this maintenance plan includes tasks subject to OSHA regulatory requirements (e.g., lockout/tagout procedures, confined space entry, hazardous energy control). Triggers mandatory safety documentation on generated work orders.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precisionAgHardware rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Hardware' ;
    rdfs:comment 'Indicates whether this maintenance plan includes calibration or servicing tasks for precision agriculture hardware such as GPS/RTK receivers, VRA controllers, NDVI sensors, or auto-steer systems. Triggers specialized calibration task workflows.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Required Skill Level' ;
    rdfs:comment 'Minimum skill level required to execute the maintenance plan tasks. \'operator\' indicates basic tasks performable by equipment operators; \'certified_mechanic\' requires OEM-certified technicians. Drives workforce assignment in SAP SuccessFactors.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTools rdf:type rdf:Property ;
    rdfs:label 'Required Tools' ;
    rdfs:comment 'Comma-separated list or description of specialized tools and equipment required to execute the maintenance plan tasks (e.g., torque wrench, hydraulic press, RTK calibration kit, diagnostic scanner). Supports tool reservation and kitting.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPrecautions rdf:type rdf:Property ;
    rdfs:label 'Safety Precautions' ;
    rdfs:comment 'Free-text description of mandatory safety precautions required before and during execution of maintenance tasks in this plan (e.g., lockout/tagout procedures, PPE requirements, confined space protocols, chemical handling). Referenced in generated work orders.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this maintenance plan is tied to a specific agricultural season (e.g., pre-planting inspection, post-harvest winterization). When True, scheduling is aligned with the crop calendar to ensure equipment readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classification of the maintenance strategy driving this plan. \'time_based\' triggers on calendar intervals (e.g., annually); \'usage_based\' triggers on engine hours or acreage; \'condition_based\' triggers on sensor thresholds (e.g., oil pressure); \'predictive\' uses IoT/telematics analytics from John Deere Operations Center.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCount rdf:type rdf:Property ;
    rdfs:label 'Task Count' ;
    rdfs:comment 'Total number of individual maintenance task line items defined within this plan (e.g., lubrication, filter replacement, calibration, inspection). Provides a quick summary of plan complexity for scheduling and labor estimation.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each OEE measurement record. Primary key for the oee_record data product in the equipment domain Silver Layer.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Reference to the operational shift or work schedule period during which this OEE record was captured. Supports shift-level fleet performance analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:acceptableOutputQuantity rdf:type rdf:Property ;
    rdfs:label 'Acceptable Output Quantity' ;
    rdfs:comment 'Quantity of output meeting quality standards during the measurement period. Used as the numerator for quality rate calculation. For harvesting equipment, represents grain meeting grade standards; for sprayers, represents correctly applied area.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOperatingTimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Operating Time Min' ;
    rdfs:comment 'Total minutes the asset was actively operating (engine running and performing work) during the measurement period, as recorded by John Deere Operations Center telematics. Equals planned production time minus unplanned downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualThroughputRate rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Rate' ;
    rdfs:comment 'The measured actual throughput rate of the asset during operating time (e.g., acres per hour, gallons per minute). Compared against theoretical throughput rate to derive performance rate.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'Ratio of actual operating time to planned production time, expressed as a decimal (e.g., 0.9250 = 92.50%). Calculated as (Planned Production Time - Unplanned Downtime) / Planned Production Time. One of the three OEE component rates.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakdownCount rdf:type rdf:Property ;
    rdfs:label 'Breakdown Count' ;
    rdfs:comment 'Number of unplanned equipment breakdowns (failures requiring corrective maintenance work orders) that occurred during the measurement period. Drives unplanned downtime and is a key input to MTBF calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Gallons' ;
    rdfs:comment 'Total fuel consumed by the asset during the measurement period in US gallons, as reported by John Deere Operations Center telematics. Used for OPEX cost allocation, fuel efficiency benchmarking, and environmental reporting.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether GPS/RTK precision positioning was active on the asset during this measurement period. When true, telematics data (acres covered, field boundaries) is sourced from John Deere Operations Center GPS telemetry; when false, data may be manually entered.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idleTimeMin rdf:type rdf:Property ;
    rdfs:label 'Idle Time Min' ;
    rdfs:comment 'Total minutes the asset engine was running but not performing productive work (idling) during the measurement period. Captured via John Deere Operations Center telematics. Contributes to performance loss analysis and fuel waste identification.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The calendar date on which this OEE measurement was recorded. Used for daily and shift-level fleet performance trending and CAPEX justification reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement End Timestamp' ;
    rdfs:comment 'The precise date and time when the OEE measurement period ended (shift or day end). Combined with start timestamp to derive total measurement window duration.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Granularity of the OEE measurement period: shift-level (per operational shift), daily (24-hour calendar day), or weekly (7-day rolling). Determines aggregation level for KPI reporting.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Timestamp' ;
    rdfs:comment 'The precise date and time when the OEE measurement period began (shift or day start). Used for granular telematics alignment with John Deere Operations Center data.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minorStoppageCount rdf:type rdf:Property ;
    rdfs:label 'Minor Stoppage Count' ;
    rdfs:comment 'Number of brief, unplanned stoppages (typically under 10 minutes each) that did not trigger a formal work order but contributed to performance rate loss during the measurement period. Sourced from John Deere Operations Center telematics event data.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeBenchmarkTarget rdf:type rdf:Property ;
    rdfs:label 'Oee Benchmark Target' ;
    rdfs:comment 'The benchmark OEE target percentage (as a decimal) defined for the asset category (e.g., 0.8500 = 85% for combines). Sourced from asset category reference data. Used to assess performance gap and trigger CAPEX replacement reviews.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Composite OEE score expressed as a decimal (e.g., 0.7906 = 79.06%), calculated as Availability Rate × Performance Rate × Quality Rate. Primary KPI for fleet performance management and CAPEX justification for equipment replacement per ISO 55000.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeVariance rdf:type rdf:Property ;
    rdfs:label 'Oee Variance' ;
    rdfs:comment 'Difference between actual OEE percentage and the benchmark target (oee_percentage minus oee_benchmark_target), expressed as a signed decimal. Negative values indicate underperformance; used to prioritize maintenance interventions and CAPEX reviews.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputUnit rdf:type rdf:Property ;
    rdfs:label 'Output Unit' ;
    rdfs:comment 'Unit of measure for total and acceptable output quantity fields. Aligned with asset type and crop/operation context. Examples: acres for field coverage, bushels (BU) or metric tons (MT) for harvested grain, gallons for applied inputs.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRate rdf:type rdf:Property ;
    rdfs:label 'Performance Rate' ;
    rdfs:comment 'Ratio of actual throughput to theoretical maximum throughput during operating time, expressed as a decimal (e.g., 0.8800 = 88.00%). Captures speed losses and minor stoppages. One of the three OEE component rates.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDowntimeMin rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Min' ;
    rdfs:comment 'Total minutes of scheduled downtime during the measurement period for preventive maintenance (PM), calibration, operator breaks, or planned changeovers. Excluded from planned production time per OEE methodology.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedProductionTimeMin rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Min' ;
    rdfs:comment 'Total scheduled operating time in minutes for the asset during the measurement period, excluding planned maintenance windows and scheduled breaks. Denominator for availability rate calculation per OEE methodology.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'Ratio of acceptable output (meeting quality standards) to total output produced during the measurement period, expressed as a decimal (e.g., 0.9700 = 97.00%). Captures quality losses such as crop damage or mis-application. One of the three OEE component rates.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalThroughputRate rdf:type rdf:Property ;
    rdfs:label 'Theoretical Throughput Rate' ;
    rdfs:comment 'The ideal or nameplate throughput rate of the asset under optimal conditions (e.g., acres per hour for a combine, gallons per minute for a sprayer). Used as the denominator for performance rate calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputUnit rdf:type rdf:Property ;
    rdfs:label 'Throughput Unit' ;
    rdfs:comment 'Unit of measure for throughput rate fields (theoretical and actual), aligned with the asset type and operation. Examples: acres_per_hour for planters/combines, gallons_per_min for sprayers, bushels_per_hour for grain handling equipment.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAcresCovered rdf:type rdf:Property ;
    rdfs:label 'Total Acres Covered' ;
    rdfs:comment 'Total land area covered by the equipment during the measurement period, in acres, as recorded by GPS/RTK telematics from John Deere Operations Center. Key operational metric for field coverage efficiency and fuel cost allocation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOutputQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Output Quantity' ;
    rdfs:comment 'Total quantity of output produced by the asset during the measurement period (e.g., total acres covered, total bushels harvested, total gallons applied). Includes both acceptable and rejected/defective output.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unplannedDowntimeMin rdf:type rdf:Property ;
    rdfs:label 'Unplanned Downtime Min' ;
    rdfs:comment 'Total minutes of unplanned equipment downtime during the measurement period due to breakdowns, failures, or unexpected stoppages. Key input to availability rate and MTBF/MTTR analysis per ISO 55000.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Reference to the SAP S/4HANA work center or operational unit (farm site, field zone, processing facility) where the equipment was deployed during this OEE measurement period.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each spare part or consumable record in the MRO (Maintenance, Repair, and Operations) inventory master. Primary key for the parts_inventory data product.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsInventory .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification of the part based on annual consumption value: A = high-value/high-priority (top 80% of spend), B = medium-value (next 15%), C = low-value (bottom 5%). Drives differentiated inventory control policies, cycle count frequencies, and safety stock levels in SAP MM.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualConsumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Annual Consumption Quantity' ;
    rdfs:comment 'Total quantity of this part consumed in the trailing 12-month period, expressed in the base unit of measure. Used as the primary input for reorder point and safety stock calculations, and for identifying slow-moving inventory candidates for write-down.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP AM (Asset Management) asset class code indicating whether this part is capitalized as a CAPEX (Capital Expenditure) item or expensed as OPEX (Operational Expenditure). Drives accounting treatment and depreciation scheduling for high-value replacement components.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or rack location within the storage facility where this part is physically located (e.g., \'A-12-03\' = Aisle A, Rack 12, Shelf 3). Managed by Manhattan Associates WMS for precise pick-and-put-away operations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleAssetModels rdf:type rdf:Property ;
    rdfs:label 'Compatible Asset Models' ;
    rdfs:comment 'Comma-separated list of specific equipment model numbers or model families this part is compatible with (e.g., \'John Deere 8R 410, John Deere 8R 370, Case IH Magnum 380\'). Enables technicians to quickly identify applicable parts during field maintenance.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Operational criticality rating of the part: critical (stockout causes immediate equipment downtime during planting or harvest), non_critical (equipment can operate temporarily without), or safety_critical (required for operator safety per OSHA standards). Drives safety stock levels and emergency procurement protocols.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'The primary agricultural equipment category this part is compatible with (e.g., tractor, combine, planter, sprayer, irrigation system). Supports parts lookup during maintenance planning and work order creation. [ENUM-REF-CANDIDATE: tractor|combine|planter|sprayer|irrigation|tillage|harvester|grain_cart|general — promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this part or consumable is classified as a hazardous material requiring special storage, handling, or disposal procedures (e.g., hydraulic fluids, battery acid, pesticide concentrates). When True, triggers compliance with EPA and OSHA hazardous materials regulations and requires an associated Safety Data Sheet (SDS).' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the part record in the inventory master: active (stocked and available), inactive (temporarily not stocked), obsolete (superseded by a newer part number), discontinued (no longer available from OEM), or on_order (replenishment in progress). Governs whether the part can be issued against work orders.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Last Issued Date' ;
    rdfs:comment 'Date on which this part was most recently issued from inventory to a maintenance work order or field technician. Used to identify slow-moving or obsolete inventory and support inventory rationalization decisions.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this part. Used to assess inventory accuracy, identify shrinkage, and schedule next count per the annual physical inventory plan. Aligns with SAP MM inventory management cycle count functionality.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (GRN) for this part from a supplier. Supports inventory freshness analysis, supplier delivery performance tracking, and shelf-life management for perishable consumables.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'The SAP S/4HANA Material Management (MM) module material number uniquely identifying this spare part or consumable within the enterprise ERP system. Serves as the primary cross-system integration key for procurement, inventory, and maintenance workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'The upper inventory limit for this part, beyond which overstocking is flagged. Used in SAP MM min/max replenishment planning to prevent excess capital tied up in slow-moving MRO (Maintenance, Repair, and Operations) inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemPartNumber rdf:type rdf:Property ;
    rdfs:label 'Oem Part Number' ;
    rdfs:comment 'The original equipment manufacturer\'s (OEM) part number as published in the equipment service manual or parts catalog. Used for cross-referencing with supplier catalogs, warranty claims, and ordering from authorized dealers (e.g., John Deere, CNH Industrial, AGCO).' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level classification of the spare part by functional category. Drives inventory segmentation, procurement routing, and storage requirements. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|pneumatic|consumable|lubricant|filter|wear_part|structural|electronic — promote to reference product]' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed technical description of the spare part including specifications, dimensions, material composition, and application context. Supports accurate identification during procurement and maintenance activities.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable short name or title of the spare part or consumable (e.g., \'Air Filter Element\', \'Hydraulic Pump Seal Kit\', \'Combine Header Drive Belt\'). Used for display in work orders, purchase requisitions, and inventory reports.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Distinguishes the nature of the inventory item: spare_part (replacement component), consumable (single-use item such as oil or filter), tool (maintenance tooling), assembly (multi-component unit), or sub_assembly (partial assembly). Drives MRO (Maintenance, Repair, and Operations) inventory policy and cost allocation between CAPEX and OPEX.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP organizational unit (plant code) representing the farm site, maintenance facility, or distribution center where this part inventory record is maintained. Enables multi-plant inventory management across geographically distributed agricultural operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The minimum stock quantity threshold at which a replenishment purchase requisition is automatically triggered in SAP MM MRP (Material Requirements Planning). Calculated based on average daily consumption during peak seasons (planting/harvest) and supplier lead time to prevent equipment downtime.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'The standard replenishment order quantity triggered when stock falls to or below the reorder point. Optimized to balance procurement costs, storage capacity, and supplier minimum order quantities (MOQ). Drives automated purchase requisition creation in SAP MM.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock quantity maintained above the reorder point to absorb demand variability and supply disruptions during critical agricultural seasons (planting, harvest). Particularly important for critical-classified parts where stockout causes immediate equipment downtime.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'Reference number for the Safety Data Sheet (SDS) associated with this hazardous part or consumable. Required by OSHA Hazard Communication Standard (HazCom) for all hazardous chemicals stored in the workplace. Null for non-hazardous parts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum storage duration in days before the part or consumable degrades or expires (applicable to lubricants, chemicals, rubber seals, and other perishable MRO items). Null for non-perishable parts. Supports FEFO (First Expired First Out) inventory management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockQuantity rdf:type rdf:Property ;
    rdfs:label 'Stock Quantity' ;
    rdfs:comment 'Current on-hand stock quantity of the part expressed in the base unit of measure (UOM). Represents unrestricted-use stock available for maintenance work orders. Updated in real time via goods receipts (GRN) and goods issues from SAP MM or Manhattan Associates WMS.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The supplier\'s own catalog or part number for this item, as used in purchase orders (PO) and goods receipt notes (GRN). Enables accurate ordering and receiving reconciliation with supplier invoices and packing lists.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total monetary value of current on-hand stock, calculated as stock_quantity multiplied by unit_cost. Represents the balance sheet carrying value of MRO (Maintenance, Repair, and Operations) inventory for financial reporting under GAAP/IFRS. Refreshed upon each inventory transaction.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The cost accounting method used to value this part\'s inventory: standard_cost (fixed standard price), moving_average (weighted average updated on each receipt), fifo (first-in first-out), or lifo (last-in first-out). Configured in SAP MM material master and governs financial reporting treatment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'OEM or supplier warranty duration in months from the date of installation or purchase. Supports warranty claim tracking and cost recovery from suppliers for premature part failures. Null if no warranty applies.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyClass rdf:type rdf:Property ;
    rdfs:label 'Accuracy Class' ;
    rdfs:comment 'Standardized accuracy classification tier for the precision device, enabling fleet-level reporting and field assignment decisions. Sub-inch RTK devices are required for high-precision VRA and planting operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification' ;
    rdfs:comment 'Manufacturer-stated positional or measurement accuracy specification for the device (e.g., \'<2.5 cm RTK\', \'<1 inch RTK sub-inch\', \'±0.5% flow rate\'). Critical for VRA prescription compliance, RTK guidance validation, and GLOBALG.A.P. precision agriculture certification.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Internal fixed asset tag or barcode number affixed to the physical device for inventory control and asset audits. Corresponds to the asset tag in SAP S/4HANA Fixed Asset Accounting (FI-AA) and physical inventory records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationTechnician rdf:type rdf:Property ;
    rdfs:label 'Calibration Technician' ;
    rdfs:comment 'Name or identifier of the technician or certified service provider who performed the most recent calibration. Required for audit trail and GLOBALG.A.P. record-keeping compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Primary data communication protocol used by the precision device to transmit data to the FMIS, telematics platform, or ISOBUS terminal. Determines integration architecture and data pipeline design. [ENUM-REF-CANDIDATE: ISOBUS|CAN_bus|NMEA_0183|NMEA_2000|RS232|Bluetooth|WiFi|cellular_4G|cellular_5G|LoRaWAN — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionSource rdf:type rdf:Property ;
    rdfs:label 'Correction Source' ;
    rdfs:comment 'Differential correction signal source used by GPS/RTK receivers to achieve sub-inch or sub-decimeter accuracy (e.g., RTK base station, WAAS, John Deere StarFire, Trimble CenterPoint RTX). Determines achievable accuracy class and subscription cost allocation. [ENUM-REF-CANDIDATE: RTK_base_station|SBAS|WAAS|OmniSTAR|StarFire|CenterPoint_RTX|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataOutputFormat rdf:type rdf:Property ;
    rdfs:label 'Data Output Format' ;
    rdfs:comment 'Primary data output format generated by the precision device for integration with FMIS platforms, GIS systems, and agronomic analytics tools (e.g., ISOXML for ISOBUS-compliant devices, shapefile for GIS integration with Esri ArcGIS).' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceName rdf:type rdf:Property ;
    rdfs:label 'Device Name' ;
    rdfs:comment 'Human-readable descriptive name assigned to the precision device for operational identification (e.g., \'RTK Receiver - Combine 4\', \'NDVI Sensor - Field 12 Sprayer\'). Supports field crew identification and FMIS integration.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceStatus rdf:type rdf:Property ;
    rdfs:label 'Device Status' ;
    rdfs:comment 'Current operational lifecycle status of the precision device. Drives maintenance scheduling, calibration compliance alerts, and asset utilization reporting. \'calibration_due\' triggers workflow in CMMS/FMIS.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware version installed on the precision device (e.g., \'3.12.1\'). Critical for compatibility validation with ISOBUS terminals, VRA controllers, and FMIS platforms. Tracked to ensure OEM-recommended firmware levels are maintained.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmisDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Fmis Device Code' ;
    rdfs:comment 'External device identifier assigned by the connected FMIS platform (e.g., John Deere Operations Center device ID, Climate FieldView device ID, Trimble Ag Software device ID). Used for cross-system data reconciliation and telematics data linkage.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the precision device was physically installed on or integrated with the parent equipment asset. Marks the start of the device\'s operational lifecycle on that asset. Used for warranty period calculation and CAPEX depreciation tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipRating rdf:type rdf:Property ;
    rdfs:label 'Ip Rating' ;
    rdfs:comment 'IEC 60529 Ingress Protection rating indicating the device\'s resistance to dust and water (e.g., \'IP67\' for dust-tight and immersion-resistant). Critical for field deployment suitability assessment in agricultural environments.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isobusCertified rdf:type rdf:Property ;
    rdfs:label 'Isobus Certified' ;
    rdfs:comment 'Indicates whether the precision device holds official ISOBUS (ISO 11783) certification, enabling plug-and-play interoperability with ISOBUS-compliant tractors and implements. Required for VRA controller and section control module compatibility validation.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date on which the most recent calibration of the precision device was performed. Used to calculate calibration compliance status and trigger next calibration scheduling. Mandatory for GLOBALG.A.P. and FSMA traceability compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) of the precision device (e.g., Trimble, John Deere, Raven Industries, Ag Leader, Topcon). Used for warranty management, technical support escalation, and procurement analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer-assigned model or part number for the precision device (e.g., \'Trimble NAV-900\', \'Raven Viper 4+\'). Used for spare parts procurement, firmware compatibility checks, and OEM service bulletin tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Scheduled date by which the next calibration of the precision device must be completed to maintain compliance. Calculated from last_calibration_date plus calibration_interval_days. Drives CMMS preventive maintenance work order generation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Max C' ;
    rdfs:comment 'Maximum ambient temperature in degrees Celsius at which the precision device is rated to operate reliably. Used for summer deployment planning and heat-stress operational risk assessment in field conditions.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTempMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Min C' ;
    rdfs:comment 'Minimum ambient temperature in degrees Celsius at which the precision device is rated to operate reliably. Used for seasonal deployment planning and cold-climate operational risk assessment.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSource rdf:type rdf:Property ;
    rdfs:label 'Power Source' ;
    rdfs:comment 'Primary power supply method for the precision device. Determines installation requirements, field operational constraints, and maintenance considerations for remote or battery-powered sensors.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original acquisition cost of the precision device in the operating currency. Used for CAPEX tracking, asset depreciation calculations, and ROI analysis of precision agriculture hardware investments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date the precision device was purchased or procured. Used as the anchor date for warranty period calculation, CAPEX depreciation schedules, and asset lifecycle reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionCount rdf:type rdf:Property ;
    rdfs:label 'Section Count' ;
    rdfs:comment 'Number of independently controllable sections on a section control module or VRA controller (e.g., 12-section boom sprayer, 24-row planter). Determines granularity of variable rate application and overlap reduction capability.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Signal Frequency Mhz' ;
    rdfs:comment 'Operating signal frequency in megahertz for GPS/RTK receivers and radio-based precision devices (e.g., 1575.42 MHz for GPS L1, 1227.60 MHz for GPS L2). Used for interference analysis and regulatory spectrum compliance with FCC/USDA requirements.' ;
    rdfs:domain ind:PrecisionDevice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalLeaseId rdf:type rdf:Property ;
    rdfs:label 'Rental Lease Id' ;
    rdfs:comment 'Unique surrogate identifier for each rental, lease, or custom hire agreement record in the equipment domain. Primary key for the rental_lease data product.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule Id' ;
    rdfs:comment 'Foreign key linking to invoice.billing_schedule. Business justification: Equipment rental and lease agreements with periodic payment structures (monthly, seasonal) are governed by billing schedules. Agriculture lease agreements for land-use equipment require automated recu' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingSchedule .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Custom hire service billing: when a farm provides equipment hire services to neighboring operations or agribusiness customers, the rental_lease counterparty must be linked to a customer account for in' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:acreageCap rdf:type rdf:Property ;
    rdfs:label 'Acreage Cap' ;
    rdfs:comment 'Maximum contracted acreage covered under the agreement before excess-use charges apply. Applicable to per-acre custom hire and seasonal lease agreements. Supports fleet cost optimization and field coverage planning.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the rental, lease, or custom hire agreement, used for cross-referencing with counterparty documents, SAP FI lease accounting, and IFRS 16 disclosures.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the rental or lease agreement. Draft indicates pending execution; active indicates in-force; suspended indicates temporarily paused; terminated indicates early exit; expired indicates natural end-of-term; closed indicates fully settled and archived.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the equipment agreement: operating_lease (off-balance-sheet lease per IFRS 16 short-term exemption), finance_lease (on-balance-sheet right-of-use asset), rental (short-term ad hoc hire), custom_hire_inbound (external operator performs field operations for the enterprise), or custom_hire_outbound (enterprise provides equipment/operators to a third party). Drives CAPEX/OPEX treatment and revenue recognition.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customHireServiceType rdf:type rdf:Property ;
    rdfs:label 'Custom Hire Service Type' ;
    rdfs:comment 'For custom hire agreements (inbound or outbound), specifies the field operation service being contracted: planting, spraying, harvesting, hauling, tillage, or fertilizing. Set to not_applicable for pure equipment leases and rentals. [ENUM-REF-CANDIDATE: planting|spraying|harvesting|hauling|tillage|fertilizing|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationPenalty rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty' ;
    rdfs:comment 'Contractual penalty amount payable if the agreement is terminated before the end_date. Used for lease exit cost analysis and IFRS 16 lease modification accounting. Null if no early termination clause exists.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Equipment Description' ;
    rdfs:comment 'Free-text description of the agricultural machinery or equipment covered by the agreement (e.g., \'John Deere 8R 410 Tractor\', \'60-ft Case IH 4440 Sprayer\'). Used when the asset is not registered in the internal asset master or for custom hire where the counterparty supplies equipment.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date on which the agreement was formally signed and executed by both parties. May differ from the start_date (effective date). Used as the principal business event date for audit and legal reference.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hoursCap rdf:type rdf:Property ;
    rdfs:label 'Hours Cap' ;
    rdfs:comment 'Maximum contracted engine or operational hours allowed under the agreement before excess-use charges apply. Applicable to hourly-rate rentals and operating leases. Sourced from John Deere Operations Center telematics for monitoring.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference number of the most recent invoice issued or received under this agreement. Used for accounts payable/receivable matching in SAP FI and payment reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The schedule at which lease or rental payments are due: monthly, quarterly, seasonal (aligned to crop season), annual, per_use (invoiced per event), or upfront (single prepayment). Drives accounts payable scheduling in SAP FI.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricType rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Type' ;
    rdfs:comment 'The type of quality or performance metric tracked under this agreement. For custom hire, this may be acres_completed, hours_logged, yield_achieved, or application_rate. Supports service-level verification and payment milestone validation.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricValue rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Value' ;
    rdfs:comment 'The actual recorded value for the performance_metric_type tracked under this agreement (e.g., 450.5 acres completed, 320 hours logged). Used for milestone billing, service verification, and OEE benchmarking.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOption rdf:type rdf:Property ;
    rdfs:label 'Purchase Option' ;
    rdfs:comment 'Indicates whether the agreement includes an option for the enterprise to purchase the equipment at or before the end_date. True if a purchase option exists. A reasonably certain purchase option affects IFRS 16 finance lease classification.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOptionPrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Price' ;
    rdfs:comment 'The contractual price at which the enterprise may purchase the leased equipment if the purchase_option is true. Used for lease vs. buy analysis and IFRS 16 lease classification assessment.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The contracted rate per unit as defined by rate_structure (e.g., dollars per acre, dollars per hour, monthly payment amount). Used for invoice validation and cost benchmarking against owned-equipment OPEX.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStructure rdf:type rdf:Property ;
    rdfs:label 'Rate Structure' ;
    rdfs:comment 'The billing rate basis for the agreement: per_acre (common for custom hire spraying/planting), per_hour (equipment rental), monthly (operating lease), seasonal (crop-season lease), annual (finance lease), or per_day (short-term rental). Drives invoice calculation and cost allocation.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the agreement includes a contractual option to renew at or before the end_date. True if a renewal option exists. Relevant for IFRS 16 lease term assessment and fleet planning.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnConditionTerms rdf:type rdf:Property ;
    rdfs:label 'Return Condition Terms' ;
    rdfs:comment 'Free-text description of the contractual conditions under which the equipment must be returned at agreement end (e.g., \'normal wear and tear acceptable\', \'full service required\', \'maximum 2000 hours\'). Used for asset return inspection and dispute resolution.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapLeaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Lease Contract Number' ;
    rdfs:comment 'The SAP S/4HANA FI lease accounting contract reference number (RE-FX or IFRS 16 module) associated with this agreement. Enables reconciliation between the operational rental_lease record and the financial accounting right-of-use asset and lease liability entries.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable security deposit paid or received at agreement commencement. Recorded as a financial asset (inbound) or liability (outbound) in SAP FI. Null if no deposit is required.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAcreageCovered rdf:type rdf:Property ;
    rdfs:label 'Total Acreage Covered' ;
    rdfs:comment 'Total number of acres covered or serviced under this agreement. For custom hire, this is the contracted field area to be planted, sprayed, or harvested. Used for per-acre billing reconciliation and yield-per-acre (YPM) cost analysis.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAgreementValue rdf:type rdf:Property ;
    rdfs:label 'Total Agreement Value' ;
    rdfs:comment 'The total contracted monetary value of the agreement over its full term. For IFRS 16 finance leases, this is the undiscounted sum of lease payments. Used for CAPEX/OPEX planning, budget allocation, and lease liability recognition.' ;
    rdfs:domain ind:RentalLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationRateActual rdf:type rdf:Property ;
    rdfs:label 'Application Rate Actual' ;
    rdfs:comment 'Actual rate of material (seed, fertilizer, agrochemical) being applied by the implement at the time of the reading, in the unit defined by the active VRA prescription. Supports compliance verification against prescribed rates and MRL (Maximum Residue Limit) audit trails.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationRateTarget rdf:type rdf:Property ;
    rdfs:label 'Application Rate Target' ;
    rdfs:comment 'Prescribed target rate of material application from the active VRA prescription at the time of the reading, in the same unit as actual_application_rate. Enables deviation analysis between prescribed and actual application for compliance and agronomic reporting.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantTempC rdf:type rdf:Property ;
    rdfs:label 'Coolant Temp C' ;
    rdfs:comment 'Engine coolant temperature in degrees Celsius at the time of the reading. Elevated values trigger predictive maintenance alerts and can indicate impending engine failure.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtcSeverity rdf:type rdf:Property ;
    rdfs:label 'Dtc Severity' ;
    rdfs:comment 'Severity classification of the active Diagnostic Trouble Code (DTC) at the time of the reading. \'Critical\' faults require immediate equipment shutdown; \'warning\' faults require scheduled maintenance; \'informational\' faults are advisory only.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineLoadPct rdf:type rdf:Property ;
    rdfs:label 'Engine Load Pct' ;
    rdfs:comment 'Engine load as a percentage of maximum rated capacity at the time of the reading. Supports OEE calculation, fuel consumption benchmarking, and predictive maintenance triggers.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Engine speed in revolutions per minute at the time of the reading. Used for fuel efficiency analysis, operator behavior monitoring, and predictive maintenance trigger evaluation.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldBoundaryMatch rdf:type rdf:Property ;
    rdfs:label 'Field Boundary Match' ;
    rdfs:comment 'Indicates whether the equipment\'s GPS position at the time of the reading falls within the registered boundary of the assigned field. False values indicate potential off-field operation, boundary drift, or GPS error.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelConsumptionRateLph rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Rate Lph' ;
    rdfs:comment 'Instantaneous fuel consumption rate in liters per hour at the time of the reading. Supports OPEX cost allocation, carbon footprint reporting, and fuel efficiency benchmarking across the fleet.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelPct rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Pct' ;
    rdfs:comment 'Remaining fuel level in the equipment\'s tank expressed as a percentage of full capacity at the time of the reading. Supports dispatch planning, refueling logistics, and downtime prevention.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsAltitudeM rdf:type rdf:Property ;
    rdfs:label 'Gps Altitude M' ;
    rdfs:comment 'Altitude of the equipment above mean sea level in meters at the time of the reading, as reported by the onboard GPS/RTK receiver. Supports terrain-aware precision agriculture analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundSpeedKph rdf:type rdf:Property ;
    rdfs:label 'Ground Speed Kph' ;
    rdfs:comment 'Actual ground speed of the equipment in kilometers per hour as measured by the GPS receiver at the time of the reading. Used for field coverage rate calculations, operator compliance, and OEE analysis.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Direction of travel of the equipment in degrees from true north (0–360) at the time of the reading. Supports field pass mapping, coverage analysis, and auto-steer validation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Pressure Kpa' ;
    rdfs:comment 'Hydraulic system pressure in kilopascals at the time of the reading. Abnormal values indicate hydraulic system faults and trigger corrective maintenance work orders.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementDepthCm rdf:type rdf:Property ;
    rdfs:label 'Implement Depth Cm' ;
    rdfs:comment 'Working depth of the attached implement (e.g., planter, tillage tool) in centimeters at the time of the reading. Supports agronomic compliance verification, VRA prescription audit trails, and soil management analytics.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementWidthM rdf:type rdf:Property ;
    rdfs:label 'Implement Width M' ;
    rdfs:comment 'Working width of the attached implement in meters at the time of the reading. Used for field coverage area calculations and pass efficiency analysis.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The UTC timestamp when this telemetry record was received and ingested into the lakehouse Silver layer from the source system (John Deere Operations Center, Trimble, or other IoT platform). Supports data latency monitoring and pipeline auditing.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Load Weight Kg' ;
    rdfs:comment 'Weight of the load carried by the equipment (e.g., grain in combine hopper, fertilizer in applicator) in kilograms at the time of the reading. Supports yield estimation, logistics planning, and axle load compliance.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviReading rdf:type rdf:Property ;
    rdfs:label 'Ndvi Reading' ;
    rdfs:comment 'Normalized Difference Vegetation Index value captured by the onboard crop sensor at the time of the reading, ranging from -1.0 to 1.0. Supports variable rate application (VRA) decisions, crop health monitoring, and precision agriculture analytics.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoEngaged rdf:type rdf:Property ;
    rdfs:label 'Pto Engaged' ;
    rdfs:comment 'Indicates whether the Power Take-Off (PTO) shaft was engaged at the time of the reading. PTO engagement signals active implement operation (e.g., mower, spreader, pump) and is used for productive-time classification in OEE calculations.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptoRpm rdf:type rdf:Property ;
    rdfs:label 'Pto Rpm' ;
    rdfs:comment 'Power Take-Off shaft speed in revolutions per minute at the time of the reading when PTO is engaged. Used to verify correct implement operating speed and diagnose PTO-related faults.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readingQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Reading Quality Flag' ;
    rdfs:comment 'Data quality classification for this telemetry record assigned during Silver layer ingestion. \'Valid\' records are used in analytics; \'suspect\' records require review; \'invalid\' records are excluded from reporting. Supports data governance and AI/ML feature engineering.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The precise UTC timestamp when the telemetry event was recorded by the equipment\'s onboard controller. EVENT_TIMESTAMP per EVENT_LOG role minimum. Distinct from ingestion audit timestamps.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtkCorrectionStatus rdf:type rdf:Property ;
    rdfs:label 'Rtk Correction Status' ;
    rdfs:comment 'Quality indicator for the GPS/RTK positional correction applied at the time of the reading. \'Fixed\' indicates sub-inch accuracy; \'float\' and \'dgps\' indicate degraded precision. Critical for VRA prescription audit trails and auto-steer accuracy validation.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Cellular or satellite communication signal strength in decibel-milliwatts (dBm) at the time of the reading. Supports data quality assessment, connectivity gap analysis, and telematics infrastructure planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionDelayMs rdf:type rdf:Property ;
    rdfs:label 'Transmission Delay Ms' ;
    rdfs:comment 'Latency in milliseconds between the equipment recording the telemetry event and the data being received by the cloud platform. Supports data quality scoring and near-real-time fleet dashboard reliability assessment.' ;
    rdfs:domain ind:TelematicsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for each warranty claim record. Primary key for the warranty_claim data product within the equipment domain.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Approved Repair Cost' ;
    rdfs:comment 'The repair cost amount formally approved by the OEM or dealer for reimbursement. May differ from claimed_repair_cost due to partial approvals or rate adjustments. Used for warranty cost recovery reporting.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the warranty claim as assigned by the internal claims management system. Used for communication with dealers, OEMs, and internal stakeholders.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the warranty claim through the OEM/dealer adjudication process. Tracks progression from initial submission through final payment or rejection. [ENUM-REF-CANDIDATE: submitted|under_review|approved|rejected|paid|closed — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the warranty claim by the nature of the defect or failure being claimed. Drives OEM adjudication routing and informs procurement reliability analysis. [ENUM-REF-CANDIDATE: parts_defect|manufacturing_defect|premature_failure|design_defect|software_defect — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Claimed Repair Cost' ;
    rdfs:comment 'The total repair cost amount submitted to the OEM or dealer as part of the warranty claim, including labor, parts, and any external service costs. Represents the gross amount claimed before OEM adjudication.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'OEM-defined code identifying the specific component, assembly, or sub-system that is the subject of the warranty claim (e.g., engine, transmission, hydraulic pump, GPS/RTK receiver, VRA controller).' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Human-readable description of the component, part, or assembly being claimed under warranty. Complements the component_code for reporting and communication with dealers and OEMs.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the warranty claim has been formally disputed with the OEM or dealer following an initial rejection or partial approval. True when a dispute has been raised; False otherwise.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes documenting the basis for disputing a rejected or partially approved warranty claim, including supporting evidence references and escalation actions taken with the OEM or dealer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total number of hours the equipment asset was out of service due to the failure covered by this warranty claim. Used for Overall Equipment Effectiveness (OEE) impact analysis and operational loss quantification.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureDate rdf:type rdf:Property ;
    rdfs:label 'Failure Date' ;
    rdfs:comment 'The calendar date on which the equipment failure or defect was first observed or reported in the field. Used to determine warranty coverage eligibility relative to purchase date and warranty period.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative description of the equipment failure, defect symptoms, and observed conditions at the time of failure. Supports OEM adjudication and root cause analysis.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureHours rdf:type rdf:Property ;
    rdfs:label 'Failure Hours' ;
    rdfs:comment 'Total engine/operational hours recorded on the asset at the time of failure. Critical for warranty eligibility determination based on hour-based warranty thresholds and for OEM reliability analysis.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostClaimed rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Claimed' ;
    rdfs:comment 'The labor cost component of the total claimed repair cost submitted to the OEM or dealer. Enables granular cost breakdown analysis for warranty cost recovery and labor rate benchmarking.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemCaseReference rdf:type rdf:Property ;
    rdfs:label 'Oem Case Reference' ;
    rdfs:comment 'The case or claim reference number assigned by the Original Equipment Manufacturer (OEM) or authorized dealer upon receipt of the warranty claim submission. Used for tracking claim status with the OEM.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCostClaimed rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Claimed' ;
    rdfs:comment 'The parts and materials cost component of the total claimed repair cost submitted to the OEM or dealer. Supports parts cost recovery tracking and procurement reliability analysis by component.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The calendar date on which the OEM or dealer issued the reimbursement payment for the approved warranty claim. Used for accounts receivable reconciliation and warranty cost recovery tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'The actual monetary amount received from the OEM or dealer as reimbursement for the approved warranty claim. Populated upon payment confirmation. Used for CAPEX/OPEX cost recovery reconciliation.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'The calendar date on which the OEM or dealer formally rejected the warranty claim. Populated only when claim_status is \'rejected\'. Used for dispute tracking and procurement reliability analysis.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Repair Completed Date' ;
    rdfs:comment 'The calendar date on which the warranty repair was completed and the asset was returned to service. Used to calculate total repair cycle time and asset availability metrics.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serialNumberComponent rdf:type rdf:Property ;
    rdfs:label 'Serial Number Component' ;
    rdfs:comment 'Serial number of the specific failed component or part, where available. Supports traceability for batch/lot defect analysis and OEM recall investigations.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Classification of the warranty coverage type under which the claim is filed. Determines applicable coverage terms, reimbursement rates, and OEM adjudication rules. [ENUM-REF-CANDIDATE: standard|extended|powertrain|precision_ag_hardware|emissions — promote to reference product if additional types are required]' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: When a work order identifies required parts or external services, a purchase requisition is raised as the originating procurement document. Agriculture equipment managers trace work_order → purchase_r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:serviceVendorId rdf:type rdf:Property ;
    rdfs:label 'Service Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Work orders for external maintenance services (dealer repairs, specialist contractors) are executed by procurement vendors. The work_order has external_service_cost indicating vendor involvement. Link' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work was completed and the equipment was returned to service. Used to calculate MTTR, downtime duration, and OEE impact. Maps to SAP PM Actual Finish Date/Time (IDAT3/IUZEIT2).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of labor hours recorded against the work order upon completion. Used for OPEX cost tracking, technician productivity analysis, and variance reporting against planned hours. Maps to SAP PM Actual Work (ISMNW).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work physically commenced on the equipment. Used to calculate response time, schedule adherence, and Mean Time to Repair (MTTR). Maps to SAP PM Actual Start Date/Time (IDAT2/IUZEIT).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakdownIndicator rdf:type rdf:Property ;
    rdfs:label 'Breakdown Indicator' ;
    rdfs:comment 'Flag indicating whether this work order was triggered by an unplanned equipment breakdown (True) versus a scheduled maintenance activity (False). Drives MTBF calculations and reliability analytics. Maps to SAP PM Breakdown Indicator (MSAUS).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text technician notes recorded at work order completion describing the root cause identified, corrective actions taken, and any follow-up recommendations. Supports knowledge management and recurring fault analysis. Maps to SAP PM Technical Findings (LTXT).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Downtime Hours' ;
    rdfs:comment 'Total hours the equipment asset was unavailable for field operations due to this maintenance event. Critical input for OEE (Overall Equipment Effectiveness) calculation and harvest/planting window impact analysis. Maps to SAP PM Breakdown Duration.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Total monetary cost of external contractor or third-party service charges applied to the work order (e.g., OEM dealer service, specialist repair). Supports make-vs-buy analysis and total maintenance cost reporting. Maps to SAP PM external service orders (PM03).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Standardized equipment fault or failure code from the CMMS fault code catalogue (e.g., SAP PM Damage Code or John Deere diagnostic trouble code). Enables structured failure mode analysis, MTBF calculations, and reliability reporting. Maps to SAP PM Damage Code (QMCOD).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlant rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plant' ;
    rdfs:comment 'SAP organizational unit (plant code) responsible for executing the maintenance work order. Determines the maintenance workshop, spare parts inventory, and labor pool. Maps to SAP PM Maintenance Plant (SWERK).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the work order as assigned by the CMMS (SAP PM). Used for cross-system reference, technician communication, and audit trails. Maps to SAP PM Order Number (AUFNR).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order within the CMMS workflow. Drives operational dashboards, KPI reporting, and SLA compliance tracking. Maps to SAP PM system status (STAT). Values: open, in_progress, completed, cancelled, on_hold.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the maintenance work order by activity type: PM (Preventive Maintenance), CM (Corrective Maintenance), INSP (Inspection), CALIB (Calibration), OVERHAUL, or SAFETY. Drives scheduling logic, cost allocation, and OPEX reporting. Maps to SAP PM Order Type (AUART). [ENUM-REF-CANDIDATE: PM|CM|INSP|CALIB|OVERHAUL|SAFETY — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsLineCount rdf:type rdf:Property ;
    rdfs:label 'Parts Line Count' ;
    rdfs:comment 'Total number of spare parts or material consumption line items recorded against this work order. Provides a quick header-level indicator of parts complexity and supports inventory replenishment trigger logic without requiring line-level joins.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete the maintenance work order, as planned by the maintenance scheduler. Used for workforce capacity planning and budget forecasting. Maps to SAP PM Planned Work (ARBEI).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Numeric priority ranking assigned to the work order indicating urgency and scheduling precedence. 1=Emergency/Critical, 2=High, 3=Medium, 4=Low/Routine. Drives resource allocation and response time SLAs. Maps to SAP PM Priority (PRIOK).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the equipment fault or maintenance requirement was first reported by the operator or detected by telematics (John Deere Operations Center). Principal business event timestamp for the work order lifecycle. Maps to SAP PM Malfunction Start Date/Time (QMDAT/QMZEIT).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Number' ;
    rdfs:comment 'Reference number of the safety permit (lock-out/tag-out, confined space, hot work) issued for this maintenance work order. Required for OSHA compliance documentation and safety audit trails.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Required' ;
    rdfs:comment 'Flag indicating whether a safety permit (e.g., lock-out/tag-out, confined space entry, chemical handling permit) is required before maintenance work can commence. Supports OSHA compliance and safety management workflows.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the work order was formally signed off and closed by the authorizing supervisor. Marks the official end of the work order lifecycle and triggers cost settlement in SAP CO.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signedOffBy rdf:type rdf:Property ;
    rdfs:label 'Signed Off By' ;
    rdfs:comment 'Name or employee identifier of the supervisor or maintenance manager who formally approved and closed the work order. Required for quality assurance, regulatory compliance, and audit trail purposes. Maps to SAP PM Completed By (ERNAM).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Total OPEX cost of the work order encompassing labor, parts, and external service charges. SSOT for maintenance cost reporting by asset, cost center, and crop enterprise. Maps to SAP CO total actual costs settled to the maintenance order (TKOSTEN).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each accounts payable invoice line item record in the silver layer lakehouse. Primary key for this entity. Entity role: TRANSACTION_LINE.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeApInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Finance Ap Invoice Id' ;
    rdfs:comment 'Foreign key reference to the parent AP invoice header record. Establishes the header-to-line relationship for this invoice line item. Satisfies TRANSACTION_LINE HEADER_REFERENCE category.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceApInvoice .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt note (GRN) record confirming physical receipt of agricultural inputs against which this invoice line is matched. Supports three-way matching and COGS allocation. Maps to SAP MIGO goods receipt document.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementGoodsReceipt .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'FK to finance.profit_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:capexOpexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Indicator' ;
    rdfs:comment 'Indicates whether this invoice line represents a capital expenditure (CAPEX) for long-term asset investment or an operational expenditure (OPEX) for day-to-day farming operations. Critical for financial reporting, budgeting, and EBITDA calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropSeason rdf:type rdf:Property ;
    rdfs:label 'Crop Season' ;
    rdfs:comment 'The agricultural crop season or growing year to which this invoice line expenditure is attributed (e.g., \'2024-Spring\', \'2024-Fall\'). Enables crop enterprise budgeting, seasonal COGS allocation, and year-over-year financial analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The actual or expected date on which the agricultural inputs or services on this invoice line were delivered or performed. Used for accrual accounting, crop season alignment, and PHI/REI compliance tracking for agrochemicals.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The monetary discount applied to this invoice line as negotiated with the vendor (e.g., volume rebate, early payment discount, seasonal pricing). Reduces the net payable amount for this line.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmoIndicator rdf:type rdf:Property ;
    rdfs:label 'Gmo Indicator' ;
    rdfs:comment 'Indicates whether the agricultural input on this invoice line contains or is derived from genetically modified organisms (GMO). Required for COOL (Country of Origin Labeling), USDA NOP organic certification compliance, and customer transparency reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'The gross monetary value of this invoice line before tax and discounts, calculated as quantity multiplied by unit price. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category. Maps to SAP RSEG-WRBTR (line item amount in document currency).' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent AP invoice, used to order and uniquely identify each line within the invoice. Satisfies TRANSACTION_LINE LINE_SEQUENCE category. Corresponds to SAP RSEG-BUZEI (line item number).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of this AP invoice line within the accounts payable workflow. \'open\' = awaiting posting; \'posted\' = GL entry created; \'blocked\' = held for review (e.g., price variance); \'reversed\' = accounting reversal applied; \'cancelled\' = line voided; \'parked\' = saved but not yet posted. Maps to SAP FI document status.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingStatus rdf:type rdf:Property ;
    rdfs:label 'Matching Status' ;
    rdfs:comment 'Status of the three-way matching process (PO, GRN, Invoice) for this line item. \'unmatched\' = no match yet; \'po_matched\' = matched to PO only; \'grn_matched\' = matched to GRN only; \'three_way_matched\' = fully matched; \'exception\' = variance requiring resolution. Critical for SOX controls.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net payable amount for this invoice line after applying discounts and before tax (line_amount minus discount_amount). Used for COGS allocation, crop enterprise budgeting, and EBITDA reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'The specific line item number on the referenced purchase order that corresponds to this invoice line, enabling precise PO-to-invoice line matching. Maps to SAP EKPO-EBELP.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'The monetary difference between the invoiced unit price and the purchase order unit price for this line, used to identify and resolve invoice discrepancies. A non-zero value triggers the matching exception workflow. Maps to SAP MM invoice verification price variance.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of the material or service invoiced on this line. Satisfies TRANSACTION_LINE LINE_QUANTITY category. Used in conjunction with unit_of_measure for volume-based COGS allocation and three-way matching against GRN quantity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between the invoiced quantity and the goods receipt quantity for this line, used to identify over- or under-billing by vendors. Supports three-way matching exception management and vendor performance tracking.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record from which this invoice line was ingested into the lakehouse silver layer (e.g., SAP_S4HANA for FI-AP module, ORACLE_NETSUITE for NetSuite AP, GRANULAR for Granular Farm Management). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The tax amount applicable to this invoice line, including sales tax, VAT, or use tax as applicable by jurisdiction. Used for tax reporting and accounts payable accruals.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax determination code applied to this invoice line, identifying the applicable tax rate and jurisdiction rules (e.g., V1 for input VAT, U1 for use tax). Maps to SAP FI MWSKZ tax code.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The agreed price per unit of measure for the material or service on this invoice line, as stated by the vendor. Used for price variance analysis against PO unit price and market benchmarks (DTN/WASDE). Maps to SAP RSEG-WRBTR / quantity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Primary key for ap_payment' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Internal identifier of the company\'s house bank account from which the payment was disbursed. References the SAP house bank/account ID configuration. Supports bank account-level cash position monitoring and liquidity management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Reference to the automated payment run batch that generated this disbursement. SAP F110 payment run identifier used to group payments executed in the same batch cycle, supporting seasonal payment cycles aligned with planting and harvest.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:bankClearingDate rdf:type rdf:Property ;
    rdfs:label 'Bank Clearing Date' ;
    rdfs:comment 'Date on which the bank confirmed the payment as cleared in the bank statement. Used for bank reconciliation, outstanding check tracking, and cash flow actuals reporting.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankClearingStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Clearing Status' ;
    rdfs:comment 'Status of the payment as reported by the bank clearing system. Indicates whether the payment has been confirmed as cleared by the bank, returned (e.g., invalid account), or rejected. Drives bank reconciliation and outstanding payment follow-up.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Physical check number assigned when payment method is CHECK. Used for check register management, positive pay file submission to the bank, and outstanding check reconciliation. Null for electronic payment methods (ACH, WIRE, EFT).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'Early payment discount amount deducted from the invoice total at time of payment. Reflects early-pay discount optimization for agricultural input purchases (e.g., seed, fertilizer, crop protection chemicals). Reduces COGS and improves ROI.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign currency exchange rate applied at the time of payment to convert the transaction currency to the company code local currency (USD). Used for foreign currency gain/loss calculation and IFRS IAS 21 compliance reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal accounting period (1-12 or 1-16 for special periods) within the fiscal year in which this payment is posted. Used for period-level cash flow reporting, EBITDA analysis, and month-end close reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which this payment is recorded for financial reporting purposes. Agricultural businesses may use non-calendar fiscal years aligned with growing seasons. Required for period-end close, GAAP/IFRS consolidated statements, and SOX financial controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'Number of individual invoices cleared by this single payment transaction. Supports partial vs. full payment analysis and multi-invoice payment run reconciliation for bulk agricultural input purchases.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company code local currency (USD) using the exchange_rate at time of payment. Used for consolidated financial statements, EBITDA reporting, and GAAP/IFRS compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Actual net amount remitted to the vendor after deducting any early payment discount taken. Equals payment_amount minus discount_taken_amount. Represents the true cash disbursement recorded in the bank statement.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Gross payment amount disbursed to the vendor in the transaction currency before any discount deduction. Represents the total cash outflow for this payment event. Used for cash flow management and EBITDA reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code indicating why a payment is blocked from processing (e.g., invoice dispute, missing COA, quality hold, vendor master incomplete). Null when payment is not blocked. Supports AP workflow management and vendor dispute resolution.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'Externally-known payment document number assigned by the financial system (SAP FI or Oracle NetSuite) at the time of payment posting. Used for audit trails, bank reconciliation, and vendor remittance communication.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments entered by AP staff regarding this payment transaction. May include vendor communication details, dispute context, seasonal payment cycle notes, or special handling instructions for agricultural input suppliers.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment reference number transmitted to the bank and included in the remittance advice to the vendor. For ACH payments, this is the transaction reference in the NACHA file. Enables vendor-side payment matching and dispute resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction. Tracks progression from initiation through bank clearing or return/void. Supports cash flow management and bank reconciliation workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment transaction type. Advance payments are common for seed and input purchases ahead of planting season. Partial payments occur for large equipment or land lease transactions. Supports cash flow forecasting and working capital analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting posting date on which the payment is recorded in the general ledger. Determines the fiscal period for financial reporting and GAAP/IFRS period-end close.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSent rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent' ;
    rdfs:comment 'Indicates whether a remittance advice notification has been sent to the vendor detailing the invoices cleared by this payment. Supports vendor communication workflows and dispute prevention for agricultural input suppliers.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remittanceSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remittance Sent Timestamp' ;
    rdfs:comment 'Date and time when the remittance advice was transmitted to the vendor. Provides audit trail for vendor communication and supports SLA tracking for payment notification.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The bank value date on which funds are credited to the vendor\'s account. May differ from payment_date due to bank processing float. Critical for accurate cash position reporting and bank statement reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The official account name as registered with the financial institution, typically the legal entity name or operating division name (e.g., \'AgriCorp Operating Account — Corn Division\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The official bank account number assigned by the financial institution. Used for payment disbursements (input purchases, payroll), crop revenue deposits, and operating line of credit draws. Classified as restricted PCI-sensitive financial data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Funds immediately available for disbursement after deducting outstanding checks, pending ACH debits, and holds. Distinct from ledger balance; used for real-time cash availability decisions during peak input purchasing seasons.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceDate rdf:type rdf:Property ;
    rdfs:label 'Balance Date' ;
    rdfs:comment 'The date as of which the daily_balance was last recorded or confirmed. Ensures temporal accuracy of cash position reporting for period-close reconciliation and treasury management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankBranchAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Address' ;
    rdfs:comment 'Physical street address of the bank branch. Used for correspondence, check mailing, and regulatory documentation for USDA program payment accounts and Farm Credit lending relationships.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held. Relevant for agricultural enterprises with regional banking relationships tied to specific farm credit districts or local agricultural lending offices.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the bank branch is domiciled (e.g., USA, CAN, BRA). Determines applicable banking regulations, currency controls, and SWIFT routing conventions for international agricultural trade settlements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full legal name of the financial institution holding the account (e.g., \'Farm Credit Services of America\', \'AgriBank FCB\', \'Wells Fargo Bank N.A.\'). Used for counterparty identification in payment processing and banking relationship management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementFrequency rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Frequency' ;
    rdfs:comment 'Frequency at which bank statements are received and processed for reconciliation. Daily statements are typical for high-volume operating accounts during planting and harvest seasons; monthly for savings and escrow accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditFacilityDrawn rdf:type rdf:Property ;
    rdfs:label 'Credit Facility Drawn' ;
    rdfs:comment 'Current outstanding drawn balance on the operating line of credit associated with this account. Tracks seasonal borrowing against the credit facility limit for input financing and working capital management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditFacilityLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Facility Limit' ;
    rdfs:comment 'Maximum approved credit limit on the operating line of credit linked to this account. Agricultural enterprises rely on seasonal operating lines to finance seed, fertilizer (NPK), and crop protection inputs ahead of harvest revenue. Null for non-credit accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyBalance rdf:type rdf:Property ;
    rdfs:label 'Daily Balance' ;
    rdfs:comment 'Most recent end-of-day ledger balance for the account as reported by the bank or treasury management system. Critical for seasonal cash flow monitoring during planting and harvest cycles, operating line of credit management, and daily liquidity reporting.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dualSignatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Dual Signatory Required' ;
    rdfs:comment 'Indicates whether this account requires dual authorization (two signatories) for payment transactions above the single-signatory threshold. Enforces segregation of duties as a SOX internal control for high-value agricultural disbursements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this bank account became active and available for use in enterprise payment processing. Used for temporal validity tracking in SAP S/4HANA and for audit trail purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this bank account ceases to be valid for payment processing. Null for open-ended active accounts. Closed accounts retain this date for historical audit trail and SOX compliance documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:houseBankAccountIdCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Id Code' ;
    rdfs:comment 'SAP S/4HANA house bank account ID (sub-account identifier within the house bank) used in payment program configuration. Distinguishes between multiple accounts at the same bank (e.g., operating vs. payroll vs. escrow accounts at the same institution).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'SAP S/4HANA house bank identifier that groups bank accounts under a single banking institution within the enterprise. Used in automatic payment program (APP) configuration to route payments through the correct bank for input supplier disbursements and crop revenue collections.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number used for cross-border payment processing in SEPA and other international banking zones. Required for European agricultural trade partners and international commodity export settlements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent completed bank reconciliation for this account. Tracks reconciliation currency for period-close management and SOX control compliance. Unreconciled accounts past due date trigger escalation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Approved overdraft protection limit for the account. Provides short-term liquidity buffer during peak agricultural disbursement periods (e.g., planting season input payments) before crop revenue is received.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'Primary payment method configured for outgoing disbursements from this account in the automatic payment program (APP). Determines how AP payments for seeds, fertilizers, crop protection chemicals, and equipment are processed.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Primary Signatory Name' ;
    rdfs:comment 'Full name of the primary authorized signatory for the bank account. Required for check signing authority, wire transfer approvals, and banking mandate documentation. Part of SOX internal control documentation for financial authorization.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current reconciliation status of the bank account for the most recent statement period. Unreconciled status triggers period-close blocking actions per SOX financial controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'American Bankers Association (ABA) routing transit number identifying the financial institution for domestic ACH and wire transfers. Used for input supplier payments, USDA program payment receipts, and payroll disbursements within the US banking system.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondarySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Secondary Signatory Name' ;
    rdfs:comment 'Full name of the secondary authorized signatory for dual-control payment authorization. Dual-signatory requirements are common for large agricultural enterprises to satisfy SOX internal control requirements for high-value transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSignatoryLimit rdf:type rdf:Property ;
    rdfs:label 'Single Signatory Limit' ;
    rdfs:comment 'Maximum transaction amount that a single authorized signatory can approve without requiring dual authorization. Transactions above this threshold require dual-signatory approval per SOX internal control policies.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'Society for Worldwide Interbank Financial Telecommunication (SWIFT) Business Identifier Code for international wire transfers. Required for cross-border agricultural commodity payments, CIF/FOB trade settlements, and foreign currency transactions with international suppliers and buyers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaProgramAccount rdf:type rdf:Property ;
    rdfs:label 'Usda Program Account' ;
    rdfs:comment 'Indicates whether this account is designated to receive USDA government program payments (e.g., ARC, PLC, CRP, EQIP, CSP). USDA program accounts require specific tracking for government payment compliance and farm program reporting.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiativeId rdf:type rdf:Property ;
    rdfs:label 'Initiative Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_initiative. Business justification: Capital projects for irrigation upgrades, renewable energy, or precision agriculture are directly linked to sustainability initiatives. Agriculture CFOs track capex ROI alongside emission reduction ta' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:primaryCapitalRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capital Requestor Employee Id' ;
    rdfs:comment 'Employee identifier of the person who submitted the capital/operational project request. Used for approval workflow routing, accountability tracking, and SOX audit trail.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Requesting Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: capital_project has requesting_cost_center_code as a STRING. Normalizing to a FK to cost_center establishes proper referential integrity linking the capital project to the organizational unit requesti' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs incurred and posted to the project (WBS element or internal order) to date, sourced from SAP CO actual cost postings. Used for budget vs. actual variance reporting and CAPEX/OPEX tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current state of the multi-level approval workflow for this request, distinct from overall project status. Tracks whether the financial authorization has been granted, is pending, or has been rejected at any approval tier. Supports SOX financial controls documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Total amount formally approved by the authorization hierarchy for this project. May differ from estimated cost if the approval was conditional or partially approved. Drives budget availability checks in SAP.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date on which this compliance obligation was formally assigned to or identified for this capital project. Supports audit trail and compliance program management.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the project budget is allocated and tracked (e.g., 2024). Used for annual capital planning, CAPEX/OPEX budget cycle management, and year-end financial reporting.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Narrative business case explaining why the project is necessary, including operational need, regulatory compliance requirement, productivity improvement, or strategic alignment. Required for SOX approval documentation and audit trail.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total value of purchase orders and contracts committed against this project but not yet invoiced or goods-receipted. Represents financial obligations that reduce available budget. Sourced from SAP MM commitment management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key code that defines the depreciation method (e.g., straight-line, declining balance) and calculation rules for the resulting fixed asset. Applicable for CAPEX projects only.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Total estimated cost of the project at the time of request submission, in the company code currency. Serves as the baseline for budget vs. actual variance analysis and ROI calculation.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'The estimated monetary cost impact of satisfying this compliance obligation on this specific capital project. Belongs to the project-obligation pairing, not to either entity alone — the same obligation may have different cost impacts on different projects depending on project scope and scale. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureCategory rdf:type rdf:Property ;
    rdfs:label 'Expenditure Category' ;
    rdfs:comment 'Classifies the request as a Capital Expenditure (CAPEX) — assets that are capitalized on the balance sheet per GAAP/IFRS — or Operational Expenditure (OPEX) — costs expensed in the current period. Drives accounting treatment, depreciation scheduling, and financial reporting.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Identifies the source of funds for the project (e.g., operating_budget, capital_budget, external_loan, government_grant such as USDA FSA programs, equipment_financing). Drives treasury and debt management reporting. [ENUM-REF-CANDIDATE: operating_budget|capital_budget|external_loan|government_grant|equipment_financing|internal_transfer|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used for cost collection on smaller CAPEX/OPEX projects that do not warrant a full WBS structure. Enables cost monitoring and settlement to fixed assets or cost centers.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Estimated number of months required to recover the initial capital investment through cost savings or incremental revenue. Used alongside ROI for capital project prioritization and approval scoring.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Planned calendar date for project completion and asset capitalization or cost settlement. Used for depreciation start date planning and project milestone tracking.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP CO profit center associated with the project, enabling profitability analysis by commodity, farm unit, or business segment. Supports EBITDA and ROI reporting at the profit center level.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative describing the scope, objectives, and deliverables of the capital or operational project. Supports business justification review and SOX documentation requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'The phase of the capital project during which this compliance obligation must be satisfied. A single project may have obligations in multiple phases (e.g., wetland determination in pre-construction, stormwater inspection during construction, final environmental sign-off at post-completion). Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the capital/operational project request through the approval and execution workflow. Drives SOX approval controls and project cost collection gating. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|in_progress|on_hold|completed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectTitle rdf:type rdf:Property ;
    rdfs:label 'Project Title' ;
    rdfs:comment 'Short, descriptive title of the capital or operational project (e.g., \'Center-Pivot Irrigation System Upgrade – Farm Unit 7\', \'New Grain Storage Facility – Elevator 3\'). Used in approval workflows and executive reporting.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Categorizes the nature of the investment (e.g., equipment_purchase for tractors/combines, land_improvement for drainage/terracing, facility_construction for grain elevators/storage, technology_infrastructure for FMIS/IoT/GPS systems, crop_trial for R&D field trials). [ENUM-REF-CANDIDATE: equipment_purchase|land_improvement|facility_construction|technology_infrastructure|field_renovation|crop_trial|irrigation_system|marketing_campaign|vehicle_fleet|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the capital or operational project request was formally submitted by the requesting cost center. Serves as the business event date for the request lifecycle.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-visible, human-readable request number assigned at submission (e.g., CAPEX-2024-00123 or OPEX-2024-00456). Used for cross-system reference in SAP S/4HANA IM (Investment Management) and Oracle NetSuite project modules.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Projected Return on Investment (ROI) percentage calculated at the time of request submission, based on estimated cost savings, yield improvements, or revenue generation. Supports capital allocation decision-making and post-implementation review.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Defines how accumulated project costs are settled at project completion in SAP CO/PS — either capitalized to a fixed asset (asset_under_construction → final asset), settled to a cost center, or posted to a GL account. Critical for correct CAPEX capitalization and OPEX expensing.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Control Relevant' ;
    rdfs:comment 'Indicates whether this project is subject to SOX internal control over financial reporting (ICFR) requirements. True for projects above the materiality threshold or involving significant asset capitalization. Drives mandatory dual-approval and documentation requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:herdId rdf:type rdf:Property ;
    rdfs:label 'Herd Id' ;
    rdfs:comment 'Foreign key linking to livestock.herd. Business justification: Livestock producers place live cattle and feeder cattle futures hedges against specific herds for price risk management. Linking commodity_hedge to herd enables hedge effectiveness testing, P&L attrib' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Herd .

ind:productionGroupId rdf:type rdf:Property ;
    rdfs:label 'Production Group Id' ;
    rdfs:comment 'Foreign key linking to livestock.production_group. Business justification: Feedlot operators hedge specific production lots (groups) against futures contracts for closeout price protection. Linking commodity_hedge to production_group supports lot-level hedge effectiveness te' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionGroup .

ind:basisRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Risk Amount' ;
    rdfs:comment 'The monetary value of the basis differential between the local cash price and the exchange-traded futures price for the hedged commodity. Represents residual price risk not eliminated by the hedge. Critical metric in agricultural commodity marketing and grain merchandising.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Broker Account Number' ;
    rdfs:comment 'The account number assigned by the futures commission merchant (FCM) or broker for the trading account under which this hedge position is held. Used for margin account reconciliation and position reporting.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'The calendar date on which the futures or options contract expires or the forward contract matures. Used for position management, roll scheduling, and hedge effectiveness testing timelines.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractMonth rdf:type rdf:Property ;
    rdfs:label 'Contract Month' ;
    rdfs:comment 'The delivery/expiration month of the futures or options contract expressed in standard exchange notation (e.g., Z24 = December 2024, H25 = March 2025). Critical for managing basis risk and roll strategy in agricultural commodity marketing.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'The name of the broker, dealer, or OTC counterparty for the hedging instrument. For exchange-traded instruments, this is typically the futures commission merchant (FCM) or clearing broker. For OTC forwards, this is the counterparty financial institution or grain merchandiser.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessTestDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Date' ;
    rdfs:comment 'The date on which the most recent hedge effectiveness test was performed. Required for hedge accounting documentation and SOX audit trail.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessTestMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Method' ;
    rdfs:comment 'The methodology used to assess hedge effectiveness as required by ASC 815/IFRS 9. \'dollar_offset\' compares changes in fair value; \'regression\' uses statistical analysis; \'hypothetical_derivative\' compares to a perfect hedge; \'critical_terms_match\' applies when key terms of hedging instrument and hedged item match.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessTestResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Result' ;
    rdfs:comment 'The outcome of the most recent hedge effectiveness assessment. \'highly_effective\' qualifies for hedge accounting treatment (80-125% offset range per ASC 815); \'ineffective\' requires de-designation and P&L recognition of ineffective portion; \'not_tested\' for instruments not yet assessed.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Code identifying the exchange on which the futures or options contract is traded. CME (Chicago Mercantile Exchange) for livestock; CBOT (Chicago Board of Trade) for grains and oilseeds; ICE (Intercontinental Exchange) for cotton and sugar; NYMEX for energy-related agricultural inputs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardPrice rdf:type rdf:Property ;
    rdfs:label 'Forward Price' ;
    rdfs:comment 'For forward contracts, the agreed-upon price at which the commodity will be bought or sold at the future settlement date. Expressed in currency per unit of measure. Null for exchange-traded futures and options.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futuresPriceAtEntry rdf:type rdf:Property ;
    rdfs:label 'Futures Price At Entry' ;
    rdfs:comment 'The exchange-quoted futures price at the time the hedge position was established. Used as the reference price for basis calculation (local cash price minus futures price) and hedge effectiveness testing.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Designation' ;
    rdfs:comment 'Formal hedge accounting designation per ASC 815 (US GAAP) or IFRS 9. \'fair_value\' hedges offset changes in fair value of a recognized asset/liability; \'cash_flow\' hedges offset variability in future cash flows; \'net_investment\' hedges offset foreign currency exposure in net investments; \'not_designated\' instruments are economic hedges not qualifying for hedge accounting treatment.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeEndDate rdf:type rdf:Property ;
    rdfs:label 'Hedge End Date' ;
    rdfs:comment 'The date on which the hedge relationship is expected to end or was terminated. Used for hedge accounting de-designation and effectiveness testing period boundaries.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hedgeNumber rdf:type rdf:Property ;
    rdfs:label 'Hedge Number' ;
    rdfs:comment 'Externally-known business identifier for the hedging instrument, typically assigned by the treasury management system or SAP S/4HANA FI-TRM module (e.g., HDG-2024-00123). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeRatio rdf:type rdf:Property ;
    rdfs:label 'Hedge Ratio' ;
    rdfs:comment 'The proportion of the hedged item\'s exposure covered by the hedging instrument, expressed as a decimal (e.g., 0.8000 = 80% coverage). Required for hedge accounting documentation under ASC 815/IFRS 9 and used in hedge effectiveness testing.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeStartDate rdf:type rdf:Property ;
    rdfs:label 'Hedge Start Date' ;
    rdfs:comment 'The date on which the hedge relationship formally begins for hedge accounting purposes per ASC 815/IFRS 9. May differ from trade_date if formal designation documentation is completed after execution.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hedgeStatus rdf:type rdf:Property ;
    rdfs:label 'Hedge Status' ;
    rdfs:comment 'Current lifecycle state of the hedging instrument. \'open\' indicates an active position; \'closed\' indicates the position has been offset or settled; \'expired\' indicates the contract reached maturity; \'cancelled\' indicates early termination; \'pending_designation\' indicates awaiting formal hedge accounting designation per ASC 815/IFRS 9.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Hedged Item Description' ;
    rdfs:comment 'Narrative description of the specific exposure or hedged item being protected by this instrument (e.g., \'Forecasted corn purchase Q3 2024 - 500,000 BU\', \'Soybean inventory held at Decatur elevator\'). Required for hedge accounting documentation under ASC 815/IFRS 9.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarginRequired rdf:type rdf:Property ;
    rdfs:label 'Initial Margin Required' ;
    rdfs:comment 'The initial margin deposit required by the exchange clearinghouse when the futures position is established. Expressed in the transaction currency. Monitored daily against margin calls for cash flow management.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the hedging instrument. \'futures\' are standardized exchange-traded contracts; \'options\' grant the right but not obligation to buy/sell at a strike price; \'forward\' contracts are OTC bilateral agreements at a fixed forward price; \'swap\' contracts exchange cash flows based on commodity price differentials.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markToMarketValue rdf:type rdf:Property ;
    rdfs:label 'Mark To Market Value' ;
    rdfs:comment 'The current fair value of the hedging instrument based on the latest available market price. Positive values indicate an unrealized gain; negative values indicate an unrealized loss. Updated daily for exchange-traded instruments per GAAP/IFRS fair value measurement requirements.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmValuationDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Date' ;
    rdfs:comment 'The date as of which the mark-to-market value was last calculated. Ensures financial reporting accuracy and supports period-end close processes in SAP S/4HANA FI.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notionalQuantity rdf:type rdf:Property ;
    rdfs:label 'Notional Quantity' ;
    rdfs:comment 'The total quantity of the underlying commodity covered by the hedging instrument. Expressed in the unit of measure applicable to the commodity (e.g., bushels for grain, hundredweight for livestock, metric tons for oilseeds). Drives exposure calculation and hedge ratio determination.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfContracts rdf:type rdf:Property ;
    rdfs:label 'Number Of Contracts' ;
    rdfs:comment 'The count of standardized exchange contracts comprising the hedge position. Each exchange contract represents a fixed notional quantity (e.g., 5,000 BU per CBOT corn contract). Used for margin calculation and position limit monitoring.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionPremiumPaid rdf:type rdf:Property ;
    rdfs:label 'Option Premium Paid' ;
    rdfs:comment 'The total premium paid to acquire an options contract, expressed in the transaction currency. Represents the maximum loss exposure for long option positions. Recorded as an asset under ASC 815/IFRS 9 hedge accounting. Null for futures and forward contracts.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'For options instruments, specifies whether the contract is a call option (right to buy) or put option (right to sell) the underlying commodity. \'not_applicable\' for futures and forward contracts. Agricultural producers typically purchase put options to establish price floors.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the notional quantity. BU (Bushel) for grains; MT (Metric Ton) for oilseeds and international contracts; CWT (Hundredweight) for livestock; LB (Pound) for cotton and sugar; TON for domestic bulk commodities.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedGainLoss rdf:type rdf:Property ;
    rdfs:label 'Realized Gain Loss' ;
    rdfs:comment 'The actual gain or loss recognized upon closing, expiration, or settlement of the hedging instrument. Positive values indicate a gain; negative values indicate a loss. Recorded to the appropriate P&L or OCI account per ASC 815/IFRS 9 hedge accounting treatment.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the hedging instrument was or is expected to be settled. For closed/expired positions, the actual settlement date. For open positions, the expected settlement date based on contract terms.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'The method by which the contract is settled at expiration. \'cash\' settlement uses the final settlement price without physical delivery; \'physical_delivery\' requires delivery of the actual commodity; \'offset\' indicates the position was closed by an opposing trade before expiration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikePrice rdf:type rdf:Property ;
    rdfs:label 'Strike Price' ;
    rdfs:comment 'For options contracts, the price at which the holder has the right to buy (call) or sell (put) the underlying commodity. Expressed in the currency per unit of measure (e.g., USD per bushel). Null for futures and forward contracts.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDate rdf:type rdf:Property ;
    rdfs:label 'Trade Date' ;
    rdfs:comment 'The date on which the hedging instrument was executed or entered into. Represents the principal business event date for the hedge transaction, used for mark-to-market valuation and hedge accounting documentation.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the hedge instrument is denominated (e.g., USD for CME/CBOT contracts, GBP for ICE London contracts). Used for multi-currency consolidation and IFRS/GAAP foreign currency translation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationMarginBalance rdf:type rdf:Property ;
    rdfs:label 'Variation Margin Balance' ;
    rdfs:comment 'The cumulative daily settlement amount reflecting gains and losses on the futures position since inception. Positive indicates net gains credited to the margin account; negative indicates net losses debited. Critical for daily cash flow management and liquidity planning.' ;
    rdfs:domain ind:CommodityHedge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressCity rdf:type rdf:Property ;
    rdfs:label 'Address City' ;
    rdfs:comment 'City of the legal entity\'s registered office address. Used for tax jurisdiction determination, regulatory filings, and geographic segmentation in financial reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Address Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the registered office address. Used for international regulatory compliance, COOL (Country of Origin Labeling) reporting, and IFRS geographic segment disclosures.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the legal entity\'s registered office address. Used for tax jurisdiction mapping, regulatory filings, and geographic analytics in the enterprise GIS.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStateProvince rdf:type rdf:Property ;
    rdfs:label 'Address State Province' ;
    rdfs:comment 'State or province of the legal entity\'s registered office. Drives state-level tax jurisdiction, USDA state program eligibility, and EPA regional compliance requirements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStreet rdf:type rdf:Property ;
    rdfs:label 'Address Street' ;
    rdfs:comment 'Street address of the legal entity\'s registered office as recorded with government authorities. Used for regulatory correspondence, USDA/FDA/EPA filings, and legal notices.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The SAP chart of accounts key assigned to this company code, defining the GL account structure used for all financial postings, cost center accounting, and COGS allocation by commodity. Ensures consistency across consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'The 4-character alphanumeric company code as defined in SAP S/4HANA FI module. Serves as the primary external business identifier for the legal entity across all financial transactions, general ledger postings, and regulatory filings. Aligns with SAP company code (BUKRS) field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code. Controls whether financial postings, procurement transactions, and payroll processing are permitted for this entity in SAP S/4HANA and Oracle NetSuite.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationChartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Consolidation Chart Of Accounts' ;
    rdfs:comment 'The group-level chart of accounts used for intercompany consolidation and segment reporting. Maps local GL accounts to the group reporting structure for GAAP/IFRS consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier for the consolidation group to which this company code belongs within the enterprise group structure. Used for multi-entity financial consolidation, intercompany elimination, and GAAP ASC 810 / IFRS 10 consolidated statement preparation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP controlling area code to which this company code is assigned. The controlling area defines the scope of cost center accounting, internal orders, and profitability analysis (CO-PA) for CAPEX/OPEX tracking and crop enterprise budgeting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area assigned to this company code for accounts receivable credit limit management and customer credit risk monitoring across the agricultural supply chain and sales distribution operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity structure within the agricultural enterprise group. Determines consolidation treatment under GAAP ASC 810 / IFRS 10 and applicable regulatory reporting obligations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaFacilityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Identifier' ;
    rdfs:comment 'EPA-assigned facility identifier for environmental compliance reporting, pesticide registration, and agricultural chemical use tracking under EPA regulations. Supports IPM program documentation and BMP compliance.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Number' ;
    rdfs:comment 'FDA-assigned establishment registration number for food manufacturing or processing facilities operated by this legal entity. Required for FSMA compliance, HACCP program registration, and FDA food safety inspections.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code (e.g., K4 for calendar year, V3 for April–March) that defines the fiscal year and posting period structure for this company code. Critical for period-end close, CAPEX/OPEX tracking, and GAAP/IFRS period reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Standard' ;
    rdfs:comment 'The accounting standard under which this company code prepares its statutory financial statements. US entities typically report under GAAP; international subsidiaries may report under IFRS. Drives chart of accounts mapping and consolidation adjustments.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApNumber rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Number' ;
    rdfs:comment 'GLOBALG.A.P. certification number assigned to this legal entity for Good Agricultural Practices compliance. Supports customer audit requirements, export market access, and GFSI-recognized food safety certification tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the jurisdiction in which the legal entity was formally incorporated. May differ from the operating country for holding companies or international subsidiaries in the global agricultural supply chain.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was formally incorporated or registered with the relevant government authority. Used for entity lifecycle management, consolidation scope determination, and regulatory filing history.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Account' ;
    rdfs:comment 'GL account number used for intercompany transaction clearing and elimination during multi-entity consolidation. Ensures accurate elimination of intercompany balances in GAAP/IFRS consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the entity as it appears on government filings, SEC registrations, USDA certifications, and consolidated financial statements. Used for GAAP/IFRS segment reporting and SOX financial controls.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Number' ;
    rdfs:comment 'USDA National Organic Program (NOP) certification number for legal entities engaged in certified organic crop production or processing. Required for organic premium pricing, COOL labeling, and USDA organic program compliance reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'SAP controlling area profit center standard hierarchy node assigned to this company code. Supports EBITDA reporting, ROI analysis by business segment, and COGS allocation by commodity across the agricultural enterprise.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group reporting (presentation) currency used in consolidated financial statements. Typically USD for US-headquartered agricultural enterprises. Distinct from the local functional currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secRegistrantNumber rdf:type rdf:Property ;
    rdfs:label 'Sec Registrant Number' ;
    rdfs:comment 'SEC Central Index Key (CIK) or registrant number for publicly traded entities within the agricultural enterprise. Required for SEC filings, SOX compliance, and GAAP financial statement disclosures.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or trading name of the legal entity used in internal reports, dashboards, and operational communications within the FMIS and ERP systems.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxInScope rdf:type rdf:Property ;
    rdfs:label 'Sox In Scope' ;
    rdfs:comment 'Indicates whether this company code is within the scope of SOX Section 302 and Section 404 internal control over financial reporting (ICFR) requirements. Drives audit procedures, control testing, and financial reporting certifications.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier used to determine applicable federal, state, and local tax rates for this legal entity. Drives sales tax, use tax, and VAT calculations in SAP S/4HANA and Oracle NetSuite. Relevant for USDA, FDA, and EPA regulatory tax obligations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Usda Entity Identifier' ;
    rdfs:comment 'USDA-assigned identifier for this legal entity used in farm program registrations, commodity reporting, FSMA compliance filings, and National Organic Program (NOP) certifications. Supports regulatory reporting to USDA APHIS and FSIS.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for the legal entity in applicable jurisdictions. Required for international agricultural trade, cross-border supply chain transactions, and IFRS tax reporting for non-US entities.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Employee ID of the manager accountable for this cost center\'s budget and expenditures, as maintained in SAP SuccessFactors HR. Used for budget approval workflows, variance reporting, and SOX financial controls accountability. Stored as employee identifier, not personal name.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code representing the primary activity performed by this cost center (e.g., \'MACH\' for machine hours, \'LABOR\' for labor hours, \'IRRIG\' for irrigation hours, \'SPRAY\' for spraying operations). Used for activity-based cost allocation and internal price calculation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP business area code representing a distinct area of operations for internal balance sheet and P&L reporting (e.g., \'CROP\' for crop operations, \'LVST\' for livestock, \'SUPL\' for supply chain). Enables cross-company-code segment reporting per GAAP ASC 280 and IFRS 8.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetAnnual rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Annual' ;
    rdfs:comment 'Approved annual CAPEX budget amount for this cost center in the controlling currency. Represents planned capital investments (equipment, infrastructure, land improvements) for the fiscal year. Supports CAPEX tracking and ROI analysis per GAAP ASC 360 / IFRS IAS 16.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'Primary agricultural commodity or livestock type associated with this cost center for COGS allocation and crop enterprise budgeting (e.g., \'corn\', \'soybeans\', \'wheat\', \'cattle\', \'hogs\', \'poultry\', \'cotton\', \'rice\'). Enables commodity-level profitability analysis and WASDE-aligned reporting. [ENUM-REF-CANDIDATE: corn|soybeans|wheat|cattle|hogs|poultry|cotton|rice|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area code to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within the same controlling area share the same chart of accounts and fiscal year variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Functional classification of the cost center indicating its primary business purpose. Drives overhead allocation rules, COGS allocation by commodity, and OPEX tracking. Values: production (direct crop/livestock production), administration (G&A overhead), research_and_development (R&D per GAAP ASC 730), field_operations (planting, harvesting, irrigation), supply_chain (logistics, warehousing), overhead (indirect shared services).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Free-text description providing additional context about the cost center\'s purpose, scope, and operational activities (e.g., \'Manages all field operations costs for the 5,000-acre corn production unit in Iowa, including planting, fertilization, crop protection, and harvest activities\'). Supports management reporting and organizational documentation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center as maintained in SAP S/4HANA CO master data (e.g., \'North Field Operations – Corn Belt\', \'Livestock Feed Management – Hog Unit 3\'). Used in financial reports and management dashboards.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center master record. Active: available for cost postings. Inactive: temporarily disabled. Locked: blocked for new postings (e.g., period-end close). Pending_approval: awaiting authorization per SOX controls. Archived: historical record no longer in use.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP functional area code classifying the cost center by business function for cost-of-sales accounting (e.g., \'PROD\' for production/COGS, \'ADMIN\' for G&A, \'SALES\' for selling expenses, \'RD\' for R&D). Supports COGS allocation by commodity and functional income statement reporting per GAAP/IFRS.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountAssignmentGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Assignment Group' ;
    rdfs:comment 'GL account assignment group linking this cost center to the appropriate general ledger accounts in SAP FI for automatic account determination. Ensures correct GL posting for COGS, OPEX, and overhead entries per the chart of accounts and GAAP/IFRS financial reporting requirements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the standard hierarchy node (cost center group) to which this cost center belongs in SAP CO. Enables hierarchical roll-up of costs for management reporting, budget consolidation, and EBITDA analysis by business segment.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProjectCostCollector rdf:type rdf:Property ;
    rdfs:label 'Is Project Cost Collector' ;
    rdfs:comment 'Indicates whether this cost center is designated as a project cost collector for capital projects, R&D programs, or special agricultural initiatives (e.g., precision agriculture rollout, irrigation infrastructure project). When True, costs posted here are tracked against a project budget in SAP PS/CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this is a statistical cost center used only for reporting and allocation base calculations (e.g., tracking headcount, acreage, or machine hours as statistical key figures) without receiving actual cost postings. Statistical cost centers support overhead distribution in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cost center master record in the source system or data platform. Critical for SOX change management controls, audit trails, and incremental data pipeline processing in the Databricks Silver Layer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'SAP CO lock indicator controlling which types of postings are permitted to this cost center. Unlocked: all postings allowed. Locked_actual: actual cost postings blocked. Locked_plan: planning postings blocked. Locked_all: all postings blocked (e.g., during period-end close or organizational restructuring).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexBudgetAnnual rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Annual' ;
    rdfs:comment 'Approved annual OPEX budget amount for this cost center in the controlling currency. Represents planned operational expenditures for the fiscal year as entered in SAP CO planning. Used for budget vs. actual variance analysis, EBITDA forecasting, and crop enterprise budgeting per GAAP/IFRS.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadAllocationKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Allocation Key' ;
    rdfs:comment 'SAP overhead allocation key (costing sheet key) assigned to this cost center, determining how indirect overhead costs are allocated from overhead cost centers to production/field operations cost centers. Critical for accurate COGS allocation by commodity and crop enterprise profitability analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural key or primary identifier of this cost center record in the originating source system (e.g., SAP cost center number, Oracle NetSuite internal ID, Granular cost center reference). Enables data lineage tracing and reconciliation between the Silver Layer and operational systems.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this cost center is active and available for cost postings in SAP CO. Supports time-dependent master data management and ensures costs are only allocated to active cost centers within their valid period. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this cost center is active and available for cost postings. After this date, the cost center is locked for new postings. Null indicates an open-ended validity. Supports fiscal year planning and organizational restructuring in SAP CO. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breakevenPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Breakeven Price Per Unit' ;
    rdfs:comment 'Minimum commodity price per unit required to cover all planned production costs (planned total cost ÷ planned total yield). Critical decision-support metric for marketing strategy, forward contract pricing, and crop insurance coverage level selection.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Budget Area Acres' ;
    rdfs:comment 'Total planned planted area in acres for this crop enterprise budget. US-standard unit used alongside hectares for domestic reporting, USDA FSA program compliance, and land rent calculations expressed per acre.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAreaHa rdf:type rdf:Property ;
    rdfs:label 'Budget Area Ha' ;
    rdfs:comment 'Total planned planted area in hectares (ha) for this crop enterprise budget. Used as the denominator for per-hectare cost and revenue calculations, break-even analysis, and ROI reporting. Aligns with field area records in Esri ArcGIS and John Deere Operations Center.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetDate rdf:type rdf:Property ;
    rdfs:label 'Budget Date' ;
    rdfs:comment 'The principal business event date on which this crop enterprise budget was formally established or initiated. Represents the BUSINESS_EVENT_TIMESTAMP (date precision) for the budget creation event, distinct from system audit timestamps. Used for period alignment in financial reporting.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the crop enterprise budget, used in financial planning documents, SAP CO cost object references, and Granular Farm Management records. Serves as the BUSINESS_IDENTIFIER for cross-system traceability.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the crop enterprise budget. Drives approval workflow and financial reporting inclusion. Draft = in preparation; Submitted = pending approval; Approved = authorized for use; Revised = updated post-approval; Final = locked for period close; Cancelled = voided. LIFECYCLE_STATUS for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version classification of the crop enterprise budget indicating whether it represents the original plan, a mid-season revision, or the final locked version. Supports variance analysis between original and revised plans per GAAP budgetary control requirements.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropInsuranceCostPerHa rdf:type rdf:Property ;
    rdfs:label 'Crop Insurance Cost Per Ha' ;
    rdfs:comment 'Planned crop insurance premium cost per hectare included in this enterprise budget. Reflects USDA Risk Management Agency (RMA) policy premiums for revenue protection or yield protection coverage. Confidential as it reflects risk management strategy.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentProgramPaymentPerHa rdf:type rdf:Property ;
    rdfs:label 'Government Program Payment Per Ha' ;
    rdfs:comment 'Planned government program payment per hectare expected to be received (e.g., USDA ARC/PLC payments, conservation program payments). Included as a revenue offset in the enterprise budget for accurate net income projection.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestEndDate rdf:type rdf:Property ;
    rdfs:label 'Harvest End Date' ;
    rdfs:comment 'Planned date by which harvest operations are expected to be completed for this crop enterprise. Drives revenue recognition timing, post-harvest handling cost planning, and storage/logistics scheduling in the supply chain.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:landRentPerHa rdf:type rdf:Property ;
    rdfs:label 'Land Rent Per Ha' ;
    rdfs:comment 'Planned cash land rent cost per hectare included in this crop enterprise budget. One of the largest variable cost components in crop production. Confidential as it reflects negotiated lease terms. Used for land cost benchmarking and lease vs. own analysis.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostPerHa rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Per Ha' ;
    rdfs:comment 'Total planned cost of production per hectare. Key benchmark metric for comparing production efficiency across fields, farms, and seasons. Used in break-even price calculations and OPEX benchmarking against industry standards.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedNetIncome rdf:type rdf:Property ;
    rdfs:label 'Planned Net Income' ;
    rdfs:comment 'Planned net income for the crop enterprise calculated as planned total revenue minus planned total cost. Primary profitability metric for crop enterprise budgeting, ROI analysis, and lender/investor reporting. Confidential as it reflects forward financial projections.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Planned Price Per Unit' ;
    rdfs:comment 'Budgeted commodity selling price per unit of measure used to calculate planned revenue. Typically derived from forward contract prices, DTN market data, or WASDE price projections. Confidential as it reflects pricing strategy and forward market positions.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRevenuePerHa rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue Per Ha' ;
    rdfs:comment 'Total planned gross revenue per hectare calculated as planned yield per hectare multiplied by planned price per unit. Core metric for crop enterprise profitability analysis, break-even determination, and ROI reporting. Confidential as it reflects forward pricing strategy.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Planned Total Cost' ;
    rdfs:comment 'Total planned cost of production for the entire budgeted area, aggregating all cost line items (seed, fertilizer NPK, crop protection, labor, equipment, irrigation, land rent, crop insurance, custom hire). Used for COGS allocation, break-even analysis, and EBITDA reporting.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalRevenue rdf:type rdf:Property ;
    rdfs:label 'Planned Total Revenue' ;
    rdfs:comment 'Total planned gross revenue for the entire budgeted area (planned revenue per hectare × budget area). Represents the gross income line in the crop enterprise budget P&L. Used for EBITDA projection and SAP S/4HANA CO profitability analysis. Confidential as it reflects forward pricing.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedYieldPerHa rdf:type rdf:Property ;
    rdfs:label 'Planned Yield Per Ha' ;
    rdfs:comment 'Expected crop yield per hectare (ha) used as the basis for revenue projections in this enterprise budget. Expressed in the commodity\'s standard unit of measure (e.g., MT/ha for grains, BU/ha for corn). Derived from historical yield records, NDVI analysis, and agronomic models.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantingStartDate rdf:type rdf:Property ;
    rdfs:label 'Planting Start Date' ;
    rdfs:comment 'Planned date on which planting operations are scheduled to begin for this crop enterprise. Used for cash flow timing, input procurement scheduling, and integration with Climate FieldView and Trimble Ag Software planting plans.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yieldUom rdf:type rdf:Property ;
    rdfs:label 'Yield Uom' ;
    rdfs:comment 'Unit of measure for yield quantities in this budget (e.g., MT = Metric Ton, BU = Bushel, CWT = Hundredweight). Ensures consistent interpretation of planned and actual yield figures across commodity types and reporting systems.' ;
    rdfs:domain ind:CropEnterpriseBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Agricultural commodity or input category for this invoice. Enables COGS allocation by commodity, seasonal input cost tracking, and crop enterprise budget variance analysis. Categories align with core agricultural input types: seeds, fertilizers (NPK), crop protection chemicals, animal feed, equipment parts, agronomic services, fuel, and other. [ENUM-REF-CANDIDATE: seeds|fertilizers|crop_protection|feed|equipment_parts|services|fuel|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Last date by which payment must be made to qualify for the early payment discount. Enables treasury teams to prioritize payments and capture available discounts on high-volume agricultural input invoices.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before tax deductions. Part of the MONETARY_TRIPLET for TRANSACTION_HEADER role. Represents the full billed value for agricultural inputs (seeds, fertilizers NPK, crop protection chemicals, feed, equipment parts). Used for COGS allocation and crop enterprise budget variance analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor\'s invoice document. Represents the BUSINESS_EVENT_TIMESTAMP (date precision) for the invoice issuance event. Used for payment terms calculation, aging analysis, and seasonal input cost tracking. Corresponds to SAP field BLDAT.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceLineCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Count' ;
    rdfs:comment 'Total number of line items on this invoice. Supports invoice complexity analysis, processing time benchmarking, and validation that all line-level detail records are present in the silver layer. Derived from the source system header record.' ;
    rdfs:domain ind:FinanceApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the AP invoice. LIFECYCLE_STATUS for TRANSACTION_HEADER role. \'draft\' = entered but not posted; \'posted\' = recorded in GL; \'approved\' = workflow approved; \'paid\' = payment cleared; \'blocked\' = payment block active; \'cancelled\' = reversed/voided.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. \'standard\' = regular vendor invoice; \'credit_memo\' = vendor credit for returns/adjustments; \'debit_memo\' = additional charge; \'recurring\' = periodic service invoice; \'intercompany\' = between related legal entities. Corresponds to SAP field BLART.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this invoice is part of a recurring payment schedule (e.g., land lease payments, equipment rental, subscription services). Supports automated invoice matching and cash flow forecasting for seasonal agricultural operations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Block Status' ;
    rdfs:comment 'Indicates whether the invoice is blocked from payment and the reason. \'unblocked\' = cleared for payment; \'manual_block\' = manually held; \'quality_block\' = QM hold pending COA review; \'price_variance\' = unit price exceeds PO tolerance; \'duplicate_check\' = potential duplicate invoice detected. Corresponds to SAP field ZLSPR.' ;
    rdfs:domain ind:FinanceApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'Internal SAP S/4HANA FI accounting document number assigned upon invoice posting. Used for cross-referencing with the general ledger and audit trail. Corresponds to SAP field BELNR in table BKPF.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way match validation comparing the purchase order (PO), goods receipt note (GRN), and vendor invoice. \'matched\' = all three documents align within tolerance; \'quantity_variance\' = invoice quantity differs from GRN; \'price_variance\' = invoice price differs from PO; \'grn_missing\' = goods receipt not yet recorded. Critical SOX control for agricultural input procurement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number as printed on the vendor\'s invoice document. Serves as the primary BUSINESS_IDENTIFIER for three-way match (PO/GRN/invoice) and vendor dispute resolution. Must be unique per vendor. Sourced from SAP S/4HANA FI document header field BELNR.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense posted against this asset from capitalization date through the last completed fiscal period. Represents the cumulative reduction in asset carrying value. Sourced from SAP FI-AA depreciation run postings.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level business category grouping assets for management reporting and CAPEX/OPEX analysis. Aligns with agricultural asset types common in USDA farm balance sheet reporting and enterprise financial consolidation. [ENUM-REF-CANDIDATE: farm_equipment|irrigation_infrastructure|grain_storage|livestock_facility|land_improvement|technology|vehicle|building — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Human-readable description of the fixed asset (e.g., \'John Deere 8R 410 Tractor\', \'Center Pivot Irrigation System - Field 12\', \'Grain Bin 50,000 BU Capacity\'). Used in financial statements, insurance schedules, and CAPEX reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset number assigned in SAP S/4HANA FI-AA (Asset Accounting module) or Oracle NetSuite fixed asset register. Serves as the primary business identifier for the asset across ERP, insurance, and audit systems.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. \'active\' = in productive use; \'under_construction\' = asset under construction (AUC) not yet capitalized; \'idle\' = temporarily out of service; \'disposed\' = sold or retired; \'transferred\' = transferred to another entity; \'scrapped\' = written off with no proceeds.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'Sub-number within the asset number used in SAP FI-AA to track component-level assets or subsequent acquisitions (e.g., engine overhaul on a tractor recorded as a sub-asset). Enables component accounting per IFRS IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusDepreciationPct rdf:type rdf:Property ;
    rdfs:label 'Bonus Depreciation Pct' ;
    rdfs:comment 'Percentage of additional first-year bonus depreciation elected under IRS Section 168(k) for qualifying farm equipment and property. Common values: 100% (2017-2022), 80% (2023), 60% (2024), 40% (2025). Reduces taxable income in acquisition year.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was formally capitalized on the balance sheet and depreciation commenced. May differ from acquisition_date for assets under construction (AUC) that are transferred to productive use upon completion.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP FI-AA depreciation area indicating the accounting framework for which this depreciation record applies. \'book\' = GAAP book depreciation; \'tax\' = US federal tax (MACRS); \'ifrs\' = IFRS IAS 16 reporting; \'state_tax\' = state-level tax depreciation; \'group\' = consolidated group reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date the asset was disposed of through sale, trade-in, scrapping, or retirement. Triggers final depreciation calculation, gain/loss on disposal recognition, and removal from the active asset register. Null if asset has not been disposed.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value proceeds received upon disposal of the asset (sale price, trade-in allowance, or insurance settlement). Used to calculate gain or loss on disposal: proceeds minus net book value at disposal date. Null if asset has not been disposed or was scrapped with no proceeds.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'Reason code for asset disposal. Used for asset lifecycle analytics, replacement planning, and CAPEX justification. \'destroyed\' may trigger insurance claims; \'traded_in\' affects new asset acquisition cost calculation. [ENUM-REF-CANDIDATE: sold|traded_in|scrapped|donated|stolen|destroyed|transferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment loss recognized on this asset where the carrying amount exceeds the recoverable amount. Triggered by events such as crop failure, flood damage to irrigation infrastructure, or obsolescence of precision agriculture technology. Recorded per GAAP ASC 360 / IFRS IAS 36.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Current insured replacement value of the asset as declared on the insurance policy. May differ from net book value (NBV) as insurance is based on replacement cost rather than depreciated book value. Used for insurance adequacy reviews.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDepreciationPostedAmount rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Posted Amount' ;
    rdfs:comment 'Depreciation expense amount posted in the most recent depreciation run for this asset. Used for period-over-period variance analysis and to validate depreciation run completeness in SOX-controlled financial close processes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDepreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Run Date' ;
    rdfs:comment 'Date of the most recently completed periodic depreciation run for this asset. Used to confirm depreciation is current and to identify assets that may have missed a depreciation posting cycle. Sourced from SAP FI-AA depreciation run history.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macrsPropertyClass rdf:type rdf:Property ;
    rdfs:label 'Macrs Property Class' ;
    rdfs:comment 'IRS MACRS recovery period class for US federal tax depreciation. Farm equipment (tractors, combines, sprayers) typically qualifies as 5-year or 7-year property; grain bins as 7-year; single-purpose agricultural structures as 10-year; land improvements as 15-year. Critical for USDA farm tax planning. [ENUM-REF-CANDIDATE: 3_year|5_year|7_year|10_year|15_year|20_year|27_5_year|39_year — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying amount of the asset on the balance sheet, calculated as acquisition_cost minus accumulated_depreciation minus any impairment losses. Reported on the enterprise balance sheet per GAAP ASC 360 and IFRS IAS 16. Key metric for CAPEX ROI analysis.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:section179Elected rdf:type rdf:Property ;
    rdfs:label 'Section 179 Elected' ;
    rdfs:comment 'Indicates whether the IRS Section 179 immediate expensing election was made for this asset in the year of acquisition. Common for farm equipment purchases to maximize tax deductions in the acquisition year. True = Section 179 elected; False = standard depreciation applied.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which this GL account is maintained (e.g., USD for US Dollar). Accounts may be maintained in local currency, group currency, or hard currency. Supports multi-currency consolidation for international agricultural operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Grouping classification that controls the number range and field selection for GL accounts within SAP S/4HANA (e.g., current assets, fixed assets, operating expenses, COGS). Supports chart of accounts structuring and financial reporting hierarchies for crop enterprise EBITDA analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongDescription rdf:type rdf:Property ;
    rdfs:label 'Account Long Description' ;
    rdfs:comment 'Extended narrative description of the GL account purpose, usage guidelines, and applicable business transactions. Supports SOX documentation requirements and auditor review.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'Further classification within the account type for agricultural enterprise reporting (e.g., current_asset, non_current_asset, current_liability, long_term_liability, operating_revenue, other_income, cogs, operating_expense, depreciation, interest_expense, tax_expense). Supports EBITDA line-item decomposition and CAPEX/OPEX segregation. [ENUM-REF-CANDIDATE: current_asset|non_current_asset|current_liability|long_term_liability|operating_revenue|other_income|cogs|operating_expense|depreciation|interest_expense|tax_expense — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'The identifier of the chart of accounts to which this GL account belongs. An enterprise may maintain multiple charts of accounts (e.g., operational CoA, group CoA for consolidation). Corresponds to SAP KTOPL field.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Commodity Allocation Flag' ;
    rdfs:comment 'Indicates whether costs or revenues posted to this GL account can be allocated to specific agricultural commodities (e.g., corn, soybeans, wheat, livestock). Enables commodity-level COGS and profitability analysis per crop enterprise. Supports USDA farm program reporting and Granular Farm Management integration.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The group-level GL account number used for intercompany elimination and consolidated financial statement preparation. Maps local chart of accounts entries to the group chart of accounts for IFRS 10 consolidation reporting. Corresponds to SAP ALTKT field.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'When True, a cost center assignment is mandatory for all postings to this GL account. Ensures cost accountability by organizational unit (e.g., field operations, irrigation, crop protection, livestock). Supports crop enterprise budgeting and OPEX tracking in SAP CO.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'SAP Controlling (CO) cost element classification: primary cost elements map directly to P&L GL accounts (e.g., seed costs, fertilizer COGS, labor); secondary cost elements are used for internal allocations and activity-based costing. Supports crop enterprise EBITDA reporting and COGS allocation by commodity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'Numeric or coded type of the SAP CO cost element (e.g., 1=primary costs/cost-reducing revenues, 3=accrual/deferral per surcharge, 11=revenues, 12=sales deductions, 21=internal settlement, 41=overhead rates, 42=assessment, 43=internal activity allocation). Drives cost allocation behavior in crop enterprise budgeting. [ENUM-REF-CANDIDATE: 1|3|11|12|21|41|42|43 — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which this GL account was deactivated or retired from active use. Null for currently active accounts. Supports chart of accounts lifecycle management and historical financial statement reconstruction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Controls which fields are required, optional, or suppressed when posting to this GL account. Corresponds to SAP FSTAG field. Ensures data completeness for cost center, profit center, and commodity allocation fields on agricultural financial postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementSection rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Section' ;
    rdfs:comment 'Indicates which primary financial statement this account appears in: balance sheet (B/S) for assets, liabilities, and equity; profit and loss (P&L) for revenues and expenses; cash flow statement; or statement of changes in equity. Critical for GAAP/IFRS dual-ledger reporting and EBITDA computation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification used for cost-of-sales accounting and segment reporting (e.g., production, sales, administration, research and development, procurement). Enables P&L by function reporting per IFRS IAS 1 and supports crop enterprise EBITDA analysis by business function.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBalanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Is Balance Sheet Account' ;
    rdfs:comment 'Flag indicating whether this GL account is a balance sheet account (True) or a profit and loss account (False). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Corresponds to SAP XBILK field.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCapexAccount rdf:type rdf:Property ;
    rdfs:label 'Is Capex Account' ;
    rdfs:comment 'Flags whether this GL account is designated for capital expenditure (CAPEX) tracking, including farm equipment purchases, land improvements, irrigation infrastructure, and precision agriculture technology investments. Supports CAPEX vs OPEX segregation for financial planning and tax depreciation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCogsAccount rdf:type rdf:Property ;
    rdfs:label 'Is Cogs Account' ;
    rdfs:comment 'Flags whether this GL account is used for Cost of Goods Sold (COGS) allocation. Supports commodity-level COGS tracking for crop enterprises (e.g., corn, soybeans, wheat) and livestock operations. Critical for gross margin analysis and EBITDA reporting by crop enterprise.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEbitdaRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Ebitda Relevant' ;
    rdfs:comment 'Indicates whether this GL account is included in EBITDA calculations for crop enterprise performance reporting. Accounts flagged as EBITDA-relevant are included in operating income before interest, taxes, depreciation, and amortization line items. Supports management reporting and investor relations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGaapRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Gaap Relevant' ;
    rdfs:comment 'Indicates whether this GL account is active and relevant under US GAAP reporting requirements. Supports dual-ledger GAAP/IFRS accounting where certain accounts may apply to one framework but not the other. Used in GAAP-basis financial statement preparation and SOX compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIfrsRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Ifrs Relevant' ;
    rdfs:comment 'Indicates whether this GL account is active and relevant under IFRS reporting requirements. Supports dual-ledger GAAP/IFRS accounting for consolidated financial statements filed with international regulators. Used in IFRS-basis financial statement preparation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOpexAccount rdf:type rdf:Property ;
    rdfs:label 'Is Opex Account' ;
    rdfs:comment 'Flags whether this GL account is designated for operational expenditure (OPEX) tracking, including seed costs, fertilizer, crop protection chemicals, labor, and irrigation operating costs. Supports CAPEX/OPEX segregation for EBITDA reporting and crop enterprise budgeting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account for a subledger (AP, AR, fixed assets, inventory). Reconciliation accounts cannot be posted to directly; postings flow from the subledger. Corresponds to SAP MITKZ field. Critical for SOX financial controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'When True, individual line items posted to this GL account are stored and displayable for detailed audit trail and drill-down analysis. Corresponds to SAP XKRES field. Required for SOX audit trail requirements and financial controls documentation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance per double-entry bookkeeping rules. Assets and expenses are normally debit; liabilities, equity, and revenues are normally credit. Used for trial balance validation and period-end close controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'When True, individual line items posted to this account are managed as open items that must be explicitly cleared (e.g., GR/IR clearing accounts, bank clearing accounts, advance payment accounts). Corresponds to SAP XOPVW field. Essential for AP/AR reconciliation and period-end close.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'When True, prevents any new financial postings to this GL account. Used during period-end close, account restructuring, or SOX-mandated account freeze periods. Corresponds to SAP XSPEB field. Critical for financial controls and audit integrity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'When True, a profit center assignment is mandatory for all postings to this GL account. Ensures segment-level profitability reporting by crop enterprise, livestock operation, or business unit. Supports IFRS 8 operating segment disclosure and management reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'When is_reconciliation_account is True, identifies which subledger this account reconciles: accounts payable (vendor), accounts receivable (customer), fixed assets, or inventory. Null or not_applicable for non-reconciliation accounts. Supports period-end close and SOX subledger-to-GL reconciliation controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-digit code that determines the assignment field populated in line items posted to this GL account (e.g., 001=posting date, 003=document number, 009=external document number, 014=assignment field). Corresponds to SAP ZUAWA field. Controls how line items are sorted and displayed in account statements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Specifies the tax relevance of the GL account for input/output tax determination (e.g., input tax, output tax, not tax-relevant, tax-exempt). Corresponds to SAP MWSKZ field. Relevant for agricultural input tax recovery on seed, fertilizer, and equipment purchases per applicable tax regulations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Amount' ;
    rdfs:comment 'Actual total payment amount received from the government program for the program year, in USD. Recorded upon receipt and reconciled against estimated amounts. Feeds into GL revenue recognition and USDA regulatory reporting.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:administeringAgency rdf:type rdf:Property ;
    rdfs:label 'Administering Agency' ;
    rdfs:comment 'Federal or state agency responsible for administering the program. USDA FSA (Farm Service Agency) administers commodity and disaster programs; USDA NRCS (Natural Resources Conservation Service) administers conservation programs; USDA RMA (Risk Management Agency) administers crop insurance programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseAcres rdf:type rdf:Property ;
    rdfs:label 'Base Acres' ;
    rdfs:comment 'USDA FSA-established base acres for the covered commodity on the farm, representing the historical planted acreage used to calculate ARC-CO and PLC program payments. Distinct from enrolled or planted acres.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Conservation Compliance Status' ;
    rdfs:comment 'Status of the farm operation\'s compliance with USDA conservation compliance requirements (Highly Erodible Land Conservation (HELC) and Wetland Conservation (WC) provisions). Non-compliance results in loss of eligibility for most USDA program benefits.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyCode rdf:type rdf:Property ;
    rdfs:label 'County Code' ;
    rdfs:comment 'FIPS county code for the county in which the enrolled farm is located and the FSA county office that administers the program. Required for ARC-CO county-level benchmark calculations and USDA reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolledAcres rdf:type rdf:Property ;
    rdfs:label 'Enrolled Acres' ;
    rdfs:comment 'Total number of acres enrolled in the program for the program year. For conservation programs (CRP, EQIP), this is the contracted acreage. For commodity programs, this represents the planted or covered acres.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the farm operation formally enrolled or signed up for the government program with the administering agency.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the farm\'s enrollment in the government program. Drives payment eligibility, compliance monitoring, and revenue planning workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Payment Amount' ;
    rdfs:comment 'Projected total payment amount expected to be received from the government program for the program year, in USD. Used for farm revenue planning, ROI analysis, and EBITDA forecasting. Calculated based on enrolled acres, base acres, payment yield, and payment rate.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farmSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Farm Serial Number' ;
    rdfs:comment 'USDA FSA-assigned Farm Serial Number uniquely identifying the farm unit registered with the local FSA county office. Required for commodity program enrollment and payment processing.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helcDetermination rdf:type rdf:Property ;
    rdfs:label 'Helc Determination' ;
    rdfs:comment 'USDA NRCS determination of whether the enrolled land contains Highly Erodible Land (HEL) and whether the farm is in compliance with required conservation practices. Affects program payment eligibility.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Level' ;
    rdfs:comment 'Percentage of expected yield or revenue covered by the crop insurance policy (e.g., 70%, 75%, 80%, 85%). Expressed as a decimal percentage. Determines indemnity payment trigger thresholds.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livestockUnits rdf:type rdf:Property ;
    rdfs:label 'Livestock Units' ;
    rdfs:comment 'Number of livestock units enrolled or covered under livestock-related programs (e.g., ELAP - Emergency Livestock Assistance Program, LFP - Livestock Forage Disaster Program). Expressed in animal units as defined by USDA.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all payment amounts associated with this program record (typically USD for USDA programs). Required for IFRS consolidated financial reporting.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentLimitationAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Limitation Amount' ;
    rdfs:comment 'Maximum allowable payment amount in USD that the farm operation may receive under USDA payment limitation rules for the program year. Varies by program type and entity structure.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentLimitationStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Limitation Status' ;
    rdfs:comment 'Indicates whether the farm operation\'s total program payments are within, at, or exceeding USDA-established annual payment limitation caps (e.g., $125,000 per person per year for ARC/PLC). Critical for compliance and payment eligibility monitoring.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRate rdf:type rdf:Property ;
    rdfs:label 'Payment Rate' ;
    rdfs:comment 'Per-unit payment rate established by the administering agency for the program year (e.g., dollars per base acre for ARC-CO/PLC, dollars per acre per year for CRP, dollars per practice unit for EQIP). Used to calculate estimated and actual payment amounts.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentRateUnit rdf:type rdf:Property ;
    rdfs:label 'Payment Rate Unit' ;
    rdfs:comment 'Unit of measure associated with the payment rate (e.g., per acre, per base acre, per bushel (BU), per hundredweight (CWT), per head of livestock, per conservation practice, per insurance policy). [ENUM-REF-CANDIDATE: per_acre|per_base_acre|per_bushel|per_cwt|per_head|per_practice|per_policy — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentYield rdf:type rdf:Property ;
    rdfs:label 'Payment Yield' ;
    rdfs:comment 'USDA FSA-established program payment yield (bushels per acre or equivalent unit) for the covered commodity, used in PLC payment calculations. Represents the farm\'s historical average yield.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP S/4HANA CO profit center associated with the government program, enabling profitability analysis by farm unit, commodity, or business segment for EBITDA and ROI reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Official agency-assigned short code or acronym for the program (e.g., ARC-CO, ARC-IC, PLC, CRP, EQIP, CSP, WHIP+, ERP, ELAP). Used for regulatory reporting and cross-referencing with USDA systems.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full official name of the government agricultural program (e.g., Agriculture Risk Coverage-County Option (ARC-CO), Price Loss Coverage (PLC), Conservation Reserve Program (CRP), Environmental Quality Incentives Program (EQIP), Conservation Stewardship Program (CSP), Whole-Farm Revenue Protection (WFRP)).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'Externally assigned program or contract number issued by the administering agency (e.g., USDA FSA farm serial number, NRCS contract number, RMA policy number). Used for cross-referencing with agency records.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'High-level classification of the government program category. Commodity programs include ARC-CO, ARC-IC, PLC. Conservation programs include CRP, EQIP, CSP. Crop insurance covers FCIC/RMA policies. Disaster assistance includes WHIP+, ERP, ELAP. State incentive covers state-level agricultural programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tractNumber rdf:type rdf:Property ;
    rdfs:label 'Tract Number' ;
    rdfs:comment 'USDA FSA-assigned tract number identifying a contiguous block of land within the farm unit. Used for base acre and enrolled acre tracking at the sub-farm level.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wetlandConservationStatus rdf:type rdf:Property ;
    rdfs:label 'Wetland Conservation Status' ;
    rdfs:comment 'USDA NRCS determination of wetland conservation compliance on the enrolled land. Farms converting wetlands to crop production may lose eligibility for USDA program benefits under Swampbuster provisions.' ;
    rdfs:domain ind:GovernmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each intercompany financial transaction record within the agricultural enterprise group. Primary key for this data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Intercompany transactions generate GL journal entries for both the sending and receiving entities. Linking intercompany_transaction to journal_entry enables traceability from the intercompany transact' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:receivingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code Id' ;
    rdfs:comment 'Reference to the legal entity (company code) on the receiving end of the intercompany transaction. Corresponds to the counterpart subsidiary or entity within the agricultural enterprise group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Reference to the legal entity (company code) initiating and posting the intercompany transaction. Corresponds to the originating subsidiary or farming entity within the agricultural enterprise group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:commodityQuantity rdf:type rdf:Property ;
    rdfs:label 'Commodity Quantity' ;
    rdfs:comment 'The quantity of agricultural commodity transferred in an intercompany commodity transfer transaction. Expressed in the unit of measure specified in commodity_quantity_uom. Populated only for transaction_type = \'commodity_transfer\'.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Commodity Quantity Uom' ;
    rdfs:comment 'Unit of measure for the commodity quantity in an intercompany commodity transfer. BU = Bushel, MT = Metric Ton, CWT = Hundredweight, LB = Pound, KG = Kilogram, TON = Short Ton. Aligns with USDA and CBOT standard commodity measurement conventions.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterSending rdf:type rdf:Property ;
    rdfs:label 'Cost Center Sending' ;
    rdfs:comment 'The SAP S/4HANA CO cost center of the sending entity associated with the intercompany transaction. Supports OPEX tracking, cost allocation, and management fee distribution across the agricultural enterprise.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the intercompany transaction\'s elimination in the consolidated financial statements. Transactions must be eliminated to avoid double-counting in GAAP/IFRS consolidated P&L and balance sheet. \'pending\' indicates awaiting elimination run; \'eliminated\' confirms full elimination; \'disputed\' flags mismatches requiring resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountReceiving rdf:type rdf:Property ;
    rdfs:label 'Gl Account Receiving' ;
    rdfs:comment 'The General Ledger (GL) account number in the receiving company code\'s chart of accounts to which the offsetting intercompany entry is posted. Supports automated intercompany clearing and reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountSending rdf:type rdf:Property ;
    rdfs:label 'Gl Account Sending' ;
    rdfs:comment 'The General Ledger (GL) account number in the sending company code\'s chart of accounts to which the intercompany transaction is posted (debit or credit). Sourced from SAP S/4HANA FI module.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount translated into the group reporting currency (typically USD) for consolidated financial statement preparation. Supports EBITDA reporting and consolidated P&L at the enterprise group level.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the enterprise group\'s reporting currency used in consolidated financial statements (e.g., USD). Defined at the consolidation group level in SAP S/4HANA.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Reference' ;
    rdfs:comment 'Reference identifier for the intercompany netting agreement under which multiple intercompany payables and receivables between entities are offset and settled as a single net payment. Reduces cash flow complexity across the agricultural enterprise group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction is included in a netting cycle, has been settled via netting, or is excluded from netting arrangements. Supports cash pooling and treasury management across the agricultural enterprise group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterReceiving rdf:type rdf:Property ;
    rdfs:label 'Profit Center Receiving' ;
    rdfs:comment 'The SAP S/4HANA CO profit center of the receiving entity for the intercompany transaction. Used for segment reporting, COGS allocation by commodity, and internal profitability analysis.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterSending rdf:type rdf:Property ;
    rdfs:label 'Profit Center Sending' ;
    rdfs:comment 'The SAP S/4HANA CO profit center of the sending entity responsible for the intercompany transaction. Enables profitability analysis by crop enterprise, livestock operation, or business segment within the agricultural group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number associated with the intercompany transaction, such as a Purchase Order (PO) number, Sales Order (SO) number, intercompany invoice number, or loan agreement reference. Enables end-to-end traceability across the agricultural supply chain.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The accounting date on which the reversal of this intercompany transaction was posted in SAP S/4HANA. Populated only when transaction_status = \'reversed\'. Used for period-end close and audit trail.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'SAP S/4HANA document number of the reversal entry created to cancel this intercompany transaction. Populated only when transaction_status = \'reversed\'. Supports audit trail and SOX financial controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross base amount of the intercompany transaction in the transaction currency. Represents the face value before any adjustments, netting, or eliminations. For commodity transfers, reflects the transfer price of agricultural goods (grain, livestock, inputs).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the intercompany transaction amount is denominated (e.g., USD, EUR, BRL). Drives foreign currency translation for consolidated financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'Free-text description of the intercompany transaction providing business context, such as the nature of the commodity transfer, management fee basis, or loan purpose. Sourced from the SAP S/4HANA document header text field.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business identifier for the intercompany transaction, typically generated by SAP S/4HANA FI module. Follows the format ICT-{YYYY}-{SEQUENCE}. Used for cross-entity reconciliation and audit trail.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction in SAP S/4HANA. \'draft\' indicates a parked document; \'posted\' confirms GL posting; \'reversed\' indicates a reversal document has been created; \'cancelled\' indicates the transaction was voided; \'on_hold\' indicates pending approval.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction by its business nature. Commodity transfers represent cross-entity movement of agricultural goods (grain, livestock, inputs). Management fees cover shared services charges. Intercompany loans represent financing between entities. Service charges cover operational support. [ENUM-REF-CANDIDATE: commodity_transfer|management_fee|intercompany_loan|service_charge|dividend|royalty|cost_allocation|capital_contribution — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Method' ;
    rdfs:comment 'The OECD-approved transfer pricing methodology applied to determine the arm\'s-length price for the intercompany transaction. Critical for tax compliance and regulatory reporting. Commodity transfers between farming subsidiaries must comply with OECD Transfer Pricing Guidelines and local tax authority requirements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The exact date and time when this journal entry was approved for posting. Provides a precise audit trail event timestamp for SOX compliance, internal control testing, and financial close timeline analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-form alphanumeric field used to sort and group GL line items for clearing and reconciliation purposes. In agricultural operations, commonly populated with crop season identifiers, field IDs, commodity lot numbers, or customer/vendor account numbers to facilitate open item management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeAmount rdf:type rdf:Property ;
    rdfs:label 'Company Code Amount' ;
    rdfs:comment 'The journal entry amount converted to the company code (local) currency. Used for entity-level financial reporting, statutory filings, and GAAP/IFRS consolidated financial statements. Derived from transaction_amount using the exchange rate at posting_date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code (local) currency in which company_code_amount is expressed. Typically USD for US-based agricultural entities but may differ for international subsidiaries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the line item is a debit (D) or credit (C) posting per double-entry bookkeeping principles. Fundamental to GL balance verification, trial balance generation, and GAAP/IFRS financial statement preparation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The exact date and time when this journal entry record was first created in the source system (SAP S/4HANA or Oracle NetSuite). Serves as the RECORD_AUDIT_CREATED timestamp for SOX-compliant audit trail and data lineage tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag identifying this journal entry as an intercompany transaction between two legal entities within the agricultural enterprise group. True = intercompany posting requiring elimination in consolidated financial statements; False = intracompany or third-party posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'The date and time when this journal entry record was last modified in the source system. Supports SOX-compliant change audit trails, data reconciliation between SAP S/4HANA and Oracle NetSuite, and Silver Layer incremental load processing.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text explaining the business purpose of this journal entry line item. Provides human-readable context for auditors, accountants, and financial analysts. Examples: \'Corn harvest COGS allocation Q3\', \'Irrigation system CAPEX accrual\', \'Intercompany feed cost recharge\'.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP two-digit posting key controlling the account type, debit/credit indicator, and field selection for this journal entry line (e.g., 40=GL debit, 50=GL credit, 31=vendor credit, 01=customer debit). Determines how the line item is processed and displayed in the GL.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry in the GL workflow. \'draft\' = entry created but not posted; \'posted\' = fully posted to GL; \'parked\' = saved for review before posting; \'held\' = temporarily suspended; \'reversed\' = reversed by a subsequent document; \'cleared\' = open items cleared against each other.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'The system user ID of the person or automated process that posted this journal entry in SAP S/4HANA or Oracle NetSuite. Essential for SOX-compliant audit trails, segregation of duties (SoD) controls, and forensic accounting investigations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry has been reversed by a subsequent accounting document. True = entry has been reversed; False = entry is active and not reversed. Critical for period-end close accuracy, accrual management, and SOX audit trail completeness.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the receiving/counterpart entity in an intercompany journal entry. Used for intercompany reconciliation, elimination of intercompany profits in consolidated financial statements, and netting agreement processing per GAAP ASC 810 and IFRS 10.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line item within a General Ledger (GL) journal entry. Serves as the primary key for this record in the Databricks Silver Layer lakehouse.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Reference to the SAP internal order used for short-term cost collection on specific agricultural activities (e.g., a planting campaign, a pest management program, or a harvest operation). Complements WBS for non-project cost tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Reference to the Work Breakdown Structure (WBS) element for project-based cost tracking. Used for CAPEX projects such as irrigation infrastructure, equipment procurement, and farm facility construction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Reference date used for payment term calculation and due date determination for vendor/customer line items. Typically the invoice date or goods receipt date for agricultural procurement transactions.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which this open item was cleared (matched and offset) by a corresponding payment or contra-posting. Null for uncleared items. Used for aging analysis and cash flow reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing transaction that offset this open item (e.g., payment clearing a vendor invoice, goods receipt clearing a GRN). Null if the line item is still open. Critical for AP/AR reconciliation and SOX audit trails.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code (legal entity) in which this posting is recorded. Typically the functional currency of the agricultural operating entity (e.g., USD for US operations).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Line Item Status' ;
    rdfs:comment 'Current processing status of this journal entry line item: open=uncleared open item, cleared=matched and offset, parked=saved but not posted, reversed=reversed by a subsequent document, blocked=payment block applied. Supports AP aging and SOX audit workflows.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating a payment block applied to this line item preventing automatic payment processing (e.g., quality hold, dispute, manual review required). Used in agricultural AP workflows for invoice verification and HACCP-related quality disputes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the quantity field (e.g., BU=Bushel, MT=Metric Ton, CWT=Hundredweight, KG=Kilogram). Aligns with USDA standard agricultural units and SAP base unit of measure configuration. [ENUM-REF-CANDIDATE: BU|MT|CWT|KG|LB|EA|L|GAL|TON — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'SAP Special GL indicator for non-standard postings such as down payments, guarantees, or bill of exchange transactions. Used in agricultural advance payment scenarios (e.g., prepaid seed contracts, crop advance payments).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Amount' ;
    rdfs:comment 'Monetary amount of this line item expressed in the originating transaction currency. Represents the raw posting value before currency translation. Satisfies TRANSACTION_LINE role LINE_VALUE_OR_RESULT category requirement.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanId rdf:type rdf:Property ;
    rdfs:label 'Loan Id' ;
    rdfs:comment 'Unique system-generated identifier for each loan or credit facility record in the agricultural enterprise debt portfolio.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Loan .

ind:collateralHerdId rdf:type rdf:Property ;
    rdfs:label 'Collateral Herd Id' ;
    rdfs:comment 'Foreign key linking to livestock.herd. Business justification: Livestock herds are pledged as collateral for FSA operating loans and commercial lines of credit. Linking loan to herd (as collateral) supports lender reporting, collateral valuation updates, and cove' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Herd .

ind:accruedInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest Amount' ;
    rdfs:comment 'Interest expense accrued since the last payment date but not yet paid. Required for period-end accrual journal entries in SAP S/4HANA FI and accurate EBITDA reporting.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Undrawn portion of the credit facility available for future draws (credit_limit_amount minus outstanding_balance). Critical for seasonal liquidity planning and crop input purchasing decisions.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralDescription rdf:type rdf:Property ;
    rdfs:label 'Collateral Description' ;
    rdfs:comment 'Narrative description of the specific assets pledged as collateral (e.g., \'Section 14 T2N R5E 320 acres farmland\', \'John Deere 8R 410 tractor SN XXXXXXX\'). Supports lien filing and asset encumbrance management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralType rdf:type rdf:Property ;
    rdfs:label 'Collateral Type' ;
    rdfs:comment 'Primary category of assets pledged as security for the loan. Agricultural loans are commonly secured by farmland, equipment, standing crops, or livestock. Drives lender risk assessment and asset encumbrance tracking. [ENUM-REF-CANDIDATE: land|equipment|crop|livestock|accounts_receivable|blanket_lien — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralValuationDate rdf:type rdf:Property ;
    rdfs:label 'Collateral Valuation Date' ;
    rdfs:comment 'Date on which the collateral was most recently appraised or valued. Lenders typically require periodic revaluation; this date triggers renewal workflows.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collateralValueAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Value Amount' ;
    rdfs:comment 'Appraised or estimated market value of the pledged collateral at the most recent valuation date. Used to calculate loan-to-value (LTV) ratios and assess collateral coverage adequacy.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Status' ;
    rdfs:comment 'Current compliance state with respect to all financial covenants on this loan. A breach status triggers escalation to CFO and legal counsel and may require SOX disclosure. Monitored at each period close.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantDescription rdf:type rdf:Property ;
    rdfs:label 'Covenant Description' ;
    rdfs:comment 'Summary of key financial covenants attached to the loan agreement (e.g., minimum current ratio of 1.25:1, maximum debt-to-asset ratio of 0.50, minimum working capital of $500,000). Covenant breaches can trigger acceleration clauses.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantReviewDate rdf:type rdf:Property ;
    rdfs:label 'Covenant Review Date' ;
    rdfs:comment 'Date of the most recent covenant compliance review or test. Lenders typically require quarterly or annual covenant testing; this date drives the next review scheduling.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum authorized borrowing capacity under a revolving line of credit or operating line. Applicable to operating lines and seasonal crop production facilities. Null for fully-drawn term loans.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Draw Period End Date' ;
    rdfs:comment 'Last date on which the borrower may draw funds under a revolving credit facility or operating line of credit. After this date, the facility enters repayment-only mode. Specific to revolving and seasonal crop production lines.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsaGuaranteePercentage rdf:type rdf:Property ;
    rdfs:label 'Fsa Guarantee Percentage' ;
    rdfs:comment 'Percentage of the loan principal guaranteed by the USDA Farm Service Agency under the Business and Industry (B&I) or Farm Loan Programs (e.g., 90.00 = 90%). Null for non-guaranteed loans. Reduces lender risk and may affect interest rate terms.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsaLoanNumber rdf:type rdf:Property ;
    rdfs:label 'Fsa Loan Number' ;
    rdfs:comment 'USDA Farm Service Agency assigned loan identifier for FSA direct or guaranteed loans. Required for federal program reporting, subsidy tracking, and USDA compliance filings. Null for non-FSA loans.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate expressed as a decimal (e.g., 0.06500 = 6.5%). For variable-rate loans, this reflects the current effective rate including the benchmark plus spread. Used for interest expense accrual in SAP S/4HANA CO and EBITDA reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRateType rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Type' ;
    rdfs:comment 'Indicates whether the interest rate is fixed for the loan term, variable (tied to a benchmark such as SOFR or Prime Rate), or hybrid (fixed for an initial period then variable). Drives interest expense forecasting and hedge accounting decisions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderName rdf:type rdf:Property ;
    rdfs:label 'Lender Name' ;
    rdfs:comment 'Name of the lending institution providing the debt facility (e.g., Farm Credit Services of America, Rabobank, Wells Fargo Agribusiness, USDA Farm Service Agency). Essential for counterparty risk management and lender relationship tracking.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderType rdf:type rdf:Property ;
    rdfs:label 'Lender Type' ;
    rdfs:comment 'Category of the lending institution. Farm Credit institutions are government-sponsored enterprises; FSA loans carry federal guarantees; commercial banks and cooperatives operate under standard banking regulations. Informs interest rate benchmarking and covenant expectations.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanNumber rdf:type rdf:Property ;
    rdfs:label 'Loan Number' ;
    rdfs:comment 'Externally-known loan reference number assigned by the lender (e.g., Farm Credit loan number, commercial bank reference, FSA loan number). Used for lender correspondence and payment remittances.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanStatus rdf:type rdf:Property ;
    rdfs:label 'Loan Status' ;
    rdfs:comment 'Current lifecycle state of the loan. Drives financial reporting classifications (current vs. non-current debt), covenant monitoring, and SOX control checkpoints.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanType rdf:type rdf:Property ;
    rdfs:label 'Loan Type' ;
    rdfs:comment 'Classification of the debt instrument. Operating lines of credit fund seasonal inputs; term loans finance equipment or land; FSA guaranteed loans are backed by the USDA Farm Service Agency; crop production loans are secured against future harvest revenue. [ENUM-REF-CANDIDATE: operating_line_of_credit|term_loan|fsa_guaranteed|crop_production|equipment_loan|real_estate_mortgage — promote to reference product]' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Contractual date on which the full outstanding principal and any accrued interest are due. Drives current vs. non-current debt classification on the balance sheet and triggers covenant review processes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Next Payment Amount' ;
    rdfs:comment 'Dollar amount of the next scheduled payment including both principal and interest components. Supports cash flow planning and AP payment run preparation in SAP S/4HANA.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Date on which the next scheduled principal or interest payment is due to the lender. Used for cash flow forecasting, AP payment scheduling in SAP S/4HANA, and covenant compliance monitoring.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationDate rdf:type rdf:Property ;
    rdfs:label 'Origination Date' ;
    rdfs:comment 'Date the loan agreement was executed and funds were first made available. Establishes the start of the amortization schedule and the effective date for interest accrual. Aligns with GAAP ASC 470 initial recognition.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'Original face value of the loan at origination. Used as the baseline for amortization schedules, interest calculations, and CAPEX/OPEX debt tracking in SAP S/4HANA FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBenchmark rdf:type rdf:Property ;
    rdfs:label 'Rate Benchmark' ;
    rdfs:comment 'Reference rate index used as the base for variable-rate loans (e.g., SOFR — Secured Overnight Financing Rate, Prime Rate, Farm Credit index). Null for fixed-rate instruments. Required for interest rate risk management and hedge effectiveness testing.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Rate Spread Bps' ;
    rdfs:comment 'Margin added to the benchmark rate expressed in basis points (e.g., 150 = 1.50%). Combined with the benchmark to derive the effective interest rate for variable-rate loans. Used in interest expense modeling and commodity hedge accounting.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Primary key for period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeCalendarId rdf:type rdf:Property ;
    rdfs:label 'Close Calendar Id' ;
    rdfs:comment 'Reference to the close calendar template that governs the schedule and sequencing of this period close task. Manages seasonal peaks around harvest settlement and crop year-end.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CloseCalendar .

ind:dependencyTaskPeriodCloseId rdf:type rdf:Property ;
    rdfs:label 'Dependency Task Period Close Id' ;
    rdfs:comment 'Reference to another period close task that must be completed before this task can begin. Enables sequencing and dependency management within the close calendar workflow.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeriodClose .

ind:esgReportId rdf:type rdf:Property ;
    rdfs:label 'Esg Report Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_report. Business justification: Financial period close in agriculture includes ESG reporting close tasks (harvest_settlement_flag present on period_close). Linking to esg_report enables coordinated financial and ESG close calendar m' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgReport .

ind:primaryPeriodEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Period Employee Id' ;
    rdfs:comment 'Reference to the employee or user responsible for executing and completing this period close task. Supports SOX accountability and segregation of duties controls.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual financial value posted or recorded as a result of completing this close task (e.g., actual accrual posted, actual depreciation run amount, actual inventory valuation). Compared against estimated amount for variance reporting.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closePeriodType rdf:type rdf:Property ;
    rdfs:label 'Close Period Type' ;
    rdfs:comment 'Classification of the close period indicating whether this is a month-end, quarter-end, year-end, crop-year-end (agricultural fiscal cycle), or special period close. Crop-year-end is specific to agricultural enterprises following USDA crop year conventions.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Close Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this period close task record, used for cross-system tracking and audit trail. Typically sourced from SAP S/4HANA or Oracle NetSuite close management workflows.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTaskName rdf:type rdf:Property ;
    rdfs:label 'Close Task Name' ;
    rdfs:comment 'Human-readable name or short description of the specific period close task, providing additional context beyond the task type code (e.g., \'Q3 Grain Inventory Mark-to-Market\', \'Harvest Settlement Accruals Posting\').' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTaskType rdf:type rdf:Property ;
    rdfs:label 'Close Task Type' ;
    rdfs:comment 'The specific type of period-end close activity being tracked. Examples include accruals posting, depreciation run, inventory valuation at harvest, intercompany reconciliation, grain inventory mark-to-market, COGS allocation by commodity, financial statement preparation, and tax provision. [ENUM-REF-CANDIDATE: accruals_posting|depreciation_run|inventory_valuation|intercompany_reconciliation|grain_mark_to_market|cogs_allocation|financial_statement_prep|tax_provision|bank_reconciliation|fixed_asset_close — promote to reference product]' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Amount' ;
    rdfs:comment 'The estimated financial value associated with this close task (e.g., estimated accrual amount, estimated depreciation charge, estimated inventory valuation adjustment). Used for pre-close planning and variance analysis.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaapIfrsStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Ifrs Standard' ;
    rdfs:comment 'The accounting standard under which this period close task is executed and reported. Supports dual GAAP/IFRS reporting for consolidated financial statements and regulatory filings.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which financial entries associated with this close task are posted to the General Ledger (GL) in SAP S/4HANA. Critical for period-end cutoff compliance under GAAP and IFRS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:harvestSettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Harvest Settlement Flag' ;
    rdfs:comment 'Indicates whether this close task is specifically associated with the agricultural harvest settlement process, which involves final grain pricing, deferred payment settlements, and crop year-end accruals. True for harvest settlement tasks; False otherwise.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this close task involves intercompany reconciliation or elimination entries between legal entities within the agricultural enterprise group. True for intercompany tasks; False for single-entity tasks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the financial period being closed. Defines the reporting window for this close cycle and aligns with GAAP/IFRS reporting timelines.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the financial period being closed. Defines the reporting window for this close cycle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriodLocked rdf:type rdf:Property ;
    rdfs:label 'Posting Period Locked' ;
    rdfs:comment 'Indicates whether the fiscal posting period has been locked in SAP S/4HANA to prevent further journal entries after close completion. True when the period is locked; False when still open for posting.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'The SOX internal control identifier or reference number associated with this period close task. Links the task to the enterprise\'s SOX control framework for financial reporting compliance and audit evidence.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNotes rdf:type rdf:Property ;
    rdfs:label 'Task Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the task owner or approver regarding the execution of this period close task, including explanations for variances, exceptions, or issues encountered during the close process.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskOwnerName rdf:type rdf:Property ;
    rdfs:label 'Task Owner Name' ;
    rdfs:comment 'Full name of the employee or user responsible for executing this period close task. Retained for audit trail and SOX control documentation purposes.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequence rdf:type rdf:Property ;
    rdfs:label 'Task Sequence' ;
    rdfs:comment 'Numeric ordering of this close task within the overall period close workflow, enabling sequenced execution and progress tracking across the close calendar.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current workflow status of the period close task indicating its progress through the close cycle. Drives close calendar dashboards and SOX control monitoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the estimated amount and the actual amount for this close task. Positive variance indicates actual exceeded estimate; negative indicates under-run. Used for close quality analysis and management reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax transaction and compliance record in the agricultural enterprise. Primary key for the tax_record data product.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTaxRecordId rdf:type rdf:Property ;
    rdfs:label 'Original Tax Record Id' ;
    rdfs:comment 'Reference to the original tax_record_id that this record amends or supersedes. Populated only when amended_indicator is True, enabling lineage tracking of tax corrections and restatements.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRecord .

ind:amendedIndicator rdf:type rdf:Property ;
    rdfs:label 'Amended Indicator' ;
    rdfs:comment 'Flag indicating whether this tax record represents an amended filing (e.g., IRS Form 1040X equivalent) correcting a previously filed return. Supports audit trail and SOX financial controls.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredTaxDirection rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Direction' ;
    rdfs:comment 'Indicates whether the deferred tax position is an asset (future tax benefit) or liability (future tax obligation) per GAAP ASC 740 and IFRS IAS 12. Applicable only when deferred_tax_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Indicator' ;
    rdfs:comment 'Flag indicating whether this tax record represents a deferred tax asset or liability per GAAP ASC 740 or IFRS IAS 12. Deferred taxes arise from temporary differences between book and tax accounting for agricultural assets such as crop inventory, biological assets, and depreciation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Exemption Amount' ;
    rdfs:comment 'Monetary value of agricultural-specific tax exemptions applied to this record, including farm fuel tax credits, ag sales tax exemptions on seeds/fertilizers/pesticides, and USDA-recognized exemptions. Reduces the net tax liability.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Number' ;
    rdfs:comment 'Reference number of the agricultural tax exemption certificate (e.g., farm sales tax exemption certificate for seeds, fertilizers, pesticides, or farm fuel). Required for audit substantiation of exemption_amount claims with state revenue departments.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'Classification of the agricultural tax exemption applied to this record. Includes farm fuel tax credits, ag sales tax exemptions on qualifying inputs (seeds, fertilizers, pesticides), organic input exemptions, and equipment exemptions per USDA and state revenue rules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Regulatory authority-assigned confirmation or acknowledgment number for the tax return or filing submission (e.g., IRS e-file acknowledgment number, state filing confirmation). Provides audit trail for regulatory compliance.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Monetary amount of interest charged by the regulatory authority on overdue tax balances. Tracked separately for GAAP/IFRS accrual accounting and financial statement disclosure.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the taxing jurisdiction (e.g., \'Iowa Department of Revenue\', \'USDA Federal\', \'Polk County Assessor\'). Supports reporting and correspondence with regulatory authorities.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Net Tax Amount' ;
    rdfs:comment 'Final tax obligation after deducting exemption_amount and any credits from tax_amount. Represents the actual cash outflow or accrual posted to the GL for GAAP/IFRS financial statement reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Statutory deadline by which the tax payment must be remitted to the regulatory authority (IRS, state revenue department, county assessor for property tax). Critical for cash flow planning and penalty avoidance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Bank or treasury payment reference number (e.g., EFTPS confirmation number for IRS payments, state e-file confirmation) confirming remittance of the tax amount. Used for payment reconciliation and audit evidence.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The governing regulatory body responsible for administering this tax obligation. Agricultural enterprises interact with IRS for federal income/excise tax, state revenue departments for sales/use tax, county assessors for property tax, and EPA for chemical excise taxes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Externally-known tax document or posting reference number assigned by the source system (SAP S/4HANA FI or Oracle NetSuite). Used for audit trail, cross-referencing with tax filings, and regulatory correspondence with IRS, state revenue departments, or EPA.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period End Date' ;
    rdfs:comment 'End date of the tax reporting period to which this tax record applies. Together with tax_period_start_date defines the taxable period for filing and accrual purposes.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period Start Date' ;
    rdfs:comment 'Start date of the tax reporting period (month, quarter, or fiscal year) to which this tax record applies. Used for period-based tax accruals, EBITDA reporting, and regulatory filing schedules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable statutory or effective tax rate expressed as a decimal (e.g., 0.0825 for 8.25%). Sourced from the tax jurisdiction configuration in SAP S/4HANA FI or Oracle NetSuite tax engine.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax obligation. Covers agricultural-specific tax types including sales tax on inputs, use tax on equipment, excise tax on agricultural chemicals (EPA-regulated), property tax on farmland, income tax provisions, and payroll tax. [ENUM-REF-CANDIDATE: sales_tax|use_tax|excise_tax|property_tax|income_tax|payroll_tax|fuel_tax|value_added_tax|withholding_tax — promote to reference product]' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross monetary value subject to taxation before applying the tax rate. For agricultural enterprises this may represent crop sale proceeds, chemical purchase value, farmland assessed value, or income before tax. Denominated in the company reporting currency.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocationId rdf:type rdf:Property ;
    rdfs:label 'Bin Location Id' ;
    rdfs:comment 'Unique surrogate identifier for each bin location record within the warehouse management system. Serves as the primary key for the bin_location data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinLocation .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Reference to the SAP plant (facility or production site) to which this bin location belongs. Aligns bin-level inventory tracking with SAP S/4HANA MM plant-level stock management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'Alphanumeric code identifying the aisle within the storage section where this bin is physically located. Used for optimizing pick paths and directing warehouse personnel to the correct physical location.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Material Types' ;
    rdfs:comment 'Comma-separated list of SAP material type codes permitted for storage in this bin (e.g., \'FERT,DUNG,ERSA\' for fertilizers, seeds, and spare parts). Enforces material segregation rules and prevents incompatible commodity co-mingling. Managed in SAP S/4HANA MM material type configuration.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the bin within its storage location. Used in WMS slot management, pick/put-away instructions, and RFID scanning operations. Corresponds to the WMS bin number in Manhattan Associates.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binName rdf:type rdf:Property ;
    rdfs:label 'Bin Name' ;
    rdfs:comment 'Human-readable descriptive name or label for the bin location (e.g., \'North Grain Bin Cell 3A\', \'Cold Bay 12\', \'Rack Position A-02-03\'). Used in operational reports and warehouse floor maps.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Status' ;
    rdfs:comment 'Current operational lifecycle status of the bin location within the WMS. Active bins are available for put-away and picking; blocked bins are temporarily unavailable; reserved bins are pre-allocated; under_maintenance bins are being serviced; decommissioned bins are permanently retired.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binType rdf:type rdf:Property ;
    rdfs:label 'Bin Type' ;
    rdfs:comment 'Classification of the physical bin structure. Determines storage rules, capacity constraints, and compatible material types. Grain bin cells hold harvested commodities; rack positions hold packaged goods; cold storage bays hold perishables; floor stacks hold palletized inventory; bulk piles hold loose commodities; chemical cabinets hold agrochemicals. [ENUM-REF-CANDIDATE: grain_bin_cell|rack_position|cold_storage_bay|floor_stack|bulk_pile|chemical_cabinet — promote to reference product]' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBu rdf:type rdf:Property ;
    rdfs:label 'Capacity Bu' ;
    rdfs:comment 'Maximum storage capacity of the bin expressed in Bushels (BU), the standard unit of measure for grain commodities in US agricultural operations. Used for grain bin cell utilization planning and WASDE reporting alignment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCwt rdf:type rdf:Property ;
    rdfs:label 'Capacity Cwt' ;
    rdfs:comment 'Maximum storage capacity of the bin expressed in Hundredweight (CWT), a standard unit used for livestock feed, fertilizer, and certain commodity pricing in US agricultural markets.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityMt rdf:type rdf:Property ;
    rdfs:label 'Capacity Mt' ;
    rdfs:comment 'Maximum storage capacity of the bin expressed in Metric Tons (MT). Used for international trade documentation, export compliance, and alignment with global commodity reporting standards (CIF/FOB contracts).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Pct' ;
    rdfs:comment 'Current fill level of the bin expressed as a percentage of its maximum capacity. Calculated from WMS inventory positions and updated on each stock movement. Drives replenishment triggers and bin assignment logic in Manhattan Associates WMS.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date the bin location was permanently decommissioned and removed from active WMS operations. Nullable for active bins. Used for capacity planning, asset retirement reporting, and historical inventory analysis.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the bin location in centimeters. Determines compatibility with stacked pallets, tall containers, or bulk commodity storage. Used in conjunction with level_code for equipment selection (e.g., high-reach forklift requirements).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGmoSegregated rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Segregated' ;
    rdfs:comment 'Indicates whether this bin is designated for GMO-segregated commodity storage. When True, the bin is used exclusively for non-GMO or identity-preserved commodities, supporting COOL (Country of Origin Labeling) and non-GMO supply chain traceability requirements.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Compatible' ;
    rdfs:comment 'Indicates whether this bin is certified and equipped to store hazardous materials such as pesticides, herbicides, or fertilizers with hazmat classifications. When True, the bin meets EPA and OSHA storage requirements for agrochemicals. Prevents co-mingling of hazmat and food-grade commodities.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicSegregated rdf:type rdf:Property ;
    rdfs:label 'Is Organic Segregated' ;
    rdfs:comment 'Indicates whether this bin is designated exclusively for USDA National Organic Program (NOP) certified organic commodities. When True, the bin must be physically segregated from non-organic storage to maintain organic certification integrity and prevent commingling.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCleanedDate rdf:type rdf:Property ;
    rdfs:label 'Last Cleaned Date' ;
    rdfs:comment 'Date the bin location was last cleaned and sanitized. Critical for food safety compliance, particularly for grain bins and cold storage bays. Supports HACCP sanitation monitoring, FSMA Preventive Controls, and GLOBALG.A.P. hygiene audit requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent WMS-driven cycle count performed on this bin location. Used to schedule future cycle counts, assess inventory accuracy compliance, and support FSMA traceability requirements. Sourced from Manhattan Associates WMS cycle count completion records.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectedDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspected Date' ;
    rdfs:comment 'Date of the most recent physical inspection of the bin location for structural integrity, pest presence, moisture ingress, or contamination. Supports USDA APHIS pest management compliance and GFSI audit readiness.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the bin location in centimeters. Used for slotting optimization, determining compatible pallet or container sizes, and space utilization analysis within the warehouse management system.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelCode rdf:type rdf:Property ;
    rdfs:label 'Level Code' ;
    rdfs:comment 'Alphanumeric code identifying the vertical level or tier of the bin within a rack or storage structure. Used for height-based storage rules and equipment selection (e.g., forklift reach requirements).' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTempCelsius rdf:type rdf:Property ;
    rdfs:label 'Max Temp Celsius' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this bin location. Exceeding this threshold triggers WMS alerts and may require stock relocation to prevent quality degradation or food safety violations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable weight load for this bin location in kilograms. Critical for structural safety compliance, particularly for rack positions and floor stacks. Prevents overloading that could cause structural failure or OSHA safety violations.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTempCelsius rdf:type rdf:Property ;
    rdfs:label 'Min Temp Celsius' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this bin location. Used to enforce cold chain compliance and prevent commodity spoilage. Monitored via IoT sensors integrated with the WMS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:putAwayStrategy rdf:type rdf:Property ;
    rdfs:label 'Put Away Strategy' ;
    rdfs:comment 'WMS put-away strategy assigned to this bin, governing how incoming stock is directed to this location. Fixed bins always receive the same material; open bins accept any compatible material; bulk bins receive large-volume commodity transfers; addition bins consolidate partial pallets; next_empty bins are filled sequentially.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'RFID tag identifier physically attached to the bin location for automated scanning and real-time inventory tracking. Enables touchless bin identification during put-away, picking, and cycle count operations in Manhattan Associates WMS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationMethod rdf:type rdf:Property ;
    rdfs:label 'Rotation Method' ;
    rdfs:comment 'Inventory rotation method applied to stock stored in this bin. FIFO (First In First Out) and FEFO (First Expired First Out) are standard for food-grade commodities to minimize spoilage and ensure compliance with food safety regulations. LIFO and LEFO may apply to non-perishable inputs.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowCode rdf:type rdf:Property ;
    rdfs:label 'Row Code' ;
    rdfs:comment 'Alphanumeric code identifying the row within the aisle for this bin. Combined with aisle_code and level_code to form the full physical coordinate of the bin within the warehouse.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageBin rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Bin' ;
    rdfs:comment 'The storage bin identifier as defined in SAP S/4HANA Warehouse Management (WM) module. Used for cross-system reconciliation between Manhattan Associates WMS and SAP S/4HANA MM inventory postings. Corresponds to the LGPLA field in SAP WM.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageSectionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Section Code' ;
    rdfs:comment 'Code identifying the logical storage section or zone within the storage location to which this bin belongs (e.g., \'SEC-A\', \'ZONE-COLD-1\'). Supports zone-based picking strategies and inventory segmentation in Manhattan Associates WMS.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature-controlled zone classification for the bin. Determines which commodities (e.g., fresh produce, frozen goods, ambient grain) can be stored in this bin. Critical for cold chain compliance and food safety under FDA and FSMA requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the bin location in centimeters. Used alongside length and height for slotting optimization and determining whether specific pallet configurations or container types can be accommodated.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsBinNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Bin Number' ;
    rdfs:comment 'The bin identifier as recorded in Manhattan Associates WMS, used for system-to-system integration and reconciliation with SAP S/4HANA WM storage bin records. This is the operational system key used in WMS transactions.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Gmo Declaration Id' ;
    rdfs:comment 'Foreign key linking to product.gmo_declaration. Business justification: BE Act (Bioengineered Food Disclosure) requires GMO commodity lots to reference a formal GMO declaration for disclosure compliance. Linking enables export market eligibility checks (EU, China, Japan a' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmoDeclaration .

ind:harvestFrostAlertId rdf:type rdf:Property ;
    rdfs:label 'Harvest Frost Alert Id' ;
    rdfs:comment 'Foreign key linking to weather.frost_alert. Business justification: Frost alerts at harvest time cause frost-damaged grain lots with reduced quality and grade. Role-prefix \'harvest_\' distinguishes this from a storage-phase frost event. Grain quality managers and insur' ;
    rdfs:domain ind:CommodityLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrostAlert .

ind:originFieldId rdf:type rdf:Property ;
    rdfs:label 'Origin Field Id' ;
    rdfs:comment 'Reference to the farm field or parcel from which this commodity lot was harvested, enabling farm-to-table traceability per FSMA Section 204 and GLOBALG.A.P. Traceability Standard. Links to field/parcel master data managed in John Deere Operations Center and Esri ArcGIS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Field .

ind:originManagementZoneId rdf:type rdf:Property ;
    rdfs:label 'Origin Management Zone Id' ;
    rdfs:comment 'Foreign key linking to land.management_zone. Business justification: Sub-field grain traceability for identity-preserved and premium grain programs: commodity lots harvested from specific management zones (high/low productivity) are segregated and priced differently. A' ;
    rdfs:domain ind:CommodityLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementZone .

ind:researchVarietyId rdf:type rdf:Property ;
    rdfs:label 'Research Variety Id' ;
    rdfs:comment 'Foreign key linking to research.variety. Business justification: Seed/grain variety traceability: a commodity_lot of seed or harvested grain corresponds to a specific research variety. This FK enables variety performance tracking from inventory, IP protection compl' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Variety .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'The best-before date for this commodity lot, after which quality may degrade but the product may still be safe for consumption. Used for FEFO (First Expired First Out) rotation logic in WMS and for customer shipment eligibility checks. Distinct from expiration_date which represents a hard safety cutoff.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (COA) issued for this commodity lot by an accredited laboratory, documenting quality test results including moisture, protein, mycotoxins, pesticide residues, and heavy metals. Required for customer shipment documentation and regulatory compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'Number of days remaining until the lot\'s expiration_date as of the last inventory snapshot date. Used for FEFO prioritization alerts, customer minimum shelf-life requirement checks, and proactive disposition planning. Negative values indicate the lot is past expiration.' ;
    rdfs:domain ind:CommodityLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Prescribed disposition action for this commodity lot, particularly for lots in quarantine, hold, or expired status. Determined by quality management review in SAP QM. Drives downstream WMS and logistics workflows for lot resolution.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1Sscc rdf:type rdf:Property ;
    rdfs:label 'Gs1 Sscc' ;
    rdfs:comment '18-digit GS1 Serial Shipping Container Code assigned to the pallet or container carrying this commodity lot, enabling RFID and barcode scanning for pallet-level traceability from farm to table. Supports EDI and WMS integration with Manhattan Associates.' ;
    rdfs:domain ind:CommodityLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which this commodity lot was produced, processed, or packaged. For harvested commodities, this is the harvest date. For processed products (feed, flour, oil), this is the processing date. Used as the anchor date for shelf-life and expiration calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityBu rdf:type rdf:Property ;
    rdfs:label 'Quantity Bu' ;
    rdfs:comment 'Current on-hand quantity of the commodity lot expressed in bushels (BU), the standard US grain trade unit of measure. Used for grain elevator accounting, CBOT futures hedging, and WASDE supply reporting. One bushel equals 56 lbs for corn/sorghum, 60 lbs for wheat/soybeans.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCwt rdf:type rdf:Property ;
    rdfs:label 'Quantity Cwt' ;
    rdfs:comment 'Current on-hand quantity of the commodity lot expressed in hundredweight (CWT = 100 lbs), commonly used for livestock feed, cotton, and specialty crop pricing and billing. Supports SAP MM inventory valuation in CWT-denominated contracts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityMt rdf:type rdf:Property ;
    rdfs:label 'Quantity Mt' ;
    rdfs:comment 'Current on-hand quantity of the commodity lot expressed in metric tons (MT), the standard international trade unit. Used for export documentation, CIF/FOB contracts, and Codex Alimentarius reporting. Derived from BU quantity using commodity-specific conversion factors but stored for operational efficiency.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityBu rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Bu' ;
    rdfs:comment 'Original quantity of this commodity lot at the time of GRN receipt, expressed in bushels. Preserved as the immutable receipt quantity for shrinkage calculation, inventory reconciliation, and audit trail. Distinct from quantity_bu which reflects current on-hand quantity after consumption and adjustments.' ;
    rdfs:domain ind:CommodityLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkagePct rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Pct' ;
    rdfs:comment 'Percentage of quantity lost from this lot due to moisture evaporation, handling losses, or storage shrink since receipt. Calculated as (received_quantity - current_quantity) / received_quantity * 100. Used for inventory valuation adjustments, storage contract billing, and loss reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Type of storage facility where this commodity lot is currently held. Determines applicable storage conditions, monitoring requirements, and handling procedures. Cold storage lots require temperature and humidity monitoring per FDA FSMA Produce Safety Rule.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomPrimary rdf:type rdf:Property ;
    rdfs:label 'Uom Primary' ;
    rdfs:comment 'The primary unit of measure used for inventory management and reporting of this commodity lot (e.g., BU for grain, MT for export commodities, CWT for feed). Aligns with SAP MM base unit of measure configuration and Manhattan WMS UOM settings. [ENUM-REF-CANDIDATE: BU|MT|CWT|LB|KG|TON|BAG|UNIT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique surrogate identifier for each cycle count event record in the WMS-driven physical inventory count system.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:primaryCycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cycle Employee Id' ;
    rdfs:comment 'Reference to the workforce employee or contractor assigned to perform the physical count. Links to SAP SuccessFactors workforce record for accountability and audit.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCycleMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Cycle Material Master Id' ;
    rdfs:comment 'Reference to the material master record for the inventory item being counted (seed, chemical, fertilizer, or harvested commodity). Links to SAP MM material master.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:warehouseTaskId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Task Id' ;
    rdfs:comment 'Manhattan Associates WMS task identifier assigned to the cycle count activity. Used for WMS workflow tracking, labor management integration, and operational audit trail.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseTask .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the confirmed inventory variance from this cycle count has been posted as an inventory adjustment in SAP MM (MI07 Post Differences). True = adjustment posted; False = pending posting. Triggers downstream inventory_adjustment record creation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical inventory count was performed. Principal business event date for the cycle count, used for FIFO/FEFO rotation validation and inventory accuracy KPI reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'Externally-known WMS-generated document number uniquely identifying the cycle count event. Corresponds to the Manhattan Associates WMS count document and SAP MM physical inventory document number used for audit trail and reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Precise date and time when the physical count activity was completed at the bin/location level. Combined with count_start_timestamp to calculate count duration for labor and efficiency KPIs.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The method used to perform the physical count. Indicates whether the counter used manual tally, RF scanner, barcode scanning, RFID technology, or an automated counting system. Supports accuracy benchmarking by method.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countQty rdf:type rdf:Property ;
    rdfs:label 'Count Qty' ;
    rdfs:comment 'The actual physical quantity counted by the counter during the cycle count event. This is the raw observed quantity entered into the WMS or SAP MM physical inventory document.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Precise date and time when the physical count activity began at the bin/location level. Used for labor productivity analysis and WMS operational reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Tracks workflow progression from open through completion and approval in the WMS and SAP MM inventory management process.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event indicating whether it was a regularly scheduled count, an ad-hoc count, a recount triggered by variance, an annual physical inventory, or a system-triggered count. [ENUM-REF-CANDIDATE: scheduled|ad_hoc|recount|annual|triggered — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'GS1 Global Trade Item Number (GTIN-14) for the material being counted. Enables barcode scanning integration with Manhattan Associates WMS and supports GS1 traceability standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material being counted by agricultural input or output category. Supports domain-specific inventory accuracy reporting across seed, chemical, fertilizer, harvested commodity, and feed stock categories.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCountDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Original Count Document Number' ;
    rdfs:comment 'For recount records (recount_flag = True), the count document number of the original cycle count that triggered this recount. Enables audit trail linking between original count and recount events.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether this cycle count record is a recount triggered by an unacceptable variance on a prior count. True = recount; False = original count. Links to the original count via original_count_document_number.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPhysicalInventoryDoc rdf:type rdf:Property ;
    rdfs:label 'Sap Physical Inventory Doc' ;
    rdfs:comment 'SAP S/4HANA MM physical inventory document number (MI01) corresponding to this cycle count event. Provides the cross-system reference key for reconciliation between Manhattan Associates WMS and SAP MM.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCountDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Count Date' ;
    rdfs:comment 'The originally planned date for the cycle count as defined in the WMS cycle count schedule. Compared against count_date to measure schedule adherence and operational compliance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'SAP MM stock type category of the inventory being counted. Determines whether the stock is available for use (unrestricted), under quality hold (quality_inspection), blocked, or restricted. Critical for QM integration.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQty rdf:type rdf:Property ;
    rdfs:label 'System Qty' ;
    rdfs:comment 'The inventory quantity recorded in the WMS/SAP system at the time the cycle count was initiated, before the physical count result is entered. Represents the book inventory position used as the baseline for variance calculation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'The unit of measure in which system_qty, count_qty, and variance_qty are expressed. Agricultural inventory uses CWT (Hundredweight), BU (Bushel), and MT (Metric Ton) for commodities; other units for inputs. Aligns with SAP MM base UOM. [ENUM-REF-CANDIDATE: CWT|BU|MT|LB|KG|EA|GAL|TON — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The variance quantity expressed as a percentage of the system quantity ((variance_qty / system_qty) * 100). Key inventory accuracy KPI metric used to assess count quality and trigger recount thresholds.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQty rdf:type rdf:Property ;
    rdfs:label 'Variance Qty' ;
    rdfs:comment 'The difference between the physical count quantity and the system quantity (count_qty minus system_qty). A positive value indicates a surplus; a negative value indicates a shortage. Used to trigger inventory adjustment records.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceRootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Variance Root Cause Code' ;
    rdfs:comment 'Standardized root cause code assigned to explain the inventory variance (e.g., SHRINKAGE, MISCOUNT, MISPLACE, DAMAGE, THEFT, SYSTEM_ERROR, UNIT_CONVERSION). Used for root cause analysis and continuous improvement of inventory accuracy. [ENUM-REF-CANDIDATE: SHRINKAGE|MISCOUNT|MISPLACE|DAMAGE|THEFT|SYSTEM_ERROR|UNIT_CONVERSION|EXPIRY — promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceRootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Variance Root Cause Description' ;
    rdfs:comment 'Free-text narrative description providing additional detail on the root cause of the inventory variance. Supplements the variance_root_cause_code with counter observations and corrective action notes.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Variance Value Usd' ;
    rdfs:comment 'The financial value of the inventory variance in US dollars, calculated as variance_qty multiplied by the standard or moving average unit price. Used for financial impact assessment, P&L reporting, and COGS adjustment authorization.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Foreign key linking to sales.delivery_order. Business justification: Outbound logistics execution: a goods issue is the physical inventory deduction triggered by a delivery order in grain trading. This FK links WMS execution to the commercial delivery obligation, suppo' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryOrder .

ind:primaryGoodsMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Material Master Id' ;
    rdfs:comment 'Reference to the material master record for the item being issued (seed, fertilizer, chemical, feed, harvested commodity, etc.).' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:stockReservationId rdf:type rdf:Property ;
    rdfs:label 'Stock Reservation Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_reservation. Business justification: A goods_issue fulfills a stock_reservation in agricultural operations (e.g., issuing fertilizer against a field application reservation, or issuing grain against a sales order reservation). Adding sto' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockReservation .

ind:destinationReference rdf:type rdf:Property ;
    rdfs:label 'Destination Reference' ;
    rdfs:comment 'Business identifier of the destination entity receiving the goods: field ID, pen number, customer delivery address code, production order number, or cost center code. Provides operational traceability to the point of consumption or application.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the destination receiving the issued goods: agricultural field (for input application), livestock pen (for feed issuance), customer (for sales delivery), production order, cost center (internal consumption), project, or scrap. [ENUM-REF-CANDIDATE: field|pen|customer|production_order|cost_center|project|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle status of the goods issue document: draft (not yet posted), posted (inventory deducted), reversed (corrected via reversal document), cancelled, or pending_approval (awaiting authorization for restricted materials).' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'The actual date and time the goods issue was posted and inventory was physically withdrawn or applied. This is the principal business event timestamp used for FIFO/FEFO depletion sequencing and COGS recognition.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Human-readable description of the material being issued (e.g., \'Glyphosate 41% Herbicide\', \'Urea 46-0-0 Fertilizer\', \'Pioneer P1197AM Corn Seed\', \'Corn #2 Yellow Dent\').' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'Business-level classification of the goods issue purpose: shipment to customer, internal consumption, field application of agricultural inputs (seeds/NPK fertilizers/crop protection chemicals), livestock feed issuance, production order issue, quality sample, or inventory write-off. [ENUM-REF-CANDIDATE: shipment|consumption|field_application|feed_issuance|production|sample|write_off — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP MM movement type code governing the inventory transaction (e.g., 201=cost center consumption, 261=production order issue, 601=customer delivery, 281=project issue). Drives accounting entries and stock depletion logic.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'SAP Production Order number linked to this goods issue when materials are issued to a manufacturing or processing order (movement type 261). Supports production cost tracking and yield analysis.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'The quantity of material withdrawn from inventory in the primary unit of measure (UOM). This is the principal quantitative fact of the goods issue transaction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityIssuedMt rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued Mt' ;
    rdfs:comment 'Issued quantity normalized to Metric Tons (MT) for cross-commodity analytics, WASDE reporting alignment, and international trade compliance. Derived from quantity_issued and uom at ingestion.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Usd' ;
    rdfs:comment 'Total COGS value of the goods issue (quantity_issued × unit_cost_usd). Used for cost center allocation, production order costing, and financial period-end close. Stored as a raw transactional value, not a derived KPI.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Usd' ;
    rdfs:comment 'Standard or moving average cost per unit of measure at the time of goods issue, used for COGS valuation. Sourced from SAP material valuation (standard price or MAP).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTaskNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Task Number' ;
    rdfs:comment 'Manhattan Associates WMS task or transfer order number associated with this goods issue, enabling end-to-end warehouse operation traceability from pick task to inventory deduction.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Foreign key linking to supply.bill_of_lading. Business justification: The BOL is the primary document presented at receiving to initiate the GRN process. Linking goods_receipt to bill_of_lading enables three-way document match (PO + BOL + GRN), supports FSMA traceabilit' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Foreign key linking to procurement.delivery_schedule. Business justification: Confirming which scheduled delivery line was fulfilled by a GRN is a core procurement-to-inventory reconciliation process. Agriculture operations track on-time delivery performance and schedule adhere' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliverySchedule .

ind:inboundPlanId rdf:type rdf:Property ;
    rdfs:label 'Inbound Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_plan. Business justification: The goods receipt is the execution confirmation of an inbound plan. Linking GRN to inbound_plan enables receiving teams to close out planned inbound arrivals, track plan-vs-actual quantity variances, ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundPlan .

ind:receivingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Food safety audit trails and GAP/HACCP compliance require identifying which employee received and inspected each grain or input delivery. The receiving employee is a standard accountability field on G' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cropVariety rdf:type rdf:Property ;
    rdfs:label 'Crop Variety' ;
    rdfs:comment 'Specific crop variety or cultivar of the harvested commodity received (e.g., \'Pioneer P1197AM\', \'Asgrow AG36X6\'). Supports variety-level traceability, seed performance tracking, and GMO segregation requirements.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevatorTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Elevator Ticket Number' ;
    rdfs:comment 'Grain elevator scale ticket number issued at the point of harvest intake. Captures the official weight and grade determination at the elevator. Applicable to harvest receipt types only.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoFefoFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Flag' ;
    rdfs:comment 'Indicates the stock rotation method applied to this receipt for lot assignment and inventory consumption sequencing. FIFO is standard for grain commodities; FEFO is applied for seed, chemical, and fertilizer inputs with expiration dates.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDetermination rdf:type rdf:Property ;
    rdfs:label 'Grade Determination' ;
    rdfs:comment 'Official USDA grade assigned to the received commodity based on test weight, moisture, damage, and other grade factors per USDA GIPSA Official Grain Standards. Drives pricing, storage assignment, and end-use routing.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the received shipment in kilograms, including packaging and container weight. Used in conjunction with tare weight to calculate net commodity weight.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:migoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Migo Document Number' ;
    rdfs:comment 'SAP goods movement document number generated by the MIGO transaction upon posting the goods receipt. Used for financial posting reconciliation and audit trail back to SAP S/4HANA MM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moisturePct rdf:type rdf:Property ;
    rdfs:label 'Moisture Pct' ;
    rdfs:comment 'Moisture content of the received commodity expressed as a percentage, measured at intake. Critical for grain quality grading, shrinkage calculation, storage condition assignment, and USDA grade determination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for the received goods. Drives hold/release decisions for inventory posting. Integrates with SAP QM inspection lot workflow.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt record. Drives downstream inventory posting, quality inspection workflow, and lot assignment. Rejected receipts trigger return-to-vendor or disposition processes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was recorded in the system. Serves as the principal business event timestamp for audit, traceability, and WMS integration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the receipt event: purchase (supplier delivery against PO), harvest (field intake from crop operations), return (customer return), or transfer (inter-facility stock movement). Determines processing workflow and traceability requirements.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'GS1 Serial Shipping Container Code (SSCC) for shipment-level tracking of the received pallet or container. Enables end-to-end supply chain traceability from supplier to storage bin.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Weight of the empty container, truck, or packaging in kilograms. Subtracted from gross weight to determine net commodity weight at intake.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testWeightLbBu rdf:type rdf:Property ;
    rdfs:label 'Test Weight Lb Bu' ;
    rdfs:comment 'Test weight of the received grain commodity expressed in pounds per bushel (lb/bu). A key USDA grade factor indicating grain density and quality. Used for grade determination and pricing adjustments.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory adjustment transaction record in the Agriculture lakehouse Silver layer. Primary key for the inventory_adjustment data product.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Material Master Id' ;
    rdfs:comment 'Reference to the material master record for the commodity, seed, chemical, or fertilizer being adjusted. Aligns with SAP S/4HANA MM material master.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:adjustmentMaterialMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Material Material Master Id' ;
    rdfs:comment 'FK to inventory.material_master' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Foreign key linking to inventory.quarantine_hold. Business justification: A quarantine_hold resolution (disposition decision: destroy, rework, return) triggers an inventory_adjustment to reflect the quantity change. Adding quarantine_hold_id FK (nullable) to inventory_adjus' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuarantineHold .

ind:wasteEventId rdf:type rdf:Property ;
    rdfs:label 'Waste Event Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_event. Business justification: Inventory adjustments for spoilage, expired product disposal, and condemned grain generate regulated waste events requiring EPA waste manifests and GRI 306 reporting. Linking inventory_adjustment to w' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteEvent .

ind:adjustedQty rdf:type rdf:Property ;
    rdfs:label 'Adjusted Qty' ;
    rdfs:comment 'Inventory quantity after the adjustment has been applied. Expressed in the primary unit of measure (CWT, BU, or MT). Represents the corrected on-hand balance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the inventory adjustment record. Controls whether the adjustment has been approved, posted to the general ledger, or reversed.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the inventory adjustment event. Shrinkage covers moisture loss, drying shrink, handling loss, and storage deterioration. Cycle count variance corrects WMS discrepancies. Damage write-off records pest damage or physical loss. Quality downgrade reclassifies commodity grade. Reclassification moves stock between categories.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeCode rdf:type rdf:Property ;
    rdfs:label 'Cause Code' ;
    rdfs:comment 'Standardized root cause code identifying the reason for the inventory discrepancy or shrinkage event (e.g., MOIST-LOSS, PEST-DMG, PROC-ERR, CYCLE-VAR). Sourced from SAP MM cause code configuration. [ENUM-REF-CANDIDATE: promote to reference product with full cause code taxonomy]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action implemented to prevent recurrence of the inventory discrepancy or shrinkage event. Supports continuous improvement and GFSI/SQF audit requirements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Flag indicating whether this adjustment record is a reversal of a previously posted adjustment. True when the record cancels a prior adjustment document. Supports audit trail integrity.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP S/4HANA MM movement type code governing the inventory posting (e.g., 551 for scrapping, 701 for physical inventory difference, 344 for transfer posting). Determines the accounting impact and stock category affected.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalQty rdf:type rdf:Property ;
    rdfs:label 'Original Qty' ;
    rdfs:comment 'Inventory quantity recorded before the adjustment event was applied. Expressed in the primary unit of measure (CWT, BU, or MT). Baseline for variance calculation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Business reason code for the inventory adjustment as defined in SAP S/4HANA MM configuration (e.g., physical inventory difference, goods issue correction, quality rejection). Distinct from cause_code which identifies root cause; reason_code identifies the business justification category.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative description of the specific reason for the inventory adjustment. Provides context beyond the structured reason_code for audit trail and corrective action documentation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Adjustment document number of the original posting that this record reverses. Populated only when is_reversal is True. Enables bidirectional audit trail linkage between original and reversal documents.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageEventDate rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Event Date' ;
    rdfs:comment 'Calendar date on which the shrinkage event (moisture loss, pest damage, storage deterioration) physically occurred. May differ from the adjustment posting date. Critical for seasonal shrinkage trend analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shrinkageType rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Type' ;
    rdfs:comment 'Specific category of shrinkage event when adjustment_type is shrinkage. Distinguishes moisture loss during drying, physical handling loss, storage deterioration over time, pest damage, or quality-driven downgrade. [ENUM-REF-CANDIDATE: moisture_loss|drying_shrink|handling_loss|storage_deterioration|pest_damage|quality_downgrade|other — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTypeAfter rdf:type rdf:Property ;
    rdfs:label 'Stock Type After' ;
    rdfs:comment 'SAP stock category of the inventory after the adjustment has been applied. Used for reclassification adjustments to confirm the target stock category.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTypeBefore rdf:type rdf:Property ;
    rdfs:label 'Stock Type Before' ;
    rdfs:comment 'SAP stock category of the inventory before the adjustment was applied. Relevant for reclassification adjustments that move stock between unrestricted, quality inspection, blocked, or restricted categories.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Value Impact Usd' ;
    rdfs:comment 'Estimated financial impact of the inventory adjustment in US Dollars (variance_qty multiplied by unit_cost_usd). Represents the COGS charge or inventory write-down posted to the general ledger. Negative values indicate inventory value reduction.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Id' ;
    rdfs:comment 'Foreign key linking to sustainability.emission_factor. Business justification: Each agricultural input material (nitrogen fertilizer, diesel, agrochemical) has a specific GHG emission factor (IPCC tier 1/2) used for scope 1 and scope 3 category 1 calculations. Linking material_m' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionFactor .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'The primary unit of measure (UOM) in which the material is managed in inventory (SAP MEINS). Agricultural materials use industry-standard units: BU (Bushel), CWT (Hundredweight), MT (Metric Ton), KG (Kilogram), GAL (Gallon). Drives quantity calculations across procurement, WMS, and sales. [ENUM-REF-CANDIDATE: BU|CWT|MT|KG|LB|L|GAL|EA|BAG|TON — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityClass rdf:type rdf:Property ;
    rdfs:label 'Commodity Class' ;
    rdfs:comment 'Agricultural commodity classification code aligned with USDA and CME Group commodity designations (e.g., \'CORN\', \'SOYBEAN\', \'WHEAT\', \'COTTON\', \'ANHYDROUS_AMMONIA\'). Used for WASDE reporting, market price linkage, and supply chain analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoFefoIndicator rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Indicator' ;
    rdfs:comment 'Inventory rotation strategy applied to this material in WMS (Manhattan Associates). FIFO (First In First Out) for commodities without expiry; FEFO (First Expired First Out) for perishables, seeds, and chemicals with shelf life. Drives pick sequencing and stock rotation compliance.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'DOT/IATA hazardous materials classification code for transport and storage compliance. Drives storage segregation rules in WMS, TMS routing restrictions, and BOL documentation. Examples: Class 3 (flammable liquids), Class 6 (toxic substances). \'non_hazmat\' for non-regulated materials. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|8|9|non_hazmat — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the material master record in SAP (MMSTA / MSTAE). Controls whether the material can be procured, used in production, or sold. \'blocked\' prevents new transactions; \'discontinued\' signals end-of-life for inventory drawdown.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Lot Management Indicator' ;
    rdfs:comment 'Indicates whether this material is managed at the lot/batch level (SAP XCHPF). True = batch-managed (LOT/GRN tracking required for traceability). Critical for FSMA traceability, HACCP lot recall capability, and FEFO rotation in WMS. Seeds, chemicals, and harvested commodities are typically batch-managed.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group code (MATKL) used to classify materials for procurement, reporting, and spend analytics. Examples: \'SEED-CORN\', \'FERT-NPK\', \'CHEM-HERB\'. Enables category management and supplier segmentation.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable short description or name of the material (e.g., \'Urea 46-0-0 Fertilizer\', \'Glyphosate 41% Herbicide\', \'Yellow Corn #2\'). Corresponds to SAP MAKTX (material description). Used in inventory reports, purchase orders, and warehouse labels.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npkNitrogenPct rdf:type rdf:Property ;
    rdfs:label 'Npk Nitrogen Pct' ;
    rdfs:comment 'Nitrogen (N) content percentage in fertilizer materials, expressed as percentage by weight. Part of the NPK (Nitrogen-Phosphorus-Potassium) nutrient analysis required for fertilizer labeling compliance and agronomic application rate calculations. Null for non-fertilizer materials.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkPhosphorusPct rdf:type rdf:Property ;
    rdfs:label 'Npk Phosphorus Pct' ;
    rdfs:comment 'Phosphorus (P2O5) content percentage in fertilizer materials, expressed as percentage by weight. Part of the NPK nutrient analysis required for fertilizer labeling and variable rate application (VRA) prescription planning. Null for non-fertilizer materials.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkPotassiumPct rdf:type rdf:Property ;
    rdfs:label 'Npk Potassium Pct' ;
    rdfs:comment 'Potassium (K2O) content percentage in fertilizer materials, expressed as percentage by weight. Part of the NPK nutrient analysis required for fertilizer labeling and soil management planning. Null for non-fertilizer materials.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pluCode rdf:type rdf:Property ;
    rdfs:label 'Plu Code' ;
    rdfs:comment 'IFPS Price Look-Up (PLU) code assigned to fresh produce and bulk agricultural commodities for retail checkout identification. Distinguishes conventional, organic, and GMO produce at point of sale.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard price (e.g., \'USD\', \'EUR\', \'BRL\'). Required for multi-currency operations in international agricultural trade and IFRS financial reporting.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'SAP procurement type (BESKZ) indicating whether the material is externally procured, produced in-house, or both. Drives MRP (Material Requirements Planning) logic in SAP PP and purchasing strategy in SAP MM.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'The unique material number assigned in SAP S/4HANA MM module (MATNR field). Serves as the primary business identifier linking this record to the operational ERP system. Used for procurement, inventory management, and production planning transactions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReference rdf:type rdf:Property ;
    rdfs:label 'Sds Reference' ;
    rdfs:comment 'Document reference number or URL for the Safety Data Sheet (SDS) associated with hazardous materials (chemicals, fertilizers). Required under OSHA Hazard Communication Standard (HazCom) 29 CFR 1910.1200 and GHS. Enables worker safety compliance and emergency response.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal Stock Keeping Unit (SKU) code used in warehouse management and inventory control systems (Manhattan Associates WMS). Unique identifier for a specific material-packaging-size combination within the distribution network.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssccPrefix rdf:type rdf:Property ;
    rdfs:label 'Sscc Prefix' ;
    rdfs:comment 'GS1 company prefix used to generate Serial Shipping Container Codes (SSCC-18) for pallet and container tracking of this material. Enables RFID-based pallet tracking and ASN (Advance Ship Notice) generation in WMS and TMS.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard or moving average price per base unit of measure for inventory valuation in SAP MM (STPRS/VERPR). Used for COGS calculation, purchase price variance (PPV) analysis, and financial reporting under IFRS IAS 2 and GAAP ASC 330. Classified confidential as it reflects internal cost strategy.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for storage of this material. Critical for grain storage (prevents mold/mycotoxin development), seed viability, and chemical stability. Used in grain bin and warehouse environmental monitoring via IoT sensors.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this material. Used alongside minimum temperature to define the acceptable storage temperature range for WMS slot assignment, cold chain compliance, and HACCP CCP monitoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this material. Drives cold storage assignment in WMS, temperature monitoring alerts via IoT sensors, and HACCP critical control point (CCP) compliance for food safety. Critical for seeds, biologicals, and perishable commodities.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringFrostAlertId rdf:type rdf:Property ;
    rdfs:label 'Triggering Frost Alert Id' ;
    rdfs:comment 'Foreign key linking to weather.frost_alert. Business justification: Frost alerts trigger quarantine holds on frost-damaged harvested grain — a named food safety and quality process. The quarantine_hold has untyped initiating_event_reference; a typed FK to frost_alert ' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrostAlert .

ind:triggeringPrecipitationEventId rdf:type rdf:Property ;
    rdfs:label 'Triggering Precipitation Event Id' ;
    rdfs:comment 'Foreign key linking to weather.precipitation_event. Business justification: Hail and flood precipitation events trigger quarantine holds on commodity lots (hail-damaged grain, flood-contaminated storage). This typed FK supports insurance claim documentation and FSMA food safe' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrecipitationEvent .

ind:triggeringWeatherAlertId rdf:type rdf:Property ;
    rdfs:label 'Triggering Weather Alert Id' ;
    rdfs:comment 'Foreign key linking to weather.weather_alert. Business justification: Severe weather alerts (tornado, flood, extreme heat) trigger quarantine holds on inventory at affected storage locations. Typed FK to weather_alert supports \'weather-triggered quarantine\' traceability' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The actual calendar date on which the quarantine hold was resolved and the inventory was either released for use, reworked, destroyed, or returned. Null until disposition is executed.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision made by the quality or regulatory authority for the quarantined inventory. Release: cleared for normal use; Rework: requires reprocessing before use; Destroy: condemned and disposed; Return: returned to supplier; Donate: donated to approved channel; Regrade: reclassified to lower grade.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text narrative documenting the rationale for the disposition decision, corrective actions taken, and any conditions attached to the release or destruction of the quarantined inventory.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Anticipated date by which the quarantine hold investigation is expected to be completed and the inventory released or dispositioned. Used for supply chain continuity planning and customer commitment management.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the quarantine hold record. Used in SAP QM usage decisions, WMS hold tags, and regulatory correspondence. Format: QH-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'The calendar date on which the quarantine hold was officially initiated and the inventory was blocked in SAP QM and WMS. Principal business event date for the hold lifecycle.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the quarantine hold record. Drives SAP QM usage decision workflow and WMS inventory blocking. Open: hold initiated; Under_review: quality/regulatory investigation in progress; Pending_disposition: investigation complete, awaiting disposition approval; Released: stock cleared for use; Closed: disposition executed; Escalated: elevated to regulatory authority.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'SAP user ID or employee identifier of the person who initiated the quarantine hold. Required for audit trail, SOX compliance, and regulatory investigation documentation.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingEventReference rdf:type rdf:Property ;
    rdfs:label 'Initiating Event Reference' ;
    rdfs:comment 'External reference number of the document or event that triggered the hold, such as a COA (Certificate of Analysis) number, HACCP deviation report number, EU RASFF notification number, FDA recall number, or internal audit finding ID.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingEventType rdf:type rdf:Property ;
    rdfs:label 'Initiating Event Type' ;
    rdfs:comment 'Categorical classification of the specific triggering event that caused the quarantine hold to be raised. Supports root cause analysis and regulatory reporting. [ENUM-REF-CANDIDATE: coa_failure|haccp_deviation|mrl_exceedance|foreign_material|microbiological|allergen|labeling|supplier_notification|regulatory_alert|customer_complaint|internal_audit — promote to reference product]' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecallRelated rdf:type rdf:Property ;
    rdfs:label 'Is Recall Related' ;
    rdfs:comment 'Indicates whether this quarantine hold is associated with a formal product recall (voluntary or mandatory). True triggers recall response procedures per FDA FSMA and USDA FSIS recall protocols.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlDetectedLevel rdf:type rdf:Property ;
    rdfs:label 'Mrl Detected Level' ;
    rdfs:comment 'Measured concentration of the residue substance detected in the sample, expressed in mg/kg (ppm). Compared against the applicable MRL threshold to determine exceedance. Null if hold is not MRL-related.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrlExceedanceSubstance rdf:type rdf:Property ;
    rdfs:label 'Mrl Exceedance Substance' ;
    rdfs:comment 'Name of the pesticide active ingredient (AI) or chemical substance that exceeded the Maximum Residue Limit (MRL) as defined by EPA or EU Regulation 396/2005, triggering the quarantine hold. Null if hold is not MRL-related.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDaysRemaining rdf:type rdf:Property ;
    rdfs:label 'Phi Days Remaining' ;
    rdfs:comment 'Number of days remaining in the Pre-Harvest Interval (PHI) at the time the hold was initiated. A positive value indicates the crop was harvested before the PHI elapsed, which may be the root cause of an MRL exceedance hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyOnHoldBu rdf:type rdf:Property ;
    rdfs:label 'Qty On Hold Bu' ;
    rdfs:comment 'Quantity of inventory placed under quarantine hold expressed in bushels (BU). Standard unit for grain commodities (corn, soybeans, wheat) in US agricultural trade and USDA WASDE reporting.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHoldCwt rdf:type rdf:Property ;
    rdfs:label 'Qty On Hold Cwt' ;
    rdfs:comment 'Quantity of inventory placed under quarantine hold expressed in hundredweight (CWT). Primary unit for grain and commodity inventory valuation and trading in US agricultural markets.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHoldMt rdf:type rdf:Property ;
    rdfs:label 'Qty On Hold Mt' ;
    rdfs:comment 'Quantity of inventory placed under quarantine hold expressed in metric tons (MT). Required for international trade documentation, EU regulatory reporting, and Codex Alimentarius compliance.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory authority (FDA recall number, USDA FSIS case number, EU RASFF notification number, EPA enforcement action number) for tracking the regulatory response to this hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this quarantine hold. Links the hold to the formal quality inspection process and usage decision workflow in SAP S/4HANA QM module.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmUsageDecision rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Usage Decision' ;
    rdfs:comment 'SAP QM usage decision code recorded at inspection lot closure. A=Accept (release to unrestricted stock), R=Reject (block/destroy), B=Return to vendor, S=Sort/rework. Drives automatic stock transfer posting in SAP MM.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsHoldTagNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Hold Tag Number' ;
    rdfs:comment 'Physical hold tag or WMS blocking record number assigned by Manhattan Associates WMS to identify and segregate the quarantined inventory in the warehouse or storage facility.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reorder Policy Id' ;
    rdfs:comment 'Unique surrogate identifier for the reorder policy configuration record. Primary key for this master configuration entity in the inventory domain.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReorderMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Reorder Material Master Id' ;
    rdfs:comment 'Reference to the inventory-managed material (seed, chemical, fertilizer, feed, or harvested commodity) for which this reorder policy applies.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:reorderMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Reorder Material Master Id' ;
    rdfs:comment 'FK to inventory.material_master' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Reorder policies for seeds, agrochemicals, and feed are owned by a specific buyer or inventory planner. Procurement and inventory management processes require identifying the responsible employee for ' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supplier Assessment Id' ;
    rdfs:comment 'Foreign key linking to quality.supplier_assessment. Business justification: Reorder policies in agriculture are quality-gated — suppliers with poor assessment scores require manual PO approval or reduced auto-replenishment. Linking reorder_policy to supplier_assessment enable' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAssessment .

ind:autoPoCreation rdf:type rdf:Property ;
    rdfs:label 'Auto Po Creation' ;
    rdfs:comment 'Indicates whether MRP-generated purchase requisitions for this material are automatically converted to purchase orders without manual buyer approval. Requires a valid source list and preferred supplier.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerGroup rdf:type rdf:Property ;
    rdfs:label 'Buyer Group' ;
    rdfs:comment 'SAP MM purchasing group (buyer group) responsible for processing purchase requisitions generated by this reorder policy. Determines routing and approval workflow for procurement.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoq rdf:type rdf:Property ;
    rdfs:label 'Eoq' ;
    rdfs:comment 'Optimal replenishment order quantity calculated to minimize total inventory holding and ordering costs. Expressed in primary UOM. Used as the fixed lot size in SAP MM MRP lot-sizing procedures.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Days' ;
    rdfs:comment 'Number of workdays required to process a goods receipt (GRN) after physical delivery, including quality inspection, weighing, and WMS putaway. Added to lead time in MRP net requirements calculation.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this material is classified as hazardous (e.g., pesticides, herbicides, fumigants). When true, EPA SDS requirements, REI (Restricted Entry Interval), and special storage/handling rules apply.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrpActive rdf:type rdf:Property ;
    rdfs:label 'Is Mrp Active' ;
    rdfs:comment 'Indicates whether this reorder policy is currently included in SAP MM MRP planning runs. When false, the policy exists as a configuration record but does not trigger automated purchase requisitions.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Regulated Substance' ;
    rdfs:comment 'Indicates whether this material is subject to regulatory quantity limits, licensing, or reporting requirements (e.g., restricted-use pesticides under EPA, controlled fertilizers under APHIS). Triggers compliance workflow on purchase requisition.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this material experiences significant seasonal demand fluctuations (e.g., planting season seeds, harvest-time chemicals). When true, seasonal demand profiles are applied in MRP planning.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'SAP MM MRP lot-sizing procedure that determines how replenishment quantities are calculated: fixed order quantity, lot-for-lot (exact requirement), EOQ, period-based, or min-max. Maps to SAP Lot Size field.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Qty' ;
    rdfs:comment 'Maximum quantity allowed per single purchase requisition to control procurement spend, storage capacity, and perishability risk. Expressed in primary UOM.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockQty rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Qty' ;
    rdfs:comment 'Upper bound on inventory quantity for this material at this storage location. Replenishment orders will not exceed this level. Prevents overstocking and storage capacity violations.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'Minimum quantity that must be ordered per purchase requisition, typically driven by supplier minimum order requirements or packaging constraints. Expressed in primary UOM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at time of goods receipt for the material to be accepted into stock. Rejects deliveries that do not meet this threshold per quality management policy.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'SAP MRP planning type that governs how replenishment is triggered: reorder point (ROP), time-phased planning, consumption-based, or manual. Directly maps to SAP MM MRP Type field (e.g., VB, VM, PD).' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultipleQty rdf:type rdf:Property ;
    rdfs:label 'Order Multiple Qty' ;
    rdfs:comment 'Quantity increment by which replenishment orders must be rounded up (e.g., full pallet, full bin, full truckload). Ensures orders align with supplier packaging or transport unit constraints.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonEndMonth rdf:type rdf:Property ;
    rdfs:label 'Peak Season End Month' ;
    rdfs:comment 'Calendar month (1–12) when peak seasonal demand ends for this material. Defines the seasonal window during which elevated reorder points and safety stock levels are applied.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakSeasonSafetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Peak Season Safety Stock Qty' ;
    rdfs:comment 'Elevated safety stock quantity applied during the defined peak season window (e.g., planting or harvest period). Overrides the standard safety stock quantity during peak months.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonStartMonth rdf:type rdf:Property ;
    rdfs:label 'Peak Season Start Month' ;
    rdfs:comment 'Calendar month (1–12) when peak seasonal demand begins for this material. Used to adjust reorder points and safety stock levels ahead of high-demand periods such as planting or harvest seasons.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this reorder policy record, used in SAP MM MRP planning runs and cross-system references.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the reorder policy configuration. Only active policies are evaluated during SAP MM MRP planning runs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'SAP purchasing organization responsible for negotiating and executing supply contracts for this material. Defines the legal and organizational entity that issues purchase orders.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Stock level threshold at which a purchase requisition is automatically triggered in SAP MM MRP. Expressed in the primary unit of measure (CWT, BU, or MT). When on-hand quantity falls to or below this value, replenishment is initiated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer stock quantity maintained to protect against demand variability and supply lead time uncertainty. Expressed in primary UOM. Corresponds to SAP MM Safety Stock field in MRP 2 view.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage environment for this material. Drives assignment to compatible storage locations (e.g., cold storage for perishables, hazmat-certified bins for chemicals). [ENUM-REF-CANDIDATE: ambient|refrigerated|frozen|controlled_atmosphere|dry|hazmat — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Material Master Id' ;
    rdfs:comment 'Reference to the material master record representing the agricultural commodity, seed, chemical, or fertilizer held in this stock position. Aligns with SAP S/4HANA MM material master.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:stockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Stock Material Master Id' ;
    rdfs:comment 'FK to inventory.material_master' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Date the material was received into inventory at the storage location (GRN posting date). Used for FIFO rotation sequencing, aging analysis, and inbound supply chain performance reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory movement (goods receipt, goods issue, transfer, or adjustment) recorded against this stock position. Used for slow-moving and obsolete inventory identification.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceVarianceUsd rdf:type rdf:Property ;
    rdfs:label 'Price Variance Usd' ;
    rdfs:comment 'Variance between the standard cost and actual purchase price for this stock position in USD. Captured at period-end for GAAP/IFRS inventory valuation adjustments and commodity price risk reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyAvailable rdf:type rdf:Property ;
    rdfs:label 'Qty Available' ;
    rdfs:comment 'Available-to-promise (ATP) quantity calculated as on-hand quantity minus reserved quantity in the primary unit of measure. Represents the uncommitted inventory available for new sales orders or production requirements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyBlocked rdf:type rdf:Property ;
    rdfs:label 'Qty Blocked' ;
    rdfs:comment 'Quantity of the material in blocked stock status (not available for use) in the primary unit of measure. Includes recalled, quarantined, or damaged inventory pending disposition decision.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Qty In Quality Inspection' ;
    rdfs:comment 'Quantity of the material currently held in quality inspection stock pending QM release in the primary unit of measure. Supports HACCP, FSMA, and GLOBALG.A.P. quality hold management.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHand rdf:type rdf:Property ;
    rdfs:label 'Qty On Hand' ;
    rdfs:comment 'Total physical quantity of the material currently on hand at the storage location in the primary unit of measure (CWT, BU, or MT). Represents the gross inventory position before reservations or holds.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReserved rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved' ;
    rdfs:comment 'Quantity of the material reserved against open sales orders, production orders, or transfer orders in the primary unit of measure. Reduces available-to-promise (ATP) quantity for new commitments.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyShrinkage rdf:type rdf:Property ;
    rdfs:label 'Qty Shrinkage' ;
    rdfs:comment 'Cumulative quantity lost to shrinkage (moisture loss, spoilage, handling losses) recorded against this stock position in the primary unit of measure. Used for shrinkage analysis, COGS adjustment, and post-harvest handling performance reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAccountingDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Accounting Doc Number' ;
    rdfs:comment 'SAP FI accounting document number (BELNR) generated for the inventory valuation posting associated with this stock position. Provides the audit trail reference for GAAP/IFRS financial reporting and SOX compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Active indicates normal inventory; expired indicates stock past its shelf life or PHI; recalled indicates a regulatory or quality recall event; quarantined indicates hold pending investigation; disposed indicates stock written off.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Value Usd' ;
    rdfs:comment 'Total book value of this stock position in US dollars (USD), calculated as on-hand quantity multiplied by unit price. Used for balance sheet inventory reporting, period-end valuation snapshots, and GAAP/IFRS financial reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Price Usd' ;
    rdfs:comment 'Inventory valuation price per primary unit of measure in US dollars (USD). For standard cost materials, this is the standard price; for moving average materials, this is the current moving average price. Used for period-end inventory valuation and COGS calculation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date as of which the inventory valuation snapshot was captured for this stock position. Used for period-end financial reporting, GAAP/IFRS inventory valuation, and commodity position reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wmsPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Position Number' ;
    rdfs:comment 'Manhattan Associates WMS internal position or license plate number for this stock position. Used for WMS-to-SAP reconciliation, cycle count management, and real-time inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Agronomists and planners create stock reservations for seed, fertilizer, and pesticide for specific field operations. Tracking the requesting employee is required for operational accountability, budge' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:isBackflush rdf:type rdf:Property ;
    rdfs:label 'Is Backflush' ;
    rdfs:comment 'Indicates whether the goods issue against this reservation will be processed via backflushing (automatic goods issue at production order confirmation) rather than manual withdrawal. Relevant for SAP PP integration.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinalIssue rdf:type rdf:Property ;
    rdfs:label 'Is Final Issue' ;
    rdfs:comment 'Indicates whether this reservation has been marked as final issue in SAP (no further goods issues expected). When True, the reservation is closed to further withdrawals even if open quantity remains.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Material Expiration Date' ;
    rdfs:comment 'Shelf-life expiration date of the reserved lot/batch. Critical for FEFO rotation, PHI (Pre-Harvest Interval) compliance, and food safety (FSMA, HACCP). Distinct from the reservation\'s own expiry date.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingOrderType rdf:type rdf:Property ;
    rdfs:label 'Originating Order Type' ;
    rdfs:comment 'Discriminator identifying the type of source document that created this reservation, enabling correct navigation to the originating system record (SAP PP, SD, MM, or FMIS).' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qtyFulfilled rdf:type rdf:Property ;
    rdfs:label 'Qty Fulfilled' ;
    rdfs:comment 'Quantity of the reservation that has already been withdrawn/consumed against this reservation. Enables partial fulfillment tracking and open-quantity calculation.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReservedBu rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved Bu' ;
    rdfs:comment 'Reserved quantity converted to Bushels (BU) for grain commodity reporting and USDA/WASDE alignment. Null for non-grain materials.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReservedMt rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved Mt' ;
    rdfs:comment 'Reserved quantity converted to Metric Tons (MT) for international trade, export documentation, and CIF/FOB contract compliance.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'The date by which the reserved stock must be available for consumption or shipment. Drives MRP planning in SAP S/4HANA and supply chain scheduling.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Date' ;
    rdfs:comment 'The principal business event timestamp — the date and time when the stock reservation was created and the stock was earmarked. Distinct from the audit created_timestamp.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-known, human-readable reservation document number generated by SAP S/4HANA MM (e.g., RES-0000123456). Used for cross-system reference and supply chain communication.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the stock reservation. \'open\' — earmarked but not yet consumed; \'partially_fulfilled\' — some quantity withdrawn; \'fulfilled\' — fully consumed; \'cancelled\' — voided before use; \'expired\' — requirement date passed without fulfillment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the business purpose driving the reservation. \'production\' — for a manufacturing/processing order; \'sales\' — earmarked for a Sales Order (SO); \'transfer\' — stock transfer between locations; \'field_application\' — reserved for crop input application (fertilizer, chemical); \'quality_hold\' — held for QM inspection; \'return\' — reserved for return processing. [ENUM-REF-CANDIDATE: production|sales|transfer|field_application|quality_hold|return — promote to reference product]' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReservationDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Reservation Doc Number' ;
    rdfs:comment 'The internal SAP document number for the reservation record (10-digit numeric string from MB21). Provides the authoritative source-system reference for reconciliation with SAP S/4HANA MM.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock category for the reserved material. \'E\' — sales order stock; \'Q\' — project stock; \'K\' — consignment stock at customer; \'W\' — consignment stock at vendor; blank — standard own stock.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsReservationReference rdf:type rdf:Property ;
    rdfs:label 'Wms Reservation Reference' ;
    rdfs:comment 'Corresponding reservation or allocation reference number in Manhattan Associates WMS. Enables reconciliation between SAP MM reservations and WMS-level stock allocations.' ;
    rdfs:domain ind:StockReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock transfer record in the inventory domain. Primary key for the stock_transfer data product.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransfer .

ind:initiatingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiating Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Grain and input stock transfers between bins or facilities require an accountable employee for authorization and audit. Inventory control reports and internal audit processes in agriculture operations' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceBinLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Bin Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.bin_location. Business justification: stock_transfer has source_storage_bin (STRING) as a denormalized WMS bin reference for the originating bin. Adding source_bin_location_id FK links to the bin_location master for granular WMS bin-level' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinLocation .

ind:sourceStockPositionId rdf:type rdf:Property ;
    rdfs:label 'Source Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: A stock_transfer reduces the source stock_position. Adding source_stock_position_id FK (nullable, populated at transfer initiation) links the transfer to the originating inventory position, enabling s' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: stock_transfer has source_storage_location (STRING) and source_plant (STRING) as denormalized references to the originating storage location. Adding source_storage_location_id FK normalizes this to th' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:destinationPlant rdf:type rdf:Property ;
    rdfs:label 'Destination Plant' ;
    rdfs:comment 'SAP plant code representing the receiving facility, farm site, or processing location to which the stock is being transferred. Required for plant-to-plant stock transport order processing in SAP MM.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageBin rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Bin' ;
    rdfs:comment 'WMS-level bin identifier within the destination storage location where the material will be physically placed. Supports directed putaway logic in Manhattan Associates WMS.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'SAP storage location code identifying the target warehouse, grain bin, cold storage unit, or field stockpile area to which inventory is being moved.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransitDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Days' ;
    rdfs:comment 'Expected number of days for the material to travel from source to destination facility. Used for in-transit inventory planning, supply chain continuity, and carrier performance benchmarking.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when the goods issue was posted in SAP S/4HANA MM, recording the moment inventory was decremented from the source location. Critical for real-time inventory accuracy and audit trails.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Timestamp' ;
    rdfs:comment 'Precise timestamp when the goods receipt was posted at the destination location in SAP S/4HANA MM or confirmed in Manhattan Associates WMS. Marks the completion of the transfer and inventory increment at destination.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isInterCompany rdf:type rdf:Property ;
    rdfs:label 'Is Inter Company' ;
    rdfs:comment 'Indicates whether this stock transfer crosses legal entity or company code boundaries, triggering inter-company billing and financial settlement processes in SAP FI/CO. True for transfers between separate legal entities; False for intra-company movements.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qtyTransferred rdf:type rdf:Property ;
    rdfs:label 'Qty Transferred' ;
    rdfs:comment 'The quantity of material being transferred, expressed in the primary unit of measure (UOM). This is the principal quantitative fact of the transfer transaction.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyTransferredMt rdf:type rdf:Property ;
    rdfs:label 'Qty Transferred Mt' ;
    rdfs:comment 'Transferred quantity normalized to Metric Tons (MT) for cross-commodity comparison, international reporting, and WASDE-aligned analytics. Derived from qty_transferred and uom at ingestion time.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether a quality inspection (QM inspection lot) must be completed upon goods receipt at the destination before the transferred stock is released to unrestricted use. Supports HACCP and food safety compliance.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapMovementType rdf:type rdf:Property ;
    rdfs:label 'Sap Movement Type' ;
    rdfs:comment 'SAP S/4HANA MM movement type code governing the inventory posting logic for this transfer (e.g., 311 for storage location transfer, 641 for STO goods issue, 101 for goods receipt). Determines accounting entries and stock update behavior.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStoNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sto Number' ;
    rdfs:comment 'SAP S/4HANA MM stock transport order document number associated with this inter-plant or inter-facility transfer. Enables reconciliation with SAP financial and materials management postings.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The principal business event date on which the stock transfer was initiated or the goods issue was posted in SAP MM. Used for FIFO/FEFO rotation validation, aging analysis, and supply chain reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-known business identifier for the stock transfer, sourced from SAP MM stock transport order (STO) number or Manhattan Associates WMS transfer order number. Used for cross-system traceability and operational communication.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriority rdf:type rdf:Property ;
    rdfs:label 'Transfer Priority' ;
    rdfs:comment 'Operational priority level assigned to the transfer, used by WMS and logistics teams to sequence execution. Critical transfers may relate to expiring lots, quality holds, or supply chain emergencies.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business justification for initiating the stock transfer, such as stock rebalancing, FIFO/FEFO rotation enforcement, quality hold relocation, consolidation, replenishment, or pre-shipment staging. Supports audit and operational reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer workflow. Tracks progression from initiation through execution to completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending|in_transit|completed|cancelled|on_hold — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the stock movement scope: bin-to-bin (within same warehouse), storage location transfer (within same plant), warehouse transfer (between warehouses at same site), plant-to-plant (inter-facility), or cross-dock. Drives routing logic and documentation requirements. [ENUM-REF-CANDIDATE: bin_to_bin|plant_to_plant|warehouse_transfer|storage_location_transfer|cross_dock|field_to_bin — promote to reference product]' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsTransferOrderReference rdf:type rdf:Property ;
    rdfs:label 'Wms Transfer Order Reference' ;
    rdfs:comment 'Reference number assigned by Manhattan Associates WMS for the warehouse-level transfer order. Links the inventory movement to the WMS execution layer for bin-to-bin and warehouse transfer operations.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the storage facility. Used for logistics, carrier routing, regulatory filings, and emergency services. Classified as confidential organizational address data.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for WMS-driven physical inventory cycle counts at this storage location. Determines how often inventory accuracy is verified against system records to support FIFO/FEFO compliance and shrinkage detection.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoFefoMethod rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Method' ;
    rdfs:comment 'Inventory rotation method enforced for this storage location. FIFO (First-In-First-Out) is standard for grain; FEFO (First-Expired-First-Out) is required for perishables and chemicals with Pre-Harvest Interval (PHI) constraints. Drives WMS pick sequencing.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertification rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification' ;
    rdfs:comment 'Primary food safety certification standard held by this storage facility (e.g., Safe Quality Food (SQF), British Retail Consortium (BRC), International Featured Standards (IFS), ISO 22000, HACCP). Drives customer eligibility and audit requirements. [ENUM-REF-CANDIDATE: SQF|BRC|IFS|GLOBALG.A.P.|ISO22000|HACCP|none — promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoSegregationRequired rdf:type rdf:Property ;
    rdfs:label 'Gmo Segregation Required' ;
    rdfs:comment 'Indicates whether this storage location is designated for Genetically Modified Organism (GMO)-segregated storage, requiring physical separation from non-GMO commodities. True = GMO segregation enforced; False = no segregation requirement.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityControlled rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled' ;
    rdfs:comment 'Indicates whether this storage location has active humidity control systems. True = humidity-controlled; False = ambient humidity. Critical for seed storage, dried commodities, and chemical storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum relative humidity level (%) designed or required for this storage location. Exceeding this threshold triggers alerts for potential spoilage, mycotoxin risk, or chemical degradation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum relative humidity level (%) designed or required for this storage location. Controls moisture conditions to prevent commodity degradation, mold growth, and seed viability loss.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory regulatory or food safety inspection at this storage location. Drives compliance calendar management and proactive audit preparation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'Four-character SAP S/4HANA MM storage location code (Lagerort) that uniquely identifies this location within a SAP plant. Used for inventory postings, Goods Receipt Note (GRN) processing, and material movements in SAP.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this storage location has active temperature control systems (refrigeration, heating, or climate control). True = temperature-controlled environment; False = ambient/uncontrolled temperature.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usdaLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Usda License Number' ;
    rdfs:comment 'USDA Warehouse Act license number issued to this storage facility, required for federally licensed grain warehouses storing commodities under USDA oversight. Mandatory for issuing warehouse receipts and participating in USDA loan programs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsZoneCode rdf:type rdf:Property ;
    rdfs:label 'Wms Zone Code' ;
    rdfs:comment 'Zone assignment code within the Manhattan Associates Warehouse Management System (WMS) that groups storage locations for pick/put-away routing, cycle counting, and labor management. Aligns with WMS zone master configuration.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.load_plan. Business justification: WMS picking and staging tasks are created to execute outbound load plans. Linking warehouse_task to load_plan enables task completion to update load plan status, supports loading sequence management, ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:primaryWarehouseMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Warehouse Material Master Id' ;
    rdfs:comment 'Reference to the agricultural material (seed, chemical, fertilizer, or harvested commodity) that is the subject of this warehouse task. Aligns with SAP S/4HANA MM material master.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when this task was assigned to a specific warehouse operator in WMS. Used to calculate queue wait time (time from creation to assignment) as a labor management KPI.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text or coded reason provided when a task is cancelled before completion (e.g., material not found, bin location error, order cancelled, system error). Populated only when task_status = cancelled. Supports root cause analysis for operational improvement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the warehouse operator confirmed task completion in WMS. Used to calculate execution duration, throughput rates, and SLA compliance. Null if task is not yet completed or was cancelled.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationBin rdf:type rdf:Property ;
    rdfs:label 'Destination Bin' ;
    rdfs:comment 'WMS bin address (aisle-bay-level-position) to which the material is to be placed or transferred. Corresponds to the destination bin field in Manhattan Associates WMS task management. Used for putaway optimization and bin capacity planning.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Elapsed time in seconds between task start and task completion. Sourced directly from Manhattan Associates WMS task management (not derived in the Silver Layer). Used for labor standard comparison, operator productivity benchmarking, and warehouse KPI reporting.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCycleCountDiscrepancy rdf:type rdf:Property ;
    rdfs:label 'Is Cycle Count Discrepancy' ;
    rdfs:comment 'Indicates whether this cycle count task resulted in a quantity discrepancy between the WMS system quantity and the physically counted quantity. When true, triggers an inventory adjustment workflow in SAP S/4HANA MM and may require supervisor approval.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the material involved in this task is classified as hazardous (e.g., pesticides, herbicides, fumigants with EPA/SDS requirements). When true, triggers special handling protocols, REI (Restricted Entry Interval) enforcement, and SDS documentation requirements.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this task involves temperature-controlled storage (cold storage, refrigerated warehouse). When true, operator must follow cold chain handling procedures and temperature monitoring requirements per FDA and FSMA cold chain rules.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qtyConfirmed rdf:type rdf:Property ;
    rdfs:label 'Qty Confirmed' ;
    rdfs:comment 'Actual quantity of material confirmed by the operator upon task completion. May differ from qty_required due to short picks, partial putaways, or cycle count discrepancies. Drives inventory adjustment postings in SAP S/4HANA MM.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyRequired rdf:type rdf:Property ;
    rdfs:label 'Qty Required' ;
    rdfs:comment 'Quantity of material required to be moved, counted, or processed as specified when the task was created. Expressed in the primary unit of measure (UOM) for the material. QUANTITATIVE_RESULT for this non-monetary transaction.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyVariance rdf:type rdf:Property ;
    rdfs:label 'Qty Variance' ;
    rdfs:comment 'Difference between qty_required and qty_confirmed (qty_required minus qty_confirmed). Positive value indicates a short pick or under-count; negative value indicates an over-pick or over-count. Used for shrinkage analysis and inventory accuracy KPI reporting.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this task. SO=Sales Order, PO=Purchase Order, GRN=Goods Receipt Note, TO=Transfer Order, RO=Return Order, CC=Cycle Count authorization. Enables filtering and reporting by business process origin.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTransferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Transfer Order Number' ;
    rdfs:comment 'SAP S/4HANA WM/EWM transfer order number corresponding to this WMS task. Enables reconciliation between Manhattan Associates WMS task execution and SAP inventory postings for financial and inventory accuracy reporting.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Standard Time Seconds' ;
    rdfs:comment 'Engineered labor standard time in seconds for this task type and material/distance combination, as configured in Manhattan Associates WMS labor management. Used to calculate labor efficiency ratio (actual vs. standard) for OEE and workforce productivity reporting.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskGroup rdf:type rdf:Property ;
    rdfs:label 'Task Group' ;
    rdfs:comment 'WMS task group or wave identifier that bundles multiple related tasks for coordinated execution (e.g., a picking wave for a sales order shipment or a cycle count batch). Corresponds to the Task Group field in Manhattan Associates WMS.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally-known WMS-generated alphanumeric task identifier used by warehouse operators and supervisors to reference a specific task in Manhattan Associates WMS. Serves as the BUSINESS_IDENTIFIER for this transaction. Corresponds to the Task ID field in Manhattan Associates WMS task management module.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the physical warehouse activity to be performed. Drives labor routing, equipment assignment, and productivity measurement. Values: putaway (inbound stock placement), picking (outbound order fulfillment), replenishment (bin restocking), consolidation (combining partial loads), relabeling (label correction/update), cycle_count (physical inventory verification per WMS cycle count schedule).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Outbound wave release number that triggered this picking or replenishment task. Links the task to a specific order fulfillment wave in Manhattan Associates WMS, enabling wave-level productivity and throughput analysis.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePaymentId rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Id' ;
    rdfs:comment 'Unique system-generated identifier for the advance payment record. Primary key for the advance_payment data product in the invoice domain.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvancePayment .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to invoice.billing_account. Business justification: Advance payments are received from agricultural buyers and must be tracked against the AR billing account master. Adding billing_account_id links advance_payment to the billing_account within the invo' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:conservationEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Conservation Enrollment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.conservation_enrollment. Business justification: USDA conservation program advance payments (EQIP, CSP, CRP) are disbursed to enrolled producers. advance_payment has seasonal_program_code as plain text but no FK to conservation_enrollment. This link' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConservationEnrollment .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the underlying agricultural commodity contract, supply agreement, or purchase contract that this advance payment is securing. Common in forward commodity contracts and crop pre-purchase agreements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:glPostingJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Advance payments (pre-harvest financing, input advances) generate GL postings (debit advance receivable, credit cash). In agriculture, linking advance_payment to its journal entry supports reconciliat' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:advanceAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Amount' ;
    rdfs:comment 'Gross amount of the advance payment received from the agricultural buyer in the transaction currency. Represents the total prepayment before any application to invoices or deductions.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the advance payment. Used in customer communications, remittance advice matching, and AR reconciliation. Follows the format ADV-YYYY-NNNNNN.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancePurpose rdf:type rdf:Property ;
    rdfs:label 'Advance Purpose' ;
    rdfs:comment 'Business purpose classification for the advance payment describing the agricultural transaction it secures. Drives accounting treatment, revenue recognition timing, and reporting segmentation. [ENUM-REF-CANDIDATE: crop_pre_purchase|seed_advance|input_supply_advance|storage_deposit|livestock_pre_purchase|freight_deposit|processing_advance — promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Cumulative amount of the advance payment that has been applied against one or more invoices to date. Derived from application events but stored for AR reporting and aging analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank-assigned transaction reference number for the advance payment wire transfer or ACH transaction. Used for bank statement reconciliation, payment tracing, and audit trail in treasury operations.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Anticipated date on which the commodity, seed, input supply, or agricultural service secured by this advance payment is expected to be delivered or completed. Drives revenue recognition scheduling, advance application planning, and contract performance monitoring.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Advance payment amount converted to the entity\'s functional currency (typically USD) using the exchange rate at receipt date. Required for consolidated financial reporting, GL posting, and GAAP/IFRS compliance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General Ledger (GL) account code to which the advance payment liability is posted (typically a customer advance/deferred revenue account). Required for GAAP/IFRS financial reporting and balance sheet classification of advance receipts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Accrued Amount' ;
    rdfs:comment 'Total interest amount accrued on the advance payment from receipt date to current date or application date. Applicable when advance payment programs carry interest obligations per contract terms.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this advance payment is between two entities within the same agricultural enterprise group (intercompany transaction). Drives intercompany elimination in consolidated financial statements per IFRS 10 and GAAP ASC 810.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or company code within the agricultural enterprise that received the advance payment. Required for intercompany reconciliation, consolidated financial reporting, and multi-entity AR management.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount of the advance payment refunded to the agricultural buyer when the advance cannot be fully applied due to contract cancellation, crop failure, or delivery shortfall. Triggers AR credit memo and cash disbursement workflows.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date on which the advance payment refund was issued to the agricultural buyer. Required for cash flow reporting, AR clearing, and buyer dispute resolution tracking.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrderReference rdf:type rdf:Property ;
    rdfs:label 'Sales Order Reference' ;
    rdfs:comment 'Sales Order (SO) number associated with the advance payment, linking the prepayment to a specific commodity sales order in SAP S/4HANA SD. Enables order-level advance tracking and delivery-based application scheduling.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalProgramCode rdf:type rdf:Property ;
    rdfs:label 'Seasonal Program Code' ;
    rdfs:comment 'Code identifying the specific seasonal advance payment program under which this prepayment was received (e.g., spring planting advance, fall harvest pre-purchase program). Agricultural commodity markets commonly operate structured seasonal advance programs tied to crop calendars.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Remaining balance of the advance payment not yet applied to any invoice. Calculated as advance_amount minus applied_amount. Represents the outstanding liability to the buyer until delivery or service completion.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTicketReference rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Reference' ;
    rdfs:comment 'Reference to the weight ticket number associated with the commodity delivery that this advance payment will be applied against. Weight tickets are the primary measurement document in grain and commodity trading for quantity verification and invoice reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Customer Account Id' ;
    rdfs:comment 'FK to customer.account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date on which the AR billing account was closed or deactivated. Null for active accounts. Used for account lifecycle reporting and historical AR analysis.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date on which the AR billing account was formally opened and activated in the AR subledger. Represents the effective start of the financial relationship between the agricultural enterprise and the buyer.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aging130Amount rdf:type rdf:Property ;
    rdfs:label 'Aging 1 30 Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices 1 to 30 days past due, expressed in the account currency. Used in AR aging reports for collections prioritization and expected credit loss provisioning.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging3160Amount rdf:type rdf:Property ;
    rdfs:label 'Aging 31 60 Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices 31 to 60 days past due, expressed in the account currency. Elevated aging in this bucket may trigger credit review or collection escalation for agricultural buyers.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging6190Amount rdf:type rdf:Property ;
    rdfs:label 'Aging 61 90 Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices 61 to 90 days past due, expressed in the account currency. Accounts in this bucket are typically escalated to senior credit management and may trigger collateral enforcement actions.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging91120Amount rdf:type rdf:Property ;
    rdfs:label 'Aging 91 120 Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices 91 to 120 days past due, expressed in the account currency. Balances in this bucket are typically subject to formal demand letters and potential write-off evaluation.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingCurrentAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Current Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices not yet past due (within current payment terms), expressed in the account currency. Part of the standard AR aging bucket analysis used for cash flow forecasting and credit management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingOver120Amount rdf:type rdf:Property ;
    rdfs:label 'Aging Over 120 Amount' ;
    rdfs:comment 'Outstanding AR balance for invoices more than 120 days past due, expressed in the account currency. Represents the highest-risk aging bucket; balances here are evaluated for bad debt write-off per GAAP ASC 310 and IFRS 9 ECL provisioning.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Account Number' ;
    rdfs:comment 'Externally-known alphanumeric AR account number assigned to the billing customer in the SAP FI-AR subledger or Oracle NetSuite AR module. Used on invoices, statements, and remittance advice for buyer identification.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgDaysToPay rdf:type rdf:Property ;
    rdfs:label 'Avg Days To Pay' ;
    rdfs:comment 'Rolling average number of days from invoice date to payment receipt for this AR account, calculated over the trailing 12-month period. Key KPI for credit risk assessment and payment behavior benchmarking in agricultural commodity sales.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountRef rdf:type rdf:Property ;
    rdfs:label 'Bank Account Ref' ;
    rdfs:comment 'Masked or tokenized reference to the customer\'s bank account used for ACH or wire transfer payments. Full account details are stored in the payment vault; this field holds only the last 4 digits or a token for reconciliation purposes.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralValue rdf:type rdf:Property ;
    rdfs:label 'Collateral Value' ;
    rdfs:comment 'Appraised or estimated monetary value of the collateral securing the AR account, expressed in the account currency. Used in credit exposure calculations and expected credit loss (ECL) modeling per IFRS 9.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score assigned to the billing account based on payment history, financial statements, and agricultural market exposure. Used to determine credit limit and payment terms. Typically sourced from internal scoring model or third-party credit bureau.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Total outstanding accounts receivable balance for this billing account as of the last subledger posting date, expressed in the account currency. Represents the sum of all open invoice amounts net of payments and credit memos.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeBalance rdf:type rdf:Property ;
    rdfs:label 'Dispute Balance' ;
    rdfs:comment 'Total outstanding AR balance currently under formal dispute by the customer, expressed in the account currency. Disputed amounts are excluded from collections activity and tracked separately per GAAP revenue recognition guidance. Common in agricultural weight-ticket reconciliation disputes.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Reconciliation Account' ;
    rdfs:comment 'SAP GL reconciliation account number to which this AR subledger account posts. Ensures the AR subledger balance reconciles to the GL trade receivables account per GAAP ASC 310 and SOX internal controls.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalTermsFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Terms Flag' ;
    rdfs:comment 'Indicates whether this AR account is subject to seasonal payment terms aligned to agricultural harvest cycles (e.g., deferred payment until post-harvest). When True, standard payment terms are overridden by the seasonal schedule defined in the payment terms code.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Federal or state tax identification number (EIN, TIN, or VAT number) for the billing customer entity. Required for 1099 reporting, USDA program payments, and international trade documentation.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRecordId rdf:type rdf:Property ;
    rdfs:label 'Ip Record Id' ;
    rdfs:comment 'Foreign key linking to research.ip_record. Business justification: IP royalty billing schedules are directly tied to specific patents or PVP certificates: each IP record defines the royalty rate, basis, and term that drives the billing schedule. Linking billing_sched' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpRecord .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether each billing run under this schedule requires explicit management approval before the invoice is released to the customer. Supports internal controls and SOX compliance for material agricultural contracts.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Invoice Flag' ;
    rdfs:comment 'Indicates whether invoices are automatically generated and posted when the billing date or milestone is reached (True), or whether manual review and approval is required before invoice creation (False).' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Fixed monetary amount to be invoiced per billing cycle. Used when the billing amount is predetermined (e.g., fixed storage fee per month). Null when billing_formula is used instead for variable or commodity-based pricing.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Billing Day Of Month' ;
    rdfs:comment 'Day of the month (1–31) on which recurring invoices are generated for monthly or quarterly schedules. For example, a value of 1 means invoices are generated on the first of each billing period month.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingFormula rdf:type rdf:Property ;
    rdfs:label 'Billing Formula' ;
    rdfs:comment 'Expression or formula used to calculate the invoice amount dynamically, supporting commodity-based pricing (e.g., \'quantity_mt * market_price_per_mt\', \'weight_cwt * rate_per_cwt\'). Used when billing_amount is not fixed. Supports NPK input pricing, weight-ticket reconciliation, and variable rate billing.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which invoices are generated under this schedule. Supports agricultural-specific cycles including seasonal (aligned with crop harvest or livestock production calendars) and milestone-based (triggered by specific agricultural events). [ENUM-REF-CANDIDATE: weekly|monthly|quarterly|semi_annual|annual|seasonal|milestone — promote to reference product]' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingMonthOfYear rdf:type rdf:Property ;
    rdfs:label 'Billing Month Of Year' ;
    rdfs:comment 'Month of the year (1–12) on which annual or seasonal invoices are generated. Supports crop harvest calendar alignment (e.g., month 10 for fall harvest billing) and livestock production cycle billing.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingToleranceDays rdf:type rdf:Property ;
    rdfs:label 'Billing Tolerance Days' ;
    rdfs:comment 'Number of days before or after the scheduled billing date within which invoice generation is still considered on-schedule. Accommodates agricultural operational variability such as harvest delays or weather-related disruptions.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedOccurrences rdf:type rdf:Property ;
    rdfs:label 'Completed Occurrences' ;
    rdfs:comment 'Count of billing events that have been successfully executed (invoices generated and posted) under this schedule to date. Used to track schedule progress and remaining billing obligations.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the billing amount for each invoice generated under this schedule. Supports volume-based, seasonal, or contractual discount arrangements common in agricultural supply chain agreements.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastBilledDate rdf:type rdf:Property ;
    rdfs:label 'Last Billed Date' ;
    rdfs:comment 'The date on which the most recent invoice was generated under this billing schedule. Used to track billing history and validate schedule adherence.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Completion Date' ;
    rdfs:comment 'The date on which the triggering milestone was confirmed as completed, authorizing invoice generation for milestone-based billing schedules.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Description of the agricultural business event or milestone that triggers invoice generation for milestone-type schedules (e.g., \'Harvest completion\', \'Grain delivery to elevator\', \'Livestock weaning\', \'Crop input delivery confirmed\').' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'The date on which the next invoice will be automatically generated or triggered under this schedule. Updated after each successful billing run.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue from invoices generated by this schedule per IFRS 15 / ASC 606 standards. \'point_in_time\' for delivery-based recognition; \'over_time\' for service contracts; \'milestone_based\' for performance obligation completion; \'proportional\' for percentage-of-completion.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this billing schedule, used for cross-system reference and communication with customers and partners (e.g., BSCHED-2024-001).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable descriptive name for the billing schedule (e.g., \'Annual Grain Storage Q1 Billing\', \'Seasonal Crop Input Monthly Installment\').' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the billing schedule. \'active\' indicates invoices are being generated; \'suspended\' indicates temporarily paused; \'completed\' indicates all billing milestones fulfilled; \'cancelled\' indicates terminated before completion; \'draft\' indicates not yet activated.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the billing schedule by its triggering mechanism. \'recurring\' for time-based periodic billing; \'milestone\' for event-triggered billing (e.g., harvest completion); \'one_time\' for single-occurrence billing; \'seasonal\' for crop or livestock production calendar-aligned billing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBillingOccurrences rdf:type rdf:Property ;
    rdfs:label 'Total Billing Occurrences' ;
    rdfs:comment 'Total number of billing events planned for this schedule over its full lifecycle. For example, a 12-month monthly schedule has 12 occurrences. Null for open-ended or milestone-only schedules.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique system-generated identifier for the credit memo record. Primary key for the credit_memo data product in the invoice domain.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the original invoice against which this credit memo is issued. Enables traceability from credit memo back to the source billing document for AR reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:lotTraceId rdf:type rdf:Property ;
    rdfs:label 'Lot Trace Id' ;
    rdfs:comment 'Foreign key linking to supply.lot_trace. Business justification: Ag credit memos for quality rejections, MRL exceedances, or grade disputes must reference the specific lot for FSMA-compliant credit processing and recall management. Linking credit_memo to lot_trace ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotTrace .

ind:commodityGrade rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade' ;
    rdfs:comment 'The USDA or industry-standard commodity grade assigned to the produce or grain at the time of the credit dispute (e.g., US No. 1, US No. 2, Choice, Select). Used to document grading disputes and price adjustment credits based on grade downgrade.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross credit amount before tax adjustments, representing the total value being reversed or reduced from the original invoice. Expressed in the transaction currency. Used for AR balance reduction and revenue recognition reversal.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the credit memo document. Used in customer communications, AR aging reports, and audit trails. Follows the format CM-YYYY-NNNNNN.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for issuing the credit memo. Agricultural-specific reasons include: PRICE_ADJ (price adjustment post-harvest), QUALITY_REJECT (quality rejection at delivery), WEIGHT_DISC (weight ticket discrepancy), PRODUCE_RETURN (return of produce), MRL_DEDUCTION (Maximum Residue Limit non-compliance deduction), GRADE_DISPUTE (commodity grading dispute). [ENUM-REF-CANDIDATE: PRICE_ADJ|QUALITY_REJECT|WEIGHT_DISC|PRODUCE_RETURN|MRL_DEDUCTION|GRADE_DISPUTE — promote to reference product]' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Free-text narrative providing detailed explanation of the credit reason beyond the standardized code. Captures specifics such as lot numbers affected, field of origin, inspector findings, or commodity grade dispute details for audit and dispute resolution purposes.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTraceable rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceable' ;
    rdfs:comment 'Indicates whether the credit memo is associated with a FSMA-traceable commodity lot requiring full supply chain traceability documentation under the FSMA Food Traceability Rule (21 CFR Part 1, Subpart S). Triggers enhanced documentation requirements for food safety audits.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryDeduction rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Deduction' ;
    rdfs:comment 'Indicates whether the credit memo was triggered by a regulatory compliance deduction (True) such as MRL non-compliance, FSMA violation penalty, or EPA/USDA-mandated recall credit, versus a commercial dispute or voluntary adjustment (False). Supports regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memoStatus rdf:type rdf:Property ;
    rdfs:label 'Memo Status' ;
    rdfs:comment 'Current lifecycle state of the credit memo. Tracks progression from draft creation through issuance, application against open invoices or future orders, and final closure or voiding. [ENUM-REF-CANDIDATE: draft|issued|applied|partially_applied|voided|expired — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credit Amount' ;
    rdfs:comment 'The total net credit amount inclusive of tax credit (credit_amount + tax_credit_amount). Represents the final value applied to the customer\'s AR balance or refunded. Used for financial settlement and GL posting.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Number' ;
    rdfs:comment 'The human-readable invoice number of the original billing document that this credit memo reverses or adjusts. Retained as a denormalized reference for audit trails, customer communications, and dispute resolution without requiring a join.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Reason' ;
    rdfs:comment 'Specific narrative for price-adjustment credits, capturing the market condition, contract clause, or WASDE-driven price revision that triggered the credit. Relevant for commodity-based pricing where spot market fluctuations or futures contract settlements require post-invoice price corrections.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCredited rdf:type rdf:Property ;
    rdfs:label 'Quantity Credited' ;
    rdfs:comment 'The quantity of agricultural commodity or product being credited, expressed in the unit of measure applicable to the transaction (e.g., bushels, metric tons, hundredweight, cases). Supports weight-ticket reconciliation and partial return credits.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Credit Amount' ;
    rdfs:comment 'The unapplied balance of the credit memo (net_credit_amount minus applied_amount). Represents the credit still available for application against future invoices or for cash refund. Critical for AR aging and customer statement accuracy.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'The tax component of the credit memo, representing the reversal of taxes originally charged on the invoiced amount. Includes applicable sales tax, VAT, or agricultural commodity tax credits as required by jurisdiction.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPriceCredited rdf:type rdf:Property ;
    rdfs:label 'Unit Price Credited' ;
    rdfs:comment 'The per-unit price used to calculate the credit amount (credit_amount = quantity_credited × unit_price_credited). Captures the price differential in price adjustment credits or the original invoice unit price for return and quality rejection credits.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitMemoId rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each debit memo record in the invoice domain. Primary key for the debit_memo data product.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Id' ;
    rdfs:comment 'Reference to the original invoice against which this debit memo is raised to recover an underbilling or apply a post-settlement adjustment. Supports AR reconciliation and audit trail.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:salesOrgId rdf:type rdf:Property ;
    rdfs:label 'Sales Org Id' ;
    rdfs:comment 'Reference to the sales organization responsible for issuing the debit memo. Determines the legal entity, currency, and revenue recognition rules applicable to the adjustment.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference to the underlying sales or purchase contract number governing the original transaction. Supports contract-based price escalation clauses and post-settlement adjustment terms common in grain and commodity trading.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Gross base amount of the debit memo before tax, representing the underbilling recovery or post-settlement adjustment. Expressed in the transaction currency. Core monetary component for AR and revenue recognition.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Number' ;
    rdfs:comment 'Externally visible, human-readable document number assigned to the debit memo at issuance. Used in customer correspondence, remittance advice, and accounts receivable (AR) reconciliation. Sourced from SAP S/4HANA FI document numbering.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonCode rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Code' ;
    rdfs:comment 'Standardized code classifying the business reason for issuing the debit memo. Supported reasons include: PRICE_ESC (price escalation), FREIGHT_ADJ (additional freight charges), STORAGE_FEE (storage fees), FUMIGATION (fumigation charges), QUALITY_PREM (quality premium adjustment), WT_TICKET_CORR (weight-ticket correction). Drives GL account determination and reporting in SAP S/4HANA.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Description' ;
    rdfs:comment 'Free-text narrative explaining the specific business justification for the debit memo, supplementing the structured debit_reason_code. For example, details of a weight-ticket discrepancy or the basis for a quality premium adjustment per COA (Certificate of Analysis).' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number for any customer dispute or deduction claim raised against this debit memo. Populated when memo_status transitions to DISPUTED. Supports AR collections and dispute resolution workflow.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Net total amount of the debit memo inclusive of tax (debit_amount + tax_amount). Represents the total receivable to be collected from the customer. Used for AR balance updates and financial reporting.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Primary key for dispute' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_finding. Business justification: Invoice disputes in commodity agriculture are directly triggered by specific inspection findings (MRL exceedance, grade failure, foreign material). A FK from dispute to inspection_finding_id enables f' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:customerClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Customer Claim Amount' ;
    rdfs:comment 'The specific monetary amount the customer is claiming as a credit, refund, or price adjustment. May differ from the disputed_amount if the customer is requesting a specific settlement figure based on their own calculations (e.g., weight-ticket reconciliation or commodity grade re-pricing).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToResolve rdf:type rdf:Property ;
    rdfs:label 'Days To Resolve' ;
    rdfs:comment 'Number of calendar days elapsed between dispute_date and resolution_date. Populated upon resolution. Used for KPI reporting on dispute resolution cycle time and SLA compliance tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The calendar date on which the customer formally raised the dispute. This is the principal business event date used for aging calculations, SLA tracking, and regulatory reporting timelines.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed free-text narrative provided by the customer or AR team describing the nature of the dispute, including specific claims, supporting evidence references, and any relevant field or delivery observations.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for the dispute, used in customer communications, USDA grain grading arbitration filings, and audit trails. Format: DSP-YYYY-NNNNNN.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the dispute. \'open\' = newly filed; \'under_review\' = assigned and being investigated; \'resolved\' = final determination reached; \'escalated\' = elevated to senior arbitration or regulatory body; \'withdrawn\' = customer retracted the claim.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the reason for the dispute. Common agricultural billing dispute types include: price_discrepancy, weight_variance, quality_rejection, grade_dispute, mrl_exceedance_deduction, duplicate_billing, contract_terms_disagreement, short_shipment, packaging_defect. [ENUM-REF-CANDIDATE: price_discrepancy|weight_variance|quality_rejection|grade_dispute|mrl_exceedance_deduction|duplicate_billing|contract_terms_disagreement|short_shipment|packaging_defect — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The portion of the invoice amount that the customer is formally contesting. May equal the full invoice amount (full dispute) or a subset (partial dispute) such as a weight variance deduction or MRL exceedance penalty.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric indicator of how many times the dispute has been escalated to a higher authority. Level 0 = not escalated; Level 1 = escalated to senior AR manager; Level 2 = escalated to legal/compliance; Level 3 = escalated to external arbitration (e.g., USDA GIPSA commodity arbitration).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text description of the reason the dispute was escalated, such as failure to reach agreement within SLA, regulatory involvement required, or high-value commodity arbitration triggered.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'The total billed amount on the original invoice as issued to the customer, captured at the time of dispute initiation for reference and variance calculation.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPartialDispute rdf:type rdf:Property ;
    rdfs:label 'Is Partial Dispute' ;
    rdfs:comment 'Indicates whether the dispute covers only a portion of the invoice amount (True) or the full invoice amount (False). Drives AR aging treatment and partial payment clearing logic in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryDispute rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Dispute' ;
    rdfs:comment 'Indicates whether the dispute involves a regulatory compliance dimension (e.g., FSMA traceability violation, EPA MRL exceedance, USDA grade certification challenge, COOL labeling dispute). Regulatory disputes trigger mandatory escalation and compliance reporting workflows.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlExceedanceDetail rdf:type rdf:Property ;
    rdfs:label 'Mrl Exceedance Detail' ;
    rdfs:comment 'Description of the Maximum Residue Limit (MRL) exceedance that triggered a deduction or dispute, including the active ingredient (AI), detected level, and applicable MRL threshold per EPA or Codex Alimentarius standards. Populated only for mrl_exceedance_deduction dispute types.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes recorded by the assigned reviewer documenting the investigation findings, evidence reviewed (weight tickets, COA, grade certificates), and the rationale for the resolution determination.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The final agreed monetary settlement amount upon resolution of the dispute. Populated only when dispute_status = \'resolved\'. May reflect a full credit, partial credit, price adjustment, or zero (claim denied).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The target date by which the dispute must be resolved per internal Service Level Agreement (SLA) or contractual dispute resolution terms. Calculated from dispute_date plus the applicable SLA window based on dispute_type and priority_level.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningNoticeId rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Id' ;
    rdfs:comment 'Unique system-generated identifier for each dunning notice record. Primary key for the dunning_notice data product.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionsOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collections Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Collections portfolio management in agriculture AR requires linking dunning notices to the responsible collections employee for workload reporting, performance reviews, and overdue account ownership. ' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditExposure rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure' ;
    rdfs:comment 'Total outstanding credit exposure for the customer at the time of dunning notice issuance, including all open invoices, not just the overdue amount. Used for credit risk management.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerResponse rdf:type rdf:Property ;
    rdfs:label 'Customer Response' ;
    rdfs:comment 'The customer\'s response to the dunning notice. Captures the outcome of the collections contact: No Response, Payment Promised, Partial Payment, Disputed, Payment Made, Arrangement Agreed, or Referred to Legal. [ENUM-REF-CANDIDATE: No Response|Payment Promised|Partial Payment|Disputed|Payment Made|Arrangement Agreed|Referred to Legal — promote to reference product]' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'The date on which the customer responded to the dunning notice. Used to measure response time and assess collections effectiveness.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningArea rdf:type rdf:Property ;
    rdfs:label 'Dunning Area' ;
    rdfs:comment 'SAP dunning area code used to segment dunning processing by business unit, region, or company code. Enables separate dunning runs for different agricultural divisions (e.g., crop inputs vs. livestock feed).' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlockReason rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Reason' ;
    rdfs:comment 'Reason code indicating why dunning has been blocked for this customer account (e.g., payment arrangement in place, dispute under review, seasonal deferral granted, legal hold). Null if no block is active.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Dunning Charge Amount' ;
    rdfs:comment 'Administrative fee or dunning charge levied on the customer for the issuance of this dunning notice, as permitted by the sales contract or applicable law.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Numeric escalation level of the dunning notice indicating severity of the collections action. Level 1 = first reminder, Level 2 = second reminder, Level 3 = final notice, Level 4 = legal action referral. Aligns with SAP dunning levels 1–4.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevelDescription rdf:type rdf:Property ;
    rdfs:label 'Dunning Level Description' ;
    rdfs:comment 'Human-readable label corresponding to the dunning level: First Reminder, Second Reminder, Final Notice, or Legal Action. Used in customer-facing correspondence and collections reporting.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningMethod rdf:type rdf:Property ;
    rdfs:label 'Dunning Method' ;
    rdfs:comment 'The communication channel used to deliver the dunning notice to the customer. Email = electronic delivery; Mail = postal letter; Phone = verbal notice; Legal = formal legal correspondence; Fax = facsimile; Portal = customer self-service portal notification.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Current escalation state of the dunning notice. Tracks whether the overdue account has been escalated beyond standard collections to legal counsel or a third-party collections agency. [ENUM-REF-CANDIDATE: Not Escalated|Pending Escalation|Escalated to Legal|Referred to Agency|Write-Off Initiated — promote to reference product]' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDunningBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Dunning Blocked' ;
    rdfs:comment 'Indicates whether further dunning actions are currently blocked for this customer account. True = dunning is blocked (e.g., due to dispute, payment plan, or seasonal deferral); False = dunning proceeds normally.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'The calendar date on which the dunning notice was formally issued and sent to the customer. Used as the reference date for response deadline calculation.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the dunning notice, used in customer correspondence and collections tracking. Format: DN-{YYYY}-{sequence}.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeStatus rdf:type rdf:Property ;
    rdfs:label 'Notice Status' ;
    rdfs:comment 'Current lifecycle status of the dunning notice. Draft = prepared but not sent; Issued = sent to customer; Responded = customer acknowledged or paid; Escalated = forwarded to legal/collections agency; Closed = resolved; Cancelled = voided.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldestInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Invoice Date' ;
    rdfs:comment 'The invoice date of the oldest unpaid invoice included in this dunning notice. Used to determine the age of the oldest outstanding receivable and assess credit risk.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueAmountFunctional rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount Functional' ;
    rdfs:comment 'Total overdue balance converted to the company\'s functional currency (typically USD) using the exchange rate at the time of notice issuance. Required for consolidated AR reporting under GAAP/IFRS.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentArrangementDate rdf:type rdf:Property ;
    rdfs:label 'Payment Arrangement Date' ;
    rdfs:comment 'The date on which a payment arrangement was formally agreed with the customer. Null if no arrangement has been established.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Arrangement Flag' ;
    rdfs:comment 'Indicates whether a formal payment arrangement or installment plan has been agreed with the customer as a result of this dunning notice. True = arrangement in place; False = no arrangement. Supports seasonal agricultural buyer cash flow management.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promisedPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Promised Payment Amount' ;
    rdfs:comment 'The amount the customer has committed to paying by the promised payment date. May be less than the full overdue amount if a partial payment arrangement has been agreed.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Promised Payment Date' ;
    rdfs:comment 'The date by which the customer has committed to making payment as part of a payment promise or arrangement. Used to monitor promise-to-pay compliance for agricultural buyers with seasonal cash flow constraints.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the customer must respond or remit payment before the dunning notice escalates to the next level. Critical for seasonal agricultural buyers managing post-harvest cash flow.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Full billing address of the customer as printed on the invoice document. Includes street, city, state, postal code, and country. Denormalized for invoice archival and legal document integrity.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the service or delivery period covered by this invoice. Used with billing_period_start to define the performance obligation period for revenue recognition under GAAP ASC 606 / IFRS 15.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the service or delivery period covered by this invoice. Relevant for contract settlement invoices, advance billing, and service-based billing where revenue is recognized over a period per GAAP ASC 606.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal name of the customer (food manufacturer, distributor, cooperative, or agricultural buyer) as it appears on the invoice. Denormalized from the billing account for invoice document rendering and archival purposes.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason code for a customer-raised invoice dispute. Applicable when invoice_status is \'disputed\'. Agricultural-specific reasons include weight disputes (scale ticket discrepancies), quality claims (grade/moisture rejections), and price discrepancies against commodity contracts. [ENUM-REF-CANDIDATE: price_discrepancy|quantity_discrepancy|quality_claim|weight_dispute|duplicate_invoice|unauthorized_deduction|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was sent to the customer for this overdue invoice. Used to schedule the next dunning run and track collections activity.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice number assigned at issuance. Used on printed billing documents, customer remittances, and payment references. Sourced from SAP FI-AR document number or Oracle NetSuite invoice number.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount of cash payments applied to this invoice through payment_allocation records. Used to calculate the outstanding balance and determine if the invoice is partially or fully paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in the general ledger per GAAP ASC 606 / IFRS 15 five-step model. May differ from invoice_date for advance billing, contract settlements, or FOB destination shipments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingTerms rdf:type rdf:Property ;
    rdfs:label 'Shipping Terms' ;
    rdfs:comment 'International commercial terms (Incoterms) defining the point of title transfer and risk allocation for the shipment. Determines revenue recognition timing under GAAP ASC 606 and affects freight cost allocation on the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate' ;
    rdfs:comment 'Certificate number issued by the relevant tax authority confirming the customer\'s tax-exempt status. Required for audit documentation when tax_exempt_flag is True. Supports IRS and state tax compliance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the customer or transaction is exempt from sales tax or VAT. Agricultural cooperatives, government entities, and certain commodity transactions may qualify for tax exemption. Drives tax calculation logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Number' ;
    rdfs:comment 'Reference number of the certified scale weight ticket used to determine commodity quantity for billing. Critical for grain elevator, livestock, and bulk commodity invoicing where payment is based on certified weight. Supports USDA grain inspection compliance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each invoice line item record in the Databricks Silver Layer. Primary key for the invoice_line data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:commodityPriceBasisId rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Basis Id' ;
    rdfs:comment 'Foreign key linking to invoice.price_basis. Business justification: invoice_line.pricing_basis is a denormalized string reference to the price_basis reference table. Agricultural commodity invoice lines are priced using specific pricing bases (futures + basis, flat pr' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBasis .

ind:basisAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Amount' ;
    rdfs:comment 'The local cash price differential (basis) relative to the futures contract reference price, expressed in the invoice currency per UOM. Positive basis indicates premium over futures; negative indicates discount. Critical for agricultural commodity pricing reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dockagePct rdf:type rdf:Property ;
    rdfs:label 'Dockage Pct' ;
    rdfs:comment 'Percentage deduction applied to the billed quantity for foreign material, moisture excess, or quality deficiencies per USDA grain inspection standards. Drives quantity and price adjustments on the invoice line.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futuresContractRef rdf:type rdf:Property ;
    rdfs:label 'Futures Contract Ref' ;
    rdfs:comment 'CME/CBOT futures contract month and symbol used as the pricing reference for this line when pricing_basis is \'futures\' or \'formula\' (e.g., \'ZC-DEC24\' for December 2024 Corn futures). Null when pricing_basis is spot or contract.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this invoice line item is subject to sales tax, VAT, or other applicable taxes. Drives tax calculation logic in SAP S/4HANA FI and Oracle NetSuite Tax modules.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Human-readable description of the commodity, crop product, livestock, or service being billed on this line (e.g., \'Yellow Corn No. 2 - Harvest 2024\', \'Feeder Cattle - 500-600 lb\', \'Custom Application Service\').' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the invoice line item indicating whether it represents a commodity sale, livestock transaction, service charge, freight, storage, handling fee, penalty, or credit memo. Drives revenue recognition category assignment. [ENUM-REF-CANDIDATE: commodity|livestock|service|freight|storage|handling|penalty|credit_memo — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Revenue recognition category assigned to this line for GL posting and financial reporting under GAAP ASC 606 / IFRS 15. Drives the revenue account mapping in SAP S/4HANA CO module and Oracle NetSuite GL.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWeight rdf:type rdf:Property ;
    rdfs:label 'Test Weight' ;
    rdfs:comment 'Test weight of the grain commodity in pounds per bushel (lb/BU) as measured at delivery. A key quality parameter affecting grade assignment and price adjustments for corn, soybeans, wheat, and other grains.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTicketRef rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Ref' ;
    rdfs:comment 'Reference number of the scale/weight ticket used to verify the quantity of grain or bulk commodity billed on this line. Critical for weight-ticket reconciliation in agricultural commodity billing. Links to the physical scale ticket from the elevator or processing facility.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each payment transaction record in the accounts receivable (AR) ledger.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross amount of the payment as submitted by the payer in the transaction currency. Represents the total funds received before any deductions, discounts, or adjustments are applied.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityLotReference rdf:type rdf:Property ;
    rdfs:label 'Commodity Lot Reference' ;
    rdfs:comment 'Lot number (LOT) or batch identifier of the agricultural commodity (grain, produce, livestock) associated with this payment. Enables traceability from payment back to specific commodity lot for FSMA compliance and quality reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialPayment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Payment' ;
    rdfs:comment 'Indicates whether this payment covers only a portion of the total invoice amount. True when applied_amount is less than the full invoice balance. Supports installment and partial payment tracking for agricultural seasonal payment programs.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerBankAccount rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Account' ;
    rdfs:comment 'Masked or tokenized bank account identifier of the payer used for ACH, EFT, or wire payments. Stored in masked format for PCI compliance. Used for payment routing validation and fraud detection.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Routing Number' ;
    rdfs:comment 'ABA routing transit number (9 digits) of the payer\'s bank for ACH and wire payment processing. Used for payment routing validation and bank reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally-known business identifier for the payment transaction, typically matching the payment document number in SAP S/4HANA FI or Oracle NetSuite. Used for cross-system reconciliation and customer remittance matching.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number from the payer\'s remittance advice document accompanying the payment. Used to match payment to specific invoices and deductions in the cash application process.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized bank return reason code when payment_status is \'returned\' (e.g., NACHA ACH return codes R01=Insufficient Funds, R02=Account Closed, R03=No Account). Required for returned payment processing and customer follow-up.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique system-generated identifier for each payment allocation record linking a payment to a specific invoice or invoice line. Serves as the primary key for this association entity.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Clearing Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Payment allocations (clearing open AR items) generate GL clearing journal entries. In agriculture AR operations, matching payments to invoices triggers GL clearing postings. clearing_document_number i' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:patronageDistributionId rdf:type rdf:Property ;
    rdfs:label 'Patronage Distribution Id' ;
    rdfs:comment 'Reference to the cooperative patronage distribution record being applied through this allocation. Supports cooperative patronage dividend application against member invoices, a common agricultural billing workflow for grain cooperatives and farm supply cooperatives.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatronageDistribution .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The gross monetary amount of the payment applied to this invoice or invoice line in the transaction currency. Core financial field for AR settlement, revenue recognition, and cash application reporting per GAAP/IFRS standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the payment was applied to the invoice. Used for aging analysis, cash application reporting, and Days Sales Outstanding (DSO) calculation. May differ from the payment receipt date in seasonal agricultural billing cycles.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible business identifier for this payment allocation record, used in AR clearing documents, remittance advice matching, and audit trails. Corresponds to the SAP FI clearing document number or Oracle NetSuite application number.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the payment allocation: pending (awaiting posting), posted (applied to AR ledger), reversed (allocation reversed/cancelled), reconciled (matched and confirmed in bank reconciliation), disputed (under investigation for discrepancy). Drives AR aging and cash application workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Categorizes the nature of the payment application: full (complete invoice settlement), partial (portion of invoice settled), advance (prepayment applied against future invoice), credit_offset (credit memo applied), netting (offsetting payable against receivable), write_off (uncollectable balance cleared). [ENUM-REF-CANDIDATE: full|partial|advance|credit_offset|netting|write_off — promote to reference product]' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'The user ID or username of the finance manager or controller who approved this payment allocation, particularly for write-offs, large variance clearances, or deduction approvals. Supports segregation of duties and SOX internal control requirements.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Allocated amount converted to the company\'s functional (base) currency for general ledger (GL) posting and financial reporting. Required for multi-currency operations in international agricultural commodity trading per IFRS 21.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityContractNumber rdf:type rdf:Property ;
    rdfs:label 'Commodity Contract Number' ;
    rdfs:comment 'Reference to the agricultural commodity purchase or sales contract against which this payment is being applied. Supports commodity contract payment matching for grain, livestock, and produce contracts. Links to forward contracts, basis contracts, and hedge-to-arrive (HTA) arrangements.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or username of the AR specialist or system process that created this payment allocation record. Required for SOX internal controls, audit trail, and segregation of duties compliance in financial operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Monetary value of deductions taken by the payer against the invoice, such as quality dockage, moisture penalties, freight charges, or promotional allowances. Distinct from discount_taken_amount as deductions are typically disputed or contractually defined adjustments in commodity billing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Code' ;
    rdfs:comment 'Code identifying the reason for any deduction taken by the payer against the invoice amount (e.g., quality deduction, moisture dockage, freight deduction, promotional allowance). Common in agricultural commodity billing where buyers deduct for grade, moisture, or foreign material.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Amount' ;
    rdfs:comment 'Monetary value of the early payment discount earned by the payer for settling the invoice before the discount due date. Distinct from standard trade discounts; tied to payment terms such as 2/10 Net 30 common in agricultural supply chain billing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Netting Reference Number' ;
    rdfs:comment 'Reference identifier for the intercompany or counterparty netting arrangement when allocation_type is \'netting\'. Used in agricultural supply chain scenarios where a company is both buyer and seller to the same counterparty (e.g., grain merchandiser netting payables against receivables).' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Business reason for reversing this payment allocation (e.g., returned check, bank rejection, incorrect application, duplicate payment). Populated only when allocation_status is \'reversed\'. Required for audit trail and AR dispute management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Monetary amount of the invoice balance written off as uncollectable or as an approved variance adjustment. Used in bad debt management, small balance write-offs, and weight-ticket variance clearance in commodity billing workflows.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Company Code' ;
    rdfs:comment 'SAP S/4HANA company code(s) for which this payment term is valid. Comma-separated if applicable to multiple company codes. Null indicates applicability across all company codes. Supports multi-entity agricultural enterprise structures.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segment' ;
    rdfs:comment 'Customer segment classification for which this payment term is designed. Allows differentiated term offerings for growers, cooperatives, distributors, and processors within the agricultural supply chain. [ENUM-REF-CANDIDATE: all|grower|cooperative|distributor|processor|retailer|export — promote to reference product]' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSalesOrg rdf:type rdf:Property ;
    rdfs:label 'Applicable Sales Org' ;
    rdfs:comment 'SAP S/4HANA sales organization code(s) for which this payment term is valid. Comma-separated if applicable to multiple sales organizations. Null indicates global applicability across all sales organizations.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDateType rdf:type rdf:Property ;
    rdfs:label 'Baseline Date Type' ;
    rdfs:comment 'Defines the reference date from which net due days and discount days are calculated. Agricultural-specific options include weight_ticket_date (grain elevator settlements) and harvest_completion_date (post-harvest deferred programs). Maps to SAP S/4HANA payment term baseline date configuration.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Required' ;
    rdfs:comment 'Minimum approved credit limit (in functional currency) that a customer must hold to be eligible for this payment term. Supports credit risk management for extended or deferred agricultural payment programs. Null if no minimum credit limit is required.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferralMaxDays rdf:type rdf:Property ;
    rdfs:label 'Deferral Max Days' ;
    rdfs:comment 'Maximum number of calendar days that payment may be deferred from the invoice date under a seasonal deferral program, regardless of when the trigger event occurs. Caps the deferral window to manage credit exposure. Null when is_seasonal_deferral is false.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deferralTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Deferral Trigger Event' ;
    rdfs:comment 'The business event that triggers the start of the payment window for seasonally deferred terms. For example, \'harvest_completion\' starts the net due days clock after crop harvest is recorded. Null when is_seasonal_deferral is false.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDays1 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 1' ;
    rdfs:comment 'Number of days from the baseline date within which payment must be received to qualify for the first-tier early payment discount percentage. Corresponds to SAP S/4HANA ZBD1T field. Null if no early payment discount applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountDays2 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 2' ;
    rdfs:comment 'Number of days from the baseline date within which payment must be received to qualify for the second-tier early payment discount. Corresponds to SAP S/4HANA ZBD2T field. Null if no second discount tier applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercent1 rdf:type rdf:Property ;
    rdfs:label 'Discount Percent 1' ;
    rdfs:comment 'Percentage discount applied to the invoice amount if payment is received within discount_days_1. Expressed as a decimal (e.g., 0.0200 = 2%). Corresponds to SAP S/4HANA ZBD1P field. Null if no early payment discount applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercent2 rdf:type rdf:Property ;
    rdfs:label 'Discount Percent 2' ;
    rdfs:comment 'Percentage discount applied to the invoice amount if payment is received within discount_days_2 but after discount_days_1. Corresponds to SAP S/4HANA ZBD2P field. Null if no second discount tier applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Procedure Code' ;
    rdfs:comment 'SAP S/4HANA dunning procedure code assigned to this payment term, controlling the escalation schedule for overdue AR notices. Seasonal agricultural terms may use specialized dunning procedures that account for harvest timing before escalating collection actions.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpTermKey rdf:type rdf:Property ;
    rdfs:label 'Erp Term Key' ;
    rdfs:comment 'Native payment term key as stored in the source ERP system (SAP S/4HANA ZTERM field, Oracle NetSuite term ID). Enables traceability and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Total number of installment payments required under this term when is_installment is true. For example, 3 for a three-payment seasonal schedule. Null when is_installment is false.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Installment Schedule Type' ;
    rdfs:comment 'Defines how installment amounts are distributed across the payment schedule. \'harvest_triggered\' supports agricultural deferred programs where installment timing is tied to crop harvest completion events. Null when is_installment is false.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInstallment rdf:type rdf:Property ;
    rdfs:label 'Is Installment' ;
    rdfs:comment 'Indicates whether this payment term requires payment in multiple installments rather than a single lump sum. When true, installment_count and installment_schedule_type define the installment structure. Common for large agricultural equipment purchases and seasonal input financing.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalDeferral rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Deferral' ;
    rdfs:comment 'Indicates whether this payment term includes a seasonal deferral provision, allowing payment to be deferred to a post-harvest or post-season window. Characteristic of agricultural deferred grain payment programs and spring input financing.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentGraceDays rdf:type rdf:Property ;
    rdfs:label 'Late Payment Grace Days' ;
    rdfs:comment 'Number of calendar days beyond the due date before late payment penalties begin to accrue. Provides a grace window before penalty charges are triggered. Null if no grace period applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latePaymentPenaltyPercent rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Percent' ;
    rdfs:comment 'Annual percentage rate applied to overdue invoice balances as a late payment penalty or interest charge. Expressed as a decimal (e.g., 0.0150 = 1.5% per annum). Null if no late payment penalty applies under this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDueDays rdf:type rdf:Property ;
    rdfs:label 'Net Due Days' ;
    rdfs:comment 'Number of calendar days from the invoice date (or baseline date) by which full payment is due. For example, 30 for Net 30 terms. Core field in SAP S/4HANA payment term configuration (ZBD3T). Drives AR due date calculation.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netsuiteTermCode rdf:type rdf:Property ;
    rdfs:label 'Netsuite Term Code' ;
    rdfs:comment 'Payment term identifier as defined in Oracle NetSuite GL/AR module. Populated when the term originates from or is synchronized with NetSuite. Supports dual-ERP environments where SAP S/4HANA and Oracle NetSuite coexist.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Payment Method Restriction' ;
    rdfs:comment 'Restricts the allowable payment methods under this term. For example, large grain settlement programs may require ACH or wire transfer only. \'none\' indicates no restriction. Maps to SAP S/4HANA payment method configuration.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceFixationRequired rdf:type rdf:Property ;
    rdfs:label 'Price Fixation Required' ;
    rdfs:comment 'Indicates whether the commodity price must be fixed (priced) before the payment due date clock starts. Relevant for deferred pricing grain contracts (basis contracts, hedge-to-arrive) where the final invoice amount is not determined at delivery.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the payment term configuration, as defined in SAP S/4HANA FI/SD module (e.g., NET30, DEFGRAIN90, LSTK45). Used on invoices, sales orders, and purchase orders for term lookup.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termDescription rdf:type rdf:Property ;
    rdfs:label 'Term Description' ;
    rdfs:comment 'Detailed narrative description of the payment term, including applicable conditions, seasonal rules, commodity restrictions, and any special settlement provisions relevant to agricultural billing scenarios.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'Human-readable name of the payment term configuration (e.g., \'Net 30 Days\', \'Deferred Grain Payment 90 Days Post-Harvest\', \'Livestock Settlement 14 Days\'). Displayed on customer-facing documents and AR aging reports.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term configuration. Inactive or deprecated terms are retained for historical invoice reference but cannot be assigned to new transactions.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the payment term by its structural type. Supports agricultural-specific types including deferred seasonal programs (post-harvest grain payment windows), commodity-price-based settlement, and livestock consignment settlement. [ENUM-REF-CANDIDATE: standard_net|early_payment_discount|deferred_seasonal|installment|consignment_settlement|commodity_price_based|prepayment — promote to reference product]' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightTicketReconciliationRequired rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Reconciliation Required' ;
    rdfs:comment 'Indicates whether payment under this term requires reconciliation against a weight ticket (scale ticket) before the invoice due date is triggered. Critical for grain elevator and commodity settlement billing scenarios where final payment amount depends on certified weight.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Id' ;
    rdfs:comment 'Unique system-generated identifier for each price adjustment record in the invoice domain. Serves as the primary key for the price_adjustment data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAdjustment .

ind:animalTransactionId rdf:type rdf:Property ;
    rdfs:label 'Animal Transaction Id' ;
    rdfs:comment 'Foreign key linking to livestock.animal_transaction. Business justification: Livestock price adjustments (grade discounts, weight shrink corrections, quality premiums) are issued against specific sale transactions. Linking price_adjustment to animal_transaction enables traceab' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnimalTransaction .

ind:coldChainReadingId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Reading Id' ;
    rdfs:comment 'Foreign key linking to supply.cold_chain_reading. Business justification: In ag cold chain (produce, dairy, frozen), temperature excursions documented in cold_chain_reading directly trigger contractual price adjustments or deductions. Linking price_adjustment to cold_chain_' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColdChainReading .

ind:adjustedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Unit Price' ;
    rdfs:comment 'The final settled unit price per unit of measure after applying the price adjustment. Reflects final commodity pricing, quality re-grading outcome, or contract true-up result.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net monetary value of the price adjustment (positive for increases, negative for decreases). Calculated as (adjusted_unit_price - original_unit_price) × quantity_affected. Drives AR debit or credit memo issuance and revenue recognition true-up.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDirection rdf:type rdf:Property ;
    rdfs:label 'Adjustment Direction' ;
    rdfs:comment 'Indicates whether the adjustment increases or decreases the original invoice amount. Drives debit memo vs. credit memo issuance and AR balance impact.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the price adjustment document. Used in customer communications, remittance advice, and audit trails. Format: PA-YYYY-NNNNNN.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futuresContractMonth rdf:type rdf:Property ;
    rdfs:label 'Futures Contract Month' ;
    rdfs:comment 'The CBOT/CME futures contract delivery month code used as the pricing reference for basis or futures-plus-basis adjustments (e.g., Z24 for December 2024 corn). Applicable when pricing_basis is \'futures_plus_basis\' or \'basis\'.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'The provisional unit price per unit of measure (e.g., per bushel, per metric ton, per hundredweight) stated on the originating invoice before any adjustment. Basis for calculating the adjustment delta.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Unit Of Measure' ;
    rdfs:comment 'Unit of measure against which the original and adjusted unit prices are expressed. Common agricultural units include BU (Bushel), CWT (Hundredweight), MT (Metric Ton), LB (Pound), KG (Kilogram), TON (Short Ton).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityFactorCode rdf:type rdf:Property ;
    rdfs:label 'Quality Factor Code' ;
    rdfs:comment 'Specific quality attribute code (e.g., test weight, heat damage, total damage, broken kernels, foreign material) that triggered a quality premium or discount adjustment. Aligns with USDA GIPSA grading factor codes.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReference rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference' ;
    rdfs:comment 'Adjustment number of the reversing price adjustment document if this record has been reversed. Populated when adjustment_status is \'reversed\'. Supports audit trail and double-entry accounting integrity.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasisId rdf:type rdf:Property ;
    rdfs:label 'Price Basis Id' ;
    rdfs:comment 'Primary key for price_basis' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketPriceId rdf:type rdf:Property ;
    rdfs:label 'Market Price Id' ;
    rdfs:comment 'Foreign key linking to sales.market_price. Business justification: A price basis record in grain trading references a specific market price source (exchange settlement, WASDE reference). Linking price_basis to market_price enables automated basis calculation, price f' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketPrice .

ind:applicableContractTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Contract Types' ;
    rdfs:comment 'Comma-separated list of contract types for which this price basis is valid (e.g., \'basis_contract,hedge_to_arrive,forward_contract,spot_purchase\'). Restricts the use of this basis record to appropriate contract contexts in invoice generation. [ENUM-REF-CANDIDATE: basis_contract|hedge_to_arrive|forward_contract|spot_purchase|deferred_payment|minimum_price — promote to reference product]' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisCode rdf:type rdf:Property ;
    rdfs:label 'Basis Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this price basis configuration (e.g., CORN-CBOT-DEC, SOY-CME-MAR). Used in contract references, invoice line items, and grain elevator systems to reference the applicable pricing basis.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Basis Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the basis amount is denominated (e.g., USD for US domestic grain markets, CAD for Canadian operations). Ensures correct currency handling in multi-currency agricultural operations.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisName rdf:type rdf:Property ;
    rdfs:label 'Basis Name' ;
    rdfs:comment 'Human-readable descriptive name for the price basis (e.g., \'December Corn CBOT Basis - Central Illinois\'). Used in reports, invoices, and contract documents for clear identification of the pricing basis applied.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisStatus rdf:type rdf:Property ;
    rdfs:label 'Basis Status' ;
    rdfs:comment 'Current lifecycle status of the price basis record. Active records are eligible for invoice pricing; inactive/expired records are retained for historical reference and audit; superseded records have been replaced by a newer basis version.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the delivery location (e.g., USA, CAN, BRA). Required for international commodity contracts, COOL compliance, and cross-border agricultural trade reporting.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'Two-letter US state or Canadian province code for the delivery location (e.g., IL, IA, KS, NE). Used for regional basis analysis, USDA reporting, and state-level agricultural compliance.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulaExpression rdf:type rdf:Property ;
    rdfs:label 'Formula Expression' ;
    rdfs:comment 'For formula-based pricing methods, the mathematical expression or rule used to calculate the final price (e.g., \'CBOT_CLOSE + BASIS + FREIGHT_ALLOWANCE - MOISTURE_DISCOUNT\'). Null for non-formula pricing methods. Stored as a string expression interpreted by the pricing engine.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAllowance rdf:type rdf:Property ;
    rdfs:label 'Freight Allowance' ;
    rdfs:comment 'The freight cost component embedded in or deducted from the basis amount, expressed per unit of measure. Represents the transportation cost from the delivery location to the terminal market or export elevator. Used in FOB vs. CIF pricing reconciliation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futuresExchange rdf:type rdf:Property ;
    rdfs:label 'Futures Exchange' ;
    rdfs:comment 'The futures exchange whose contract price is used as the reference price for this basis (e.g., CBOT for corn/soybeans/wheat, CME for cattle/hogs, ICE for cotton). Null for spot_market or flat_price methods.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoApplicable rdf:type rdf:Property ;
    rdfs:label 'Gmo Applicable' ;
    rdfs:comment 'Indicates whether this price basis applies to GMO commodity (True) or non-GMO/identity-preserved commodity (False). Non-GMO commodities typically command a premium basis over standard GMO commodity prices, requiring separate basis records.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingCharge rdf:type rdf:Property ;
    rdfs:label 'Handling Charge' ;
    rdfs:comment 'The per-unit elevator or handling fee included in or deducted from the basis calculation (e.g., 0.02 USD/BU for grain elevator handling). Represents the cost of receiving, storing, and loading grain at the delivery location.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'The maximum commodity quantity (in the specified unit of measure) for which this basis applies. Basis records may be quantity-banded for volume pricing tiers. Null indicates no maximum quantity restriction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Quantity' ;
    rdfs:comment 'The minimum commodity quantity (in the specified unit of measure) required for this basis to apply. Basis levels may differ for small lots vs. full truckload or barge quantities. Null indicates no minimum quantity restriction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Moisture Adjustment Rate' ;
    rdfs:comment 'The per-unit price adjustment applied per percentage point of moisture above or below the standard moisture level (e.g., -0.0035 USD/BU per 1% moisture above 15.5% for corn). Used in weight-ticket reconciliation and invoice adjustments for grain quality discounts.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCeiling rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling' ;
    rdfs:comment 'The maximum cash price per unit of measure above which this basis will not result in an invoice price, regardless of futures movement. Null if no ceiling applies. Used in capped-price contract billing scenarios common in livestock and specialty crop markets.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceFloor rdf:type rdf:Property ;
    rdfs:label 'Price Floor' ;
    rdfs:comment 'The minimum cash price per unit of measure below which this basis will not result in an invoice price, regardless of futures movement (e.g., minimum price guarantee in minimum-price contracts). Null if no floor applies. Used in minimum-price contract billing scenarios.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'The method used to determine the commodity price for invoice calculations. Options include: futures_basis (price = futures + basis), spot_market (current cash price), formula (custom formula-driven), flat_price (fixed agreed price), basis_contract (basis locked, futures open), hedge_to_arrive (futures locked, basis open).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTestWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Standard Test Weight Lbs' ;
    rdfs:comment 'The reference test weight in pounds per bushel at which no test weight adjustment is applied (e.g., 56 lbs/BU for corn, 60 lbs/BU for soybeans, 60 lbs/BU for wheat). Deviations from this standard trigger price adjustments per test_weight_adjustment_rate.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testWeightAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Test Weight Adjustment Rate' ;
    rdfs:comment 'The per-unit price adjustment applied per pound below the standard test weight (e.g., -0.01 USD/BU per pound below 56 lbs/BU for corn). Test weight is a key quality factor in grain pricing that affects invoice amounts.' ;
    rdfs:domain ind:PriceBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivableFinancingId rdf:type rdf:Property ;
    rdfs:label 'Receivable Financing Id' ;
    rdfs:comment 'Unique system-generated identifier for each receivable financing transaction record. Primary key for the receivable_financing data product.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementId rdf:type rdf:Property ;
    rdfs:label 'Arrangement Id' ;
    rdfs:comment 'Reference to the master financing facility or framework agreement under which this individual transaction is executed. Multiple financing transactions may be grouped under a single arrangement (e.g., a revolving factoring facility).' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancingArrangement .

ind:advanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Advance Rate Pct' ;
    rdfs:comment 'The percentage of the total invoice face amount that the financing institution advances to the agricultural enterprise at disbursement. Expressed as a decimal (e.g., 0.8500 = 85%). The remaining percentage is held as a reserve until customer payment is received.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dilutionAmount rdf:type rdf:Property ;
    rdfs:label 'Dilution Amount' ;
    rdfs:comment 'Total value of credits, returns, disputes, or adjustments that reduce the collectible value of the financed receivables pool below the original face amount. Dilution is a key risk metric monitored by financing institutions and affects reserve calculations. Common in agricultural trade due to quality disputes and weight-ticket adjustments.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Date on which the financing institution transferred the advance amount to the agricultural enterprise. Represents the principal business event date for this financing transaction. Critical for cash flow reporting and seasonal liquidity management during post-harvest periods.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factoredInvoiceCount rdf:type rdf:Property ;
    rdfs:label 'Factored Invoice Count' ;
    rdfs:comment 'Number of individual AR invoices included in this financing transaction. Supports reconciliation between the financing batch and the underlying invoice pool, particularly relevant for agricultural commodity trading where multiple weight-ticket-backed invoices may be bundled.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoringFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Factoring Fee Amount' ;
    rdfs:comment 'Total fee charged by the financing institution for the receivable financing service. Includes service fees, discount charges, and any other financing costs. Recognized as a financing cost in the income statement per GAAP ASC 860 and IFRS 9.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoringFeeRatePct rdf:type rdf:Property ;
    rdfs:label 'Factoring Fee Rate Pct' ;
    rdfs:comment 'The fee rate applied to the total invoice face amount to calculate the factoring fee. Expressed as a decimal (e.g., 0.015000 = 1.5%). May be a flat rate or tiered based on invoice age, customer credit quality, or commodity type.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Code' ;
    rdfs:comment 'Internal or industry-standard code identifying the financing institution. Used for system integration, GL posting, and counterparty reporting. May correspond to a bank identifier code (BIC/SWIFT) or internal vendor code in SAP FI.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Name' ;
    rdfs:comment 'Legal name of the financial institution (bank, factor, or special purpose vehicle) to which the receivables are sold or pledged. Critical for counterparty risk management and financial statement disclosure under GAAP ASC 860 derecognition assessment.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Financing Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the receivable financing arrangement, used for communication with the financing institution and internal tracking. Corresponds to the facility or transaction reference in SAP FI or Oracle NetSuite AR modules.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingStatus rdf:type rdf:Property ;
    rdfs:label 'Financing Status' ;
    rdfs:comment 'Current lifecycle status of the receivable financing transaction, tracking progression from initiation through settlement. Values: draft (being prepared), submitted (sent to institution), approved (institution confirmed), active (funds disbursed), settled (fully reconciled), cancelled (voided).' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingType rdf:type rdf:Property ;
    rdfs:label 'Financing Type' ;
    rdfs:comment 'Classification of the receivable financing arrangement. Factoring involves outright sale of AR; invoice discounting retains collection responsibility; supply chain finance is buyer-led; asset-backed lending pledges AR as collateral; forfaiting is used for medium-term trade receivables. Common in agricultural commodity trading for seasonal cash flow management.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDerecognized rdf:type rdf:Property ;
    rdfs:label 'Is Derecognized' ;
    rdfs:comment 'Indicates whether the financed receivables have been removed from the agricultural enterprise balance sheet per GAAP ASC 860 or IFRS 9 derecognition criteria. True = receivables derecognized (off-balance-sheet); False = receivables remain on balance sheet (secured borrowing treatment).' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer (invoice obligor) has been formally notified of the assignment or sale of their receivable to the financing institution. Notification is legally required in many jurisdictions for the assignment to be enforceable against the debtor. True = notification sent; False = not yet notified.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recourseLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Recourse Limit Amount' ;
    rdfs:comment 'Maximum monetary exposure retained by the agricultural enterprise under a partial recourse arrangement. Null for full recourse or without recourse transactions. Used for contingent liability disclosure in financial statements per GAAP ASC 460.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recourseType rdf:type rdf:Property ;
    rdfs:label 'Recourse Type' ;
    rdfs:comment 'Defines the credit risk allocation between the agricultural enterprise and the financing institution. Full recourse: enterprise bears all credit risk; partial recourse: shared risk up to a defined limit; without recourse: financing institution assumes all credit risk. Determines whether the receivable qualifies for derecognition under GAAP ASC 860 and IFRS 9.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'Amount withheld by the financing institution as a reserve against potential dilution, disputes, or credit losses. Released to the agricultural enterprise upon confirmed customer payment. Equals total_invoice_face_amount minus advance_amount minus factoring_fee_amount.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Released Amount' ;
    rdfs:comment 'Amount of the withheld reserve that has been remitted back to the agricultural enterprise following confirmed customer payment collection by the financing institution. Supports reconciliation of the total financing cycle.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of the settlement process for this financing transaction. Tracks whether the financing institution has remitted reserve amounts back to the enterprise following customer payment collection. Overdue indicates maturity_date has passed without full settlement.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInvoiceFaceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Face Amount' ;
    rdfs:comment 'Aggregate face value of all AR invoices included in this financing transaction before any advance rate, fees, or deductions. Represents the gross receivables pool being financed. Used for GAAP ASC 860 derecognition and IFRS 9 impairment calculations.' ;
    rdfs:domain ind:ReceivableFinancing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Primary key for revenue_recognition' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonCreditId rdf:type rdf:Property ;
    rdfs:label 'Carbon Credit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_credit. Business justification: ASC 606 / IFRS 15 revenue recognition for carbon credit sales requires tracing each recognition event to the specific carbon credit instrument being recognized. revenue_recognition has commodity_lot_r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonCredit .

ind:originalEventRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Event Revenue Recognition Id' ;
    rdfs:comment 'For reversal or adjustment events, references the original revenue_recognition_event_id that is being reversed or corrected. Enables audit trail linkage between original recognition and its reversal/correction entries.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Reference to the specific performance obligation within the contract that this recognition event satisfies. Under ASC 606/IFRS 15, revenue is recognized when or as each performance obligation is satisfied.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The portion of the transaction price that has been invoiced or received but not yet recognized as revenue, pending future performance obligation satisfaction. Recorded as a contract liability on the balance sheet. Common in multi-season crop contracts and prepaid input supply agreements.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'The document number or journal entry reference generated in the General Ledger system (SAP S/4HANA) when the revenue recognition amount was posted. Enables direct drill-through from the recognition event to the GL journal entry for audit and reconciliation purposes.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContractModification rdf:type rdf:Property ;
    rdfs:label 'Is Contract Modification' ;
    rdfs:comment 'Indicates whether this revenue recognition event was triggered by or resulted from a contract modification (change order, price renegotiation, scope change). Contract modifications require reassessment of performance obligations and transaction price allocation under ASC 606/IFRS 15.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableConsiderationConstrained rdf:type rdf:Property ;
    rdfs:label 'Is Variable Consideration Constrained' ;
    rdfs:comment 'Indicates whether the variable consideration estimate included in this recognition event has been constrained (i.e., limited to the amount highly probable of not resulting in a significant revenue reversal). Required disclosure under ASC 606 constraint guidance for agricultural price-variable contracts.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceObligationSatisfiedPct rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Satisfied Pct' ;
    rdfs:comment 'For over-time revenue recognition, the cumulative percentage of the performance obligation satisfied as of this recognition event date. Expressed as a percentage (0.00 to 100.00). Used to calculate the recognized amount for long-term contract farming, agronomy services, and multi-season supply agreements.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionEventDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Event Date' ;
    rdfs:comment 'The business date on which the revenue recognition event occurred — i.e., the date the performance obligation was satisfied and revenue became recognizable. For commodity sales, this is typically the title transfer date per the Bill of Lading (BOL) or weight ticket.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event. \'Pending\' indicates awaiting trigger conditions; \'recognized\' indicates revenue has been posted to GL; \'deferred\' indicates revenue is held pending future obligation satisfaction; \'reversed\' indicates a prior recognition has been corrected; \'cancelled\' indicates the event was voided.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTrigger rdf:type rdf:Property ;
    rdfs:label 'Recognition Trigger' ;
    rdfs:comment 'The specific business event or condition that triggered this revenue recognition event. Identifies whether recognition was triggered by physical delivery confirmation, legal title transfer (commodity), contract milestone completion, period-end proportional allocation, consignment sale by the buyer, or customer invoice acceptance. [ENUM-REF-CANDIDATE: delivery_confirmed|title_transfer|contract_milestone|period_end_allocation|consignment_sale|invoice_acceptance — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Classification of the revenue recognition method applied to this event. \'Point_in_time\' applies to standard crop commodity deliveries; \'over_time\' applies to long-term service or contract farming arrangements; \'bill_and_hold\' applies where goods are invoiced but not yet shipped; \'consignment_release\' applies when consigned agricultural goods are sold by the consignee; \'commodity_title_transfer\' applies to grain elevator and commodity exchange transactions where title transfer timing governs recognition.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The gross monetary amount of revenue recognized in this event, expressed in the transaction currency. For agricultural commodity sales, this reflects the agreed contract price multiplied by the delivered quantity (weight-ticket reconciled). Core financial metric for revenue reporting under ASC 606/IFRS 15.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'The total transaction price allocated to this performance obligation as determined under ASC 606 Step 3 (Determine Transaction Price). Includes fixed consideration and any variable consideration estimates. For commodity contracts, reflects the agreed price per unit multiplied by contracted quantity.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'The estimated amount of variable consideration included in the transaction price for this recognition event. Variable consideration in agriculture includes price adjustments for commodity grade/quality premiums or discounts, volume rebates, weather-contingent pricing, and harvest yield-based true-ups. Constrained to the amount that is highly probable of not reversing per ASC 606 constraint guidance.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementStatementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Statement Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each settlement statement record in the lakehouse silver layer. Primary key for the settlement_statement data product.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseId rdf:type rdf:Property ;
    rdfs:label 'Lease Id' ;
    rdfs:comment 'Foreign key linking to land.lease. Business justification: Crop-share and flex-rent lease settlements require linking settlement statements to the underlying lease to calculate landlord/tenant payment splits, verify flex-rent trigger prices, and produce lease' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lease .

ind:creditsIssuedAmount rdf:type rdf:Property ;
    rdfs:label 'Credits Issued Amount' ;
    rdfs:comment 'Total value of credit memos, price adjustments, quality deductions reversals, and other credits applied to the producer\'s account during the settlement period.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The channel through which the settlement statement was delivered to the producer. Email: electronic delivery; Postal Mail: physical mailing; EDI: electronic data interchange for cooperative/elevator systems; Portal: producer self-service web portal; Fax: facsimile transmission.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryingDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Drying Deduction Amount' ;
    rdfs:comment 'Total grain drying fees deducted from the producer\'s settlement for moisture reduction services applied to delivered grain during the settlement period.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Deduction Amount' ;
    rdfs:comment 'Total grain handling and elevation fees deducted from the producer\'s settlement for receiving, conditioning, and loading-out services at the elevator during the settlement period.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total gross amount of all invoices and charges billed to the producer during the settlement period, before credits, deductions, or payments. Represents the sum of commodity purchases, services, and other charges.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'The definitive net amount due to or from the producer after applying opening balance, invoiced amounts, credits, payments, and all deductions. Positive value indicates amount owed by producer; negative value indicates amount payable to producer.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The accounts receivable (AR) balance carried forward from the prior settlement period for this producer or account. Represents the starting point for the current period reconciliation.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Total of all other miscellaneous deductions applied during the settlement period not captured in storage, drying, or handling categories, such as checkoff assessments, inspection fees, or loan repayments.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patronageDividendAmount rdf:type rdf:Property ;
    rdfs:label 'Patronage Dividend Amount' ;
    rdfs:comment 'The cooperative patronage dividend or equity distribution allocated to the producer-member for the settlement period, based on their proportional volume of business with the cooperative. Applicable only for cooperative settlement types.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentsReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payments Received Amount' ;
    rdfs:comment 'Total cash payments, ACH transfers, wire transfers, and check payments received from or applied to the producer\'s account during the settlement period.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the settlement cycle frequency. Daily: grain elevator daily settlements; Weekly: livestock auction settlements; Monthly: standard AR billing; Seasonal: harvest-season settlements; Crop Year: annual cooperative patronage distributions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Producer Account Number' ;
    rdfs:comment 'The externally-known account or member number assigned to the producer or cooperative member, as printed on the settlement statement. Used for producer self-service reconciliation and grain elevator licensing compliance.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producerName rdf:type rdf:Property ;
    rdfs:label 'Producer Name' ;
    rdfs:comment 'Legal name of the agricultural producer, cooperative, grain elevator, or commodity buyer as it appears on the settlement statement. Retained on the statement for document integrity and regulatory compliance.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The official business date on which the settlement statement was generated and issued to the producer or counterparty. This is the principal real-world event date for the settlement document.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for the settlement statement as printed on the document and referenced in producer communications. Follows the format SS-YYYY-NNNNNN.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle state of the settlement statement. Draft: in preparation; Issued: sent to producer; Disputed: producer has raised a discrepancy; Settled: fully paid and reconciled; Cancelled/Void: reversed or invalidated.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Storage Deduction Amount' ;
    rdfs:comment 'Total grain storage fees deducted from the producer\'s settlement for commodity storage at the elevator or warehouse facility during the settlement period. A key deduction category in grain elevator settlements.' ;
    rdfs:domain ind:SettlementStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of commodity or product covered by this settlement statement, expressed in the unit of measure specified in quantity_uom. Supports weight-ticket reconciliation and bushel/metric ton settlement calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerAssetId rdf:type rdf:Property ;
    rdfs:label 'Trailer Asset Id' ;
    rdfs:comment 'License plate number or fleet identifier of the trailer carrying the commodity. Separate from truck ID as trailers may be interchanged. Used for tare weight lookup and load traceability.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:brokenKernelsPct rdf:type rdf:Property ;
    rdfs:label 'Broken Kernels Pct' ;
    rdfs:comment 'Percentage of broken corn kernels and foreign material (BCFM) in a corn sample, as defined by USDA FGIS grading standards. A key grade factor for corn that drives price discounts and grade assignment.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damagePct rdf:type rdf:Property ;
    rdfs:label 'Damage Pct' ;
    rdfs:comment 'Percentage of grain kernels that are heat-damaged, mold-damaged, sprouted, or otherwise damaged as determined by USDA FGIS inspection. A primary grade factor affecting commodity grade assignment and price discounts.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full name of the truck driver delivering the commodity. Required for chain-of-custody documentation, FSMA traceability, and facility access records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSplitLoad rdf:type rdf:Property ;
    rdfs:label 'Is Split Load' ;
    rdfs:comment 'Indicates whether this weight ticket represents a split-load delivery where a single truck carries commodity from multiple fields, farms, or ownership lots. When True, multiple weight tickets may share the same truck/trailer ID and require proportional allocation.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightBu rdf:type rdf:Property ;
    rdfs:label 'Net Weight Bu' ;
    rdfs:comment 'Net commodity weight converted to bushels (BU) using USDA standard test weight per bushel for the specific commodity (e.g., 56 lbs/bu for corn, 60 lbs/bu for wheat). Used for grain pricing, settlement, and WASDE reporting. Null for livestock and cotton.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Contracted or market price per unit of measure (per bushel for grain, per CWT for livestock, per pound for cotton) applied to this weight ticket for settlement calculation. Sourced from the applicable sales order or commodity contract.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleDatetime rdf:type rdf:Property ;
    rdfs:label 'Scale Datetime' ;
    rdfs:comment 'The certified date and time the commodity was weighed on the certified scale. This is the principal business event timestamp and the authoritative quantity determination moment per state weights-and-measures law. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Externally-known, human-readable certified scale ticket number assigned by the elevator or receiving facility. Used for reconciliation against invoice lines, grain settlement documents, and USDA FGIS inspection records. Unique within a facility.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle state of the weight ticket. \'draft\' = captured but not yet certified; \'open\' = certified and awaiting settlement; \'settled\' = reconciled to an invoice line and payment; \'voided\' = cancelled/corrected; \'disputed\' = under quality or quantity dispute.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique system-generated identifier for the bad debt write-off transaction record in the accounts receivable (AR) ledger.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDisputeId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dispute Id' ;
    rdfs:comment 'Foreign key linking to invoice.dispute. Business justification: write_off.dispute_case_reference is a denormalized string reference to the dispute record. Bad debt write-offs in agricultural AR frequently follow failed dispute resolution. Normalizing to invoice_di' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:allowanceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Allowance Account Code' ;
    rdfs:comment 'GL account code for the Allowance for Doubtful Accounts contra-asset account offset entry. Under the allowance method, the write-off reduces this account rather than directly expensing. Required for GAAP ASC 310-10 indirect write-off method.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountFunctional rdf:type rdf:Property ;
    rdfs:label 'Amount Functional' ;
    rdfs:comment 'Write-off amount converted to the company\'s functional (reporting) currency using the exchange rate at the time of write-off. Required for GAAP/IFRS financial statement reporting and GL posting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role identifier of the individual or committee that authorized the write-off per the SOX-compliant delegation of authority matrix. Required for audit trail and internal controls documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Hierarchical approval tier required and obtained for this write-off based on the amount threshold in the delegation of authority policy. Higher write-off amounts require escalation to senior financial officers per SOX controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReference rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Reference' ;
    rdfs:comment 'External collection agency case or account reference number when the debt was referred to a third-party collection agency prior to write-off. Supports recovery tracking and agency fee reconciliation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceList rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference List' ;
    rdfs:comment 'Comma-separated list of invoice numbers included in this write-off transaction when multiple invoices are consolidated into a single write-off event. Supports AR aging reconciliation and audit trail. For single-invoice write-offs, contains the single invoice number.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Tax Deductible' ;
    rdfs:comment 'Indicates whether the write-off qualifies as a tax-deductible bad debt expense under applicable tax law. Drives tax provision calculations and deferred tax asset recognition.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'Total face value of the original invoice(s) at the time of issuance before any partial payments or credits. Enables calculation of partial write-off percentage and supports credit risk analytics.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialPaymentApplied rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Applied' ;
    rdfs:comment 'Total payments previously received and applied against the invoice(s) prior to the write-off. The net uncollectable balance equals original_invoice_amount minus partial_payment_applied.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Categorized business reason for the bad debt write-off. Agriculture-specific reasons include crop_failure_hardship (customer unable to pay due to crop loss event) and dispute_settlement (negotiated resolution). Required for GAAP bad debt expense classification and management reporting. [ENUM-REF-CANDIDATE: bankruptcy|insolvency|crop_failure_hardship|dispute_settlement|statute_of_limitations|customer_deceased|other — promote to reference product]' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Free-text narrative providing additional context for the write-off reason. For crop failure hardship cases, may include crop type, affected season, and loss event reference. Supports audit documentation and SOX compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'Total amount subsequently recovered from the customer after the write-off was posted. Populated when recovery_flag is True. Used to record bad debt recovery income and adjust net bad debt expense reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which the recovered amount was received from the customer. Used for period-accurate bad debt recovery income recognition and cash flow reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Flag' ;
    rdfs:comment 'Indicates whether any subsequent recovery of the written-off amount has been initiated or received. When True, triggers monitoring of recovery transactions and potential reversal of bad debt expense per GAAP.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this write-off has been reversed (e.g., due to subsequent full payment or erroneous posting). When True, the write-off_status should reflect \'reversed\' and a reversal document reference should be present.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Impact Amount' ;
    rdfs:comment 'Estimated tax deduction or tax benefit amount associated with the bad debt write-off. Relevant for income tax reporting where bad debt deductions are allowable under applicable tax regulations.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The business event date on which the bad debt write-off was formally executed and recognized. Used for GAAP bad debt expense recognition in the correct accounting period.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the write-off transaction. Used in audit trails, SOX compliance documentation, and GL posting references. Format: WO-YYYY-NNNNNN.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle state of the write-off transaction within the SOX-compliant approval and GL posting workflow. Tracks progression from initial submission through approval, GL posting, and any subsequent reversal.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bmpCategory rdf:type rdf:Property ;
    rdfs:label 'Bmp Category' ;
    rdfs:comment 'Best Management Practice (BMP) environmental category that this conservation practice addresses: soil_health, water_quality, nutrient_management, pest_management, wildlife habitat, or carbon_sequestration. Supports environmental stewardship reporting.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Carbon Credit Eligible' ;
    rdfs:comment 'Indicates whether this conservation practice qualifies for carbon credit or greenhouse gas offset programs (e.g., cover crops, no-till, agroforestry) under ISCC or voluntary carbon market standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the conservation practice was officially certified as meeting USDA NRCS or program standards by the certifying agency.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifyingAgency rdf:type rdf:Property ;
    rdfs:label 'Certifying Agency' ;
    rdfs:comment 'Name of the agency or organization that certified the conservation practice as meeting applicable standards (e.g., USDA NRCS, state department of agriculture, third-party certifier, GLOBALG.A.P.).' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Share Amount' ;
    rdfs:comment 'Dollar amount of government cost-share payment received or approved for this conservation practice under the applicable USDA program. Expressed in USD.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareContractNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Share Contract Number' ;
    rdfs:comment 'Official USDA NRCS or FSA contract number associated with the cost-share program agreement funding this conservation practice. Used for program compliance tracking and payment reconciliation.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareProgram rdf:type rdf:Property ;
    rdfs:label 'Cost Share Program' ;
    rdfs:comment 'USDA cost-share or incentive program funding this conservation practice: EQIP (Environmental Quality Incentives Program), CSP (Conservation Stewardship Program), RCPP (Regional Conservation Partnership Program), ACEP (Agricultural Conservation Easement Program), REAP (Rural Energy for America Program), or none for self-funded practices.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisFeatureCode rdf:type rdf:Property ;
    rdfs:label 'Gis Feature Code' ;
    rdfs:comment 'Esri ArcGIS feature identifier linking this conservation practice record to its spatial geometry (polygon, polyline, or point) in the GIS layer for mapping and spatial analysis.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Reference rdf:type rdf:Property ;
    rdfs:label 'Iso14001 Reference' ;
    rdfs:comment 'Reference to the ISO 14001 Environmental Management System clause or environmental objective that this conservation practice supports (e.g., clause 6.1.2 Environmental Aspects, clause 8.1 Operational Planning).' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance activity performed on this conservation practice to ensure continued effectiveness and compliance with NRCS practice standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceRequired rdf:type rdf:Property ;
    rdfs:label 'Maintenance Required' ;
    rdfs:comment 'Indicates whether this conservation practice requires scheduled maintenance activities (e.g., annual inspection, vegetation management, structural repair) to maintain its effectiveness and program compliance.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next required maintenance inspection or activity for this conservation practice, supporting proactive maintenance planning and program compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organicProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Organic Program Eligible' ;
    rdfs:comment 'Indicates whether this conservation practice is compatible with and supports USDA National Organic Program (NOP) certification requirements for organic production systems.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Practice Area Acres' ;
    rdfs:comment 'Total area covered by the conservation practice measured in acres. Used for area-based practices such as cover crops, filter strips, and nutrient management plans.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practiceCategory rdf:type rdf:Property ;
    rdfs:label 'Practice Category' ;
    rdfs:comment 'USDA NRCS classification category grouping the conservation practice by discipline: agronomy (soil/crop management), engineering (structural), forestry, range, or wildlife.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceCode rdf:type rdf:Property ;
    rdfs:label 'Practice Code' ;
    rdfs:comment 'Official USDA Natural Resources Conservation Service (NRCS) practice standard code identifying the type of conservation practice (e.g., 340 Cover Crop, 412 Grassed Waterway, 590 Nutrient Management, 393 Filter Strip, 484 Mulching).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Practice Effectiveness Rating' ;
    rdfs:comment 'Qualitative assessment of the conservation practice effectiveness in addressing the targeted resource concern, as evaluated during NRCS certification or periodic review (high, medium, low, not_evaluated).' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLifespanYears rdf:type rdf:Property ;
    rdfs:label 'Practice Lifespan Years' ;
    rdfs:comment 'Expected operational lifespan of the conservation practice in years as defined by USDA NRCS practice standards (e.g., cover crop annual, grassed waterway 10 years, terrace 25 years).' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:practiceLinearFeet rdf:type rdf:Property ;
    rdfs:label 'Practice Linear Feet' ;
    rdfs:comment 'Length of the conservation practice measured in linear feet. Used for linear practices such as grassed waterways, filter strips, riparian buffers, and terraces.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practiceName rdf:type rdf:Property ;
    rdfs:label 'Practice Name' ;
    rdfs:comment 'Official USDA NRCS descriptive name of the conservation practice corresponding to the practice code (e.g., Cover Crop, Grassed Waterway, Nutrient Management Plan, Filter Strip).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceNotes rdf:type rdf:Property ;
    rdfs:label 'Practice Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, site-specific conditions, deviations from standard specifications, or observations recorded during installation or certification of the conservation practice.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Status' ;
    rdfs:comment 'Current lifecycle status of the conservation practice: planned (approved but not yet installed), installed (physically implemented), certified (verified by certifying agency), expired (past lifespan or contract end), or cancelled (discontinued before completion).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producerCost rdf:type rdf:Property ;
    rdfs:label 'Producer Cost' ;
    rdfs:comment 'Net cost borne by the producer after deducting cost-share payments from total practice cost. Calculated as total_practice_cost minus cost_share_amount. Supports farm financial planning and CAPEX/OPEX reporting.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceConcern rdf:type rdf:Property ;
    rdfs:label 'Resource Concern' ;
    rdfs:comment 'USDA NRCS-defined resource concern that this conservation practice addresses (e.g., soil erosion by water, soil erosion by wind, excess nutrients in surface water, degraded plant condition). Aligns with NRCS Resource Concern Inventory.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPracticeCost rdf:type rdf:Property ;
    rdfs:label 'Total Practice Cost' ;
    rdfs:comment 'Total actual cost incurred to install and implement the conservation practice, including materials, labor, and equipment. Used to calculate net producer cost after cost-share payments.' ;
    rdfs:domain ind:ConservationPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:easementId rdf:type rdf:Property ;
    rdfs:label 'Easement Id' ;
    rdfs:comment 'Unique system-generated identifier for the easement record. Primary key for the land.easement data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Easement .

ind:annualPayment rdf:type rdf:Property ;
    rdfs:label 'Annual Payment' ;
    rdfs:comment 'Annual recurring payment made to the grantor for the easement right, expressed in US dollars. Applicable for term easements with periodic compensation structures. Used for OPEX budgeting and financial planning in Granular Farm Management.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaAcres rdf:type rdf:Property ;
    rdfs:label 'Area Acres' ;
    rdfs:comment 'Total land area encumbered by the easement, measured in acres. Applicable for area-based easements such as conservation easements or drainage easements. May be null for linear corridor easements defined by width and length.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Total monetary compensation paid to the grantor (landowner) for granting the easement rights, expressed in US dollars. Includes one-time payments and the present value of any annualized payments. Relevant for CAPEX tracking and land asset valuation.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationProgram rdf:type rdf:Property ;
    rdfs:label 'Conservation Program' ;
    rdfs:comment 'Name of the USDA or government conservation program under which the easement was established, if applicable. Examples include ACEP (Agricultural Conservation Easement Program), WRP (Wetland Reserve Program), or RCPP (Regional Conservation Partnership Program). Null if not a conservation easement.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorWidthFt rdf:type rdf:Property ;
    rdfs:label 'Corridor Width Ft' ;
    rdfs:comment 'Width of the easement corridor in feet, applicable for linear easements such as utility rights-of-way, pipeline easements, and road access corridors. Used in conjunction with easement_length_ft to calculate the encumbered area.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:easementNumber rdf:type rdf:Property ;
    rdfs:label 'Easement Number' ;
    rdfs:comment 'Externally-known document or instrument number assigned by the county recorder or title company at the time of recording. Used for title due diligence and cross-referencing recorded documents.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easementStatus rdf:type rdf:Property ;
    rdfs:label 'Easement Status' ;
    rdfs:comment 'Current lifecycle status of the easement. Active indicates the easement is in force; expired indicates the term has lapsed; terminated indicates early legal termination; pending indicates recorded but not yet effective; suspended indicates temporarily inactive due to legal dispute or review.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easementType rdf:type rdf:Property ;
    rdfs:label 'Easement Type' ;
    rdfs:comment 'Classification of the easement by its legal purpose. Common types include right-of-way (road/rail corridor), utility (power/telecom lines), drainage (water flow), conservation (land preservation), access (ingress/egress), and pipeline (oil/gas/water). [ENUM-REF-CANDIDATE: right_of_way|utility|drainage|conservation|access|pipeline|irrigation|flood_control|scenic|agricultural_preservation — promote to reference product]' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Required' ;
    rdfs:comment 'Indicates whether an environmental impact review or assessment is required for activities within or adjacent to the easement area. True = environmental review required per EPA or state agency mandate; False = no review required.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gisGeometryRef rdf:type rdf:Property ;
    rdfs:label 'Gis Geometry Ref' ;
    rdfs:comment 'Reference identifier linking to the easement boundary geometry stored in Esri ArcGIS. Enables spatial analysis, field mapping, and RTK-accurate boundary visualization in the John Deere Operations Center and ArcGIS GIS platform.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisLayerName rdf:type rdf:Property ;
    rdfs:label 'Gis Layer Name' ;
    rdfs:comment 'Name of the ArcGIS feature layer or map service layer containing the easement geometry. Used to locate and render the easement boundary in GIS-based land use planning and environmental monitoring workflows.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:granteeName rdf:type rdf:Property ;
    rdfs:label 'Grantee Name' ;
    rdfs:comment 'Full legal name of the party receiving the easement right — typically a utility company, government agency, neighboring landowner, or conservation organization. Required for title due diligence and regulatory compliance.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:granteeType rdf:type rdf:Property ;
    rdfs:label 'Grantee Type' ;
    rdfs:comment 'Classification of the grantee entity receiving the easement right. Supports analytics on easement exposure by counterparty category and regulatory reporting. [ENUM-REF-CANDIDATE: utility_company|government_agency|neighbor|conservation_org|railroad|pipeline_company|irrigation_district|municipality — promote to reference product]' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'Full legal name of the party granting the easement right — typically the landowner or agricultural operator who owns the burdened parcel. Required for title due diligence and legal enforceability.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPerpetual rdf:type rdf:Property ;
    rdfs:label 'Is Perpetual' ;
    rdfs:comment 'Indicates whether the easement is perpetual (no expiration date) or term-limited. True = perpetual easement with no expiration; False = term easement with a defined expiration date.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoredDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitored Date' ;
    rdfs:comment 'Date of the most recent stewardship monitoring visit or compliance inspection conducted on the easement area. Required for conservation easement compliance reporting to USDA NRCS and GFSI certification bodies.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalDescription rdf:type rdf:Property ;
    rdfs:label 'Legal Description' ;
    rdfs:comment 'Formal legal description of the easement area as recorded in the deed or instrument, using metes and bounds, lot/block, or Public Land Survey System (PLSS) section-township-range notation. Required for title due diligence and legal enforceability.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthFt rdf:type rdf:Property ;
    rdfs:label 'Length Ft' ;
    rdfs:comment 'Total linear length of the easement corridor in feet. Used for linear easements such as utility lines, pipelines, and road rights-of-way. Combined with corridor_width_ft to determine total encumbered area.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedUses rdf:type rdf:Property ;
    rdfs:label 'Permitted Uses' ;
    rdfs:comment 'Narrative description of land uses explicitly permitted within the easement area by the grantor. May include grazing, crop production, or recreational access where not restricted by the easement terms. Supports land use planning and compliance audits.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingCounty rdf:type rdf:Property ;
    rdfs:label 'Recording County' ;
    rdfs:comment 'Name of the county or jurisdiction where the easement instrument was officially recorded. Required for title due diligence and regulatory compliance reporting.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingDate rdf:type rdf:Property ;
    rdfs:label 'Recording Date' ;
    rdfs:comment 'Date the easement instrument was officially recorded with the county recorder or relevant land registry authority. Establishes the legal priority and effective date of the encumbrance.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordingState rdf:type rdf:Property ;
    rdfs:label 'Recording State' ;
    rdfs:comment 'Two-letter US state code (e.g., IA, IL, KS) where the easement instrument was recorded. Used for jurisdictional compliance and regulatory reporting to USDA, EPA, and state agricultural agencies.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionsDescription rdf:type rdf:Property ;
    rdfs:label 'Restrictions Description' ;
    rdfs:comment 'Narrative description of land use restrictions imposed by the easement on the grantor\'s parcel. Includes prohibited activities such as construction, tillage, chemical application, or tree removal within the easement corridor. Critical for crop planning, BMP compliance, and GLOBALG.A.P. certification.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review or monitoring inspection of the easement, particularly for conservation easements requiring annual stewardship monitoring per USDA NRCS requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleInsurancePolicy rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Policy' ;
    rdfs:comment 'Policy number of the title insurance policy that covers this easement encumbrance. Used for risk management, title due diligence, and insurance claims processing.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Flag' ;
    rdfs:comment 'Indicates whether an active easement violation or encroachment has been identified on this easement. True = violation or encroachment currently under investigation or remediation; False = no known violation.' ;
    rdfs:domain ind:Easement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:farmManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Farm Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Farm managers are employees; the denormalized farm_manager_name text field should be replaced with a proper FK to employee for org chart reporting, manager accountability, performance management, and ' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cluIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clu Identifier' ;
    rdfs:comment 'USDA FSA Common Land Unit (CLU) identifier linking this farm unit to the official USDA geospatial land unit registry. CLU is the smallest unit of land with a permanent, contiguous boundary used for FSA program administration and acreage reporting.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationProgramEnrollment rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Enrollment' ;
    rdfs:comment 'Name or code of USDA conservation programs in which this farm unit is enrolled (e.g., CRP, EQIP, CSP, RCPP). Supports BMP compliance tracking, conservation payment eligibility, and ISO 14001 environmental management reporting.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Name of the county in which the majority of this farm unit\'s land is located. Required for FSA county office assignment, crop insurance county-level rate determination, and USDA program administration.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropInsuranceUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Crop Insurance Unit Number' ;
    rdfs:comment 'Risk Management Agency (RMA) assigned crop insurance unit number linking this farm unit to its crop insurance policy structure. Used for indemnity calculations, acreage reporting, and production history tracking under USDA RMA programs.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA CO module cost center code assigned to this farm unit for enterprise financial management, OPEX/CAPEX allocation, and profitability analysis. Links farm unit operations to the general ledger for enterprise budgeting.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Profit Center Code' ;
    rdfs:comment 'SAP S/4HANA CO module profit center code for this farm unit, enabling enterprise-level profitability analysis, EBITDA reporting, and ROI tracking at the farm unit level.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farmType rdf:type rdf:Property ;
    rdfs:label 'Farm Type' ;
    rdfs:comment 'Classification of the farm unit by primary production system. Drives enterprise budgeting templates, crop insurance unit structuring, and FSA program eligibility. [ENUM-REF-CANDIDATE: grain|livestock|mixed|specialty_crop|orchard|vegetable|aquaculture|dairy|poultry — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farmUnitName rdf:type rdf:Property ;
    rdfs:label 'Farm Unit Name' ;
    rdfs:comment 'Human-readable name assigned to the farm unit, typically reflecting the operating entity or geographic identity of the farm (e.g., \'Sunrise Grain Farm\', \'Heartland Livestock Unit\'). Used in reporting, FSA program enrollment, and enterprise budgeting.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmisReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Fmis Reference Code' ;
    rdfs:comment 'External reference identifier for this farm unit in the Farm Management Information System (FMIS), such as Granular Farm Management or Climate FieldView. Enables cross-system data integration and operational data lineage tracking.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaCountyCode rdf:type rdf:Property ;
    rdfs:label 'Fsa County Code' ;
    rdfs:comment 'USDA FSA numeric county code for the county office administering this farm unit. Combined with FSA state code and farm number to form the complete FSA farm identifier for program enrollment and payment tracking.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaFarmNumber rdf:type rdf:Property ;
    rdfs:label 'Fsa Farm Number' ;
    rdfs:comment 'USDA Farm Service Agency (FSA) assigned farm number uniquely identifying this farm unit within the FSA county office system. Required for FSA program enrollment, crop insurance unit structuring, and USDA program payment tracking.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaStateCode rdf:type rdf:Property ;
    rdfs:label 'Fsa State Code' ;
    rdfs:comment 'USDA FSA numeric state code assigned to the state where this farm unit is registered. Used in conjunction with FSA county code and farm number for unique FSA record identification and program payment routing.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaTractNumber rdf:type rdf:Property ;
    rdfs:label 'Fsa Tract Number' ;
    rdfs:comment 'USDA FSA tract number associated with this farm unit, identifying the contiguous block of land under common ownership or control within the FSA farm. Used for FSA program eligibility, acreage reporting, and USDA payment calculations.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisBoundaryReference rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary Reference' ;
    rdfs:comment 'Reference identifier or URL to the GIS polygon boundary layer for this farm unit in Esri ArcGIS or John Deere Operations Center. Enables RTK-accurate field mapping, GPS positioning, and spatial analytics for precision agriculture applications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationType rdf:type rdf:Property ;
    rdfs:label 'Irrigation Type' ;
    rdfs:comment 'Primary irrigation method employed on this farm unit. Informs water resource management planning, evapotranspiration (ET) calculations, water use efficiency reporting, and USDA conservation program eligibility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasedAcres rdf:type rdf:Property ;
    rdfs:label 'Leased Acres' ;
    rdfs:comment 'Total acres of land under cash rent or crop share lease agreements within this farm unit. Supports OPEX planning, lease liability reporting under IFRS 16/ASC 842, and FSA program eligibility determination.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Status' ;
    rdfs:comment 'Current USDA National Organic Program (NOP) certification status of the farm unit. Drives premium pricing, market channel eligibility, input restrictions, and compliance reporting requirements under USDA NOP regulations.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownedAcres rdf:type rdf:Property ;
    rdfs:label 'Owned Acres' ;
    rdfs:comment 'Total acres of land owned outright by the operating entity within this farm unit. Supports land asset valuation, CAPEX planning, and differentiation from leased land in enterprise financial reporting.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWatershed rdf:type rdf:Property ;
    rdfs:label 'Primary Watershed' ;
    rdfs:comment 'Name or HUC (Hydrologic Unit Code) of the primary watershed in which this farm unit is located. Used for EPA water quality compliance, BMP planning, conservation program eligibility, and environmental monitoring under ISO 14001.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tillagePractice rdf:type rdf:Property ;
    rdfs:label 'Tillage Practice' ;
    rdfs:comment 'Predominant tillage practice employed on this farm unit. Supports soil health management, carbon sequestration reporting, BMP compliance, and USDA conservation program eligibility assessments.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOperatedAcres rdf:type rdf:Property ;
    rdfs:label 'Total Operated Acres' ;
    rdfs:comment 'Total land area operated by this farm unit in acres, encompassing both owned and leased parcels. Used for FSA acreage reporting, crop insurance unit sizing, enterprise budgeting, and USDA program payment calculations.' ;
    rdfs:domain ind:FarmUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arcgisFeatureCode rdf:type rdf:Property ;
    rdfs:label 'Arcgis Feature Code' ;
    rdfs:comment 'Integration key referencing the corresponding feature object ID in the Esri ArcGIS geodatabase. Enables bidirectional synchronization between the lakehouse silver layer and the authoritative GIS system of record.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectDirection rdf:type rdf:Property ;
    rdfs:label 'Aspect Direction' ;
    rdfs:comment 'Predominant compass direction that the field slope faces, derived from DEM analysis in Esri ArcGIS. Influences solar radiation exposure, frost pocket risk, and crop variety selection. [ENUM-REF-CANDIDATE: N|NE|E|SE|S|SW|W|NW|flat — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Boundary Effective Date' ;
    rdfs:comment 'Date from which the current boundary version is considered authoritative and operationally active. Used for temporal field geometry queries and FSA acreage compliance reporting.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boundaryGeojson rdf:type rdf:Property ;
    rdfs:label 'Boundary Geojson' ;
    rdfs:comment 'GeoJSON-encoded polygon or multipolygon representing the RTK-accurate field boundary geometry sourced from Esri ArcGIS. Stores the current active boundary version. Supports FSA compliance boundary reporting and precision VRA zone delineation.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryVersion rdf:type rdf:Property ;
    rdfs:label 'Boundary Version' ;
    rdfs:comment 'Monotonically incrementing version number of the field boundary geometry, supporting temporal boundary change tracking for FSA compliance and historical spatial analysis. Incremented each time the boundary is updated in ArcGIS.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the field centroid in decimal degrees (WGS84), derived from RTK-accurate boundary geometry. Used for weather data integration, GIS spatial queries, and precision agriculture applications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the field centroid in decimal degrees (WGS84), derived from RTK-accurate boundary geometry. Used for weather data integration, GIS spatial queries, and precision agriculture applications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationPracticeCode rdf:type rdf:Property ;
    rdfs:label 'Conservation Practice Code' ;
    rdfs:comment 'USDA NRCS conservation practice standard code (e.g., 340 Cover Crop, 412 Grassed Waterway) applied to the field. Supports BMP (Best Management Practices) compliance tracking, EQIP program reporting, and ISO 14001 environmental management.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drainageClass rdf:type rdf:Property ;
    rdfs:label 'Drainage Class' ;
    rdfs:comment 'USDA NRCS standard drainage class describing the natural drainage condition of the field\'s dominant soil. Drives tile drainage planning, irrigation scheduling, and BMP selection. [ENUM-REF-CANDIDATE: excessively_drained|well_drained|moderately_well_drained|somewhat_poorly_drained|poorly_drained|very_poorly_drained — promote to reference product]' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Mean elevation of the field above sea level in metres, derived from digital elevation model (DEM) data in Esri ArcGIS. Used for frost risk assessment, drainage planning, and microclimate modelling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldCode rdf:type rdf:Property ;
    rdfs:label 'Field Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the field, used in operational systems such as John Deere Operations Center, Trimble Ag Software, and SAP S/4HANA PP module for field-level planning and task assignment.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'Human-readable name assigned to the field or paddock by the farm operator, used for identification in farm management information systems (FMIS), field maps, and operational communications.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatus rdf:type rdf:Property ;
    rdfs:label 'Field Status' ;
    rdfs:comment 'Current operational lifecycle status of the field. \'active\' indicates the field is in production; \'fallow\' indicates a rest period; \'retired\' indicates the field is no longer in use; \'quarantine\' indicates a regulatory hold; \'conservation\' indicates enrollment in a conservation program such as CRP.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldType rdf:type rdf:Property ;
    rdfs:label 'Field Type' ;
    rdfs:comment 'Classification of the field by its primary agricultural use type. Drives applicable crop planning, irrigation, and compliance workflows. [ENUM-REF-CANDIDATE: cropland|pasture|orchard|vineyard|greenhouse|paddock|wetland|woodland — promote to reference product]' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaFieldNumber rdf:type rdf:Property ;
    rdfs:label 'Fsa Field Number' ;
    rdfs:comment 'USDA Farm Service Agency (FSA) assigned field number within the tract, uniquely identifying the field for federal acreage reporting, crop insurance, and USDA program compliance.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoRestricted rdf:type rdf:Property ;
    rdfs:label 'Gmo Restricted' ;
    rdfs:comment 'Indicates whether the field is designated as GMO-restricted, prohibiting the planting of genetically modified organism (GMO) seed varieties. Supports identity preservation (IP) programs and non-GMO supply chain segregation.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigatedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Irrigated Area Ha' ;
    rdfs:comment 'Area of the field that is equipped and actively managed for irrigation, measured in hectares. Used for water resource management planning, evapotranspiration (ET) calculations, and irrigation scheduling.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jdOpsFieldCode rdf:type rdf:Property ;
    rdfs:label 'Jd Ops Field Code' ;
    rdfs:comment 'External integration key referencing the field record in John Deere Operations Center (precision agriculture and fleet telematics platform). Enables cross-system field-level data linkage for planting, spraying, and harvest operations.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landUseCode rdf:type rdf:Property ;
    rdfs:label 'Land Use Code' ;
    rdfs:comment 'Standardized land use classification code assigned to the field per USDA NASS or local regulatory authority (e.g., USDA CLU land use code). Used for regulatory reporting, conservation program eligibility, and GIS land use mapping.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseRatePerHa rdf:type rdf:Property ;
    rdfs:label 'Lease Rate Per Ha' ;
    rdfs:comment 'Annual cash rent or equivalent lease cost per hectare for this field, used in land cost budgeting, COGS (Cost of Goods Sold) allocation, and ROI (Return on Investment) analysis in Granular Farm Management and SAP CO.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the land tenure arrangement for this field. Drives financial planning in Granular Farm Management, land cost allocation in SAP CO, and lease obligation reporting under IFRS 16.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndviLastScore rdf:type rdf:Property ;
    rdfs:label 'Ndvi Last Score' ;
    rdfs:comment 'Most recent NDVI (Normalized Difference Vegetation Index) score for the field, ranging from -1.0 to 1.0, derived from satellite or drone imagery. Used for crop health monitoring, yield forecasting, and VRA prescription generation.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviObservationDate rdf:type rdf:Property ;
    rdfs:label 'Ndvi Observation Date' ;
    rdfs:comment 'Date on which the most recent NDVI score was captured via satellite or drone imagery. Used to assess the currency of vegetation health data for crop scouting and agronomic decision-making.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slopePercent rdf:type rdf:Property ;
    rdfs:label 'Slope Percent' ;
    rdfs:comment 'Average slope of the field expressed as a percentage (rise over run × 100). Used for erosion risk assessment, irrigation design, machinery safety planning, and BMP (Best Management Practices) compliance.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilSeriesName rdf:type rdf:Property ;
    rdfs:label 'Soil Series Name' ;
    rdfs:comment 'USDA NRCS official soil series name for the dominant soil type in the field (e.g., \'Drummer\', \'Tama\', \'Clarion\'). Used for soil health benchmarking, input rate calibration, and agronomic planning.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilTextureClass rdf:type rdf:Property ;
    rdfs:label 'Soil Texture Class' ;
    rdfs:comment 'USDA soil texture classification for the dominant topsoil horizon, describing the relative proportions of sand, silt, and clay. Influences water-holding capacity, tillage timing, and fertilizer application rates. [ENUM-REF-CANDIDATE: sand|loamy_sand|sandy_loam|loam|silt_loam|silt|clay_loam|silty_clay_loam|sandy_clay|silty_clay|clay — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two- or three-letter ISO 3166-2 state or province code where the field is located. Used for regulatory jurisdiction routing, state-level compliance reporting, and geographic segmentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAreaHa rdf:type rdf:Property ;
    rdfs:label 'Total Area Ha' ;
    rdfs:comment 'Total gross area of the field measured in hectares, derived from RTK-accurate GIS boundary geometry in Esri ArcGIS. Used for yield-per-acre metric (YPM) calculations, input rate planning, and FSA acreage reporting.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraZoneCount rdf:type rdf:Property ;
    rdfs:label 'Vra Zone Count' ;
    rdfs:comment 'Number of sub-field management zones delineated within this field for variable rate application (VRA) prescriptions, based on EC (Electrical Conductivity), yield history, and NDVI (Normalized Difference Vegetation Index) data. Supports precision agriculture planning in Trimble Ag Software.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldBoundaryId rdf:type rdf:Property ;
    rdfs:label 'Field Boundary Id' ;
    rdfs:comment 'Unique surrogate identifier for each versioned field boundary record in the land domain. Primary key for the field_boundary data product. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFieldId rdf:type rdf:Property ;
    rdfs:label 'Primary Field Id' ;
    rdfs:comment 'Reference to the parent agricultural field entity that this boundary version describes. Multiple boundary versions may exist for the same field over time as boundaries are split, merged, or re-surveyed.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Field .

ind:tertiaryTrimbleFieldId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Trimble Field Id' ;
    rdfs:comment 'Field identifier assigned by Trimble Ag Software for variable rate prescription (VRA) and crop scouting integration. Enables linkage of boundary geometry with Trimble-generated field plans and prescription maps.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Field .

ind:accuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Accuracy Meters' ;
    rdfs:comment 'Quantitative positional accuracy of the boundary geometry expressed in meters (root mean square error or circular error probable). Complements accuracy_class with a precise numeric value for spatial quality assessment and compliance reporting.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arcgisFeatureClassRef rdf:type rdf:Property ;
    rdfs:label 'Arcgis Feature Class Ref' ;
    rdfs:comment 'Reference identifier for the corresponding feature class and object ID within the Esri ArcGIS geodatabase. Enables direct linkage between this data product and the authoritative GIS source layer for spatial queries and map rendering.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaHectares rdf:type rdf:Property ;
    rdfs:label 'Area Hectares' ;
    rdfs:comment 'Total calculated area of the field boundary in hectares, derived from the boundary geometry. Used for international reporting, metric-system compliance, and integration with global agricultural standards (GLOBALG.A.P., ISO 14001 environmental reporting).' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryCode rdf:type rdf:Property ;
    rdfs:label 'Boundary Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this field boundary within the farm management information system (FMIS). Used for cross-system referencing between ArcGIS, John Deere Operations Center, and SAP S/4HANA.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryName rdf:type rdf:Property ;
    rdfs:label 'Boundary Name' ;
    rdfs:comment 'Human-readable name assigned to this field boundary, typically matching the field name used operationally (e.g., \'North 40\', \'River Bottom Field\'). Serves as the primary identity label for business users.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundarySource rdf:type rdf:Property ;
    rdfs:label 'Boundary Source' ;
    rdfs:comment 'Method or technology used to capture or derive this field boundary. \'RTK_GPS_survey\' indicates Real-Time Kinematic (RTK) GPS ground survey; \'drone_imagery\' indicates boundary derived from UAV aerial imagery; \'ArcGIS_digitized\' indicates manual digitization in Esri ArcGIS; \'satellite_imagery\' indicates derivation from satellite imagery; \'manual_entry\' indicates operator-entered coordinates.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryStatus rdf:type rdf:Property ;
    rdfs:label 'Boundary Status' ;
    rdfs:comment 'Current lifecycle status of this boundary version. \'active\' indicates the current operative boundary; \'superseded\' indicates a prior version replaced by a newer one; \'draft\' indicates a boundary under review before activation; \'retired\' indicates a boundary no longer in use; \'pending_review\' indicates awaiting FSA or agronomist validation.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyFipsCode rdf:type rdf:Property ;
    rdfs:label 'County Fips Code' ;
    rdfs:comment 'Five-digit Federal Information Processing Standards (FIPS) code identifying the US county in which this field boundary is located. Required for USDA FSA county office assignment, crop insurance rating, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsEpsgCode rdf:type rdf:Property ;
    rdfs:label 'Crs Epsg Code' ;
    rdfs:comment 'EPSG (European Petroleum Survey Group) numeric code identifying the coordinate reference system (CRS) in which the boundary geometry coordinates are expressed (e.g., 4326 for WGS84, 32614 for UTM Zone 14N). Critical for accurate spatial calculations and cross-system interoperability.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:elevationAvgMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Avg Meters' ;
    rdfs:comment 'Average elevation of the field above mean sea level in meters, derived from digital elevation model (DEM) data. Used for microclimate analysis, frost risk assessment, and precision agriculture zone delineation.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geometryType rdf:type rdf:Property ;
    rdfs:label 'Geometry Type' ;
    rdfs:comment 'GIS geometry type of the boundary shape as defined by ISO 19125 Simple Features. \'Polygon\' for contiguous single-parcel fields; \'MultiPolygon\' for non-contiguous fields composed of multiple disconnected parcels (e.g., fields separated by roads or waterways).' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryWkt rdf:type rdf:Property ;
    rdfs:label 'Geometry Wkt' ;
    rdfs:comment 'Full boundary geometry encoded in Well-Known Text (WKT) format as per OGC standards. Stores the polygon or multipolygon coordinate ring defining the precise field boundary. Used by Esri ArcGIS and John Deere Operations Center for spatial analysis and field mapping.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmoRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Restricted' ;
    rdfs:comment 'Indicates whether this field boundary has a contractual or certification-based restriction prohibiting the planting of genetically modified organism (GMO) crops. True if GMO planting is prohibited; False if GMO crops are permitted.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landUseType rdf:type rdf:Property ;
    rdfs:label 'Land Use Type' ;
    rdfs:comment 'Primary land use classification for this field boundary. Determines applicable regulatory requirements, conservation program eligibility, and crop planning constraints. [ENUM-REF-CANDIDATE: cropland|pasture|orchard|vineyard|fallow|wetland|woodland|conservation|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perimeterMeters rdf:type rdf:Property ;
    rdfs:label 'Perimeter Meters' ;
    rdfs:comment 'Total calculated perimeter length of the field boundary in meters, derived from the boundary geometry. Used for fencing cost estimation, irrigation system design, and field edge management planning.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Date on which the field boundary was physically surveyed or digitized to produce this version. Used to assess boundary currency, trigger re-survey workflows, and support FSA acreage certification timelines.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyedBy rdf:type rdf:Property ;
    rdfs:label 'Surveyed By' ;
    rdfs:comment 'Name or identifier of the person, organization, or system that performed or certified the boundary survey (e.g., licensed surveyor name, drone service provider, or system name such as \'John Deere Operations Center Auto-Boundary\'). Supports audit trail and data quality accountability.' ;
    rdfs:domain ind:FieldBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Application Efficiency Pct' ;
    rdfs:comment 'Ratio of water beneficially used by the crop to the total water applied by the irrigation system, expressed as a percentage. Key performance indicator for water use efficiency benchmarking against USDA NRCS and GLOBALG.A.P. standards.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Bmp Compliant' ;
    rdfs:comment 'Indicates whether this irrigation or drainage zone is currently operating in compliance with applicable Best Management Practices (BMP) for water management as defined by USDA NRCS and state environmental agencies. Supports ISO 14001 environmental compliance reporting.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designApplicationRateInHr rdf:type rdf:Property ;
    rdfs:label 'Design Application Rate In Hr' ;
    rdfs:comment 'Engineered water application rate of the irrigation system expressed in inches per hour. Used to match application rate to soil infiltration capacity to prevent runoff and ensure uniform distribution. Sourced from system design specifications.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Drainage Area Acres' ;
    rdfs:comment 'Total land area served by the subsurface tile drainage system in this zone, measured in acres. Used for drainage coefficient calculations, drainage district permit compliance, and BMP reporting. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageCoefficientInDay rdf:type rdf:Property ;
    rdfs:label 'Drainage Coefficient In Day' ;
    rdfs:comment 'Design drainage rate of the subsurface tile system expressed in inches of water removed per day. Determines system capacity to handle peak rainfall events and maintain trafficable field conditions. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageDistrictPermitRef rdf:type rdf:Property ;
    rdfs:label 'Drainage District Permit Ref' ;
    rdfs:comment 'Permit number or reference code issued by the local drainage district authority governing the subsurface tile drainage system. Required for regulatory compliance and environmental reporting. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etSchedulingEnabled rdf:type rdf:Property ;
    rdfs:label 'Et Scheduling Enabled' ;
    rdfs:comment 'Indicates whether this irrigation zone uses Evapotranspiration (ET)-based scheduling to determine irrigation timing and volume. ET-based scheduling integrates weather data and crop coefficients to optimize water use efficiency.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gisBoundaryRef rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary Ref' ;
    rdfs:comment 'Reference identifier or layer name for the zone boundary polygon stored in Esri ArcGIS. Enables spatial analysis, overlap detection, and RTK-accurate field mapping for precision water management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationContractor rdf:type rdf:Property ;
    rdfs:label 'Installation Contractor' ;
    rdfs:comment 'Name of the contractor or company that installed the irrigation system or subsurface tile drainage system. Used for warranty claims, maintenance coordination, and capital expenditure (CAPEX) documentation.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Installation Cost Usd' ;
    rdfs:comment 'Total capital expenditure (CAPEX) incurred for the installation of the irrigation or drainage system, expressed in US dollars. Used for asset valuation, depreciation calculations, and ROI analysis in SAP S/4HANA FI-AA and Granular Farm Management financial planning.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationYear rdf:type rdf:Property ;
    rdfs:label 'Installation Year' ;
    rdfs:comment 'Calendar year in which the irrigation or drainage system was installed. Used for asset age tracking, depreciation scheduling, and infrastructure replacement planning in SAP S/4HANA Fixed Assets.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irrigatedAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Irrigated Area Acres' ;
    rdfs:comment 'Total land area served by this irrigation zone measured in acres. Used for permitted volume compliance calculations, water use efficiency reporting, and USDA Farm Service Agency (FSA) acreage reporting.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedVolumeAcreFt rdf:type rdf:Property ;
    rdfs:label 'Permitted Volume Acre Ft' ;
    rdfs:comment 'Maximum annual water withdrawal volume authorized under the associated water right permit, expressed in acre-feet. Compliance ceiling for seasonal irrigation scheduling and water use reporting to state water authorities.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoistureSensorCount rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Sensor Count' ;
    rdfs:comment 'Number of soil moisture sensor locations deployed within this irrigation zone for real-time soil water status monitoring. Supports IoT-driven precision irrigation scheduling via John Deere Operations Center integration.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soilMoistureSensorLocations rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Sensor Locations' ;
    rdfs:comment 'GPS coordinate string or GIS reference describing the placement locations of soil moisture sensors within the zone (e.g., WKT MULTIPOINT or comma-separated lat/lon pairs). Supports precision water management and IoT sensor mapping in Esri ArcGIS.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemCondition rdf:type rdf:Property ;
    rdfs:label 'System Condition' ;
    rdfs:comment 'Current physical condition assessment of the irrigation or drainage infrastructure. Drives maintenance prioritization, capital replacement planning, and OEE reporting in SAP S/4HANA PM and John Deere Operations Center.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemType rdf:type rdf:Property ;
    rdfs:label 'System Type' ;
    rdfs:comment 'Classification of the irrigation delivery system technology installed in this zone. Determines application efficiency benchmarks, scheduling parameters, and maintenance requirements. Applicable when zone_type = \'irrigation\'. [ENUM-REF-CANDIDATE: center_pivot|drip|flood|subsurface_drip|linear_move|traveling_gun — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tileDepthInches rdf:type rdf:Property ;
    rdfs:label 'Tile Depth Inches' ;
    rdfs:comment 'Installation depth of the subsurface drainage tile below the soil surface in inches. Affects drainage effectiveness, frost protection, and interaction with soil horizons. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tileDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Tile Diameter Inches' ;
    rdfs:comment 'Internal diameter of the subsurface drainage tile pipe in inches. Determines hydraulic capacity and drainage coefficient. Used for system capacity calculations and replacement planning. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tileMapGisRef rdf:type rdf:Property ;
    rdfs:label 'Tile Map Gis Ref' ;
    rdfs:comment 'Reference identifier or layer name for the subsurface tile drainage map stored in Esri ArcGIS. Enables spatial visualization of tile layout, outlet locations, and drainage area boundaries for BMP planning and contractor coordination.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tileMaterial rdf:type rdf:Property ;
    rdfs:label 'Tile Material' ;
    rdfs:comment 'Material composition of the subsurface drainage tile pipe installed in this zone. Corrugated plastic/HDPE is the modern standard; clay and concrete are legacy materials found in older installations. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tileOutletLatitude rdf:type rdf:Property ;
    rdfs:label 'Tile Outlet Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the subsurface tile drainage system outlet location in decimal degrees (WGS84). Used for field mapping in Esri ArcGIS and environmental monitoring of drainage discharge points. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tileOutletLongitude rdf:type rdf:Property ;
    rdfs:label 'Tile Outlet Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the subsurface tile drainage system outlet location in decimal degrees (WGS84). Used for field mapping in Esri ArcGIS and environmental monitoring of drainage discharge points. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tileSystemType rdf:type rdf:Property ;
    rdfs:label 'Tile System Type' ;
    rdfs:comment 'Classification of the subsurface tile drainage system layout installed in this zone. \'Pattern\' indicates systematic grid installation; \'random\' indicates targeted placement in wet spots; \'interceptor\' indicates placement to intercept lateral water flow. Applicable when zone_type = \'subsurface_drainage\'.' ;
    rdfs:domain ind:IrrigationZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current operational lifecycle status of the irrigation or drainage zone. Drives scheduling eligibility, maintenance planning, and asset reporting in SAP S/4HANA PM and John Deere Operations Center.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Discriminator indicating whether this zone record represents an irrigation delivery system or a subsurface tile drainage system. Drives which set of operational attributes are applicable for the zone.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipId rdf:type rdf:Property ;
    rdfs:label 'Ownership Id' ;
    rdfs:comment 'Unique surrogate identifier for each land ownership record in the system. Primary key for the land_ownership data product.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Prior Ownership Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding ownership record in the chain of title for this parcel. Enables traversal of the full ownership history and chain-of-title lineage.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:assessorParcelNumber rdf:type rdf:Property ;
    rdfs:label 'Assessor Parcel Number' ;
    rdfs:comment 'The Assessor Parcel Number (APN) assigned by the county assessor\'s office for property tax assessment purposes. Also known as a parcel identification number (PIN) or tax parcel number. Used for cross-referencing with county tax records.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainSequence rdf:type rdf:Property ;
    rdfs:label 'Chain Sequence' ;
    rdfs:comment 'Sequential integer indicating the position of this ownership record in the chain of title for the parcel. A value of 1 represents the earliest recorded ownership; higher values represent more recent ownership records. Supports chain-of-title history and ownership lineage analysis.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conservationEasementFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Easement Flag' ;
    rdfs:comment 'Indicates whether this parcel is subject to a conservation easement that restricts certain land uses in perpetuity or for a defined term. Conservation easements are commonly held by land trusts or government agencies under USDA NRCS programs.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conveyanceDate rdf:type rdf:Property ;
    rdfs:label 'Conveyance Date' ;
    rdfs:comment 'The date on which the ownership interest was conveyed (transferred) from the prior owner to the current owner, as stated in the deed instrument. Distinct from recording_date (when filed) and effective_date (when legally binding).' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the data quality and verification status of this ownership record. \'Verified\' means the record has been validated against official county recorder or title company sources; \'unverified\' means the record has not yet been validated; \'under_review\' means validation is in progress; \'rejected\' means the record failed validation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedBook rdf:type rdf:Property ;
    rdfs:label 'Deed Book' ;
    rdfs:comment 'The deed book (volume) number in the county recorder\'s office where the deed instrument is officially recorded. Used in conjunction with deed_page for precise legal document retrieval.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Deed Instrument Type' ;
    rdfs:comment 'Classification of the legal deed instrument used to convey ownership. Warranty deeds provide full title guarantees; quitclaim deeds convey only the grantor\'s existing interest; grant deeds include implied warranties; trustee and sheriff deeds arise from trust or court proceedings.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedPage rdf:type rdf:Property ;
    rdfs:label 'Deed Page' ;
    rdfs:comment 'The page number within the deed book at the county recorder\'s office where the deed instrument is officially recorded. Used in conjunction with deed_book for precise legal document retrieval.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deedReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deed Reference Number' ;
    rdfs:comment 'Unique reference number assigned to the deed instrument conveying ownership of this parcel. Used to cross-reference with county recorder and title company records for chain-of-title verification.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceDescription rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Description' ;
    rdfs:comment 'Narrative description of any encumbrances, liens, easements, mortgages, conservation easements, or other title restrictions affecting this ownership record. Populated when encumbrance_flag is True.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceFlag rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Flag' ;
    rdfs:comment 'Indicates whether this ownership record is subject to any encumbrances, liens, easements, mortgages, or other claims against the title that may affect the owner\'s full use and enjoyment of the parcel.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:farmServiceAgencyTractNumber rdf:type rdf:Property ;
    rdfs:label 'Farm Service Agency Tract Number' ;
    rdfs:comment 'The USDA Farm Service Agency (FSA) tract number assigned to this parcel for farm program eligibility, commodity program enrollment, and conservation program participation tracking.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEntityType rdf:type rdf:Property ;
    rdfs:label 'Owner Entity Type' ;
    rdfs:comment 'Classification of the legal entity type of the owner. Distinguishes between natural persons and legal entities for regulatory reporting, USDA farm program eligibility, and compliance with FSMA and COOL requirements. [ENUM-REF-CANDIDATE: individual|corporation|llc|partnership|trust|government|cooperative|nonprofit — promote to reference product]' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle state of this ownership record. \'Current\' indicates active legal ownership; \'historical\' indicates a past ownership interest that has been transferred or extinguished; \'disputed\' flags records under legal challenge; \'pending\' indicates a transfer in progress; \'transferred\' indicates completed conveyance to a new owner.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Fractional ownership interest held by this owner in the parcel, expressed as a percentage (e.g., 50.0000 for a 50% undivided interest). Supports multi-owner parcels with tenancy-in-common or LLC membership fractional interest tracking. All ownership records for a parcel should sum to 100%.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:titleInsuranceCompany rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Company' ;
    rdfs:comment 'Name of the title insurance underwriter or company that issued the title insurance policy for this ownership record. Used for claims processing and title defect resolution.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Title Insurance Policy Number' ;
    rdfs:comment 'The policy number of the title insurance policy issued to protect the owner\'s interest in this parcel against title defects, liens, or encumbrances not discovered during the title search. Issued by a licensed title insurance underwriter.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaFarmNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Farm Number' ;
    rdfs:comment 'The USDA Farm Service Agency (FSA) farm number associated with this parcel, used for enrollment in commodity support programs, conservation programs, and crop insurance. A single farm number may encompass multiple tracts and parcels.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationPractice rdf:type rdf:Property ;
    rdfs:label 'Conservation Practice' ;
    rdfs:comment 'Planned USDA NRCS conservation practice code or description for the field (e.g., 590 - Nutrient Management, 329 - Residue and Tillage Management, 340 - Cover and Green Manure Crop). Supports EQIP and CSP program compliance and BMP documentation.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropInsuranceType rdf:type rdf:Property ;
    rdfs:label 'Crop Insurance Type' ;
    rdfs:comment 'USDA RMA crop insurance plan type elected for this field. APH: Actual Production History; RP: Revenue Protection; RPHPE: Revenue Protection with Harvest Price Exclusion; YP: Yield Protection; AIP: Area Insurance Plan; WFRP: Whole-Farm Revenue Protection.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crpContractNumber rdf:type rdf:Property ;
    rdfs:label 'Crp Contract Number' ;
    rdfs:comment 'USDA FSA-assigned CRP contract number for the field enrollment. Required for FSA program compliance reporting and annual rental payment reconciliation. Null when crp_enrolled is False.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crpEnrolled rdf:type rdf:Property ;
    rdfs:label 'Crp Enrolled' ;
    rdfs:comment 'Indicates whether this field is enrolled in the USDA Conservation Reserve Program (CRP) for the plan period (True = CRP enrolled; False = not enrolled). CRP enrollment restricts commodity production and triggers conservation practice requirements and annual rental payments.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crpPracticeCode rdf:type rdf:Property ;
    rdfs:label 'Crp Practice Code' ;
    rdfs:comment 'USDA FSA conservation practice code assigned to the CRP contract (e.g., CP1 - Introduced Grasses, CP21 - Filter Strips, CP38 - SAFE for Upland Birds). Defines the conservation cover type and management requirements for the enrolled acres.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the originating operational system of record from which this land use plan record was sourced or integrated. Supports data lineage, reconciliation, and silver layer provenance tracking in the Databricks lakehouse. [ENUM-REF-CANDIDATE: granular|trimble|climate_fieldview|john_deere_ops|arcgis|sap_s4hana|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaCluNumber rdf:type rdf:Property ;
    rdfs:label 'Fsa Clu Number' ;
    rdfs:comment 'USDA FSA Common Land Unit (CLU) identifier for the specific field boundary. The CLU is the smallest unit of land with a permanent, contiguous boundary used for FSA program administration and acreage reporting.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoPlanned rdf:type rdf:Property ;
    rdfs:label 'Gmo Planned' ;
    rdfs:comment 'Indicates whether genetically modified organism (GMO) seed varieties are planned for use on this field in the crop year (True = GMO seed planned; False = non-GMO). Relevant for identity preservation programs, export compliance, and COOL (Country of Origin Labeling) requirements.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationPlanned rdf:type rdf:Property ;
    rdfs:label 'Irrigation Planned' ;
    rdfs:comment 'Indicates whether irrigation is planned for this field in the crop year (True = irrigation planned; False = dryland/rainfed production). Drives water resource management planning, evapotranspiration (ET) budgeting, and irrigation infrastructure scheduling.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for agronomist or farm manager notes regarding special considerations, deviations from standard rotation, environmental constraints, or other planning context relevant to this field\'s land use plan.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'The calendar date on which the land use plan period ends, typically the end of the crop year or harvest completion. Used for plan lifecycle management and multi-year planning horizon tracking.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'The calendar date on which the land use plan period begins, typically the start of the crop year (e.g., January 1 or the beginning of the growing season). Used for plan effective period management and FSA program year alignment.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAcres rdf:type rdf:Property ;
    rdfs:label 'Planned Acres' ;
    rdfs:comment 'Total planned production or conservation acres for this field in the crop year, measured in acres. Used for FSA acreage reporting, crop insurance coverage calculations, and input planning (seed, fertilizer, chemical). Aligns with FSA CLU (Common Land Unit) acreage.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationSequence rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence' ;
    rdfs:comment 'Numeric position of this crop in the planned multi-year rotation cycle for the field (e.g., 1 = first year of rotation, 2 = second year). Supports crop rotation planning for soil health, pest management (IPM), and nutrient cycling optimization.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Granular plan ID, Trimble field plan ID). Enables traceability back to the system of record for reconciliation and audit purposes in the silver layer.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetYield rdf:type rdf:Property ;
    rdfs:label 'Target Yield' ;
    rdfs:comment 'Planned or expected crop yield for the field in the crop year, expressed in the commodity\'s standard unit of measure (bushels per acre for grain, tons per acre for forage). Used for input planning, crop insurance APH (Actual Production History) benchmarking, and financial planning.' ;
    rdfs:domain ind:UsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldUnit rdf:type rdf:Property ;
    rdfs:label 'Yield Unit' ;
    rdfs:comment 'Unit of measure for the target_yield field. BU/acre (Bushel per Acre) for grain crops; CWT/acre (Hundredweight per Acre) for some specialty crops; Ton/acre for forage; LB/acre for some specialty crops; MT/hectare for metric reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenantAccountId rdf:type rdf:Property ;
    rdfs:label 'Tenant Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Leases are executed between legal entities (accounts). The tenant operator account is required for billing, FSA farm operator designation, crop insurance enrollment, and lease payment processing. Role' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the lease agreement contains an automatic renewal clause. When True, the lease renews for an additional term at expiry unless either party provides written notice of termination within the required notice period.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashRentRatePerAcre rdf:type rdf:Property ;
    rdfs:label 'Cash Rent Rate Per Acre' ;
    rdfs:comment 'Annual cash rent rate expressed in US dollars per acre. Applicable for cash_rent and flex_rent lease types. Represents the base rental obligation per acre per year. Sensitive commercial term.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationPracticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Practice Required Flag' ;
    rdfs:comment 'Indicates whether the lease agreement mandates adherence to specific conservation practices (e.g., cover cropping, no-till, buffer strips) as a condition of tenancy. Supports BMP and ISO 14001 environmental compliance tracking.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cropRestriction rdf:type rdf:Property ;
    rdfs:label 'Crop Restriction' ;
    rdfs:comment 'Free-text description of any crop-specific restrictions or requirements stipulated in the lease (e.g., no GMO crops, organic production required, specific rotation mandated). Impacts crop planning and seed selection decisions.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Crop Share Percentage' ;
    rdfs:comment 'Percentage of crop proceeds or harvested commodity allocated to the landowner under a crop share lease arrangement. Typically ranges from 25% to 50%. Applicable only when lease_type is \'crop_share\'.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flexRentBasePrice rdf:type rdf:Property ;
    rdfs:label 'Flex Rent Base Price' ;
    rdfs:comment 'The commodity base price (in $/bushel or $/MT) used as the reference point for flex rent adjustment calculations. When the actual commodity price exceeds this threshold, additional rent is triggered. Applicable only for flex_rent lease type.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flexRentCapPerAcre rdf:type rdf:Property ;
    rdfs:label 'Flex Rent Cap Per Acre' ;
    rdfs:comment 'Maximum allowable flex rent payment per acre per year, capping the upside obligation for the tenant regardless of commodity price or yield performance. Applicable only for flex_rent lease type.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flexRentTriggerMechanism rdf:type rdf:Property ;
    rdfs:label 'Flex Rent Trigger Mechanism' ;
    rdfs:comment 'The mechanism that activates the flex rent adjustment above the base cash rent. Price trigger: based on commodity market price. Yield trigger: based on actual field yield (YPM). Revenue trigger: based on gross revenue per acre. None: not applicable for non-flex leases.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementsAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Improvements Allowed Flag' ;
    rdfs:comment 'Indicates whether the lease agreement permits the tenant to make permanent improvements to the land (e.g., drainage tile installation, building construction, irrigation infrastructure). Relevant for CAPEX planning and land stewardship.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the lease agreement. Used in correspondence with landowners, FSA filings, and internal reference. Format: LSE-YYYY-NNNNNN.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle state of the lease agreement. Active: in force and binding. Expired: past end date without renewal. Terminated: ended early by either party. Pending: executed but not yet effective. Under negotiation: terms being discussed. Draft: not yet executed.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueMonth rdf:type rdf:Property ;
    rdfs:label 'Payment Due Month' ;
    rdfs:comment 'Calendar month (1–12) in which the primary annual rent payment is due to the landowner. For semi-annual schedules, this represents the first payment month. Used by the finance domain to schedule AP obligations.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Frequency at which cash rent payments are due to the landowner under the lease agreement. Drives accounts payable scheduling in the finance domain. Common agricultural practice is annual or semi-annual.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to the lease end date by which written notice of non-renewal or termination must be provided by either party. Typically 30, 60, or 90 days for agricultural leases. Drives automated renewal alert workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightOfFirstRefusalFlag rdf:type rdf:Property ;
    rdfs:label 'Right Of First Refusal Flag' ;
    rdfs:comment 'Indicates whether the lease agreement grants the tenant/operator a right of first refusal (ROFR) to purchase the land if the landowner decides to sell. When True, the operator must be offered the opportunity to match any third-party purchase offer.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalLeasedAcres rdf:type rdf:Property ;
    rdfs:label 'Total Leased Acres' ;
    rdfs:comment 'Total land area covered under this lease agreement, expressed in acres. Used for cash rent calculation, FSA reporting, and land tenure analytics. Sourced from FSA farm records or GIS boundary measurement.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agronomistNotes rdf:type rdf:Property ;
    rdfs:label 'Agronomist Notes' ;
    rdfs:comment 'Free-text field for agronomist or crop consultant observations about the management zone, including special management considerations, historical problem areas, or recommendations for upcoming season. Captured in Granular Farm Management or Trimble Ag Software during field scouting.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cecMeq100g rdf:type rdf:Property ;
    rdfs:label 'Cec Meq 100g' ;
    rdfs:comment 'Mean cation exchange capacity (CEC) of the management zone soil expressed in milliequivalents per 100 grams (meq/100g). Measures the soil\'s ability to hold and supply positively charged nutrient ions (Ca, Mg, K, Na). Higher CEC indicates greater nutrient-holding capacity. Used for fertilizer rate calibration and soil amendment planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delineationMethod rdf:type rdf:Property ;
    rdfs:label 'Delineation Method' ;
    rdfs:comment 'Method used to spatially delineate the management zone boundary. EC (Electrical Conductivity) scanning uses Veris or EM38 sensors; yield history uses multi-year combine yield monitor data from Climate FieldView or John Deere Operations Center; satellite NDVI uses remote sensing imagery; manual uses operator-drawn boundaries in Esri ArcGIS or Trimble Ag; soil sampling uses interpolated soil test point data; topographic analysis uses digital elevation model (DEM) data.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delineationYear rdf:type rdf:Property ;
    rdfs:label 'Delineation Year' ;
    rdfs:comment 'Calendar year in which the management zone boundary was originally delineated or most recently revised. Used to assess zone data currency and schedule periodic re-delineation based on updated EC scanning, yield history, or satellite imagery data.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecDeepDsM rdf:type rdf:Property ;
    rdfs:label 'Ec Deep Ds M' ;
    rdfs:comment 'Apparent soil electrical conductivity (EC) reading at deep depth (typically 0-90 cm) expressed in deciSiemens per meter (dS/m). Measured via Veris 3100 or EM38 sensor. Reflects subsoil characteristics including clay pan depth and water-holding capacity. Complements shallow EC for comprehensive zone delineation.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecScanDate rdf:type rdf:Property ;
    rdfs:label 'Ec Scan Date' ;
    rdfs:comment 'Date on which the soil electrical conductivity (EC) scanning survey was conducted for this management zone. Used to assess data currency and schedule re-scanning intervals (typically every 3-5 years per BMP guidelines).' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecShallowDsM rdf:type rdf:Property ;
    rdfs:label 'Ec Shallow Ds M' ;
    rdfs:comment 'Apparent soil electrical conductivity (EC) reading at shallow depth (typically 0-30 cm) expressed in deciSiemens per meter (dS/m). Measured via Veris 3100 or EM38 sensor during EC scanning. Correlates with soil texture, clay content, and salinity. Used as primary input for EC-based zone delineation and VRA (Variable Rate Application) prescription generation.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalZoneCode rdf:type rdf:Property ;
    rdfs:label 'External Zone Code' ;
    rdfs:comment 'Native identifier of this management zone in the originating source system (e.g., Trimble Ag zone GUID, John Deere Operations Center zone ID, Esri ArcGIS feature OID). Enables bidirectional synchronization and traceability between the lakehouse Silver Layer and operational precision agriculture platforms.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisPolygonWkt rdf:type rdf:Property ;
    rdfs:label 'Gis Polygon Wkt' ;
    rdfs:comment 'Spatial boundary of the management zone stored as Well-Known Text (WKT) polygon geometry in WGS84 coordinate reference system (EPSG:4326). Sourced from Esri ArcGIS or John Deere Operations Center RTK-accurate field mapping. Enables spatial joins with soil sampling points, yield data, and satellite imagery layers.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSoilSampleDate rdf:type rdf:Property ;
    rdfs:label 'Last Soil Sample Date' ;
    rdfs:comment 'Date of the most recent composite soil sampling event conducted within this management zone. Used to assess soil data currency and trigger re-sampling workflows. GLOBALG.A.P. and USDA NRCS BMP guidelines recommend soil sampling every 2-4 years.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndviImageDate rdf:type rdf:Property ;
    rdfs:label 'Ndvi Image Date' ;
    rdfs:comment 'Date on which the satellite or aerial imagery used to calculate the current NDVI value was captured. Critical for assessing data currency and seasonal relevance of the vegetation index reading.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nitrogenLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Lbs Acre' ;
    rdfs:comment 'Mean available nitrogen (N) level in the management zone soil expressed in pounds per acre (lbs/acre), derived from composite soil sampling. Component of NPK (Nitrogen Phosphorus Potassium) nutrient profile. Used to calculate nitrogen fertilizer application rates in VRA prescriptions and comply with nutrient management plan requirements.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicMatterPct rdf:type rdf:Property ;
    rdfs:label 'Organic Matter Pct' ;
    rdfs:comment 'Mean soil organic matter (OM) content expressed as a percentage of dry soil weight for the management zone. Measured via loss-on-ignition or Walkley-Black method from composite soil samples. Higher OM improves water retention, nutrient cycling, and soil structure. Key indicator for carbon sequestration reporting under ISCC and sustainability programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phosphorusLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Lbs Acre' ;
    rdfs:comment 'Mean available phosphorus (P) level in the management zone soil expressed in pounds per acre (lbs/acre), derived from composite soil sampling. Component of NPK nutrient profile. Used to calculate phosphorus fertilizer application rates in VRA prescriptions and support EPA water quality compliance for phosphorus runoff management.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumLbsAcre rdf:type rdf:Property ;
    rdfs:label 'Potassium Lbs Acre' ;
    rdfs:comment 'Mean available potassium (K) level in the management zone soil expressed in pounds per acre (lbs/acre), derived from composite soil sampling. Component of NPK nutrient profile. Used to calculate potassium fertilizer application rates in VRA prescriptions.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityClass rdf:type rdf:Property ;
    rdfs:label 'Productivity Class' ;
    rdfs:comment 'Agronomic productivity classification of the management zone based on historical yield performance and soil capability. High productivity zones receive premium input rates; low productivity zones may receive reduced inputs or conservation treatment under BMP (Best Management Practices) guidelines.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slopePct rdf:type rdf:Property ;
    rdfs:label 'Slope Pct' ;
    rdfs:comment 'Mean slope gradient of the management zone expressed as a percentage (rise over run × 100), derived from digital elevation model (DEM) analysis in Esri ArcGIS. Used for erosion risk assessment, drainage planning, and equipment operation safety. Slopes above 8% may require conservation practices under USDA NRCS BMP guidelines.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilPhMean rdf:type rdf:Property ;
    rdfs:label 'Soil Ph Mean' ;
    rdfs:comment 'Mean soil pH (Potential of Hydrogen) value for the management zone, representing average soil acidity or alkalinity on a 0-14 scale. Calculated from composite soil samples within the zone. Critical for nutrient availability assessment and lime application rate determination in VRA prescriptions. Optimal range for most crops is 6.0-7.0.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraEligible rdf:type rdf:Property ;
    rdfs:label 'Vra Eligible' ;
    rdfs:comment 'Indicates whether this management zone is eligible for variable rate application (VRA) prescription generation in Trimble Ag Software or John Deere Operations Center. Zones must meet minimum area thresholds and have current soil data to qualify for VRA. True = eligible for VRA prescriptions; False = not eligible.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the management zone within the farm management information system (FMIS). Used as the business key in Trimble Ag Software and John Deere Operations Center for variable rate application (VRA) prescription generation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable descriptive name assigned to the management zone (e.g., \'North Field High Productivity Zone\', \'EC Zone 3 - Sandy Loam\'). Used in FMIS reporting and VRA prescription labeling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneVersion rdf:type rdf:Property ;
    rdfs:label 'Zone Version' ;
    rdfs:comment 'Sequential version number of the management zone boundary definition, incremented each time the zone polygon or classification attributes are revised. Supports audit trail and historical comparison of zone configurations across growing seasons.' ;
    rdfs:domain ind:ManagementZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualPropertyTax rdf:type rdf:Property ;
    rdfs:label 'Annual Property Tax' ;
    rdfs:comment 'Most recent annual property tax levy assessed by the county on this parcel in USD, used for OPEX budgeting, land cost-per-acre analysis, and financial planning in Granular Farm Management.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apn rdf:type rdf:Property ;
    rdfs:label 'Apn' ;
    rdfs:comment 'County assessor-assigned Assessor Parcel Number (APN) uniquely identifying the parcel within the county tax roll. Primary government-issued cadastral identifier used for title searches, deed recording, and property tax assessment.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcgisLayerCode rdf:type rdf:Property ;
    rdfs:label 'Arcgis Layer Code' ;
    rdfs:comment 'Unique feature identifier within the Esri ArcGIS parcel boundary layer, enabling direct linkage to the authoritative GIS polygon geometry for spatial analysis, field mapping, and environmental monitoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedValue rdf:type rdf:Property ;
    rdfs:label 'Assessed Value' ;
    rdfs:comment 'County assessor\'s most recent assessed market value of the parcel in USD, used for property tax calculation, financial reporting, and land portfolio valuation.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deedRecordingDate rdf:type rdf:Property ;
    rdfs:label 'Deed Recording Date' ;
    rdfs:comment 'Date the current deed or title instrument was officially recorded with the county recorder, establishing the effective date of ownership transfer and priority in the title chain.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floodZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Flood Zone Designation' ;
    rdfs:comment 'FEMA National Flood Insurance Program (NFIP) flood zone designation for the parcel, used for crop insurance underwriting, lender requirements, conservation planning, and drainage infrastructure investment decisions.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaCroplandAcres rdf:type rdf:Property ;
    rdfs:label 'Fsa Cropland Acres' ;
    rdfs:comment 'USDA FSA-determined cropland acres within the parcel eligible for commodity program enrollment, ARC/PLC payments, and conservation program base acre calculations.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrigatedAcres rdf:type rdf:Property ;
    rdfs:label 'Irrigated Acres' ;
    rdfs:comment 'Total acres within the parcel served by an irrigation system (surface, drip, pivot, or flood), used for water right allocation, irrigation scheduling, and USDA program reporting.' ;
    rdfs:domain ind:Land ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landUseDesignation rdf:type rdf:Property ;
    rdfs:label 'Land Use Designation' ;
    rdfs:comment 'Primary land use classification for the parcel as designated by the county assessor or USDA FSA, determining eligible farm programs, conservation requirements, and operational planning. [ENUM-REF-CANDIDATE: cropland|pasture|rangeland|woodland|wetland|farmstead|idle|conservation|orchard|vineyard|fallow — promote to reference product]' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrcsLandCapabilityClass rdf:type rdf:Property ;
    rdfs:label 'Nrcs Land Capability Class' ;
    rdfs:comment 'USDA Natural Resources Conservation Service (NRCS) land capability class (I–VIII) and subclass (e, w, s, c) rating the parcel\'s suitability for cultivation, indicating erosion risk, drainage limitations, and conservation treatment needs.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicTransitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Organic Transition Start Date' ;
    rdfs:comment 'Date on which the parcel began the USDA NOP-required 36-month transition period from conventional to certified organic production, used to track certification eligibility and compliance timelines.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parcelName rdf:type rdf:Property ;
    rdfs:label 'Parcel Name' ;
    rdfs:comment 'Operational or colloquial name assigned to the parcel by the farm operation (e.g., \'North Quarter\', \'River Bottom Field\') for internal identification and communication.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelStatus rdf:type rdf:Property ;
    rdfs:label 'Parcel Status' ;
    rdfs:comment 'Current lifecycle status of the parcel record indicating its operational and administrative state within the enterprise land management system.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plssRange rdf:type rdf:Property ;
    rdfs:label 'Plss Range' ;
    rdfs:comment 'Range designation (e.g., R5E) within the PLSS grid, representing the east-west position relative to a principal meridian.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plssSection rdf:type rdf:Property ;
    rdfs:label 'Plss Section' ;
    rdfs:comment 'Section number (1–36) within the Public Land Survey System (PLSS) township-range grid identifying the one-square-mile land division containing this parcel.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plssTownship rdf:type rdf:Property ;
    rdfs:label 'Plss Township' ;
    rdfs:comment 'Township designation (e.g., T12N) within the PLSS grid, representing the north-south position relative to a principal meridian baseline.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primeFarmlandClass rdf:type rdf:Property ;
    rdfs:label 'Prime Farmland Class' ;
    rdfs:comment 'USDA NRCS prime farmland classification indicating the land\'s capability for sustained agricultural production, used for conservation program eligibility (ACEP, RCPP), environmental impact assessments, and land use planning.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilSurveyMapUnit rdf:type rdf:Property ;
    rdfs:label 'Soil Survey Map Unit' ;
    rdfs:comment 'USDA NRCS Web Soil Survey map unit symbol (e.g., \'HrA\', \'MnB2\') identifying the dominant soil series and slope class for the parcel, used for soil health planning, conservation program eligibility, and variable rate application (VRA) prescriptions.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeededAcres rdf:type rdf:Property ;
    rdfs:label 'Total Deeded Acres' ;
    rdfs:comment 'Total land area of the parcel as recorded in the county deed or land registry, expressed in acres. Represents the legal boundary area and is the authoritative acreage for title, tax assessment, and FSA program enrollment.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetlandIndicator rdf:type rdf:Property ;
    rdfs:label 'Wetland Indicator' ;
    rdfs:comment 'Flag indicating whether any portion of the parcel contains USDA NRCS-delineated wetlands subject to Swampbuster provisions (Food Security Act), EPA Section 404 permitting, and conservation program restrictions.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'County or municipal zoning designation for the parcel (e.g., A-1 Agricultural, A-2 Rural Residential, EFU Exclusive Farm Use) governing permitted land uses, structure placement, and development rights.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awcCmCm rdf:type rdf:Property ;
    rdfs:label 'Awc Cm Cm' ;
    rdfs:comment 'Available Water Capacity (AWC) expressed as centimeters of water per centimeter of soil depth (cm/cm), representing the volume of water held between field capacity and permanent wilting point. Critical input for irrigation scheduling and evapotranspiration (ET) modeling.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkDensityGCm3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density G Cm3' ;
    rdfs:comment 'Soil bulk density expressed in grams per cubic centimeter (g/cm³), representing the mass of dry soil per unit volume including pore space. Indicates soil compaction level; values above 1.6 g/cm³ typically restrict root growth. Informs tillage and cover crop decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthToRestrictiveLayerCm rdf:type rdf:Property ;
    rdfs:label 'Depth To Restrictive Layer Cm' ;
    rdfs:comment 'Depth in centimeters from the soil surface to the first restrictive layer (e.g., fragipan, claypan, bedrock, seasonal high water table). Limits effective rooting depth and influences crop selection, drainage tile placement, and irrigation design.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecDsM rdf:type rdf:Property ;
    rdfs:label 'Ec Ds M' ;
    rdfs:comment 'Soil electrical conductivity (EC) measured in deciSiemens per meter (dS/m), indicating soil salinity level. Values above 4 dS/m may indicate salinity stress for most crops. Used for precision agriculture zone delineation and irrigation water quality management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erosionRiskClass rdf:type rdf:Property ;
    rdfs:label 'Erosion Risk Class' ;
    rdfs:comment 'Qualitative erosion risk classification for this soil profile based on USDA NRCS Universal Soil Loss Equation (USLE/RUSLE) factors including erodibility (K-factor), slope, and cover. Drives conservation practice selection and FSMA Produce Safety Rule compliance for water quality.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisMapUnitAreaHa rdf:type rdf:Property ;
    rdfs:label 'Gis Map Unit Area Ha' ;
    rdfs:comment 'Area of the soil mapping unit or management zone in hectares as calculated from the GIS polygon in Esri ArcGIS. Used for proportional nutrient application calculations, yield per acre metric (YPM) normalization, and land valuation.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHydric rdf:type rdf:Property ;
    rdfs:label 'Is Hydric' ;
    rdfs:comment 'Boolean flag indicating whether this soil is classified as a hydric soil by USDA NRCS criteria, meaning it formed under conditions of saturation, flooding, or ponding long enough to develop anaerobic conditions. Hydric soils are associated with wetlands and trigger regulatory review under Section 404 of the Clean Water Act and USDA NRCS wetland conservation provisions.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimeFarmland rdf:type rdf:Property ;
    rdfs:label 'Is Prime Farmland' ;
    rdfs:comment 'Boolean flag indicating whether this soil mapping unit is designated as Prime Farmland, Farmland of Statewide Importance, or Unique Farmland by USDA NRCS. Prime farmland designation affects land use planning, conservation program eligibility (CRP, EQIP), and regulatory review for development.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kFactor rdf:type rdf:Property ;
    rdfs:label 'K Factor' ;
    rdfs:comment 'USDA NRCS soil erodibility K-factor from the Universal Soil Loss Equation (USLE/RUSLE), ranging from 0.02 (least erodible) to 0.69 (most erodible). Quantifies the susceptibility of soil to detachment and transport by rainfall and runoff. Used in conservation planning and NRCS EQIP program applications.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Reference Number' ;
    rdfs:comment 'External laboratory sample reference or accession number assigned by the certified soil testing laboratory. Enables traceability back to the original Certificate of Analysis (COA) and laboratory report for audit and GLOBALG.A.P. compliance verification.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landCapabilityClass rdf:type rdf:Property ;
    rdfs:label 'Land Capability Class' ;
    rdfs:comment 'USDA NRCS Land Capability Classification (LCC) rating from Class I (fewest limitations) to Class VIII (unsuitable for cultivation). Used for conservation planning, crop insurance rating, and USDA program eligibility determination. [ENUM-REF-CANDIDATE: I|II|III|IV|V|VI|VII|VIII — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landCapabilitySubclass rdf:type rdf:Property ;
    rdfs:label 'Land Capability Subclass' ;
    rdfs:comment 'USDA NRCS Land Capability Subclass modifier indicating the primary limitation type: \'e\' (erosion), \'w\' (wetness/drainage), \'s\' (soil limitations), \'c\' (climate). Complements the land_capability_class for conservation practice planning under BMP guidelines.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementZone rdf:type rdf:Property ;
    rdfs:label 'Management Zone' ;
    rdfs:comment 'Agronomic management zone designation within the field (e.g., \'Zone 1 - High Productivity\', \'Zone 3 - Low OM\'). Used for variable rate application (VRA) prescriptions in Trimble Ag Software and Climate FieldView to optimize input use efficiency.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mukey rdf:type rdf:Property ;
    rdfs:label 'Mukey' ;
    rdfs:comment 'USDA NRCS SSURGO (Soil Survey Geographic Database) Map Unit Key (MUKEY) — the unique national identifier for the soil map unit polygon. Enables direct linkage to the SSURGO database for detailed soil property lookup, Web Soil Survey integration, and NRCS program eligibility verification.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenPpm rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Ppm' ;
    rdfs:comment 'Plant-available nitrogen (N) concentration in the soil expressed in parts per million (ppm), typically measured as nitrate-N or ammonium-N. Core component of NPK (Nitrogen-Phosphorus-Potassium) soil fertility assessment driving fertilization event planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrcsSoilSeries rdf:type rdf:Property ;
    rdfs:label 'Nrcs Soil Series' ;
    rdfs:comment 'Official USDA NRCS soil series name assigned to this mapping unit (e.g., \'Drummer\', \'Tama\', \'Clarion\'). Derived from the SSURGO/Web Soil Survey database and used for agronomic benchmarking and land valuation.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phMethod rdf:type rdf:Property ;
    rdfs:label 'Ph Method' ;
    rdfs:comment 'Laboratory method used to determine the soil pH value (e.g., 1:1 water suspension, 1:2 CaCl2 solution). Required for accurate interpretation and cross-laboratory comparability of pH results per USDA NRCS and university extension standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'Soil pH (Potential of Hydrogen) measurement representing soil acidity or alkalinity on a 0–14 scale, typically measured in a 1:1 soil-water suspension. Drives lime application decisions, nutrient availability, and crop selection. Target range for most crops: 6.0–7.0.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phosphorusPpm rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Ppm' ;
    rdfs:comment 'Plant-available phosphorus (P) concentration in the soil expressed in parts per million (ppm), typically measured by Bray-1, Mehlich-3, or Olsen extraction method. Core NPK component driving phosphate fertilizer recommendations and environmental runoff risk assessment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumPpm rdf:type rdf:Property ;
    rdfs:label 'Potassium Ppm' ;
    rdfs:comment 'Plant-available potassium (K) concentration in the soil expressed in parts per million (ppm), typically measured by Mehlich-3 or ammonium acetate extraction. Core NPK component influencing crop quality, drought tolerance, and potash fertilizer application rates.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this soil profile or management zone within the farm management information system (FMIS). Used for cross-referencing with Granular Farm Management and Trimble Ag Software records.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable descriptive name for the soil profile or management zone (e.g., \'North Field Zone A\', \'River Bottom Unit 3\'). Used for display and reporting in FMIS dashboards.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictiveLayerType rdf:type rdf:Property ;
    rdfs:label 'Restrictive Layer Type' ;
    rdfs:comment 'Classification of the soil restrictive layer type encountered at the depth recorded in depth_to_restrictive_layer_cm. Determines the agronomic and engineering implications for root penetration, drainage, and deep tillage feasibility. [ENUM-REF-CANDIDATE: fragipan|claypan|bedrock|hardpan|water table|caliche|permafrost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDate rdf:type rdf:Property ;
    rdfs:label 'Sampling Date' ;
    rdfs:comment 'Date on which the soil sample was collected for laboratory analysis that established or last updated this soil profile. Determines the currency of the soil data for agronomic decision-making; most university extension services recommend resampling every 3–4 years.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingDepthCm rdf:type rdf:Property ;
    rdfs:label 'Sampling Depth Cm' ;
    rdfs:comment 'Depth in centimeters at which the soil sample was collected (e.g., 0–15 cm for surface, 15–30 cm for subsoil). Sampling depth affects interpretation of pH, OM, and nutrient results and must be consistent across sampling events for trend analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilOrder rdf:type rdf:Property ;
    rdfs:label 'Soil Order' ;
    rdfs:comment 'Highest-level USDA Soil Taxonomy classification order for this soil profile (e.g., Mollisol, Alfisol). Determines broad agronomic suitability and management approach. [ENUM-REF-CANDIDATE: Alfisol|Andisol|Aridisol|Entisol|Gelisol|Histosol|Inceptisol|Mollisol|Oxisol|Spodosol|Ultisol|Vertisol — promote to reference product]' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilSuborder rdf:type rdf:Property ;
    rdfs:label 'Soil Suborder' ;
    rdfs:comment 'Second-level USDA Soil Taxonomy classification suborder for this soil profile (e.g., Udoll, Aquoll). Provides finer agronomic classification for crop suitability and drainage management planning.' ;
    rdfs:domain ind:SoilProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textureClass rdf:type rdf:Property ;
    rdfs:label 'Texture Class' ;
    rdfs:comment 'USDA soil texture classification based on the relative proportions of sand, silt, and clay as determined by the USDA textural triangle. Drives irrigation scheduling, tillage decisions, and nutrient management planning. [ENUM-REF-CANDIDATE: sand|loamy sand|sandy loam|loam|silt loam|silt|sandy clay loam|clay loam|silty clay loam|sandy clay|silty clay|clay — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labVendorId rdf:type rdf:Property ;
    rdfs:label 'Lab Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Soil testing laboratories are qualified vendors in the procurement system. Linking soil_sample to the lab vendor enables vendor qualification tracking, invoice matching for lab services, COA verificat' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:baseSaturationPct rdf:type rdf:Property ;
    rdfs:label 'Base Saturation Pct' ;
    rdfs:comment 'Percentage of the soil\'s Cation Exchange Capacity (CEC) occupied by base cations (calcium, magnesium, potassium, sodium). Calculated from individual cation concentrations relative to CEC. Used to assess nutrient balance and guide lime and fertilizer application strategies.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bufferPh rdf:type rdf:Property ;
    rdfs:label 'Buffer Ph' ;
    rdfs:comment 'Buffer pH value measured using a buffered solution (e.g., Shoemaker-McLean-Pratt or Sikora buffer) to determine the lime requirement for acidic soils. Used in conjunction with water pH to calculate the amount of agricultural lime needed to raise soil pH to target levels.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calciumPpm rdf:type rdf:Property ;
    rdfs:label 'Calcium Ppm' ;
    rdfs:comment 'Plant-available calcium (Ca) concentration in parts per million (ppm). Calcium is a secondary macronutrient essential for cell wall development and root growth. Also used in calculating percent base saturation and Cation Exchange Capacity (CEC) balance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'Unique reference number of the Certificate of Analysis (COA) issued by the laboratory for this soil sample. The COA is the official document certifying the analytical results and chain of custody.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropSeasonYear rdf:type rdf:Property ;
    rdfs:label 'Crop Season Year' ;
    rdfs:comment 'The four-digit crop production year associated with this soil sampling event (e.g., 2024). Used to align soil test results with the corresponding growing season for fertilizer prescription planning and year-over-year soil health trend analysis.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Number' ;
    rdfs:comment 'Official accreditation or certification number of the laboratory that analyzed the sample, issued by a recognized accreditation body (e.g., A2LA, NELAP). Supports regulatory compliance and audit traceability.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labReportDate rdf:type rdf:Property ;
    rdfs:label 'Lab Report Date' ;
    rdfs:comment 'Date on which the laboratory issued the official analytical results report for this soil sample. Used to calculate lab turnaround time and determine data currency for fertilizer prescriptions.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Lab Submission Date' ;
    rdfs:comment 'Date on which the collected soil sample was submitted to the analytical laboratory for processing. Used to track turnaround time and chain-of-custody compliance.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limeRecommendationLbsAc rdf:type rdf:Property ;
    rdfs:label 'Lime Recommendation Lbs Ac' ;
    rdfs:comment 'Laboratory-recommended agricultural lime application rate in pounds per acre, calculated from soil pH and buffer pH results to raise soil pH to the target level for the planned crop. Directly used in fertilizer prescription and VRA lime application planning.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:magnesiumPpm rdf:type rdf:Property ;
    rdfs:label 'Magnesium Ppm' ;
    rdfs:comment 'Plant-available magnesium (Mg) concentration in parts per million (ppm). Magnesium is a secondary macronutrient and central component of chlorophyll. Used in CEC base saturation calculations and dolomitic lime application decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrateNPpm rdf:type rdf:Property ;
    rdfs:label 'Nitrate N Ppm' ;
    rdfs:comment 'Plant-available nitrate nitrogen (NO3-N) concentration in parts per million (ppm) as measured in the soil sample. A key component of the Nitrogen-Phosphorus-Potassium (NPK) nutrient profile. Directly informs nitrogen fertilizer application rates and VRA prescriptions.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrogenRecommendationLbsAc rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Recommendation Lbs Ac' ;
    rdfs:comment 'Laboratory or agronomist-recommended nitrogen (N) fertilizer application rate in pounds per acre based on soil nitrate-N test results, organic matter nitrogen credit, and planned crop yield goal. Core input for NPK fertilizer prescription and VRA planning.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phWater rdf:type rdf:Property ;
    rdfs:label 'Ph Water' ;
    rdfs:comment 'Soil pH measured using the 1:1 soil-to-water suspension method, representing the Potential of Hydrogen (pH) — the primary indicator of soil acidity or alkalinity. Values range from 0-14; optimal crop production typically falls between 6.0-7.0. Drives lime application recommendations.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phosphorusMethod rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Method' ;
    rdfs:comment 'Laboratory extraction method used to determine plant-available phosphorus concentration. Bray-1 is standard for acidic soils; Mehlich-3 is a universal extractant; Olsen is used for calcareous/alkaline soils. Method must be recorded as results are not directly comparable across methods.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phosphorusRecommendationLbsAc rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Recommendation Lbs Ac' ;
    rdfs:comment 'Laboratory or agronomist-recommended phosphate (P2O5) fertilizer application rate in pounds per acre based on soil phosphorus test results and planned crop yield goal. Core input for NPK fertilizer prescription and VRA planning.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumRecommendationLbsAc rdf:type rdf:Property ;
    rdfs:label 'Potassium Recommendation Lbs Ac' ;
    rdfs:comment 'Laboratory or agronomist-recommended potash (K2O) fertilizer application rate in pounds per acre based on soil potassium test results and planned crop yield goal. Core input for NPK fertilizer prescription and VRA planning.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleDepthIn rdf:type rdf:Property ;
    rdfs:label 'Sample Depth In' ;
    rdfs:comment 'Depth in inches at which the soil sample was collected from the surface. Standard agronomic sampling depths are 0-6 inches (topsoil) or 6-12 inches (subsoil). Critical for interpreting nutrient availability relative to root zone.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Method' ;
    rdfs:comment 'Method used to collect the soil sample. Grid sampling uses a systematic spatial grid; zone sampling collects within defined management zones; composite combines multiple cores; benchmark uses fixed reference points for longitudinal tracking.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Externally-known, human-readable sample identifier assigned at time of collection, used for lab submission tracking and field cross-referencing. Typically formatted as a lab accession or farm-assigned code (e.g., FARM-2024-F01-Z3).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the soil sample record, tracking progression from field collection through laboratory analysis to agronomic approval for use in fertilizer prescriptions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingTechnician rdf:type rdf:Property ;
    rdfs:label 'Sampling Technician' ;
    rdfs:comment 'Name or identifier of the agronomist, certified crop advisor (CCA), or field technician who physically collected the soil sample. Used for chain-of-custody documentation and quality assurance traceability.' ;
    rdfs:domain ind:LandSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfurPpm rdf:type rdf:Property ;
    rdfs:label 'Sulfur Ppm' ;
    rdfs:comment 'Plant-available sulfur (S) concentration in parts per million (ppm). Sulfur is a secondary macronutrient critical for protein synthesis and enzyme function. Deficiencies are increasingly common in high-yield cropping systems and drive sulfur fertilizer recommendations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincPpm rdf:type rdf:Property ;
    rdfs:label 'Zinc Ppm' ;
    rdfs:comment 'Plant-available zinc (Zn) micronutrient concentration in parts per million (ppm), measured by Mehlich-3 or DTPA extraction. Zinc deficiency is common in high-pH soils and drives micronutrient fertilizer recommendations for corn and other sensitive crops.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holderAccountId rdf:type rdf:Property ;
    rdfs:label 'Holder Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Water rights are held by legal entities (accounts). Water right transfers, annual use reporting to state agencies, and curtailment notifications are directed to the holder account. Water rights can be' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:annualUseReportRequired rdf:type rdf:Property ;
    rdfs:label 'Annual Use Report Required' ;
    rdfs:comment 'Indicates whether the permit requires submission of an annual water use report to the issuing regulatory agency. True if mandatory reporting is required; False otherwise. Drives compliance calendar and reporting workflow.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualVolumeAcreFeet rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Acre Feet' ;
    rdfs:comment 'Maximum volume of water authorized for diversion or extraction per calendar or water year, expressed in acre-feet. One acre-foot equals approximately 325,851 US gallons. This is the primary volumetric entitlement cap for compliance and water budget planning.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aquiferName rdf:type rdf:Property ;
    rdfs:label 'Aquifer Name' ;
    rdfs:comment 'Name or designation of the groundwater aquifer from which extraction is authorized. Applicable for groundwater rights only. Used for aquifer management, depletion tracking, and state groundwater conservation district compliance.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curtailmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Curtailment Effective Date' ;
    rdfs:comment 'The date on which the current curtailment order became effective. Null if no curtailment is in effect. Used for operational planning and water supply risk management.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curtailmentStatus rdf:type rdf:Property ;
    rdfs:label 'Curtailment Status' ;
    rdfs:comment 'Current curtailment status indicating whether the regulatory authority has restricted or reduced authorized diversions due to drought, shortage, or senior right priority calls. Not_curtailed means full use is authorized; curtailed means diversion is prohibited; partially_curtailed means reduced diversion is allowed.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateCfs rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Cfs' ;
    rdfs:comment 'Maximum instantaneous diversion or extraction rate authorized under the water right, expressed in cubic feet per second (CFS). Governs the rate of water withdrawal at any given moment, distinct from the annual volume cap.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holderType rdf:type rdf:Property ;
    rdfs:label 'Holder Type' ;
    rdfs:comment 'Legal entity classification of the water right holder. Determines applicable regulatory requirements, reporting obligations, and transfer restrictions under state water law.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjudicated rdf:type rdf:Property ;
    rdfs:label 'Is Adjudicated' ;
    rdfs:comment 'Indicates whether this water right has been formally adjudicated (confirmed by a court or administrative proceeding) as part of a general stream adjudication. Adjudicated rights have legally confirmed priority and volume.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether this water right may be legally transferred, sold, or leased to another party under applicable state water law. True if transferable; False if appurtenant to the land and non-transferable.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Name of the governmental or regulatory authority that issued the water right permit or certificate (e.g., State Engineer\'s Office, State Water Resources Control Board, Bureau of Reclamation). Required for regulatory correspondence and compliance reporting.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'Two-letter US state code of the jurisdiction that issued the water right. Determines the applicable state water law doctrine (prior appropriation vs. riparian) and regulatory framework.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUseReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Use Report Date' ;
    rdfs:comment 'Date on which the most recent annual water use report was submitted to the regulatory agency. Used to track reporting compliance and identify overdue filings.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'The date on which the water permit or certificate expires and must be renewed. Null for perpetual rights. Used for compliance calendar management and renewal workflow triggers.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'The date on which the water permit or certificate was officially issued by the issuing regulatory agency. May differ from the priority date in appropriative systems.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permittedUse rdf:type rdf:Property ;
    rdfs:label 'Permitted Use' ;
    rdfs:comment 'The authorized beneficial use category for which the water right was granted. Irrigation covers crop and field watering; livestock covers animal husbandry water supply; domestic covers on-farm household use; municipal, industrial, and recreational uses apply where applicable. Use must match actual application for compliance. [ENUM-REF-CANDIDATE: irrigation|livestock|domestic|municipal|industrial|recreational|aquaculture|dust_suppression — promote to reference product if additional uses are needed]' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfUseDescription rdf:type rdf:Property ;
    rdfs:label 'Place Of Use Description' ;
    rdfs:comment 'Legal description or narrative of the authorized place(s) where diverted or extracted water may be beneficially used. May reference legal land descriptions (township, range, section) or parcel identifiers. Restricts where water can be applied under the permit.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointOfDiversionLat rdf:type rdf:Property ;
    rdfs:label 'Point Of Diversion Lat' ;
    rdfs:comment 'GPS latitude coordinate (decimal degrees, WGS84) of the authorized point of diversion or extraction. Required for regulatory mapping, GIS integration with Esri ArcGIS, and field verification of diversion infrastructure.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointOfDiversionLon rdf:type rdf:Property ;
    rdfs:label 'Point Of Diversion Lon' ;
    rdfs:comment 'GPS longitude coordinate (decimal degrees, WGS84) of the authorized point of diversion or extraction. Required for regulatory mapping, GIS integration with Esri ArcGIS, and field verification of diversion infrastructure.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousHolderName rdf:type rdf:Property ;
    rdfs:label 'Previous Holder Name' ;
    rdfs:comment 'Name of the entity or individual from whom this water right was most recently transferred. Supports chain-of-title documentation and transfer history for regulatory compliance.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'The legally established date that determines the seniority of this water right relative to other rights on the same water source. Under prior appropriation doctrine, earlier priority dates have superior claim during shortage conditions. Critical for western-state water allocation compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Legal classification of the water right doctrine under which the entitlement is held. Surface rights derive from surface water bodies; groundwater rights pertain to aquifer extraction; riparian rights attach to land adjacent to a water body; appropriative rights follow prior appropriation doctrine (first-in-time, first-in-right) common in western US states; prescriptive rights arise from long-term use. [ENUM-REF-CANDIDATE: surface|groundwater|riparian|appropriative|prescriptive|adjudicated — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Season End Date' ;
    rdfs:comment 'The calendar date on which authorized water diversion or use must cease each year under seasonal restrictions of the permit. Null if the right has no seasonal restriction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Season Start Date' ;
    rdfs:comment 'The calendar date on which authorized water diversion or use may begin each year under seasonal restrictions of the permit. Null if the right has no seasonal restriction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceWaterBody rdf:type rdf:Property ;
    rdfs:label 'Source Water Body' ;
    rdfs:comment 'Name of the surface water body (river, stream, canal, reservoir, lake) or groundwater basin from which water is authorized to be diverted or extracted. Required for source identification in regulatory filings and environmental monitoring.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceWaterBodyType rdf:type rdf:Property ;
    rdfs:label 'Source Water Body Type' ;
    rdfs:comment 'Classification of the water source type. Distinguishes surface water sources (river, stream, canal, reservoir, lake, spring) from groundwater sources (aquifer) for regulatory categorization and environmental impact assessment. [ENUM-REF-CANDIDATE: river|stream|canal|reservoir|lake|spring|aquifer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterDistrict rdf:type rdf:Property ;
    rdfs:label 'Water District' ;
    rdfs:comment 'Name of the irrigation district, water conservation district, or water management area within which this water right is administered. Relevant for district-level allocation, assessment fees, and delivery scheduling.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterRightStatus rdf:type rdf:Property ;
    rdfs:label 'Water Right Status' ;
    rdfs:comment 'Current lifecycle status of the water right. Active indicates the right is valid and in use; inactive indicates the right is held but not currently exercised; transferred indicates ownership or appurtenance has changed; forfeited indicates the right has been lost due to non-use or regulatory action; suspended indicates temporary regulatory hold.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDepthFt rdf:type rdf:Property ;
    rdfs:label 'Well Depth Ft' ;
    rdfs:comment 'Total drilled depth of the extraction well in feet below ground surface. Applicable for groundwater rights. Used for aquifer characterization, pump sizing, and regulatory well construction compliance.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Well Registration Number' ;
    rdfs:comment 'Official registration or permit number assigned to the extraction well by the state well permitting authority. Applicable for groundwater rights. Links the water right to the physical well infrastructure for compliance and inspection records.' ;
    rdfs:domain ind:WaterRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalId rdf:type rdf:Property ;
    rdfs:label 'Animal Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each individual animal record. Serves as the primary key and universal reference across all livestock management systems.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Animal .

ind:breedId rdf:type rdf:Property ;
    rdfs:label 'Breed Id' ;
    rdfs:comment 'Reference identifier linking to the breed master record for this animal\'s registered or recognized breed (e.g., Angus, Hereford, Duroc, Merino). Supports genetic performance benchmarking, EPD (Expected Progeny Difference) analysis, and breed association reporting.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Breed .

ind:damAnimalId rdf:type rdf:Property ;
    rdfs:label 'Dam Animal Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the mother (dam) animal record within this same table. Enables maternal lineage tracing for genetic performance analysis, EPD calculations, and pedigree documentation. Null for purchased animals with unknown dam.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Animal .

ind:penLocationId rdf:type rdf:Property ;
    rdfs:label 'Pen Location Id' ;
    rdfs:comment 'Reference identifier for the current physical pen, pasture, or paddock where the animal is housed or grazing. Supports daily management, feeding operations, and biosecurity zone tracking. Linked to the facility location master.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PenLocation .

ind:sireAnimalId rdf:type rdf:Property ;
    rdfs:label 'Sire Animal Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the father (sire) animal record or AI (Artificial Insemination) sire reference. Enables paternal lineage tracing for EPD (Expected Progeny Difference) analysis, genetic improvement programs, and pedigree documentation.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Animal .

ind:sourceVendorId rdf:type rdf:Property ;
    rdfs:label 'Source Vendor Id' ;
    rdfs:comment 'Reference identifier for the external vendor, auction house, or producer from whom the animal was purchased. Null for born-on-farm animals. Supports supplier traceability, biosecurity source tracking, and procurement analytics in SAP S/4HANA MM module.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:antibioticFree rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Free' ;
    rdfs:comment 'Indicates whether the animal has never received antibiotic treatments and qualifies for \'Never Ever 3\' (NE3) or antibiotic-free marketing programs. Drives premium market channel eligibility and label claim compliance.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Actual or estimated calendar date the animal was born. Used to calculate age, determine production class eligibility, schedule vaccinations, and compute days-on-feed (DOF). Required for USDA age verification programs and COOL documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:birthWeightKg rdf:type rdf:Property ;
    rdfs:label 'Birth Weight Kg' ;
    rdfs:comment 'Body weight of the animal recorded at or shortly after birth, expressed in kilograms. Baseline measurement for growth performance tracking, EPD (Expected Progeny Difference) calculations, and dam/sire genetic evaluation.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Description of the hot iron or freeze brand applied to the animal for permanent ownership identification. Includes brand symbol, location on body, and registration state. Required for cattle ownership verification in brand-law states and theft prevention.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedCompositionPct rdf:type rdf:Property ;
    rdfs:label 'Breed Composition Pct' ;
    rdfs:comment 'Percentage of the animal\'s genetics attributable to the primary breed identified in breed_id. Expressed as a decimal percentage (e.g., 75.00 for 75% Angus). Used for crossbreeding program management, breed association registration eligibility, and genetic improvement analytics.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Current Weight Kg' ;
    rdfs:comment 'Most recently recorded live body weight of the animal in kilograms. Updated at each weigh event. Used for feed ration calculation, marketing weight assessment, and growth performance monitoring. Distinct from birth weight and harvest weight.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earTagNumber rdf:type rdf:Property ;
    rdfs:label 'Ear Tag Number' ;
    rdfs:comment 'Visual alphanumeric identifier printed on the physical ear tag applied to the animal. Used for visual identification in the field and pen. May be a farm-assigned number or official USDA 840 tag number. Supports COOL country-of-origin labeling traceability.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eid rdf:type rdf:Property ;
    rdfs:label 'Eid' ;
    rdfs:comment 'Electronic Identification number as printed on the visual ear tag and encoded in the RFID transponder. May differ from the raw RFID tag number in formatted display. Used in John Deere Operations Center and Granular Farm Management for animal-level record linkage.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'Current veterinary health status of the animal. HEALTHY=no active health concerns; SICK=active illness under observation; QUARANTINE=isolated for biosecurity or regulatory reasons; TREATED=currently under veterinary treatment with active withdrawal period; RECOVERED=returned to healthy status post-treatment; CONDEMNED=condemned by veterinary inspection.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastWeighDate rdf:type rdf:Property ;
    rdfs:label 'Last Weigh Date' ;
    rdfs:comment 'Calendar date of the most recent live weight measurement. Used to assess recency of weight data, calculate average daily gain (ADG) since last weigh, and trigger re-weigh alerts when interval exceeds operational thresholds.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officialUsdaTag rdf:type rdf:Property ;
    rdfs:label 'Official Usda Tag' ;
    rdfs:comment 'Official USDA 840-prefix 15-digit national uniform ear tag number assigned under the USDA Animal Disease Traceability (ADT) framework. Required for interstate movement of cattle, bison, and other covered species. Begins with country code 840 (USA).' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Indicates whether the animal was born on the operation, purchased from an external source, or transferred in from another company-owned facility. Critical for COOL country-of-origin labeling, FSMA traceability, and biosecurity risk classification.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parityNumber rdf:type rdf:Property ;
    rdfs:label 'Parity Number' ;
    rdfs:comment 'Number of times a female animal has given birth (parturitions). Parity 0 = never calved/farrowed/lambed; Parity 1 = first calf/litter; etc. Used for reproductive performance analysis, culling decisions, and production benchmarking for dairy and cow-calf operations.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionClass rdf:type rdf:Property ;
    rdfs:label 'Production Class' ;
    rdfs:comment 'Operational production class that defines the animal\'s role in the production system. Determines applicable management protocols, feed rations, performance benchmarks, and marketing channels. [ENUM-REF-CANDIDATE: COW_CALF|STOCKER|FEEDLOT|DAIRY|BREEDING|SHOW|SEEDSTOCK|REPLACEMENT_HEIFER — promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexCode rdf:type rdf:Property ;
    rdfs:label 'Sex Code' ;
    rdfs:comment 'Biological sex and reproductive status of the animal. M=Male (intact bull/boar/ram), F=Female (cow/sow/ewe), C=Castrated male (steer/barrow/wether), S=Spayed female, B=Barrow. Drives production class assignment, feed ration, and harvest yield expectations.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesCode rdf:type rdf:Property ;
    rdfs:label 'Species Code' ;
    rdfs:comment 'Standardized species classification of the animal. Drives applicable regulatory frameworks (FSIS, APHIS), withdrawal period rules, and feed ration formulations. [ENUM-REF-CANDIDATE: BOVINE|SWINE|OVINE|CAPRINE|EQUINE|POULTRY|CERVID|BISON|OTHER — promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tattooNumber rdf:type rdf:Property ;
    rdfs:label 'Tattoo Number' ;
    rdfs:comment 'Permanent alphanumeric tattoo applied inside the ear or on the body for permanent identification, particularly for swine, sheep, and registered cattle. Used as a backup identifier when ear tags are lost and for breed association registration.' ;
    rdfs:domain ind:Animal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalDispositionId rdf:type rdf:Property ;
    rdfs:label 'Animal Disposition Id' ;
    rdfs:comment 'Primary key for animal_disposition' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:livestockProductId rdf:type rdf:Property ;
    rdfs:label 'Livestock Product Id' ;
    rdfs:comment 'Foreign key linking to product.livestock_product. Business justification: FSMA farm-to-fork traceability and USDA FSIS lot tracking require linking the harvest/disposition event to the resulting livestock_product record. This is the foundational slaughter-to-product traceab' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LivestockProduct .

ind:originDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Origin Declaration Id' ;
    rdfs:comment 'Foreign key linking to sales.origin_declaration. Business justification: USDA COOL regulations require meat sold at retail to carry country-of-origin labeling traceable to the harvest record. Linking animal_disposition to the COOL origin_declaration enables automated COOL ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OriginDeclaration .

ind:primaryAnimalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Animal Employee Id' ;
    rdfs:comment 'Reference to the FSIS or USDA-accredited veterinary inspector who conducted ante-mortem and/or post-mortem inspection. Required for regulatory audit trail and inspection record integrity.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ageDays rdf:type rdf:Property ;
    rdfs:label 'Age Days' ;
    rdfs:comment 'Age of the animal in days at the time of disposition, calculated from birth date. Used for regulatory age-at-slaughter compliance (e.g., veal, bob veal), carcass quality grading, and performance benchmarking.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antibioticWithdrawalCompliant rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Withdrawal Compliant' ;
    rdfs:comment 'Indicates whether all antibiotic and veterinary drug withdrawal periods were satisfied prior to harvest. Critical food safety compliance flag. False triggers mandatory hold and regulatory notification under FSIS residue testing protocols.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aphisReportNumber rdf:type rdf:Property ;
    rdfs:label 'Aphis Report Number' ;
    rdfs:comment 'Official USDA APHIS report number assigned when this disposition event triggers a mandatory regulatory notification (e.g., foreign animal disease suspicion, mass mortality event). Null if no APHIS report was required.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedCode rdf:type rdf:Property ;
    rdfs:label 'Breed Code' ;
    rdfs:comment 'Standardized breed identifier for the animal. Relevant for carcass quality grading, yield prediction, and genetic performance analytics. Sourced from the animal master record at time of disposition.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carcassDispositionCode rdf:type rdf:Property ;
    rdfs:label 'Carcass Disposition Code' ;
    rdfs:comment 'FSIS post-mortem inspection outcome for the carcass. Passed indicates approved for human consumption; condemned indicates rejected and must be destroyed or rendered; retained indicates held pending further inspection.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeOfDeathCode rdf:type rdf:Property ;
    rdfs:label 'Cause Of Death Code' ;
    rdfs:comment 'Standardized veterinary code identifying the primary cause of death for non-harvest disposition types (natural death, euthanasia, condemnation). Null for planned harvest events. [ENUM-REF-CANDIDATE: respiratory_disease|digestive_disorder|injury_trauma|metabolic_disorder|infectious_disease|unknown — promote to reference product]' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeOfDeathDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Of Death Description' ;
    rdfs:comment 'Free-text veterinary narrative describing the cause of death or reason for condemnation. Supplements the standardized cause_of_death_code with clinical detail for mortality investigations and APHIS reporting.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condemnationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Condemnation Reason Code' ;
    rdfs:comment 'Standardized FSIS code identifying the regulatory reason for carcass condemnation. Null for passed carcasses. Required for FSIS annual condemnation reporting and food safety analytics. [ENUM-REF-CANDIDATE: septicemia|pneumonia|peritonitis|abscess|contamination|bruising|cancer|other — promote to reference product]' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNumber rdf:type rdf:Property ;
    rdfs:label 'Disposition Number' ;
    rdfs:comment 'Externally-known business identifier for this disposition event, used in regulatory submissions, veterinary records, and supply chain documentation. Formatted as DISP-YYYY-NNNNNN.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Precise date and time at which the terminal disposition event was executed. Required for Pre-Harvest Interval (PHI) and Restricted Entry Interval (REI) compliance calculations and ante-mortem inspection sequencing.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'Classification of the terminal lifecycle event. Determines downstream regulatory reporting obligations, carcass handling procedures, and financial treatment. [ENUM-REF-CANDIDATE: harvest|natural_death|euthanasia|condemnation|salvage_sale|emergency_slaughter — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dressingYieldPct rdf:type rdf:Property ;
    rdfs:label 'Dressing Yield Pct' ;
    rdfs:comment 'Ratio of hot carcass weight to live weight expressed as a percentage. Key performance indicator for harvest efficiency and carcass value. Calculated as (hot_carcass_weight_kg / live_weight_kg) * 100.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hotCarcassWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hot Carcass Weight Kg' ;
    rdfs:comment 'Weight of the carcass immediately after slaughter and evisceration, before chilling, expressed in kilograms. Primary basis for yield calculations, grading, and producer payment in harvest events.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTreatmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Treatment Date' ;
    rdfs:comment 'Date of the most recent veterinary drug or antibiotic treatment administered to the animal prior to disposition. Used to verify withdrawal period compliance and calculate days-off-drug at time of harvest.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTreatmentDrug rdf:type rdf:Property ;
    rdfs:label 'Last Treatment Drug' ;
    rdfs:comment 'Name of the most recent veterinary drug or antibiotic administered to the animal. Used in conjunction with last_treatment_date to verify withdrawal period compliance against FDA-approved withdrawal intervals.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveWeightKg rdf:type rdf:Property ;
    rdfs:label 'Live Weight Kg' ;
    rdfs:comment 'Live body weight of the animal recorded at the time of ante-mortem inspection or mortality event, expressed in kilograms. Used for yield calculations, payment settlement, and performance analytics.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:necropsyFindings rdf:type rdf:Property ;
    rdfs:label 'Necropsy Findings' ;
    rdfs:comment 'Summary of pathological findings from the post-mortem examination. Documents lesions, disease conditions, and contributing factors identified during necropsy. Supports disease surveillance and herd health management.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necropsyPerformed rdf:type rdf:Property ;
    rdfs:label 'Necropsy Performed' ;
    rdfs:comment 'Indicates whether a post-mortem examination (necropsy) was conducted on the animal. Required for APHIS disease surveillance reporting and mortality investigation protocols.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date on which the disposition event was officially reported to the regulatory authority. Used to verify timely reporting compliance with FSIS and APHIS notification deadlines.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReported rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reported' ;
    rdfs:comment 'Indicates whether this disposition event has been submitted to the applicable regulatory authority (FSIS, APHIS, or state agency). Supports compliance monitoring and audit readiness.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salvageSaleValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Sale Value' ;
    rdfs:comment 'Monetary value received for the animal or carcass in a salvage sale disposition. Applicable only when disposition_type is salvage_sale. Used for financial loss recovery accounting and insurance claim support.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Usda Quality Grade' ;
    rdfs:comment 'Official USDA quality grade assigned to the carcass based on marbling, maturity, and other palatability factors. Drives pricing, market channel selection, and producer premium payments. Applicable primarily to beef. [ENUM-REF-CANDIDATE: Prime|Choice|Select|Standard|Commercial|Utility|Cutter|Canner — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaYieldGrade rdf:type rdf:Property ;
    rdfs:label 'Usda Yield Grade' ;
    rdfs:comment 'Numerical USDA yield grade (1.0–5.9) indicating the estimated percentage of boneless, closely trimmed retail cuts from the round, loin, rib, and chuck. Lower values indicate higher cutability. Used for pricing and market channel decisions.' ;
    rdfs:domain ind:AnimalDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:animalMovementId rdf:type rdf:Property ;
    rdfs:label 'Animal Movement Id' ;
    rdfs:comment 'Unique system-generated identifier for each animal or group movement transaction record. Primary key for the animal_movement data product.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to supply.carrier. Business justification: Livestock transport uses approved carriers with FSMA Sanitary Transport certification. Linking animal_movement to carrier enables carrier performance tracking, sanitary transport compliance verificati' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:destinationLocationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Facility Id' ;
    rdfs:comment 'Reference to the location (pen, pasture, barn, facility, or external premises) to which the animal or group was moved. Used for biosecurity zone tracking and APHIS traceability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:destinationPremisesFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Premises Facility Id' ;
    rdfs:comment 'USDA-registered premises identification number (PIN) for the destination location. Required for inter-premises movements under APHIS Animal Disease Traceability rule. Format follows USDA National Premises Information Repository (NPIR) standard.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who drove the transport vehicle for this movement. Used for workforce accountability and chain-of-custody documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryAnimalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Animal Facility Id' ;
    rdfs:comment 'Reference to the location (pen, pasture, barn, facility, or external premises) from which the animal or group departed. Used for biosecurity zone tracking and APHIS traceability.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:transportOrderId rdf:type rdf:Property ;
    rdfs:label 'Transport Order Id' ;
    rdfs:comment 'Foreign key linking to supply.transport_order. Business justification: Livestock transport requires carrier assignment, route planning, and equipment scheduling via transport orders. Linking animal_movement to transport_order enables FSMA Sanitary Transport compliance tr' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportOrder .

ind:averageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Average Weight Kg' ;
    rdfs:comment 'Average live weight in kilograms of animals in this movement at time of loading. Used for transport payload calculations, sale weight documentation, and performance benchmarking against YPM (Yield Per Acre Metric) targets.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biosecurityZoneCrossing rdf:type rdf:Property ;
    rdfs:label 'Biosecurity Zone Crossing' ;
    rdfs:comment 'Indicates whether this movement crosses a defined biosecurity zone boundary. True triggers mandatory cleaning and disinfection (C&D) protocols for transport vehicles and equipment per APHIS biosecurity guidelines.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandInspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Brand Inspection Number' ;
    rdfs:comment 'State brand inspection certificate number issued for livestock movements in brand-law states. Required for cattle and horse movements in western US states to verify ownership and prevent theft.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolCountryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Cool Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country of origin for COOL (Country of Origin Labeling) compliance. Required for covered commodities sold at retail under USDA AMS COOL regulations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateCode rdf:type rdf:Property ;
    rdfs:label 'Destination State Code' ;
    rdfs:comment 'Two-letter US state code for the destination location of this movement. Required for APHIS interstate movement reporting and COOL compliance documentation.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headCountArrived rdf:type rdf:Property ;
    rdfs:label 'Head Count Arrived' ;
    rdfs:comment 'Actual number of animals confirmed received at the destination location upon arrival. May differ from head_count_moved due to in-transit mortality or escapes. Used for shrink calculation and inventory reconciliation.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headCountMoved rdf:type rdf:Property ;
    rdfs:label 'Head Count Moved' ;
    rdfs:comment 'Number of individual animals included in this movement transaction. For individual animal movements this is 1; for group movements this reflects the total head count transferred. Critical for inventory reconciliation and APHIS traceability.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Health Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the veterinary health certificate accompanying this movement. Movements occurring after this date are non-compliant with APHIS interstate movement regulations.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interstateMovement rdf:type rdf:Property ;
    rdfs:label 'Interstate Movement' ;
    rdfs:comment 'Indicates whether this movement crosses state lines. True triggers mandatory APHIS official identification and Certificate of Veterinary Inspection (CVI) requirements under the Animal Disease Traceability rule.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'The calendar date on which the animal or group movement physically occurred. Principal business event date used for APHIS traceability reporting, COOL compliance, and withdrawal period calculations.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementNotes rdf:type rdf:Property ;
    rdfs:label 'Movement Notes' ;
    rdfs:comment 'Free-text field for operational notes, special handling instructions, or observations recorded at time of movement. May include animal condition observations, loading difficulties, or regulatory exceptions noted by the handler.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReason rdf:type rdf:Property ;
    rdfs:label 'Movement Reason' ;
    rdfs:comment 'Business reason or purpose for the animal or group movement. Drives downstream processing workflows, APHIS reporting categories, and biosecurity zone management. [ENUM-REF-CANDIDATE: weaning|backgrounding|feedlot_placement|sale|harvest|death|breeding|health_treatment|pasture_rotation|quarantine — promote to reference product]' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this movement transaction, used for cross-referencing with transport documents, USDA premises records, and operational systems such as SAP S/4HANA livestock movement orders. Serves as the human-readable transaction code.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle state of the movement transaction. Tracks the workflow from planning through physical completion, supporting operational visibility and exception management.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the animal or group movement was initiated or completed, captured from FMIS or IoT gate sensors. Provides sub-day precision for biosecurity event sequencing and audit trails.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:officialIdNumber rdf:type rdf:Property ;
    rdfs:label 'Official Id Number' ;
    rdfs:comment 'The official identification number (e.g., RFID tag number, ear tag number, brand registration number) recorded at time of movement. Required for APHIS interstate movement documentation and disease traceability investigations.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialIdType rdf:type rdf:Property ;
    rdfs:label 'Official Id Type' ;
    rdfs:comment 'Type of official animal identification applied or verified at time of movement. RFID (Radio Frequency Identification) ear tags are the USDA-approved official identification for interstate movements under ADT rule.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStateCode rdf:type rdf:Property ;
    rdfs:label 'Origin State Code' ;
    rdfs:comment 'Two-letter US state code for the origin location of this movement. Required for APHIS interstate movement reporting, COOL country/state of origin labeling, and state brand inspection compliance.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total live weight in kilograms of all animals in this movement at time of loading. Used for transport billing, sale contracts, and FSIS ante-mortem documentation.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Transport Distance Km' ;
    rdfs:comment 'Total distance in kilometers traveled during this movement. Used for animal welfare compliance (EU transport regulations, USDA 28-Hour Law), transport cost allocation, and carbon footprint reporting.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportDurationHours rdf:type rdf:Property ;
    rdfs:label 'Transport Duration Hours' ;
    rdfs:comment 'Total hours animals were in transit during this movement. Critical for USDA 28-Hour Law compliance (animals must be unloaded for rest, water, and feed after 28 consecutive hours of transport) and animal welfare audits.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Vehicle License Plate' ;
    rdfs:comment 'License plate number of the transport vehicle or trailer used for this movement. Recorded for biosecurity traceability, DOT compliance, and chain-of-custody documentation when the vehicle is not registered in the fleet asset system.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veterinaryHealthCertNumber rdf:type rdf:Property ;
    rdfs:label 'Veterinary Health Cert Number' ;
    rdfs:comment 'Certificate of Veterinary Inspection (CVI) or health certificate number issued by an accredited veterinarian for interstate or international movements. Required by APHIS for regulated species and disease-control movements.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalPeriodActive rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Period Active' ;
    rdfs:comment 'Indicates whether any animal in this movement is currently within an antibiotic or chemical withdrawal period (Pre-Harvest Interval - PHI). True prevents movement to harvest facilities and triggers FSIS compliance holds. Supports antibiotic stewardship and FSMA compliance.' ;
    rdfs:domain ind:AnimalMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brokerId rdf:type rdf:Property ;
    rdfs:label 'Broker Id' ;
    rdfs:comment 'Foreign key linking to sales.broker. Business justification: Livestock auctions and direct packer sales routinely involve licensed livestock commission agents/brokers. USDA Packers and Stockyards Act requires tracking broker involvement in livestock transaction' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Broker .

ind:salesPriceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Price Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.price_agreement. Business justification: Livestock packer sales operate under negotiated price agreements (formula pricing, grid pricing, or cash market agreements). Linking animal_transaction to the governing price agreement enables price v' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreement .

ind:antibioticWithdrawalClearDate rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Withdrawal Clear Date' ;
    rdfs:comment 'The date on or after which the animals are cleared from any antibiotic withdrawal period and are eligible for harvest or sale. Critical for FSIS food safety compliance and prevention of violative drug residues in meat products. Populated based on most recent treatment records.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgWeightPerHeadLbs rdf:type rdf:Property ;
    rdfs:label 'Avg Weight Per Head Lbs' ;
    rdfs:comment 'Average live weight per individual animal in pounds at the time of transfer. Derived operationally at point of transaction (scale ticket) and stored as a business fact. Supports performance benchmarking, feed efficiency analysis, and grading decisions.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandInspectionCertNumber rdf:type rdf:Property ;
    rdfs:label 'Brand Inspection Cert Number' ;
    rdfs:comment 'Certificate number issued by the state brand inspection authority verifying ownership of branded livestock at time of transfer. Required in brand law states (e.g., TX, CO, MT, WY) for cattle and horse transactions to establish legal title.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breed rdf:type rdf:Property ;
    rdfs:label 'Breed' ;
    rdfs:comment 'Breed designation of the animals in the transaction (e.g., Angus, Hereford, Duroc, Hampshire). Relevant for cost basis accounting, genetic program tracking, and premium pricing in sales contracts.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeYieldBasis rdf:type rdf:Property ;
    rdfs:label 'Grade Yield Basis' ;
    rdfs:comment 'The pricing and grading basis applied to outbound sale transactions. Indicates whether the sale price is based on live weight, dressed weight, USDA yield grade, USDA quality grade, or a formula-based pricing arrangement. Populated only for sale transactions.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headCount rdf:type rdf:Property ;
    rdfs:label 'Head Count' ;
    rdfs:comment 'Number of individual animals included in this transaction. Used for inventory reconciliation, cost-per-head calculations, and APHIS movement reporting. Combined with weight and price fields to derive per-unit economics.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Health Certificate Number' ;
    rdfs:comment 'Official USDA APHIS Veterinary Services (VS) health certificate number issued by an accredited veterinarian certifying the health status of animals at time of movement. Required for interstate and international livestock shipments per 9 CFR Part 86.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountry rdf:type rdf:Property ;
    rdfs:label 'Origin Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country of origin for the animals. Required for COOL compliance, import permit processing, and APHIS international traceability. Populated for all transactions; defaults to USA for domestic transfers.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originState rdf:type rdf:Property ;
    rdfs:label 'Origin State' ;
    rdfs:comment 'Two-letter US state code of the origin premises from which the animals were shipped. Required for COOL (Country of Origin Labeling) chain-of-custody documentation and APHIS interstate movement reporting.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerCwt rdf:type rdf:Property ;
    rdfs:label 'Price Per Cwt' ;
    rdfs:comment 'Purchase or sale price expressed per hundredweight (CWT = 100 lbs) in USD. Standard pricing basis for cattle and hog transactions in North American livestock markets. Populated when the transaction is priced on a weight basis.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerHead rdf:type rdf:Property ;
    rdfs:label 'Price Per Head' ;
    rdfs:comment 'Purchase or sale price expressed on a per-head basis in USD. Populated when the transaction is priced per individual animal rather than per CWT. Mutually exclusive with price_per_cwt for a given transaction; one or both may be populated depending on transaction channel.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantinePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Quarantine Period Days' ;
    rdfs:comment 'Number of days the purchased animals must remain in quarantine isolation before integration into the main herd or flock. Populated only for purchase transactions where quarantine_required = True. Supports antibiotic withdrawal period tracking and biosecurity compliance.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineRequired rdf:type rdf:Property ;
    rdfs:label 'Quarantine Required' ;
    rdfs:comment 'Indicates whether the purchased animals are subject to a mandatory quarantine period upon arrival at the receiving premises. Applicable to purchase transactions only. Drives receiving pen assignment and health monitoring workflows.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTagRange rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Range' ;
    rdfs:comment 'Range or list of RFID electronic identification tag numbers (e.g., 840 USDA official ear tags) assigned to the animals in this transaction. Supports APHIS electronic animal identification traceability requirements and individual animal tracking.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species classification of the animals involved in the transaction (e.g., bovine for cattle, swine for hogs, ovine for sheep). Drives regulatory reporting requirements, withdrawal period tracking, and FSIS/APHIS compliance rules. [ENUM-REF-CANDIDATE: bovine|swine|ovine|caprine|equine|poultry|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Value' ;
    rdfs:comment 'Gross total monetary value of the livestock transfer in USD, representing the full purchase cost (for inbound) or gross sale revenue (for outbound). Used for cost basis accounting, revenue recognition, and enterprise profitability analysis in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Total Weight Lbs' ;
    rdfs:comment 'Aggregate live weight in pounds of all animals in the transaction at the time of transfer (purchase weight for inbound; sale weight for outbound). Used for CWT (hundredweight) pricing calculations, cost basis accounting, and yield analysis.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'The commercial channel through which the livestock transfer was executed. Direct = farm-to-farm; Auction = physical livestock auction market; Video Auction = remote video-based auction (e.g., Superior Livestock); Formula = price tied to a market index or formula; Private Treaty = negotiated private sale.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The principal real-world business event date on which the livestock transfer (purchase or sale) was executed — i.e., the date of ownership transfer or market transaction. Distinct from transport or arrival dates.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionDirection rdf:type rdf:Property ;
    rdfs:label 'Transaction Direction' ;
    rdfs:comment 'Indicates whether this record represents an inbound livestock purchase (animals acquired from an external party) or an outbound livestock sale (animals transferred to an external buyer). Drives which conditional attributes are populated (e.g., quarantine period for purchases; grade/yield basis for sales).' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportCarrierName rdf:type rdf:Property ;
    rdfs:label 'Transport Carrier Name' ;
    rdfs:comment 'Name of the licensed livestock transport carrier responsible for moving the animals between premises. Required for APHIS traceability, FMCSA compliance, and freight cost allocation.' ;
    rdfs:domain ind:AnimalTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalWelfareAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Animal Welfare Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each animal welfare assessment record. Serves as the primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthProtocolId rdf:type rdf:Property ;
    rdfs:label 'Health Protocol Id' ;
    rdfs:comment 'Foreign key linking to livestock.health_protocol. Business justification: animal_welfare_assessment.welfare_protocol is currently a STRING field storing the protocol name/code. health_protocol is the master record for standardized herd health and welfare protocols. Normaliz' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthProtocol .

ind:animalCountAssessed rdf:type rdf:Property ;
    rdfs:label 'Animal Count Assessed' ;
    rdfs:comment 'Total number of individual animals observed and evaluated during this assessment session. Used to calculate prevalence rates for scored welfare indicators.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antibioticUseFlag rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Use Flag' ;
    rdfs:comment 'Indicates whether antibiotic treatments were administered to animals in the assessed pen or herd during the assessment period. Supports antibiotic stewardship tracking and withdrawal period compliance.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The calendar date on which the animal welfare evaluation was physically conducted at the pen or herd location. This is the principal real-world event date for this transaction.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment End Timestamp' ;
    rdfs:comment 'Precise date and time when the welfare assessment observation period concluded, enabling duration calculation and assessor productivity tracking.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the assessment, used in audit documentation, corrective action reports, and certification body submissions. Format: AWA-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Timestamp' ;
    rdfs:comment 'Precise date and time when the welfare assessment observation period began, used for duration tracking and scheduling compliance.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the welfare assessment record, tracking workflow from initial data entry through review and closure. [ENUM-REF-CANDIDATE: draft|in_progress|completed|reviewed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment purpose: routine internal evaluation, pre-certification audit preparation, third-party certification audit, corrective action follow-up, or regulatory inspection.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Assessor Certification Number' ;
    rdfs:comment 'Professional certification or accreditation number of the assessor (e.g., PAACO-certified auditor number, veterinary license number), required for certification body submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual who conducted the welfare assessment, captured for audit documentation and certification body reporting where assessor identity must be recorded.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyConditionScore rdf:type rdf:Property ;
    rdfs:label 'Body Condition Score' ;
    rdfs:comment 'Numeric score assessing the nutritional status and fat reserves of assessed animals using the standardized Body Condition Scoring (BCS) scale (typically 1-5 for cattle, 1-9 for swine). A key welfare indicator for feed adequacy.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the third-party certification or accreditation body associated with this assessment (e.g., GLOBALG.A.P. approved certifier, SQF certification body, BRC-approved auditor). Required for certification audit traceability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationReference rdf:type rdf:Property ;
    rdfs:label 'Certification Reference' ;
    rdfs:comment 'External reference number or audit report number issued by the certification body for this assessment, enabling cross-referencing with certification body records and retailer audit portals.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanlinessScore rdf:type rdf:Property ;
    rdfs:label 'Cleanliness Score' ;
    rdfs:comment 'Scored assessment of animal hygiene and coat/skin cleanliness, reflecting housing conditions, stocking density, and manure management. Expressed on the protocol-defined scale.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fearResponseScore rdf:type rdf:Property ;
    rdfs:label 'Fear Response Score' ;
    rdfs:comment 'Behavioral welfare indicator measuring animal fear and stress response during human approach or handling, scored per the applicable protocol (e.g., flight zone test, avoidance distance). Reflects human-animal relationship quality.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedAccessScore rdf:type rdf:Property ;
    rdfs:label 'Feed Access Score' ;
    rdfs:comment 'Scored assessment of animal access to adequate feed, including feeder space, feed availability, and diet appropriateness. Reflects Freedom from Hunger under the Five Freedoms framework.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assessment Date' ;
    rdfs:comment 'Scheduled date for the next welfare assessment or corrective action verification visit, set based on assessment outcome rating and certification body requirements.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:injuryPrevalencePct rdf:type rdf:Property ;
    rdfs:label 'Injury Prevalence Pct' ;
    rdfs:comment 'Percentage of assessed animals exhibiting visible injuries, lesions, wounds, or integument alterations (e.g., tail biting, horn injuries, pressure sores). Key welfare outcome indicator.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lamenessScore rdf:type rdf:Property ;
    rdfs:label 'Lameness Score' ;
    rdfs:comment 'Prevalence rate or average locomotion score for lameness observed in the assessed population, expressed as a percentage of lame animals or a standardized locomotion score. Critical welfare and productivity indicator.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mortalityRatePct rdf:type rdf:Property ;
    rdfs:label 'Mortality Rate Pct' ;
    rdfs:comment 'Observed mortality rate for the assessed pen or herd during the evaluation period, expressed as a percentage. A critical welfare outcome metric tracked against PAACO and GLOBALG.A.P. thresholds.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallWelfareScore rdf:type rdf:Property ;
    rdfs:label 'Overall Welfare Score' ;
    rdfs:comment 'Composite welfare score calculated per the applied protocol methodology, aggregating all scored indicators into a single numeric outcome. Used for trend analysis, certification thresholds, and retailer reporting.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:respiratoryDiseasePct rdf:type rdf:Property ;
    rdfs:label 'Respiratory Disease Pct' ;
    rdfs:comment 'Percentage of assessed animals showing clinical signs of respiratory disease (e.g., Bovine Respiratory Disease complex). Tracked as a health and welfare outcome indicator per PAACO audit criteria.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockingDensityScore rdf:type rdf:Property ;
    rdfs:label 'Stocking Density Score' ;
    rdfs:comment 'Scored evaluation of animal stocking density relative to protocol-defined space allowances (e.g., square feet per animal). Reflects freedom of movement and housing welfare compliance.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterAccessScore rdf:type rdf:Property ;
    rdfs:label 'Water Access Score' ;
    rdfs:comment 'Scored assessment of animal access to clean, fresh water including drinker availability, functionality, and cleanliness. Reflects Freedom from Thirst under the Five Freedoms framework.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:welfareNotes rdf:type rdf:Property ;
    rdfs:label 'Welfare Notes' ;
    rdfs:comment 'Free-text field for assessor observations, contextual notes, environmental conditions at time of assessment, or additional welfare findings not captured in scored indicators.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:welfareOutcomeRating rdf:type rdf:Property ;
    rdfs:label 'Welfare Outcome Rating' ;
    rdfs:comment 'Categorical rating derived from the overall welfare score, classifying the assessment outcome against protocol-defined thresholds. Used for pass/fail determination in certification audits.' ;
    rdfs:domain ind:AnimalWelfareAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedingEventId rdf:type rdf:Property ;
    rdfs:label 'Breeding Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each breeding event or semen/embryo inventory record. Serves as the primary key for the breeding_event data product.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BreedingEvent .

ind:breedingProgramId rdf:type rdf:Property ;
    rdfs:label 'Breeding Program Id' ;
    rdfs:comment 'Reference to the genetic improvement or breeding program under which this event is conducted. Links the event to a defined breeding objective, selection criteria, and EPD targets.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:primaryBreedingFemaleAnimalId rdf:type rdf:Property ;
    rdfs:label 'Primary Breeding Female Animal Id' ;
    rdfs:comment 'Reference to the dam (female animal) involved in the breeding activity. Links to the animal master record for the cow, heifer, sow, ewe, or other female subject of the breeding event.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Animal .

ind:semenInventoryId rdf:type rdf:Property ;
    rdfs:label 'Semen Inventory Id' ;
    rdfs:comment 'Reference to the semen inventory lot record used in an artificial insemination event. Nullable for natural service and embryo transfer events. Links to the semen_inventory record type within this product or a dedicated inventory record.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemenInventory .

ind:actualParturitionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Parturition Date' ;
    rdfs:comment 'Actual recorded date on which the dam gave birth (calved, farrowed, lambed, etc.). Used to calculate gestation length, compare against expected date, and update reproductive performance records. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breedingDate rdf:type rdf:Property ;
    rdfs:label 'Breeding Date' ;
    rdfs:comment 'Calendar date on which the breeding activity (natural service, artificial insemination, or embryo transfer) was performed. Principal real-world event date for the breeding transaction. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breedingMethod rdf:type rdf:Property ;
    rdfs:label 'Breeding Method' ;
    rdfs:comment 'Method used to achieve conception. \'natural_service\' indicates direct mating; \'artificial_insemination\' (AI) uses processed semen; \'embryo_transfer\' (ET) implants a flushed embryo; \'in_vitro_fertilization\' (IVF) uses laboratory-produced embryos.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedingNotes rdf:type rdf:Property ;
    rdfs:label 'Breeding Notes' ;
    rdfs:comment 'Free-text field for recording additional observations, complications, or contextual information about the breeding event or inventory record (e.g., synchronization protocol used, heat detection method, embryo quality grade, technician observations).' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the semen or embryo was collected from the donor animal. Used for lot age tracking, quality assessment, and regulatory compliance with USDA semen import/export requirements. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptionCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conception Check Date' ;
    rdfs:comment 'Date on which pregnancy diagnosis (rectal palpation, ultrasound, or blood test) was performed to confirm or deny conception following the breeding event. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptionRateHistoryPct rdf:type rdf:Property ;
    rdfs:label 'Conception Rate History Pct' ;
    rdfs:comment 'Recorded historical conception rate (as a percentage) for this sire or semen lot based on prior breeding events. Derived from field performance data and used in sire selection and AI program planning. Distinct from the result of any single breeding event.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conceptionResult rdf:type rdf:Property ;
    rdfs:label 'Conception Result' ;
    rdfs:comment 'Outcome of the pregnancy diagnosis check. \'confirmed_pregnant\' indicates successful conception; \'open\' indicates the animal did not conceive; \'recheck_required\' indicates inconclusive result requiring follow-up; \'not_checked\' indicates no pregnancy check has been performed.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Purchase cost per semen straw or embryo unit in USD. Used for breeding cost accounting, COGS (Cost of Goods Sold) allocation to offspring, and ROI analysis of genetic improvement programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdBirthWeight rdf:type rdf:Property ;
    rdfs:label 'Epd Birth Weight' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for birth weight for the sire, expressed in pounds. Positive values indicate heavier-than-average offspring. Used in sire selection to manage calving difficulty and neonatal survival.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdCalvingEase rdf:type rdf:Property ;
    rdfs:label 'Epd Calving Ease' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for calving ease for the sire. Expressed as a percentage advantage in unassisted births compared to breed average. Used in sire selection to minimize dystocia risk.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdMarbling rdf:type rdf:Property ;
    rdfs:label 'Epd Marbling' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for marbling (intramuscular fat) for the sire. Expressed as a USDA marbling score unit advantage. Used in beef quality grade prediction and premium market targeting.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdMilk rdf:type rdf:Property ;
    rdfs:label 'Epd Milk' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for milk production for the sire, expressed in pounds. Reflects the milking ability transmitted through daughters. Used in maternal breed selection for calf nutrition and growth.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdRea rdf:type rdf:Property ;
    rdfs:label 'Epd Rea' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for Ribeye Area (REA) for the sire, expressed in square inches. Indicates genetic merit for muscle expression and cutability. Used in carcass merit prediction and sire selection for yield grade improvement.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdWeaningWeight rdf:type rdf:Property ;
    rdfs:label 'Epd Weaning Weight' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for weaning weight for the sire, expressed in pounds. Indicates the sire\'s genetic merit for pre-weaning growth. Key metric in beef and sheep genetic improvement programs.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdYearlingWeight rdf:type rdf:Property ;
    rdfs:label 'Epd Yearling Weight' ;
    rdfs:comment 'Expected Progeny Difference (EPD) value for yearling weight for the sire, expressed in pounds. Indicates the sire\'s genetic merit for post-weaning growth rate. Used in feedlot performance prediction and sire selection.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedParturitionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Parturition Date' ;
    rdfs:comment 'Calculated expected date of birth (calving, farrowing, lambing, etc.) based on breeding date and species-specific gestation length. Used for calving/farrowing schedule planning, nutritional management, and labor allocation. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geneticRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Genetic Registration Number' ;
    rdfs:comment 'Official breed association registration number for the sire. Serves as the externally-known unique identifier for the sire in breed registry databases, enabling EPD lookup and genetic verification.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicEnhancedEpd rdf:type rdf:Property ;
    rdfs:label 'Genomic Enhanced Epd' ;
    rdfs:comment 'Indicates whether the EPD values for this sire are genomic-enhanced (GE-EPD), meaning they incorporate DNA marker information in addition to traditional pedigree and performance data. Genomic-enhanced EPDs have higher accuracy, especially for young sires.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offspringCount rdf:type rdf:Property ;
    rdfs:label 'Offspring Count' ;
    rdfs:comment 'Number of live offspring born from this breeding event (e.g., 1 for singleton calf, 2 for twins). Recorded at parturition. Used for litter size tracking, multiple birth analysis, and reproductive performance KPIs.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postThawMotilityPct rdf:type rdf:Property ;
    rdfs:label 'Post Thaw Motility Pct' ;
    rdfs:comment 'Quality grade expressed as the percentage of progressively motile sperm cells observed after thawing a representative straw from the lot. Minimum acceptable threshold is typically 30-35% per USDA AMS standards. Used to assess semen quality and predict conception rates.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current count of semen straws or embryos available in inventory for this lot. Decremented upon each use in an AI or ET breeding event. Used for inventory planning and reorder decisions.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator field that separates the two concerns managed by this data product: \'breeding_activity\' for actual mating/insemination events, and \'semen_inventory\' for semen or embryo inventory management records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semenSupplier rdf:type rdf:Property ;
    rdfs:label 'Semen Supplier' ;
    rdfs:comment 'Name of the commercial semen supplier or AI stud from which the semen was procured (e.g., ABS Global, Select Sires, Semex, Genex). Used for vendor performance tracking, procurement records, and quality traceability.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sireBreed rdf:type rdf:Property ;
    rdfs:label 'Sire Breed' ;
    rdfs:comment 'Breed designation of the sire (e.g., Angus, Hereford, Holstein, Simmental). Used for crossbreeding program management, breed composition tracking, and genetic diversity analysis.' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sireName rdf:type rdf:Property ;
    rdfs:label 'Sire Name' ;
    rdfs:comment 'Registered name of the sire used in the breeding event or associated with the semen/embryo inventory record. Used for genetic reporting, catalog references, and breeder communications.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synchronizationProtocol rdf:type rdf:Property ;
    rdfs:label 'Synchronization Protocol' ;
    rdfs:comment 'Hormonal synchronization protocol used to coordinate estrus and ovulation timing prior to the AI or ET event. Common protocols include CIDR (Controlled Internal Drug Release), OvSynch, CoSynch, Select-Synch, and MGA (melengestrol acetate). \'none\' indicates natural estrus detection was used. [ENUM-REF-CANDIDATE: CIDR|OvSynch|CoSynch|Select_Synch|MGA|none|TAI|FTAI — promote to reference product]' ;
    rdfs:domain ind:BreedingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Feed Delivery Id' ;
    rdfs:comment 'Unique system-generated identifier for each feed delivery event. Primary key for the feed_delivery data product in the livestock domain.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedRationId rdf:type rdf:Property ;
    rdfs:label 'Feed Ration Id' ;
    rdfs:comment 'Identifier of the prescribed feed ration formulation delivered. Used to verify nutritional compliance against the prescribed ration, support GMP (Good Manufacturing Practices) audits, and enable deviation analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeedRation .

ind:animalCountFed rdf:type rdf:Property ;
    rdfs:label 'Animal Count Fed' ;
    rdfs:comment 'Number of animals present in the pen or group at the time of feed delivery. Used to calculate per-head feed intake, normalize FCR (Feed Conversion Ratio) metrics, and detect anomalies in feed allocation relative to group size.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bunkScore rdf:type rdf:Property ;
    rdfs:label 'Bunk Score' ;
    rdfs:comment 'Standardized numeric score (typically 0–4 scale) assessing the amount of feed remaining in the bunk at the time of delivery or pre-delivery inspection. Score 0 = empty/slick bunk; Score 4 = heavy refusal. Used to calibrate next delivery quantity and monitor animal appetite and health status.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text field for operator observations, exceptions, or special conditions recorded at the time of feed delivery (e.g., equipment malfunction, animal behavior observations, ingredient substitutions). Supports SOP (Standard Operating Procedure) deviation documentation and veterinary review.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known business identifier for the feed delivery event, used for cross-referencing with feed management systems, SAP production orders, and operator logs. Follows the format FD-YYYY-NNNNNN.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySequence rdf:type rdf:Property ;
    rdfs:label 'Delivery Sequence' ;
    rdfs:comment 'Sequential order number of this delivery within the daily feeding schedule (e.g., 1st feeding, 2nd feeding). Supports multi-feeding-per-day operations, feeding frequency analysis, and nutritional timing compliance.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the feed delivery event, tracking progression from scheduled through completion or cancellation. Supports operational monitoring and FCR (Feed Conversion Ratio) completeness checks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The principal real-world date and time when the feed delivery event occurred at the pen or group location. Used for feed scheduling compliance, nutritional timing analysis, and FCR (Feed Conversion Ratio) tracking.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryVarianceKg rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Kg' ;
    rdfs:comment 'Difference between the prescribed quantity and the actual quantity delivered on an as-fed basis, in kilograms (actual minus prescribed). Positive values indicate over-delivery; negative values indicate under-delivery. Used for nutritional compliance verification and ration adherence KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dryMatterPct rdf:type rdf:Property ;
    rdfs:label 'Dry Matter Pct' ;
    rdfs:comment 'Dry matter percentage of the delivered ration at the time of delivery, expressed as a percentage. Used to convert as-fed quantities to dry matter basis and to verify ration moisture content against the prescribed formulation.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedCostPerKg rdf:type rdf:Property ;
    rdfs:label 'Feed Cost Per Kg' ;
    rdfs:comment 'Unit cost of the delivered feed ration per kilogram on an as-fed basis, sourced from the feed inventory lot or procurement record. Used for feed cost allocation per animal group, COGS (Cost of Goods Sold) calculation, and financial reporting in SAP S/4HANA CO module.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedSourceType rdf:type rdf:Property ;
    rdfs:label 'Feed Source Type' ;
    rdfs:comment 'Classification of the feed source for this delivery. Indicates whether the ration was mixed on-farm (TMR), purchased as a complete feed, custom-mixed by a feed mill, or derived from co-products. Supports feed cost analysis, supply chain traceability, and GLOBALG.A.P. compliance.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMedicatedFeed rdf:type rdf:Property ;
    rdfs:label 'Is Medicated Feed' ;
    rdfs:comment 'Indicates whether the delivered ration contains a medicated additive subject to FDA Veterinary Feed Directive (VFD) or APHIS withdrawal period requirements. When True, triggers mandatory withdrawal period tracking and regulatory documentation requirements.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixingDurationMin rdf:type rdf:Property ;
    rdfs:label 'Mixing Duration Min' ;
    rdfs:comment 'Duration in minutes that the TMR (Total Mixed Ration) mixer was operated to prepare the ration batch prior to delivery. Mixing time affects ration uniformity and particle size distribution; tracked for GMP (Good Manufacturing Practices) compliance and equipment OEE (Overall Equipment Effectiveness) analysis.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribedQuantityAsfedKg rdf:type rdf:Property ;
    rdfs:label 'Prescribed Quantity Asfed Kg' ;
    rdfs:comment 'The ration-prescribed target quantity of feed to be delivered on an as-fed basis, in kilograms. Compared against actual quantity delivered to calculate delivery variance and assess nutritional compliance against the prescribed ration.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDeliveredAsfedKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Asfed Kg' ;
    rdfs:comment 'Total weight of feed delivered to the pen or group on an as-fed basis, measured in kilograms. As-fed weight includes moisture content and is the primary operational quantity recorded at delivery. Used for feed cost allocation and FCR (Feed Conversion Ratio) calculations.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDeliveredDmKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Dm Kg' ;
    rdfs:comment 'Total weight of feed delivered expressed on a dry matter (DM) basis, measured in kilograms. Dry matter quantity normalizes for moisture variation across ration ingredients and is the standard basis for nutritional compliance verification and FCR (Feed Conversion Ratio) analysis.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rationName rdf:type rdf:Property ;
    rdfs:label 'Ration Name' ;
    rdfs:comment 'Human-readable name or description of the feed ration delivered (e.g., \'Grower Phase 2 TMR\', \'Lactating Cow Ration\'). Provides operational context for operators and supports reporting without requiring a ration master lookup.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Refusal Quantity Kg' ;
    rdfs:comment 'Weight of feed remaining uneaten in the bunk or feeder at the time of the next delivery or scheduled bunk reading, measured in kilograms. Refusal data is critical for adjusting ration delivery amounts, monitoring animal health, and calculating net intake for FCR (Feed Conversion Ratio) analysis.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'The planned date and time for the feed delivery as defined in the feeding schedule. Compared against actual delivery_timestamp to calculate delivery timing variance and assess adherence to the nutritional management plan.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFeedCost rdf:type rdf:Property ;
    rdfs:label 'Total Feed Cost' ;
    rdfs:comment 'Total cost of feed delivered in this event, calculated as quantity_delivered_asfed_kg multiplied by feed_cost_per_kg. Used for feed cost allocation per pen/group, COGS (Cost of Goods Sold) reporting, and EBITDA analysis. Stored as a transactional fact to preserve the cost at time of delivery.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vfdNumber rdf:type rdf:Property ;
    rdfs:label 'Vfd Number' ;
    rdfs:comment 'The FDA Veterinary Feed Directive (VFD) authorization number associated with the medicated feed delivered. Required for regulatory compliance when is_medicated_feed is True. Supports APHIS and FSIS audit traceability.' ;
    rdfs:domain ind:FeedDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Period End Date' ;
    rdfs:comment 'The date after which animals that received medicated feed are eligible for harvest, calculated from the delivery date plus the required withdrawal period for the active ingredient (AI). Critical for FSIS pre-harvest compliance and antibiotic residue avoidance.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryFeedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Feed Employee Id' ;
    rdfs:comment 'Reference to the licensed animal nutritionist or feed specialist responsible for formulating or approving this ration. Supports accountability, NRC compliance documentation, and audit trail for regulatory inspections.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:antibioticFlag rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Flag' ;
    rdfs:comment 'Indicates whether this ration contains any antibiotic or medicated feed additive subject to VFD (Veterinary Feed Directive) or withdrawal period requirements. True = medicated; False = non-medicated. Critical for FSIS antibiotic residue compliance and withdrawal period tracking.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calciumPct rdf:type rdf:Property ;
    rdfs:label 'Calcium Pct' ;
    rdfs:comment 'Calculated calcium (Ca) content of the ration as a percentage of dry matter. Critical macro-mineral for bone development, milk production, and metabolic health. NRC compliance metric for all species.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerHeadPerDay rdf:type rdf:Property ;
    rdfs:label 'Cost Per Head Per Day' ;
    rdfs:comment 'Calculated feed cost in USD per animal per day based on ingredient prices and inclusion rates in the formulation. Applicable to formulation records. Key input for COGS (Cost of Goods Sold) allocation, OPEX tracking, and ROI analysis per production class.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crudeProteinPct rdf:type rdf:Property ;
    rdfs:label 'Crude Protein Pct' ;
    rdfs:comment 'Calculated crude protein content of the ration as a percentage of dry matter. Key NRC nutritional compliance metric for protein adequacy across species and production classes. Applicable to formulation records.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationDate rdf:type rdf:Property ;
    rdfs:label 'Formulation Date' ;
    rdfs:comment 'Date on which the ration formulation was created or last revised by the nutritionist. Applicable to formulation records. Used for version control and audit trail of recipe changes.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmoFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Flag' ;
    rdfs:comment 'Indicates whether the ration formulation contains any GMO (Genetically Modified Organism) ingredients. True = contains GMO ingredients; False = non-GMO. Supports USDA National Organic Program (NOP) compliance, COOL labeling, and customer transparency requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixingInstructions rdf:type rdf:Property ;
    rdfs:label 'Mixing Instructions' ;
    rdfs:comment 'Operational instructions for preparing the TMR or batch mix, including ingredient loading sequence, mixer run time, and any special handling notes. Applicable to formulation records. Supports SOP compliance and feed uniformity.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negMcalPerCwt rdf:type rdf:Property ;
    rdfs:label 'Neg Mcal Per Cwt' ;
    rdfs:comment 'Net Energy for Gain (NEg) value of the ration expressed in megacalories per hundredweight (CWT) of dry matter. Used for NRC-compliant growth performance prediction and ration optimization in beef cattle finishing programs.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nemMcalPerCwt rdf:type rdf:Property ;
    rdfs:label 'Nem Mcal Per Cwt' ;
    rdfs:comment 'Net Energy for Maintenance (NEm) value of the ration expressed in megacalories per hundredweight (CWT) of dry matter. Used for NRC-compliant energy adequacy assessment in beef and dairy cattle rations.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrcComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Nrc Compliance Flag' ;
    rdfs:comment 'Indicates whether the ration formulation meets all NRC (National Research Council) nutrient requirement thresholds for the target species and production class. True = compliant; False = one or more NRC thresholds not met. Applicable to formulation records.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityDeliveredDmLbs rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Dm Lbs' ;
    rdfs:comment 'Total weight of feed delivered expressed on a dry matter (DM) basis in pounds. Calculated from as-fed quantity and dry matter percentage. Used for NRC-compliant nutrient intake calculations and ration balancing.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDeliveredLbs rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Lbs' ;
    rdfs:comment 'Total weight of feed delivered to the pen on an as-fed basis, measured in pounds (lbs). Applicable to delivery records. Used for feed cost allocation per animal, FCR tracking, and daily intake monitoring.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rationNumber rdf:type rdf:Property ;
    rdfs:label 'Ration Number' ;
    rdfs:comment 'Externally-known business identifier for the ration formulation or delivery event, used for cross-system reference and traceability (e.g., RAT-2024-00123). Sourced from Granular Farm Management or SAP PP.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalAmountLbs rdf:type rdf:Property ;
    rdfs:label 'Refusal Amount Lbs' ;
    rdfs:comment 'Weight of feed remaining uneaten in the bunk at the time of the next feeding, measured in pounds. Applicable to delivery records. Used to calculate actual intake, adjust ration quantities, and monitor animal health and appetite.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDailyIntakeLbs rdf:type rdf:Property ;
    rdfs:label 'Target Daily Intake Lbs' ;
    rdfs:comment 'Planned daily feed intake per head per day on an as-fed basis, in pounds. Applicable to formulation records. Derived from NRC nutrient requirements for the target species and production class. Drives delivery quantity planning.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSpecies rdf:type rdf:Property ;
    rdfs:label 'Target Species' ;
    rdfs:comment 'Animal species for which this ration is formulated or delivered (e.g., cattle, swine, poultry). Drives NRC nutritional compliance checks and species-specific regulatory requirements under APHIS and FSIS. [ENUM-REF-CANDIDATE: cattle|swine|poultry|sheep|goat|equine|other — promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdnPct rdf:type rdf:Property ;
    rdfs:label 'Tdn Pct' ;
    rdfs:comment 'Total Digestible Nutrients (TDN) content of the ration as a percentage of dry matter. Primary energy metric for ruminant rations used in NRC compliance and ration balancing. Applicable to formulation records.' ;
    rdfs:domain ind:FeedRation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withdrawalPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Period Days' ;
    rdfs:comment 'Number of days animals must not receive this medicated ration prior to slaughter to ensure antibiotic residue levels are within FDA/FSIS MRL (Maximum Residue Limit) tolerances. Applicable when antibiotic_flag is True. Critical for FSIS compliance and food safety.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomicTestId rdf:type rdf:Property ;
    rdfs:label 'Genomic Test Id' ;
    rdfs:comment 'Unique system-generated identifier for each genomic test record. Primary key for the genomic_test data product.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breedAssociationRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Breed Association Registration Number' ;
    rdfs:comment 'Official registration number assigned to the animal by its breed association following genomic testing and parentage verification. Enables breed-registered marketing premiums and EPD publication.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callRatePct rdf:type rdf:Property ;
    rdfs:label 'Call Rate Pct' ;
    rdfs:comment 'Percentage of SNP markers that were successfully genotyped (called) out of the total markers on the chip. A quality metric; samples below threshold (typically 90%) may be flagged for re-testing.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coatColorGenotype rdf:type rdf:Property ;
    rdfs:label 'Coat Color Genotype' ;
    rdfs:comment 'Genomically determined coat color genotype (e.g., BB, Bb, bb for black/red in Angus; E+/E+ for Hereford). Used for breed purity verification, registration requirements, and marketing of color-specific genetics.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epdAccuracy rdf:type rdf:Property ;
    rdfs:label 'Epd Accuracy' ;
    rdfs:comment 'Accuracy value (0.00–1.00) associated with the genomic-enhanced EPD estimates, reflecting the reliability of the prediction based on the amount of genomic and phenotypic data available. Higher accuracy reduces selection risk.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epdFeedEfficiency rdf:type rdf:Property ;
    rdfs:label 'Epd Feed Efficiency' ;
    rdfs:comment 'Genomic-enhanced EPD for residual feed intake (RFI) or feed efficiency. Lower RFI values indicate more feed-efficient progeny. Supports selection decisions to reduce feed costs and environmental footprint.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geneticConditionAm rdf:type rdf:Property ;
    rdfs:label 'Genetic Condition Am' ;
    rdfs:comment 'Carrier status for Arthrogryposis Multiplex (AM), a lethal recessive genetic defect in Angus cattle. Identifies carriers to prevent mating combinations that produce affected calves. Required for American Angus Association registration.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticConditionNh rdf:type rdf:Property ;
    rdfs:label 'Genetic Condition Nh' ;
    rdfs:comment 'Carrier status for Neuropathic Hydrocephalus (NH), a lethal recessive genetic defect in Angus cattle. Identifies carriers to prevent mating combinations that produce affected calves.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicMeritIndexScore rdf:type rdf:Property ;
    rdfs:label 'Genomic Merit Index Score' ;
    rdfs:comment 'Composite genomic selection index score combining multiple EPD traits into a single economic merit value (e.g., $B Beef Value, $M Maternal Weaning Value, $W Weaned Calf Value for beef; TPI Total Performance Index or NM$ Net Merit for dairy). Enables ranking of animals for overall genetic merit.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Official accreditation or certification number of the testing laboratory issued by a recognized accreditation body (e.g., ISO/IEC 17025). Supports regulatory compliance and result validity verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIndexType rdf:type rdf:Property ;
    rdfs:label 'Merit Index Type' ;
    rdfs:comment 'Identifier for the specific economic selection index represented by the genomic_merit_index_score (e.g., $B = Beef Value, $M = Maternal Weaning Value, TPI = Total Performance Index, NM$ = Net Merit Dollar). Required to correctly interpret the index score value.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentageVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Parentage Verification Result' ;
    rdfs:comment 'Outcome of DNA-based parentage verification test indicating whether the recorded sire and/or dam are confirmed or excluded based on genomic marker comparison. Critical for breed association registration and pedigree integrity.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polledGenotype rdf:type rdf:Property ;
    rdfs:label 'Polled Genotype' ;
    rdfs:comment 'Genomically determined genotype for the polled (hornless) trait. PP = homozygous polled, Pp = heterozygous polled (carrier), pp = horned. Supports animal welfare compliance by enabling selection for naturally polled animals, reducing need for dehorning.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultDate rdf:type rdf:Property ;
    rdfs:label 'Result Date' ;
    rdfs:comment 'Date on which the laboratory reported final genomic test results. Used to calculate turnaround time and trigger downstream genetic selection workflows.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date on which the biological sample was collected from the animal for genomic testing. Critical for traceability and chain-of-custody documentation.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snpChipPlatform rdf:type rdf:Property ;
    rdfs:label 'Snp Chip Platform' ;
    rdfs:comment 'Genotyping array or SNP chip platform used for the genomic test (e.g., GGP-LD, GGP-HD, Illumina BovineHD 777K, Illumina BovineSNP50 50K, Affymetrix Axiom). Determines marker density and genomic prediction accuracy.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snpMarkerCount rdf:type rdf:Property ;
    rdfs:label 'Snp Marker Count' ;
    rdfs:comment 'Number of SNP markers successfully genotyped on the animal. Indicates genotyping density and data completeness; lower counts may indicate sample quality issues or imputation.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCost rdf:type rdf:Property ;
    rdfs:label 'Test Cost' ;
    rdfs:comment 'Total cost charged by the testing laboratory for performing the genomic test on this sample. Used for cost tracking, ROI analysis of genomic selection programs, and procurement reporting.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testPanel rdf:type rdf:Property ;
    rdfs:label 'Test Panel' ;
    rdfs:comment 'Type of genomic analysis panel performed on the sample. Determines the scope of genetic information returned, from parentage verification to full genomic profiling for EPD calculation. [ENUM-REF-CANDIDATE: parentage|breed_composition|trait_markers|full_genomic_profile|genetic_conditions|snp_discovery — promote to reference product]' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Test Reference Number' ;
    rdfs:comment 'Externally-known laboratory accession or submission number assigned by the testing laboratory to uniquely identify this genomic test submission. Used for cross-referencing with lab reports and breed association records.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the genomic test record, tracking progression from sample submission through laboratory processing to result delivery.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDamRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Verified Dam Registration Number' ;
    rdfs:comment 'Breed association registration number of the genomically confirmed dam. Populated when parentage verification confirms or identifies the dam. Used for pedigree records and breed association reporting.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedSireRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Verified Sire Registration Number' ;
    rdfs:comment 'Breed association registration number of the genomically confirmed sire. Populated when parentage verification confirms or identifies the sire. Used for pedigree records and breed association reporting.' ;
    rdfs:domain ind:GenomicTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationRoute rdf:type rdf:Property ;
    rdfs:label 'Administration Route' ;
    rdfs:comment 'The prescribed route of drug administration as specified on the FDA-approved label (e.g., subcutaneous injection, intramuscular injection, oral drench, pour-on). Deviations from the approved route constitute extra-label drug use (ELDU) requiring a valid VCPR. [ENUM-REF-CANDIDATE: subcutaneous|intramuscular|intravenous|oral|intranasal|topical|pour_on — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antibioticClass rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Class' ;
    rdfs:comment 'Pharmacological class of the antibiotic used in this protocol (e.g., macrolide, tetracycline, beta-lactam). Required for antibiotic stewardship reporting, resistance monitoring, and FDA GFI #213 medically important antimicrobial tracking. Null or not_applicable for non-antibiotic protocols. [ENUM-REF-CANDIDATE: macrolide|tetracycline|beta_lactam|fluoroquinolone|sulfonamide|aminoglycoside|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageAmount rdf:type rdf:Property ;
    rdfs:label 'Dosage Amount' ;
    rdfs:comment 'The prescribed dose quantity of the drug product per unit of animal body weight or per head as specified in the protocol. Used in conjunction with dosage_uom to calculate total drug volume for treatment events.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosageUom rdf:type rdf:Property ;
    rdfs:label 'Dosage Uom' ;
    rdfs:comment 'Unit of measure for the prescribed dosage amount (e.g., ml per hundredweight (CWT), ml per head, mg per kg body weight). Ensures accurate dose calculation and label compliance per FDA NADA/ANADA approved labeling.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityScope rdf:type rdf:Property ;
    rdfs:label 'Facility Scope' ;
    rdfs:comment 'Name or code of the specific facility or premises to which this protocol applies. Null if the protocol applies enterprise-wide across all facilities. Enables facility-specific protocol management and APHIS premises-level compliance tracking.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injectionSite rdf:type rdf:Property ;
    rdfs:label 'Injection Site' ;
    rdfs:comment 'Anatomical location for injection administration as specified by BQA guidelines to minimize carcass damage and maximize meat quality. Neck injection is the BQA-preferred site for cattle. Not applicable for non-injectable routes.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAntibioticProtocol rdf:type rdf:Property ;
    rdfs:label 'Is Antibiotic Protocol' ;
    rdfs:comment 'Indicates whether this protocol involves the use of medically important antimicrobials (antibiotics). True triggers mandatory antibiotic stewardship tracking, VFD requirements where applicable, and antibiotic-free program compliance checks per FDA GFI #213 and GFI #209.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExtraLabelUse rdf:type rdf:Property ;
    rdfs:label 'Is Extra Label Use' ;
    rdfs:comment 'Indicates whether this protocol involves extra-label drug use (ELDU) — use of an FDA-approved drug in a manner not specified on the approved label (different species, dose, route, or indication). ELDU requires a valid VCPR and veterinarian authorization per 21 CFR Part 530.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Is Prescription Required' ;
    rdfs:comment 'Indicates whether the drug product in this protocol requires a valid veterinary prescription (Rx) for procurement and use. Drives procurement compliance checks in SAP MM and vendor management workflows.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVfdRequired rdf:type rdf:Property ;
    rdfs:label 'Is Vfd Required' ;
    rdfs:comment 'Indicates whether a Veterinary Feed Directive (VFD) is required for the drug product used in this protocol. True for medically important antimicrobials administered via feed or water under 21 CFR Part 558. Drives VFD documentation workflow in SAP QM.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTreatmentsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Treatments Allowed' ;
    rdfs:comment 'Maximum number of times this protocol may be applied to a single animal within a production cycle before escalation to a veterinarian or chronic/realizer designation. Supports antibiotic stewardship and chronic animal management decisions.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milkWithdrawalDays rdf:type rdf:Property ;
    rdfs:label 'Milk Withdrawal Days' ;
    rdfs:comment 'Mandatory milk discard period in days following drug administration for dairy animals, as specified on the FDA-approved label. Applicable only to dairy production classes; null for beef/non-dairy protocols. Required for Grade A Pasteurized Milk Ordinance (PMO) compliance.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolCode rdf:type rdf:Property ;
    rdfs:label 'Protocol Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the health protocol, used for cross-referencing in treatment records, vaccination logs, and veterinary documentation. Serves as the business identifier referenced in FMIS and SAP QM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolName rdf:type rdf:Property ;
    rdfs:label 'Protocol Name' ;
    rdfs:comment 'Descriptive human-readable name of the health protocol (e.g., \'Arrival Processing BRD Metaphylaxis\', \'Spring Vaccination Schedule - Cow-Calf\'). Used in reporting, treatment records, and veterinary documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNotes rdf:type rdf:Property ;
    rdfs:label 'Protocol Notes' ;
    rdfs:comment 'Free-text field for veterinarian or protocol administrator notes, special instructions, contraindications, or clinical observations relevant to protocol application. Supports clinical decision-making and audit documentation.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Status' ;
    rdfs:comment 'Current lifecycle state of the health protocol. Draft indicates under development; active indicates approved and in use; suspended indicates temporarily halted pending review; retired indicates no longer in use; pending_review indicates awaiting veterinarian re-approval.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'Classification of the protocol by its operational purpose. Arrival processing covers new animal intake procedures; metaphylaxis covers mass antibiotic treatment at arrival; vaccination_schedule covers routine immunization programs; parasite_control covers deworming and ectoparasite management; treatment_guideline covers individual animal therapy; biosecurity covers disease prevention procedures.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retreatmentIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Retreatment Interval Days' ;
    rdfs:comment 'Minimum number of days that must elapse between successive applications of this protocol to the same animal. Prevents over-treatment, supports antibiotic stewardship, and ensures withdrawal period compliance between treatments.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Scheduled review interval in days for this protocol (e.g., 365 for annual review). Drives automated review reminders and protocol currency compliance tracking. Supports VCPR maintenance requirements and GLOBALG.A.P. audit readiness.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerMorbidityRatePct rdf:type rdf:Property ;
    rdfs:label 'Trigger Morbidity Rate Pct' ;
    rdfs:comment 'Pen or herd morbidity rate percentage at or above which this metaphylaxis or mass treatment protocol is triggered (e.g., 10% pen pull rate triggers mass treatment). Null if trigger_type is not morbidity_rate. Supports evidence-based metaphylaxis decision-making.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerTemperatureThresholdC rdf:type rdf:Property ;
    rdfs:label 'Trigger Temperature Threshold C' ;
    rdfs:comment 'Rectal temperature threshold in degrees Celsius at or above which this protocol is triggered for an individual animal (e.g., 39.7°C for BRD treatment initiation). Null if trigger_type is not temperature_threshold. Used by pen riders and veterinary staff to standardize pull decisions.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The type of trigger criterion that initiates application of this protocol. Temperature threshold triggers are based on rectal temperature readings; morbidity_rate triggers are based on pen pull rates; arrival_processing triggers apply automatically at animal intake; scheduled triggers follow a calendar-based vaccination schedule.' ;
    rdfs:domain ind:HealthProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthTreatmentId rdf:type rdf:Property ;
    rdfs:label 'Health Treatment Id' ;
    rdfs:comment 'Unique surrogate identifier for each health treatment record or protocol template in the livestock health management system. Primary key for the health_treatment data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthTreatment .

ind:holdRecordId rdf:type rdf:Property ;
    rdfs:label 'Hold Record Id' ;
    rdfs:comment 'Foreign key linking to quality.hold_record. Business justification: Treatments triggering withdrawal periods place animals or their products (milk, meat) on quality hold. Linking health_treatment to hold_record enables withdrawal compliance tracking and prevents prema' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HoldRecord .

ind:veterinaryPrescriptionId rdf:type rdf:Property ;
    rdfs:label 'Veterinary Prescription Id' ;
    rdfs:comment 'Foreign key linking to livestock.veterinary_prescription. Business justification: health_treatment.prescription_reference is currently a STRING field storing the prescription reference number. veterinary_prescription is the master record for VFDs and prescriptions. Normalizing by a' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VeterinaryPrescription .

ind:boosterDueDate rdf:type rdf:Property ;
    rdfs:label 'Booster Due Date' ;
    rdfs:comment 'The date on which a follow-up booster vaccination is due for the treated animal, based on the vaccine manufacturer\'s protocol. Applicable only for vaccination treatment types requiring multi-dose schedules. Drives vaccination schedule alerts in the FMIS.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalSigns rdf:type rdf:Property ;
    rdfs:label 'Clinical Signs' ;
    rdfs:comment 'Free-text description of the observable clinical signs or symptoms presented by the animal or group at the time of treatment, as recorded by the attending veterinarian or farm staff. Supports HACCP documentation and veterinary case history.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code' ;
    rdfs:comment 'Standardized veterinary diagnosis code identifying the disease or condition being treated, aligned with USDA APHIS disease reporting codes or ICD-10-CM veterinary adaptations. Used for APHIS disease surveillance reporting and herd health analytics.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageUnit rdf:type rdf:Property ;
    rdfs:label 'Dosage Unit' ;
    rdfs:comment 'Unit of measure for the administered dosage amount (e.g., mL, mg, mg/kg body weight). Required for accurate withdrawal period calculation and FDA VFD documentation.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfAnimalsTreated rdf:type rdf:Property ;
    rdfs:label 'Number Of Animals Treated' ;
    rdfs:comment 'Count of individual animals included in this treatment event. Value is 1 for individual animal treatments; greater than 1 for group-level treatments such as metaphylaxis or arrival processing. Used for drug inventory reconciliation and treatment cost allocation.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productUsedUnit rdf:type rdf:Property ;
    rdfs:label 'Product Used Unit' ;
    rdfs:comment 'Unit of measure for the total_product_used quantity (e.g., mL, mg, doses). Required for drug inventory reconciliation and cost reporting.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Retreatment Flag' ;
    rdfs:comment 'Indicates whether this treatment record represents a re-treatment of an animal that did not respond adequately to a prior treatment for the same condition. True when this is a follow-up treatment; False for initial treatments. Supports antibiotic stewardship and treatment efficacy analytics.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'Electronic RFID tag identifier associated with the treated animal, used for automated identification in chute-side treatment systems and integration with John Deere Operations Center livestock modules. Supports ISO 11784/11785 RFID standards.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'The method by which the drug or vaccine was delivered to the animal (e.g., subcutaneous injection, intramuscular injection, oral drench, topical pour-on, intranasal spray). Affects withdrawal period applicability and FSIS residue compliance.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatedByName rdf:type rdf:Property ;
    rdfs:label 'Treated By Name' ;
    rdfs:comment 'Full name of the veterinarian or farm staff member who administered the treatment. Captured for FSIS, HACCP, and GLOBALG.A.P. audit trail requirements. May be a licensed veterinarian (DVM) or trained farm employee acting under veterinary supervision.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCost rdf:type rdf:Property ;
    rdfs:label 'Treatment Cost' ;
    rdfs:comment 'Total cost of the treatment event in the farm\'s operating currency, including drug product cost and veterinary service fees where applicable. Used for herd health cost-of-production analysis, OPEX reporting, and Granular Farm Management financial planning integration.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentNumber rdf:type rdf:Property ;
    rdfs:label 'Treatment Number' ;
    rdfs:comment 'Externally-known business identifier for the treatment event or protocol template, used for cross-referencing with veterinary records, VFD documentation, and SAP QM notifications. Format typically follows farm-assigned numbering conventions (e.g., TRT-2024-00123).' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Treatment Outcome' ;
    rdfs:comment 'Clinical outcome of the treatment as assessed at the end of the treatment course or at follow-up evaluation. Used for herd health analytics, treatment efficacy reporting, and antibiotic stewardship program monitoring.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current lifecycle state of the treatment record. \'draft\' indicates a record in preparation; \'active\' indicates an ongoing treatment; \'completed\' indicates the treatment course is finished; \'cancelled\' indicates the treatment was voided; \'pending_approval\' indicates awaiting veterinarian sign-off for VFD-regulated products.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Timestamp' ;
    rdfs:comment 'Precise date and time at which the treatment was administered, captured for IoT-integrated barn management systems and time-sensitive drug administration protocols requiring exact timing records.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Classification of the treatment purpose. \'therapeutic\' treats an existing disease; \'prophylactic\' prevents disease in healthy animals; \'vaccination\' administers a biological vaccine; \'metaphylaxis\' treats an entire group when a portion shows disease; \'arrival_processing\' covers standard processing at receiving; \'parasite_control\' targets internal or external parasites.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Trigger Criteria' ;
    rdfs:comment 'For protocol_template records, describes the specific conditions that trigger execution of this protocol (e.g., \'rectal temperature > 104°F\', \'morbidity rate > 10% in pen within 7 days\', \'BRD pull rate exceeds threshold\'). Null for treatment_instance records.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaccineLotNumber rdf:type rdf:Property ;
    rdfs:label 'Vaccine Lot Number' ;
    rdfs:comment 'The manufacturer\'s lot number (batch identifier) for the vaccine product administered. Required for USDA APHIS Veterinary Biologics traceability, adverse event reporting, and product recall management. Applicable only when treatment_type is \'vaccination\'.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veterinarianApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Veterinarian Approval Date' ;
    rdfs:comment 'The date on which the supervising veterinarian reviewed and approved this treatment record or protocol template. Required for VFD-regulated antibiotic treatments and GLOBALG.A.P. animal health certification audits.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:veterinarianLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Veterinarian License Number' ;
    rdfs:comment 'State-issued veterinary license number of the attending or supervising veterinarian responsible for the treatment authorization. Required for VFD documentation and VCPR compliance. Null when treatment is administered by non-veterinary farm staff under a standing order.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vfdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vfd Reference Number' ;
    rdfs:comment 'The official Veterinary Feed Directive (VFD) document reference number issued by the licensed veterinarian authorizing the use of a VFD antibiotic in animal feed. Mandatory for medically important antimicrobials used in feed per FDA VFD regulations. Null for non-VFD treatments.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDays rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Days' ;
    rdfs:comment 'The mandatory number of days that must elapse after the last treatment before the animal or its products (meat, milk, eggs) may enter the food supply, as specified on the drug label. Also referred to as Pre-Harvest Interval (PHI) for meat animals. Critical for FSIS residue avoidance compliance.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawalStatus rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Status' ;
    rdfs:comment 'Current compliance status of the animal with respect to drug withdrawal period. \'in_withdrawal\' indicates the animal cannot yet be harvested; \'cleared\' indicates the withdrawal period has elapsed; \'not_applicable\' applies to non-withdrawal products or protocol templates.' ;
    rdfs:domain ind:HealthTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:herdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Herd Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor designated as the responsible herd manager. Used for accountability tracking, SAP SuccessFactors workforce assignment, and regulatory contact identification for APHIS inspections.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:herdVeterinarianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Herd Veterinarian Employee Id' ;
    rdfs:comment 'Reference to the licensed veterinarian of record (VOR) responsible for health oversight of this herd. Required for VCPR (Veterinarian-Client-Patient Relationship) compliance, antibiotic prescription authorization, and FSIS residue avoidance programs.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:premisesFacilityId rdf:type rdf:Property ;
    rdfs:label 'Premises Facility Id' ;
    rdfs:comment 'USDA APHIS-assigned Premises Identification Number (PIN) for the physical location where the herd resides. Required for Animal Disease Traceability (ADT) compliance and interstate movement documentation. Format: 3-letter state code + 7-digit number.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:avgBodyWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Body Weight Kg' ;
    rdfs:comment 'Average live body weight in kilograms of animals in the herd at the most recent weigh event. Used for feed conversion ratio (FCR) calculations, drug dosage determination, and market readiness assessment. Supports YPM (Yield Per Acre Metric) and performance benchmarking.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDailyGainKg rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Gain Kg' ;
    rdfs:comment 'Average daily weight gain in kilograms per animal, calculated from the most recent performance measurement period. Key production KPI for finishing herds; benchmarked against breed standards and used in feed efficiency analysis.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biosecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Biosecurity Level' ;
    rdfs:comment 'Assigned biosecurity risk classification for the herd facility, determining visitor access controls, quarantine protocols, and disease surveillance intensity. Enhanced level is triggered by proximity to foreign animal disease outbreaks or APHIS disease alerts.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Earliest expiration date across all active certifications (organic, GAP, GLOBALG.A.P.) held by this herd. Used to trigger recertification workflows and prevent lapsed-certification sales into premium market channels.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Operational classification of the herd\'s production stage or management purpose (e.g., breeding, finishing, nursery, cow-calf, stocker, replacement). Drives feed ration formulation, housing allocation, and performance KPI benchmarks. [ENUM-REF-CANDIDATE: breeding|finishing|nursery|grow-out|cow-calf|stocker|replacement|farrowing|lactating|dry|other — promote to reference product]' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentHeadCount rdf:type rdf:Property ;
    rdfs:label 'Current Head Count' ;
    rdfs:comment 'Actual number of live animals currently in the herd as of the last inventory reconciliation. Drives feed ration calculations, housing capacity utilization, and USDA NASS livestock inventory reporting. Updated upon births, deaths, purchases, and transfers.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diseaseStatus rdf:type rdf:Property ;
    rdfs:label 'Disease Status' ;
    rdfs:comment 'Current disease surveillance status of the herd as determined by USDA APHIS or state veterinarian. \'confirmed\' status triggers mandatory reporting, movement restrictions, and potential depopulation under the National Animal Health Emergency Management System (NAHEMS).' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispersalDate rdf:type rdf:Property ;
    rdfs:label 'Dispersal Date' ;
    rdfs:comment 'Calendar date on which the herd was fully dispersed through sale, harvest, or depopulation. Null for active herds. Used to close the herd lifecycle record and trigger final regulatory reporting to USDA APHIS.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedMarketDate rdf:type rdf:Property ;
    rdfs:label 'Expected Market Date' ;
    rdfs:comment 'Projected date when the herd or a cohort of animals is expected to reach market weight and be ready for sale or harvest. Used for sales order planning, slaughter scheduling, and logistics coordination with TMS and WMS systems.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Calendar date on which this herd grouping was formally established or first registered in the FMIS. Used for herd age tracking, performance period calculations, and audit trail compliance under FSMA traceability requirements.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:herdCode rdf:type rdf:Property ;
    rdfs:label 'Herd Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the herd, used in operational systems such as SAP S/4HANA livestock modules, FMIS records, and regulatory submissions to USDA APHIS. Serves as the cross-system reference key.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:herdName rdf:type rdf:Property ;
    rdfs:label 'Herd Name' ;
    rdfs:comment 'Human-readable descriptive name assigned to the herd or flock grouping (e.g., \'North Pasture Angus Cow-Calf Herd\', \'Broiler House 4 Flock\'). Used in operational reports, Granular Farm Management, and John Deere Operations Center displays.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:herdStatus rdf:type rdf:Property ;
    rdfs:label 'Herd Status' ;
    rdfs:comment 'Current lifecycle status of the herd record. \'active\' indicates operational management; \'quarantined\' triggers APHIS disease containment protocols; \'dispersed\' indicates the herd has been sold or depopulated; \'pending\' indicates formation in progress.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housingType rdf:type rdf:Property ;
    rdfs:label 'Housing Type' ;
    rdfs:comment 'Primary housing or production system type for the herd (e.g., pasture, confinement, feedlot, free-range). Determines applicable animal welfare standards, GAP certification requirements, and environmental compliance obligations under EPA regulations. [ENUM-REF-CANDIDATE: pasture|confinement|semi-confinement|feedlot|free-range|barn|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAntibioticFree rdf:type rdf:Property ;
    rdfs:label 'Is Antibiotic Free' ;
    rdfs:comment 'Indicates whether this herd is managed under a no-antibiotics-ever (NAE) or raised-without-antibiotics (RWA) program. Drives treatment protocol restrictions, veterinary prescription controls, and premium market channel eligibility.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGapCertified rdf:type rdf:Property ;
    rdfs:label 'Is Gap Certified' ;
    rdfs:comment 'Indicates whether this herd operation holds a current Good Agricultural Practices (GAP) certification. Enables premium market access and satisfies retailer food safety audit requirements under GFSI-recognized schemes.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlobalgApCertified rdf:type rdf:Property ;
    rdfs:label 'Is Globalg Ap Certified' ;
    rdfs:comment 'Indicates whether this herd holds a current GLOBALG.A.P. Integrated Farm Assurance (IFA) certification for livestock. Required for export market access to EU and other international buyers demanding GFSI-recognized certification.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmoFree rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Free' ;
    rdfs:comment 'Indicates whether this herd is managed under a non-GMO feed program, qualifying for Non-GMO Project Verified or equivalent labeling claims on derived products. Affects feed procurement specifications and supply chain segregation.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastHealthCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Date' ;
    rdfs:comment 'Date of the most recent veterinary health inspection or herd health assessment. Used to ensure compliance with VCPR requirements, schedule next health review, and support APHIS accredited veterinarian documentation.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:morbidityRatePct rdf:type rdf:Property ;
    rdfs:label 'Morbidity Rate Pct' ;
    rdfs:comment 'Rolling percentage of animals in the herd that have been treated for illness during the current production period. Tracks herd health status, antibiotic use patterns, and biosecurity effectiveness. Supports FSIS residue avoidance program reporting.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Movement Restriction Flag' ;
    rdfs:comment 'Indicates whether this herd is currently subject to a USDA APHIS or state-imposed movement restriction order (e.g., due to disease quarantine, regulatory hold, or embargo). When True, blocks interstate movement documentation and sale order processing.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pastureAreaHa rdf:type rdf:Property ;
    rdfs:label 'Pasture Area Ha' ;
    rdfs:comment 'Total pasture or grazing area allocated to this herd in hectares. Used for stocking density calculations, EPA CAFO nutrient management planning, and USDA NRCS conservation program compliance. Integrated with Esri ArcGIS land parcel data.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Primary agricultural production purpose of the herd (e.g., beef, dairy, swine, poultry, sheep). Determines applicable FSIS inspection requirements, HACCP plans, and market channel routing. [ENUM-REF-CANDIDATE: beef|dairy|swine|broiler|layer|turkey|sheep|goat|mixed|other — promote to reference product]' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockingDensityHeadPerHa rdf:type rdf:Property ;
    rdfs:label 'Stocking Density Head Per Ha' ;
    rdfs:comment 'Current stocking density expressed as number of animal head per hectare of allocated pasture or housing area. Monitored against regulatory thresholds for EPA CAFO permits, organic certification land requirements, and animal welfare standards.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetHeadCount rdf:type rdf:Property ;
    rdfs:label 'Target Head Count' ;
    rdfs:comment 'Planned or budgeted number of animal head for this herd grouping, used for capacity planning, feed procurement forecasting, and financial budgeting in Granular Farm Management. Compared against current_head_count for variance analysis.' ;
    rdfs:domain ind:Herd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welfareAuditDate rdf:type rdf:Property ;
    rdfs:label 'Welfare Audit Date' ;
    rdfs:comment 'Date of the most recent animal welfare audit for this herd. Used to determine audit currency, schedule next audit, and satisfy retailer supply chain assurance requirements.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:welfareAuditScore rdf:type rdf:Property ;
    rdfs:label 'Welfare Audit Score' ;
    rdfs:comment 'Numeric score from the most recent animal welfare audit conducted against an approved standard (e.g., Animal Welfare Approved, Certified Humane, GLOBALG.A.P.). Expressed as a percentage (0.00–100.00). Required by major retail customers and GFSI-aligned buyers.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkProductionRecordId rdf:type rdf:Property ;
    rdfs:label 'Milk Production Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each milk production record in the silver layer lakehouse. Primary key for this transactional entity. Entity role: TRANSACTION_HEADER — captures a discrete milking event or Dairy Herd Improvement Association (DHIA) test-day observation for an individual animal or group.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkTankId rdf:type rdf:Property ;
    rdfs:label 'Bulk Tank Id' ;
    rdfs:comment 'Reference to the bulk milk storage tank into which this milking event\'s yield was deposited. Enables bulk tank-level SCC compliance tracking, milk pickup lot traceability, and cold chain monitoring per FDA PMO requirements.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BulkTank .

ind:conductivityMsCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Ms Cm' ;
    rdfs:comment 'Electrical conductivity (EC) of the milk sample measured in millisiemens per centimeter (mS/cm). Elevated EC is an early indicator of subclinical mastitis and udder inflammation. Captured by inline sensors in automatic milking systems and modern parlor equipment.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInMilk rdf:type rdf:Property ;
    rdfs:label 'Days In Milk' ;
    rdfs:comment 'Number of days elapsed since the animal\'s most recent calving event at the time of this milking record. DIM (Days in Milk) is the primary axis for lactation curve modeling, peak milk prediction, and dry-off scheduling. Calculated from calving date but stored as a business-critical operational field.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dhiaTestDayFlag rdf:type rdf:Property ;
    rdfs:label 'Dhia Test Day Flag' ;
    rdfs:comment 'Indicates whether this record is an official DHIA (Dairy Herd Improvement Association) test-day observation conducted by a certified DHIA supervisor. True = official DHIA test-day; False = routine parlor or non-official record. Determines eligibility for DHIA genetic evaluation and official production records.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:divertReason rdf:type rdf:Property ;
    rdfs:label 'Divert Reason' ;
    rdfs:comment 'Reason code for diverting milk from the bulk tank when is_abnormal_milk is True. COLOSTRUM: first-milking colostrum; ANTIBIOTIC_WITHDRAWAL: animal within withdrawal period (PHI — Pre-Harvest Interval); MASTITIS: clinical mastitis; BLOOD_TINGED: visible blood contamination; DRUG_TREATMENT: other veterinary drug treatment; NONE: not diverted. Supports antibiotic residue compliance and FSIS regulatory reporting.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatPct rdf:type rdf:Property ;
    rdfs:label 'Fat Pct' ;
    rdfs:comment 'Percentage of butterfat content in the milk sample, measured via DHIA test-day analysis or inline sensor. Used for component-based milk pricing (fat premium/deduction), breed performance benchmarking, and nutritional ration adjustment. Regulatory threshold compliance per FDA Grade A Pasteurized Milk Ordinance (PMO).' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatYieldKg rdf:type rdf:Property ;
    rdfs:label 'Fat Yield Kg' ;
    rdfs:comment 'Absolute quantity of butterfat produced in this milking event, calculated as milk_yield_kg × fat_pct / 100. Stored as a business field for DHIA component reporting, Federal Milk Marketing Order (FMMO) component pricing, and dairy enterprise financial reconciliation.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAbnormalMilk rdf:type rdf:Property ;
    rdfs:label 'Is Abnormal Milk' ;
    rdfs:comment 'Indicates whether the milk from this event was classified as abnormal (e.g., colostrum, mastitic milk, antibiotic-treated milk, blood-tinged milk) and therefore diverted from the bulk tank. True = abnormal/diverted; False = normal saleable milk. Critical for milk quality compliance and antibiotic residue tracking under FSIS and FDA PMO.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lactationNumber rdf:type rdf:Property ;
    rdfs:label 'Lactation Number' ;
    rdfs:comment 'Sequential count of the animal\'s completed and current lactations (parity). First-calf heifers are parity 1. Used for stratified performance benchmarking, culling decision support, and genetic evaluation. Aligns with parity_number in the animal master record.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lactosePct rdf:type rdf:Property ;
    rdfs:label 'Lactose Pct' ;
    rdfs:comment 'Percentage of lactose in the milk sample. Elevated lactose deviation can indicate early-stage mastitis or metabolic disorders. Used in conjunction with SCC and MUN for udder health monitoring and milk quality compliance.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearScore rdf:type rdf:Property ;
    rdfs:label 'Linear Score' ;
    rdfs:comment 'Logarithmic transformation of somatic cell count expressed on a 0–9 linear scale, as defined by DHIA. Provides a normalized, statistically stable measure of udder health for genetic evaluation, herd benchmarking, and DHIA enrollment reporting.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Milk Temperature C' ;
    rdfs:comment 'Temperature of the milk at the point of collection, expressed in degrees Celsius. Used for milk quality compliance (FDA PMO requires rapid cooling to ≤10°C within 4 hours of milking), cold chain monitoring, and detection of fever-related health events in the animal.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkYieldKg rdf:type rdf:Property ;
    rdfs:label 'Milk Yield Kg' ;
    rdfs:comment 'Volume of milk produced by the animal during this milking event, expressed in kilograms. Primary quantitative outcome of the milking transaction. Used for lactation curve modeling, DHIA test-day reporting, and dairy enterprise revenue estimation.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkYieldLbs rdf:type rdf:Property ;
    rdfs:label 'Milk Yield Lbs' ;
    rdfs:comment 'Volume of milk produced during this milking event expressed in pounds (lbs). Retained alongside kg for compatibility with USDA NASS reporting, DHIA test-day records, and domestic dairy market pricing conventions (hundredweight/CWT basis).' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkingDate rdf:type rdf:Property ;
    rdfs:label 'Milking Date' ;
    rdfs:comment 'Calendar date on which the milking event or DHIA test-day observation occurred. Principal business event date used for daily, monthly, and lactation-period reporting. Formatted as yyyy-MM-dd per model conventions.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milkingDurationSec rdf:type rdf:Property ;
    rdfs:label 'Milking Duration Sec' ;
    rdfs:comment 'Total elapsed time in seconds for the milking event from unit attachment to detachment. Used for parlor throughput optimization, teat condition monitoring, and robotic milking system performance analysis (OEE — Overall Equipment Effectiveness).' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milkingEventNumber rdf:type rdf:Property ;
    rdfs:label 'Milking Event Number' ;
    rdfs:comment 'Externally-known business identifier for this milking event or test-day record, typically assigned by the parlor management system or DHIA testing service (e.g., DHIA test-day report number, parlor event ID). Used for cross-system reconciliation with source systems such as Climate FieldView or Granular Farm Management.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milkingSession rdf:type rdf:Property ;
    rdfs:label 'Milking Session' ;
    rdfs:comment 'Identifies the milking session within the day: AM (morning), PM (evening), MID (midday for 3x programs), or labeled 3X variants for three-times-daily milking schedules. Critical for normalizing yield comparisons across different milking frequency programs. [ENUM-REF-CANDIDATE: AM|PM|MID|3X_AM|3X_PM|3X_MID — promote to reference product]' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milkingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Milking Timestamp' ;
    rdfs:comment 'Precise date and time when the milking event was recorded, including timezone offset. Enables intra-day sequencing of milking sessions, parlor throughput analysis, and robotic milking interval tracking. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:munMgDl rdf:type rdf:Property ;
    rdfs:label 'Mun Mg Dl' ;
    rdfs:comment 'Concentration of urea nitrogen in milk expressed in milligrams per deciliter (mg/dL). MUN (Milk Urea Nitrogen) is an indicator of dietary protein-energy balance and rumen fermentation efficiency. Used for ration formulation adjustments and environmental nitrogen management compliance.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakFlowRateKgMin rdf:type rdf:Property ;
    rdfs:label 'Peak Flow Rate Kg Min' ;
    rdfs:comment 'Maximum milk flow rate recorded during the milking event, expressed in kilograms per minute. Indicator of teat canal health, milking unit vacuum performance, and potential mastitis risk. Captured by parlor management systems and robotic milking units.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinPct rdf:type rdf:Property ;
    rdfs:label 'Protein Pct' ;
    rdfs:comment 'Percentage of true protein content in the milk sample. Used for component-based milk pricing (protein premium/deduction), cheese yield estimation, and feed ration optimization. Key performance indicator for dairy enterprise profitability.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinYieldKg rdf:type rdf:Property ;
    rdfs:label 'Protein Yield Kg' ;
    rdfs:comment 'Absolute quantity of true protein produced in this milking event, calculated as milk_yield_kg × protein_pct / 100. Stored for DHIA component reporting, FMMO protein pricing, and cheese yield estimation in downstream processing.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:somaticCellCount rdf:type rdf:Property ;
    rdfs:label 'Somatic Cell Count' ;
    rdfs:comment 'Number of somatic cells per milliliter of milk (cells/mL). Primary indicator of udder health and mastitis status. Regulatory threshold: FDA PMO Grade A standard ≤750,000 cells/mL; EU standard ≤400,000 cells/mL. Directly impacts milk quality premiums/penalties and bulk tank SCC compliance.' ;
    rdfs:domain ind:MilkProductionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawalClearDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Clear Date' ;
    rdfs:comment 'Date on which the animal\'s antibiotic or drug withdrawal period expires and milk is eligible to re-enter the bulk tank. Populated when divert_reason is ANTIBIOTIC_WITHDRAWAL or DRUG_TREATMENT. Critical for FSIS antibiotic residue compliance and FDA PMO Grade A milk eligibility. Aligns with withdrawal_clear_date in the animal master.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parturitionRecordId rdf:type rdf:Property ;
    rdfs:label 'Parturition Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each parturition (birth/calving/farrowing/lambing/kidding) event record. Serves as the primary key for this transactional entity.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryParturitionAnimalId rdf:type rdf:Property ;
    rdfs:label 'Primary Parturition Animal Id' ;
    rdfs:comment 'Reference to the female parent (dam) animal record that gave birth. Links to the animal master record for the dam, enabling lineage tracing and dam performance analytics.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Animal .

ind:primaryParturitionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Parturition Employee Id' ;
    rdfs:comment 'Reference to the farm worker or veterinary staff member who attended and recorded the parturition event. Used for workforce accountability and SOP compliance tracking.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:birthTime rdf:type rdf:Property ;
    rdfs:label 'Birth Time' ;
    rdfs:comment 'Precise date and time when the first offspring was born during the parturition event. Enables time-of-day analysis for staffing optimization and dystocia risk assessment.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:birthType rdf:type rdf:Property ;
    rdfs:label 'Birth Type' ;
    rdfs:comment 'Classification of the parturition by number of offspring born in the event (e.g., single, twin, triplet). Impacts dam recovery protocols, colostrum management, and offspring survival rates.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colostrumAdministered rdf:type rdf:Property ;
    rdfs:label 'Colostrum Administered' ;
    rdfs:comment 'Indicates whether colostrum was administered to the newborn offspring following birth. Critical for passive immunity transfer and neonatal survival; required for animal welfare compliance documentation.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colostrumSource rdf:type rdf:Property ;
    rdfs:label 'Colostrum Source' ;
    rdfs:comment 'Source of colostrum provided to the newborn offspring: from the dam directly, pooled from other animals, commercial colostrum supplement, or frozen colostrum bank. Relevant for biosecurity and disease transmission risk management.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colostrumVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Colostrum Volume Ml' ;
    rdfs:comment 'Volume of colostrum administered to the newborn offspring in millilitres. Used to verify adequate passive immunity transfer per species-specific protocols and animal welfare standards.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damBodyConditionScore rdf:type rdf:Property ;
    rdfs:label 'Dam Body Condition Score' ;
    rdfs:comment 'Body Condition Score (BCS) of the dam at the time of parturition, assessed on a standardized scale (e.g., 1–5 for cattle/sheep, 1–9 for swine). Indicates dam nutritional status and predicts post-partum reproductive performance.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damParity rdf:type rdf:Property ;
    rdfs:label 'Dam Parity' ;
    rdfs:comment 'The parity number (number of times the dam has given birth, including this event) at the time of parturition. First-parity animals carry higher dystocia risk; used for reproductive lifecycle analytics.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damPostPartumStatus rdf:type rdf:Property ;
    rdfs:label 'Dam Post Partum Status' ;
    rdfs:comment 'Health status of the dam immediately following the parturition event. Drives post-partum care protocols, veterinary treatment scheduling, and culling decisions.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dystociaFlag rdf:type rdf:Property ;
    rdfs:label 'Dystocia Flag' ;
    rdfs:comment 'Indicates whether the parturition involved dystocia (difficult birth requiring intervention). Drives veterinary follow-up workflows and is used in sire EPD (Expected Progeny Difference) calculations.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:easeOfBirthScore rdf:type rdf:Property ;
    rdfs:label 'Ease Of Birth Score' ;
    rdfs:comment 'Standardized numeric score (typically 1–5 scale) indicating the difficulty of the parturition: 1=No assistance, 2=Easy pull, 3=Hard pull, 4=Mechanical assistance, 5=Caesarean/Veterinary. Used for dystocia tracking, sire selection, and animal welfare compliance. [ENUM-REF-CANDIDATE: 1|2|3|4|5 — promote to reference product]' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gestationLengthDays rdf:type rdf:Property ;
    rdfs:label 'Gestation Length Days' ;
    rdfs:comment 'Number of days from confirmed conception or breeding date to the birth date. Compared against species-standard gestation norms to flag premature or overdue births and assess breeding program accuracy.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interventionType rdf:type rdf:Property ;
    rdfs:label 'Intervention Type' ;
    rdfs:comment 'Type of veterinary or assisted intervention performed during the parturition event. Used for dystocia severity classification, cost allocation, and sire/dam selection analytics.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offspringBornAlive rdf:type rdf:Property ;
    rdfs:label 'Offspring Born Alive' ;
    rdfs:comment 'Count of offspring born alive during this parturition event. Key metric for reproductive efficiency reporting and herd performance benchmarking.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offspringStillborn rdf:type rdf:Property ;
    rdfs:label 'Offspring Stillborn' ;
    rdfs:comment 'Count of offspring born dead (stillborn) during this parturition event. Used for mortality analysis, genetic program evaluation, and animal welfare compliance reporting.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placentaExpelled rdf:type rdf:Property ;
    rdfs:label 'Placenta Expelled' ;
    rdfs:comment 'Indicates whether the placenta (afterbirth) was fully expelled following parturition. Retained placenta is a significant post-partum health risk requiring veterinary intervention; tracked for dam health monitoring.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placentaExpulsionHours rdf:type rdf:Property ;
    rdfs:label 'Placenta Expulsion Hours' ;
    rdfs:comment 'Number of hours after birth until the placenta was fully expelled. Values exceeding species-specific thresholds (e.g., >12 hours in cattle) trigger retained placenta alerts and veterinary follow-up workflows.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationType rdf:type rdf:Property ;
    rdfs:label 'Presentation Type' ;
    rdfs:comment 'Describes the position of the fetus at the time of delivery (anterior/normal, posterior/backward, transverse/sideways). Relevant for dystocia risk assessment and veterinary intervention records.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOffspringBorn rdf:type rdf:Property ;
    rdfs:label 'Total Offspring Born' ;
    rdfs:comment 'Total count of offspring born during this parturition event, including stillborn. Used for litter size analytics and dam reproductive performance KPIs.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veterinaryIntervention rdf:type rdf:Property ;
    rdfs:label 'Veterinary Intervention' ;
    rdfs:comment 'Indicates whether a licensed veterinarian was required to intervene during the parturition event (e.g., caesarean section, manual correction of malpresentation). Drives post-event health monitoring and cost tracking.' ;
    rdfs:domain ind:ParturitionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidZoneId rdf:type rdf:Property ;
    rdfs:label 'Rfid Zone Id' ;
    rdfs:comment 'Identifier for the RFID reader zone or antenna array associated with this pen location. Used to automatically detect and log animal entries and exits via RFID ear tags, supporting real-time occupancy tracking and USDA APHIS 840 traceability requirements.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:aisleRowNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Row Number' ;
    rdfs:comment 'Aisle or row designation within a building where this pen is located (e.g., \'Aisle 3\', \'Row B\'). Supports precise pen location navigation for feed delivery crews, veterinary staff, and welfare auditors within large confinement facilities.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqft rdf:type rdf:Property ;
    rdfs:label 'Area Sqft' ;
    rdfs:comment 'Physical area of the pen or indoor housing unit measured in square feet. Used for indoor confinement facilities (barns, farrowing rooms, milking parlors) where square footage per animal head is the applicable welfare compliance metric.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biosecurityZone rdf:type rdf:Property ;
    rdfs:label 'Biosecurity Zone' ;
    rdfs:comment 'Biosecurity zone designation assigned to the pen per the operation\'s biosecurity plan. Governs personnel access controls, equipment movement restrictions, and disease containment protocols. Critical for APHIS foreign animal disease response planning and GLOBALG.A.P. biosecurity compliance.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingNumber rdf:type rdf:Property ;
    rdfs:label 'Building Number' ;
    rdfs:comment 'Identifier for the building or structure within the parent facility that contains this pen. Used for facility layout navigation, maintenance work order routing in SAP S/4HANA PM module, and emergency response planning.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityHead rdf:type rdf:Property ;
    rdfs:label 'Capacity Head' ;
    rdfs:comment 'Maximum number of animal head this pen or housing unit is designed to hold at one time, based on species-specific stocking density standards and welfare regulations. Used for occupancy management, welfare compliance audits, and feed ration planning.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date the pen or housing unit was first placed into operational service. Used for asset lifecycle tracking, maintenance scheduling, depreciation calculations (CAPEX), and historical occupancy trend analysis.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentOccupancy rdf:type rdf:Property ;
    rdfs:label 'Current Occupancy' ;
    rdfs:comment 'Current number of animal head present in the pen at the time of last update. Enables real-time occupancy monitoring, stocking density compliance checks, and feed delivery quantity calculations. Updated upon each animal movement event.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date the pen or housing unit was permanently taken out of service. Nullable for active pens. Supports asset lifecycle management, historical capacity reporting, and regulatory premises deregistration with USDA APHIS.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Feed Delivery Method' ;
    rdfs:comment 'Method by which feed rations are delivered to animals within this pen. Drives feed delivery scheduling, TMR (Total Mixed Ration) batch targeting, and feed management system integration with Granular Farm Management and SAP S/4HANA PP module.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flooringType rdf:type rdf:Property ;
    rdfs:label 'Flooring Type' ;
    rdfs:comment 'Type of flooring surface within the pen or housing unit. Impacts animal welfare assessments (lameness, injury risk), manure management practices, and compliance with GLOBALG.A.P. and GFSI welfare audit criteria. [ENUM-REF-CANDIDATE: concrete|slatted|dirt|rubber_mat|bedded_pack|pasture|grated — promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBiosecurityRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Biosecurity Restricted' ;
    rdfs:comment 'Indicates whether this pen requires restricted personnel access under the operation\'s biosecurity plan. When true, access logs, PPE requirements, and visitor protocols are enforced per APHIS biosecurity guidelines and GLOBALG.A.P. standards.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClimateControlled rdf:type rdf:Property ;
    rdfs:label 'Is Climate Controlled' ;
    rdfs:comment 'Indicates whether the pen or housing unit has active climate control systems (heating, cooling, or humidity regulation). Relevant to welfare compliance for sensitive species/life stages (farrowing, nursery), energy cost tracking, and IoT sensor deployment planning.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCovered rdf:type rdf:Property ;
    rdfs:label 'Is Covered' ;
    rdfs:comment 'Indicates whether the pen or housing unit has a roof or overhead shelter structure. Affects weather protection assessments, welfare audit scoring, and heat/cold stress risk classification for animal health management.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDisinfectedDate rdf:type rdf:Property ;
    rdfs:label 'Last Disinfected Date' ;
    rdfs:comment 'Date the pen was most recently disinfected with an approved disinfectant product. Distinct from cleaning — disinfection is a separate biosecurity step required between animal groups and after disease events. Tracked for APHIS and FSIS compliance.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightingType rdf:type rdf:Property ;
    rdfs:label 'Lighting Type' ;
    rdfs:comment 'Type of lighting available within the pen or housing unit. Relevant to animal welfare assessments, photoperiod management for reproductive performance, and energy efficiency reporting under CAPEX/OPEX tracking.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manureManagementType rdf:type rdf:Property ;
    rdfs:label 'Manure Management Type' ;
    rdfs:comment 'Method used to collect, store, or manage manure generated within this pen. Required for EPA nutrient management plan compliance, USDA NRCS BMP (Best Management Practices) reporting, and environmental permit documentation.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penCode rdf:type rdf:Property ;
    rdfs:label 'Pen Code' ;
    rdfs:comment 'Externally-known alphanumeric code or label assigned to the pen or housing unit, used in operational signage, feed delivery manifests, animal movement records, and FMIS integrations (e.g., Granular Farm Management, SAP S/4HANA PP module). Must be unique within the parent facility.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penName rdf:type rdf:Property ;
    rdfs:label 'Pen Name' ;
    rdfs:comment 'Human-readable descriptive name for the pen or housing unit (e.g., \'North Farrowing Room 3\', \'Pasture B-12\', \'Feedlot Pen 7A\'). Used in operational reports, welfare audit documentation, and staff communications.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStage rdf:type rdf:Property ;
    rdfs:label 'Production Stage' ;
    rdfs:comment 'Livestock production stage for which this pen is designated. Determines applicable feed ration programs, health protocols, withdrawal period tracking, and welfare audit criteria. Aligns with SAP S/4HANA PP production order classification and Granular Farm Management livestock records. [ENUM-REF-CANDIDATE: nursery|grower|finisher|breeding|gestation|farrowing|lactation|dry_lot|backgrounding — promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesType rdf:type rdf:Property ;
    rdfs:label 'Species Type' ;
    rdfs:comment 'Primary livestock species for which this pen or housing unit is designed and designated. Determines applicable welfare standards, ventilation requirements, stocking density limits, and regulatory reporting frameworks (APHIS, FSIS, USDA). [ENUM-REF-CANDIDATE: cattle|swine|poultry|sheep|goat|equine|mixed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockingDensityLimit rdf:type rdf:Property ;
    rdfs:label 'Stocking Density Limit' ;
    rdfs:comment 'Maximum allowable stocking density for this pen expressed as head per acre (outdoor) or square feet per head (indoor), per applicable welfare and regulatory standards. Used to enforce compliance thresholds and trigger alerts when current occupancy approaches or exceeds limits.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockingDensityUom rdf:type rdf:Property ;
    rdfs:label 'Stocking Density Uom' ;
    rdfs:comment 'Unit of measure for the stocking density limit field. Distinguishes between outdoor (head per acre) and indoor (square feet per head) density metrics to ensure correct welfare compliance calculations.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationType rdf:type rdf:Property ;
    rdfs:label 'Ventilation Type' ;
    rdfs:comment 'Type of ventilation system installed in or applicable to the pen or housing unit. Affects air quality management, heat stress mitigation, disease transmission risk, and welfare compliance under USDA APHIS and GLOBALG.A.P. standards.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:welfareCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Welfare Certification Status' ;
    rdfs:comment 'Current animal welfare certification status for this pen location under applicable certification programs (e.g., GLOBALG.A.P., Certified Humane, Animal Welfare Approved). Drives audit scheduling, corrective action tracking, and customer-facing welfare claims.' ;
    rdfs:domain ind:PenLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Reference to the farm manager or production supervisor accountable for the day-to-day management of this production group. Used for operational accountability, audit trails, and workforce performance reporting.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closeout Date' ;
    rdfs:comment 'Actual date on which the production group was closed out (harvested, sold, or dispersed). Populated upon group closure; null while group is active. Used for variance analysis against target closeout date.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:antibioticFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Antibiotic Free Flag' ;
    rdfs:comment 'Indicates whether this production group is enrolled in a no-antibiotics-ever (NAE) or raised-without-antibiotics (RWA) program. Drives withdrawal period tracking, treatment restrictions, and market channel eligibility (e.g., premium natural/organic buyers).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avgPlacementWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Placement Weight Kg' ;
    rdfs:comment 'Average live body weight in kilograms of animals at the time of placement into this production group. Baseline for average daily gain (ADG) calculations and feed ration calibration.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOnFeedTarget rdf:type rdf:Property ;
    rdfs:label 'Days On Feed Target' ;
    rdfs:comment 'Target number of days animals in this production group are expected to be on feed from placement to closeout. Derived from placement date and target closeout date; stored explicitly for scheduling and performance benchmarking.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the production group, used in operational systems (SAP PP lot, Granular Farm Management group code, FMIS reference). Unique within a facility and production year.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Human-readable descriptive name for the production group (e.g., \'Spring 2024 Finishing Pen 12\', \'Broiler Flock 2024-W22\'). Used in operational reports and dashboards.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupStatus rdf:type rdf:Property ;
    rdfs:label 'Group Status' ;
    rdfs:comment 'Current lifecycle status of the production group. \'active\' indicates animals are currently under management; \'closed\' indicates the group has been harvested or dispersed; \'transferred\' indicates animals moved to another group; \'cancelled\' indicates group was voided before placement; \'pending\' indicates group is planned but not yet placed.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date on which animals were placed into this production group and pen/location. Marks the official start of the production phase and triggers feed delivery, health protocol, and performance tracking timelines.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementHeadCount rdf:type rdf:Property ;
    rdfs:label 'Placement Head Count' ;
    rdfs:comment 'Number of animals placed into the production group at the start of the production phase. Serves as the baseline denominator for mortality rate, feed cost per head, and closeout performance calculations.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionPhase rdf:type rdf:Property ;
    rdfs:label 'Production Phase' ;
    rdfs:comment 'Defined production phase that characterizes the management stage of this group (e.g., receiving, backgrounding, finishing for beef; nursery, grow-finish for swine; brooding for poultry; lactating, dry for dairy). Determines applicable feed rations, health protocols, and performance benchmarks. [ENUM-REF-CANDIDATE: receiving|backgrounding|finishing|lactating|dry|nursery|grow_finish|farrowing|brooding|laying — promote to reference product]' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAdgKg rdf:type rdf:Property ;
    rdfs:label 'Target Adg Kg' ;
    rdfs:comment 'Target average daily gain in kilograms per animal per day for this production group during the current phase. Key performance indicator (KPI) for growth performance benchmarking and feed ration adequacy assessment.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Target Closeout Date' ;
    rdfs:comment 'Planned date for the production group to reach market weight and be harvested or transferred, closing out the production phase. Used for harvest scheduling, logistics planning, and financial closeout projections.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetFcr rdf:type rdf:Property ;
    rdfs:label 'Target Fcr' ;
    rdfs:comment 'Target feed conversion ratio (FCR) — kilograms of feed consumed per kilogram of live weight gain — for this production group. Core efficiency KPI used in feed cost management and production benchmarking.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFeedCostPerHead rdf:type rdf:Property ;
    rdfs:label 'Target Feed Cost Per Head' ;
    rdfs:comment 'Target total feed cost in the operational currency per animal head for the full production phase. Used in closeout cost accounting, COGS calculation, and production budget variance analysis.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarketWeightKg rdf:type rdf:Property ;
    rdfs:label 'Target Market Weight Kg' ;
    rdfs:comment 'Target live body weight in kilograms at which animals in this group are expected to reach market-ready condition. Used to calculate days-on-feed projections, feed conversion ratio (FCR) targets, and harvest scheduling.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMortalityRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Mortality Rate Pct' ;
    rdfs:comment 'Target maximum mortality rate expressed as a percentage of placement head count for this production group over the production phase. Used for animal welfare compliance benchmarking and health protocol effectiveness evaluation.' ;
    rdfs:domain ind:ProductionGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:canisterId rdf:type rdf:Property ;
    rdfs:label 'Canister Id' ;
    rdfs:comment 'Identifier of the canister within the storage tank where the goblet or cane holding the semen straws or embryos is located. Provides precise sub-tank location for efficient retrieval during AI or ET procedures.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemenCanister .

ind:conceptionRatePct rdf:type rdf:Property ;
    rdfs:label 'Conception Rate Pct' ;
    rdfs:comment 'Historical conception rate (pregnancy rate per AI attempt) achieved with this sire\'s semen lot, expressed as a percentage. Derived from breeding outcome records and used for genetic selection decisions and AI program planning. Updated as breeding results are recorded.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conceptionRateSampleSize rdf:type rdf:Property ;
    rdfs:label 'Conception Rate Sample Size' ;
    rdfs:comment 'Number of AI attempts used to calculate the historical conception rate for this semen lot. Provides statistical confidence context for the conception_rate_pct value; small sample sizes indicate lower reliability.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gobletCanePosition rdf:type rdf:Property ;
    rdfs:label 'Goblet Cane Position' ;
    rdfs:comment 'Specific goblet and cane position within the canister where the semen straws or embryos are stored (e.g., \'G2-C3\'). Enables precise physical retrieval and supports inventory audit accuracy.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Quantity' ;
    rdfs:comment 'Original quantity of semen straws or embryos received at the time of the lot\'s first receipt into inventory. Used as the baseline for consumption tracking, utilization rate analysis, and breeding cost accounting.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Overall quality classification of the semen lot based on post-thaw motility, morphology, and concentration assessments from the COA. Used for AI program tier selection and supplier quality management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexSortTarget rdf:type rdf:Property ;
    rdfs:label 'Sex Sort Target' ;
    rdfs:comment 'Target sex for sorted semen straws (female for heifer production, male for bull calf production). Only applicable when sexed_semen is True. Drives replacement heifer program planning and calf crop gender management.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexedSemen rdf:type rdf:Property ;
    rdfs:label 'Sexed Semen' ;
    rdfs:comment 'Indicates whether the semen straws in this inventory lot are sex-sorted (sexed semen), allowing producers to select for heifer or bull calves. Sexed semen commands a premium price and has lower conception rates than conventional semen.' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sireRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Sire Registration Number' ;
    rdfs:comment 'Official breed association registration number for the sire (bull or ram) from which semen was collected. Used for genetic pedigree verification, EPD lookup, and regulatory compliance with breed registries (e.g., American Angus Association, Holstein Association USA).' ;
    rdfs:domain ind:SemenInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaccinationRecordId rdf:type rdf:Property ;
    rdfs:label 'Vaccination Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each vaccination record. Primary key for the vaccination_record data product in the livestock domain.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:herdVaccinationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Herd Vaccination Schedule Id' ;
    rdfs:comment 'Reference to the herd vaccination schedule plan against which this record is being tracked for compliance. Enables gap analysis between planned and actual vaccinations.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HerdVaccinationSchedule .

ind:administrationDate rdf:type rdf:Property ;
    rdfs:label 'Administration Date' ;
    rdfs:comment 'The calendar date on which the vaccine was administered to the animal or group. Principal business event date for regulatory reporting, withdrawal period calculation, and booster scheduling.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:administrationLocation rdf:type rdf:Property ;
    rdfs:label 'Administration Location' ;
    rdfs:comment 'Name or identifier of the farm, barn, pen, or facility location where the vaccination was administered. Supports geographic disease surveillance, APHIS premises identification, and GLOBALG.A.P. site-level audit trails.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Administration Timestamp' ;
    rdfs:comment 'Precise date and time the vaccine was administered, captured from the farm management system or mobile device. Supports time-sensitive withdrawal period calculations and audit trail integrity.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adverseReactionDescription rdf:type rdf:Property ;
    rdfs:label 'Adverse Reaction Description' ;
    rdfs:comment 'Free-text description of any adverse reaction observed following vaccination (e.g., anaphylaxis, injection site swelling, fever). Populated only when adverse_reaction_observed is True. Supports APHIS CVB adverse event reporting.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseReactionObserved rdf:type rdf:Property ;
    rdfs:label 'Adverse Reaction Observed' ;
    rdfs:comment 'Indicates whether an adverse reaction was observed in the animal(s) following vaccination. A value of True triggers creation of an adverse event report to USDA APHIS Center for Veterinary Biologics (CVB) and initiates veterinary follow-up.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:animalCount rdf:type rdf:Property ;
    rdfs:label 'Animal Count' ;
    rdfs:comment 'Count of animals vaccinated in a group/herd-level vaccination event. Populated when herd_group_id is set and individual animal records are not created. Used for herd immunity coverage calculations.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (COA) issued by the vaccine manufacturer for the specific lot, confirming potency, purity, and safety testing results. Corresponds to COA in common agricultural jargon.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainMaintained rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Maintained' ;
    rdfs:comment 'Indicates whether the required cold chain storage conditions were maintained for the vaccine from receipt through administration. A value of False triggers a non-compliance flag and may invalidate the vaccination record for regulatory purposes.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diseaseTarget rdf:type rdf:Property ;
    rdfs:label 'Disease Target' ;
    rdfs:comment 'The disease, pathogen, or condition the vaccine is intended to prevent or control (e.g., \'Bovine Respiratory Disease\', \'Porcine Reproductive and Respiratory Syndrome\', \'Newcastle Disease\'). Supports disease surveillance analytics and APHIS reportable disease tracking.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageMl rdf:type rdf:Property ;
    rdfs:label 'Dosage Ml' ;
    rdfs:comment 'Volume of vaccine administered in milliliters (mL) per animal or per dose. Must conform to label-approved dosage. Deviations from label dosage require veterinary authorization and are flagged for compliance review.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseNumber rdf:type rdf:Property ;
    rdfs:label 'Dose Number' ;
    rdfs:comment 'Sequential dose number within a multi-dose vaccination series (e.g., 1 = primary, 2 = booster). Enables tracking of vaccination series completion and booster compliance.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerLotNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Lot Number' ;
    rdfs:comment 'Manufacturer-assigned lot or batch number printed on the vaccine vial label. Critical for product recall traceability, adverse event investigation, and APHIS biologics compliance. Corresponds to LOT in common agricultural jargon.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which the vaccine was stored prior to administration. Verified against label-required cold chain specifications (typically 2–8°C for refrigerated biologics). Out-of-range values trigger cold chain breach alerts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vaccineExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Vaccine Expiry Date' ;
    rdfs:comment 'Expiration date printed on the vaccine vial or packaging. Used to verify that the vaccine was not expired at time of administration and to flag non-compliant records for regulatory review.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vaccineName rdf:type rdf:Property ;
    rdfs:label 'Vaccine Name' ;
    rdfs:comment 'Commercial or proprietary name of the vaccine product administered (e.g., \'Bovishield Gold FP 5\', \'Porcilis PRRS\'). Denormalized from the vaccine product master for operational reporting and label compliance.' ;
    rdfs:domain ind:VaccinationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaccineType rdf:type rdf:Property ;
    rdfs:label 'Vaccine Type' ;
    rdfs:comment 'Biological classification of the vaccine formulation. Determines handling requirements, storage conditions, and regulatory classification under APHIS biologics licensing.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Animal Weight Kg' ;
    rdfs:comment 'The average or representative body weight in kilograms of the animals at the time of prescription. Used for weight-based dosage calculations and to verify appropriate dosing.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSpecies rdf:type rdf:Property ;
    rdfs:label 'Approved Species' ;
    rdfs:comment 'The animal species for which the drug is approved and prescribed (e.g., cattle, swine, poultry, sheep, goats). Must align with FDA label approval or AMDUCA extra-label use authorization. [ENUM-REF-CANDIDATE: cattle|swine|poultry|sheep|goats|equine|aquaculture — promote to reference product]' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageFrequency rdf:type rdf:Property ;
    rdfs:label 'Dosage Frequency' ;
    rdfs:comment 'The frequency or schedule at which the prescribed drug is to be administered (e.g., once daily, continuous feed, single dose). Required on the prescription label per FDA regulations.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClass rdf:type rdf:Property ;
    rdfs:label 'Drug Class' ;
    rdfs:comment 'Antimicrobial or pharmacological class of the prescribed drug (e.g., tetracycline, macrolide, ionophore, beta-lactam). Used for antibiotic stewardship analytics and WHO critically important antimicrobial (CIA) classification tracking.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvmLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Dvm License Number' ;
    rdfs:comment 'The state-issued veterinary license number of the prescribing veterinarian (DVM). Required on all VFD documents per FDA regulation and for FSIS antibiotic stewardship audit trails.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvmState rdf:type rdf:Property ;
    rdfs:label 'Dvm State' ;
    rdfs:comment 'The US state in which the prescribing veterinarian holds their active license. Required for cross-state regulatory compliance verification.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eggWithdrawalDays rdf:type rdf:Property ;
    rdfs:label 'Egg Withdrawal Days' ;
    rdfs:comment 'The number of days eggs must be withheld from sale following drug administration in laying poultry. Applicable only for poultry operations; null for non-poultry species.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extraLabelUse rdf:type rdf:Property ;
    rdfs:label 'Extra Label Use' ;
    rdfs:comment 'Indicates whether this prescription involves extra-label drug use (use of an FDA-approved drug in a manner not specified on the approved label). Extra-label use requires a valid VCPR and is regulated under AMDUCA (Animal Medicinal Drug Use Clarification Act).' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indication rdf:type rdf:Property ;
    rdfs:label 'Indication' ;
    rdfs:comment 'The disease, condition, or clinical indication for which the drug is being prescribed (e.g., bovine respiratory disease, necrotic enteritis, mastitis prevention). Required for VCPR documentation and FSIS antibiotic use justification.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfAnimals rdf:type rdf:Property ;
    rdfs:label 'Number Of Animals' ;
    rdfs:comment 'The total count of animals covered under this prescription or VFD. Required on VFD documents per FDA regulation and used for dosage calculation and antibiotic use density metrics.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescriptionType rdf:type rdf:Property ;
    rdfs:label 'Prescription Type' ;
    rdfs:comment 'Classification of the prescription by regulatory category. VFD (Veterinary Feed Directive) applies to medicated feed products; prescription_drug covers legend drugs requiring a valid VCPR; OTC_extra_label covers over-the-counter drugs used in an extra-label manner; compounded covers compounded preparations. [ENUM-REF-CANDIDATE: VFD|prescription_drug|OTC_extra_label|compounded — promote to reference product]' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAuthorized rdf:type rdf:Property ;
    rdfs:label 'Quantity Authorized' ;
    rdfs:comment 'The total quantity of drug or medicated feed product authorized under this prescription (e.g., total grams, total pounds of medicated feed, total vials). Controls dispensing limits and prevents over-use.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'The cumulative quantity of drug or medicated feed product actually dispensed against this prescription to date. Used to track partial fills and ensure authorized quantity is not exceeded.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any additional veterinarian instructions, warnings, or conditions associated with the prescription (e.g., do not use in animals producing milk for human consumption, refrigerate after opening). Captures label-specific or VCPR-specific guidance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Days' ;
    rdfs:comment 'The number of days the prescribed drug treatment is to be administered. Used to calculate total drug quantity needed, withdrawal period start date, and antibiotic use days for stewardship reporting.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vcprReference rdf:type rdf:Property ;
    rdfs:label 'Vcpr Reference' ;
    rdfs:comment 'The reference number or identifier for the established Veterinarian-Client-Patient Relationship (VCPR) under which this prescription was issued. A valid VCPR is a legal prerequisite for issuing any veterinary prescription or VFD under FDA regulations.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vfdDistributorName rdf:type rdf:Property ;
    rdfs:label 'Vfd Distributor Name' ;
    rdfs:comment 'The name of the licensed feed manufacturer or distributor authorized to produce and supply the medicated feed under this VFD. Required on VFD documents per FDA regulation for medicated feed traceability.' ;
    rdfs:domain ind:VeterinaryPrescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalEndDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal End Date' ;
    rdfs:comment 'The calculated calendar date on which the withdrawal period ends and the animal or animal products are cleared for harvest or sale. Derived from last treatment date plus withdrawal_period_days; stored for operational scheduling and FSIS compliance verification.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weightMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Weight Measurement Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual weight measurement record. Serves as the primary key for the weight_measurement data product in the livestock domain Silver Layer.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adgKg rdf:type rdf:Property ;
    rdfs:label 'Adg Kg' ;
    rdfs:comment 'Average Daily Gain (ADG) in kilograms per day, calculated as the difference between current and previous body weight divided by the number of days elapsed. A key Key Performance Indicator (KPI) for growth performance tracking and feed conversion ratio (FCR) analysis. Stored as a captured/confirmed value from the source system, not recomputed.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Adjusted Weight Kg' ;
    rdfs:comment 'Body weight after applying shrink percentage adjustment, representing the net pay weight used for sale, transfer, or harvest transactions. Calculated as body_weight_kg × (1 - shrink_pct/100) and stored for traceability.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyWeightKg rdf:type rdf:Property ;
    rdfs:label 'Body Weight Kg' ;
    rdfs:comment 'The measured live body weight of the individual animal or average body weight per head for a group measurement, expressed in kilograms. This is the principal quantitative outcome of the measurement event. Used in ADG calculations, FCR analysis, and harvest readiness assessment.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Body Weight Lbs' ;
    rdfs:comment 'The measured live body weight expressed in pounds (lbs), the primary unit of measure used in US domestic livestock markets, USDA reporting, and sale/harvest transactions. Maintained alongside kg for dual-unit reporting compliance.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOnFeed rdf:type rdf:Property ;
    rdfs:label 'Days On Feed' ;
    rdfs:comment 'Number of days the animal or group has been on the current feed ration since feedlot entry or last production stage transition. Used in conjunction with ADG to assess feed conversion efficiency and project harvest readiness date.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameScore rdf:type rdf:Property ;
    rdfs:label 'Frame Score' ;
    rdfs:comment 'Numerical frame score (typically 1–9 for beef cattle) based on hip height measurement at a standard age, used to predict mature body size and optimal harvest weight. Supports breed selection, feeding program design, and market endpoint targeting.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Harvest Ready Flag' ;
    rdfs:comment 'Boolean indicator set to True when the animal\'s current body weight, BCS, and days on feed meet the defined harvest readiness criteria for the production program. Triggers harvest scheduling workflow and FSIS pre-harvest notification processes.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipHeightCm rdf:type rdf:Property ;
    rdfs:label 'Hip Height Cm' ;
    rdfs:comment 'Measured hip height of the animal in centimeters at the time of weighing, used to calculate frame score and assess skeletal development relative to body weight. Supports growth curve modeling and breed standard compliance.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The technique or equipment type used to obtain the body weight. Affects measurement precision and confidence. Individual scale and load cell are most accurate; weigh tape and estimated methods carry higher variance and are flagged accordingly in analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text field for operator observations recorded at the time of weighing, such as animal behavior, equipment anomalies, environmental conditions, or reasons for weight variance. Supports audit trail and veterinary follow-up.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Number' ;
    rdfs:comment 'Externally-known business identifier for the weight measurement event, used for cross-referencing with farm management systems, scale printouts, and audit trails. Format: WM-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current workflow state of the weight measurement record. \'recorded\' = initial capture; \'verified\' = validated by supervisor or QA; \'rejected\' = failed validation rules; \'voided\' = cancelled after entry error.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time when the weight measurement was physically taken. This is the principal real-world event timestamp, distinct from record audit timestamps. Critical for Average Daily Gain (ADG) calculations and production checkpoint tracking.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Previous Measurement Date' ;
    rdfs:comment 'The date of the immediately preceding weight measurement for the same animal or group. Used to calculate the interval in days for ADG computation and to validate measurement frequency compliance.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousWeightKg rdf:type rdf:Property ;
    rdfs:label 'Previous Weight Kg' ;
    rdfs:comment 'The body weight recorded at the immediately preceding measurement event for the same animal or group, in kilograms. Stored on this record to support ADG validation and trend analysis without requiring a self-join.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkPct rdf:type rdf:Property ;
    rdfs:label 'Shrink Pct' ;
    rdfs:comment 'Estimated or measured percentage of body weight lost due to gut fill, stress, or transit prior to weighing (pencil shrink or actual shrink). Applied in sale weight calculations and market price negotiations. Standard industry practice in US livestock markets.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGroupWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Group Weight Kg' ;
    rdfs:comment 'Total combined live weight of all animals in a group measurement event, expressed in kilograms. Null for individual animal measurements. Used for pen-level inventory valuation and feed planning.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weighCondition rdf:type rdf:Property ;
    rdfs:label 'Weigh Condition' ;
    rdfs:comment 'Describes the gut-fill or fasting condition of the animal at the time of weighing, which directly affects the accuracy and comparability of weight measurements. Used to apply appropriate shrink adjustments and flag outlier weights.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Weight Variance Flag' ;
    rdfs:comment 'Boolean indicator set to True when the measured body weight deviates from the expected weight by more than the configured tolerance threshold (e.g., ±15% from breed/age/stage benchmark). Triggers data quality review and potential animal health investigation.' ;
    rdfs:domain ind:WeightMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Primary key for budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Employee Id' ;
    rdfs:comment 'Reference to the employee or manager formally accountable for this procurement budget. The budget owner is responsible for approving spend requests, monitoring variance, and authorizing budget revisions. Sourced from SAP SuccessFactors HR.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The total monetary value of procurement spend actually incurred to date against this budget, based on posted Goods Receipt Notes (GRNs) and approved vendor invoices processed through SAP MM/FI and Oracle NetSuite AP. Represents confirmed expenditure.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this procurement budget record within the ERP and farm management systems. Used for cross-system reconciliation between SAP CO and Granular Farm Management.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name for the procurement budget record (e.g., \'FY2025 Q2 Seed & Fertilizer - North Farm\'). Used in reporting dashboards and budget owner communications.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexOpexClassification rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Classification' ;
    rdfs:comment 'Indicates whether this procurement budget is classified as Capital Expenditure (CAPEX) for long-term asset acquisition (e.g., irrigation infrastructure, equipment) or Operational Expenditure (OPEX) for recurring inputs (e.g., seeds, fertilizers, agrochemicals, fuel). Critical for financial reporting under GAAP and IFRS.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The total monetary value of open and confirmed Purchase Orders (POs) that have been raised against this budget but not yet invoiced or goods-receipted. Derived from open PO commitments in SAP MM. Represents encumbered budget that is no longer freely available.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputCategory rdf:type rdf:Property ;
    rdfs:label 'Input Category' ;
    rdfs:comment 'Classification of the agricultural input type covered by this budget record. Drives spend analytics by input category and supports NPK fertilizer, AI (Active Ingredient) agrochemical, and feed ingredient cost tracking. [ENUM-REF-CANDIDATE: seed|fertilizer|agrochemical|feed|fuel|parts|supplies|other — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this procurement budget record is locked against further modifications (True) or remains open for amendment (False). Budgets are typically locked at period close or upon reaching a frozen status to preserve financial integrity.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'The date on which this procurement budget record was most recently revised or amended. Tracks the most recent budget adjustment event, supporting audit trails and reforecast cycle management.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Original Allocated Amount' ;
    rdfs:comment 'The initial budget amount as approved at the start of the budget period, before any revisions or amendments. Preserved for variance analysis comparing original plan versus revised plan versus actuals — a key OPEX control metric.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'The unencumbered budget balance remaining for new procurement commitments, calculated as allocated_amount minus committed_amount minus actual_spend_amount. Provides real-time budget availability for procurement controllers and farm managers.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential integer counter tracking how many times this procurement budget has been revised since initial approval. Version 0 represents the original approved budget; each subsequent amendment increments this counter. Supports budget reforecast audit trails.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendToBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Spend To Budget Pct' ;
    rdfs:comment 'The percentage of the allocated budget that has been consumed by actual spend to date (actual_spend_amount / allocated_amount × 100). A key KPI for procurement controllers to monitor budget utilization rate and flag potential overspend risk.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferInAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer In Amount' ;
    rdfs:comment 'The total monetary amount transferred into this budget record from other budget lines or cost centers during the period. Supports budget reallocation tracking between input categories or farm enterprises.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOutAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Out Amount' ;
    rdfs:comment 'The total monetary amount transferred out of this budget record to other budget lines or cost centers during the period. Together with transfer_in_amount, enables full reconciliation of budget movements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeIngredientConcentration rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Concentration' ;
    rdfs:comment 'Percentage concentration of the active ingredient (AI) in the formulated product, expressed as weight/weight (w/w) or weight/volume (w/v) percent. Used for dose calculation, MRL compliance, and SDS documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeIngredientName rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Name' ;
    rdfs:comment 'Common chemical name of the primary active ingredient (AI) responsible for the pesticidal action of the product, as listed on the EPA-approved label. Critical for MRL compliance checks and PHI determination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aphisImportPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Aphis Import Permit Number' ;
    rdfs:comment 'APHIS-issued permit number authorizing the importation of regulated biological inputs, biopesticides, or plant protection products. Required for cross-border procurement of biological agents under APHIS jurisdiction.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the active ingredient concentration value (e.g., % w/w, % w/v, g/L). Ensures correct interpretation of concentration for compliance calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalInstructions rdf:type rdf:Property ;
    rdfs:label 'Disposal Instructions' ;
    rdfs:comment 'Disposal methods and instructions for the chemical product and its container as specified in SDS Section 13. Includes EPA waste classification, disposal facility requirements, and container rinsing procedures. Required for EPA RCRA compliance and environmental management.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContact rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact' ;
    rdfs:comment '24-hour emergency telephone number for chemical emergency response, as listed on SDS Section 1 (e.g., CHEMTREC 1-800-424-9300). Required by OSHA HazCom and DOT hazardous materials regulations for emergency response coordination.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAidMeasures rdf:type rdf:Property ;
    rdfs:label 'First Aid Measures' ;
    rdfs:comment 'Summary of first aid instructions for exposure routes (inhalation, skin contact, eye contact, ingestion) as specified in SDS Section 4. Required for OSHA HazCom compliance and emergency response planning at field and warehouse locations.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Standardized formulation type code for the crop protection product (e.g., EC=Emulsifiable Concentrate, WP=Wettable Powder, SC=Suspension Concentrate, WG=Water Dispersible Granule, GR=Granule, SL=Soluble Liquid). Used for application equipment selection, mixing instructions, and storage classification. [ENUM-REF-CANDIDATE: EC|WP|SC|WG|GR|SL|EW|CS|DP|UL|SP|ZC — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapCertificationApplicable rdf:type rdf:Property ;
    rdfs:label 'Gap Certification Applicable' ;
    rdfs:comment 'Indicates whether this chemical compliance record is subject to GAP certification requirements, including GLOBALG.A.P. IFA or equivalent scheme. When true, the chemical\'s use must be documented in the farm\'s GAP compliance records and subject to third-party audit.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsHazardClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Classification' ;
    rdfs:comment 'GHS hazard classification category for the chemical product, identifying the type and severity of physical, health, and environmental hazards (e.g., \'Acute Toxicity Category 3\', \'Flammable Liquid Category 2\'). Drives PPE requirements, storage segregation, and emergency response planning.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCriticalControlPoint rdf:type rdf:Property ;
    rdfs:label 'Haccp Critical Control Point' ;
    rdfs:comment 'Indicates whether this chemical input is identified as a critical control point (CCP) in the facility\'s HACCP plan. When true, mandatory monitoring, corrective action, and verification procedures apply per Codex Alimentarius HACCP principles and FSMA Preventive Controls.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardStatements rdf:type rdf:Property ;
    rdfs:label 'Hazard Statements' ;
    rdfs:comment 'Standardized GHS H-code hazard statements describing the nature and degree of hazards posed by the chemical (e.g., \'H301: Toxic if swallowed; H400: Very toxic to aquatic life\'). Stored as a semicolon-delimited list of H-codes and descriptions. Required on SDS Section 2.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFsmaPreventiveControl rdf:type rdf:Property ;
    rdfs:label 'Is Fsma Preventive Control' ;
    rdfs:comment 'Indicates whether this chemical input is subject to FSMA preventive controls requirements, triggering mandatory hazard analysis, preventive control measures, monitoring, corrective actions, and recordkeeping under the FSMA Preventive Controls for Human Food rule.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedUsePesticide rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Use Pesticide' ;
    rdfs:comment 'Indicates whether the product is classified as a Restricted Use Pesticide (RUP) by the EPA, requiring purchase and use only by certified applicators or persons under their direct supervision. Critical for procurement authorization and applicator certification tracking.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Label Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the product label has been reviewed and confirmed to comply with all applicable EPA label requirements, including use directions, safety precautions, PHI, REI, and first aid statements. Required for GAP certification and HACCP compliance documentation.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlCommodity rdf:type rdf:Property ;
    rdfs:label 'Mrl Commodity' ;
    rdfs:comment 'The specific agricultural commodity (e.g., corn grain, soybean, wheat) for which the MRL value applies. MRL values are commodity-specific and market-specific, requiring separate records per commodity-market combination.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlMarket rdf:type rdf:Property ;
    rdfs:label 'Mrl Market' ;
    rdfs:comment 'The regulatory jurisdiction or export market for which the MRL value applies (e.g., USA, EU, Japan, China). Different markets have different MRL standards; this field enables multi-market compliance tracking.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlValue rdf:type rdf:Property ;
    rdfs:label 'Mrl Value' ;
    rdfs:comment 'Maximum Residue Limit (MRL) for the active ingredient on the target commodity, expressed in mg/kg (ppm). Represents the highest legally permissible concentration of pesticide residue in or on food and feed commodities. Used for export market compliance and FSMA preventive controls.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Required personal protective equipment (PPE) for handling, mixing, loading, and applying the chemical product as specified on the EPA label and SDS Section 8. Includes gloves, respirator type, eye protection, and protective clothing specifications. Mandatory for EPA Worker Protection Standard compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatements rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statements' ;
    rdfs:comment 'Standardized GHS P-code precautionary statements describing recommended measures to minimize or prevent adverse effects from exposure, storage, or disposal (e.g., \'P260: Do not breathe dust/fume; P501: Dispose of contents in accordance with local regulations\'). Stored as semicolon-delimited P-codes.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Classification of the crop protection product by its primary mode of action or target pest category. Drives regulatory pathway, label requirements, and IPM program classification. [ENUM-REF-CANDIDATE: herbicide|insecticide|fungicide|rodenticide|biopesticide|plant_growth_regulator|adjuvant|nematicide|bactericide — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Registration Effective Date' ;
    rdfs:comment 'Date on which the EPA registration for this chemical product became effective. Marks the start of the legally authorized period for sale and use of the product in the United States under FIFRA.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sds Expiry Date' ;
    rdfs:comment 'Date by which the Safety Data Sheet (SDS) must be reviewed and reissued or confirmed current. Typically set 3-5 years from the revision date per industry practice. Triggers SDS renewal workflow to maintain OSHA HazCom compliance.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most recent revision of the Safety Data Sheet (SDS) as issued by the chemical manufacturer or supplier. OSHA requires SDS to be updated within 3 months of new hazard information. Critical for ensuring workers have access to current hazard information.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signalWord rdf:type rdf:Property ;
    rdfs:label 'Signal Word' ;
    rdfs:comment 'GHS/EPA signal word appearing on the product label and SDS indicating the relative level of hazard severity: DANGER (most severe), WARNING (moderate), CAUTION (least severe), or none for non-hazardous products. Required on SDS Section 2 and product label.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'State Registration Status' ;
    rdfs:comment 'Registration status of the pesticide product in the specific state(s) where it will be used. States may impose additional registration requirements beyond federal EPA registration. [ENUM-REF-CANDIDATE: registered|not_registered|pending|cancelled|restricted — promote to reference product if multi-state tracking is required]' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Storage conditions and requirements for the chemical product as specified in SDS Section 7, including temperature range, humidity, segregation from incompatible materials, ventilation, and container requirements. Used for warehouse storage planning and EPA/OSHA compliance.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Agriculture delivery scheduling requires directing inbound shipments to specific grain elevators or warehouses for capacity planning and receiving dock scheduling. The existing delivery_location_id po' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual calendar date on which the agricultural input was physically received at the delivery location. Populated upon Goods Receipt Note (GRN) processing. Used for on-time delivery KPI calculation and vendor performance scoring.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transportation carrier or logistics provider responsible for delivering the agricultural input. Used for carrier performance tracking and freight audit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReference rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference' ;
    rdfs:comment 'Carrier-assigned reference or tracking number for the shipment. Enables real-time shipment tracking and exception management for in-transit deliveries.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Reason code or description explaining why a delivery schedule line has been delayed or cancelled. Supports supply chain risk analysis, vendor performance management, and contingency planning for critical agricultural inputs.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'Classification of the delivery destination type. Determines receiving procedures, storage requirements, and compliance checks (e.g., feed mill requires FDA feed safety compliance; chemical warehouse requires SDS and EPA storage regulations). [ENUM-REF-CANDIDATE: farm_gate|grain_elevator|warehouse|feed_mill|fuel_tank|processing_plant — promote to reference product]' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalEnd rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival End' ;
    rdfs:comment 'End timestamp of the estimated arrival window at the delivery location. Together with estimated_arrival_start defines the delivery window for receiving operations and carrier coordination.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalStart rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Start' ;
    rdfs:comment 'Start timestamp of the estimated arrival window at the delivery location. Supports dock scheduling, receiving staff planning, and cold-chain management for perishable biologicals.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms (INCOTERMS) code defining the point of risk and cost transfer between vendor and buyer. Common agricultural trade terms include FOB (Free On Board) and CIF (Cost Insurance and Freight). Governs freight cost allocation and insurance responsibility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPerishable rdf:type rdf:Property ;
    rdfs:label 'Is Perishable' ;
    rdfs:comment 'Indicates whether the agricultural input is a perishable biological product (e.g., live beneficial insects, biostimulants, inoculants, vaccines) requiring cold-chain management and expedited just-in-time delivery. Triggers special handling and temperature monitoring requirements.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Phi Compliance Required' ;
    rdfs:comment 'Indicates whether the delivered crop protection chemical requires Pre-Harvest Interval (PHI) compliance tracking. When True, the receiving system must enforce PHI restrictions to ensure MRL compliance at harvest. Applicable to pesticides and herbicides with EPA-registered PHI requirements.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The principal planned calendar date on which the agricultural input is scheduled to arrive at the delivery location. Aligned with seasonal crop planting calendars and livestock feeding program schedules to ensure timely availability.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of agricultural input received and confirmed via Goods Receipt Note (GRN) processing. May differ from scheduled_quantity due to short shipments, overages, or quality rejections. Triggers AP invoice matching in Oracle NetSuite.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the delivery schedule line, typically sourced from SAP S/4HANA MM scheduling agreement or Purchase Order (PO) schedule line. Used for cross-system reconciliation and vendor communication.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'The planned quantity of agricultural input material to be delivered on this schedule line, expressed in the base unit of measure (e.g., MT metric tons, BU bushels, CWT hundredweight, liters, units). Drives pre-positioning and inventory planning.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Required' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet (SDS) is required for this delivery. Mandatory for crop protection chemicals, fertilizers, and fuel deliveries per EPA and OSHA Hazard Communication Standard (HazCom). SDS must accompany shipment documentation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalProgram rdf:type rdf:Property ;
    rdfs:label 'Seasonal Program' ;
    rdfs:comment 'Name or code of the seasonal agricultural program this delivery schedule supports (e.g., \'Spring Planting 2025\', \'Fall Fertilizer Pre-Position\', \'Q3 Feed Ingredient Program\'). Enables grouping of schedule lines by crop season or livestock feeding cycle for supply continuity planning.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used for delivering the agricultural input. Common modes include truck (road), rail, barge (waterway), and air (for perishable biologicals). Influences BOL documentation requirements and freight cost allocation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Confirmed Date' ;
    rdfs:comment 'The delivery date formally confirmed by the vendor or supplier, which may differ from the planned delivery date. Used for vendor performance measurement and supply risk assessment.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeIngredientPct rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Pct' ;
    rdfs:comment 'Concentration of the active ingredient expressed as a percentage of the total formulation (e.g., 41.0 for 41% glyphosate). Used for application rate calculations, MRL compliance verification, and SDS documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aphisPermitCategory rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Category' ;
    rdfs:comment 'USDA APHIS permit classification for biological inputs including biocontrol agents, plant pests, and veterinary biologicals. Required for import, interstate movement, and field release of regulated biological organisms. Null or \'not_applicable\' for non-biological inputs.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogStatus rdf:type rdf:Property ;
    rdfs:label 'Catalog Status' ;
    rdfs:comment 'Current lifecycle status of the input in the master catalog. Controls whether the input is available for purchase requisition and PO creation in SAP S/4HANA MM. \'restricted\' indicates regulatory or internal procurement hold.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropTarget rdf:type rdf:Property ;
    rdfs:label 'Crop Target' ;
    rdfs:comment 'Primary crop or crop group for which this input is registered, approved, or intended (e.g., \'corn\', \'soybean\', \'wheat\', \'cotton\', \'all_crops\'). Drives crop-specific procurement planning, VRA prescription compatibility, and EPA label compliance.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputName rdf:type rdf:Property ;
    rdfs:label 'Input Name' ;
    rdfs:comment 'Human-readable commercial or trade name of the agricultural input (e.g., \'Roundup PowerMAX\', \'Pioneer P1197AM\', \'Urea 46-0-0\'). Used for display, reporting, and procurement communications.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputSubcategory rdf:type rdf:Property ;
    rdfs:label 'Input Subcategory' ;
    rdfs:comment 'Granular classification within the input category (e.g., for crop_protection: herbicide, insecticide, fungicide, nematicide; for fertilizer: nitrogen, phosphorus, potassium, micronutrient, organic). Supports IPM program management and NPK spend analytics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTracked rdf:type rdf:Property ;
    rdfs:label 'Lot Tracked' ;
    rdfs:comment 'Indicates whether this input requires lot/batch number tracking throughout the supply chain for traceability, recall management, and FSMA compliance. True for seeds, crop protection chemicals, feed ingredients, and biologicals.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique material number assigned in SAP S/4HANA MM or Oracle NetSuite for this agricultural input. Used as the primary cross-system business identifier for procurement, inventory, and AP processing.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeOfAction rdf:type rdf:Property ;
    rdfs:label 'Mode Of Action' ;
    rdfs:comment 'Biochemical mode of action classification for crop protection chemicals using HRAC (herbicides), IRAC (insecticides), or FRAC (fungicides) group codes (e.g., \'HRAC Group 9\', \'IRAC Group 4A\'). Critical for IPM resistance management programs.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlPpm rdf:type rdf:Property ;
    rdfs:label 'Mrl Ppm' ;
    rdfs:comment 'Maximum Residue Limit for the active ingredient on the target crop, expressed in parts per million (PPM). Regulatory threshold set by EPA, Codex Alimentarius, or importing country standards. Drives pre-harvest interval enforcement and food safety compliance.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkGrade rdf:type rdf:Property ;
    rdfs:label 'Npk Grade' ;
    rdfs:comment 'NPK nutrient analysis expressed as N-P-K percentage (e.g., \'46-0-0\' for urea, \'18-46-0\' for DAP, \'0-0-60\' for potash). Mandatory for all fertilizer inputs. Null for non-fertilizer inputs. Drives soil fertility planning and nutrient management compliance.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertifier rdf:type rdf:Property ;
    rdfs:label 'Organic Certifier' ;
    rdfs:comment 'Name of the USDA-accredited certifying agent that issued the organic certification for this input (e.g., \'CCOF\', \'Oregon Tilth\', \'OMRI\'). Required when organic_certified is True. Supports NOP audit trail and supplier qualification.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseUom rdf:type rdf:Property ;
    rdfs:label 'Purchase Uom' ;
    rdfs:comment 'Unit of measure used on purchase orders and vendor invoices, which may differ from the base UOM (e.g., purchased in MT but stocked in KG). Supports PO creation and AP invoice matching in SAP S/4HANA MM.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedUse rdf:type rdf:Property ;
    rdfs:label 'Restricted Use' ;
    rdfs:comment 'Indicates whether this crop protection chemical is classified as a Restricted Use Pesticide (RUP) by the EPA, requiring a certified pesticide applicator license for purchase and application. Drives applicator certification verification in procurement workflow.' ;
    rdfs:domain ind:InputCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Vendor-assigned or internal SKU code for this input, used for order management, barcode scanning, and RFID tracking in the warehouse. Supports Manhattan Associates WMS receiving and inventory control operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementApInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Procurement Ap Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the accounts payable invoice record in the procurement domain. Primary key for this data product. Entity role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementApInvoice .

ind:coaReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Received Flag' ;
    rdfs:comment 'Indicates whether the vendor\'s Certificate of Analysis (COA) has been received for regulated agricultural inputs (crop protection chemicals, fertilizers, feed ingredients). COA is required for FSMA compliance and quality acceptance. Missing COA triggers dispute type \'missing_coa_sds\'.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditNoteReference rdf:type rdf:Property ;
    rdfs:label 'Credit Note Reference' ;
    rdfs:comment 'Reference number of the vendor-issued credit note associated with this invoice, issued following dispute resolution (e.g., quality rejection of crop protection chemicals, quantity shortfall). Null if no credit note has been issued.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of the dispute resolution process for this invoice. Tracks progression from dispute initiation through vendor negotiation to resolution or escalation. Resolved disputes may result in credit note issuance or invoice adjustment.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRootCause rdf:type rdf:Property ;
    rdfs:label 'Dispute Root Cause' ;
    rdfs:comment 'Root cause classification for the invoice dispute, used for supplier performance analytics and process improvement. Examples include vendor billing error, receiving discrepancy, contract interpretation, quality failure, or documentation non-compliance (missing COA/SDS). [ENUM-REF-CANDIDATE: vendor_billing_error|receiving_discrepancy|contract_interpretation|quality_failure|documentation_noncompliance|pricing_error|other — promote to reference product]' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Date' ;
    rdfs:comment 'Last date by which payment must be made to qualify for the early payment discount (e.g., 2/10 Net 30 — pay within 10 days to receive 2% discount). Null if no early payment discount applies.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered by the vendor for early payment (e.g., 0.02 = 2% discount if paid within the early payment discount window). Used for cash flow optimization and dynamic discounting decisions in agricultural input procurement.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchDiscrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Match Discrepancy Amount' ;
    rdfs:comment 'Monetary value of the discrepancy identified during three-way match validation, expressed in the invoice currency. Positive value indicates over-invoicing; negative indicates under-invoicing. Used to determine dispute escalation thresholds.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchDiscrepancyType rdf:type rdf:Property ;
    rdfs:label 'Match Discrepancy Type' ;
    rdfs:comment 'Type of discrepancy identified during three-way match validation. Quantity variance indicates invoiced quantity differs from GRN quantity; price variance indicates invoiced unit price differs from PO price. Drives dispute initiation and resolution workflow.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Net amount payable to the vendor after applying taxes, discounts, and any credit adjustments, expressed in the invoice currency. Represents the final obligation amount. Part of MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netsuiteApDocRef rdf:type rdf:Property ;
    rdfs:label 'Netsuite Ap Doc Ref' ;
    rdfs:comment 'Oracle NetSuite internal AP document reference number assigned upon invoice entry into the AP sub-ledger. Used for cross-system reconciliation between procurement and finance domains.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Received Flag' ;
    rdfs:comment 'Indicates whether the vendor\'s Safety Data Sheet (SDS) has been received for hazardous agricultural inputs (crop protection chemicals, pesticides, herbicides). SDS is mandatory under EPA and OSHA regulations for chemical handling and storage compliance.' ;
    rdfs:domain ind:ProcurementApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Goods receipts for agricultural inputs are performed by specific receiving employees. Linking to employee supports FSMA traceability requirements, quality inspection accountability, and labor producti' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Quantity of the received agricultural input that passed quality inspection and was accepted into inventory. Triggers inventory update and AP invoice matching for the accepted portion.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaReceived rdf:type rdf:Property ;
    rdfs:label 'Coa Received' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) was received from the supplier with this delivery. Mandatory for fertilizers, crop protection chemicals, feed ingredients, and biologicals per GFSI and GLOBALG.A.P. requirements.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Match Status' ;
    rdfs:comment 'Status of the Accounts Payable (AP) three-way match process between the Purchase Order (PO), Goods Receipt Note (GRN), and supplier invoice. Drives payment release or block in Oracle NetSuite and SAP FI/AP.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Number' ;
    rdfs:comment 'Lot or batch number assigned to the received agricultural input at time of GRN posting. Critical for forward and backward traceability across the supply chain, PHI (Pre-Harvest Interval) compliance, and MRL (Maximum Residue Limit) testing.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlTestingRequired rdf:type rdf:Property ;
    rdfs:label 'Mrl Testing Required' ;
    rdfs:comment 'Indicates whether MRL (Maximum Residue Limit) testing is required for this received input before release to use. Applicable to crop protection chemicals and certain feed ingredients per EPA and Codex Alimentarius standards.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the agricultural input ordered on the originating Purchase Order (PO) line. Used for over/under delivery variance analysis and AP three-way match.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of the received agricultural input that failed quality inspection and was rejected. Triggers supplier return process and debit memo in AP. Must be reconciled with accepted_quantity + rejected_quantity = received_quantity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Coded reason for rejection of the rejected quantity. Examples: DAMAGED, MRL_EXCEEDANCE, COA_FAIL, WRONG_PRODUCT, TEMP_EXCEEDANCE, LABEL_NONCOMPLIANT, PEST_CONTAMINATION. Populated only when rejected_quantity > 0. [ENUM-REF-CANDIDATE: DAMAGED|MRL_EXCEEDANCE|COA_FAIL|WRONG_PRODUCT|TEMP_EXCEEDANCE|LABEL_NONCOMPLIANT|PEST_CONTAMINATION|SHORT_DATED — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsOnFile rdf:type rdf:Property ;
    rdfs:label 'Sds On File' ;
    rdfs:comment 'Indicates whether a current Safety Data Sheet (SDS) is on file for the received chemical or biological input. Mandatory for crop protection chemicals, fertilizers, and fuel per EPA and OSHA Hazard Communication Standard (HazCom).' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Specific storage bin, silo, tank, or warehouse location where the accepted quantity was physically placed after receipt. Used for inventory putaway confirmation and WMS task management.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt C' ;
    rdfs:comment 'Recorded temperature in degrees Celsius at the time of receipt for cold-chain sensitive agricultural inputs including biologicals, vaccines, and temperature-sensitive feed ingredients. Null for non-temperature-sensitive materials.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Exceedance Flag' ;
    rdfs:comment 'Indicates whether the recorded temperature at receipt exceeded the specified cold-chain tolerance for the material. When True, triggers quality hold and supplier notification workflow. Applicable to biologicals, vaccines, and cold-chain feed ingredients.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalReceiptValue rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Value' ;
    rdfs:comment 'Total monetary value of the accepted quantity at the PO unit price (accepted_quantity × unit_price). Used for inventory valuation posting, AP accrual, and spend analytics. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorDeliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Delivery Note Number' ;
    rdfs:comment 'Supplier-issued delivery note or packing slip number accompanying the shipment. Used for cross-referencing vendor documentation during GRN processing and dispute resolution.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Purchase orders are created and owned by procurement buyers (employees). Linking buyer to PO supports procurement accountability reporting, spend-by-buyer analysis, and segregation-of-duties controls ' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchasingGroupId rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchasing_group. Business justification: Every purchase order is managed by a purchasing group (the buyer team responsible for the category). Currently purchase_order stores purchasing_group_code as a STRING, which should be normalized to a ' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchasingGroup .

ind:purchasingOrgId rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchasing_org. Business justification: Every purchase order is issued by a purchasing organization. Currently purchase_order stores purchasing_org_code as a STRING, which should be normalized to a proper FK relationship. This enables joini' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchasingOrg .

ind:vendorQuotationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quotation Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_quotation. Business justification: A purchase order is typically awarded based on a vendor quotation. purchase_order.vendor_quote_ref (STRING) is a denormalized reference to the winning quotation. Adding vendor_quotation_id FK formaliz' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuotation .

ind:aphisPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Required' ;
    rdfs:comment 'Indicates whether an APHIS import or movement permit is required for the agricultural inputs on this PO (e.g., regulated seeds, biological control agents, plant materials, or animal feed ingredients subject to APHIS oversight). Triggers permit documentation workflow.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Flag' ;
    rdfs:comment 'Indicates whether this PO involves EPA-regulated materials such as registered pesticides, herbicides, fungicides, or other crop protection chemicals subject to EPA FIFRA registration requirements. Triggers SDS documentation requirements and MRL compliance review.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code (e.g., \'FOB Houston\' or \'CIF Rotterdam\'). Specifies the exact geographic point of risk and cost transfer. Corresponds to SAP MM EKKO.INCO2.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Required' ;
    rdfs:comment 'Indicates whether lot-level traceability is required for the inputs on this PO. When true, GRN processing must capture LOT numbers for each delivery. Mandatory for seeds (variety purity), crop protection chemicals (MRL compliance), and feed ingredients (FSMA traceability). Drives inventory.commodity_lot creation on receipt.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPoValue rdf:type rdf:Property ;
    rdfs:label 'Net Po Value' ;
    rdfs:comment 'Net total value of the purchase order after applying header-level discounts but before tax. Represents the actual procurement spend commitment for budget and OPEX/CAPEX reporting. Used in EBITDA and COGS analysis for agricultural input cost management.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netsuitePoRef rdf:type rdf:Property ;
    rdfs:label 'Netsuite Po Ref' ;
    rdfs:comment 'Oracle NetSuite internal PO transaction reference number. Used for AP processing, vendor payment reconciliation, and GL posting in NetSuite. Enables cross-system traceability between SAP MM and NetSuite for dual-system procurement environments.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'The business date on which the purchase order was formally issued to the vendor. This is the principal real-world event date for the PO transaction. Used for aging analysis, payment term calculation, and regulatory compliance documentation. Corresponds to SAP MM EKKO.BEDAT.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNotes rdf:type rdf:Property ;
    rdfs:label 'Po Notes' ;
    rdfs:comment 'Free-text field for additional instructions, special handling requirements, or procurement-specific notes communicated to the vendor on this PO. May include PHI/REI compliance reminders for crop protection chemical orders, organic certification requirements, or special packaging instructions.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks the PO from initial draft through approval, issuance to vendor, goods receipt, and final closure or cancellation. Drives workflow routing in SAP MM and AP processing in NetSuite. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|partially_received|fully_received|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement mechanism. Standard POs are single-event purchases; blanket POs cover recurring supply agreements; contract releases draw against a master contract; emergency POs bypass standard approval for urgent agricultural inputs. Corresponds to SAP MM EKKO.BSART (purchasing document type).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the buyer requests delivery of the ordered agricultural inputs at the specified plant or storage location. Used for supply chain planning, crop season alignment, and vendor on-time delivery KPI measurement. Corresponds to SAP MM EKKO.EINDT (delivery date at header level).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMmDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Mm Doc Number' ;
    rdfs:comment 'SAP S/4HANA MM purchasing document number from the EKKO table (EBELN field). 10-digit numeric identifier used for cross-system traceability between the Databricks Silver Layer and SAP MM. Enables drill-back to source ERP for AP processing and GRN matching.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Gross total value of the purchase order in the PO currency, representing the sum of all line item totals before any header-level discounts or taxes. Used for spend analytics, budget commitment tracking, and AP liability accrual. Corresponds to SAP MM EKKO total value.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Available Flag' ;
    rdfs:comment 'Indicates whether sufficient budget is available in the assigned cost center to fund this requisition at the time of submission. Derived from SAP CO budget availability check (AVAC). True = budget confirmed; False = budget insufficient or not checked.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedToPoFlag rdf:type rdf:Property ;
    rdfs:label 'Converted To Po Flag' ;
    rdfs:comment 'Indicates whether this approved requisition has been converted into a formal Purchase Order (PO) in SAP MM. True = PO raised; False = PO not yet created. Supports open requisition monitoring.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Physical delivery address or farm site location where the requisitioned agricultural inputs are to be delivered. May reference a specific field, storage facility, or warehouse location.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated procurement cost calculated as requested quantity multiplied by estimated unit cost. Used for budget availability validation and CAPEX/OPEX spend approval thresholds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the agricultural input at the time of requisition, used for budget availability checks and spend forecasting. Expressed in the operating currency.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Free-text business justification provided by the requester explaining the operational need for the agricultural input, including agronomic rationale, IPM program requirements, or livestock nutrition plan references.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netsuiteprRef rdf:type rdf:Property ;
    rdfs:label 'Netsuitepr Ref' ;
    rdfs:comment 'Cross-reference identifier for the corresponding purchase requisition record in Oracle NetSuite (used for AP processing and financial reconciliation where NetSuite is the financial system of record alongside SAP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether the requisitioned input requires regulatory pre-approval before procurement, such as EPA registration for pesticides, APHIS permits for biological inputs, or FDA compliance for feed additives.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of the agricultural input material requested, expressed in the base unit of measure (UOM). Supports volume-based spend estimation and supplier capacity planning.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name of the farm operations, agronomy, livestock, maintenance, or other internal department that initiated the purchase requisition. Used for spend analytics and budget allocation reporting.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'The date by which the requested agricultural input must be delivered to the plant or farm site to meet operational needs such as planting windows, PHI compliance, or livestock feeding schedules.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'The business date on which the purchase requisition was formally raised by the requesting department. This is the principal real-world event date for this transaction, distinct from system audit timestamps.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the purchase requisition, used across procurement workflows and communications. Corresponds to SAP MM BANF number (EBAN-BANFN).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the purchase requisition within the procurement approval workflow. Tracks progression from initial draft through approval and conversion to a formal Purchase Order (PO). [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|cancelled|converted_to_po — promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBanfNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Banf Number' ;
    rdfs:comment 'SAP S/4HANA MM native 10-digit purchase requisition document number (BANF/EBAN table key). Used for direct traceability back to the system of record for AP processing and audit.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Required Flag' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet (SDS) is required for the requisitioned material, applicable to agrochemicals, fertilizers, and hazardous substances. True = SDS documentation mandatory before PO conversion. Supports EPA and OSHA compliance.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnClaimId rdf:type rdf:Property ;
    rdfs:label 'Return Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for the return or claim record raised against a vendor for non-conforming agricultural inputs. Primary key for this entity.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cropLossEventId rdf:type rdf:Property ;
    rdfs:label 'Crop Loss Event Id' ;
    rdfs:comment 'Foreign key linking to crop.loss_event. Business justification: Crop loss events caused by failed inputs (poor germination, ineffective pesticide) directly trigger vendor return claims. This FK links the agronomic evidence of loss to the procurement claim, support' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LossEvent .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Return claims for rejected agricultural inputs (failed MRL tests, germination failures) are initiated by quality or receiving employees. Linking to employee supports quality management accountability,' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReturnProcurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Procurement Goods Receipt Id' ;
    rdfs:comment 'Reference to the Goods Receipt Note (GRN) at which the non-conforming input was received and inspected. Establishes the physical receipt event for the claim.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementGoodsReceipt .

ind:approvedCreditValue rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Value' ;
    rdfs:comment 'Vendor-approved credit amount for the return claim, which may differ from the originally claimed value following negotiation or partial acceptance. Used for credit note reconciliation in Oracle NetSuite AP.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'Calendar date on which the return or claim was formally raised against the vendor. Serves as the principal business event date for claim aging, SLA tracking, and vendor performance reporting.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimDescription rdf:type rdf:Property ;
    rdfs:label 'Claim Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, defect, or dispute forming the basis of the return claim. Captures field observations, inspection findings, and specific deviation from purchase specification.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimValue rdf:type rdf:Property ;
    rdfs:label 'Claim Value' ;
    rdfs:comment 'Monetary value of the return claim representing the cost recovery amount sought from the vendor. Calculated as claimed quantity multiplied by unit price from the originating PO. Used for AP credit note processing and vendor spend analytics.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedQuantity rdf:type rdf:Property ;
    rdfs:label 'Claimed Quantity' ;
    rdfs:comment 'Quantity of agricultural input subject to the return or claim, expressed in the unit of measure of the original purchase order. Represents the affected volume for cost recovery calculation.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which the return claim was formally closed, either through credit note application, replacement goods receipt, or mutual agreement. Marks end of claim lifecycle for reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteDate rdf:type rdf:Property ;
    rdfs:label 'Credit Note Date' ;
    rdfs:comment 'Date on which the vendor issued the credit note for the approved return claim value. Triggers AP credit application in Oracle NetSuite or SAP FI-AP for payment offset.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Type of supporting evidence submitted with the return claim. Certificate of Analysis (COA) failures, laboratory test results, field germination observations, and SDS non-compliance documentation are critical for agrochemical and seed claims. [ENUM-REF-CANDIDATE: coa_failure|lab_test_result|field_observation|photo_evidence|germination_test|sds_non_compliance|mrl_exceedance|efficacy_trial — promote to reference product]' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:germinationRateClaimedPct rdf:type rdf:Property ;
    rdfs:label 'Germination Rate Claimed Pct' ;
    rdfs:comment 'Actual germination rate percentage observed in the field or laboratory, forming the basis of a seed germination guarantee claim. Compared against the vendor-guaranteed germination rate specified in the purchase contract.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplySuspensionTriggered rdf:type rdf:Property ;
    rdfs:label 'Supply Suspension Triggered' ;
    rdfs:comment 'Indicates whether this return claim triggered a supply suspension for the vendor or specific input material. Activated for MRL exceedances, FSMA violations, or critical quality failures requiring immediate procurement halt.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorAcknowledgedDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledged Date' ;
    rdfs:comment 'Date on which the vendor formally acknowledged receipt and validity of the return claim. Used to measure vendor responsiveness and calculate claim resolution cycle time for supplier performance scorecards.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorGuaranteedGerminationPct rdf:type rdf:Property ;
    rdfs:label 'Vendor Guaranteed Germination Pct' ;
    rdfs:comment 'Germination rate percentage guaranteed by the vendor as specified in the seed purchase contract or product label. Used as the benchmark for germination failure claim validation under the Federal Seed Act.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Notes' ;
    rdfs:comment 'Vendor\'s formal written response to the return claim, including acceptance, rejection rationale, or proposed resolution. Captured for dispute management and vendor performance audit trail.' ;
    rdfs:domain ind:ReturnClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique system-generated identifier for the Request for Quotation record. Maps to SAP MM EKKO-EBELN for document type AN.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:customerPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Customer Preference Id' ;
    rdfs:comment 'Foreign key linking to customer.preference. Business justification: Customer-specification-driven sourcing: procurement issues RFQs with parameters (organic certification, GMO status, COOL origin, MRL standards) derived directly from customer preference records. Agric' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:rfqAwardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Rfq Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor selected as the winner of the competitive bidding process. Populated after evaluation is complete and award decision is made. Links to the Purchase Order (PO) creation step in SAP MM.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:rfqVendorId rdf:type rdf:Property ;
    rdfs:label 'Rfq Vendor Id' ;
    rdfs:comment 'Reference to the qualified vendor or supplier to whom this RFQ is issued. In multi-vendor RFQs, each vendor receives a separate RFQ record. Maps to SAP MM vendor master (LFA1-LIFNR).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:evalWeightCertification rdf:type rdf:Property ;
    rdfs:label 'Eval Weight Certification' ;
    rdfs:comment 'Percentage weight assigned to vendor certification status (e.g., GLOBALG.A.P., SQF, BRC, ISO 22000, USDA Organic) in the multi-criteria evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evalWeightLeadTime rdf:type rdf:Property ;
    rdfs:label 'Eval Weight Lead Time' ;
    rdfs:comment 'Percentage weight assigned to vendor lead time in the multi-criteria evaluation scoring model. Reflects the importance of timely delivery for crop season alignment and planting window compliance.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evalWeightPrice rdf:type rdf:Property ;
    rdfs:label 'Eval Weight Price' ;
    rdfs:comment 'Percentage weight assigned to price in the multi-criteria vendor response evaluation scoring model. Together with lead time, certification, and quality history weights, must sum to 100%. Supports transparent competitive bidding per USDA procurement standards.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evalWeightQualityHistory rdf:type rdf:Property ;
    rdfs:label 'Eval Weight Quality History' ;
    rdfs:comment 'Percentage weight assigned to vendor historical quality performance (COA compliance, rejection rates, audit scores) in the multi-criteria evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code (e.g., \'FOB Chicago\', \'CIF New Orleans\'). Specifies the exact point of risk and cost transfer for agricultural input shipments. Maps to SAP MM EKKO-INCO2.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputSpecification rdf:type rdf:Property ;
    rdfs:label 'Input Specification' ;
    rdfs:comment 'Detailed technical specification of the agricultural input required. For crop protection: Active Ingredient (AI) concentration and formulation type. For fertilizers: NPK grade/analysis (e.g., 46-0-0 Urea). For seeds: variety, hybrid, and GMO/non-GMO status. For feed ingredients: nutritional profile (protein, energy, moisture).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minVendorResponses rdf:type rdf:Property ;
    rdfs:label 'Min Vendor Responses' ;
    rdfs:comment 'The minimum number of vendor quotation responses required before the RFQ can proceed to evaluation. Enforces competitive bidding requirements and prevents single-source procurement without justification.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrlComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Required' ;
    rdfs:comment 'Indicates whether vendor must certify that crop protection chemicals comply with Maximum Residue Limit (MRL) standards for the target crop and market. Applicable to pesticides, herbicides, and fungicides per EPA and Codex Alimentarius standards.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertifiedRequired rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Required' ;
    rdfs:comment 'Indicates whether the vendor must supply inputs certified under the USDA National Organic Program (NOP) or equivalent organic certification standard. Drives vendor qualification filtering and COA documentation requirements.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'The precise date and time by which vendors must submit their quotation responses. Used to enforce competitive bidding timelines and trigger evaluation workflows. Maps to SAP MM EKKO-ANGDT (quotation deadline).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultingPoNumber rdf:type rdf:Property ;
    rdfs:label 'Resulting Po Number' ;
    rdfs:comment 'The SAP MM Purchase Order document number generated from this RFQ upon vendor award. Provides traceability from competitive sourcing event to binding procurement commitment. Maps to SAP MM EKKO-EBELN for document type NB.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed narrative description of the sourcing requirement, including input specifications, intended use, agronomic context, and any special handling or compliance requirements.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Externally visible business document number assigned to the RFQ, used in vendor communications and procurement correspondence. Corresponds to SAP MM purchasing document number (EKKO-EBELN) with document type AN.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle state of the RFQ document. Tracks progression from internal drafting through vendor issuance, response collection, evaluation, and final closure or cancellation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Type' ;
    rdfs:comment 'Classifies the procurement event type driving this RFQ. Spot purchases address immediate needs; seasonal contracts cover full growing season requirements; contract renewals re-compete existing supplier agreements; blanket orders establish volume commitments.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPrice rdf:type rdf:Property ;
    rdfs:label 'Target Price' ;
    rdfs:comment 'Internal benchmark or target price per UOM that procurement expects to achieve through competitive bidding. Used for vendor response evaluation and spend analytics. Treated as confidential business data and not disclosed to vendors.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'The end date after which vendor quotation responses are no longer considered valid. Ensures price commitments are time-bounded for seasonal agricultural input procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'The start date from which vendor quotation responses are considered valid and binding for price and availability commitments.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendor\'s bank account number used for electronic funds transfer (EFT) and ACH payment processing. Classified restricted due to PCI/financial data sensitivity.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'ABA routing transit number identifying the vendor\'s financial institution for ACH and wire transfer payments. Classified restricted due to financial data sensitivity.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of ordered quantity actually delivered by the vendor within the scorecard period. Measures supply reliability for critical agricultural inputs such as seeds, NPK fertilizers, and crop protection chemicals.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsmaSvcpCompliant rdf:type rdf:Property ;
    rdfs:label 'Fsma Svcp Compliant' ;
    rdfs:comment 'Indicates whether the vendor has been verified as compliant with FSMA Supplier Verification Control Program (SVCP) requirements under 21 CFR Part 1, Subpart L. Required for vendors supplying food-grade or food-contact agricultural inputs.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme' ;
    rdfs:comment 'GFSI-benchmarked food safety certification scheme held by the vendor (e.g., Safe Quality Food (SQF), British Retail Consortium (BRC), International Featured Standards (IFS), FSSC 22000). Determines eligibility for supplying food-contact or food-grade agricultural inputs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterm Default' ;
    rdfs:comment 'Default International Commercial Terms (Incoterms) agreed with this vendor for shipment of agricultural inputs. Determines risk transfer point and freight cost responsibility. Free On Board (FOB) and Cost Insurance and Freight (CIF) are most common for bulk commodity inputs.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of vendor invoices that matched the corresponding PO and GRN without discrepancy within the scorecard period. Drives AP processing efficiency and three-way match success rate.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAuditScore rdf:type rdf:Property ;
    rdfs:label 'Last Audit Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) from the most recent vendor qualification audit. Reflects compliance with GAP, GMP, HACCP, and food safety standards. Scores below threshold trigger conditional status or disqualification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of purchase orders delivered by the vendor on or before the confirmed delivery date within the current scorecard period. Key performance indicator (KPI) for vendor scorecard and contract renewal decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openCorrectiveActions rdf:type rdf:Property ;
    rdfs:label 'Open Corrective Actions' ;
    rdfs:comment 'Count of open corrective action requests (CARs) issued to the vendor for quality, compliance, or delivery failures. Non-zero values may trigger conditional status or procurement holds pending resolution.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Rating' ;
    rdfs:comment 'Composite vendor performance rating derived from on-time delivery, fill rate, quality acceptance, invoice accuracy, and regulatory compliance scores. Drives preferred vendor designation and contract renewal decisions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date on which the vendor was most recently granted approved or conditional qualification status following audit and documentation review.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle state of the vendor\'s qualification within the approved supplier program. Controls whether purchase orders may be issued. \'Conditional\' indicates approval with restrictions (e.g., limited input categories or volume caps).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of received goods that passed quality inspection (GRN quality check) without rejection or return within the scorecard period. Reflects vendor\'s adherence to COA specifications and MRL compliance for agrochemical inputs.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Score' ;
    rdfs:comment 'Composite score (0.00–100.00) reflecting the vendor\'s compliance with applicable regulatory requirements including EPA registration currency, APHIS permit validity, SDS documentation completeness, FSMA SVCP status, and MRL adherence.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which the vendor must complete re-qualification activities (audit, documentation refresh, certification renewal) to maintain approved status. Triggers procurement alerts when approaching.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapVendorAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Account Group' ;
    rdfs:comment 'SAP S/4HANA MM vendor account group code (e.g., LIEF for standard suppliers, KRED for one-time vendors) controlling field selection, number ranges, and partner functions in the vendor master.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Period End Date' ;
    rdfs:comment 'End date of the performance measurement period for which the current scorecard metrics (on-time delivery, fill rate, quality acceptance, invoice accuracy, regulatory compliance) were calculated.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Compliance Flag' ;
    rdfs:comment 'Indicates whether the vendor has provided current Safety Data Sheets (SDS) for all supplied chemical inputs (fertilizers, agrochemicals, fuel) in compliance with OSHA HazCom 2012 (GHS). True = all required SDS documents on file and current.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Alphanumeric business identifier assigned to the vendor in SAP S/4HANA MM and Oracle NetSuite for cross-system reference, purchase order creation, and AP processing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor by the primary category of agricultural inputs or services supplied. Drives procurement routing, compliance requirements, and SDS/EPA documentation obligations. [ENUM-REF-CANDIDATE: seed_supplier|fertilizer_distributor|agrochemical_supplier|feed_ingredient_vendor|fuel_supplier|equipment_parts_dealer|service_provider|logistics_carrier|other — promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAuditId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Id' ;
    rdfs:comment 'Unique system-generated identifier for the vendor audit record. Primary key for the vendor_audit data product in the procurement domain.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAudit .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The calendar date on which the audit activity concluded. For single-day audits, this equals audit_date. Used to calculate audit duration and schedule follow-up activities.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Indicates whether the audit was conducted on-site at the vendor facility, remotely via document review and virtual inspection, or as a hybrid combining both approaches.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document reference number or URL pointing to the full audit report stored in the document management system. Enables retrieval of detailed findings, evidence, and auditor notes for regulatory review and dispute resolution.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Overall outcome of the audit: pass (vendor meets all requirements), conditional_pass (vendor meets minimum requirements but must address findings within a defined period), fail (vendor does not meet minimum requirements and is disqualified or suspended pending corrective action).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification Number' ;
    rdfs:comment 'Professional certification or accreditation number of the lead auditor issued by a recognized body (e.g., GFSI, SQF, BRC, GLOBALG.A.P.). Used to verify auditor credentials and maintain audit trail integrity.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor who conducted the audit. May be an internal quality assurance staff member or a third-party certification body auditor.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization or certification body the lead auditor represents (e.g., internal quality team, SGS, Bureau Veritas, NSF International, SQF Institute).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Received Date' ;
    rdfs:comment 'The date on which the vendor\'s Corrective Action Plan (CAP) or evidence of corrective actions was received by the procurement quality team. Used to track vendor responsiveness and compliance with remediation timelines.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action process: not_required (no CAP needed), pending (CAP not yet submitted), submitted (CAP received, under review), accepted (CAP approved by quality team), rejected (CAP insufficient, resubmission required), overdue (past due date without submission).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaComplianceIncluded rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Included' ;
    rdfs:comment 'Indicates whether EPA regulatory compliance was included in the audit scope. Relevant for crop protection chemical (Active Ingredient/AI) and pesticide suppliers subject to EPA registration and Maximum Residue Limit (MRL) requirements.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foodSafetyIncluded rdf:type rdf:Property ;
    rdfs:label 'Food Safety Included' ;
    rdfs:comment 'Indicates whether food safety systems (HACCP, FSMA, GFSI) were included in the audit scope. Supports FSMA Supplier Verification for Human Food (SVCP) compliance tracking.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapComplianceIncluded rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Included' ;
    rdfs:comment 'Indicates whether Good Agricultural Practices (GAP) compliance was included in the audit scope. Relevant for seed, produce, and raw agricultural commodity suppliers.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceIncluded rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Included' ;
    rdfs:comment 'Indicates whether Good Manufacturing Practices (GMP) compliance was included in the audit scope. Relevant for feed ingredient, fertilizer, and agrochemical suppliers.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major findings represent significant system failures or regulatory deviations that must be corrected within a defined timeframe to maintain supplier qualification status.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrlComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s adherence to Maximum Residue Limit (MRL) requirements for crop protection chemicals and Active Ingredients (AI) was verified during the audit. Supports EPA and Codex Alimentarius MRL compliance.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'The planned date for the next routine surveillance audit of this vendor, determined by audit frequency policy based on vendor risk tier and audit result history.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of audit observations recorded. Observations are noted areas of concern or improvement opportunities that do not constitute formal non-conformances but are tracked for trend analysis and continuous improvement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Audit Due Date' ;
    rdfs:comment 'The target date by which the re-audit must be completed. Null when re_audit_required is False. Used for scheduling and compliance deadline tracking.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Re Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up re-audit is required to verify that corrective actions have been effectively implemented. Typically set to True for failed audits or conditional passes with critical findings.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsDocumentationVerified rdf:type rdf:Property ;
    rdfs:label 'Sds Documentation Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s Safety Data Sheet (SDS) documentation for chemical and biological inputs was reviewed and verified as current and compliant during the audit. Critical for EPA and OSHA compliance for agrochemical and fertilizer suppliers.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorFacilityCountry rdf:type rdf:Property ;
    rdfs:label 'Vendor Facility Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the vendor facility location. Used for Country of Origin Labeling (COOL) compliance, import risk assessment, and FSMA Foreign Supplier Verification Program (FSVP) applicability determination.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorFacilityName rdf:type rdf:Property ;
    rdfs:label 'Vendor Facility Name' ;
    rdfs:comment 'Name of the specific vendor facility or site that was audited. A single vendor may operate multiple facilities, each requiring independent audit records.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Vendor contracts have a designated contract owner employee responsible for renewals, compliance monitoring, and vendor relationship management. The existing \'contract_owner\' plain-text column is a den' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierSustainabilityId rdf:type rdf:Property ;
    rdfs:label 'Supplier Sustainability Id' ;
    rdfs:comment 'Foreign key linking to sustainability.supplier_sustainability. Business justification: Agriculture supply contracts are increasingly conditioned on supplier sustainability scores and corrective action plan status. Linking vendor_contract to supplier_sustainability enables contract renew' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSustainability .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'The contracted base unit price for the agricultural input, expressed per unit of measure (volume_uom). For formula-based or WASDE-indexed contracts, this is the reference price before adjustments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the vendor contract. Draft: under negotiation; Pending Approval: awaiting authorization; Active: binding and in force; Suspended: temporarily halted; Expired: past end date without renewal; Terminated: ended early; Closed: fully fulfilled and archived. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|closed — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the procurement contract by its commercial structure. Framework agreements cover multiple POs over time; spot contracts are single-event; annual supply agreements govern a full crop year; blanket purchase orders allow call-offs; consignment contracts defer payment until consumption. [ENUM-REF-CANDIDATE: framework|spot|annual_supply|blanket_purchase|consignment|index_linked — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total estimated monetary value of the contract over its full term, calculated as contracted_volume × base_price. Used for spend analytics, CAPEX/OPEX planning, and financial reporting. For formula-based contracts, this is the estimated value at time of signing.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedVolume rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume' ;
    rdfs:comment 'Total quantity of the agricultural input committed under this contract for the contract period. Expressed in the unit of measure specified in volume_uom (BU, MT, CWT, L, KG, etc.).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International commercial terms (Incoterms) governing risk transfer and freight responsibility between the enterprise and the vendor. FOB = Free On Board; CIF = Cost Insurance and Freight; EXW = Ex Works; DAP = Delivered at Place; DDP = Delivered Duty Paid; FCA = Free Carrier; CFR = Cost and Freight. [ENUM-REF-CANDIDATE: FOB|CIF|EXW|DAP|DDP|FCA|CFR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTermsLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms Location' ;
    rdfs:comment 'Named place or port associated with the Incoterms delivery terms (e.g., \'Port of New Orleans\' for FOB, \'Chicago Terminal\' for DAP). Required to complete the Incoterms designation per ICC 2020.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Required' ;
    rdfs:comment 'Indicates whether the agricultural input covered by this contract (e.g., pesticides, herbicides, fungicides) requires EPA registration under FIFRA (Federal Insecticide, Fungicide, and Rodenticide Act). Mandatory compliance check for chemical input procurement.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forceMajeureFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Flag' ;
    rdfs:comment 'Indicates whether the contract includes a force majeure clause that excuses non-performance due to extraordinary events (natural disasters, crop failures, regulatory actions). Critical for agricultural supply chain risk management.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalgApRequired rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Required' ;
    rdfs:comment 'Indicates whether the vendor is contractually required to hold a valid GLOBALG.A.P. (Global Good Agricultural Practices) certification for the duration of this contract. True = certification mandatory.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity per individual purchase order call-off against this contract. Expressed in the same unit of measure as volume_uom. Vendor may refuse orders below this threshold.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Agreed payment terms governing invoice settlement (e.g., \'Net 30\', \'2/10 Net 30\', \'Net 60 EOM\'). Drives AP payment scheduling in SAP FI and Oracle NetSuite AR.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether the contract contains penalty clauses for non-performance, late delivery, or quality failures. True = penalty clauses exist; False = no penalty provisions.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Narrative description of penalty provisions including trigger conditions, calculation method, and maximum liability cap (e.g., \'2% of PO value per week of delay, capped at 10%\'). Null if penalty_clause_flag is False.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentFormula rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Formula' ;
    rdfs:comment 'Text description or algebraic expression defining how the price is adjusted for formula-based or index-linked contracts (e.g., \'WASDE corn price + $0.15/BU basis\'). Null for fixed-price contracts.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Price Effective Date' ;
    rdfs:comment 'Date from which the contracted pricing terms (base_price, price_type) become effective. May differ from contract start_date if pricing is renegotiated mid-term.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Price Expiry Date' ;
    rdfs:comment 'Date on which the contracted pricing terms expire. After this date, new pricing must be negotiated or the contract reverts to spot pricing. Aligns with SAP MM condition validity end date.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Mechanism by which the contract price is determined. Fixed: locked price for the contract term; Formula-based: price derived from a calculation; WASDE-indexed: price tied to USDA World Agricultural Supply and Demand Estimates; Spot: prevailing market price at time of order; Cost-plus: vendor cost plus agreed margin.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedValue rdf:type rdf:Property ;
    rdfs:label 'Released Value' ;
    rdfs:comment 'Cumulative monetary value of all purchase orders (POs) released against this contract to date. Enables spend tracking against contract ceiling and open commitment reporting.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapOutlineAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Outline Agreement Number' ;
    rdfs:comment 'SAP S/4HANA MM module outline agreement document number (10-digit) serving as the system-of-record identifier for this contract. Used for integration with AP processing and GRN matching.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierThreshold1 rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold 1' ;
    rdfs:comment 'First volume breakpoint (in volume_uom) at which a tiered pricing discount or rebate is triggered. Orders exceeding this quantity qualify for the Tier 1 price adjustment.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThreshold2 rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold 2' ;
    rdfs:comment 'Second volume breakpoint (in volume_uom) at which a higher tiered pricing discount or rebate is triggered. Null if only one tier exists.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Vendor quotation evaluation is a formal procurement process requiring employee traceability for competitive bidding compliance. The existing \'evaluated_by\' plain-text column is a denormalized employee' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaAvailable rdf:type rdf:Property ;
    rdfs:label 'Coa Available' ;
    rdfs:comment 'Indicates whether the vendor has provided or confirmed availability of a Certificate of Analysis (COA) for the quoted input. COA documents quality parameters (e.g., NPK content for fertilizers, germination rate for seeds, AI concentration for crop protection). Required for QM inspection in SAP.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Named delivery point or destination for the quoted shipment (e.g., farm gate, warehouse code, port of entry). Relevant for FOB/CIF term interpretation and logistics cost calculation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount offered by the vendor on the quoted unit price (e.g., volume discount, early payment discount, seasonal promotion). Used in price comparison and contract negotiation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Vendor\'s estimated date of delivery to the specified delivery location based on the quoted lead time. Used for crop season scheduling, planting window alignment, and warehouse receiving planning.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date on which the procurement team completed the formal evaluation and comparison of this quotation against competing vendor quotes. Supports procurement cycle time KPI reporting.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrlComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the vendor has confirmed that the quoted crop protection chemical or input complies with applicable Maximum Residue Limits (MRL) as set by EPA, FDA, and Codex Alimentarius. Required for food safety and export market access.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotationDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Date' ;
    rdfs:comment 'The date on which the vendor issued and submitted this quotation. Represents the principal business event date for the quotation document.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Externally-known vendor-assigned quotation reference number as printed on the vendor\'s quotation document. Used for cross-referencing with vendor invoices, POs, and GRNs.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle state of the vendor quotation within the procurement workflow. Drives PO creation eligibility and contract negotiation actions. Values: received (quotation received from vendor), under_evaluation (being assessed by procurement team), accepted (selected for PO creation), rejected (not selected), expired (validity period lapsed).' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'The quantity of the agricultural input offered by the vendor at the quoted unit price. Represents the vendor\'s supply commitment for this quotation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'The vendor\'s quoted price per unit of measure for the agricultural input. Forms the basis for PO pricing, contract negotiation, and spend analytics. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the vendor quotation was received and recorded in the procurement system. Used for audit trail and RFQ response time analytics.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdsAvailable rdf:type rdf:Property ;
    rdfs:label 'Sds Available' ;
    rdfs:comment 'Indicates whether the vendor has provided or confirmed availability of a Safety Data Sheet (SDS) for the quoted chemical or biological input. Mandatory for OSHA HazCom compliance and EPA chemical handling requirements.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'Total value of the quotation calculated as quoted_unit_price multiplied by quoted_quantity. Used for spend analytics, budget comparison, and PO value authorization thresholds.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'Vendor\'s own internal reference or document number for this quotation, as provided by the supplier. Supports reconciliation with vendor-side records during PO and GRN matching.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaToxicityCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Toxicity Category' ;
    rdfs:comment 'The EPA acute toxicity category (I through IV) assigned to the agrochemical product based on oral, dermal, inhalation, and eye/skin irritation studies. Category I = most toxic (DANGER label); Category IV = least toxic. Drives PPE requirements, worker safety training, and medical surveillance programs.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Groundwater Advisory Flag' ;
    rdfs:comment 'Indicates whether the EPA-registered label includes a groundwater advisory statement, signaling potential for leaching into groundwater under certain soil and climatic conditions. True = groundwater advisory present; False = no advisory. Drives BMP (Best Management Practices) and buffer zone requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Label Approval Date' ;
    rdfs:comment 'The date on which the current version of the EPA-registered product label was approved. The label is the law under FIFRA — this date establishes the authoritative version for compliance purposes and triggers label update workflows when amendments are approved.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the company that physically manufactures or formulates the agrochemical product. May differ from the EPA registrant for generic or private-label products. Used for supplier management and procurement in SAP S/4HANA MM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxApplicationRate rdf:type rdf:Property ;
    rdfs:label 'Max Application Rate' ;
    rdfs:comment 'The maximum allowable application rate of the agrochemical product per application event as specified on the EPA-registered label. Used in conjunction with application_rate_unit to enforce label compliance and prevent over-application.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSeasonalApplications rdf:type rdf:Property ;
    rdfs:label 'Max Seasonal Applications' ;
    rdfs:comment 'The maximum number of times the agrochemical product may be applied per growing season per crop as specified on the EPA-registered label. Enforces resistance management and prevents MRL exceedances from cumulative applications.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modeOfActionCode rdf:type rdf:Property ;
    rdfs:label 'Mode Of Action Code' ;
    rdfs:comment 'The IRAC (Insecticide Resistance Action Committee), HRAC (Herbicide Resistance Action Committee), or FRAC (Fungicide Resistance Action Committee) mode of action classification code for the active ingredient. Critical for IPM resistance management rotation planning (e.g., HRAC Group 9 for glyphosate, FRAC Group 11 for strobilurins).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omriListedFlag rdf:type rdf:Property ;
    rdfs:label 'Omri Listed Flag' ;
    rdfs:comment 'Indicates whether the agrochemical product appears on the Organic Materials Review Institute (OMRI) Products List, confirming suitability for use in certified organic operations. True = OMRI listed; False = not listed. Complements organic_approved_flag with third-party verification.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Approved Flag' ;
    rdfs:comment 'Indicates whether the agrochemical product is approved for use in certified organic production systems under the USDA National Organic Program (NOP). True = approved for organic use; False = not approved. Drives product selection for organic-certified fields and NOP compliance documentation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'The quantity of agrochemical product contained in the standard commercial packaging unit (e.g., 2.5, 1.0, 5.0). Used in conjunction with package_unit for procurement, inventory management, and application rate calculations in SAP S/4HANA MM.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageUnit rdf:type rdf:Property ;
    rdfs:label 'Package Unit' ;
    rdfs:comment 'Unit of measure for the package size (e.g., gallon, liter, kg, lb). Combined with package_size to define the standard commercial unit for procurement, inventory, and cost tracking. [ENUM-REF-CANDIDATE: gallon|quart|pint|liter|kg|lb|oz|fl_oz|ton — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preHarvestIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Pre Harvest Interval Days' ;
    rdfs:comment 'The minimum number of days that must elapse between the last application of the agrochemical product and the harvest of the treated crop, as specified on the EPA-registered label. Critical for MRL compliance and food safety under FSMA and GLOBALG.A.P. requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Internal SKU or material number assigned in SAP S/4HANA MM to uniquely identify the agrochemical product within the enterprise ERP system. Used for procurement, inventory, and cost tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The registered commercial or trade name of the agrochemical product as it appears on the EPA-registered label and product packaging (e.g., \'Roundup PowerMAX\', \'Headline AMP Fungicide\').' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the agrochemical product in the master catalog. \'active\' = currently registered and available for use; \'discontinued\' = no longer manufactured or sold; \'suspended\' = EPA registration suspended pending review; \'pending_registration\' = awaiting EPA approval; \'cancelled\' = EPA registration voluntarily cancelled.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the agrochemical product by its primary mode of action or functional category. Drives regulatory compliance requirements, application protocols, and PHI/REI enforcement. [ENUM-REF-CANDIDATE: pesticide|herbicide|fungicide|insecticide|fertilizer|adjuvant|plant_growth_regulator|rodenticide|nematicide|fumigant — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantName rdf:type rdf:Property ;
    rdfs:label 'Registrant Name' ;
    rdfs:comment 'The name of the company or individual holding the EPA registration for the agrochemical product (e.g., \'Bayer CropScience\', \'Syngenta AG\', \'BASF Corporation\'). Used for regulatory correspondence, label verification, and supplier qualification.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resistanceGroup rdf:type rdf:Property ;
    rdfs:label 'Resistance Group' ;
    rdfs:comment 'The resistance management group designation (e.g., \'HRAC Group 9\', \'IRAC Group 4A\', \'FRAC Group 3\') used to plan chemical rotation programs and prevent development of resistant pest populations. Supports IPM compliance and GLOBALG.A.P. requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedEntryIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Restricted Entry Interval Hours' ;
    rdfs:comment 'The minimum number of hours that must pass after a pesticide application before workers may re-enter the treated area without personal protective equipment (PPE), as mandated by the EPA Worker Protection Standard (WPS). Required for OSHA and EPA compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sds Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the current Safety Data Sheet (SDS) for the agrochemical product, compliant with OSHA Hazard Communication Standard (HazCom 2012) and GHS format. Required for worker safety, emergency response, and regulatory compliance. Sourced from SAP S/4HANA QM document management.' ;
    rdfs:domain ind:AgrochemicalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'The guaranteed shelf life of the agrochemical product in months from the date of manufacture, as specified by the manufacturer. Used for inventory rotation (FIFO), expiry date tracking, and procurement planning in SAP S/4HANA MM and Manhattan Associates WMS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'The maximum storage temperature in degrees Celsius permitted for safe storage of the agrochemical product, as specified in the SDS and product label. Exceeding this threshold may cause product degradation, pressure buildup, or hazardous reactions. Used for WMS storage compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'The minimum storage temperature in degrees Celsius required to maintain product integrity and prevent degradation, as specified in the SDS and product label. Used for warehouse storage condition compliance in Manhattan Associates WMS.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'The United Nations (UN) four-digit identification number assigned to hazardous materials for international transport (e.g., \'UN1993\' for flammable liquids, \'UN2902\' for pesticides). Required on shipping documents, BOL, and placards for DOT and IATA compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Unique surrogate identifier for each bundle component association record within the agricultural product catalog. Primary key for this entity.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Reference to the parent bundle product (e.g., a seed+fertilizer+crop protection kit, or a livestock feed package) that contains this component. Links to the product catalog master record for the bundle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:primaryBundleSubstituteProductMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Bundle Substitute Product Master Id' ;
    rdfs:comment 'Reference to the approved substitute product that may replace this component when substitution_allowed_flag is True and the primary component is unavailable. Enables pre-approved substitution workflows in warehouse fulfillment and order management.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component product included in one unit of the parent bundle. Supports fractional quantities for bulk commodities (e.g., 2.5 kg of seed per bundle, 0.5 L of agrochemical per kit). Used for inventory reservation and fulfillment decomposition.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Numeric ordering position of this component within the bundle, used for display sequencing, picking order in warehouse fulfillment, and structured bill-of-materials presentation. Aligns with SAP BOM item number sequencing.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSku rdf:type rdf:Property ;
    rdfs:label 'Component Sku' ;
    rdfs:comment 'The Stock Keeping Unit (SKU) code for this component as it appears within the bundle context. May differ from the standalone product SKU when the component is packaged or sized differently for bundle inclusion (e.g., a smaller pack size of seed included in a starter kit bundle).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of this bundle component association: active (currently included in bundle), inactive (temporarily excluded), discontinued (permanently removed from bundle), or pending_approval (awaiting quality or regulatory review before activation).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component\'s role within the bundle: primary (core required component), optional (customer-selectable add-on), promotional (included for marketing purposes), sample (trial quantity), or freebie (complimentary item). Drives fulfillment logic and revenue recognition treatment.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentUom rdf:type rdf:Property ;
    rdfs:label 'Component Uom' ;
    rdfs:comment 'Unit of measure for the component quantity within the bundle (e.g., KG for kilograms, BU for bushels, L for liters, EA for each). Aligns with USDA commodity measurement standards and SAP base unit of measure configuration. [ENUM-REF-CANDIDATE: KG|LB|MT|CWT|BU|L|ML|EA|BAG|TON|OZ|GAL — promote to reference product]' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentVolumeL rdf:type rdf:Property ;
    rdfs:label 'Component Volume L' ;
    rdfs:comment 'The volume of this component in liters as included in the bundle, used for packaging dimension calculations, storage space planning, and container load optimization. Particularly relevant for liquid agrochemicals, fertilizer solutions, and liquid feed supplements.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Component Weight Kg' ;
    rdfs:comment 'The gross weight of this component in kilograms as included in the bundle, used for total bundle weight calculation, freight cost estimation, shipping label generation, and logistics planning. Aligns with SAP material master weight data.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentSplitFlag rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Split Flag' ;
    rdfs:comment 'Indicates whether this component may be fulfilled separately from other bundle components (True) or must be shipped together with all other components in a single shipment (False). Supports split-shipment scenarios for agricultural bundles where seed and agrochemicals may ship from different warehouses.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this component is classified as a hazardous material requiring special handling, storage, and shipping documentation (e.g., certain agrochemicals, pesticides, or fertilizers). Triggers HAZMAT compliance workflows in logistics and warehouse operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryReservationFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Reservation Flag' ;
    rdfs:comment 'Indicates whether inventory for this component should be reserved at the component level upon bundle order placement (True) or managed at the bundle level only (False). Drives Manhattan Associates WMS inventory reservation logic for component-level stock allocation.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this component is mandatory for the bundle to be valid and fulfillable. True = component must be present for bundle fulfillment; False = component is optional and may be excluded. Distinct from substitution_allowed_flag which governs product swaps rather than component inclusion.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Pricing Contribution Amount' ;
    rdfs:comment 'The monetary value attributed to this component within the overall bundle price, representing the component\'s share of the bundle\'s total selling price. Used for revenue allocation, cost-of-goods-sold (COGS) decomposition, and component-level profitability analysis.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingContributionCurrency rdf:type rdf:Property ;
    rdfs:label 'Pricing Contribution Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the component pricing contribution amount (e.g., USD, EUR, CAD). Supports multi-currency agricultural commodity trading and international supply chain operations.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingContributionPct rdf:type rdf:Property ;
    rdfs:label 'Pricing Contribution Pct' ;
    rdfs:comment 'The percentage of the total bundle price attributable to this component, expressed as a decimal percentage (e.g., 35.50 for 35.5%). Used alongside the absolute pricing contribution amount for proportional revenue recognition and margin analysis per component.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariableFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Variable Flag' ;
    rdfs:comment 'Indicates whether the component quantity within the bundle is fixed (False) or variable/customer-selectable (True) within the min/max quantity bounds. Supports configurable agricultural input bundles where farmers select quantities based on acreage or herd size.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCompatibilityCode rdf:type rdf:Property ;
    rdfs:label 'Storage Compatibility Code' ;
    rdfs:comment 'Code identifying the storage compatibility class of this component, used to ensure incompatible components within a bundle are not co-located in warehouse storage (e.g., separating oxidizers from flammables, or keeping seed away from agrochemicals). Aligns with EPA and OSHA storage segregation requirements.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether this component may be substituted with an alternative product during order fulfillment when the primary component is out of stock or unavailable. True = substitution permitted; False = component is mandatory and cannot be substituted. Supports Manhattan Associates WMS substitution logic.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedMaterialsListRef rdf:type rdf:Property ;
    rdfs:label 'Allowed Materials List Ref' ;
    rdfs:comment 'Reference identifier or document URL for the USDA NOP National List of Allowed and Prohibited Substances applicable to this organic certification scope. Ensures that only approved inputs are used in certified organic production.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMarkets rdf:type rdf:Property ;
    rdfs:label 'Approved Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes representing jurisdictions where this GMO transformation event or certification has received regulatory approval for commercial use or import (e.g., USA, CAN, BRA, CHN, EU member states). Critical for export documentation and market access decisions.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Cycle Months' ;
    rdfs:comment 'Frequency of the required audit or inspection cycle expressed in months (e.g., 12 for annual, 6 for semi-annual). Determines the recurrence interval for compliance audits under the certification program.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Be Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether the product is subject to USDA National Bioengineered Food Disclosure Standard (NBFDS) labeling requirements. True if the product contains detectable modified genetic material from the USDA BE disclosure list.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brcGrade rdf:type rdf:Property ;
    rdfs:label 'Brc Grade' ;
    rdfs:comment 'BRC Global Standard audit grade awarded at the most recent certification audit (AA, A, B, C, or D), where AA is the highest achievable grade for unannounced audits. Null if certification_type is not BRC.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Accreditation Number' ;
    rdfs:comment 'Accreditation number assigned to the certifying body by the relevant oversight authority (e.g., USDA NOP accreditation number for organic certifying agents, GFSI accreditation reference). Validates the legitimacy of the certifying organization.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyName rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Name' ;
    rdfs:comment 'Name of the accredited third-party organization or regulatory agency that issued the certification (e.g., Oregon Tilth, CCOF, NSF International, SGS, Bureau Veritas, Non-GMO Project, SQF Institute). Required for audit and export documentation.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairTradeProducerCode rdf:type rdf:Property ;
    rdfs:label 'Fair Trade Producer Code' ;
    rdfs:comment 'Unique producer or cooperative code assigned by Fair Trade USA or Fairtrade International to identify the certified producer organization associated with this product\'s fair trade certification.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertifyingBody rdf:type rdf:Property ;
    rdfs:label 'Halal Certifying Body' ;
    rdfs:comment 'Name of the recognized halal certifying organization (e.g., IFANCA, ISWA, HFA) that issued the halal certification for this product. Null if certification_type is not halal.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Ip Protocol Reference' ;
    rdfs:comment 'Reference code or document identifier for the Identity Preservation (IP) protocol applied to maintain non-GMO or specialty crop segregation integrity throughout the supply chain. Required for Non-GMO Project Verified and identity-preserved commodity programs.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kosherCertifyingAgency rdf:type rdf:Property ;
    rdfs:label 'Kosher Certifying Agency' ;
    rdfs:comment 'Name of the recognized kosher certifying agency (e.g., OU, OK, KOF-K, Star-K) that issued the kosher certification for this product. Null if certification_type is not kosher.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelClaimText rdf:type rdf:Property ;
    rdfs:label 'Label Claim Text' ;
    rdfs:comment 'Approved marketing claim text authorized by this certification for use on product packaging and retail labels (e.g., \'USDA Organic\', \'Non-GMO Project Verified\', \'Certified Kosher\', \'Fair Trade Certified\'). Must align with certifying body approved language.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date of the most recent laboratory testing, residue verification, or document review performed to confirm ongoing compliance with certification requirements (e.g., MRL residue testing for organic, identity preservation testing for non-GMO).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonGmoProjectVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Project Verified Flag' ;
    rdfs:comment 'Indicates whether the product has received Non-GMO Project Verified status, entitling it to display the Non-GMO Project butterfly seal on retail packaging. Supports non-GMO market access and premium pricing.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicTransitionFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Transition Flag' ;
    rdfs:comment 'Indicates whether the product is in the USDA NOP organic transition period (36-month land transition requirement) rather than fully certified organic. Transition products cannot be labeled or sold as certified organic.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the certifying body formally revoked the certification. Populated only when certification_status is \'revoked\'. Required for regulatory reporting and product recall risk management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sqfLevel rdf:type rdf:Property ;
    rdfs:label 'Sqf Level' ;
    rdfs:comment 'SQF certification level achieved: Level 1 (food safety fundamentals), Level 2 (HACCP-based food safety plan), or Level 3 (comprehensive food safety and quality management system). Null if certification_type is not SQF.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Transition Start Date' ;
    rdfs:comment 'Date on which the 36-month USDA NOP organic transition period began for the associated land or product. Null if organic_transition_flag is false. Used to calculate transition completion eligibility.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this commodity is classified as a major food allergen under FDA regulations (e.g., wheat, soybeans, peanuts, tree nuts, milk, eggs, fish, shellfish, sesame). Triggers allergen labeling and cross-contact prevention requirements.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Specific allergen classification when allergen_flag is True (e.g., \'gluten/wheat\', \'soy\', \'peanut\', \'tree nut\', \'milk\', \'egg\', \'fish\', \'shellfish\', \'sesame\'). Required for FDA-compliant allergen labeling and HACCP allergen control plans.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateUom rdf:type rdf:Property ;
    rdfs:label 'Alternate Uom' ;
    rdfs:comment 'Secondary unit of measure used for conversion, international trade, or customer-specific reporting (e.g., MT as alternate to BU for export contracts). Supports dual-unit inventory management in SAP MM. [ENUM-REF-CANDIDATE: BU|CWT|MT|LB|KG|TON|BBL|GAL|DOZ|HEAD|OTHER — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkPrice rdf:type rdf:Property ;
    rdfs:label 'Benchmark Price' ;
    rdfs:comment 'Reference benchmark price per standard unit of measure for this commodity, typically derived from the nearest futures contract or USDA AMS market report. Used for budget planning, contract pricing, and financial reporting. Expressed in USD.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Externally-known enterprise code uniquely identifying the commodity across operational systems (SAP MM material number, Granular Farm Management commodity code). Used for cross-system reconciliation and procurement referencing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Human-readable name of the agricultural commodity (e.g., \'Yellow Corn No. 2\', \'Hard Red Winter Wheat\', \'Soybeans\'). Used in reporting, labeling, and trade documentation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity record in the enterprise catalog. Active = currently traded/produced; Inactive = temporarily suspended; Discontinued = no longer produced or traded; Pending Approval = awaiting regulatory or internal approval for new commodity onboarding.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Required Flag' ;
    rdfs:comment 'Indicates whether Country of Origin Labeling (COOL) is mandatory for this commodity under USDA AMS regulations. True = COOL labeling required at retail (e.g., beef, pork, lamb, chicken, fish, fresh/frozen produce); False = exempt.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeMarket rdf:type rdf:Property ;
    rdfs:label 'Exchange Market' ;
    rdfs:comment 'Primary futures exchange where this commodity is traded (e.g., CBOT for grains, ICE for cotton and sugar). Determines which price feed and contract specifications apply for hedging and mark-to-market valuation. [ENUM-REF-CANDIDATE: CBOT|CME|ICE|NYMEX|KCBT|MGE|EURONEXT|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTicker rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticker' ;
    rdfs:comment 'Exchange ticker symbol for the commodity on futures markets (e.g., \'ZC\' for CBOT Corn, \'ZS\' for CBOT Soybeans, \'ZW\' for CBOT Wheat, \'CT\' for ICE Cotton). Used for market price benchmarking, hedging, and DTN/WASDE price feed integration.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCategory rdf:type rdf:Property ;
    rdfs:label 'Haccp Category' ;
    rdfs:comment 'HACCP food safety category classification for this commodity. Determines the applicable HACCP plan type and critical control point requirements for processing and handling. Aligns with GFSI, SQF, and BRC food safety management standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code used for international trade documentation, customs declarations, import/export compliance, and duty rate determination. Typically 6–10 digits per WCO standard.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentMaxPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Max Pct' ;
    rdfs:comment 'Maximum allowable moisture content percentage for this commodity at point of acceptance or storage. Exceeding this threshold triggers drying requirements or grade dockage. Critical for grain quality management per USDA GIPSA grading standards (e.g., corn ≤15.5%, soybeans ≤13%).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nopCategory rdf:type rdf:Property ;
    rdfs:label 'Nop Category' ;
    rdfs:comment 'USDA National Organic Program (NOP) classification for this commodity. Certified organic = fully compliant with 7 CFR Part 205; Transitional = in 3-year transition period; Conventional = standard production; Not applicable = non-crop commodity.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Eligible Flag' ;
    rdfs:comment 'Indicates whether this commodity is eligible for organic certification under the USDA National Organic Program (NOP). True = eligible for organic production and labeling; False = not eligible (e.g., synthetic inputs required). Drives segregation requirements in storage and logistics.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether the commodity is perishable and requires temperature-controlled storage or expedited handling. True = perishable (e.g., fresh produce, dairy, eggs); False = non-perishable (e.g., dry grains, cotton). Drives warehouse task prioritization in Manhattan Associates WMS.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the benchmark_price (e.g., USD, EUR, BRL). Supports multi-currency operations for international commodity trading and export contracts.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUom rdf:type rdf:Property ;
    rdfs:label 'Standard Uom' ;
    rdfs:comment 'Primary unit of measure used for trading, pricing, and inventory tracking of this commodity (e.g., BU = Bushel for grains, CWT = Hundredweight for livestock, MT = Metric Ton for export). Aligns with SAP MM base unit of measure and USDA reporting standards. [ENUM-REF-CANDIDATE: BU|CWT|MT|LB|KG|TON|BBL|GAL|DOZ|HEAD|OTHER — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWeightMinLbsBu rdf:type rdf:Property ;
    rdfs:label 'Test Weight Min Lbs Bu' ;
    rdfs:comment 'Minimum acceptable test weight in pounds per bushel for grade determination of this grain commodity (e.g., US No. 2 Yellow Corn = 54 lbs/bu). Used in USDA GIPSA official grading and price dockage calculations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalYieldPerAcre rdf:type rdf:Property ;
    rdfs:label 'Typical Yield Per Acre' ;
    rdfs:comment 'Reference average yield per acre for this commodity under standard production conditions, expressed in the standard_uom (e.g., 180 BU/acre for corn, 50 BU/acre for soybeans). Used as baseline for yield variance analysis, crop insurance, and USDA APH (Actual Production History) calculations.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uomConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Uom Conversion Factor' ;
    rdfs:comment 'Numeric factor to convert from standard_uom to alternate_uom (e.g., 1 BU corn = 0.0254 MT; factor = 0.0254). Essential for export documentation, international invoicing, and cross-system inventory reconciliation.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Usda Commodity Code' ;
    rdfs:comment 'Official USDA commodity code assigned by the Agricultural Marketing Service (AMS) or Farm Service Agency (FSA). Required for USDA program participation, federal reporting, and commodity loan eligibility determination.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaGradeStandard rdf:type rdf:Property ;
    rdfs:label 'Usda Grade Standard' ;
    rdfs:comment 'Reference to the applicable USDA grade standard designation for this commodity (e.g., \'US No. 1\', \'US No. 2\', \'US Extra Fancy\', \'USDA Choice\'). Determines quality thresholds, price premiums/discounts, and market eligibility. Linked to grading_standard reference product.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTraitEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Evaluation Id' ;
    rdfs:comment 'Foreign key linking to research.trait_evaluation. Business justification: GMO declarations for commercial products are supported by trait evaluation studies that generated the regulatory data package. APHIS petition submissions, FDA consultations, and EPA registrations requ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraitEvaluation .

ind:transformationEventId rdf:type rdf:Property ;
    rdfs:label 'Transformation Event Id' ;
    rdfs:comment 'Unique identifier for the specific genetic transformation event (e.g., MON810, GTS 40-3-2, Bt11). Assigned by the developer and referenced in APHIS regulatory petitions. Used for traceability in export documentation and market approval verification.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransformationEvent .

ind:aphisPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'Aphis Petition Number' ;
    rdfs:comment 'APHIS petition number associated with the deregulation or regulatory approval of the specific bioengineered trait or transformation event. Used to verify US market approval status and cross-reference APHIS regulatory records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beDisclosureType rdf:type rdf:Property ;
    rdfs:label 'Be Disclosure Type' ;
    rdfs:comment 'Method of BE food disclosure used on product labeling as required by USDA NBFDS. Options include on-package text, USDA BE symbol, electronic/digital link (QR code), or phone number. \'not_required\' when product is exempt.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chinaMarketApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'China Market Approved Flag' ;
    rdfs:comment 'Indicates whether this GMO transformation event has received regulatory approval for import or commercial use in China. Required for export documentation to Chinese buyers and compliance with MARA (Ministry of Agriculture and Rural Affairs) biosafety certificates.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the GMO declaration was formally submitted or issued. Represents the principal business event date for this record, distinct from system audit timestamps.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Externally-known unique business identifier for this GMO declaration record, used in regulatory submissions, export documentation, and audit trails. Follows internal numbering convention (e.g., GMO-2024-00123).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the GMO declaration record. Tracks the workflow from initial draft through regulatory review to approval, expiry, or withdrawal. [ENUM-REF-CANDIDATE: draft|pending_review|approved|rejected|expired|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredBy rdf:type rdf:Property ;
    rdfs:label 'Declared By' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for submitting this GMO declaration. Used for accountability, audit trail, and regulatory compliance documentation.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorOrganism rdf:type rdf:Property ;
    rdfs:label 'Donor Organism' ;
    rdfs:comment 'Scientific name of the organism from which the introduced genetic material was derived (e.g., \'Agrobacterium tumefaciens\', \'Bacillus thuringiensis\'). Required for regulatory submissions and export documentation.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euMarketApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Market Approved Flag' ;
    rdfs:comment 'Indicates whether this GMO transformation event has received regulatory approval for commercial use or import in the European Union. Critical for export compliance and trade documentation.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Gmo Threshold Percent' ;
    rdfs:comment 'Maximum allowable percentage of GMO material for the product to be classified as non-GMO or to meet the applicable regulatory threshold for the target market (e.g., 0.9% for EU, 5.0% for Japan). Drives compliance determination logic.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:introducedGene rdf:type rdf:Property ;
    rdfs:label 'Introduced Gene' ;
    rdfs:comment 'Name of the gene or genetic construct introduced into the organism (e.g., \'cp4 epsps\', \'cry1Ab\', \'bar\'). Used for scientific documentation, regulatory submissions, and export market approval cross-referencing.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:japanMarketApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Japan Market Approved Flag' ;
    rdfs:comment 'Indicates whether this GMO transformation event has received regulatory approval for import or commercial use in Japan. Required for export documentation to Japanese buyers under Japan\'s Food Safety Commission GMO approval framework.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonGmoCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Certificate Number' ;
    rdfs:comment 'Certificate or verification number issued by the non-GMO verification body. Used for audit trail, customer documentation, and regulatory compliance. Null when no third-party verification exists.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonGmoVerificationBody rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Verification Body' ;
    rdfs:comment 'Name of the third-party organization that verified and certified the non-GMO status of the product (e.g., Non-GMO Project, USDA Organic NOP). Applicable only when gmo_status is \'non_gmo\'. \'none\' indicates no third-party verification.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional notes, qualifications, or explanations related to the GMO declaration. May include details on testing anomalies, conditional approvals, or market-specific exceptions.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the quality assurance or regulatory compliance officer who reviewed and approved or rejected this GMO declaration. Required for audit trail and SOX compliance.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleLotNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Lot Number' ;
    rdfs:comment 'Lot or batch number of the product sample submitted for GMO testing. Enables traceability from the GMO declaration back to the specific production lot for recall management and audit purposes.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultPercent rdf:type rdf:Property ;
    rdfs:label 'Test Result Percent' ;
    rdfs:comment 'Quantitative result of GMO testing expressed as a percentage of GMO material detected in the sample (e.g., 0.0500 = 0.05%). Used to assess compliance against regulatory thresholds (e.g., EU 0.9% labeling threshold, Japan 5% threshold).' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited laboratory that performed GMO testing on the product. Must be an ISO 17025-accredited laboratory for regulatory acceptance of results.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethod rdf:type rdf:Property ;
    rdfs:label 'Testing Method' ;
    rdfs:comment 'Laboratory method used to test for the presence or absence of GMO material in the product (e.g., PCR - Polymerase Chain Reaction, ELISA - Enzyme-Linked Immunosorbent Assay). \'not_tested\' when no laboratory testing was performed.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Threshold Jurisdiction' ;
    rdfs:comment 'Jurisdiction or market for which the gmo_threshold_percent applies. Uses ISO 3166-1 alpha-3 country codes or \'global\' for internationally harmonized thresholds. Enables multi-market compliance management. [ENUM-REF-CANDIDATE: USA|EU|CHN|JPN|BRA|CAN|AUS|global — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traitDescription rdf:type rdf:Property ;
    rdfs:label 'Trait Description' ;
    rdfs:comment 'Descriptive name and functional summary of the introduced genetic trait (e.g., \'Herbicide tolerance - glyphosate\', \'Insect resistance - Bt Cry1Ab protein\', \'Drought tolerance - DREB transcription factor\'). Supports product labeling, COA documentation, and export market compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usMarketApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Us Market Approved Flag' ;
    rdfs:comment 'Indicates whether this GMO transformation event has received regulatory approval for commercial use in the United States market. Verified against APHIS deregulation status and FDA/EPA approvals.' ;
    rdfs:domain ind:GmoDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableMarketClass rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Class' ;
    rdfs:comment 'Market class or sub-class of the commodity to which this grading standard applies (e.g., \'Hard Red Winter\', \'Soft White\', \'Yellow Dent Corn\', \'Angus Beef\'). Provides finer commodity segmentation within the commodity type for accurate grade assignment.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Coa Template Reference' ;
    rdfs:comment 'Reference identifier for the COA document template associated with this grading standard. Used by quality inspection workflows in SAP QM to auto-populate COA documents upon grade assignment.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorRequirement rdf:type rdf:Property ;
    rdfs:label 'Color Requirement' ;
    rdfs:comment 'Descriptive color specification or color score range required for this grade designation (e.g., \'minimum 50% red color for US Extra Fancy apples\', \'bright yellow for US No. 1 corn\'). Applies primarily to produce and livestock grading per USDA AMS standards.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foreignMaterialMaxPct rdf:type rdf:Property ;
    rdfs:label 'Foreign Material Max Pct' ;
    rdfs:comment 'Maximum allowable percentage of foreign material (non-commodity matter) permitted for this grade designation. A standard GIPSA grading factor for grains, oilseeds, and other bulk commodities.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gfsiSchemeAlignment rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme Alignment' ;
    rdfs:comment 'Identifies the GFSI-recognized food safety scheme (e.g., SQF, BRC, IFS, GLOBALG.A.P., FSSC 22000) with which this grading standard is aligned or compatible. Supports customer audit and certification requirements.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoApplicability rdf:type rdf:Property ;
    rdfs:label 'Gmo Applicability' ;
    rdfs:comment 'Indicates whether this grading standard applies to GMO products, non-GMO products, or both. Supports product line segregation for non-GMO and conventional product lines per USDA and GLOBALG.A.P. requirements.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDesignation rdf:type rdf:Property ;
    rdfs:label 'Grade Designation' ;
    rdfs:comment 'Official grade label assigned by the administering agency (e.g., \'US No. 1\', \'US No. 2\', \'US Extra Fancy\', \'USDA Prime\', \'USDA Choice\', \'US Grade A\'). Represents the quality tier within the standard. [ENUM-REF-CANDIDATE: US No. 1|US No. 2|US No. 3|US Extra Fancy|USDA Prime|USDA Choice|USDA Select|US Grade A|US Grade B|US Grade C — promote to reference product]' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingMethod rdf:type rdf:Property ;
    rdfs:label 'Grading Method' ;
    rdfs:comment 'Primary method used to assess and assign this grade (e.g., visual inspection, mechanical sizing, laboratory analysis, electronic/NIR sensing, or a combination). Determines inspection workflow and equipment requirements in SAP QM and field operations.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Required frequency of grading inspections for commodities subject to this standard (e.g., per lot, per shipment, per batch, periodic, continuous). Drives quality inspection scheduling in SAP QM and Manhattan WMS workflows.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlThresholdPpm rdf:type rdf:Property ;
    rdfs:label 'Mrl Threshold Ppm' ;
    rdfs:comment 'Maximum Residue Limit (MRL) threshold in parts per million (ppm) for pesticide or chemical residues applicable to this grading standard. Compliance with MRL is required for grade certification and export eligibility per EPA and Codex Alimentarius standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seriousDefectsMaxPct rdf:type rdf:Property ;
    rdfs:label 'Serious Defects Max Pct' ;
    rdfs:comment 'Maximum allowable percentage of serious defects (e.g., heat-damaged kernels, mold, insect damage) permitted for this grade. Serious defects are a distinct sub-category of total defects with stricter tolerance limits per GIPSA standards.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Size Requirement' ;
    rdfs:comment 'Size specification or size range required for this grade designation (e.g., minimum diameter in mm, weight per unit, count per carton). Applies to produce, eggs, and livestock products per USDA AMS grading standards.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the grading standard (e.g., \'USDA-GR1-CORN\', \'AMS-EF-APPLE\'). Used as the business key for cross-system reference and COA generation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Standard Document Url' ;
    rdfs:comment 'URL link to the official published grading standard document on the administering agency\'s website (e.g., USDA AMS, GIPSA). Provides direct access to the authoritative source document for quality inspectors and compliance teams.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardStatus rdf:type rdf:Property ;
    rdfs:label 'Standard Status' ;
    rdfs:comment 'Current lifecycle status of the grading standard. \'active\' indicates the standard is currently in force; \'superseded\' indicates replaced by a newer version; \'withdrawn\' indicates no longer applicable; \'draft\' or \'pending\' indicates under review or awaiting official publication.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code' ;
    rdfs:comment 'Standard code of the newer grading standard that replaces this record when status is \'superseded\'. Enables forward navigation in the version chain for compliance and historical reporting.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDefectsMaxPct rdf:type rdf:Property ;
    rdfs:label 'Total Defects Max Pct' ;
    rdfs:comment 'Maximum allowable percentage of total defects (damaged kernels, heat damage, broken kernels, etc.) permitted for this grade designation. Applies to grain, oilseed, and produce grading per GIPSA and AMS standards.' ;
    rdfs:domain ind:GradingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minApplicationRate rdf:type rdf:Property ;
    rdfs:label 'Min Application Rate' ;
    rdfs:comment 'The minimum label-specified application rate for this input product per unit area or per unit of crop. Used in conjunction with application_rate_unit to define the lower bound of the label rate range for VRA prescription generation and compliance auditing.' ;
    rdfs:domain ind:InputProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelId rdf:type rdf:Property ;
    rdfs:label 'Label Id' ;
    rdfs:comment 'Unique system-generated identifier for each label record in the agricultural product labeling catalog. Primary key for the label data product.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergenCrossContactRisk rdf:type rdf:Property ;
    rdfs:label 'Allergen Cross Contact Risk' ;
    rdfs:comment 'Assessed risk level for unintentional allergen cross-contact during production, handling, or packaging. Drives \'may contain\' advisory statement decisions and HACCP allergen control plan requirements.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMilkFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Milk Flag' ;
    rdfs:comment 'Indicates whether milk (FDA Big 9 allergen) is intentionally included as an ingredient in this product. When True, milk must be declared in the ingredient list and allergen statement per FALCPA.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSoyFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Soy Flag' ;
    rdfs:comment 'Indicates whether soybeans (FDA Big 9 allergen) are intentionally included as an ingredient. Particularly relevant in agricultural products given soy\'s prevalence in processed and feed products.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenWheatFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Wheat Flag' ;
    rdfs:comment 'Indicates whether wheat (FDA Big 9 allergen) is intentionally included as an ingredient. When True, wheat must be declared in the ingredient list and allergen statement per FALCPA.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or market identifiers for which this label version is approved and valid (e.g., \'USA,CAN,MEX\'). Supports multi-market label management and export compliance.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkFileReference rdf:type rdf:Property ;
    rdfs:label 'Artwork File Reference' ;
    rdfs:comment 'File path, document management system reference, or URI pointing to the approved label artwork file (e.g., PDF, AI, EPS). Supports label artwork version control and print production workflows.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caloriesPerServing rdf:type rdf:Property ;
    rdfs:label 'Calories Per Serving' ;
    rdfs:comment 'Total caloric value per serving as declared on the Nutrition Facts panel, expressed in kilocalories (kcal). Calculated from macronutrient composition per FDA rounding rules.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coolDesignation rdf:type rdf:Property ;
    rdfs:label 'Cool Designation' ;
    rdfs:comment 'Country of origin declaration required under COOL (Country of Origin Labeling) regulations. Specifies the country or countries where the product was produced, grown, or processed. Uses ISO 3166-1 alpha-3 country codes (e.g., \'USA\', \'MEX\', \'CAN\').' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpAllergenControlPlanRef rdf:type rdf:Property ;
    rdfs:label 'Haccp Allergen Control Plan Ref' ;
    rdfs:comment 'Reference identifier for the HACCP allergen control plan document governing allergen management for this product label. Links label allergen declarations to the facility\'s preventive controls documentation.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientStatement rdf:type rdf:Property ;
    rdfs:label 'Ingredient Statement' ;
    rdfs:comment 'Full ingredient list as it appears on the label, listed in descending order of predominance by weight. Must comply with FDA 21 CFR Part 101.4 ingredient declaration requirements.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCode rdf:type rdf:Property ;
    rdfs:label 'Label Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this label version, used for cross-referencing with SAP QM label management and regulatory submission tracking.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelName rdf:type rdf:Property ;
    rdfs:label 'Label Name' ;
    rdfs:comment 'Human-readable descriptive name of the label, typically reflecting the product name, market, and version (e.g., \'Organic Whole Wheat Flour — US Retail v3\').' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelStatus rdf:type rdf:Property ;
    rdfs:label 'Label Status' ;
    rdfs:comment 'Current lifecycle state of the label record. Tracks progression from draft through regulatory approval to active use, supersession by a newer version, or withdrawal from market.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Classification of the label by its intended commercial use channel: retail consumer packaging, foodservice bulk, export market, private label, or ingredient/intermediate product.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Flag' ;
    rdfs:comment 'Indicates whether this label\'s associated product has been verified to comply with applicable Maximum Residue Limit (MRL) thresholds for pesticide and agrochemical residues as set by EPA, Codex Alimentarius, or destination market regulators.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightDeclaration rdf:type rdf:Property ;
    rdfs:label 'Net Weight Declaration' ;
    rdfs:comment 'Mandatory net weight or net quantity statement as it appears on the label (e.g., \'5 LB (2.27 kg)\', \'16 FL OZ (473 mL)\'). Must comply with NIST Handbook 133 and FDA net quantity of contents regulations.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonGmoClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Claim Flag' ;
    rdfs:comment 'Indicates whether this label carries a non-GMO (Genetically Modified Organism) claim. When True, supporting documentation and supply chain traceability records must be maintained per USDA BE Disclosure Standard.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nutritionAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Nutrition Analysis Method' ;
    rdfs:comment 'Method used to determine the nutrition facts panel values: laboratory analysis (wet chemistry), nutrient database calculation (USDA FoodData Central), recipe calculation, or a combination. Affects accuracy and regulatory defensibility.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicSealAuthorized rdf:type rdf:Property ;
    rdfs:label 'Organic Seal Authorized' ;
    rdfs:comment 'Indicates whether this label is authorized to display the USDA Organic seal under the National Organic Program (NOP). True only when the product and operation hold valid NOP certification.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proteinG rdf:type rdf:Property ;
    rdfs:label 'Protein G' ;
    rdfs:comment 'Protein content per serving in grams as declared on the Nutrition Facts panel. Mandatory declaration on FDA Nutrition Facts label.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Official reference number or tracking code issued by the regulatory authority (e.g., USDA AMS label approval number, FDA submission reference) confirming this label has been reviewed and authorized.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Serving Size Description' ;
    rdfs:comment 'Serving size as declared on the Nutrition Facts panel (e.g., \'1 cup (240g)\', \'2 tablespoons (32g)\'). Must align with FDA Reference Amounts Customarily Consumed (RACC) for the product category.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingsPerContainer rdf:type rdf:Property ;
    rdfs:label 'Servings Per Container' ;
    rdfs:comment 'Number of servings per container as declared on the Nutrition Facts panel. May be a whole number or decimal (e.g., 2.5 servings). Required for FDA-compliant Nutrition Facts labeling.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Mg' ;
    rdfs:comment 'Sodium content per serving in milligrams as declared on the Nutrition Facts panel. Key nutrient for dietary guidance and FDA mandatory declaration.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateG rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate G' ;
    rdfs:comment 'Total carbohydrate content per serving in grams as declared on the Nutrition Facts panel, including dietary fiber and total sugars.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatG rdf:type rdf:Property ;
    rdfs:label 'Total Fat G' ;
    rdfs:comment 'Total fat content per serving in grams as declared on the Nutrition Facts panel. Includes saturated fat, trans fat, polyunsaturated fat, and monounsaturated fat.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaAmsApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Usda Ams Approval Status' ;
    rdfs:comment 'Status of the label submission and approval with the USDA Agricultural Marketing Service (AMS), required for meat, poultry, and egg products. Tracks submission through final approval or rejection.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaGradeShieldFlag rdf:type rdf:Property ;
    rdfs:label 'Usda Grade Shield Flag' ;
    rdfs:comment 'Indicates whether this label is authorized to display a USDA grade shield (e.g., USDA Grade A, USDA Choice). Requires grading certificate from USDA AMS grading service.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingRequirementDays rdf:type rdf:Property ;
    rdfs:label 'Aging Requirement Days' ;
    rdfs:comment 'Minimum number of days the product must be aged (dry-aged or wet-aged) before it is eligible for sale or distribution. Applicable primarily to beef and certain cheese products. Drives inventory hold logic and release scheduling in WMS.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breedSource rdf:type rdf:Property ;
    rdfs:label 'Breed Source' ;
    rdfs:comment 'The breed or genetic lineage of the source animal (e.g., \'Angus\', \'Hereford\', \'Holstein\', \'Duroc\', \'Merino\'). Relevant for premium product differentiation, breed-specific marketing claims, and traceability back to source herd. Aligns with USDA AMS breed verification programs.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Temp Max C' ;
    rdfs:comment 'Maximum allowable storage and transport temperature in degrees Celsius. Exceeding this threshold triggers a cold chain deviation event and potential product hold. Used in conjunction with cold_chain_temp_min_c to define the safe temperature corridor.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainTempMinC rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Temp Min C' ;
    rdfs:comment 'Minimum allowable storage and transport temperature in degrees Celsius for maintaining product safety and quality. Used to configure cold chain monitoring alerts, TMS temperature requirements, and warehouse zone assignments. Critical for HACCP CCP compliance.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOriginLabel rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Label' ;
    rdfs:comment 'The full COOL (Country of Origin Labeling) declaration text as it appears on the product label (e.g., \'Product of USA\', \'Product of USA and Canada\'). Distinct from cool_country_of_origin (ISO code); this field stores the exact label-compliant text required by USDA AMS COOL regulations for multi-origin products.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutDescription rdf:type rdf:Property ;
    rdfs:label 'Cut Description' ;
    rdfs:comment 'Detailed description of the specific meat cut, dairy product variant, or product form (e.g., \'Bone-In Ribeye Steak 1-inch\', \'Whole Milk Pasteurized Homogenized\', \'Grade AA Large White Eggs 12-count\'). Provides the precise product specification for procurement, labeling, and customer order fulfillment.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatContentPercent rdf:type rdf:Property ;
    rdfs:label 'Fat Content Percent' ;
    rdfs:comment 'Fat content of the product expressed as a percentage by weight. Applicable to meat (lean-to-fat ratio), dairy (butterfat percentage for milk and cheese), and processed products. Used for nutritional labeling compliance, grading, and product specification matching.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsisEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fsis Establishment Number' ;
    rdfs:comment 'Official FSIS-assigned establishment number for the slaughter or processing facility where the product was inspected and passed. Required on all FSIS-inspected product labels and COA documents. Enables traceability to the inspected facility.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsisInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Fsis Inspection Status' ;
    rdfs:comment 'Current FSIS ante-mortem and post-mortem inspection status for the livestock product. \'passed\' indicates the product has received FSIS mark of inspection and is cleared for commerce; \'failed\' indicates condemned product; \'conditional\' requires further evaluation; \'pending\' awaits inspection; \'exempt\' applies to products not subject to mandatory FSIS inspection.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether the product holds a valid Halal certification from an accredited certifying body. True = Halal certified; False = not certified. Drives market eligibility for Halal-compliant customers and export markets requiring Halal documentation.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hormoneFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Hormone Free Flag' ;
    rdfs:comment 'Indicates whether the product carries a verified \'No Added Hormones\' or hormone-free label claim. True = hormone-free claim verified; False = no such claim. Applicable primarily to beef and dairy products. Requires FSIS label approval.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether the product holds a valid Kosher certification from an accredited certifying body. True = Kosher certified; False = not certified. Drives market eligibility for Kosher-compliant customers and retail channels requiring Kosher documentation.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'The packaging format applied to the livestock product (e.g., vacuum_packed, modified_atmosphere, fresh_tray, bulk, frozen, cryovac, carton). Determines shelf life, cold chain requirements, and handling instructions. Used in WMS for storage zone assignment and order picking configuration. [ENUM-REF-CANDIDATE: vacuum_packed|modified_atmosphere|fresh_tray|bulk|frozen|cryovac|carton — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'The date on which the product underwent primary processing (cutting, deboning, pasteurization, packaging). Distinct from slaughter_date; used for shelf-life calculation, lot traceability, and HACCP critical control point documentation.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaughterDate rdf:type rdf:Property ;
    rdfs:label 'Slaughter Date' ;
    rdfs:comment 'The date on which the source animal was slaughtered or, for dairy/egg products, the date of primary processing/collection. Critical for shelf-life calculation, aging period tracking, cold chain compliance, and FSIS traceability requirements.' ;
    rdfs:domain ind:LivestockProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeIngredientCasNumber rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Cas Number' ;
    rdfs:comment 'CAS Registry Number uniquely identifying the pesticide active ingredient chemical substance. Enables unambiguous cross-referencing across regulatory databases and SDS documentation.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalMethodReference rdf:type rdf:Property ;
    rdfs:label 'Analytical Method Reference' ;
    rdfs:comment 'Reference to the validated analytical method (e.g., AOAC, EN, EPA method number) used for laboratory detection and quantification of the residue to verify compliance with this MRL. Supports COA and laboratory accreditation alignment.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codexReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Codex Reference Number' ;
    rdfs:comment 'Official Codex Alimentarius MRL reference number (CXL number) for this tolerance, enabling direct cross-reference to the Codex MRL database. Used for international trade documentation and export COA verification.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGroup rdf:type rdf:Property ;
    rdfs:label 'Commodity Group' ;
    rdfs:comment 'Broader commodity group classification under which the specific commodity falls (e.g., cereal grains, fruiting vegetables, root and tuber vegetables, meat and poultry). Supports group tolerance application per EPA and Codex rules.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityPart rdf:type rdf:Property ;
    rdfs:label 'Commodity Part' ;
    rdfs:comment 'Specific part of the commodity to which the MRL applies (e.g., whole commodity, edible portion only, peel, grain, muscle tissue, fat, liver, milk, eggs). Relevant for processed commodity tolerances and animal product MRLs. [ENUM-REF-CANDIDATE: whole_commodity|edible_portion|peel|seed|grain|muscle|fat|liver|kidney|milk|eggs — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultMrlFlag rdf:type rdf:Property ;
    rdfs:label 'Default Mrl Flag' ;
    rdfs:comment 'Indicates whether this MRL is a default/general tolerance applied in the absence of a specific established tolerance (e.g., Codex default of 0.01 ppm, EU default of 0.01 ppm under Regulation EC 396/2005). True = default MRL applies; False = specific established tolerance.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Regulatory justification for a tolerance exemption, applicable when tolerance_type is \'exemption\'. Describes why the active ingredient is exempt from MRL requirements (e.g., naturally occurring substance, minimal risk, biochemical pesticide). Null for non-exemption tolerance types.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Applicability Flag' ;
    rdfs:comment 'Indicates whether this MRL tolerance specifically applies to or was established in the context of GMO crop varieties (e.g., herbicide-tolerant GMO crops with higher herbicide residue tolerances). True = GMO-specific tolerance; False = applies to conventional and GMO equally.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Import Tolerance Flag' ;
    rdfs:comment 'Indicates whether this MRL was established specifically as an import tolerance to facilitate trade for commodities treated with a pesticide not registered domestically. True = import tolerance; False = domestic tolerance. Relevant for FOB/CIF export documentation.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the importing or regulating country associated with this MRL. Used for export eligibility checks and Country of Origin Labeling (COOL) compliance. Null for multi-country jurisdictions (e.g., EU, Codex).' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitOfQuantificationPpm rdf:type rdf:Property ;
    rdfs:label 'Limit Of Quantification Ppm' ;
    rdfs:comment 'Lowest concentration of the active ingredient residue that can be reliably quantified by the validated analytical method. Used to determine whether a non-detect result constitutes MRL compliance, particularly for default MRL tolerances.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrlValuePpm rdf:type rdf:Property ;
    rdfs:label 'Mrl Value Ppm' ;
    rdfs:comment 'The established maximum residue limit expressed in parts per million (ppm, equivalent to mg/kg) for the active ingredient on the specified commodity. Core compliance threshold used for COA verification, pre-harvest interval enforcement, and export eligibility determination.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingFactor rdf:type rdf:Property ;
    rdfs:label 'Processing Factor' ;
    rdfs:comment 'Ratio of residue concentration in the processed commodity to residue concentration in the raw agricultural commodity (RAC). Used to calculate MRL compliance for processed food products derived from the raw commodity. Values >1 indicate concentration; values <1 indicate reduction.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The regulatory authority or jurisdiction that established this MRL (e.g., US_EPA for United States Environmental Protection Agency, EU for European Union Regulation EC 396/2005, CODEX for Codex Alimentarius Commission). Critical for export documentation and multi-market compliance. [ENUM-REF-CANDIDATE: US_EPA|EU|CODEX|CANADA|JAPAN|AUSTRALIA|CHINA|BRAZIL|MEXICO|KOREA|INDIA|TAIWAN — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueDefinition rdf:type rdf:Property ;
    rdfs:label 'Residue Definition' ;
    rdfs:comment 'Regulatory definition of what constitutes the measurable residue for enforcement purposes, including parent compound and relevant metabolites or degradation products. Critical for laboratory COA analysis method alignment.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Native record identifier from the originating regulatory database (e.g., EPA tolerance petition number, Codex CXL reference, EU database entry ID). Enables traceability back to the authoritative source system for audit and refresh purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceStatus rdf:type rdf:Property ;
    rdfs:label 'Tolerance Status' ;
    rdfs:comment 'Current lifecycle status of the MRL tolerance record: \'active\' for currently enforceable tolerances, \'revoked\' for cancelled tolerances, \'expired\' for time-limited tolerances past their expiry date, \'pending\' for proposed tolerances under regulatory review, \'suspended\' for temporarily suspended tolerances.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceType rdf:type rdf:Property ;
    rdfs:label 'Tolerance Type' ;
    rdfs:comment 'Classification of the MRL tolerance type: \'established\' for standard EPA/Codex tolerances, \'exemption\' for active ingredients exempt from tolerance requirements, \'import_tolerance\' for tolerances set specifically for imported commodities, \'emergency_exemption\' for Section 18 emergency use tolerances, \'group_tolerance\' for tolerances covering a commodity group.' ;
    rdfs:domain ind:MrlThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineId rdf:type rdf:Property ;
    rdfs:label 'Product Line Id' ;
    rdfs:comment 'Reference to the product line covered under this organic certification when the certificate applies to a group of related products rather than a single SKU. Supports organic certification at the product family level.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductLine .

ind:allowedMaterialsListReference rdf:type rdf:Property ;
    rdfs:label 'Allowed Materials List Reference' ;
    rdfs:comment 'Document reference or identifier for the approved materials list associated with this certification. Lists all inputs (fertilizers, pesticides, processing aids) approved for use under the certified organic system plan, cross-referenced against the USDA National List of Allowed and Prohibited Substances.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL pointing to the scanned or digital copy of the official organic certificate issued by the certifying agent. Supports audit trail, labeling compliance verification, and customer COA (Certificate of Analysis) requests.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAcreage rdf:type rdf:Property ;
    rdfs:label 'Certified Acreage' ;
    rdfs:comment 'Total land area in acres covered under this organic certification. Represents the certified organic production footprint and is used for yield planning, premium pricing calculations, and regulatory reporting to USDA.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifyingAgentCode rdf:type rdf:Property ;
    rdfs:label 'Certifying Agent Code' ;
    rdfs:comment 'The official USDA-assigned accreditation code or identifier for the certifying agent. Used for regulatory cross-referencing with USDA AMS accreditation records and electronic filing systems.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Compliant Flag' ;
    rdfs:comment 'Indicates whether the organic certification record supports Country of Origin Labeling (COOL) compliance requirements. COOL mandates disclosure of the country of origin for covered commodities at retail, and organic products must meet both NOP and COOL labeling requirements.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalencyStandard rdf:type rdf:Property ;
    rdfs:label 'Equivalency Standard' ;
    rdfs:comment 'Identifies the specific international organic standard or equivalency arrangement recognized by this certification (e.g., EU Organic, Canada Organic, Japan JAS Organic, IFOAM). Populated only when international_equivalency_flag is True.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliant Flag' ;
    rdfs:comment 'Indicates whether the certified organic operation is also compliant with applicable Food Safety Modernization Act (FSMA) rules, including the Produce Safety Rule and Preventive Controls for Human Food. Organic certification does not automatically confer FSMA compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Free Flag' ;
    rdfs:comment 'Indicates whether the certified operation and its products are verified as free from Genetically Modified Organisms (GMOs). USDA NOP prohibits the use of excluded methods including genetic engineering; this flag confirms GMO-free status as part of organic compliance.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalEquivalencyFlag rdf:type rdf:Property ;
    rdfs:label 'International Equivalency Flag' ;
    rdfs:comment 'Indicates whether this certification is recognized under an international organic equivalency arrangement (e.g., USDA-EU Organic Equivalency Agreement, USDA-Canada Organic Equivalency Arrangement). Enables certified organic products to be sold as organic in partner countries without additional certification.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Scheduled date for the next on-site inspection by the certifying agent. Used for compliance planning and operational readiness to ensure the operation is prepared for the annual NOP inspection.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nopSystemPlanReference rdf:type rdf:Property ;
    rdfs:label 'Nop System Plan Reference' ;
    rdfs:comment 'Document reference number or identifier for the Organic System Plan (OSP) submitted to and approved by the certifying agent. The OSP is the foundational compliance document describing all practices, materials, and monitoring activities for the certified operation.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationName rdf:type rdf:Property ;
    rdfs:label 'Operation Name' ;
    rdfs:comment 'The legal name of the certified organic operation (farm, ranch, or handling facility) as it appears on the organic certificate. This is the entity name recognized by the certifying agent and USDA NOP for compliance purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicLabelType rdf:type rdf:Property ;
    rdfs:label 'Organic Label Type' ;
    rdfs:comment 'The USDA NOP-defined organic labeling category authorized for products under this certification. 100_percent_organic: all ingredients are certified organic. Organic: at least 95% certified organic ingredients. Made_with_organic: 70-95% certified organic ingredients. Organic_ingredients: less than 70% organic, may list specific organic ingredients. Determines permissible label claims and USDA Organic Seal usage.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPricingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Pricing Eligible Flag' ;
    rdfs:comment 'Indicates whether products covered by this certification are currently eligible for organic premium pricing in sales and distribution channels. Eligibility requires active certification status and valid organic label type authorization.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Narrative description of the reason for permanent revocation of the organic certification. Documents the specific violation or fraudulent activity that resulted in the certifying agent revoking the certificate.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Transition Complete Flag' ;
    rdfs:comment 'Indicates whether the mandatory 36-month organic transition period has been completed for the land or operation covered by this certification. True indicates the operation has fulfilled the transition requirement and is eligible for full organic certification.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processedGoodId rdf:type rdf:Property ;
    rdfs:label 'Processed Good Id' ;
    rdfs:comment 'Unique surrogate identifier for each processed or value-added agricultural good in the master catalog. Primary key for the processed_good data product.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessedGood .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Structured declaration of major food allergens present in or potentially cross-contaminated in this processed good, as required by FDA FALCPA. Includes the 9 major allergens: milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomReference rdf:type rdf:Property ;
    rdfs:label 'Bom Reference' ;
    rdfs:comment 'Reference identifier linking this processed good to its Bill of Materials (BOM) in SAP S/4HANA PP module. The BOM defines the raw material inputs, quantities, and assembly instructions required for production.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesPerPallet rdf:type rdf:Property ;
    rdfs:label 'Cases Per Pallet' ;
    rdfs:comment 'Standard number of trade cases stacked per pallet for this processed good. Drives warehouse slotting, transportation load planning, and freight cost calculation.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaPreventiveControlsFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Preventive Controls Flag' ;
    rdfs:comment 'Indicates whether this processed good is subject to FSMA Preventive Controls for Human Food requirements (21 CFR Part 117). When true, a written food safety plan with hazard analysis and preventive controls must be maintained.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the production process for this processed good has been validated as compliant with Good Manufacturing Practices (GMP) as defined under FDA 21 CFR Part 110/117. Required for food safety certification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpPlanReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Reference' ;
    rdfs:comment 'Document reference identifier for the HACCP (Hazard Analysis and Critical Control Points) plan governing the production of this processed good. Required for FSMA compliance and GFSI certification audits.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentUnit rdf:type rdf:Property ;
    rdfs:label 'Net Content Unit' ;
    rdfs:comment 'Unit of measure for the net content value (e.g., kg, g, lb, oz, L, mL, MT, CWT, BU). Aligns with SAP S/4HANA base unit of measure and USDA standard units for agricultural commodities. [ENUM-REF-CANDIDATE: kg|g|lb|oz|L|mL|MT|CWT|BU — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'Numeric net content quantity of the processed good per consumer unit (e.g., 25.000 for a 25 kg bag of flour, 0.400 for a 400 g can). Used for labeling compliance and unit-of-measure conversions.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nopCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Nop Certificate Number' ;
    rdfs:comment 'USDA National Organic Program (NOP) certificate number issued by the accredited certifying agent. Required on organic product labels and for audit trail compliance. Null if organic_certified_flag is false.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalProfileReference rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile Reference' ;
    rdfs:comment 'Reference identifier linking to the detailed nutritional facts panel data for this processed good, including calories, macronutrients, vitamins, and minerals. Required for FDA Nutrition Facts Label compliance.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingMethod rdf:type rdf:Property ;
    rdfs:label 'Processing Method' ;
    rdfs:comment 'Primary industrial processing method applied to transform raw agricultural inputs into the finished good. Informs GMP compliance requirements, HACCP plan selection, and energy/resource planning. [ENUM-REF-CANDIDATE: milling|pressing|canning|freezing|drying|pelleting|pasteurization|fermentation|extrusion|blending — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Commercial product line classification indicating the market positioning of the processed good. Supports organic, non-GMO, conventional, premium, private label, and commodity product line management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard production cost per unit of the processed good as maintained in SAP S/4HANA CO (Controlling) module. Used for COGS (Cost of Goods Sold) calculation, variance analysis, and financial reporting under GAAP/IFRS.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditionType rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Type' ;
    rdfs:comment 'Categorical storage condition requirement for the processed good. Drives warehouse zone assignment in Manhattan Associates WMS and cold chain logistics planning in TMS.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerCase rdf:type rdf:Property ;
    rdfs:label 'Units Per Case' ;
    rdfs:comment 'Number of individual consumer units packed per trade case. Used for order quantity conversion, warehouse pick planning in Manhattan Associates WMS, and sales order entry in SAP S/4HANA SD.' ;
    rdfs:domain ind:ProcessedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'Calendar date after which the bundle is no longer available for new sales orders. Null indicates open-ended availability. Critical for seasonal programs aligned with planting windows and PHI compliance cutoffs.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'Calendar date from which the bundle becomes available for sales order entry. Used for seasonal crop input programs (e.g., spring planting packages available from January 1) and promotional bundle windows.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bundleCategory rdf:type rdf:Property ;
    rdfs:label 'Bundle Category' ;
    rdfs:comment 'Agricultural domain classification of the bundle grouping: e.g., \'seed_crop_protection\' (seed + IPM program), \'fertilizer_seed\' (NPK starter + seed treatment), \'feed_supplement\' (livestock feed + nutritional supplement ration), \'commodity_logistics\' (grain commodity + BOL/freight service). Supports product hierarchy analytics and dealer program reporting. [ENUM-REF-CANDIDATE: seed_crop_protection|seed_treatment|fertilizer_seed|feed_supplement|commodity_logistics|input_program|custom_application — promote to reference product]' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the bundle in commercial catalogs, dealer agreements, and ERP sales order entry. Aligns with SAP S/4HANA material number for bundle materials.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed commercial description of the bundle including agronomic purpose, target crop or livestock species, key benefits, and program highlights. Used in dealer catalogs, Salesforce CRM opportunity management, and customer-facing marketing materials.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable commercial name of the product bundle as presented to dealers, distributors, and customers (e.g., \'Spring Corn Starter Program\', \'Beef Cattle Feed + Supplement Ration Pack\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle state of the bundle offering: \'draft\' (under development, not yet available for sale), \'active\' (available for order entry), \'discontinued\' (no longer offered, existing orders honored), \'seasonal\' (available only within defined availability window), \'suspended\' (temporarily unavailable due to supply or compliance hold).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure: \'fixed\' (pre-defined components, no substitution), \'configurable\' (customer selects from allowed components), \'promotional\' (time-limited marketing bundle), \'subscription\' (recurring delivery program), \'financing\' (crop input financing package with deferred payment). [ENUM-REF-CANDIDATE: fixed|configurable|promotional|subscription|financing — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct product components included in this bundle definition. Derived at bundle creation and maintained as a denormalized operational field to support quick bundle complexity assessment without joining to component lines.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coolLabelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cool Label Required Flag' ;
    rdfs:comment 'Indicates whether Country of Origin Labeling (COOL) is required on the bundle packaging or accompanying documentation per USDA AMS regulations (True = COOL labeling mandatory; False = not required). Applies to covered commodities including muscle cuts, ground meats, fish, perishable agricultural commodities, peanuts, and ginseng.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Program Code' ;
    rdfs:comment 'Code referencing the input supply dealer agreement or crop input financing program under which this bundle is offered. Links the bundle to specific dealer incentive structures, early-order discount programs, and Salesforce CRM partner agreement tracking.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Decomposition Allowed Flag' ;
    rdfs:comment 'Indicates whether a bundle order can be decomposed into individual product fulfillment lines for warehouse picking, inventory reservation, and invoicing purposes (True = decompose to component lines; False = fulfill as a pre-assembled bundle unit). Critical for Manhattan Associates WMS order fulfillment logic.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the sum-of-components price when pricing_method is \'discounted_package\'. Represents the value-added selling incentive for purchasing the bundle versus individual products. Range: 0.00–100.00.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyOrderCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Early Order Cutoff Date' ;
    rdfs:comment 'Last date by which an order must be placed to qualify for the early_order_discount_pct. A key commercial date in pre-season crop input programs and dealer stocking agreements.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyOrderDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Order Discount Pct' ;
    rdfs:comment 'Additional percentage discount applied when the bundle is ordered before the early-order cutoff date, incentivizing pre-season purchasing commitments common in crop input dealer programs. Range: 0.00–100.00.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Financing Eligible Flag' ;
    rdfs:comment 'Indicates whether this bundle qualifies for crop input financing programs (deferred payment, operating line of credit, or third-party ag lender programs). True = bundle is eligible for financing at point of sale; False = cash/standard credit terms only.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Published commercial list price for the complete bundle as a single sellable unit, expressed in the operating currency. Used as the baseline for dealer discount calculations and crop input financing packages.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingProgramName rdf:type rdf:Property ;
    rdfs:label 'Marketing Program Name' ;
    rdfs:comment 'Name of the branded marketing or dealer incentive program under which this bundle is promoted (e.g., \'Grow More Spring Program 2025\', \'Precision Livestock Nutrition Package\'). Supports Salesforce CRM campaign attribution and ROI reporting.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each node in the product hierarchy. Primary key for the product_hierarchy data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:parentHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent node in the product hierarchy tree. Null for root-level Division nodes. Enables recursive traversal for roll-up reporting across crop commodities, livestock products, and processed goods.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name or identifier of the business data steward responsible for maintaining the accuracy and completeness of this hierarchy node. Supports data governance accountability, change management workflows, and master data management (MDM) ownership tracking.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP S/4HANA Sales Division code associated with this hierarchy node. Drives pricing, sales organization assignment, and profit center determination. Examples: CROP (Crop Commodities), LVST (Livestock Products), PROC (Processed Goods), SEED (Seed & Inputs), VADD (Value-Added Products).' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Cross-reference code mapping this hierarchy node to an external classification system such as UNSPSC (United Nations Standard Products and Services Code), HS (Harmonized System) tariff code, or trading partner category code. Supports EDI, customs documentation, and global trade compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCategory rdf:type rdf:Property ;
    rdfs:label 'Food Safety Category' ;
    rdfs:comment 'FDA/USDA food safety classification for products in this hierarchy node. Determines applicable food safety regulations, inspection requirements, and labeling rules. Ready-to-Eat products require stricter controls than Raw Agricultural Commodities. Non-Food and Crop Input nodes are exempt from food safety rules.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaCategory rdf:type rdf:Property ;
    rdfs:label 'Fsma Category' ;
    rdfs:comment 'FDA Food Safety Modernization Act (FSMA) regulatory category applicable to products in this hierarchy node. Determines which FSMA rules govern production, handling, and supply chain requirements. Drives compliance program assignment and audit scope.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiSchemeApplicable rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme Applicable' ;
    rdfs:comment 'Primary Global Food Safety Initiative (GFSI)-recognized certification scheme applicable to products in this hierarchy node. Drives supplier qualification, audit requirements, and customer contract compliance. Values: SQF (Safe Quality Food), BRC (British Retail Consortium), IFS (International Featured Standards), GLOBALG.A.P., Not Applicable.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoClassification rdf:type rdf:Property ;
    rdfs:label 'Gmo Classification' ;
    rdfs:comment 'Indicates the Genetically Modified Organism (GMO) status applicable to products in this hierarchy node. Values: GMO (contains genetically modified material), Non-GMO (no GMO material, not certified), GMO-Free Certified (third-party verified non-GMO), Not Applicable (e.g., agrochemicals). Required for COOL labeling, USDA BE (Bioengineered) disclosure, and export documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpcBrickCode rdf:type rdf:Property ;
    rdfs:label 'Gpc Brick Code' ;
    rdfs:comment 'GS1 Global Product Classification (GPC) Brick-level code for this hierarchy node. Enables standardized product categorization for retail trading partners, EDI transactions, and global supply chain interoperability. Particularly relevant for produce, dairy, and packaged goods nodes.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingStandardCode rdf:type rdf:Property ;
    rdfs:label 'Grading Standard Code' ;
    rdfs:comment 'USDA Agricultural Marketing Service (AMS) grading standard code applicable to products in this hierarchy node (e.g., US No. 1, US Grade A, USDA Choice). Governs quality grading, inspection requirements, and grade-based pricing. Used in SAP QM quality inspection and COA documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Applicable Flag' ;
    rdfs:comment 'Indicates whether Hazard Analysis and Critical Control Points (HACCP) plans are required for products in this hierarchy node. True = HACCP plan mandatory (e.g., meat, poultry, juice, seafood); False = HACCP not required. Drives food safety program assignment and FSIS/FDA audit requirements.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy node. Corresponds to the SAP S/4HANA PRODH (Product Hierarchy) field used in SD pricing and MM material classification. Used for cross-system integration with SAP, Oracle NetSuite, and Granular Farm Management.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Detailed business description of this hierarchy node, including the scope of products it encompasses, applicable production methods, and any relevant regulatory or quality notes. Used in training materials, data catalogs, and business user documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable name of this hierarchy node (e.g., \'Grains & Oilseeds\', \'Fresh Produce\', \'Dairy Products\', \'Crop Inputs - Seed\'). Used in reporting, category management, and retail planogram structures.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of this product hierarchy node. Active = in use for product classification and reporting; Inactive = temporarily disabled; Deprecated = replaced by a new node, retained for historical data; Pending Approval = awaiting business owner sign-off before activation. Controls whether new products can be assigned to this node.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Business label for the hierarchy depth at this node. Standardized level names: Division, Category, Sub-Category, Product Family, SKU. Enables consistent labeling in reports and dashboards without requiring numeric level interpretation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Applicable Flag' ;
    rdfs:comment 'Indicates whether EPA/Codex Alimentarius Maximum Residue Limits (MRL) for pesticide residues apply to products in this hierarchy node. True = MRL testing and compliance required; False = MRL not applicable (e.g., non-food inputs). Drives residue testing protocols and COA requirements.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Materialized full path string from root to this node using delimiter notation (e.g., \'Crop Commodities / Grains / Cereal Grains / Corn\'). Supports efficient hierarchy traversal queries in Databricks without recursive CTEs. Maintained as a denormalized convenience field.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Required Flag' ;
    rdfs:comment 'Indicates whether Pre-Harvest Interval (PHI) tracking is required for products in this hierarchy node. True = PHI compliance mandatory (food/feed crops subject to pesticide application); False = PHI not applicable. Drives crop protection event tracking and harvest scheduling compliance.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pluCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Plu Category Code' ;
    rdfs:comment 'International Federation for Produce Standards (IFPS) Price Look-Up (PLU) category code for fresh produce hierarchy nodes. Used at retail point-of-sale for produce identification and pricing. Applicable primarily to fresh fruit, vegetable, and herb product hierarchy nodes.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUom rdf:type rdf:Property ;
    rdfs:label 'Pricing Uom' ;
    rdfs:comment 'Unit of measure used for pricing and invoicing products in this hierarchy node. May differ from reporting UOM (e.g., corn priced per BU but reported in MT). Drives SAP S/4HANA SD condition record pricing and Oracle NetSuite invoice generation. [ENUM-REF-CANDIDATE: BU|CWT|MT|LB|KG|TON|DOZ|EA|GAL|L — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineType rdf:type rdf:Property ;
    rdfs:label 'Product Line Type' ;
    rdfs:comment 'High-level classification of the product line represented by this hierarchy node. Distinguishes between Crop Commodity (grains, produce, fiber), Livestock Product (meat, dairy, eggs), Processed Good, Seed Input, Value-Added, and Agrochemical product lines. Drives business rules, compliance requirements, and reporting segmentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingUom rdf:type rdf:Property ;
    rdfs:label 'Reporting Uom' ;
    rdfs:comment 'Primary unit of measure used for volume and yield reporting for products in this hierarchy node. Aligned with USDA NASS and WASDE reporting conventions. BU = Bushel, CWT = Hundredweight, MT = Metric Ton, LB = Pound, KG = Kilogram, TON = Short Ton, DOZ = Dozen, EA = Each, GAL = Gallon, L = Liter. Used in SAP S/4HANA MM base unit of measure configuration. [ENUM-REF-CANDIDATE: BU|CWT|MT|LB|KG|TON|DOZ|EA|GAL|L — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Retail Category Code' ;
    rdfs:comment 'Internal retail category management code used for merchandising, planogram assignment, and retail buyer reporting. Aligns with PLU (Price Look-Up) category structures and retail trading partner category definitions. Used in Salesforce CRM for customer-facing category reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Material Group' ;
    rdfs:comment 'SAP S/4HANA Material Group (MATKL field) associated with this hierarchy node. Used in SAP MM for procurement categorization, account determination, and purchasing info records. Enables cross-reference between the product hierarchy and SAP material master classification.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProductHierarchy rdf:type rdf:Property ;
    rdfs:label 'Sap Product Hierarchy' ;
    rdfs:comment 'SAP S/4HANA native Product Hierarchy (PRODH) code for this node, up to 18 characters. Used directly in SAP SD condition records for pricing, rebate agreements, and sales reporting. Serves as the integration key between this data product and SAP S/4HANA SD/MM modules.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric sort order for displaying this hierarchy node among its siblings at the same parent level. Controls the display sequence in SAP S/4HANA product hierarchy browsers, reporting dashboards, and retail category management tools. Lower numbers appear first.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureClass rdf:type rdf:Property ;
    rdfs:label 'Temperature Class' ;
    rdfs:comment 'Required storage and handling temperature classification for products in this hierarchy node. Drives cold chain logistics requirements, warehouse slotting in Manhattan Associates WMS, and transportation mode selection in TMS. Values: Ambient, Refrigerated, Frozen, Controlled Atmosphere.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to research.research_program. Business justification: Commercial agricultural products are the output of research programs. R&D ROI reporting, pipeline-to-commercial traceability, and innovation accounting require linking each commercial product master r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial brand or trade name under which the product is marketed and sold. Relevant for value-added, processed, and seed products. Used in Salesforce CRM for customer-facing product catalog and sales pipeline management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this product was or is scheduled to be discontinued and removed from active use in transactions. Null for active products. Used for lifecycle management, inventory liquidation planning, and customer notification workflows.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foodSafetyCert rdf:type rdf:Property ;
    rdfs:label 'Food Safety Cert' ;
    rdfs:comment 'Primary food safety certification standard applicable to this product (e.g., SQF - Safe Quality Food, BRC - British Retail Consortium, IFS - International Featured Standards, GLOBALG.A.P., HACCP, ISO 22000). Drives audit requirements and customer qualification criteria.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Regulated Flag' ;
    rdfs:comment 'Indicates whether this product is subject to FDA Food Safety Modernization Act (FSMA) regulations, including Preventive Controls for Human Food (21 CFR Part 117) or Produce Safety Rule (21 CFR Part 112). Drives food safety plan requirements and traceability obligations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Compliant Flag' ;
    rdfs:comment 'Indicates whether this product is produced under verified Good Agricultural Practices (GAP) standards. True = GAP-certified production. Required for certain retail customer contracts and export market access. Aligned with USDA GAP/GHP audit program.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradingStandard rdf:type rdf:Property ;
    rdfs:label 'Grading Standard' ;
    rdfs:comment 'USDA or industry grading standard applied to this product (e.g., USDA Grade A, US No. 1, US Extra Fancy, USDA Choice, Prime). Determines quality classification for pricing, contract compliance, and market access. Aligned with USDA Agricultural Marketing Service grade standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humiditySensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Humidity Sensitivity Flag' ;
    rdfs:comment 'Indicates whether this product requires controlled humidity storage conditions. True = humidity-sensitive product requiring specific relative humidity (RH) range in storage. Drives warehouse zone assignment and storage condition monitoring.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightSensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Light Sensitive Flag' ;
    rdfs:comment 'Indicates whether this product requires protection from light exposure during storage and transport. True = light-sensitive product (e.g., certain produce, seed varieties, specialty crops). Drives packaging and storage specification requirements.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonGmoFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Flag' ;
    rdfs:comment 'Indicates whether this product is verified as non-GMO (Genetically Modified Organism). True = non-GMO verified product. Relevant for labeling compliance, customer preference management, and Non-GMO Project verification programs.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertNumber rdf:type rdf:Property ;
    rdfs:label 'Organic Cert Number' ;
    rdfs:comment 'Official USDA National Organic Program (NOP) certification number issued by the accredited certifying agent. Required on organic product labels and COA (Certificate of Analysis) documentation. Null for non-organic products.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Third-level product hierarchy classification providing granular segmentation within a product category (e.g., within Grains: Corn, Wheat, Soybeans, Rice; within Fresh Produce: Leafy Greens, Root Vegetables, Citrus). Supports detailed analytics and procurement planning.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code (UPC) barcode identifier used for retail point-of-sale scanning, consumer packaging, and retail distribution. Required for products sold through retail channels.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP MM valuation class code that determines the G/L (General Ledger) account assignment for inventory postings. Controls how inventory value is recorded in financial accounting (FI module) and cost accounting (CO module). Critical for COGS (Cost of Goods Sold) and inventory valuation reporting.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory status record in the agricultural product regulatory catalog. Primary key for the regulatory_status data product.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biotechSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Biotech Submission Id' ;
    rdfs:comment 'Foreign key linking to research.biotech_submission. Business justification: A product\'s regulatory approval status is directly supported by and traceable to a biotech submission to APHIS/EPA/FDA. Regulatory affairs teams need this link to track submission-to-approval timeline' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiotechSubmission .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the regulatory authorization granted for this product. Indicates whether the product is approved for food use, animal feed use, export to foreign markets, import into domestic market, domestic sale, seed registration, or pesticide registration. [ENUM-REF-CANDIDATE: food_use|feed_use|export_approved|import_approved|domestic_sale|seed_registration|pesticide_registration — promote to reference product]' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedUseDescription rdf:type rdf:Property ;
    rdfs:label 'Approved Use Description' ;
    rdfs:comment 'Narrative description of the specific approved uses, conditions, or restrictions associated with this regulatory authorization. Captures scope limitations such as approved crop targets, processing conditions, or end-use restrictions as defined by the regulatory agency.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Export Restriction Flag' ;
    rdfs:comment 'Indicates whether this product is subject to export restrictions from the domestic market to the specified jurisdiction. True when export is restricted or prohibited; False when export is permitted. Critical for export compliance and trade documentation.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foodSafetyCertStandard rdf:type rdf:Property ;
    rdfs:label 'Food Safety Cert Standard' ;
    rdfs:comment 'The food safety certification standard under which this product has been approved or is required to comply for the specified jurisdiction. Standards include SQF (Safe Quality Food), BRC (British Retail Consortium), IFS (International Featured Standards), GLOBALG.A.P., ISO 22000, HACCP, or FSSC 22000. [ENUM-REF-CANDIDATE: SQF|BRC|IFS|GLOBALG.A.P.|ISO22000|HACCP|FSSC22000|none — promote to reference product]' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Approval Status' ;
    rdfs:comment 'Regulatory approval status for Genetically Modified Organism (GMO) content of this product in the specified jurisdiction. Jurisdictions vary significantly in GMO approval requirements; this field tracks per-market GMO authorization.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Import Restriction Flag' ;
    rdfs:comment 'Indicates whether this product is subject to import restrictions in the specified jurisdiction. True when import is restricted or prohibited; False when import is permitted. Supports APHIS phytosanitary and customs compliance.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether regulatory inspection by the relevant agency (USDA, FDA, FSIS, or foreign equivalent) is required before this product can be sold or exported in the specified jurisdiction.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the market or jurisdiction in which this regulatory approval applies. Used for Country of Origin Labeling (COOL) compliance and export market access management.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Sub-national or regional jurisdiction (e.g., US state, EU member state, Canadian province) where the regulatory approval applies, when approval scope is more granular than country level. Supports state-level pesticide registrations and regional food safety mandates.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirement' ;
    rdfs:comment 'Description of jurisdiction-specific labeling requirements applicable to this product, including Country of Origin Labeling (COOL), GMO disclosure, organic certification marks, allergen declarations, or nutritional labeling mandates.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliance Status' ;
    rdfs:comment 'Indicates whether this product meets the Maximum Residue Limit (MRL) thresholds established by the regulatory agency for the specified jurisdiction. Non-compliant status triggers quarantine holds and export blocks.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Cert Required Flag' ;
    rdfs:comment 'Indicates whether organic certification under the USDA National Organic Program (NOP) or equivalent international standard is required for this product to be sold or exported under an organic label in the specified jurisdiction.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phytosanitaryCertRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Cert Required Flag' ;
    rdfs:comment 'Indicates whether an APHIS phytosanitary certificate is required for export of this product to the specified jurisdiction. True when a phytosanitary certificate must accompany shipments; False when not required.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'The governing regulatory body that issued the approval or authorization for this product. Examples include USDA (United States Department of Agriculture), FDA (Food and Drug Administration), EPA (Environmental Protection Agency), FSIS (Food Safety and Inspection Service), APHIS (Animal and Plant Health Inspection Service), or international equivalents. [ENUM-REF-CANDIDATE: USDA|FDA|EPA|FSIS|APHIS|CODEX|ISO|OTHER — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Classification of the product under the regulatory framework for the specified jurisdiction. Determines which regulatory pathway, inspection regime, and compliance requirements apply. [ENUM-REF-CANDIDATE: commodity|processed_food|livestock_product|seed|agrochemical|feed|organic|specialty_crop — promote to reference product]' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the designated regulatory affairs contact responsible for managing this registration and communicating with the regulatory agency. Business-confidential contact information for compliance correspondence.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalPendingFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Pending Flag' ;
    rdfs:comment 'Indicates whether a renewal application has been submitted to the regulatory agency and is currently awaiting decision. True when renewal is in progress; False when no renewal action is pending.' ;
    rdfs:domain ind:RegulatoryStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aphisPermitId rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: GMO seed varieties require APHIS permits for field trials and deregulation. seed_variety has aphis_petition_number as a denormalized reference; a proper FK to the permit record enables regulatory stat' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:breedingPipelineId rdf:type rdf:Property ;
    rdfs:label 'Breeding Pipeline Id' ;
    rdfs:comment 'Foreign key linking to research.breeding_pipeline. Business justification: Commercial seed variety products are the output of breeding pipeline entries. R&D ROI tracking, PVP certificate filing, and IP protection documentation require tracing each commercial seed variety bac' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BreedingPipeline .

ind:breederName rdf:type rdf:Property ;
    rdfs:label 'Breeder Name' ;
    rdfs:comment 'Name of the seed company, research institution, or individual breeder that developed and holds intellectual property rights over this variety (e.g., \'Bayer Crop Science\', \'Corteva Agriscience\', \'Syngenta\'). Required for licensing compliance and royalty tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogYear rdf:type rdf:Property ;
    rdfs:label 'Catalog Year' ;
    rdfs:comment 'The crop year (4-digit year) for which this seed variety is listed in the commercial product catalog. Used for annual catalog management, variety retirement tracking, and historical performance analysis in Granular Farm Management and Climate FieldView.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cropType rdf:type rdf:Property ;
    rdfs:label 'Crop Type' ;
    rdfs:comment 'High-level agronomic classification of the crop category. Used for product hierarchy segmentation, supply chain routing, and USDA commodity code alignment. [ENUM-REF-CANDIDATE: grain|oilseed|fiber|forage|vegetable|fruit|pulse|tuber|specialty|cover_crop — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToMaturity rdf:type rdf:Property ;
    rdfs:label 'Days To Maturity' ;
    rdfs:comment 'Average number of calendar days from planting to physiological maturity under typical growing conditions for the primary production region. Used for crop scheduling, harvest planning, and frost risk assessment in Climate FieldView and Granular Farm Management.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diseaseResistanceProfile rdf:type rdf:Property ;
    rdfs:label 'Disease Resistance Profile' ;
    rdfs:comment 'Structured description of the variety\'s resistance or tolerance ratings to key crop diseases (e.g., \'Gray Leaf Spot: R, Northern Corn Leaf Blight: MR, Goss\'s Wilt: S\'). Ratings typically follow industry conventions: R=Resistant, MR=Moderately Resistant, MS=Moderately Susceptible, S=Susceptible. Informs crop protection planning and IPM programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtToleranceRating rdf:type rdf:Property ;
    rdfs:label 'Drought Tolerance Rating' ;
    rdfs:comment 'Categorical rating of the variety\'s ability to maintain yield under water-deficit stress conditions. Used for irrigation planning, water resource management, and ET (Evapotranspiration)-based irrigation scheduling in precision agriculture systems.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:herbicideToleranceTraits rdf:type rdf:Property ;
    rdfs:label 'Herbicide Tolerance Traits' ;
    rdfs:comment 'Comma-separated list of herbicide tolerance traits present in this variety (e.g., \'glyphosate, glufosinate, dicamba\'). Used for agrochemical selection, VRA prescription compatibility, and EPA resistance management compliance. Supports IPM resistance group tracking.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insectResistanceTraits rdf:type rdf:Property ;
    rdfs:label 'Insect Resistance Traits' ;
    rdfs:comment 'Comma-separated list of insect resistance traits (e.g., \'Bt Cry1Ab, Cry3Bb1, VIP3A\') present in this variety. Used for EPA insect resistance management (IRM) compliance, refuge planning, and IPM program design. Required for APHIS regulatory documentation on Bt crops.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date on which this seed variety was first commercially introduced to the market or added to the internal product catalog. Used for variety lifecycle management, performance trend analysis, and regulatory documentation.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensorCode rdf:type rdf:Property ;
    rdfs:label 'Licensor Code' ;
    rdfs:comment 'Unique identifier for the seed licensor or technology provider as registered in the ERP procurement master. Used to link seed variety to licensing agreements, royalty schedules, and supplier records in SAP S/4HANA MM.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonGmoVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Verified Flag' ;
    rdfs:comment 'Indicates whether this seed variety has received third-party non-GMO verification (e.g., Non-GMO Project Verified, USDA Process Verified Program). Distinct from NOP organic eligibility — a variety can be non-GMO verified without being organically produced. Supports customer segregation and premium market positioning.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nopOrganicEligible rdf:type rdf:Property ;
    rdfs:label 'Nop Organic Eligible' ;
    rdfs:comment 'Indicates whether this seed variety is eligible for use in USDA National Organic Program (NOP) certified organic production. True = organically produced seed available and eligible; False = not eligible (e.g., treated with prohibited substances or GMO). Drives organic crop planning and NOP compliance documentation.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Package Weight Kg' ;
    rdfs:comment 'Net weight of the standard commercial seed package in kilograms. Used for freight calculation, warehouse storage planning, and logistics management in Manhattan Associates WMS and TMS (Transportation Management System).' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantHeightCategory rdf:type rdf:Property ;
    rdfs:label 'Plant Height Category' ;
    rdfs:comment 'Categorical classification of the variety\'s typical plant height at maturity. Used for equipment calibration (combine header height), lodging risk assessment, and field operation planning in John Deere Operations Center.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantVarietyProtectionNumber rdf:type rdf:Property ;
    rdfs:label 'Plant Variety Protection Number' ;
    rdfs:comment 'USDA Plant Variety Protection Office certificate number assigned to this variety, granting intellectual property protection to the breeder. Null if the variety is not PVP-protected or is in the public domain. Required for licensing compliance and royalty management.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedPlantingRegions rdf:type rdf:Property ;
    rdfs:label 'Recommended Planting Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions, states, or USDA Plant Hardiness Zones where this variety is agronomically recommended for commercial production (e.g., \'Corn Belt, Northern Plains, Zone 5-7\'). Supports geographic segmentation in Esri ArcGIS field mapping and regional sales planning.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeMaturityRating rdf:type rdf:Property ;
    rdfs:label 'Relative Maturity Rating' ;
    rdfs:comment 'Numeric relative maturity rating indicating the number of days or heat units required for the variety to reach physiological maturity relative to a standard check variety (e.g., 108.5 for a 108.5-day corn hybrid, 3.8 for a 3.8 maturity group soybean). Critical for crop planning, planting date optimization, and frost risk management in Climate FieldView and Trimble Ag Software.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedClass rdf:type rdf:Property ;
    rdfs:label 'Seed Class' ;
    rdfs:comment 'Official seed certification class indicating the generation and purity level of the seed as defined by the Association of Official Seed Certifying Agencies (AOSCA). Classes: \'breeder\' (source seed from originating breeder), \'foundation\' (first generation from breeder seed), \'registered\' (second generation), \'certified\' (commercially distributed certified seed), \'commercial\' (uncertified commercial seed).' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Seed Size Category' ;
    rdfs:comment 'Physical size classification of the seed kernel used for planter plate selection, seeding equipment calibration, and seed unit weight calculations. Affects planter population accuracy and is required for John Deere Operations Center equipment setup.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedTreatmentActiveIngredient rdf:type rdf:Property ;
    rdfs:label 'Seed Treatment Active Ingredient' ;
    rdfs:comment 'Comma-separated list of active ingredients (AI) in the seed treatment formulation (e.g., \'clothianidin, metalaxyl, fludioxonil\'). Required for MRL compliance, EPA registration cross-reference, and FSMA produce safety rule documentation.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedTreatmentApplied rdf:type rdf:Property ;
    rdfs:label 'Seed Treatment Applied' ;
    rdfs:comment 'Name or code of the seed treatment product(s) applied to the seed lot prior to sale or planting (e.g., \'Poncho 1250 + Acceleron\', \'Cruiser Maxx Vibrance\'). Includes fungicide, insecticide, and biological seed treatments. Required for EPA label compliance, PHI/REI tracking, and NOP organic eligibility determination.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingRatePerAcre rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Per Acre' ;
    rdfs:comment 'Manufacturer or agronomist-recommended seeding rate expressed as seeds per acre for optimal stand establishment. Used for VRA (Variable Rate Application) prescription generation in Trimble Ag Software and seed quantity planning in Granular Farm Management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedsPerUnit rdf:type rdf:Property ;
    rdfs:label 'Seeds Per Unit' ;
    rdfs:comment 'Number of seeds per standard commercial unit (e.g., seeds per 80,000-count bag for corn, seeds per 140,000-count bag for soybean). Used for inventory management, seeding rate calculations, and order quantity planning in SAP S/4HANA MM and Manhattan Associates WMS.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traitPackage rdf:type rdf:Property ;
    rdfs:label 'Trait Package' ;
    rdfs:comment 'Descriptive label of the bundled biotechnology or conventionally bred trait stack applied to this variety (e.g., \'RoundupReady2Xtend + Bollgard3\', \'Enlist E3\', \'LibertyLink GT27\'). Captures herbicide tolerance, insect resistance, drought tolerance, and other engineered or selected traits. Used for IPM planning, agrochemical compatibility, and regulatory reporting.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietyCode rdf:type rdf:Property ;
    rdfs:label 'Variety Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the seed variety in ERP and FMIS systems (e.g., SAP S/4HANA material master number or Trimble Ag Software variety code). Used as the business key for cross-system integration and SKU linkage.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietyName rdf:type rdf:Property ;
    rdfs:label 'Variety Name' ;
    rdfs:comment 'Commercial or proprietary name of the seed variety as registered by the breeder or licensor (e.g., \'DeKalb DKC62-08\', \'Pioneer P1197AM\'). This is the primary human-readable identifier used in field operations, procurement, and sales.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietyStatus rdf:type rdf:Property ;
    rdfs:label 'Variety Status' ;
    rdfs:comment 'Current lifecycle status of the seed variety in the product catalog. \'active\' indicates commercially available; \'discontinued\' indicates no longer sold or planted; \'under_review\' indicates pending regulatory or internal evaluation; \'pending_approval\' indicates awaiting APHIS or NOP certification; \'withdrawn\' indicates removed due to regulatory or quality issues.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPotentialRating rdf:type rdf:Property ;
    rdfs:label 'Yield Potential Rating' ;
    rdfs:comment 'Categorical rating of the variety\'s yield potential relative to comparable varieties in the same crop class and maturity group, as determined by multi-environment trial (MET) data. Used for variety selection, agronomic planning, and YPM (Yield Per Acre Metric) benchmarking in Granular Farm Management.' ;
    rdfs:domain ind:SeedVariety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionRuleId rdf:type rdf:Property ;
    rdfs:label 'Substitution Rule Id' ;
    rdfs:comment 'Unique system-generated identifier for the product substitution rule record. Primary key for the substitution_rule data product in the SAP S/4HANA MM material substitution configuration context.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySubstitutionSubstituteProductMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Substitution Substitute Product Master Id' ;
    rdfs:comment 'Reference to the approved substitute agricultural product or commodity that can replace the primary product in order fulfillment, procurement, or feed formulation scenarios. Links to product.product_master.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:salesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Id' ;
    rdfs:comment 'Reference to the SAP S/4HANA sales organization for which this substitution rule is valid in order fulfillment scenarios. Null indicates applicability across all sales organizations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:autoSubstitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Substitution Flag' ;
    rdfs:comment 'Indicates whether the system (SAP S/4HANA MM) may automatically apply this substitution rule without manual intervention when the trigger condition is met. False requires a planner or procurement officer to manually confirm the substitution.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Required' ;
    rdfs:comment 'Indicates whether explicit customer approval must be obtained before applying this substitution in a sales order fulfillment context. True requires customer confirmation; False allows automatic substitution. Relevant for COOL and customer contract compliance.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerGroupRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Group Restriction' ;
    rdfs:comment 'Identifies a specific customer segment or customer group (e.g., food manufacturers, retail chains, export accounts) for which this substitution rule is restricted. Null means the rule applies to all customers. Aligns with Salesforce CRM customer segmentation.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTraceabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Required' ;
    rdfs:comment 'Indicates whether this substitution triggers additional traceability documentation requirements under the FDA Food Safety Modernization Act (FSMA) Food Traceability Rule (Section 204). True requires lot-level tracking and Key Data Elements (KDEs) to be captured.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeEquivalencyFlag rdf:type rdf:Property ;
    rdfs:label 'Grade Equivalency Flag' ;
    rdfs:comment 'Indicates whether the substitute product meets the same USDA grading standard as the primary product (True = grade-equivalent substitution). Used in quality assurance workflows and COA documentation to confirm substitution does not downgrade product quality.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSubstitutionQty rdf:type rdf:Property ;
    rdfs:label 'Max Substitution Qty' ;
    rdfs:comment 'Maximum quantity of the substitute product (in the defined unit of measure) that may be applied under this rule per order or procurement event. Prevents over-substitution and supports supply chain planning constraints.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrlCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Compliant Flag' ;
    rdfs:comment 'Indicates whether the substitute product meets the same Maximum Residue Limit (MRL) thresholds as the primary product for pesticide and agrochemical residues. Required for food safety compliance under FDA, EPA, and Codex Alimentarius standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonGmoEquivalencyFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Equivalency Flag' ;
    rdfs:comment 'Indicates whether the substitute product maintains the same non-GMO (Genetically Modified Organism) status as the primary product. Critical for non-GMO product lines and customer labeling commitments under USDA BE (Bioengineered) disclosure rules.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicEquivalencyFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Equivalency Flag' ;
    rdfs:comment 'Indicates whether the substitute product maintains the same organic certification status as the primary product under USDA National Organic Program (NOP). True means both products are NOP-certified organic; False means organic status differs and substitution may affect labeling.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialPct rdf:type rdf:Property ;
    rdfs:label 'Price Differential Pct' ;
    rdfs:comment 'Percentage difference in standard cost between the substitute product and the primary product (positive = substitute is more expensive, negative = substitute is cheaper). Used in procurement cost impact analysis and COGS (Cost of Goods Sold) variance reporting.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking (1 = highest priority) used to sequence multiple approved substitutes for the same primary product. Determines which substitute is selected first when multiple substitution rules are active simultaneously in SAP S/4HANA MM.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Quantity Conversion Factor' ;
    rdfs:comment 'Numeric multiplier applied to the primary product quantity to determine the equivalent substitute quantity (e.g., 1.05 means 5% more substitute is needed per unit of primary). Accounts for grade equivalency differences in weight, volume, or nutritional value.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Flag' ;
    rdfs:comment 'Indicates whether this substitution is subject to regulatory restrictions (e.g., USDA, FDA, EPA, APHIS import/export controls, or state-level agricultural regulations) that limit when or where the substitute product may be used.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this substitution rule, used in SAP S/4HANA MM material substitution configuration and cross-referenced in procurement and order fulfillment workflows.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the substitution rule governing whether it may be applied in fulfillment or procurement operations. Active rules are eligible for automatic or manual substitution; suspended rules require review before use.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Free-text business justification describing why this substitution rule was established (e.g., \'Corn No. 2 Yellow substituted for Corn No. 1 Yellow during Q4 harvest shortfall; grade equivalency confirmed by QA\'). Supports audit documentation and supply chain resilience planning.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionScope rdf:type rdf:Property ;
    rdfs:label 'Substitution Scope' ;
    rdfs:comment 'Business process context in which this substitution rule is applicable: order_fulfillment (sales order dispatch), procurement (purchase order sourcing), feed_formulation (livestock nutrition ingredient swap), or all (unrestricted across all processes).' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Categorical classification of the substitution relationship: equivalent_grade (same quality tier, different lot/source), approved_alternative (customer or regulatory pre-approved swap), emergency (supply disruption-driven), seasonal (crop availability-driven), feed_formulation (ingredient swap in livestock nutrition plans). Drives workflow routing in SAP S/4HANA MM.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyConstraintTrigger rdf:type rdf:Property ;
    rdfs:label 'Supply Constraint Trigger' ;
    rdfs:comment 'Business condition that activates this substitution rule: stock_shortage (inventory below reorder point), seasonal_unavailability (crop not in season), quality_hold (primary product under quarantine), supplier_disruption (vendor supply failure), price_threshold (cost exceeds approved ceiling). Drives automated substitution logic in SAP S/4HANA MM.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAuditQualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Quality Audit Id' ;
    rdfs:comment 'Reference to the immediately preceding audit record for the same facility and standard, enabling trend analysis and certification history tracking.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:trialSiteId rdf:type rdf:Property ;
    rdfs:label 'Trial Site Id' ;
    rdfs:comment 'Foreign key linking to the specific trial site included in scope for this audit.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrialSite .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Name of the certification body, regulatory agency, or organization that conducted or commissioned the audit (e.g., NSF International, SGS, Bureau Veritas, USDA AMS, FDA).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Free-text notes recorded by the auditor regarding this specific credential during this specific audit. May include observations about renewal status, scope limitations, or corrective action recommendations specific to this credential review.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date on which the certification body formally issued the certificate following a successful audit. Marks the start of the certification validity period.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Certification Outcome' ;
    rdfs:comment 'The formal certification decision resulting from the audit: certified (new certification granted), recertified (existing certification renewed), conditional (certification granted with conditions), suspended (certification temporarily withdrawn), withdrawn (certification permanently revoked), or not_certified (audit failed).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The formal quality or food safety standard against which this audit was conducted (e.g., SQF, BRC, IFS, GLOBALG.A.P., USDA Organic, ISO 22000, HACCP, GAP). [ENUM-REF-CANDIDATE: SQF|BRC|IFS|GLOBALG.A.P.|USDA_Organic|ISO_22000|HACCP|GAP|GMP|FSMA — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionClosedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Closed Date' ;
    rdfs:comment 'The date on which all corrective actions from this audit were formally accepted and closed by the auditing body or internal quality team. Null if corrective actions are still open.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of calendar days the audit spanned from actual start to actual end. Used for audit program benchmarking and resource planning.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingIfExpired rdf:type rdf:Property ;
    rdfs:label 'Finding If Expired' ;
    rdfs:comment 'The formal audit finding recorded if the credential was expired, lapsed, or otherwise non-compliant at the time of the audit review. Populated only when the credential failed verification; null if the credential was current and valid.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRule rdf:type rdf:Property ;
    rdfs:label 'Fsma Rule' ;
    rdfs:comment 'The specific FSMA rule or subpart applicable to this audit, if the audit is FSMA-related (e.g., Produce Safety Rule, Preventive Controls for Human Food, Foreign Supplier Verification Program). Null for non-FSMA audits.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapCertified rdf:type rdf:Property ;
    rdfs:label 'Gap Certified' ;
    rdfs:comment 'Indicates whether this audit resulted in or maintained a Good Agricultural Practices (GAP) certification. Relevant for USDA GAP/GHP audits and GLOBALG.A.P. assessments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformance Count' ;
    rdfs:comment 'Total number of minor non-conformances identified during the audit. Minor non-conformances require corrective action within a defined timeframe but do not immediately jeopardize certification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The date by which the next audit (recertification or surveillance) must be completed to maintain continuous certification status. Derived from certificate expiry and standard-specific surveillance requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'The unique reference number of the formal audit report document issued by the auditing body. Used for document management, regulatory submissions, and customer sharing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAuditScope rdf:type rdf:Property ;
    rdfs:label 'Site Audit Scope' ;
    rdfs:comment 'Narrative description of the operations, processes, or product categories audited at this specific trial site within the broader audit engagement. May differ from the overall audit scope when a multi-site audit covers different activities at each site.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCertificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Site Certification Outcome' ;
    rdfs:comment 'The formal certification decision for this specific trial site resulting from the audit. In multi-site campaigns, individual sites may receive different outcomes (e.g., one site certified, another conditionally certified). Cannot reside on audit alone as it varies per site.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'The specific version or edition of the certification standard used for this audit (e.g., SQF Edition 9, BRC Issue 9, IFS Food Version 8). Critical for tracking compliance against evolving standard requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:comment 'Indicates whether the certification or license was confirmed as current, valid, and compliant at the time of this audit review. True means the auditor verified the credential was in good standing during the audit; false indicates it could not be verified or was found non-compliant.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or identifier of the qualified person (laboratory director, quality manager, or authorized signatory) who approved and released this COA. Required for GFSI audit documentation and regulatory traceability.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Status' ;
    rdfs:comment 'Current lifecycle status of the COA document. \'released\' indicates the COA is approved for customer-facing distribution. \'superseded\' indicates a newer version has replaced this record. Drives SAP QM usage decision workflow.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpCompliant rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Compliant' ;
    rdfs:comment 'Indicates whether all HACCP Critical Control Point (CCP) parameters tested in this COA are within established critical limits. False triggers mandatory corrective action under FSMA Preventive Controls and FSIS HACCP regulations.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heavyMetalType rdf:type rdf:Property ;
    rdfs:label 'Heavy Metal Type' ;
    rdfs:comment 'Specific heavy metal analyte tested. Each metal has distinct regulatory maximum levels under FDA, Codex Alimentarius, and EU regulations requiring separate tracking.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heavyMetalsResultPpm rdf:type rdf:Property ;
    rdfs:label 'Heavy Metals Result Ppm' ;
    rdfs:comment 'Measured concentration of heavy metal contaminants (lead, cadmium, arsenic, mercury) in parts per million. Compared against FDA and Codex Alimentarius maximum levels for food safety compliance.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:microbialResult rdf:type rdf:Property ;
    rdfs:label 'Microbial Result' ;
    rdfs:comment 'Measured microbial count expressed as colony forming units per gram (CFU/g). Covers total plate count, E. coli, Salmonella, Listeria, and other pathogens per HACCP critical control point specifications.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:microbialTestType rdf:type rdf:Property ;
    rdfs:label 'Microbial Test Type' ;
    rdfs:comment 'Specific microbiological analyte or pathogen tested. Salmonella and Listeria are HACCP critical control point parameters under FSMA Preventive Controls and FSIS regulations.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mycotoxinResultPpb rdf:type rdf:Property ;
    rdfs:label 'Mycotoxin Result Ppb' ;
    rdfs:comment 'Measured concentration of mycotoxins (aflatoxin, deoxynivalenol, fumonisin, ochratoxin, zearalenone) in parts per billion (ppb). Compared against FDA action levels and EU MRL limits for regulatory compliance.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mycotoxinType rdf:type rdf:Property ;
    rdfs:label 'Mycotoxin Type' ;
    rdfs:comment 'Specific mycotoxin analyte tested in this COA record. Different mycotoxins have distinct FDA action levels and MRL thresholds under Codex Alimentarius and EU regulations.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideResidueResultPpm rdf:type rdf:Property ;
    rdfs:label 'Pesticide Residue Result Ppm' ;
    rdfs:comment 'Measured pesticide residue concentration in parts per million (ppm). Compared against EPA-established Maximum Residue Limits (MRL) and Codex Alimentarius MRL tables for regulatory compliance and export eligibility.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Full descriptive name of the commodity or product as it appears on the COA document, including variety, grade, or specification designation where applicable.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Indicates whether the lot covered by this COA has been approved for customer shipment and commercial release. \'blocked\' prevents order fulfillment in SAP SD. Distinct from coa_status which tracks the document lifecycle.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date on which laboratory analysis was performed on the sample. Used to determine result validity windows and compliance with regulatory testing timelines.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentCapaCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Parent Capa Corrective Action Id' ;
    rdfs:comment 'Reference to a parent CAPA record when this CAPA was generated as a follow-up due to ineffective closure of a prior action. Enables CAPA lineage tracking and recurrence chain analysis.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:primaryCorrectiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Employee Id' ;
    rdfs:comment 'Identifier of the employee or team lead assigned as the primary owner accountable for implementing the corrective and preventive action. Links to the workforce/employee master record in SAP SuccessFactors.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingEventId rdf:type rdf:Property ;
    rdfs:label 'Training Event Id' ;
    rdfs:comment 'Foreign key linking to workforce.training_event. Business justification: Under FSMA preventive controls and GFSI schemes, corrective actions frequently mandate a specific training event as the preventive measure. Linking CAPA records to the fulfilling training event is req' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEvent .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date on which all corrective and preventive actions were fully implemented and the CAPA record was formally closed following successful verification. Compared against target_completion_date to measure on-time closure performance.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Externally-known business identifier for the CAPA record, formatted as CAPA-{YEAR}-{SEQUENCE}. Used for cross-referencing in audit reports, regulatory submissions, and SAP QM notification workflows.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record, tracking progression from initial opening through root cause analysis, implementation, verification, and closure. Drives workflow routing in SAP S/4HANA QM.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classifies whether the action is purely corrective (addressing an existing nonconformance), purely preventive (addressing a potential risk), or both. Determines reporting category for FSMA, SQF, BRC, and IFS compliance.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date on which the effectiveness review was conducted to assess whether the implemented corrective and preventive actions successfully eliminated the root cause and prevented recurrence of the nonconformance.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Notes' ;
    rdfs:comment 'Narrative notes from the effectiveness review, documenting evidence reviewed, observations made, and rationale for the effectiveness determination. Supports audit trail and continuous improvement documentation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Outcome of the post-implementation effectiveness review, assessing whether the corrective and preventive actions successfully eliminated the root cause and prevented recurrence. A \'not_effective\' outcome triggers a new CAPA cycle.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Reportable Flag' ;
    rdfs:comment 'Indicates whether this CAPA is associated with a food safety event that requires reporting or documentation under the Food Safety Modernization Act (FSMA), including Preventive Controls, Produce Safety, or Foreign Supplier Verification Program requirements.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapGmpViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Gmp Violation Flag' ;
    rdfs:comment 'Indicates whether the nonconformance or finding that triggered this CAPA constitutes a violation of Good Agricultural Practices (GAP) or Good Manufacturing Practices (GMP). Flags records requiring mandatory regulatory reporting.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCcpReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Reference' ;
    rdfs:comment 'Reference to the specific HACCP Critical Control Point (CCP) or Preventive Control associated with this CAPA, where applicable. Links the corrective action to the HACCP plan for food safety traceability and regulatory compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateContainmentAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Containment Action' ;
    rdfs:comment 'Description of the immediate containment or disposition action taken at the time of the finding to prevent affected product from reaching the market or causing further harm (e.g., product quarantine, lot hold, process stoppage). Distinct from the root-cause-based corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the systemic preventive action(s) implemented to eliminate the potential cause of a nonconformance or to prevent recurrence across similar processes, products, or facilities. Addresses systemic risk beyond the immediate corrective fix.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific regulatory clause, standard requirement, or certification criterion that the CAPA addresses (e.g., FSMA 21 CFR Part 117.150, GLOBALG.A.P. IFA v6 AF 4.1, SQF Element 2.5.3). Supports regulatory reporting and audit readiness.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Method' ;
    rdfs:comment 'Structured methodology used to identify the root cause of the nonconformance or finding. Common methods include 5-Why analysis, fishbone (Ishikawa) diagram, fault tree analysis, Failure Mode and Effects Analysis (FMEA), Pareto analysis, or brainstorming. [ENUM-REF-CANDIDATE: 5_why|fishbone|fault_tree|failure_mode_effects_analysis|pareto|brainstorming|other — promote to reference product]' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Human-readable business identifier of the originating record (e.g., nonconformance report number, audit finding reference, inspection report number). Supports cross-document traceability in regulatory submissions and audit packages.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Categorizes the originating trigger for the CAPA record. Indicates whether the action was initiated from an inspection finding, nonconformance report, audit finding, environmental monitoring positive, customer complaint, Maximum Residue Limit (MRL) exceedance, food safety incident, or internal observation. [ENUM-REF-CANDIDATE: inspection_finding|nonconformance|audit_finding|environmental_monitoring|customer_complaint|mrl_exceedance|food_safety_incident|internal_observation — promote to reference product]' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Unique surrogate identifier for each environmental monitoring record in the food safety surveillance program.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to quality.regulatory_submission. Business justification: environmental_monitoring has regulatory_submission_required (BOOLEAN) and fsma_program_code indicating regulatory reporting obligations. Adding regulatory_submission_id FK links the monitoring record ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:sampleSiteId rdf:type rdf:Property ;
    rdfs:label 'Sample Site Id' ;
    rdfs:comment 'Unique identifier for the physical sampling location within the facility or field (e.g., floor drain, conveyor belt, water source inlet). Used for trend analysis and site-specific corrective action tracking.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSite .

ind:waterStewardshipPlanId rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Plan Id' ;
    rdfs:comment 'Foreign key linking to sustainability.water_stewardship_plan. Business justification: Water stewardship plans require documented water quality monitoring as evidence of plan implementation. Linking environmental_monitoring records to the water_stewardship_plan they support enables plan' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterStewardshipPlan .

ind:actionLimit rdf:type rdf:Property ;
    rdfs:label 'Action Limit' ;
    rdfs:comment 'Threshold value at or above which a corrective action is automatically triggered. For pathogens, any detection constitutes an action limit breach. For indicator organisms, this is the numeric threshold defined in the environmental monitoring program.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedBy rdf:type rdf:Property ;
    rdfs:label 'Collected By' ;
    rdfs:comment 'Name or employee identifier of the individual who physically collected the environmental sample. Required for chain-of-custody documentation and FSMA audit evidence.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Date and time when the environmental sample was physically collected from the monitoring site. Principal business event timestamp for this record. Used for trend analysis, frequency compliance verification, and FSMA audit trails.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmatoryTestRequired rdf:type rdf:Property ;
    rdfs:label 'Confirmatory Test Required' ;
    rdfs:comment 'Indicates whether a confirmatory (second) test is required following a presumptive positive result. True when initial screening detects a pathogen and confirmation by an alternative validated method is mandated by the monitoring program or regulatory requirement.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consecutivePositiveCount rdf:type rdf:Property ;
    rdfs:label 'Consecutive Positive Count' ;
    rdfs:comment 'Number of consecutive positive or above-threshold results recorded at this sample site prior to and including the current result. Used to evaluate adverse trends and escalate corrective action intensity per the environmental monitoring program.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaProgramCode rdf:type rdf:Property ;
    rdfs:label 'Fsma Program Code' ;
    rdfs:comment 'FSMA regulatory program under which this environmental monitoring event is conducted: PC-HF = Preventive Controls for Human Food (21 CFR Part 117); PC-AF = Preventive Controls for Animal Food (21 CFR Part 507); PSR = Produce Safety Rule (21 CFR Part 112); FSVP = Foreign Supplier Verification Program.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapAuditEvidenceFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Audit Evidence Flag' ;
    rdfs:comment 'Indicates whether this environmental monitoring record is designated as audit evidence for a GAP or GLOBALG.A.P. certification audit. Flagged records are included in audit evidence packages and must meet documentation completeness requirements.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genericEColiResult rdf:type rdf:Property ;
    rdfs:label 'Generic E Coli Result' ;
    rdfs:comment 'Numeric generic E. coli count in MPN/100mL for agricultural water samples. FSMA Produce Safety Rule specifies a geometric mean threshold of 126 MPN/100mL and a statistical threshold value (STV) of 410 MPN/100mL for agricultural water used on produce.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringProgramVersion rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Version' ;
    rdfs:comment 'Version identifier of the written environmental monitoring program document under which this sample was collected. Ensures results are evaluated against the correct action limits and frequencies as the program evolves over time.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Monitoring Record Number' ;
    rdfs:comment 'Externally-visible business identifier for the environmental monitoring event, used in GFSI audit evidence packages and FSMA regulatory submissions. Format: EM-YYYY-NNNNNN.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringZone rdf:type rdf:Property ;
    rdfs:label 'Monitoring Zone' ;
    rdfs:comment 'Zone classification of the sample site per industry-standard environmental monitoring zoning: Zone 1 = direct food contact surfaces; Zone 2 = adjacent non-food contact surfaces; Zone 3 = areas removed from food contact; Zone 4 = external/remote areas. Drives sampling frequency and corrective action thresholds.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall pass or fail determination for this environmental monitoring sample based on comparison of the test result against the action limit and program specifications. Drives corrective action workflow initiation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitativeResult rdf:type rdf:Property ;
    rdfs:label 'Qualitative Result' ;
    rdfs:comment 'Qualitative outcome of the environmental microbiological test. For pathogen testing (Listeria, Salmonella), results are typically reported as Detected/Not Detected. Presumptive Positive triggers confirmatory testing before corrective action.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantitativeResult rdf:type rdf:Property ;
    rdfs:label 'Quantitative Result' ;
    rdfs:comment 'Numeric count or concentration result for indicator organism testing (e.g., coliform count, aerobic plate count). Expressed in the unit defined by result_unit_of_measure. Null for qualitative-only pathogen tests.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultReportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Reported Timestamp' ;
    rdfs:comment 'Date and time the final test result was reported by the laboratory to the quality team. Used to measure turnaround time and ensure timely corrective action initiation within program-defined windows.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Result Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantitative test result (e.g., CFU/cm2 for surface swabs, CFU/mL for water samples, MPN/100mL for agricultural water per FSMA Produce Safety Rule). Null when result is qualitative only.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Received Timestamp' ;
    rdfs:comment 'Date and time the environmental sample was received at the laboratory. Used to calculate sample hold time compliance and chain-of-custody integrity.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleSiteDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Site Description' ;
    rdfs:comment 'Descriptive name and location detail of the sampling point (e.g., \'Floor drain near chiller exit, Zone 2, Building A\'). Supports audit evidence and site mapping.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Scheduled frequency at which this monitoring site is sampled as defined in the environmental monitoring program plan. Used to verify compliance with program requirements and identify gaps in monitoring coverage.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganism rdf:type rdf:Property ;
    rdfs:label 'Target Organism' ;
    rdfs:comment 'The pathogen or indicator organism being tested in this monitoring event. Drives test method selection, action limits, and regulatory notification requirements. [ENUM-REF-CANDIDATE: Listeria spp.|Listeria monocytogenes|Salmonella|E. coli O157:H7|Generic E. coli|Coliforms|Aerobic Plate Count|Yeast and Mold — promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodCode rdf:type rdf:Property ;
    rdfs:label 'Test Method Code' ;
    rdfs:comment 'Standardized analytical method code used for pathogen or indicator organism detection (e.g., AOAC 2004.02 for Listeria, BAM Chapter 5 for Salmonella, ISO 11290-1 for Listeria monocytogenes). Ensures method traceability for GFSI and regulatory audits.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Trend Analysis Flag' ;
    rdfs:comment 'Indicates whether this result has been flagged by the trend analysis algorithm as part of an adverse trend pattern (e.g., repeated indicator organism positives in the same zone, increasing counts over consecutive sampling events). Triggers proactive investigation before action limit is breached.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Facility Monitoring Id' ;
    rdfs:comment 'Primary key for facility_monitoring' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFacilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the individual who performed the scouting observation or sanitation operation. Supports accountability and training compliance tracking.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Action Threshold Exceeded' ;
    rdfs:comment 'Indicates whether the observed pest population count has exceeded the defined action threshold, triggering a required IPM intervention or pesticide application. True = threshold exceeded; False = within acceptable limits.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atpPassFail rdf:type rdf:Property ;
    rdfs:label 'Atp Pass Fail' ;
    rdfs:comment 'Pass/fail determination for the ATP swab test based on the facility\'s defined RLU threshold. Drives corrective action requirements and GFSI audit evidence documentation.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpTestResultRlu rdf:type rdf:Property ;
    rdfs:label 'Atp Test Result Rlu' ;
    rdfs:comment 'Result of the ATP bioluminescence swab test expressed in Relative Light Units (RLU). Lower values indicate cleaner surfaces. Compared against the facility\'s pass/fail threshold to validate sanitation effectiveness per FSMA preventive controls.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningAgentConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Cleaning Agent Concentration Ppm' ;
    rdfs:comment 'Concentration of the cleaning or sanitizing agent applied, expressed in parts per million (PPM). Must fall within the EPA-registered or manufacturer-specified range for food-contact surface sanitation.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Contact Time Minutes' ;
    rdfs:comment 'Actual duration in minutes that the cleaning or sanitizing agent remained in contact with the surface being treated. Compared against the required minimum contact time specified in the SOP (Standard Operating Procedure) for efficacy validation.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicThreshold rdf:type rdf:Property ;
    rdfs:label 'Economic Threshold' ;
    rdfs:comment 'The pest population density level at which economic damage begins to occur, expressed as count per unit area or trap. Used as the baseline for IPM action threshold comparison and treatment justification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Precise date and time when the monitoring activity was completed. Used to calculate actual contact time for sanitation agents and total scouting duration.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Precise date and time when the monitoring activity commenced. Required for contact time calculations in sanitation events and for audit trail completeness under FSMA preventive controls.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gapComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Status' ;
    rdfs:comment 'Assessment of whether this monitoring event meets GAP compliance requirements for field sanitation, pest management, and worker hygiene. Used as evidence in GLOBALG.A.P. and USDA GAP audits.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisCoordinates rdf:type rdf:Property ;
    rdfs:label 'Gis Coordinates' ;
    rdfs:comment 'Latitude and longitude coordinates (decimal degrees, WGS84) of the monitoring location, captured via GPS for precision agriculture field mapping and spatial analysis in Esri ArcGIS.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Status' ;
    rdfs:comment 'Assessment of whether this monitoring event meets GMP compliance requirements for sanitation preventive controls in processing and storage facilities. Used as evidence in FDA, SQF, BRC, and IFS audits.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbialPassFail rdf:type rdf:Property ;
    rdfs:label 'Microbial Pass Fail' ;
    rdfs:comment 'Pass/fail determination for the microbial test result based on regulatory or facility-defined acceptance criteria. Drives corrective action, product hold, and regulatory notification workflows.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbialTestOrganism rdf:type rdf:Property ;
    rdfs:label 'Microbial Test Organism' ;
    rdfs:comment 'Specific pathogen or indicator organism targeted by the microbial test (e.g., Listeria monocytogenes, Salmonella, E. coli O157:H7, Total Aerobic Count). Required for FSMA environmental monitoring program documentation.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbialTestResult rdf:type rdf:Property ;
    rdfs:label 'Microbial Test Result' ;
    rdfs:comment 'Result of microbiological testing performed on environmental swabs or surface samples (e.g., Total Plate Count, Listeria spp., Salmonella spp., E. coli). Expressed as colony-forming units per area or detected/not detected. Null if no microbial test was performed.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific monitoring point within the facility or field (e.g., trap station ID, zone code, room designation). Aligns with the facility\'s IPM monitoring map and GIS field mapping.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current lifecycle state of the monitoring record, from scheduling through completion and quality supervisor sign-off.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestCategory rdf:type rdf:Property ;
    rdfs:label 'Pest Category' ;
    rdfs:comment 'Broad classification of the pest type observed. Supports IPM program reporting, EPA regulatory submissions, and trend analysis across monitoring locations. [ENUM-REF-CANDIDATE: insect|rodent|weed|fungal|bacterial|nematode|bird|other — promote to reference product]' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestSpecies rdf:type rdf:Property ;
    rdfs:label 'Pest Species' ;
    rdfs:comment 'Scientific or common name of the pest species identified during scouting (e.g., Helicoverpa armigera, aphid, rodent). Null for sanitation-type monitoring records. Used for IPM decision-making and EPA pesticide use justification.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCount rdf:type rdf:Property ;
    rdfs:label 'Population Count' ;
    rdfs:comment 'Number of individual pests observed or captured at the monitoring location during the scouting event. Used to compare against economic threshold and action threshold values for IPM decision-making.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rinseVerificationPassed rdf:type rdf:Property ;
    rdfs:label 'Rinse Verification Passed' ;
    rdfs:comment 'Indicates whether the post-sanitation rinse verification check was passed, confirming removal of cleaning agent residues from food-contact surfaces. True = passed; False = failed, requiring re-sanitation.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanitationEventType rdf:type rdf:Property ;
    rdfs:label 'Sanitation Event Type' ;
    rdfs:comment 'Classification of the sanitation activity performed: pre-operational (before production), operational (during production), post-harvest (after harvest), allergen changeover (between allergen-containing runs), or environmental (scheduled environmental monitoring). Null for pest scouting records.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Signoff Timestamp' ;
    rdfs:comment 'Date and time when the quality supervisor reviewed and approved the monitoring record. Required for FSMA preventive controls documentation and GFSI audit evidence.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trapPlacementDate rdf:type rdf:Property ;
    rdfs:label 'Trap Placement Date' ;
    rdfs:comment 'Date the trap or monitoring device was placed at the monitoring location. Used to calculate trap exposure duration and assess catch rate per day.' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trapType rdf:type rdf:Property ;
    rdfs:label 'Trap Type' ;
    rdfs:comment 'Type of monitoring device or scouting method used to detect or capture pests. Null for sanitation records. [ENUM-REF-CANDIDATE: sticky_trap|pheromone_trap|light_trap|pitfall_trap|bait_station|visual_count|sweep_net — promote to reference product]' ;
    rdfs:domain ind:FacilityMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryHaccpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Haccp Employee Id' ;
    rdfs:comment 'Reference to the qualified individual designated as the HACCP team leader responsible for plan development, maintenance, and regulatory compliance. Corresponds to Codex Alimentarius Step 1 (assemble HACCP team).' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:biologicalHazardsIdentified rdf:type rdf:Property ;
    rdfs:label 'Biological Hazards Identified' ;
    rdfs:comment 'Indicates whether biological hazards (e.g., Salmonella, E. coli O157:H7, Listeria monocytogenes) were identified as significant hazards requiring a Critical Control Point (CCP) in this HACCP plan.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpCount rdf:type rdf:Property ;
    rdfs:label 'Ccp Count' ;
    rdfs:comment 'Total number of Critical Control Points (CCPs) identified and documented within this HACCP plan. Used for plan completeness validation and audit readiness checks.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccpDescription rdf:type rdf:Property ;
    rdfs:label 'Ccp Description' ;
    rdfs:comment 'Narrative description of the CCP process step where control is applied (e.g., \'Pasteurization heat treatment\', \'Metal detection at packaging line exit\', \'Chlorine wash for fresh produce\').' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpNumber rdf:type rdf:Property ;
    rdfs:label 'Ccp Number' ;
    rdfs:comment 'Unique identifier for a specific Critical Control Point within the HACCP plan (e.g., CCP-1B for biological, CCP-2C for chemical, CCP-3P for physical). Used to cross-reference monitoring logs and corrective action records.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalHazardsIdentified rdf:type rdf:Property ;
    rdfs:label 'Chemical Hazards Identified' ;
    rdfs:comment 'Indicates whether chemical hazards (e.g., pesticide residues exceeding MRL, allergens, mycotoxins, heavy metals, cleaning chemical residues) were identified as significant hazards in this HACCP plan.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionProcedure rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Procedure' ;
    rdfs:comment 'Documented procedure to be followed when a deviation from the critical limit is detected at the CCP, including product disposition, process correction, and root cause investigation steps. Corresponds to Codex Alimentarius Principle 5.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitDescription rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Description' ;
    rdfs:comment 'Documented critical limit(s) for each CCP that distinguish safe from unsafe product (e.g., \'Internal temperature ≥ 72°C for ≥ 15 seconds\', \'Chlorine concentration 50–200 ppm\', \'Metal detector sensitivity: 1.5mm ferrous\'). Corresponds to Codex Alimentarius Principle 3.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether any active deviation from a critical limit has been recorded against this HACCP plan in the current monitoring period. True signals that a corrective action is open or pending closure.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaPreventiveControlsApplicable rdf:type rdf:Property ;
    rdfs:label 'Fsma Preventive Controls Applicable' ;
    rdfs:comment 'Indicates whether this HACCP plan is subject to the FDA Food Safety Modernization Act (FSMA) Preventive Controls for Human Food rule (21 CFR Part 117). False may apply to exempt facilities or animal food operations governed by a separate rule.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Documented intended use and consumer population for the product covered by this plan, including whether the product is intended for vulnerable populations (e.g., infants, immunocompromised). Informs hazard severity assessment.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'Description of the procedure, instrument, or technique used to monitor the CCP parameter (e.g., \'Calibrated digital thermometer\', \'Inline pH meter\', \'Metal detector test piece challenge\'). Supports equipment calibration traceability.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringParameter rdf:type rdf:Property ;
    rdfs:label 'Monitoring Parameter' ;
    rdfs:comment 'The physical or chemical parameter measured at the CCP to verify the critical limit is being met (e.g., temperature in °C, pH, chlorine concentration in ppm, metal detector sensitivity in mm). Corresponds to Codex Alimentarius Principle 4. [ENUM-REF-CANDIDATE: temperature|pH|chlorine_concentration|metal_detector_sensitivity|water_activity|time|pressure|flow_rate|turbidity|conductivity|other — promote to reference product]' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalHazardsIdentified rdf:type rdf:Property ;
    rdfs:label 'Physical Hazards Identified' ;
    rdfs:comment 'Indicates whether physical hazards (e.g., metal fragments, glass, bone, hard plastic, stones) were identified as significant hazards requiring a CCP such as metal detection or X-ray inspection in this HACCP plan.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planScope rdf:type rdf:Property ;
    rdfs:label 'Plan Scope' ;
    rdfs:comment 'Defines the operational scope of the HACCP plan — whether it covers an entire facility, a specific process line, a commodity category, or a specific finished product. Determines applicability during audits.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisitePrograms rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Programs' ;
    rdfs:comment 'List of prerequisite programs (PRPs) supporting this HACCP plan, such as Good Manufacturing Practices (GMP), sanitation standard operating procedures (SSOPs), pest control, and allergen management programs. PRPs are foundational controls that underpin the HACCP system.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processDescription rdf:type rdf:Property ;
    rdfs:label 'Process Description' ;
    rdfs:comment 'Narrative description of the production or processing scope covered by this HACCP plan, including process flow steps from raw material receipt through finished product dispatch. Required by Codex Alimentarius Step 4 (process flow diagram description).' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordkeepingRequirements rdf:type rdf:Property ;
    rdfs:label 'Recordkeeping Requirements' ;
    rdfs:comment 'Description of the records that must be maintained to document HACCP plan implementation, including monitoring logs, corrective action records, verification records, and retention periods. Corresponds to Codex Alimentarius Principle 7.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationProcedure rdf:type rdf:Property ;
    rdfs:label 'Verification Procedure' ;
    rdfs:comment 'Documented activities used to confirm the HACCP plan is functioning effectively, including calibration schedules, record review, periodic product testing, and internal audits. Corresponds to Codex Alimentarius Principle 6.' ;
    rdfs:domain ind:HaccpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition decision for the held lot. \'release\' — lot approved for normal use; \'rework\' — lot requires reprocessing before use; \'destroy\' — lot condemned and destroyed; \'return_to_supplier\' — lot returned to originating supplier; \'downgrade\' — lot approved for lower-grade use; \'pending\' — disposition not yet determined.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Narrative explanation supporting the final disposition decision, including reference to test results, regulatory guidance, or management approval. Required for FSMA and GFSI audit documentation.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Hold Cost Estimate' ;
    rdfs:comment 'Estimated financial impact of the hold in USD, including potential product loss, rework costs, and operational disruption. Used for financial reporting, COGS impact assessment, and management decision-making.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdDurationHours rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Hours' ;
    rdfs:comment 'Total elapsed time in hours from hold initiation to release or current timestamp if still open. Stored as a business field to support SLA monitoring and regulatory reporting without requiring real-time calculation.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Timestamp' ;
    rdfs:comment 'The exact date and time the hold was formally initiated and the lot was placed under restriction. This is the principal business event timestamp for the hold record lifecycle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdLocationCode rdf:type rdf:Property ;
    rdfs:label 'Hold Location Code' ;
    rdfs:comment 'Specific location identifier (bin number, warehouse zone, field block ID, or processing line code) where the held material is physically segregated. Used for warehouse management and physical audit trail.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdLocationType rdf:type rdf:Property ;
    rdfs:label 'Hold Location Type' ;
    rdfs:comment 'Classification of the physical location type where the held material is stored or segregated. Supports warehouse management integration and physical segregation compliance.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'The date and time the hold was formally released and the lot was returned to unrestricted status. Null if the hold is still active. Used to calculate hold duration and measure quality response time KPIs.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'The total quantity of the commodity or product placed under hold, expressed in the unit of measure specified in quantity_uom. Critical for disposition planning and financial impact assessment.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallPotential rdf:type rdf:Property ;
    rdfs:label 'Recall Potential' ;
    rdfs:comment 'Indicates whether this hold has been assessed as having potential to escalate to a product recall. True triggers recall readiness protocols and senior management notification per FSMA and FDA recall procedures.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapUsageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Usage Decision Code' ;
    rdfs:comment 'The SAP QM module usage decision code recorded in SAP S/4HANA at the time of disposition (e.g., A1 — Accepted, R1 — Rejected, R2 — Rework). Enables direct integration and reconciliation with the ERP system of record.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Date' ;
    rdfs:comment 'Date on which the supplier was formally notified of the hold. Null if supplier_notified is False. Used for supplier quality management and contractual compliance tracking.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierNotified rdf:type rdf:Property ;
    rdfs:label 'Supplier Notified' ;
    rdfs:comment 'Indicates whether the originating supplier has been formally notified of the hold. Required for return-to-supplier disposition and supplier quality management processes.' ;
    rdfs:domain ind:HoldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The calendar date on which the inspection was actually performed. May differ from scheduled_date due to rescheduling or operational delays.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gapModuleAgWaterScore rdf:type rdf:Property ;
    rdfs:label 'Gap Module Ag Water Score' ;
    rdfs:comment 'Module-level compliance score for the Agricultural Water section of a GAP compliance assessment. Evaluates water source testing, microbial standards, irrigation method risk, and water quality records per FSMA and USDA GAP requirements.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapModuleFieldSanitationScore rdf:type rdf:Property ;
    rdfs:label 'Gap Module Field Sanitation Score' ;
    rdfs:comment 'Module-level compliance score for the Field Sanitation and Hygiene section of a GAP compliance assessment. Evaluates toilet facilities, handwashing stations, field equipment sanitation, and harvest container cleanliness.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapModuleSoilAmendmentsScore rdf:type rdf:Property ;
    rdfs:label 'Gap Module Soil Amendments Score' ;
    rdfs:comment 'Module-level compliance score for the Soil Amendments section of a GAP compliance assessment. Evaluates manure application intervals, compost treatment standards, and biological soil amendment risk management.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapModuleTraceabilityScore rdf:type rdf:Property ;
    rdfs:label 'Gap Module Traceability Score' ;
    rdfs:comment 'Module-level compliance score for the Traceability and Recordkeeping section of a GAP compliance assessment. Evaluates lot identification, harvest records, chain-of-custody documentation, and recall readiness.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapModuleWorkerHealthScore rdf:type rdf:Property ;
    rdfs:label 'Gap Module Worker Health Score' ;
    rdfs:comment 'Module-level compliance score for the Worker Health, Hygiene, and Training section of a GAP compliance assessment. Evaluates handwashing facilities, illness policies, training records, and personal hygiene practices per FSMA Produce Safety Rule requirements.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorCredential rdf:type rdf:Property ;
    rdfs:label 'Inspector Credential' ;
    rdfs:comment 'Certification or credential held by the inspector (e.g., PCQI - Preventive Controls Qualified Individual, Lead Auditor ISO 22000, GLOBALG.A.P. approved CB auditor). Validates inspector qualification for the inspection type.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Scheduled date for the follow-up re-inspection when reinspection_required is true. Used for compliance calendar management and audit scheduling.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether a follow-up re-inspection is required to verify corrective action completion or to re-evaluate a failed inspection outcome.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Event Id' ;
    rdfs:comment 'Reference to the parent inspection or audit event that generated this finding. Links the finding to its originating quality event (inspection run, audit session, or certification visit).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Reference to the party (internal auditor, second-party customer auditor, or third-party certification body inspector) who identified and recorded this finding. Supports auditor qualification tracking and finding pattern analysis.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorFindingInspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Inspection Finding Id' ;
    rdfs:comment 'Reference to the earlier finding record that this finding is a recurrence of. Populated when repeat_finding_flag is True. Enables trend analysis and systemic non-conformance identification across audit cycles.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:safetyEventId rdf:type rdf:Property ;
    rdfs:label 'Safety Event Id' ;
    rdfs:comment 'Foreign key linking to workforce.safety_event. Business justification: Inspection findings related to WPS violations, pesticide handler exposure, or worker safety GMP failures directly correspond to safety incidents. Agriculture regulators (EPA WPS, OSHA) require cross-r' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyEvent .

ind:ccpReference rdf:type rdf:Property ;
    rdfs:label 'Ccp Reference' ;
    rdfs:comment 'Identifier of the HACCP Critical Control Point (CCP) associated with this finding, if applicable (e.g., CCP-01 Thermal Processing, CCP-02 Metal Detection). Links the finding to the HACCP plan for hazard analysis and corrective action tracking.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDueDate rdf:type rdf:Property ;
    rdfs:label 'Closure Due Date' ;
    rdfs:comment 'Deadline by which the corrective action must be fully implemented and the finding verified as closed. Distinct from response_due_date (plan submission) — this is the implementation completion deadline. Used for certification readiness tracking.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when this finding was identified or observed during the inspection or audit. Distinct from record creation audit timestamp. Critical for PHI (Pre-Harvest Interval) and REI (Restricted Entry Interval) compliance timelines.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or URL to supporting evidence documents (photographs, laboratory test results, COA, temperature logs, pesticide application records) stored in the document management system. Supports audit trail completeness and regulatory submission packages.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the finding per food safety and quality management standards. Critical = immediate food safety risk or regulatory violation; Major = significant non-conformance likely to result in product failure; Minor = partial non-conformance; Observation = noted deviation not yet non-conforming; Opportunity for Improvement (OFI) = best-practice recommendation. Drives corrective action urgency and certification impact.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Food Safety Risk Flag' ;
    rdfs:comment 'Indicates whether this finding poses a direct food safety risk requiring immediate escalation under HACCP or FSMA protocols. When True, triggers mandatory notification workflows to the food safety team and may require product hold or recall assessment.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapGmpCategory rdf:type rdf:Property ;
    rdfs:label 'Gap Gmp Category' ;
    rdfs:comment 'Categorizes the finding within the GAP/GMP compliance framework. Supports structured reporting to USDA, FDA, and GLOBALG.A.P. certification bodies and enables category-level trend analysis for continuous improvement programs. [ENUM-REF-CANDIDATE: GAP|GMP|HACCP|sanitation|traceability|pest_control|water_quality|worker_health|equipment|documentation — promote to reference product]' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionArea rdf:type rdf:Property ;
    rdfs:label 'Inspection Area' ;
    rdfs:comment 'The physical area, zone, process step, or operational unit where the finding was identified (e.g., receiving dock, cold storage, processing line 3, field block A, irrigation system). Supports spatial analysis of non-conformance patterns.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Free-text field for additional contextual notes, observations, or recommendations recorded by the inspector or auditor at the time of the finding. Supplements the structured finding_description with qualitative context for root cause analysis.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipmRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Ipm Related Flag' ;
    rdfs:comment 'Indicates whether this finding is related to Integrated Pest Management (IPM) program compliance, including pest scouting records, pesticide application logs, PHI (Pre-Harvest Interval) adherence, or REI (Restricted Entry Interval) compliance.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectiveEvidence rdf:type rdf:Property ;
    rdfs:label 'Objective Evidence' ;
    rdfs:comment 'Factual, verifiable evidence supporting the finding — records reviewed, measurements taken, observations made, or interviews conducted. Required by ISO 19011 and all GFSI scheme auditing protocols to substantiate the finding classification.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEventType rdf:type rdf:Property ;
    rdfs:label 'Parent Event Type' ;
    rdfs:comment 'Discriminator indicating whether the parent event was a quality inspection (routine operational check) or a formal audit (internal, second-party, or third-party certification audit). Drives workflow routing and reporting.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this finding must be reported to a regulatory authority (USDA, FDA, FSIS, EPA, APHIS). When True, triggers mandatory regulatory notification workflows and documentation requirements under FSMA, FSIS directives, or EPA regulations.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Rating' ;
    rdfs:comment 'Risk-based severity assessment of the finding\'s potential impact on food safety, product quality, regulatory compliance, or business continuity. Distinct from finding_classification (which is scheme-defined); this is the internal risk management rating used for prioritization and HACCP hazard analysis alignment.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardClauseReference rdf:type rdf:Property ;
    rdfs:label 'Standard Clause Reference' ;
    rdfs:comment 'The specific clause, control point, element, or requirement number within the applicable standard scheme against which this finding was raised (e.g., FSMA 21 CFR Part 117.135, GLOBALG.A.P. CB.7.1, SQF Element 2.4.3, BRC Clause 4.11.2, IFS Requirement 4.18.1). Essential for certification body reporting and corrective action traceability.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedClosedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Closed Date' ;
    rdfs:comment 'Actual date on which the finding was verified as effectively closed following corrective action implementation. Populated by the verifying auditor or quality manager. Used to calculate closure cycle time and assess corrective action effectiveness.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collected By Employee Id' ;
    rdfs:comment 'Reference to the employee or field technician who physically collected the sample. Required for chain-of-custody documentation and FSMA traceability.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Reference to the SAP QM inspection lot under which this sample was collected. Links the lab sample to the broader quality inspection event in the ERP system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:testPanelId rdf:type rdf:Property ;
    rdfs:label 'Test Panel Id' ;
    rdfs:comment 'Reference to the requested test panel defining the suite of analytical tests to be performed on this sample (e.g., pesticide residue panel, mycotoxin panel, microbiological panel, nutritional panel).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestPanel .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique identifier for the chain-of-custody document accompanying this sample from collection through laboratory receipt. Provides legal defensibility for test results and supports FSMA traceability and regulatory inspection readiness.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPointDescription rdf:type rdf:Property ;
    rdfs:label 'Collection Point Description' ;
    rdfs:comment 'Specific description of the exact collection point within the facility or field (e.g., \'North field block 3, row 12\', \'Bin 7 - top layer\', \'Processing Line 2 - post-wash CCP\'). Provides granular traceability beyond the collection point type classification.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPointType rdf:type rdf:Property ;
    rdfs:label 'Collection Point Type' ;
    rdfs:comment 'Classification of the physical location or process stage where the sample was collected. Supports field-to-COA traceability and HACCP critical control point mapping. Values: field (in-crop collection), bin (grain storage), processing_line (in-process), receiving_dock (incoming goods), storage (warehouse), transport (in-transit).' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaSamplingPlanRef rdf:type rdf:Property ;
    rdfs:label 'Fsma Sampling Plan Ref' ;
    rdfs:comment 'Reference code or document identifier for the FSMA-compliant sampling plan under which this sample was collected. Supports FDA inspection readiness and FSMA Subpart O environmental monitoring and food safety plan documentation. Aligns with FSMA business jargon.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiSchemeCode rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme Code' ;
    rdfs:comment 'Identifies the GFSI-benchmarked certification scheme under which this sample was collected or is being used to demonstrate compliance. Supports certification audit readiness for SQF, BRC, IFS, and GLOBALG.A.P. schemes. Aligns with GFSI, SQF, BRC, IFS business jargons.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Flag' ;
    rdfs:comment 'Indicates whether this sample was collected as part of HACCP (Hazard Analysis and Critical Control Points) critical control point monitoring or verification activities. True requires enhanced documentation and regulatory retention per FSMA Preventive Controls rule. Aligns with HACCP business jargon.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Compliance Flag' ;
    rdfs:comment 'Indicates whether the sample collection date was verified to be after the required Pre-Harvest Interval (PHI) for any applied crop protection products. True confirms PHI compliance at time of sampling. Critical for pesticide residue MRL compliance. Aligns with PHI business jargon.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedAtLabTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received At Lab Timestamp' ;
    rdfs:comment 'Date and time when the sample was officially received and logged at the testing laboratory. Used to calculate sample transit time, assess sample integrity, and enforce holding time limits per analytical method requirements.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Required Completion Date' ;
    rdfs:comment 'Target date by which laboratory testing and result reporting must be completed. Drives laboratory scheduling, SLA monitoring, and release-hold decisions for production lots awaiting quality clearance.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultsReleasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Results Released Timestamp' ;
    rdfs:comment 'Date and time when the laboratory officially released the test results and COA. Marks the completion of the testing lifecycle and triggers downstream quality disposition workflows in SAP QM.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleCondition rdf:type rdf:Property ;
    rdfs:label 'Sample Condition' ;
    rdfs:comment 'Assessment of the physical condition of the sample upon receipt at the laboratory. Acceptable: sample integrity maintained; Compromised: minor integrity issues noted but testing may proceed with caveats; Rejected: sample integrity failed, testing cannot proceed. Drives chain-of-custody decisions.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleNotes rdf:type rdf:Property ;
    rdfs:label 'Sample Notes' ;
    rdfs:comment 'Free-text field for additional observations, anomalies, or contextual information recorded at the time of sample collection or receipt. Captures field conditions, equipment calibration notes, or deviations from standard sampling protocol that may affect result interpretation.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Measured quantity of material collected for the sample (e.g., weight in grams, volume in milliliters). Used to verify adequacy of sample size per analytical method requirements and sampling plan specifications.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity field. Standard units include grams (g), kilograms (kg), milliliters (mL), liters (L), milligrams (mg), and ounces (oz). Must align with the unit specified in the analytical method.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Code' ;
    rdfs:comment 'Classification of why this sample was collected relative to the sampling plan schedule. Routine: scheduled periodic sampling; Triggered: collected in response to an event or non-conformance; Regulatory: mandated by USDA/FDA/EPA inspection; Verification: HACCP verification sampling; Validation: process or method validation sampling.' ;
    rdfs:domain ind:LabSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedExportMarket rdf:type rdf:Property ;
    rdfs:label 'Affected Export Market' ;
    rdfs:comment 'ISO 3-letter country code(s) of export markets impacted by the MRL exceedance or food safety incident. Drives market withdrawal decisions and trade compliance actions.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Affected Value Usd' ;
    rdfs:comment 'Estimated financial value of the affected product or commodity in US dollars. Used for financial impact assessment, insurance claims, and EBITDA impact reporting.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectedResidueLevel rdf:type rdf:Property ;
    rdfs:label 'Detected Residue Level' ;
    rdfs:comment 'Measured pesticide residue concentration in mg/kg (ppm) as determined by laboratory analysis. Populated for nonconformance_type = \'mrl_exceedance\'. Compared against applicable MRL standard.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Calendar date on which the nonconformance was first identified or detected. Used for regulatory reporting timelines and corrective action due date calculations.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'Stage in the production or supply chain where the nonconformance was detected. Supports root cause analysis and process improvement targeting. [ENUM-REF-CANDIDATE: receiving|in_process|finished_goods|storage|dispatch|field|customer_complaint|audit|laboratory — promote to reference product]' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyIncidentSubtype rdf:type rdf:Property ;
    rdfs:label 'Food Safety Incident Subtype' ;
    rdfs:comment 'Specific category of food safety incident. Populated only when nonconformance_type = \'food_safety_incident\'. Drives HACCP critical control point review and regulatory reporting requirements.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapAuditFindingRef rdf:type rdf:Property ;
    rdfs:label 'Gap Audit Finding Ref' ;
    rdfs:comment 'Reference number linking this nonconformance to a specific GAP or GMP audit finding. Enables traceability between audit programs and resulting nonconformance records.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'HACCP hazard classification for food safety incidents. Categorizes the nature of the food safety hazard to guide risk assessment and control measure selection.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Closure Status' ;
    rdfs:comment 'Detailed closure workflow status for food safety incidents and major nonconformances. Tracks progression from initial detection through CAPA verification and regulatory sign-off.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mockRecallFlag rdf:type rdf:Property ;
    rdfs:label 'Mock Recall Flag' ;
    rdfs:comment 'Indicates whether this record represents a mock/simulated recall exercise rather than an actual recall event. Required for GFSI, SQF, BRC, and GLOBALG.A.P. certification audit readiness.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncStatus rdf:type rdf:Property ;
    rdfs:label 'Nc Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record within the quality management workflow.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceType rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Type' ;
    rdfs:comment 'Classification of the nonconformance category. \'product\' = physical product defect; \'process\' = deviation from SOP/GMP; \'system\' = management system gap; \'mrl_exceedance\' = Maximum Residue Limit (MRL) exceedance; \'food_safety_incident\' = HACCP/FSMA food safety event.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qm Notification Number' ;
    rdfs:comment 'External quality notification number from SAP S/4HANA QM module (Q-notification). Serves as the cross-system business identifier for this nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgenciesNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agencies Notified' ;
    rdfs:comment 'Comma-separated list of regulatory agencies formally notified of this nonconformance (e.g., FDA, USDA, FSIS, EPA, APHIS). Populated when regulatory_notification_required is True.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or employee identifier of the person who initially reported or raised the nonconformance. Supports accountability tracking and audit trail requirements.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The national or international accreditation body that accredits the certification body (e.g., ANAB - ANSI National Accreditation Board, UKAS - United Kingdom Accreditation Service, DAkkS). Validates the legitimacy of the certification body and is required for GFSI scheme recognition.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The name of the accredited third-party certification body or registrar that issued the certificate (e.g., NSF International, SGS, Bureau Veritas, DNV, Intertek). Required for regulatory reporting to USDA, FDA, and FSIS and for GFSI scheme compliance.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiSchemeFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme Flag' ;
    rdfs:comment 'Indicates whether this certification is recognized under the Global Food Safety Initiative (GFSI) benchmarking framework (True) or is a non-GFSI scheme (False). GFSI-recognized schemes include SQF, BRC, IFS, FSSC 22000, and GLOBALG.A.P. Critical for customer and retailer compliance requirements.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalgApProducerNumber rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Producer Number' ;
    rdfs:comment 'The unique GLOBALG.A.P. producer or certificate number assigned by the GLOBALG.A.P. secretariat and published in the GLOBALG.A.P. database. Required for GLOBALG.A.P. certification verification by buyers and retailers.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeOrLevel rdf:type rdf:Property ;
    rdfs:label 'Grade Or Level' ;
    rdfs:comment 'The grade, level, or rating awarded by the certification body upon successful audit (e.g., SQF Level 2, SQF Level 3, BRC Grade AA/A/B/C/D, IFS Higher Level/Foundation Level). Null for schemes that do not use graded outcomes. Used for benchmarking and customer qualification.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Certification Date' ;
    rdfs:comment 'The date on which the facility or operation first achieved certification under this scheme, regardless of subsequent renewals. Used to calculate certification tenure and demonstrate long-standing compliance to customers and regulators.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isccCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iscc Certificate Number' ;
    rdfs:comment 'The unique certificate number issued under the International Sustainability and Carbon Certification (ISCC) scheme for bioenergy and biomass sustainability compliance. Null for non-ISCC certifications.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Site Flag' ;
    rdfs:comment 'Indicates whether this certificate covers multiple sites or facilities under a single certificate number (True) or a single site (False). Multi-site certifications are common for GLOBALG.A.P. Option 2 and BRC multi-site schemes.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonconformanceCountMajor rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count Major' ;
    rdfs:comment 'The number of major non-conformances identified during the most recent certification audit. Major non-conformances require corrective action within a defined timeframe and may result in certification suspension if unresolved. Tracked per SAP S/4HANA QM module non-conformance records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonconformanceCountMinor rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count Minor' ;
    rdfs:comment 'The number of minor non-conformances identified during the most recent certification audit. Minor non-conformances require corrective action but do not immediately threaten certification status. Tracked per SAP S/4HANA QM module.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'The product category or commodity type covered by the certification scope as defined by the scheme (e.g., GLOBALG.A.P. crop category: Fruit and Vegetables; BRC product category: Fresh Produce; SQF food sector category). Supports product-level compliance mapping.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Name or employee identifier of the internal quality manager or food safety coordinator responsible for maintaining this certification and managing the renewal process. Supports accountability tracking and escalation workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeName rdf:type rdf:Property ;
    rdfs:label 'Scheme Name' ;
    rdfs:comment 'The name of the food safety or quality certification scheme under which the certificate was issued (e.g., Safe Quality Food (SQF), British Retail Consortium (BRC), International Featured Standards (IFS), GLOBALG.A.P., ISO 22000, USDA Organic/National Organic Program (NOP), International Sustainability and Carbon Certification (ISCC), Fair Trade). Drives certification readiness dashboards and renewal workflows.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeVersion rdf:type rdf:Property ;
    rdfs:label 'Scheme Version' ;
    rdfs:comment 'The edition or version number of the certification scheme standard under which the audit was conducted (e.g., SQF Edition 9, BRC Issue 9, IFS Food Version 8). Critical for tracking standard upgrades and ensuring compliance with the current scheme revision.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaOrganicOpNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Organic Op Number' ;
    rdfs:comment 'The USDA National Organic Program (NOP) operation number assigned to the certified organic operation. Required for USDA organic labeling compliance and traceability under the National Organic Program regulations.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSubmissionRegulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Parent Submission Regulatory Submission Id' ;
    rdfs:comment 'Self-referencing identifier linking this submission to a prior submission it amends, supersedes, or is a resubmission of. Enables tracking of submission amendment chains and version history.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:agencyConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Confirmation Number' ;
    rdfs:comment 'The unique confirmation or tracking number issued by the regulatory agency upon receipt of the submission (e.g., FDA Prior Notice Confirmation Number, USDA permit number). Distinct from the internal submission_number.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseCode rdf:type rdf:Property ;
    rdfs:label 'Agency Response Code' ;
    rdfs:comment 'Standardized code representing the regulatory agency\'s official determination or response to this submission. Distinct from submission_status which reflects internal workflow state.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Agency Response Notes' ;
    rdfs:comment 'Free-text notes or summary of the regulatory agency\'s official response, determination letter, or feedback received. Captures key findings, conditions of approval, or required corrective actions mandated by the agency.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the internal compliance officer, regulatory affairs specialist, or team responsible for managing this submission through its lifecycle. Supports workflow assignment and accountability tracking.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Description of the agricultural commodity, product, or food category that is the subject of this regulatory submission (e.g., fresh produce, processed grain, livestock, pesticide product). Supports COOL (Country of Origin Labeling) and traceability reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether this submission contains confidential business information (CBI) as designated under applicable regulatory frameworks (e.g., EPA CBI claims under FIFRA, FDA trade secret designations). True if CBI protections apply.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCounselRef rdf:type rdf:Property ;
    rdfs:label 'External Counsel Ref' ;
    rdfs:comment 'Reference to external legal counsel or regulatory consultant engaged to support this submission, where applicable. Captures the firm name or engagement reference for attorney-client privilege tracking.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRuleCategory rdf:type rdf:Property ;
    rdfs:label 'Fsma Rule Category' ;
    rdfs:comment 'Specific FSMA (Food Safety Modernization Act) rule category applicable to this submission. Enables granular FSMA compliance tracking across the seven major rules. Null if submission is not FSMA-related.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated_penalty_amount (e.g., USD for US Dollar). Supports multi-currency financial risk reporting for international operations.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'The date on which the official response, acknowledgment, or determination was received from the regulatory agency following the submission. Null if no response has been received yet.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required' ;
    rdfs:comment 'Indicates whether the regulatory agency has required a resubmission or amendment to this filing due to deficiencies, missing information, or rejection. True if resubmission is required; False otherwise.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDescription rdf:type rdf:Property ;
    rdfs:label 'Submission Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory submission, including the scope, purpose, and any relevant context about the filing obligation, the triggering event, or the regulatory requirement being fulfilled.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this submission, either by the submitting organization or by the receiving regulatory agency upon acknowledgment. Used for tracking and correspondence (e.g., FDA registration number, USDA permit number).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Submission Period End' ;
    rdfs:comment 'The end date of the reporting or compliance period covered by this submission. Together with submission_period_start, defines the temporal scope of the regulatory report.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Submission Period Start' ;
    rdfs:comment 'The start date of the reporting or compliance period covered by this submission (e.g., start of the annual pesticide use reporting period, beginning of the organic certification cycle). Applicable for periodic filings.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory submission as tracked by the quality and compliance team. Reflects the last known status from the regulatory agency or internal workflow.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTitle rdf:type rdf:Property ;
    rdfs:label 'Submission Title' ;
    rdfs:comment 'Descriptive title or name of the regulatory submission as used in official correspondence and internal tracking (e.g., \'Annual Pesticide Use Report FY2024\', \'FSMA Facility Registration Renewal\', \'Organic Certification Application - North Farm\').' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Classification of the regulatory submission by its purpose and program. [ENUM-REF-CANDIDATE: fsma_facility_registration|reportable_food_registry|pesticide_use_report|organic_certification_application|export_health_certificate|prior_notice|adverse_event_report|label_approval|import_permit|environmental_compliance_report — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperatorId rdf:type rdf:Property ;
    rdfs:label 'Cooperator Id' ;
    rdfs:comment 'Foreign key linking to research.cooperator. Business justification: Cooperator qualification assessment is a named QA process: before authorizing external farm cooperators for research trials, quality teams assess their GAP compliance, facility standards, and food saf' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cooperator .

ind:previousAssessmentSupplierAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Previous Assessment Supplier Assessment Id' ;
    rdfs:comment 'Reference to the immediately preceding supplier assessment record for the same supplier, enabling longitudinal performance tracking and trend analysis across assessment cycles.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAssessment .

ind:primarySupplierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Employee Id' ;
    rdfs:comment 'Reference to the internal employee or qualified auditor responsible for conducting and signing off on the supplier assessment. Links to the workforce/employee master record.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Due Date' ;
    rdfs:comment 'Scheduled deadline by which the assessment must be completed. Used for compliance monitoring and procurement quality gate enforcement.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Externally-visible business identifier for the assessment record, used in correspondence, audit trails, and regulatory submissions. Format: SA-YYYY-NNNNNN.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Number' ;
    rdfs:comment 'Reference number of the formal assessment report document issued upon completion. Used for document management, regulatory submission, and audit trail purposes.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'Name of the organization conducting the assessment — may be internal quality team, a third-party certification body (e.g., NSF, SGS, Bureau Veritas), or a regulatory agency. Distinguishes first-party, second-party, and third-party assessments.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsvpVerified rdf:type rdf:Property ;
    rdfs:label 'Fsvp Verified' ;
    rdfs:comment 'Indicates whether the supplier has been verified under the FSMA Foreign Supplier Verification Program (FSVP) requirements. Applicable to foreign suppliers of food for human or animal consumption imported into the United States.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardAnalysisConducted rdf:type rdf:Property ;
    rdfs:label 'Hazard Analysis Conducted' ;
    rdfs:comment 'Indicates whether a formal HACCP-based hazard analysis was conducted as part of this supplier assessment to identify biological, chemical, and physical hazards associated with the supplied inputs.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reassessment Due Date' ;
    rdfs:comment 'Date by which the next periodic or follow-up supplier assessment must be completed. Drives automated reassessment scheduling and procurement hold triggers when overdue.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification assigned to the supplier based on assessment findings, product hazard profile, regulatory history, and geographic risk factors. Drives reassessment frequency and procurement control intensity: critical/high require more frequent verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreCoaConsistency rdf:type rdf:Property ;
    rdfs:label 'Score Coa Consistency' ;
    rdfs:comment 'Criterion score (0.00–100.00) evaluating the consistency, accuracy, and completeness of COA documents provided by the supplier across multiple lots and shipments. Measures alignment between declared and tested values.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreDocumentationCompleteness rdf:type rdf:Property ;
    rdfs:label 'Score Documentation Completeness' ;
    rdfs:comment 'Criterion score (0.00–100.00) evaluating the completeness and accuracy of supplier-submitted documentation including COA records, SDS sheets, regulatory certificates, and quality management system documentation.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreFacilityStandards rdf:type rdf:Property ;
    rdfs:label 'Score Facility Standards' ;
    rdfs:comment 'Criterion score (0.00–100.00) evaluating the supplier\'s facility conditions including GMP compliance, sanitation, pest control, infrastructure, and food safety environment as observed during on-site or remote assessment.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreProductConformance rdf:type rdf:Property ;
    rdfs:label 'Score Product Conformance' ;
    rdfs:comment 'Criterion score (0.00–100.00) evaluating the supplier\'s historical product conformance based on COA consistency, MRL compliance, lot rejection rates, and non-conformance incident history.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreRegulatoryCompliance rdf:type rdf:Property ;
    rdfs:label 'Score Regulatory Compliance' ;
    rdfs:comment 'Criterion score (0.00–100.00) evaluating the supplier\'s compliance with applicable regulatory requirements including USDA, FDA, EPA, APHIS registrations, certifications, and inspection records.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Classification of the type of supplier being assessed, reflecting the nature of inputs or services provided. Drives applicable assessment criteria and regulatory requirements. [ENUM-REF-CANDIDATE: seed_supplier|agrochemical_vendor|feed_ingredient_supplier|contract_grower|packaging_material_provider|fertilizer_supplier|equipment_parts_supplier — promote to reference product]' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analyst Signoff Timestamp' ;
    rdfs:comment 'The date and time when the laboratory analyst formally reviewed and signed off on the test result. Required for COA issuance and ISO/IEC 17025 quality system compliance.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dilutionFactor rdf:type rdf:Property ;
    rdfs:label 'Dilution Factor' ;
    rdfs:comment 'The dilution factor applied to the sample prior to analysis. Used to back-calculate the actual concentration in the original sample matrix and ensure accurate MRL compliance determination.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'Broad classification of the test parameter type. Supports regulatory reporting segmentation and HACCP critical control point (CCP) categorization. [ENUM-REF-CANDIDATE: mycotoxin|pesticide_residue|microbiological|physical|chemical|nutritional|heavy_metal|sensory — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantitationLimit rdf:type rdf:Property ;
    rdfs:label 'Quantitation Limit' ;
    rdfs:comment 'The lowest concentration at which the analyte can be quantitatively measured with acceptable precision and accuracy. Distinct from LOD; used for MRL compliance determination and COA reporting.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryPercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Percent' ;
    rdfs:comment 'The percentage recovery of a spiked control sample used to validate the analytical method performance for this test run. Acceptable recovery ranges are defined by AOAC and Codex Alimentarius guidelines (typically 70–120%).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this test result must be reported to a regulatory authority (USDA, FDA, FSIS, EPA, or APHIS). Triggered by failed MRL results, CCP deviations, or mandatory surveillance program requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultType rdf:type rdf:Property ;
    rdfs:label 'Result Type' ;
    rdfs:comment 'Indicates whether this result is an original first-run test, a repeat test, a confirmatory test following a suspect result, or a retest after corrective action. Supports regulatory investigation workflows.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodName rdf:type rdf:Property ;
    rdfs:label 'Test Method Name' ;
    rdfs:comment 'Descriptive name of the analytical method used (e.g., \'AOAC QuEChERS Multi-Residue Pesticide Method\', \'ISO Horizontal Method for Salmonella Detection\'). Complements the method code for COA readability.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-text field for laboratory analyst observations, anomalies, interferences, or qualifications associated with this test result. Supports audit trail documentation and COA footnotes.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPerformedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Performed Timestamp' ;
    rdfs:comment 'The date and time when the analytical test was physically performed in the laboratory. Distinct from sample receipt and result sign-off timestamps. Critical for FSMA traceability and COA dating.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testResultNumber rdf:type rdf:Property ;
    rdfs:label 'Test Result Number' ;
    rdfs:comment 'Externally-known business identifier for this test result, used on Certificates of Analysis (COA) and regulatory submissions. Typically sourced from SAP QM or the laboratory information management system (LIMS).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyValue rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Value' ;
    rdfs:comment 'The expanded measurement uncertainty associated with the test result, expressed in the same unit as the measured value. Required for ISO/IEC 17025 accredited laboratory reporting and MRL compliance boundary decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessionId rdf:type rdf:Property ;
    rdfs:label 'Accession Id' ;
    rdfs:comment 'Primary key for accession' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accession .

ind:accessionName rdf:type rdf:Property ;
    rdfs:label 'Accession Name' ;
    rdfs:comment 'Common or working name assigned to the accession, such as a landrace name, cultivar designation, or experimental line code. Supports identification in field trials and breeding program records.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionNumber rdf:type rdf:Property ;
    rdfs:label 'Accession Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to the germplasm accession at the time of acquisition or registration. Used for cross-referencing with donor organizations, USDA GRIN, and CGIAR databases.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionType rdf:type rdf:Property ;
    rdfs:label 'Accession Type' ;
    rdfs:comment 'Classification of the germplasm accession by its biological and breeding origin. Distinguishes wild relatives, landraces, elite lines, experimental hybrids, obsolete cultivars, and active breeding lines for program targeting and biodiversity reporting. [ENUM-REF-CANDIDATE: wild_relative|landrace|elite_line|experimental_hybrid|obsolete_cultivar|breeding_line — promote to reference product]' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Method or channel through which the accession was acquired. Supports provenance documentation, benefit-sharing compliance, and program cost attribution. [ENUM-REF-CANDIDATE: field_collection|gene_bank_exchange|breeding_program|commercial_purchase|research_collaboration|farmer_donation — promote to reference product]' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aphisDeregulationStatus rdf:type rdf:Property ;
    rdfs:label 'Aphis Deregulation Status' ;
    rdfs:comment 'Regulatory deregulation status under USDA APHIS biotechnology regulations for GMO accessions. Tracks whether the accession has received non-regulated status, is under review, or remains regulated. Required for APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableSeedQuantityG rdf:type rdf:Property ;
    rdfs:label 'Available Seed Quantity G' ;
    rdfs:comment 'Current available quantity of seed stock for this accession measured in grams. Drives regeneration scheduling when stock falls below minimum safety thresholds and supports distribution request fulfillment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgiarAccessionCode rdf:type rdf:Property ;
    rdfs:label 'Cgiar Accession Code' ;
    rdfs:comment 'Cross-reference identifier for this accession in the CGIAR genebank system. Supports international germplasm exchange, biodiversity conservation programs, and compliance with CGIAR open-access policies.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAltitudeM rdf:type rdf:Property ;
    rdfs:label 'Collection Altitude M' ;
    rdfs:comment 'Altitude in meters above sea level at the original collection site. Used in climate adaptation research, ecological niche modeling, and characterization of stress-tolerance traits.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where the germplasm was originally collected. Supports biodiversity provenance tracking, Nagoya Protocol compliance, and country-of-origin reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionLatitude rdf:type rdf:Property ;
    rdfs:label 'Collection Latitude' ;
    rdfs:comment 'GPS latitude coordinate (decimal degrees, WGS84) of the original collection site. Supports geospatial analysis of genetic diversity, climate adaptation modeling, and Esri ArcGIS mapping of germplasm provenance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionLongitude rdf:type rdf:Property ;
    rdfs:label 'Collection Longitude' ;
    rdfs:comment 'GPS longitude coordinate (decimal degrees, WGS84) of the original collection site. Supports geospatial analysis of genetic diversity, climate adaptation modeling, and Esri ArcGIS mapping of germplasm provenance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commonCropName rdf:type rdf:Property ;
    rdfs:label 'Common Crop Name' ;
    rdfs:comment 'Common or vernacular name of the crop species (e.g., Corn, Soybean, Wheat). Used in business reporting, labeling, and communication with non-scientific stakeholders.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorOrganization rdf:type rdf:Property ;
    rdfs:label 'Donor Organization' ;
    rdfs:comment 'Name of the organization, institution, or individual that donated or provided the germplasm accession. Required for benefit-sharing obligations under the Nagoya Protocol and FAO ITPGRFA Material Transfer Agreements (MTAs).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grinAccessionCode rdf:type rdf:Property ;
    rdfs:label 'Grin Accession Code' ;
    rdfs:comment 'Cross-reference identifier for this accession in the USDA GRIN (Germplasm Resources Information Network) database. Enables interoperability with the national germplasm repository and supports USDA regulatory submissions.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipProtectionType rdf:type rdf:Property ;
    rdfs:label 'Ip Protection Type' ;
    rdfs:comment 'Type of intellectual property protection applied to this accession. Determines distribution restrictions, licensing requirements, and Material Transfer Agreement (MTA) obligations for internal and external use.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGerminationTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Germination Test Date' ;
    rdfs:comment 'Date of the most recent germination viability test conducted on this accession. Used to determine when the next viability test is due and to assess current seed health status.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maturityGroup rdf:type rdf:Property ;
    rdfs:label 'Maturity Group' ;
    rdfs:comment 'Maturity group or relative maturity classification of the accession (e.g., soybean maturity groups 0–X, corn relative maturity days). Used for geographic adaptation targeting and trial plot assignment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSafetyQuantityG rdf:type rdf:Property ;
    rdfs:label 'Minimum Safety Quantity G' ;
    rdfs:comment 'Minimum seed quantity threshold in grams below which a regeneration event must be triggered to maintain conservation security. Defined per FAO genebank safety duplication standards.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mta Required Flag' ;
    rdfs:comment 'Indicates whether a Material Transfer Agreement (MTA) is required before this accession can be distributed or shared externally. Driven by IP protection status, donor agreements, and FAO ITPGRFA obligations.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextGerminationTestDate rdf:type rdf:Property ;
    rdfs:label 'Next Germination Test Date' ;
    rdfs:comment 'Scheduled date for the next germination viability test based on storage conditions, current germination rate, and FAO genebank monitoring intervals. Supports proactive conservation management.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organicEligible rdf:type rdf:Property ;
    rdfs:label 'Organic Eligible' ;
    rdfs:comment 'Indicates whether this accession is eligible for use in USDA National Organic Program (NOP) certified production systems. Non-GMO and untreated seed is required for organic eligibility.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ploidyLevel rdf:type rdf:Property ;
    rdfs:label 'Ploidy Level' ;
    rdfs:comment 'Chromosomal ploidy level of the accession (e.g., diploid, tetraploid, hexaploid). Important for breeding compatibility assessments, hybridization planning, and genetic characterization.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvpCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Pvp Certificate Number' ;
    rdfs:comment 'Certificate number issued by the USDA Plant Variety Protection Office for accessions protected under the Plant Variety Protection Act. Required for IP compliance tracking and licensing management.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Phytosanitary quarantine status of the accession as determined by USDA APHIS Plant Protection and Quarantine (PPQ) inspections. Accessions under quarantine cannot be distributed or used in open field trials.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regenerationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regeneration Required Flag' ;
    rdfs:comment 'Indicates whether this accession requires a regeneration cycle due to low seed quantity, low germination rate, or approaching viability threshold. Triggers regeneration planning workflows in the crop improvement program.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyDuplicateLocation rdf:type rdf:Property ;
    rdfs:label 'Safety Duplicate Location' ;
    rdfs:comment 'Name or identifier of the external facility where a safety duplicate of this accession is stored (e.g., Svalbard Global Seed Vault, CGIAR backup site). Required for FAO genebank safety duplication compliance.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traitStackDescription rdf:type rdf:Property ;
    rdfs:label 'Trait Stack Description' ;
    rdfs:comment 'Narrative description of the stacked genetic traits present in this accession, including herbicide tolerance, insect resistance, drought tolerance, and disease resistance traits. Supports breeding program targeting and regulatory documentation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Viability Status' ;
    rdfs:comment 'Current germination viability status of the accession seed stock. Drives regeneration scheduling, distribution eligibility, and conservation priority decisions. Non-viable or low-viability accessions trigger regeneration workflows.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSubmissionBiotechSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Parent Submission Biotech Submission Id' ;
    rdfs:comment 'Self-referencing identifier linking a supplemental or amended submission to its original parent submission record. Supports tracking of submission amendment chains and agency request-for-additional-information (RAI) response packages.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiotechSubmission .

ind:agencyDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Agency Decision Date' ;
    rdfs:comment 'The date on which the regulatory agency issued its final decision (approval, rejection, or conditional approval) on the submission. Null if the submission is still under review.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyDecisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Agency Decision Outcome' ;
    rdfs:comment 'The final regulatory decision issued by the agency upon completion of review. Captures whether the submission was approved, conditionally approved (with stipulations), rejected, withdrawn by the submitter, or resulted in a no-action-required determination.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyProgramOffice rdf:type rdf:Property ;
    rdfs:label 'Agency Program Office' ;
    rdfs:comment 'The specific program office or division within the regulatory agency responsible for reviewing the submission (e.g., APHIS Biotechnology Regulatory Services, EPA Office of Pesticide Programs, FDA Center for Food Safety and Applied Nutrition).' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Agency Receipt Date' ;
    rdfs:comment 'The date the regulatory agency officially acknowledged receipt of the submission. May differ from submission_date if there was a postal or processing delay. Used to calculate official review clock start.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedAgentName rdf:type rdf:Property ;
    rdfs:label 'Authorized Agent Name' ;
    rdfs:comment 'Name of the authorized regulatory agent or legal representative who signed and filed the submission on behalf of the organization. Required for USDA APHIS and EPA filings where a designated agent must be identified.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Claim Flag' ;
    rdfs:comment 'Indicates whether the submission includes a Confidential Business Information (CBI) claim under FOIA exemptions, protecting proprietary data from public disclosure. Relevant for EPA FIFRA and USDA APHIS submissions containing trade secrets.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPackageLocation rdf:type rdf:Property ;
    rdfs:label 'Data Package Location' ;
    rdfs:comment 'URI or file path to the regulatory data package stored in the enterprise document management system or data lake. Points to the compiled submission dossier including study reports, environmental assessments, and supporting scientific data.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketNumber rdf:type rdf:Property ;
    rdfs:label 'Docket Number' ;
    rdfs:comment 'The official docket, petition, or case number assigned by the receiving regulatory agency (e.g., USDA APHIS petition number, EPA registration number, FDA docket number). This is the externally-known identifier used to track the submission within the agency\'s system.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Assessment Required' ;
    rdfs:comment 'Indicates whether a formal Environmental Assessment (EA) or Environmental Impact Statement (EIS) is required under NEPA (National Environmental Policy Act) for this submission. Relevant for USDA APHIS biotech deregulation petitions.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaSubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Number' ;
    rdfs:comment 'The FDA-assigned submission or docket number for food safety consultations, GRAS (Generally Recognized as Safe) notifications, or FSMA research exemption filings. Populated for FDA-directed submissions.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmoSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Submission' ;
    rdfs:comment 'Indicates whether this submission pertains to a genetically modified organism (GMO) or biotech-derived product. True for USDA APHIS deregulation petitions and EPA biotech pesticide registrations; False for conventional variety registrations or FSMA exemptions.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlApplicable rdf:type rdf:Property ;
    rdfs:label 'Mrl Applicable' ;
    rdfs:comment 'Indicates whether Maximum Residue Limit (MRL) establishment or tolerance setting is required as part of this regulatory submission. Relevant for pesticide registration submissions under EPA FIFRA and Codex Alimentarius MRL harmonization.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this submission has been designated as a high-priority filing by the regulatory affairs function, requiring expedited internal review, escalated resource allocation, or accelerated agency engagement.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Public Comment Period End Date' ;
    rdfs:comment 'The closing date of the mandatory public comment period for submissions that require Federal Register publication and public notice (e.g., USDA APHIS deregulation petitions). Null for submissions not subject to public comment.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Free-text field for regulatory affairs staff to record supplemental context, agency communication summaries, internal review comments, or strategic notes related to the submission that do not fit structured fields.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionVersion rdf:type rdf:Property ;
    rdfs:label 'Submission Version' ;
    rdfs:comment 'Version number of the submission package, incremented each time a revised or supplemental data package is filed with the agency in response to agency requests for additional information (RAI) or voluntary amendments.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittingOrganization rdf:type rdf:Property ;
    rdfs:label 'Submitting Organization' ;
    rdfs:comment 'Legal name of the organization formally submitting the regulatory package to the agency. May be the company itself or an authorized third-party regulatory consultant or CRO acting on behalf of the company.' ;
    rdfs:domain ind:BiotechSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:germplasmAccessionId rdf:type rdf:Property ;
    rdfs:label 'Germplasm Accession Id' ;
    rdfs:comment 'Foreign key linking to research.accession. Business justification: Breeding pipeline entries originate from germplasm accessions in the gene bank. breeding_pipeline currently stores germplasm_accession_number as a free-text STRING. Adding germplasm_accession_id FK no' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accession .

ind:primaryBreedingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Breeding Employee Id' ;
    rdfs:comment 'Identifier of the lead breeder, agronomist, or R&D manager who made the formal advancement decision for this pipeline entry. Supports accountability, audit trail, and governance reporting. References the workforce/employee master.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:statisticalResultId rdf:type rdf:Property ;
    rdfs:label 'Statistical Result Id' ;
    rdfs:comment 'Foreign key linking to research.statistical_result. Business justification: Breeding pipeline advancement decisions are based on statistical analysis of multi-environment trial performance. Links pipeline entries to the statistical analysis that supports advancement decisions' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatisticalResult .

ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_target. Business justification: Sustainable agriculture breeding programs explicitly advance varieties to meet corporate sustainability targets (climate resilience, lower input intensity). This link enables pipeline-to-target progre' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Target .

ind:varietyId rdf:type rdf:Property ;
    rdfs:label 'Variety Id' ;
    rdfs:comment 'Reference to the linked variety record in the research.variety product, connecting this pipeline entry to its registered or candidate variety profile including trait stack, PVP certificate, and germplasm accession data.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Variety .

ind:advancementDate rdf:type rdf:Property ;
    rdfs:label 'Advancement Date' ;
    rdfs:comment 'Calendar date on which the formal advancement decision was made for this pipeline entry. Used for pipeline velocity analysis, cycle time KPIs, and R&D governance audit trails.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advancementDecision rdf:type rdf:Property ;
    rdfs:label 'Advancement Decision' ;
    rdfs:comment 'Formal decision outcome for this pipeline entry at the current stage gate review: \'advance\' = proceed to next stage, \'discontinue\' = remove from pipeline, \'hold\' = defer decision, \'repeat-stage\' = re-evaluate at same stage in next cycle. Core field for R&D portfolio management.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aphisSubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Aphis Submission Ref' ;
    rdfs:comment 'Reference number for the USDA APHIS Biotechnology Regulatory Services (BIRS) submission associated with this GMO pipeline entry (e.g., permit number, notification number, or petition number for deregulation). Required for regulatory compliance tracking of biotech crop entries.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedingCycleYear rdf:type rdf:Property ;
    rdfs:label 'Breeding Cycle Year' ;
    rdfs:comment 'The crop year or breeding season in which this pipeline entry was created or is currently being evaluated (e.g., 2024). Used for cohort analysis, R&D cycle tracking, and multi-year pipeline trend reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryName rdf:type rdf:Property ;
    rdfs:label 'Entry Name' ;
    rdfs:comment 'Human-readable working name or experimental designation assigned to this breeding pipeline entry (e.g., \'XB-2024-CORN-F3-07\'). Used by breeders and R&D portfolio managers to identify the entry throughout the crop improvement lifecycle.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReleaseYear rdf:type rdf:Property ;
    rdfs:label 'Estimated Release Year' ;
    rdfs:comment 'Projected calendar year for commercial variety release based on current pipeline stage, advancement velocity, and regulatory timeline. Used for R&D portfolio planning, seed production scheduling, and commercial launch planning.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCrossDescription rdf:type rdf:Property ;
    rdfs:label 'Parent Cross Description' ;
    rdfs:comment 'Description of the parental cross or pedigree used to develop this pipeline entry (e.g., \'A x B\', \'BC2F3 from donor line X\'). Classified confidential due to proprietary breeding program IP. Essential for pedigree traceability and breeding program continuity.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineEntryCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Entry Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this breeding pipeline entry across R&D systems (e.g., Granular Farm Management, SAP S/4HANA PP module). Used as the business key for cross-system reconciliation and USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the breeding pipeline for this entry. Standard stages: F2 (second filial generation), F3 (third filial generation), BC (backcross), PYT (Preliminary Yield Trial), AYT (Advanced Yield Trial), EYT (Elite Yield Trial), pre-commercial (final evaluation before commercial release). Drives advancement decisions and R&D portfolio prioritization. [ENUM-REF-CANDIDATE: F2|F3|BC|PYT|AYT|EYT|pre-commercial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current lifecycle status of this breeding pipeline entry. \'active\' = under evaluation at current stage; \'advanced\' = approved for next stage; \'discontinued\' = dropped from pipeline; \'on-hold\' = temporarily paused; \'released\' = commercially released variety.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvpApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pvp Application Number' ;
    rdfs:comment 'Application or certificate number issued by the USDA Plant Variety Protection Office for this pipeline entry. Classified confidential due to IP sensitivity. Populated when ip_protection_type is \'PVP\' or \'pending\'.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria Met' ;
    rdfs:comment 'Indicates whether this pipeline entry met all predefined selection criteria (yield threshold, disease resistance, agronomic traits, quality parameters) required for advancement at the current stage gate. True = all criteria satisfied; False = one or more criteria not met.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteriaNotes rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria Notes' ;
    rdfs:comment 'Free-text description of the specific selection criteria evaluated at this stage gate, including any criteria that were not met or required waiver. Supports transparent R&D decision documentation and regulatory audit readiness.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageEntryDate rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Date' ;
    rdfs:comment 'Date on which this pipeline entry was formally entered into its current pipeline stage. Used to calculate stage duration, pipeline velocity metrics, and cycle time KPIs for R&D portfolio management.' ;
    rdfs:domain ind:BreedingPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Primary geographic region or market for which this pipeline entry is being developed (e.g., \'US Corn Belt\', \'Southeast Asia\', \'Sub-Saharan Africa\'). Drives trial site selection, regulatory submission routing, and commercial launch planning.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPotentialBuAc rdf:type rdf:Property ;
    rdfs:label 'Yield Potential Bu Ac' ;
    rdfs:comment 'Estimated or observed yield potential of this pipeline entry expressed in bushels per acre (BU/AC) under optimal conditions, based on trial data to date. Key quantitative metric for advancement decisions and commercial value assessment. Derived from statistical_result records; stored here as the current best estimate for portfolio reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeTrialCount rdf:type rdf:Property ;
    rdfs:label 'Active Trial Count' ;
    rdfs:comment 'Number of currently active field trials assigned to this cooperator. Used for capacity planning, workload balancing, and cooperator performance monitoring in the FMIS (Farm Management Information System).' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'Expiration date of the cooperator agreement. Null indicates an open-ended agreement. Triggers renewal workflow when approaching expiration. Cooperators with expired agreements are ineligible for new trial assignments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementRef rdf:type rdf:Property ;
    rdfs:label 'Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the executed cooperator agreement governing the research partnership. Links to the legal agreement document in the document management system.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'Effective start date of the cooperator agreement, from which the cooperator is authorized to participate in field trials and receive research materials.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Ref' ;
    rdfs:comment 'Reference number for the Non-Disclosure Agreement (NDA) or confidentiality agreement executed with this cooperator. Governs protection of proprietary research data, variety performance data, and IP shared during trial activities.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperatorCode rdf:type rdf:Property ;
    rdfs:label 'Cooperator Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the cooperator for use in trial documentation, agreements, and regulatory submissions (e.g., USDA APHIS biotech submissions). Unique across all cooperating entities.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperatorStatus rdf:type rdf:Property ;
    rdfs:label 'Cooperator Status' ;
    rdfs:comment 'Current lifecycle state of the cooperator\'s participation in the research program. Drives eligibility for new trial assignments, material transfers, and data sharing activities.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the cooperator has provided explicit consent for sharing trial data with third parties, regulatory bodies, or research consortia. Required for GDPR compliance in international operations and FSMA data sharing provisions.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Date' ;
    rdfs:comment 'Date on which the cooperator provided or last renewed data sharing consent. Used for GDPR consent lifecycle management and audit trail compliance.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:farmLatitude rdf:type rdf:Property ;
    rdfs:label 'Farm Latitude' ;
    rdfs:comment 'GPS (Global Positioning System) latitude coordinate of the cooperator\'s primary farm or research site in decimal degrees (WGS84 datum). Supports GIS-based trial mapping in Esri ArcGIS and spatial analysis for precision agriculture programs.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farmLongitude rdf:type rdf:Property ;
    rdfs:label 'Farm Longitude' ;
    rdfs:comment 'GPS (Global Positioning System) longitude coordinate of the cooperator\'s primary farm or research site in decimal degrees (WGS84 datum). Supports GIS-based trial mapping in Esri ArcGIS and spatial analysis for precision agriculture programs.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstParticipationYear rdf:type rdf:Property ;
    rdfs:label 'First Participation Year' ;
    rdfs:comment 'Calendar year in which the cooperator first participated in the organization\'s research program. Used to calculate tenure, assess historical performance, and prioritize cooperators for strategic trial assignments.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmoTrialAuthorized rdf:type rdf:Property ;
    rdfs:label 'Gmo Trial Authorized' ;
    rdfs:comment 'Indicates whether the cooperator is authorized to conduct GMO (Genetically Modified Organism) field trials under USDA APHIS biotechnology regulatory permits. Mandatory check before assigning GMO trait evaluation trials.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationCapability rdf:type rdf:Property ;
    rdfs:label 'Irrigation Capability' ;
    rdfs:comment 'Type of irrigation infrastructure available at the cooperator\'s farm. Used for trial design matching — irrigation-dependent trials (e.g., ET-based water use studies) require cooperators with specific irrigation capabilities.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAlsoCommercialCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Also Commercial Customer' ;
    rdfs:comment 'Indicates whether this cooperator also exists as a commercial customer in the customer domain. When True, the customer domain owns the commercial identity and this record owns only the research partnership identity. Enforces cross-domain boundary governance.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State or province component of the cooperator\'s official mailing address. Used for USDA APHIS state-level regulatory reporting and extension service alignment.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtaReference rdf:type rdf:Property ;
    rdfs:label 'Mta Reference' ;
    rdfs:comment 'Document reference number for the executed Material Transfer Agreement (MTA) with this cooperator. Used for IP audit trails and USDA APHIS regulatory submissions involving GMO or proprietary materials.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtaStatus rdf:type rdf:Property ;
    rdfs:label 'Mta Status' ;
    rdfs:comment 'Current status of the Material Transfer Agreement (MTA) governing the transfer of proprietary seed, biological, or research materials to the cooperator. Required for GMO trait evaluations and proprietary variety trials under USDA APHIS and IP protection frameworks.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal or registered name of the cooperating organization (e.g., farm operation, university, extension service, or research institution). Used as the primary identity label in trial documentation and partner communications.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Classification of the cooperating entity by organizational category. Determines applicable agreement templates, data sharing protocols, and regulatory reporting pathways. [ENUM-REF-CANDIDATE: farm|university|extension_service|research_institution|government_agency|ngo|private_lab — promote to reference product]' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCropFocus rdf:type rdf:Property ;
    rdfs:label 'Preferred Crop Focus' ;
    rdfs:comment 'Primary crop species or commodity that the cooperator specializes in for research trials (e.g., corn, soybeans, wheat, cotton). Used for trial-cooperator matching in crop improvement programs and USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFarmAreaHa rdf:type rdf:Property ;
    rdfs:label 'Total Farm Area Ha' ;
    rdfs:comment 'Total land area of the cooperator\'s farm or research site in hectares. Used for trial capacity planning, variable rate application (VRA) prescription sizing, and GLOBALG.A.P. farm registration.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSeasonsParticipated rdf:type rdf:Property ;
    rdfs:label 'Total Seasons Participated' ;
    rdfs:comment 'Cumulative count of growing seasons in which the cooperator has participated in field trials. Reflects depth of research partnership and is used for cooperator tier classification and incentive program eligibility.' ;
    rdfs:domain ind:Cooperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experimentalDesignId rdf:type rdf:Property ;
    rdfs:label 'Experimental Design Id' ;
    rdfs:comment 'Unique surrogate identifier for each experimental design record in the research domain. Primary key for the experimental_design data product.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalDesign .

ind:alphaLevel rdf:type rdf:Property ;
    rdfs:label 'Alpha Level' ;
    rdfs:comment 'Type I error rate (alpha) for hypothesis testing in this experimental design, expressed as a decimal (e.g., 0.0500 = 5%). Governs statistical significance thresholds for treatment comparisons.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockCount rdf:type rdf:Property ;
    rdfs:label 'Block Count' ;
    rdfs:comment 'Number of blocking units in the experimental design. Applicable for RCBD, Split-Plot, and Alpha-Lattice designs. Null for CRD where no blocking is applied.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cvThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Cv Threshold Pct' ;
    rdfs:comment 'Maximum acceptable Coefficient of Variation (CV) percentage for yield or primary response variable measurements. Trials exceeding this CV threshold are flagged for review before inclusion in variety performance databases.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Primary method used to collect trial plot observations and measurements. Determines data pipeline integration (e.g., Climate FieldView for combine monitor, John Deere Operations Center for IoT/telematics, Trimble for digital tablet).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityAcceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Data Quality Acceptance Criteria' ;
    rdfs:comment 'Narrative description of the data quality thresholds and acceptance rules for this experimental design (e.g., maximum allowable CV%, missing data tolerance, outlier exclusion rules). Governs which plot observations are included in final analysis.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCode rdf:type rdf:Property ;
    rdfs:label 'Design Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this experimental design across systems (e.g., FMIS, Trimble Ag, Granular). Used for cross-system referencing and regulatory submissions to USDA APHIS.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designDescription rdf:type rdf:Property ;
    rdfs:label 'Design Description' ;
    rdfs:comment 'Free-text narrative describing the scientific objectives, hypotheses, and key design decisions for this experimental design. Provides context for agronomists, statisticians, and regulatory reviewers.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable descriptive name for the experimental design (e.g., \'Corn Hybrid Yield Trial RCBD 2024 - Iowa\'). Used in reports, dashboards, and regulatory submissions.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designSoftware rdf:type rdf:Property ;
    rdfs:label 'Design Software' ;
    rdfs:comment 'Name and version of the statistical software used to generate the experimental design and randomization (e.g., \'R v4.3.1 - agricolae package\', \'SAS v9.4 PROC PLAN\', \'Agrobase Generation II\'). Required for reproducibility.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Statistical design type governing plot layout and treatment randomization. RCBD = Randomized Complete Block Design; CRD = Completely Randomized Design. Determines blocking structure and analysis model. [ENUM-REF-CANDIDATE: RCBD|CRD|Latin_Square|Split_Plot|Strip_Trial|Augmented|Alpha_Lattice — promote to reference product]' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fertilizerScheduleRef rdf:type rdf:Property ;
    rdfs:label 'Fertilizer Schedule Ref' ;
    rdfs:comment 'Reference code or document identifier for the standardized NPK (Nitrogen Phosphorus Potassium) fertilizer application schedule prescribed for this experimental design. Links to the nutrient management plan.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTrialFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Trial Flag' ;
    rdfs:comment 'Indicates whether this experimental design involves GMO (Genetically Modified Organism) traits or biotech events. When True, triggers mandatory USDA APHIS BPRE/BRS regulatory submission workflow and containment protocol requirements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:harvestProcedureRef rdf:type rdf:Property ;
    rdfs:label 'Harvest Procedure Ref' ;
    rdfs:comment 'Reference code to the standardized harvest procedure document specifying plot combine settings, moisture adjustment protocols, and yield data capture requirements for this experimental design.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationManagementRule rdf:type rdf:Property ;
    rdfs:label 'Irrigation Management Rule' ;
    rdfs:comment 'Irrigation management protocol applied uniformly across all trial plots. ET (Evapotranspiration)-based and soil moisture-triggered rules require IoT sensor integration. Rainfed indicates no supplemental irrigation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minPlotSizeSqm rdf:type rdf:Property ;
    rdfs:label 'Min Plot Size Sqm' ;
    rdfs:comment 'Minimum acceptable plot size in square meters as specified by the experimental design protocol. Plots below this threshold are flagged as non-compliant and excluded from statistical analysis.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planting Window End' ;
    rdfs:comment 'Latest acceptable planting date for trial plots under this experimental design protocol. Planting outside this window invalidates the trial data per protocol acceptance criteria.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planting Window Start' ;
    rdfs:comment 'Earliest acceptable planting date for trial plots under this experimental design protocol. Defines the opening of the planting date window to ensure agronomic validity of results.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResponseVariable rdf:type rdf:Property ;
    rdfs:label 'Primary Response Variable' ;
    rdfs:comment 'The principal agronomic measurement or outcome variable that this experimental design is powered to detect (e.g., \'grain yield BU/acre\', \'plant stand count\', \'disease severity rating\'). Drives statistical power calculations and analysis model selection.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the experimental design protocol document (e.g., \'1.0\', \'2.3\'). Enables version control and audit trail for protocol amendments. Required for USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationSeed rdf:type rdf:Property ;
    rdfs:label 'Randomization Seed' ;
    rdfs:comment 'Numeric seed value used by the design generation software to produce the treatment randomization sequence. Enables exact reproducibility of the randomization for audit and re-analysis purposes.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of replications (blocks or repetitions) specified in the experimental design. Directly determines statistical power and the minimum number of trial plots required.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoutingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Scouting Frequency Days' ;
    rdfs:comment 'Minimum required interval in days between crop scouting observations for trial plots under this design. Governs IPM (Integrated Pest Management) monitoring cadence and data collection scheduling.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seedingRateTarget rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Target' ;
    rdfs:comment 'Standardized target seeding rate specified in the protocol for all trial plots, expressed in seeds per acre. Deviations beyond the tolerance threshold trigger a data quality flag.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedingRateUnit rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Unit' ;
    rdfs:comment 'Unit of measure for the target seeding rate specification (e.g., seeds per acre, kg per hectare). Ensures consistent interpretation across geographies and reporting systems.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalPowerTarget rdf:type rdf:Property ;
    rdfs:label 'Statistical Power Target' ;
    rdfs:comment 'Target statistical power (1 - beta) for the experimental design, expressed as a decimal (e.g., 0.8000 = 80%). Used to validate that replication count is sufficient to detect the minimum detectable difference.' ;
    rdfs:domain ind:ExperimentalDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Count' ;
    rdfs:comment 'Total number of distinct treatments (including controls) defined in this experimental design. Governs the number of treatment randomization assignments per replication.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputUsageId rdf:type rdf:Property ;
    rdfs:label 'Input Usage Id' ;
    rdfs:comment 'Primary key for input_usage' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryDrawdownGoodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Inventory Drawdown Goods Issue Id' ;
    rdfs:comment 'Reference to the inventory goods issue or drawdown transaction that reduced stock when this input material was consumed. Supports research Cost of Goods Sold (COGS) reconciliation and inventory audit trail.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:aphisPermitRef rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Ref' ;
    rdfs:comment 'USDA Animal and Plant Health Inspection Service (APHIS) permit or notification number governing the use of this input material in a regulated field trial. Required for GMO trait evaluations and biotech regulatory submissions under 7 CFR Part 340.' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaTreatedHa rdf:type rdf:Property ;
    rdfs:label 'Area Treated Ha' ;
    rdfs:comment 'Total area of the trial plot treated with this input material, expressed in hectares. Used to validate quantity_used against application_rate and area, and to support per-hectare COGS calculations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationNotes rdf:type rdf:Property ;
    rdfs:label 'Deviation Notes' ;
    rdfs:comment 'Free-text description of any deviation from the experimental protocol for this input usage event. Required when protocol_deviation_flag is True. Documents the nature, cause, and corrective action for the deviation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoInputFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Input Flag' ;
    rdfs:comment 'Indicates whether the input material (particularly seed lots) is derived from or constitutes a Genetically Modified Organism (GMO). True = GMO input; False = non-GMO input. Triggers USDA APHIS permit compliance requirements for regulated field trials.' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputMaterialType rdf:type rdf:Property ;
    rdfs:label 'Input Material Type' ;
    rdfs:comment 'Classification of the research input material consumed. Drives regulatory traceability requirements: \'seed\' triggers seed lot tracking; \'crop_protection\' triggers EPA registration and PHI/REI compliance; \'fertilizer\' triggers NPK nutrient tracking; \'soil_amendment\' triggers EC/pH impact analysis.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Flag' ;
    rdfs:comment 'Indicates whether the actual input usage deviated from the experimental protocol specification (e.g., wrong rate, wrong timing, wrong material). True = deviation occurred; False = protocol followed. Triggers mandatory deviation documentation for GCP/GAP compliance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUsed rdf:type rdf:Property ;
    rdfs:label 'Quantity Used' ;
    rdfs:comment 'Actual quantity of the input material consumed during the trial application. Combined with unit_of_measure to express the full consumption amount. Used for inventory drawdown, COGS calculation, and application rate verification against the experimental protocol.' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reiEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Rei End Datetime' ;
    rdfs:comment 'Calculated datetime when the Restricted Entry Interval (REI) expires following application of a crop protection product. Derived from application_timestamp plus the label-specified REI duration. Required for worker safety compliance under EPA Worker Protection Standard.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetRate rdf:type rdf:Property ;
    rdfs:label 'Target Rate' ;
    rdfs:comment 'Protocol-specified target application rate for this input material as defined in the experimental design. Compared against actual application_rate to detect protocol deviations and support Good Agricultural Practices (GAP) compliance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the input material consumed in this usage record, calculated as quantity_used multiplied by cost_per_unit. Supports research COGS tracking, trial budget management, and input cost-efficacy correlation reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRecordCode rdf:type rdf:Property ;
    rdfs:label 'Usage Record Code' ;
    rdfs:comment 'Human-readable business identifier for this input usage record, used in field documentation, USDA APHIS regulatory submissions, and cross-system reconciliation. Follows the RIU- prefix convention.' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'Current lifecycle state of the input usage record. \'draft\' indicates pending confirmation; \'confirmed\' indicates verified consumption; \'adjusted\' indicates a corrected quantity; \'voided\' indicates a cancelled or erroneous entry; \'under_review\' indicates flagged for quality or compliance review.' ;
    rdfs:domain ind:InputUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedAccountId rdf:type rdf:Property ;
    rdfs:label 'Licensed Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Seed companies license patented varieties and traits to commercial customer accounts. IP licensing management requires tracking which customer accounts hold active licenses for specific IP records, su' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:annuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Due Date' ;
    rdfs:comment 'Next scheduled date by which maintenance fees or annuity payments must be submitted to the relevant IP authority to keep the patent or PVP certificate in force. Missing this date results in lapse of IP rights.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Official application number assigned by the IP authority upon receipt of the filing (e.g., USPTO application serial number, PCT application number). Distinct from the granted patent or PVP certificate number and used to track prosecution status.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Legal name of the entity that owns the IP rights, which may be the company, a subsidiary, a joint venture partner, or an individual. Reflects the recorded assignee at the relevant IP authority.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizedValue rdf:type rdf:Property ;
    rdfs:label 'Capitalized Value' ;
    rdfs:comment 'Capitalized book value of the IP asset recorded on the balance sheet as an intangible asset, in the company\'s functional currency. Calculated per IFRS IAS 38 or GAAP ASC 350 criteria for internally developed intangible assets.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to this IP record, governing access controls and disclosure restrictions. Restricted applies to trade secrets and pre-filing inventions; confidential applies to granted patents under licensing negotiation; internal applies to published patents; public applies to fully disclosed and expired IP.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date on which the IP application was formally filed with the relevant authority (USPTO, USDA PVPO, WIPO, or national patent office). Establishes priority date for patent prosecution and PVP proceedings.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftoAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Fto Assessment Date' ;
    rdfs:comment 'Date on which the most recent Freedom-to-Operate (FTO) legal analysis was completed. Used to determine whether the FTO assessment is current and whether a refresh is required due to new third-party patent filings.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftoStatus rdf:type rdf:Property ;
    rdfs:label 'Fto Status' ;
    rdfs:comment 'Current status of the Freedom-to-Operate (FTO) legal analysis determining whether commercializing this IP asset would infringe third-party IP rights. Clear indicates no blocking patents identified; blocked indicates conflicting third-party rights exist; under review indicates analysis in progress.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date on which the IP rights were formally granted or issued by the relevant authority. Null for applications still pending or abandoned.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationPipelineStage rdf:type rdf:Property ;
    rdfs:label 'Innovation Pipeline Stage' ;
    rdfs:comment 'Stage of the internal agricultural innovation pipeline at which this IP asset is positioned, from early discovery through commercialization. Supports R&D portfolio management, CAPEX/OPEX planning, and strategic IP investment decisions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorNames rdf:type rdf:Property ;
    rdfs:label 'Inventor Names' ;
    rdfs:comment 'Comma-separated list of full legal names of all named inventors or breeders as recorded on the IP application. Required for patent validity and PVP certificate issuance. Supports inventor recognition and royalty-sharing programs.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipNumber rdf:type rdf:Property ;
    rdfs:label 'Ip Number' ;
    rdfs:comment 'Externally-known identifier for the IP asset, such as a patent number (e.g., US10,123,456), Plant Variety Protection (PVP) certificate number, or provisional application number as assigned by the relevant IP authority.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Status' ;
    rdfs:comment 'Current lifecycle state of the IP record. Pending indicates application filed but not yet granted; granted indicates formal IP rights awarded; active indicates rights currently enforceable; expired indicates protection period lapsed; abandoned indicates application withdrawn or lapsed; licensed indicates rights transferred or sublicensed to a third party.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipType rdf:type rdf:Property ;
    rdfs:label 'Ip Type' ;
    rdfs:comment 'Classification of the IP asset by legal protection mechanism. Utility patents cover novel processes or compositions; plant patents cover asexually reproduced varieties; PVP certificates protect sexually reproduced varieties under PVPA; trade secrets protect proprietary formulations or methods; licensing agreements govern third-party use rights. [ENUM-REF-CANDIDATE: utility_patent|plant_patent|pvp_certificate|provisional_application|trade_secret|licensing_agreement|design_patent|plant_breeders_right — promote to reference product]' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code indicating the jurisdiction in which the IP rights are filed or granted (e.g., US, EP for European Patent, WO for PCT international application). Determines applicable IP law and enforcement territory.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Current licensing arrangement for the IP asset. Exclusively licensed means rights granted to a single licensee; non-exclusively licensed allows multiple licensees; sublicensed means a licensee has granted rights to a third party; cross-licensed means mutual rights exchanged with another IP holder.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFeePaid rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Paid' ;
    rdfs:comment 'Indicates whether the current period maintenance fee or annuity has been paid to keep the IP asset in force. True indicates payment confirmed; False indicates payment outstanding or overdue.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outsideCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or patent attorney firm engaged to prosecute or manage this IP asset. Supports legal spend tracking, vendor management, and IP portfolio administration.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage in the IP prosecution process at the relevant authority. Tracks progress from initial filing through examination, office action responses, appeals, allowance, and final grant. Supports IP counsel workflow management.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The contractual basis on which royalties are calculated, such as net sales revenue, gross sales, per unit sold, per acre planted, or a one-time lump sum payment. Determines how royalty obligations are computed and reported.' ;
    rdfs:domain ind:IpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'Contractual royalty rate expressed as a percentage of net sales or licensed revenue payable to the IP owner or licensor. Used for financial planning, IFRS 15 revenue recognition, and IP portfolio valuation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipmStudyId rdf:type rdf:Property ;
    rdfs:label 'Ipm Study Id' ;
    rdfs:comment 'Primary key for ipm_study' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationTiming rdf:type rdf:Property ;
    rdfs:label 'Application Timing' ;
    rdfs:comment 'Description of when the treatment was applied relative to the pest economic threshold or disease forecasting model trigger (e.g., \'at economic threshold\', \'preventive - pre-threshold\', \'curative - post-threshold exceeded\'). Core IPM decision-making attribute.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Economic Threshold Unit' ;
    rdfs:comment 'Unit of measure for the economic threshold value (e.g., \'insects_per_plant\', \'percent_leaf_area_infected\', \'eggs_per_row_foot\'). Required for correct interpretation of the economic threshold comparison.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Economic Threshold Value' ;
    rdfs:comment 'The pest population density or disease severity level at which economic damage justifies the cost of treatment intervention. Used to evaluate whether treatment timing was economically justified per IPM decision rules.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efficacyRatingPct rdf:type rdf:Property ;
    rdfs:label 'Efficacy Rating Pct' ;
    rdfs:comment 'The measured percentage of pest or disease control achieved by the treatment relative to the untreated control plot. Primary quantitative outcome metric for IPM efficacy studies. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmoTraitFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Flag' ;
    rdfs:comment 'Indicates whether the crop variety used in the IPM study incorporates a GMO (Genetically Modified Organism) trait relevant to pest resistance (e.g., Bt trait for insect resistance). Required for USDA APHIS biotech regulatory submissions and COOL (Country of Origin Labeling) compliance.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipmStrategyType rdf:type rdf:Property ;
    rdfs:label 'Ipm Strategy Type' ;
    rdfs:comment 'Classification of the IPM control strategy employed in the study (chemical, biological, cultural, mechanical, physical, or integrated combination). Supports IPM program optimization and BMP (Best Management Practices) reporting.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedPestDensity rdf:type rdf:Property ;
    rdfs:label 'Observed Pest Density' ;
    rdfs:comment 'The actual measured pest population density or disease incidence level recorded at the time of treatment application. Compared against the economic threshold to validate IPM decision-making.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phytotoxicityObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Phytotoxicity Observed Flag' ;
    rdfs:comment 'Indicates whether visible crop phytotoxicity (plant injury caused by the treatment product) was observed during the study (True = phytotoxicity observed; False = no phytotoxicity). Required for EPA label safety data and product stewardship reporting.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phytotoxicitySeverity rdf:type rdf:Property ;
    rdfs:label 'Phytotoxicity Severity' ;
    rdfs:comment 'Categorical severity rating of observed crop phytotoxicity caused by the treatment product. Populated only when phytotoxicity_observed_flag is True. Supports EPA label safety data submissions and product stewardship decisions.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resistanceManagementClass rdf:type rdf:Property ;
    rdfs:label 'Resistance Management Class' ;
    rdfs:comment 'The mode-of-action (MOA) resistance management classification code for the active ingredient, per IRAC (Insecticide Resistance Action Committee), FRAC (Fungicide Resistance Action Committee), or HRAC (Herbicide Resistance Action Committee) classification systems (e.g., \'IRAC Group 3A\', \'FRAC Code 11\'). Critical for resistance management rotation planning.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the IPM efficacy study, used in EPA registration submissions, USDA APHIS biotech regulatory filings, and internal R&D tracking. Format: IPM-{STUDYCODE}-{YEAR}.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'The calendar date on which the IPM efficacy study concluded or final efficacy assessments were completed.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-text field for capturing additional observations, anomalies, weather events, or contextual information relevant to the IPM efficacy study that are not captured in structured fields. Supports scientific reproducibility and EPA GLP documentation requirements.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'The calendar date on which the IPM efficacy study commenced, marking the principal real-world event time for study initiation. Used for PHI (Pre-Harvest Interval) and REI (Restricted Entry Interval) compliance tracking.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the IPM efficacy study, tracking progression from planning through completion or cancellation.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Descriptive title of the IPM efficacy study, summarizing the target pest or disease, treatment product, and crop system under evaluation.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganismName rdf:type rdf:Property ;
    rdfs:label 'Target Organism Name' ;
    rdfs:comment 'Common or scientific name of the pest, disease pathogen, or weed species targeted by the IPM treatment in this study (e.g., \'Botrytis cinerea\', \'Western Corn Rootworm\', \'Palmer Amaranth\'). Aligns with EPA pesticide registration target organism classification.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganismType rdf:type rdf:Property ;
    rdfs:label 'Target Organism Type' ;
    rdfs:comment 'Classification of the target organism category for the IPM study. Drives resistance management strategy, MRL compliance requirements, and EPA registration data submission grouping. [ENUM-REF-CANDIDATE: insect|fungal_pathogen|bacterial_pathogen|nematode|weed|rodent|mite|virus — promote to reference product]' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the observed pest density exceeded the economic threshold at the time of treatment application (True = threshold exceeded; False = below threshold). Validates IPM decision compliance and supports program optimization reporting.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:untreatedControlEfficacyPct rdf:type rdf:Property ;
    rdfs:label 'Untreated Control Efficacy Pct' ;
    rdfs:comment 'The pest or disease incidence level observed in the untreated control plots, expressed as a percentage. Used as the baseline denominator for calculating relative efficacy rating and validating study integrity.' ;
    rdfs:domain ind:IpmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark Id' ;
    rdfs:comment 'Primary key for performance_benchmark' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: performance_benchmark.approved_by is a plain-text denormalization of the approving employee. Variety release decisions require an auditable approval chain linking to a specific employee record. Role-p' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:historicalClimateNormalId rdf:type rdf:Property ;
    rdfs:label 'Historical Climate Normal Id' ;
    rdfs:comment 'Foreign key linking to weather.climate_normal. Business justification: Seed performance benchmarking requires environmental context normalization — GDD normals, precipitation normals, and frost-free days define the climate envelope for each benchmark region. performance_' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClimateNormal .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this benchmark record, used in seed selection reports, commercial release documentation, and cross-system references. Follows the BNK- prefix convention.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the benchmark record. Controls visibility and use in seed selection recommendations and commercial release decisions. [ENUM-REF-CANDIDATE: draft|under_review|approved|published|superseded|archived — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkVarietyCode rdf:type rdf:Property ;
    rdfs:label 'Check Variety Code' ;
    rdfs:comment 'Code identifying the industry-standard or internal check variety used as the performance baseline for comparison in this benchmark. Essential for relative performance calculations and commercial release decisions.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseResistanceRating rdf:type rdf:Property ;
    rdfs:label 'Disease Resistance Rating' ;
    rdfs:comment 'Composite disease resistance performance rating aggregated across all trial environments, scored on a standardized scale (e.g., 1-9 or 1-100). Reflects resistance to key pathogens relevant to the crop species and region.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diseaseResistanceScale rdf:type rdf:Property ;
    rdfs:label 'Disease Resistance Scale' ;
    rdfs:comment 'Defines the scoring scale used for the disease resistance rating (e.g., 1-9 where 1=highly susceptible, 9=highly resistant). Required for correct interpretation of the rating value.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanYieldBuAc rdf:type rdf:Property ;
    rdfs:label 'Mean Yield Bu Ac' ;
    rdfs:comment 'Mean yield expressed in bushels per acre (BU/AC) aggregated across all trial environments in the MET dataset. Primary yield performance metric for US-market seed selection recommendations.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanYieldMtHa rdf:type rdf:Property ;
    rdfs:label 'Mean Yield Mt Ha' ;
    rdfs:comment 'Mean yield expressed in metric tons per hectare (MT/HA) aggregated across all trial environments. Primary yield metric for international markets and FAO/Codex reporting.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metAnalysisVersion rdf:type rdf:Property ;
    rdfs:label 'Met Analysis Version' ;
    rdfs:comment 'Version identifier of the statistical analysis pipeline or model used to aggregate raw yield_measurement records into this benchmark. Enables reproducibility and audit of benchmark derivation methodology.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureAtHarvestPct rdf:type rdf:Property ;
    rdfs:label 'Moisture At Harvest Pct' ;
    rdfs:comment 'Mean grain moisture percentage at harvest across trial environments. Impacts drying costs, storage quality, and marketability. Key agronomic performance metric for commercial variety evaluation.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndviMean rdf:type rdf:Property ;
    rdfs:label 'Ndvi Mean' ;
    rdfs:comment 'Mean Normalized Difference Vegetation Index (NDVI) value across trial plots and environments, derived from remote sensing data. Indicator of canopy health, biomass, and crop vigor for the benchmarked variety.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseRecommendation rdf:type rdf:Property ;
    rdfs:label 'Release Recommendation' ;
    rdfs:comment 'Formal recommendation derived from benchmark analysis for commercial variety release decision (recommend_release, do_not_release, conditional_release, pending_review). Authoritative output used by the crop improvement program.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standabilityScore rdf:type rdf:Property ;
    rdfs:label 'Standability Score' ;
    rdfs:comment 'Aggregated standability score measuring the variety\'s resistance to lodging (root and stalk lodging) across trial environments. Critical for harvest efficiency and yield loss prevention. Scored on a standardized scale.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalSignificance rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance' ;
    rdfs:comment 'Statistical significance level of the yield and performance differences reported in this benchmark (e.g., p<0.05, p<0.01). Validates the scientific rigor of the benchmark for commercial release decisions.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWeightKgHl rdf:type rdf:Property ;
    rdfs:label 'Test Weight Kg Hl' ;
    rdfs:comment 'Mean test weight in kilograms per hectoliter (KG/HL) across trial environments. Indicator of grain quality, density, and market grade. Used in quality assurance and buyer specifications.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialEnvironmentCount rdf:type rdf:Property ;
    rdfs:label 'Trial Environment Count' ;
    rdfs:comment 'Number of distinct environments (location-year combinations) included in the multi-environment trial (MET) aggregation that produced this benchmark. Higher counts indicate greater statistical reliability.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldStabilityIndex rdf:type rdf:Property ;
    rdfs:label 'Yield Stability Index' ;
    rdfs:comment 'Statistical measure of yield consistency across diverse environments in the MET dataset (e.g., Finlay-Wilkinson regression coefficient or Eberhart-Russell stability variance). Lower variance indicates more stable performance across environments.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldStabilityMethod rdf:type rdf:Property ;
    rdfs:label 'Yield Stability Method' ;
    rdfs:comment 'Statistical methodology used to calculate the yield stability index for this benchmark (e.g., Finlay-Wilkinson regression, AMMI, GGE-Biplot). Required for reproducibility and scientific validity of benchmark comparisons.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldVsCheckPct rdf:type rdf:Property ;
    rdfs:label 'Yield Vs Check Pct' ;
    rdfs:comment 'Percentage difference in mean yield of the benchmarked variety compared to the check variety (positive = outperforms check, negative = underperforms). Core metric for commercial variety release decisions.' ;
    rdfs:domain ind:PerformanceBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precisionAgPilotId rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Pilot Id' ;
    rdfs:comment 'Unique system-generated identifier for each precision agriculture technology pilot program record. Serves as the primary key for this master resource entity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrecisionAgPilot .

ind:sponsoringAccountId rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Commercial customers (food manufacturers, large buyers) co-fund precision ag pilots to improve supply chain traceability and yield. Tracking the sponsoring customer account enables cost-sharing billin' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Cumulative actual expenditure incurred for the pilot program to date in the reporting currency. Compared against approved_budget for variance analysis and financial reporting in SAP S/4HANA CO.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aphisSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Aphis Submission Reference' ;
    rdfs:comment 'USDA APHIS-assigned reference number for the regulatory notification or permit associated with this pilot (e.g., for GMO trait evaluations or biotech field trials). Null if aphis_submission_required is False.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aphisSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Aphis Submission Required' ;
    rdfs:comment 'Indicates whether the pilot involves regulated biotechnology (GMO traits, gene editing) requiring a USDA APHIS regulatory submission or notification under 7 CFR Part 340. Critical for compliance workflow triggering.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Budget' ;
    rdfs:comment 'Total approved budget allocated to the pilot program in the reporting currency. Used for CAPEX/OPEX planning, R&D investment tracking, and ROI calculation post-pilot. Classified confidential due to commercial sensitivity.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement exists with the technology vendor or research partner governing the use of pilot-generated field data. Critical for GDPR compliance in international operations and proprietary data protection.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoInvolved rdf:type rdf:Property ;
    rdfs:label 'Gmo Involved' ;
    rdfs:comment 'Indicates whether the pilot involves genetically modified organism (GMO) varieties or biotech traits. Triggers USDA APHIS compliance workflows, COOL labeling requirements, and IP protection protocols.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationSystem rdf:type rdf:Property ;
    rdfs:label 'Integration System' ;
    rdfs:comment 'Primary operational system of record that the pilot integrates with for data ingestion and field operations management. Drives ETL pipeline configuration and data lineage tracking in the Databricks Lakehouse silver layer. [ENUM-REF-CANDIDATE: john_deere_operations_center|climate_fieldview|trimble_ag|granular|esri_arcgis|sap_s4hana|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiUnit rdf:type rdf:Property ;
    rdfs:label 'Kpi Unit' ;
    rdfs:comment 'Unit of measure for the target KPI baseline and goal values. Ensures consistent interpretation across pilot programs (e.g., pct for percentage-based KPIs, bu_ac for yield in bushels per acre, mt_ha for metric tons per hectare).' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotCode rdf:type rdf:Property ;
    rdfs:label 'Pilot Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the pilot program (e.g., PAG-VRA-2024-0001). Used in cross-system references, vendor communications, and regulatory submissions to USDA APHIS.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotName rdf:type rdf:Property ;
    rdfs:label 'Pilot Name' ;
    rdfs:comment 'Descriptive human-readable name of the pilot program (e.g., \'RTK-Guided VRA Corn Trial 2024 — Iowa\'). Used in reporting dashboards, FMIS records, and stakeholder communications.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotObjective rdf:type rdf:Property ;
    rdfs:label 'Pilot Objective' ;
    rdfs:comment 'Narrative description of the primary business objective the pilot is designed to achieve (e.g., \'Reduce nitrogen input by 15% while maintaining yield parity using VRA prescriptions\'). Supports innovation pipeline tracking and USDA grant reporting.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotScaleAcres rdf:type rdf:Property ;
    rdfs:label 'Pilot Scale Acres' ;
    rdfs:comment 'Total land area enrolled in the pilot program measured in acres. Used for resource planning, cost-per-acre analysis, and scaling decisions. Aligns with John Deere Operations Center field mapping and Esri ArcGIS spatial records.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pilotScaleHa rdf:type rdf:Property ;
    rdfs:label 'Pilot Scale Ha' ;
    rdfs:comment 'Total land area enrolled in the pilot program measured in hectares. Supports international reporting and metric-system compliance for GLOBALG.A.P. and ISO 22000 submissions alongside the acre-based measure.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pilotStatus rdf:type rdf:Property ;
    rdfs:label 'Pilot Status' ;
    rdfs:comment 'Current lifecycle state of the pilot program. Drives workflow routing, budget release, and reporting eligibility. Values: draft (planning phase), active (in-field execution), on_hold (temporarily suspended), completed (concluded with results), cancelled (terminated before completion).' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Document Reference' ;
    rdfs:comment 'Reference identifier for the formal pilot protocol document (SOP) stored in the document management system. Ensures experimental design reproducibility and supports USDA APHIS regulatory submissions and GFSI audit readiness.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsSummary rdf:type rdf:Property ;
    rdfs:label 'Results Summary' ;
    rdfs:comment 'Narrative summary of key pilot outcomes and findings upon completion. Populated at pilot conclusion to support go/no-go scaling decisions, innovation pipeline reporting, and USDA NIFA grant final reports.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpRecommendation rdf:type rdf:Property ;
    rdfs:label 'Scale Up Recommendation' ;
    rdfs:comment 'Post-pilot recommendation from the lead agronomist and R&D committee on whether to scale the technology to full commercial deployment. Drives innovation pipeline stage-gate decisions and CAPEX planning in SAP S/4HANA.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryIntegrationSystem rdf:type rdf:Property ;
    rdfs:label 'Secondary Integration System' ;
    rdfs:comment 'Secondary operational system of record involved in the pilot (e.g., Esri ArcGIS for spatial mapping alongside John Deere Operations Center for telematics). Supports multi-system data lineage documentation. [ENUM-REF-CANDIDATE: john_deere_operations_center|climate_fieldview|trimble_ag|granular|esri_arcgis|sap_s4hana|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetKpi rdf:type rdf:Property ;
    rdfs:label 'Target Kpi' ;
    rdfs:comment 'Primary KPI the pilot is designed to improve or validate. OEE (Overall Equipment Effectiveness) for autonomous equipment trials, yield_uplift_pct for crop improvement pilots, input_reduction_pct for VRA and IPM efficacy studies, ndvi_improvement for drone sensing pilots, fuel_reduction_pct and labor_reduction_pct for automation trials.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetKpiBaselineValue rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Baseline Value' ;
    rdfs:comment 'Pre-pilot baseline measurement of the target KPI against which pilot outcomes will be benchmarked (e.g., current OEE of 72.5, current yield of 185.0 bu/ac). Enables statistically valid ROI and uplift calculations post-pilot.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetKpiGoalValue rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Goal Value' ;
    rdfs:comment 'Quantified target value for the primary KPI that defines pilot success (e.g., OEE of 85.0, yield uplift of 10%). Used in go/no-go decision gates and innovation pipeline scoring.' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyCategory rdf:type rdf:Property ;
    rdfs:label 'Technology Category' ;
    rdfs:comment 'Broad functional category grouping the technology type for portfolio analysis and R&D investment reporting. Sensing (NDVI, IoT sensors), Application (VRA, irrigation), Navigation (RTK, GPS), Analytics (AI/ML, NDVI analytics), Automation (autonomous equipment), Connectivity (IoT networks, DTN integration).' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyType rdf:type rdf:Property ;
    rdfs:label 'Technology Type' ;
    rdfs:comment 'Classification of the precision agriculture technology being evaluated (e.g., RTK-guided VRA, drone-based NDVI sensing, IoT soil moisture network, AI-driven planting prescription, autonomous equipment). [ENUM-REF-CANDIDATE: rtk_vra|drone_ndvi|iot_soil_moisture|ai_planting_prescription|autonomous_equipment|satellite_imagery|variable_rate_irrigation|yield_mapping — promote to reference product]' ;
    rdfs:domain ind:PrecisionAgPilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancementDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Advancement Decision Date' ;
    rdfs:comment 'Date on which the pipeline advancement decision was formally made and recorded. Used for breeding cycle timeline analysis and regulatory submission documentation.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Usd' ;
    rdfs:comment 'Total approved budget allocated to the research program in US dollars. Used for CAPEX/OPEX planning, ROI tracking, and financial reporting under GAAP/IFRS. Distinct from actual spend tracked in the finance domain.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionMaker rdf:type rdf:Property ;
    rdfs:label 'Decision Maker' ;
    rdfs:comment 'Name or identifier of the individual (e.g., Chief Breeder, R&D Director) who authorized the pipeline advancement decision. Required for accountability and audit trail under SOX.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCommercialReleaseYear rdf:type rdf:Property ;
    rdfs:label 'Estimated Commercial Release Year' ;
    rdfs:comment 'Projected calendar year in which a variety or technology developed under this program is expected to reach commercial release. Used for innovation pipeline planning and market launch scheduling.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalPartnerOrganizations rdf:type rdf:Property ;
    rdfs:label 'External Partner Organizations' ;
    rdfs:comment 'Comma-separated list or narrative of external organizations collaborating on the program (e.g., universities, CGIAR centers, seed companies, government agencies). Supports IP/partnership agreement tracking.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Required' ;
    rdfs:comment 'Indicates whether the program requires adherence to Good Agricultural Practices (GAP) protocols for field trial execution. When True, triggers GAP documentation and audit requirements under GLOBALG.A.P. and FSMA.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoTraitsInvolved rdf:type rdf:Property ;
    rdfs:label 'Gmo Traits Involved' ;
    rdfs:comment 'Indicates whether the program involves evaluation or development of GMO traits. When True, triggers USDA APHIS biotech regulatory submission requirements and APHIS deregulation tracking workflows.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Number' ;
    rdfs:comment 'Official grant award number or agreement identifier assigned by the funding body (e.g., USDA NIFA award number, EPA grant ID). Required for regulatory reporting and financial audit trails under GAAP/IFRS.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipmFocus rdf:type rdf:Property ;
    rdfs:label 'Ipm Focus' ;
    rdfs:comment 'Indicates whether the program includes an Integrated Pest Management (IPM) efficacy study component. When True, links to EPA-compliant IPM protocols and MRL compliance tracking.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lead rdf:type rdf:Property ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Full name of the principal scientist, breeder, or program manager accountable for the research program\'s execution and outcomes. Used for accountability tracking and stakeholder communication.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nifaGrantReference rdf:type rdf:Property ;
    rdfs:label 'Nifa Grant Reference' ;
    rdfs:comment 'Specific USDA NIFA program or grant initiative reference (e.g., \'AFRI Foundational Program\', \'SBIR Phase II\') to which this research program is aligned. Enables grant portfolio reporting and compliance tracking.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Application Number' ;
    rdfs:comment 'USPTO or international patent application number filed in connection with innovations developed under this program. Applicable when ip_protection_type is \'plant_patent\' or \'utility_patent\'. Supports IP portfolio management.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionAgTechnology rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Technology' ;
    rdfs:comment 'Name or description of the precision agriculture technology platform being piloted or evaluated under this program (e.g., \'RTK-guided VRA seeding\', \'IoT soil sensor network\', \'NDVI drone scouting\'). Applicable for precision_ag program types.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the research program. Drives portfolio management workflows: \'draft\' (planning), \'active\' (in execution), \'on_hold\' (paused), \'completed\' (objectives met), \'cancelled\' (terminated early).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringDivision rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Division' ;
    rdfs:comment 'Internal business division or organizational unit that owns and sponsors the program (e.g., \'Crop Sciences R&D\', \'Sustainable Agriculture Division\'). Used for OPEX/CAPEX allocation and internal charge-back.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'Narrative description of the overarching strategic goal the program is designed to achieve (e.g., \'Develop drought-tolerant corn hybrids for the US Corn Belt to improve YPM under water-limited conditions\'). Aligns program to corporate R&D strategy.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFramework rdf:type rdf:Property ;
    rdfs:label 'Sustainability Framework' ;
    rdfs:comment 'Name of the sustainability or environmental certification framework to which the program contributes (e.g., \'ISCC\', \'GLOBALG.A.P. GRASP\', \'ISO 14001\', \'Fair Trade USA\'). Applicable for sustainability program types.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCount rdf:type rdf:Property ;
    rdfs:label 'Trial Count' ;
    rdfs:comment 'Number of individual field trials or experimental plots currently registered under this research program. Provides a quick portfolio size indicator for program management dashboards. Not a calculated aggregate — sourced directly from program registration metadata.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchSoilSampleId rdf:type rdf:Property ;
    rdfs:label 'Research Soil Sample Id' ;
    rdfs:comment 'Unique surrogate identifier for each soil sampling event and associated laboratory analysis record within the research domain. Primary key for this entity.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchProjectId rdf:type rdf:Property ;
    rdfs:label 'Research Project Id' ;
    rdfs:comment 'Reference to the overarching agricultural research project or experiment program under which this soil sampling event was conducted. Supports IP tracking and innovation pipeline management.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchProject .

ind:soilCarbonSequestrationId rdf:type rdf:Property ;
    rdfs:label 'Soil Carbon Sequestration Id' ;
    rdfs:comment 'Foreign key linking to sustainability.soil_carbon_sequestration. Business justification: Carbon credit verification requires full traceability from soil_carbon_sequestration records (VCU issuance) back to the underlying laboratory soil sample measurements. Research soil samples provide th' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoilCarbonSequestration .

ind:analysisPackage rdf:type rdf:Property ;
    rdfs:label 'Analysis Package' ;
    rdfs:comment 'Tier of laboratory analysis requested for this soil sample, determining which analytes are measured. Options range from basic (pH, EC, NPK) to full profile (all macro/micro-nutrients, texture, bulk density). Drives lab cost allocation and research scope.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clayPct rdf:type rdf:Property ;
    rdfs:label 'Clay Pct' ;
    rdfs:comment 'Percentage of clay-sized particles (<0.002 mm) in the soil sample by weight. Clay content directly influences CEC (Cation Exchange Capacity), shrink-swell behaviour, and nutrient retention in research trial soils.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Coa Document Ref' ;
    rdfs:comment 'Reference number or URL to the COA (Certificate of Analysis) document issued by the laboratory, containing the official certified analytical results. Required for regulatory submissions to USDA APHIS and internal quality assurance sign-off.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironPpm rdf:type rdf:Property ;
    rdfs:label 'Iron Ppm' ;
    rdfs:comment 'Plant-available iron (Fe) micro-nutrient concentration in the soil sample measured in parts per million (ppm). Iron availability is pH-dependent and critical for chlorophyll production; monitored in soil pH amendment research.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaselineSample rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Sample' ;
    rdfs:comment 'Flag indicating whether this soil sample represents the pre-treatment baseline characterisation for a trial plot (True) or a post-treatment monitoring sample (False). Baseline samples are used as the control reference in amendment efficacy statistical analysis.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the accredited external or internal laboratory that performed the soil chemical and physical analysis. Required for result traceability, audit compliance, and inter-laboratory comparison studies.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Lab Submission Ref' ;
    rdfs:comment 'External reference number assigned by the accredited soil testing laboratory upon receipt of the sample. Used for chain-of-custody tracking, COA (Certificate of Analysis) retrieval, and audit trail linkage to lab reports.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfSubsamples rdf:type rdf:Property ;
    rdfs:label 'Number Of Subsamples' ;
    rdfs:comment 'Count of individual sub-sample cores or grabs composited to form this soil sample. Relevant for composite sampling designs; higher sub-sample counts improve spatial representativeness of trial plot characterisation.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Results Received Date' ;
    rdfs:comment 'Date on which the laboratory analysis results were received and ingested into the research data system. Used to calculate lab turnaround time and to trigger downstream amendment experiment design workflows.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for the soil sample, used on lab submission forms, chain-of-custody documents, and COA (Certificate of Analysis) reports. Follows the enterprise soil sample coding convention.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampledBy rdf:type rdf:Property ;
    rdfs:label 'Sampled By' ;
    rdfs:comment 'Name or employee identifier of the field technician or agronomist who physically collected the soil sample. Required for chain-of-custody documentation and experimental reproducibility audits.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sandPct rdf:type rdf:Property ;
    rdfs:label 'Sand Pct' ;
    rdfs:comment 'Percentage of sand-sized particles (0.05–2.0 mm) in the soil sample by weight. Used with silt and clay percentages to verify texture class assignment and support precision soil amendment modelling.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siltPct rdf:type rdf:Property ;
    rdfs:label 'Silt Pct' ;
    rdfs:comment 'Percentage of silt-sized particles (0.002–0.05 mm) in the soil sample by weight. Combined with sand and clay fractions to determine soil texture class and water retention characteristics for trial plot baseline data.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterHoldingCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Water Holding Capacity Pct' ;
    rdfs:comment 'Maximum percentage of water the soil can retain against gravity, expressed as a percentage of dry soil weight. Key parameter for irrigation scheduling research, drought-tolerance variety trials, and ET (Evapotranspiration) modelling.' ;
    rdfs:domain ind:ResearchSoilSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisRunDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Run Date' ;
    rdfs:comment 'The calendar date on which the statistical analysis was executed. Used for versioning analytical outputs and tracking when results were generated relative to trial completion.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Run Timestamp' ;
    rdfs:comment 'Precise date and time when the statistical analysis job was executed, including timezone offset. Enables exact reproducibility tracking and audit of analytical pipeline runs.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Classification of the statistical method category applied to generate this result. ANOVA = Analysis of Variance; MET = Multi-Environment Trial analysis; GGE biplot = Genotype plus Genotype-by-Environment biplot for stability analysis; mean_separation = LSD/HSD/Tukey post-hoc tests. [ENUM-REF-CANDIDATE: ANOVA|regression|mean_separation|MET|GGE_biplot|stability|correlation|descriptive|mixed_model|path_analysis — promote to reference product]' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkVarietyMean rdf:type rdf:Property ;
    rdfs:label 'Check Variety Mean' ;
    rdfs:comment 'Mean value of the response variable for the check variety in this analysis. Provides the absolute performance baseline against which experimental varieties are compared. Expressed in the same units as response_variable_unit.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkVarietyName rdf:type rdf:Property ;
    rdfs:label 'Check Variety Name' ;
    rdfs:comment 'Name of the check or control variety used as the performance benchmark in the trial. Variety performance is often expressed relative to the check. Required for commercial variety release decisions and seed selection recommendations.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvPct rdf:type rdf:Property ;
    rdfs:label 'Cv Pct' ;
    rdfs:comment 'Coefficient of Variation expressed as a percentage (CV%), calculated as (standard deviation / grand mean) × 100. Measures experimental precision and data quality. CV% values above 20% for yield trials typically indicate poor experimental control per USDA guidelines.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentCount rdf:type rdf:Property ;
    rdfs:label 'Environment Count' ;
    rdfs:comment 'Number of distinct environments (location-year combinations) included in a Multi-Environment Trial (MET) analysis. A higher count increases the reliability of stability estimates. Applicable when analysis_type is MET, GGE_biplot, or stability.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fStatistic rdf:type rdf:Property ;
    rdfs:label 'F Statistic' ;
    rdfs:comment 'The F-statistic value from the ANOVA table for the primary treatment effect. Ratio of treatment mean square to error mean square. Used to assess whether treatment differences are statistically meaningful.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grandMean rdf:type rdf:Property ;
    rdfs:label 'Grand Mean' ;
    rdfs:comment 'Overall mean value of the response variable across all treatments and replications in the analysis. Serves as the baseline for interpreting treatment effects and computing relative performance metrics.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsdValue rdf:type rdf:Property ;
    rdfs:label 'Hsd Value' ;
    rdfs:comment 'Tukey\'s Honestly Significant Difference (HSD) value at the specified alpha level. More conservative than LSD; used when all pairwise comparisons are of interest. Stored alongside LSD to support different reporting standards.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPublicationReady rdf:type rdf:Property ;
    rdfs:label 'Is Publication Ready' ;
    rdfs:comment 'Indicates whether this statistical result has been reviewed, approved, and is ready for inclusion in external publications, regulatory submissions, or public trial reports. True = approved for publication; False = internal use only or pending review.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lsdValue rdf:type rdf:Property ;
    rdfs:label 'Lsd Value' ;
    rdfs:comment 'Fisher\'s Least Significant Difference (LSD) value at the specified alpha level. Two treatment means differing by more than this value are considered statistically different. Standard mean separation metric in agronomic variety trials.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'Probability value (p-value) for the primary treatment effect in the ANOVA or regression analysis. Values below the significance threshold (typically 0.05 or 0.10) indicate statistically significant treatment differences. Core output for publication-ready trial reporting.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'Coefficient of determination (R²) from the statistical model, ranging 0 to 1. Indicates the proportion of total variation in the response variable explained by the model. Used to assess model fit quality in regression and ANOVA analyses.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseVariable rdf:type rdf:Property ;
    rdfs:label 'Response Variable' ;
    rdfs:comment 'The dependent variable or agronomic trait being analyzed (e.g., \'yield_bu_acre\', \'plant_height_cm\', \'test_weight_lbs_bu\', \'disease_severity_pct\', \'standability_score\'). Defines what outcome the statistical model is measuring.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseVariableUnit rdf:type rdf:Property ;
    rdfs:label 'Response Variable Unit' ;
    rdfs:comment 'Unit of measurement for the response variable (e.g., \'BU/acre\', \'MT/ha\', \'kg/ha\', \'cm\', \'score 1-9\', \'percent\'). Required for correct interpretation of all quantitative result fields. Aligns with BU (Bushel) and MT (Metric Ton) standard agricultural units.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCode rdf:type rdf:Property ;
    rdfs:label 'Result Code' ;
    rdfs:comment 'Externally-known business identifier for this statistical result record, following the format SR-{DOMAIN}-{YEAR}-{SEQUENCE} (e.g., SR-YIELD-2024-00042). Used for cross-referencing in publications, regulatory submissions, and internal reports.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultNotes rdf:type rdf:Property ;
    rdfs:label 'Result Notes' ;
    rdfs:comment 'Free-text field for analyst annotations, data quality observations, model assumptions, outlier notes, or contextual information relevant to interpreting this statistical result. Supports scientific rigor and peer review processes.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceCode rdf:type rdf:Property ;
    rdfs:label 'Significance Code' ;
    rdfs:comment 'Conventional significance notation derived from the p-value: ns = not significant (p>0.10); * = significant at p≤0.05; ** = highly significant at p≤0.01; *** = very highly significant at p≤0.001. Standard notation used in agronomic publication tables.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareName rdf:type rdf:Property ;
    rdfs:label 'Software Name' ;
    rdfs:comment 'Name of the statistical software platform used to execute the analysis (e.g., SAS, R, JMP). Required for reproducibility documentation and regulatory submissions to USDA APHIS. [ENUM-REF-CANDIDATE: SAS|R|JMP|Genstat|ASReml|Python|SPSS — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the statistical software used (e.g., \'SAS 9.4\', \'R 4.3.1\', \'JMP Pro 17\'). Critical for reproducibility — different versions may produce slightly different numerical outputs.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityIndex rdf:type rdf:Property ;
    rdfs:label 'Stability Index' ;
    rdfs:comment 'Quantitative stability index value for variety performance across environments, derived from Finlay-Wilkinson regression (regression coefficient b) or Eberhart-Russell variance of deviations. Values near 1.0 (Finlay-Wilkinson) indicate average stability. Critical for commercial variety release decisions and seed selection recommendations.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityMethod rdf:type rdf:Property ;
    rdfs:label 'Stability Method' ;
    rdfs:comment 'The specific stability analysis method used to compute the stability_index. Finlay-Wilkinson and Eberhart-Russell are regression-based; GGE biplot and AMMI are multivariate. Required to correctly interpret the stability_index value.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardError rdf:type rdf:Property ;
    rdfs:label 'Standard Error' ;
    rdfs:comment 'Standard error of the treatment mean for the response variable. Quantifies the precision of the mean estimate. Published in trial result tables alongside treatment means for scientific reporting.' ;
    rdfs:domain ind:StatisticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Method' ;
    rdfs:comment 'Specific statistical procedure or algorithm applied (e.g., \'Two-way ANOVA with interaction\', \'Finlay-Wilkinson regression\', \'REML mixed model\', \'Tukey HSD\', \'Fisher LSD\', \'Eberhart-Russell stability\', \'AMMI\'). Provides methodological detail beyond the analysis_type classification for reproducibility and publication.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemetryEventId rdf:type rdf:Property ;
    rdfs:label 'Telemetry Event Id' ;
    rdfs:comment 'Primary key for telemetry_event' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batteryLevelPct rdf:type rdf:Property ;
    rdfs:label 'Battery Level Pct' ;
    rdfs:comment 'Remaining battery charge percentage of the IoT sensor or device at the time of the telemetry event. Used for predictive maintenance scheduling and to flag readings that may be unreliable due to low-power device states.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Structured alphanumeric code uniquely identifying the type of telemetry event (e.g., SOIL_MOIST_READ, NDVI_SCAN, VRA_CMD, RTK_FIX, EC_READ). Used for programmatic event classification and downstream routing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (UTC) at which the telemetry event was recorded by the device or sensor. This is the principal real-world observation time, distinct from ingestion or processing timestamps. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isOutlier rdf:type rdf:Property ;
    rdfs:label 'Is Outlier' ;
    rdfs:comment 'Boolean flag indicating whether the telemetry event reading_value was identified as a statistical outlier by automated anomaly detection algorithms (e.g., z-score or IQR-based methods). True indicates the value deviates significantly from the expected distribution for this sensor and event type.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Composite numeric quality score (0.00–100.00) assigned to the telemetry event based on multi-dimensional quality checks including GPS accuracy, sensor calibration status, signal strength, and value range validation. Supports tiered data confidence levels for AI/ML model training.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingDepthCm rdf:type rdf:Property ;
    rdfs:label 'Reading Depth Cm' ;
    rdfs:comment 'Depth in centimetres at which the soil sensor reading was taken (e.g., 15 cm, 30 cm, 60 cm for soil moisture or EC probes). Null for surface or aerial measurements such as NDVI drone scans or equipment position events.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingUnit rdf:type rdf:Property ;
    rdfs:label 'Reading Unit' ;
    rdfs:comment 'The unit of measure associated with the reading_value (e.g., pct for soil moisture percentage, ds_m for Electrical Conductivity (EC) in dS/m, celsius for temperature, ndvi for Normalized Difference Vegetation Index (NDVI), kg_ha for Variable Rate Application (VRA) rate). Ensures dimensional correctness in analytics. [ENUM-REF-CANDIDATE: pct|ds_m|celsius|ndvi|kg_ha|l_ha|mm|m_s|degrees|mbar|lux|mv — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingValue rdf:type rdf:Property ;
    rdfs:label 'Reading Value' ;
    rdfs:comment 'The principal quantitative measurement or observed value captured by the sensor or device for this telemetry event (e.g., soil moisture percentage, EC in dS/m, temperature in °C, NDVI index value, VRA application rate). The unit of measure is captured in reading_unit.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtkAccuracyCm rdf:type rdf:Property ;
    rdfs:label 'Rtk Accuracy Cm' ;
    rdfs:comment 'Horizontal positioning accuracy in centimetres as reported by the Real-Time Kinematic (RTK) GPS receiver at the time of the event. Values below 2.5 cm indicate RTK-fixed precision; higher values indicate degraded or float solutions. Critical for VRA prescription accuracy validation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtkFixType rdf:type rdf:Property ;
    rdfs:label 'Rtk Fix Type' ;
    rdfs:comment 'Classification of the GPS/GNSS positioning solution quality at the time of the event. \'fixed\' indicates centimetre-level RTK accuracy; \'float\' indicates sub-decimetre; \'dgps\' indicates differential correction; \'autonomous\' indicates standard GPS; \'none\' indicates no fix. Drives data quality scoring for precision agriculture analytics.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanAltitudeM rdf:type rdf:Property ;
    rdfs:label 'Scan Altitude M' ;
    rdfs:comment 'Altitude above ground level (AGL) in metres at which the drone or UAV conducted the NDVI or multispectral scan. Affects image resolution and NDVI calculation accuracy. Null for ground-based sensor events.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedKmH rdf:type rdf:Property ;
    rdfs:label 'Speed Km H' ;
    rdfs:comment 'Ground speed of the equipment in kilometres per hour at the time of the telemetry event. Used to validate application uniformity for VRA operations and to detect equipment anomalies such as stalls or over-speed conditions.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Transmission Latency Ms' ;
    rdfs:comment 'Time in milliseconds between the event timestamp recorded by the device and the timestamp of receipt by the data ingestion platform. Used to assess real-time data pipeline performance and identify network latency issues in precision agriculture IoT deployments.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vraActualRate rdf:type rdf:Property ;
    rdfs:label 'Vra Actual Rate' ;
    rdfs:comment 'The actual application rate recorded by the VRA controller at the time of the event (in units defined by reading_unit). Compared against vra_target_rate to assess application accuracy and controller performance. Null for non-VRA event types.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraTargetRate rdf:type rdf:Property ;
    rdfs:label 'Vra Target Rate' ;
    rdfs:comment 'The prescribed target application rate from the active VRA prescription at the time of the event (in units defined by reading_unit). Null for non-VRA event types. Used to compute rate deviation and application accuracy metrics.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traitEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Trait Evaluation Id' ;
    rdfs:comment 'Primary key for trait_evaluation' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Containment Protocol Reference' ;
    rdfs:comment 'Internal document reference code or SOP identifier for the biosafety and containment protocol governing this trait evaluation. Ensures traceability to approved containment procedures required under USDA APHIS confined field trial permits.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation End Date' ;
    rdfs:comment 'Planned or actual date on which the trait evaluation study concluded, including post-harvest monitoring period. Null if the study is ongoing. Used for project closure, regulatory reporting, and pipeline milestone tracking.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPhase rdf:type rdf:Property ;
    rdfs:label 'Evaluation Phase' ;
    rdfs:comment 'Current phase of the trait evaluation lifecycle indicating the regulatory and operational containment level. Greenhouse = controlled indoor environment; Confined Field Trial = outdoor trial under USDA APHIS permit; Non-Regulated = USDA determination of non-regulated status; Deregulated = full commercial release approval obtained.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date on which the trait evaluation study formally commenced, corresponding to first planting or greenhouse inoculation. Used for timeline tracking, regulatory permit compliance, and R&D milestone reporting.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the trait evaluation study within the internal R&D pipeline. Drives workflow routing, resource allocation, and regulatory submission scheduling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaConsultationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Consultation Number' ;
    rdfs:comment 'FDA voluntary consultation identifier assigned under the FDA\'s Coordinated Framework for Regulation of Biotechnology. Tracks the food and feed safety consultation process for the evaluated trait event. Null if consultation has not been initiated.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneConstructDescription rdf:type rdf:Property ;
    rdfs:label 'Gene Construct Description' ;
    rdfs:comment 'Technical description of the genetic construct introduced, including promoter, coding sequence, terminator, and selectable marker elements. Supports molecular characterization data packages for regulatory dossiers and IP documentation.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Gmo Label Required' ;
    rdfs:comment 'Indicates whether products derived from this trait event require GMO labeling under applicable regulations (e.g., USDA National Bioengineered Food Disclosure Standard, EU Regulation 1829/2003). Drives supply chain segregation and labeling compliance workflows.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipPatentNumber rdf:type rdf:Property ;
    rdfs:label 'Ip Patent Number' ;
    rdfs:comment 'Patent number(s) associated with the trait event, gene construct, or transformation technology. Supports IP portfolio management, licensing negotiations, and freedom-to-operate assessments.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipProtectionStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Protection Status' ;
    rdfs:comment 'Current status of intellectual property protection for the trait event. Informs licensing strategy, commercialization timelines, and R&D investment decisions.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlStatus rdf:type rdf:Property ;
    rdfs:label 'Mrl Status' ;
    rdfs:comment 'Status of Maximum Residue Limit establishment for the active ingredient expressed by this trait event in target crop commodities. Drives export market access decisions and food safety compliance for international trade.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:petitionSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Petition Submission Date' ;
    rdfs:comment 'Date on which the USDA APHIS petition for determination of non-regulated status was formally submitted. Null if petition has not been filed. Drives regulatory timeline tracking and commercialization planning.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryEfficacyMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Efficacy Metric' ;
    rdfs:comment 'Name of the principal quantitative measurement used to assess trait performance (e.g., yield per acre in BU/acre, percent insect damage reduction, drought survival rate). Defines the key performance indicator for the evaluation study.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEfficacyUnit rdf:type rdf:Property ;
    rdfs:label 'Primary Efficacy Unit' ;
    rdfs:comment 'Unit of measure for the primary efficacy value (e.g., BU/acre, MT/ha, percent, kg/ha). Ensures dimensional consistency for cross-study comparisons and regulatory data submissions.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEfficacyValue rdf:type rdf:Property ;
    rdfs:label 'Primary Efficacy Value' ;
    rdfs:comment 'Measured or observed value of the primary efficacy metric for this trait evaluation study. Represents the principal quantitative outcome of the evaluation (e.g., 185.5 BU/acre yield, 92.3% pest control efficacy). Unit of measure is defined in primary_efficacy_unit.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date on which the primary regulatory approval (USDA APHIS non-regulated status determination, EPA registration, or FDA consultation completion) was received. Null if approval has not yet been granted. Critical for commercialization go/no-go decisions.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Consolidated status of the regulatory submission process across applicable agencies (USDA APHIS, EPA, FDA). Provides a single-field summary for pipeline reporting and executive dashboards.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackedEventFlag rdf:type rdf:Property ;
    rdfs:label 'Stacked Event Flag' ;
    rdfs:comment 'Indicates whether this trait evaluation involves a stacked (pyramided) combination of two or more transformation events in a single variety. Stacked events require additional regulatory data packages and stewardship considerations.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stewardshipRequirements rdf:type rdf:Property ;
    rdfs:label 'Stewardship Requirements' ;
    rdfs:comment 'Narrative description of mandatory stewardship obligations associated with this trait event, including refuge requirements, isolation distances, post-harvest land use restrictions, and grower stewardship agreements. Supports compliance with EPA resistance management plans and USDA stewardship conditions.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketRegions rdf:type rdf:Property ;
    rdfs:label 'Target Market Regions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the intended commercial markets for this trait event. Drives multi-jurisdictional regulatory strategy, import tolerance (IT) applications, and COOL compliance planning.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traitEventName rdf:type rdf:Property ;
    rdfs:label 'Trait Event Name' ;
    rdfs:comment 'Human-readable name assigned to the specific biotechnology transformation event under evaluation (e.g., MON 810, Bt11, GA21). Serves as the primary identity label for the trait event across regulatory submissions and internal pipeline tracking.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traitType rdf:type rdf:Property ;
    rdfs:label 'Trait Type' ;
    rdfs:comment 'Classification of the primary agronomic or quality trait conferred by the transformation event. Drives regulatory pathway selection, stewardship requirements, and internal R&D pipeline categorization. [ENUM-REF-CANDIDATE: herbicide_tolerance|insect_resistance|drought_tolerance|yield_enhancement|disease_resistance|nitrogen_use_efficiency|stacked_trait|quality_enhancement — promote to reference product]' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationEventCode rdf:type rdf:Property ;
    rdfs:label 'Transformation Event Code' ;
    rdfs:comment 'Externally recognized alphanumeric code assigned to the specific transformation event by the developing organization or regulatory body (e.g., MON-00810-6). Used as the business identifier in USDA APHIS petitions, EPA registrations, and FDA consultations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationMethod rdf:type rdf:Property ;
    rdfs:label 'Transformation Method' ;
    rdfs:comment 'Biotechnology method used to introduce the genetic construct into the host plant genome. Determines applicable regulatory classification (GMO vs. new genomic techniques) and influences the regulatory pathway under USDA APHIS and EU frameworks.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPlotCount rdf:type rdf:Property ;
    rdfs:label 'Trial Plot Count' ;
    rdfs:comment 'Total number of experimental plots assigned to this trait evaluation study across all trial locations and seasons. Supports statistical power calculations, resource planning, and regulatory data sufficiency assessments.' ;
    rdfs:domain ind:TraitEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regenerativePracticeId rdf:type rdf:Property ;
    rdfs:label 'Regenerative Practice Id' ;
    rdfs:comment 'Foreign key linking to sustainability.regenerative_practice. Business justification: Research trials testing cover cropping, reduced tillage, or organic amendments must reference the canonical regenerative_practice definition for ESG reporting alignment and practice efficacy validatio' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegenerativePractice .

ind:actualApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Application Date' ;
    rdfs:comment 'Actual calendar date on which the treatment was applied in the field. The principal real-world event date for this treatment record. Used for PHI/REI compliance verification, efficacy analysis, and trial data reconciliation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aiConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Ai Concentration Pct' ;
    rdfs:comment 'Percentage concentration of the Active Ingredient (AI) in the treatment formulation (e.g., 22.9% azoxystrobin). Used for MRL compliance calculations and EPA FIFRA label verification.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerUnitArea rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit Area' ;
    rdfs:comment 'Estimated or actual cost of applying this treatment per unit area (e.g., USD per acre or USD per hectare). Used for Return on Investment (ROI) analysis, OPEX tracking, and economic threshold evaluation in IPM decision-making.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentalUsePermit rdf:type rdf:Property ;
    rdfs:label 'Experimental Use Permit' ;
    rdfs:comment 'EPA Experimental Use Permit (EUP) number for treatments not yet fully registered but authorized for field research under FIFRA Section 5. Required for USDA APHIS biotech regulatory submissions and trial compliance documentation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipmStrategy rdf:type rdf:Property ;
    rdfs:label 'Ipm Strategy' ;
    rdfs:comment 'Integrated Pest Management (IPM) strategy classification for the treatment (e.g., chemical, biological, cultural, mechanical, threshold-based). Supports EPA and USDA IPM program compliance and sustainable farming practice reporting.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationRegime rdf:type rdf:Property ;
    rdfs:label 'Irrigation Regime' ;
    rdfs:comment 'Irrigation management strategy applied in the treatment, expressed relative to Evapotranspiration (ET) replacement (e.g., full ET replacement, 75% deficit, rainfed). Applicable when treatment_type = \'irrigation\'. Supports water resource management analytics.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControl rdf:type rdf:Property ;
    rdfs:label 'Is Control' ;
    rdfs:comment 'Indicates whether this treatment represents the control group (untreated check or standard practice baseline) in the experimental design. Essential for statistical analysis and yield response calculations.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npkNitrogenRate rdf:type rdf:Property ;
    rdfs:label 'Npk Nitrogen Rate' ;
    rdfs:comment 'Rate of Nitrogen (N) component in the fertilizer treatment expressed in the treatment\'s unit of measure (e.g., lb N/ac). Part of the NPK (Nitrogen-Phosphorus-Potassium) nutrient management plan. Applicable when treatment_type = \'fertilizer\'.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkPhosphorusRate rdf:type rdf:Property ;
    rdfs:label 'Npk Phosphorus Rate' ;
    rdfs:comment 'Rate of Phosphorus (P) component in the fertilizer treatment expressed in the treatment\'s unit of measure (e.g., lb P2O5/ac). Part of the NPK (Nitrogen-Phosphorus-Potassium) nutrient management plan. Applicable when treatment_type = \'fertilizer\'.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npkPotassiumRate rdf:type rdf:Property ;
    rdfs:label 'Npk Potassium Rate' ;
    rdfs:comment 'Rate of Potassium (K) component in the fertilizer treatment expressed in the treatment\'s unit of measure (e.g., lb K2O/ac). Part of the NPK (Nitrogen-Phosphorus-Potassium) nutrient management plan. Applicable when treatment_type = \'fertilizer\'.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Application Date' ;
    rdfs:comment 'Scheduled calendar date for applying the treatment in the field trial. Used for trial planning, equipment scheduling, and Pre-Harvest Interval (PHI) and Restricted Entry Interval (REI) compliance pre-calculation.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current regulatory approval status of the treatment for use on the target crop in the applicable jurisdiction (e.g., EPA-approved, USDA APHIS experimental use permit, restricted use). Critical for compliance gate checks in trial planning and USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedVarietyCode rdf:type rdf:Property ;
    rdfs:label 'Seed Variety Code' ;
    rdfs:comment 'Proprietary or industry-standard code identifying the seed variety used in a seed variety treatment (e.g., Pioneer P1197 AM, Dekalb DKC62-08). Links to seed lot and variety trial records. Applicable when treatment_type = \'seed_variety\'.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal sequence number of this treatment within the trial\'s treatment list (e.g., T1, T2, T3). Used for randomization, plot assignment, and statistical analysis output alignment in replicated experimental designs.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCrop rdf:type rdf:Property ;
    rdfs:label 'Target Crop' ;
    rdfs:comment 'The crop species or commodity for which this treatment is designed and registered (e.g., corn, soybean, wheat, cotton). Required for EPA FIFRA label use site compliance and USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPestOrWeed rdf:type rdf:Property ;
    rdfs:label 'Target Pest Or Weed' ;
    rdfs:comment 'The specific pest, disease, weed, or abiotic stress the treatment is designed to control or mitigate (e.g., \'Gray Leaf Spot\', \'Waterhemp\', \'Corn Rootworm\', \'Nitrogen deficiency\'). Supports Integrated Pest Management (IPM) efficacy studies and scouting observation linkage.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the treatment within a trial or across the research program. Used in field notebooks, statistical analysis outputs, and regulatory submissions (e.g., USDA APHIS biotech submissions).' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentName rdf:type rdf:Property ;
    rdfs:label 'Treatment Name' ;
    rdfs:comment 'Human-readable descriptive name of the treatment (e.g., \'Pioneer P1197 AM + 120 lb N/ac\', \'Azoxystrobin 6 fl oz/ac\', \'Drip Irrigation 1.2 ET Replacement\'). Used in reports, dashboards, and scientific publications.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vraEnabled rdf:type rdf:Property ;
    rdfs:label 'Vra Enabled' ;
    rdfs:comment 'Indicates whether this treatment is configured for Variable Rate Application (VRA) using precision agriculture technology (e.g., Trimble Ag Software VRA prescriptions, John Deere Operations Center). Enables spatial analytics and prescription map linkage.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationStage rdf:type rdf:Property ;
    rdfs:label 'Application Stage' ;
    rdfs:comment 'The crop growth stage at which the treatment was applied (e.g., pre_plant, vegetative, reproductive). Critical for efficacy analysis, label compliance, and correlation with yield outcomes in variety trial and IPM efficacy studies. [ENUM-REF-CANDIDATE: pre_plant|at_plant|emergence|vegetative|reproductive|pre_harvest|post_harvest — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TreatmentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'The precise date and time at which the treatment application was performed in the field. Principal business event timestamp. Used for PHI (Pre-Harvest Interval) and REI (Restricted Entry Interval) compliance calculations and time-series efficacy analysis.' ;
    rdfs:domain ind:TreatmentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Total quantity of input material consumed during this application event (actual_rate × area_treated_ha, or directly measured). Used for inventory drawdown, research COGS tracking, and input consumption reporting.' ;
    rdfs:domain ind:TreatmentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedMs rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Ms' ;
    rdfs:comment 'Wind speed in meters per second recorded at the time of application. Critical for drift risk assessment, label compliance (maximum wind speed restrictions for pesticide applications), and environmental impact analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containmentProtocol rdf:type rdf:Property ;
    rdfs:label 'Containment Protocol' ;
    rdfs:comment 'Description of the biological containment measures applied to prevent unintended gene flow or environmental release during GMO trait trials (e.g., isolation distances, pollen barriers, border rows, bagging). Required for APHIS permit compliance.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLockDate rdf:type rdf:Property ;
    rdfs:label 'Data Lock Date' ;
    rdfs:comment 'Date on which trial data was formally locked, preventing further modifications to raw data records. Required for data integrity, regulatory submissions, and statistical analysis finalization.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficacyRating rdf:type rdf:Property ;
    rdfs:label 'Efficacy Rating' ;
    rdfs:comment 'Quantitative efficacy rating (percentage control) of the IPM treatment or crop protection product against the target pest organism. Expressed as percent control (0-100). Applicable for trial_type = \'IPM\'. Used for MRL compliance and label claim support.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentalDesign rdf:type rdf:Property ;
    rdfs:label 'Experimental Design' ;
    rdfs:comment 'Statistical experimental design used for the trial. RCBD = Randomized Complete Block Design; CRD = Completely Randomized Design; Latin_Square; Split_Plot; Alpha_Lattice; Augmented. Determines analysis methodology and statistical model selection.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTraitEventName rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Event Name' ;
    rdfs:comment 'Official name of the GMO transformation event under evaluation (e.g., \'MON 810\', \'Bt11\', \'GTS 40-3-2\'). Applicable for trial_type = \'GMO_trait\'. Required for USDA APHIS biotech regulatory submissions.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoTraitType rdf:type rdf:Property ;
    rdfs:label 'Gmo Trait Type' ;
    rdfs:comment 'Classification of the GMO trait being evaluated. Applicable for trial_type = \'GMO_trait\'. Drives regulatory pathway selection and stewardship protocol requirements. [ENUM-REF-CANDIDATE: herbicide_tolerance|insect_resistance|drought_tolerance|disease_resistance|yield_enhancement|quality_trait|nitrogen_use_efficiency|abiotic_stress_tolerance — promote to reference product]' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'Scientific hypothesis being tested in the trial. Documents the expected outcome and forms the basis for statistical analysis design and interpretation of results.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmoContained rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Contained' ;
    rdfs:comment 'Indicates whether the trial involves contained GMO material subject to USDA APHIS 7 CFR Part 340 field trial permit requirements. Drives containment protocol enforcement and regulatory notification workflows.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midSeasonReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mid Season Review Date' ;
    rdfs:comment 'Date of the scheduled mid-season agronomic review and data collection checkpoint. Used to assess trial progress, identify anomalies, and make in-season management adjustments.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Formal statement of the primary research objective or business question the trial is designed to answer. Captured at protocol approval and used in regulatory submissions and research publications.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestTargetOrganism rdf:type rdf:Property ;
    rdfs:label 'Pest Target Organism' ;
    rdfs:comment 'Scientific or common name of the pest, disease, or weed species targeted by the IPM (Integrated Pest Management) efficacy study (e.g., \'Diabrotica virgifera (Western Corn Rootworm)\', \'Fusarium graminearum (Fusarium Head Blight)\'). Applicable for trial_type = \'IPM\'.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Stage within the research and development pipeline at which this trial is being conducted. Supports innovation pipeline tracking and R&D portfolio management from early discovery through commercial readiness.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotScale rdf:type rdf:Property ;
    rdfs:label 'Pilot Scale' ;
    rdfs:comment 'Geographic and operational scale of the precision agriculture pilot. Applicable for trial_type = \'precision_ag\'. Determines resource requirements, statistical validity, and readiness for commercial rollout.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plotCount rdf:type rdf:Property ;
    rdfs:label 'Plot Count' ;
    rdfs:comment 'Total number of experimental plots assigned to this trial. Drives statistical power calculations, replication design validation, and resource allocation for field operations.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:precisionAgTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Precision Ag Technology Type' ;
    rdfs:comment 'Classification of the precision agriculture technology being piloted. Applicable for trial_type = \'precision_ag\'. VRA = Variable Rate Application; RTK = Real-Time Kinematic positioning; IoT = Internet of Things sensors; NDVI = Normalized Difference Vegetation Index imaging.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Approval Date' ;
    rdfs:comment 'Date on which the trial protocol was formally reviewed and approved by the research governance committee or regulatory body. Key lifecycle milestone required before field operations may begin.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date on which the final trial report was submitted to the sponsoring program, regulatory body, or external partner. Final lifecycle milestone for trial closure and IP documentation.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technologyVendor rdf:type rdf:Property ;
    rdfs:label 'Technology Vendor' ;
    rdfs:comment 'Name of the technology vendor or research partner providing the precision agriculture technology or equipment under evaluation. Applicable for trial_type = \'precision_ag\'. Used for vendor performance tracking and partnership management.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCode rdf:type rdf:Property ;
    rdfs:label 'Trial Code' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the trial for cross-system reference, regulatory submissions, and partner communications. Used in USDA APHIS biotech submissions and GLOBALG.A.P. documentation.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialName rdf:type rdf:Property ;
    rdfs:label 'Trial Name' ;
    rdfs:comment 'Descriptive human-readable name of the trial or experiment (e.g., \'Corn Hybrid Yield Trial 2024 - Iowa\', \'Glyphosate-Resistant Weed IPM Study\'). Used in reporting, dashboards, and research publications.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Status' ;
    rdfs:comment 'Current lifecycle state of the trial. Drives workflow routing, data lock controls, and reporting eligibility. \'planned\' = protocol approved, not yet initiated; \'active\' = field operations underway; \'completed\' = data locked and report submitted; \'cancelled\' = trial terminated before completion.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialType rdf:type rdf:Property ;
    rdfs:label 'Trial Type' ;
    rdfs:comment 'Classification of the trial by its primary research objective. Drives type-specific attribute applicability: variety (seed performance benchmarks), soil_amendment (soil health experiments), IPM (Integrated Pest Management efficacy), GMO_trait (genetically modified organism trait evaluation), precision_ag (precision agriculture technology pilot).' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialObservationId rdf:type rdf:Property ;
    rdfs:label 'Trial Observation Id' ;
    rdfs:comment 'Unique system-generated identifier for each trial observation record. Serves as the primary key for the trial_observation data product in the research domain.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bbchGrowthStage rdf:type rdf:Property ;
    rdfs:label 'Bbch Growth Stage' ;
    rdfs:comment 'Standardized BBCH (Biologische Bundesanstalt, Bundessortenamt und CHemische Industrie) scale code representing the crop developmental stage at time of observation (00–99). Used for phenological alignment across varieties and trial sites in crop improvement programs.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canopyCoverPct rdf:type rdf:Property ;
    rdfs:label 'Canopy Cover Pct' ;
    rdfs:comment 'Estimated percentage of ground area covered by crop canopy at time of observation (0–100%). Indicator of crop vigor, weed suppression potential, and biomass accumulation. Collected via manual estimation, drone imagery, or NDVI analysis.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diseaseRating rdf:type rdf:Property ;
    rdfs:label 'Disease Rating' ;
    rdfs:comment 'Standardized rating of disease incidence and severity observed on the crop at the time of scouting (e.g., percentage of plants infected, severity scale 0–9). Used in crop protection efficacy studies and resistance trait evaluations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecValueDsM rdf:type rdf:Property ;
    rdfs:label 'Ec Value Ds M' ;
    rdfs:comment 'Soil electrical conductivity (EC) reading in deciSiemens per meter (dS/m), measured by EC probes or sensors. Indicates soil salinity, nutrient levels, and texture variability. Key input for variable rate application (VRA) prescriptions and soil management research.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lodgingScore rdf:type rdf:Property ;
    rdfs:label 'Lodging Score' ;
    rdfs:comment 'Standardized score (typically 0–9 or 0–100%) indicating the degree of stem or root lodging observed in the trial plot. Critical trait measurement in variety performance trials and crop improvement programs.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationDate rdf:type rdf:Property ;
    rdfs:label 'Observation Date' ;
    rdfs:comment 'Calendar date on which the observation was made. Used for day-level aggregation, growing season alignment, and post-season reporting where timestamp precision is not required.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationType rdf:type rdf:Property ;
    rdfs:label 'Observation Type' ;
    rdfs:comment 'Categorical classification of what was measured or observed (e.g., growth_stage, stand_count, canopy_cover, ndvi, pest_incidence, disease_rating, weed_pressure, lodging_score, soil_moisture, ec_reading, temperature, vra_log, rtk_accuracy). Determines the semantic meaning of the reading_value field. [ENUM-REF-CANDIDATE: growth_stage|stand_count|canopy_cover|ndvi|pest_incidence|disease_rating|weed_pressure|lodging_score|soil_moisture|ec_reading|temperature|vra_log|rtk_accuracy — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pestIncidenceRating rdf:type rdf:Property ;
    rdfs:label 'Pest Incidence Rating' ;
    rdfs:comment 'Quantitative rating of pest presence and severity at the observation point, expressed as percentage of plants affected or a standardized scale score. Supports IPM (Integrated Pest Management) efficacy analysis and threshold-based intervention decisions.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityFlagReason rdf:type rdf:Property ;
    rdfs:label 'Quality Flag Reason' ;
    rdfs:comment 'Free-text explanation for a non-valid data quality flag (e.g., sensor malfunction, equipment calibration drift, observer error, environmental interference). Required when data_quality_flag is \'suspect\', \'invalid\', or \'estimated\'.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the agronomist, data manager, or researcher who reviewed and validated this observation record. Supports audit trail requirements for USDA APHIS regulatory submissions and GFSI compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorDepthCm rdf:type rdf:Property ;
    rdfs:label 'Sensor Depth Cm' ;
    rdfs:comment 'Depth in centimeters at which a soil sensor probe (moisture, temperature, EC) was installed or reading was taken. Critical for interpreting soil measurement data in soil amendment experiments and irrigation research.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standCount rdf:type rdf:Property ;
    rdfs:label 'Stand Count' ;
    rdfs:comment 'Number of emerged plants per unit area (typically plants per linear foot or per square meter) recorded during the observation. Key metric for evaluating seed germination performance and planting uniformity in variety trials.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vraControllerLogRef rdf:type rdf:Property ;
    rdfs:label 'Vra Controller Log Ref' ;
    rdfs:comment 'Reference identifier for the VRA (Variable Rate Application) controller log entry associated with this observation. Links precision ag equipment application records to field trial observations for input efficacy analysis.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weedPressureScore rdf:type rdf:Property ;
    rdfs:label 'Weed Pressure Score' ;
    rdfs:comment 'Scored assessment of weed density and competitive pressure within the trial plot at time of observation. Supports herbicide efficacy trials, IPM program evaluation, and sustainable farming practice research.' ;
    rdfs:domain ind:TrialObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCecMeq100g rdf:type rdf:Property ;
    rdfs:label 'Baseline Cec Meq 100g' ;
    rdfs:comment 'Pre-trial baseline measurement of soil Cation Exchange Capacity (CEC) in milliequivalents per 100 grams of soil. Indicates the soil\'s ability to hold and supply nutrients; used as a covariate in NPK fertilizer response trials and soil amendment efficacy studies.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineEcDsM rdf:type rdf:Property ;
    rdfs:label 'Baseline Ec Ds M' ;
    rdfs:comment 'Pre-trial baseline measurement of soil Electrical Conductivity (EC) in deciSiemens per meter (dS/m). Indicates soil salinity levels and is a key covariate for irrigation response trials, salt-tolerant variety evaluations, and soil amendment experiments.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineNdvi rdf:type rdf:Property ;
    rdfs:label 'Baseline Ndvi' ;
    rdfs:comment 'Pre-trial baseline Normalized Difference Vegetation Index (NDVI) value for the plot, ranging from -1 to 1. Derived from remote sensing imagery (satellite or UAV) via Climate FieldView or Esri ArcGIS. Used as a covariate for crop vigor analysis and to establish pre-treatment vegetation conditions.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineOmPct rdf:type rdf:Property ;
    rdfs:label 'Baseline Om Pct' ;
    rdfs:comment 'Pre-trial baseline measurement of soil Organic Matter (OM) content expressed as a percentage of dry soil weight. Key indicator of soil health and fertility; used as a covariate in nutrient response trials, cover crop efficacy studies, and sustainable farming practice evaluations.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselinePh rdf:type rdf:Property ;
    rdfs:label 'Baseline Ph' ;
    rdfs:comment 'Pre-trial baseline measurement of soil pH (Potential of Hydrogen) for this plot, indicating soil acidity or alkalinity on a scale of 0-14. Critical covariate for nutrient availability analysis, fertilizer response trials, and soil amendment efficacy studies. Measured prior to treatment application.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockNumber rdf:type rdf:Property ;
    rdfs:label 'Block Number' ;
    rdfs:comment 'The block number assigned to this plot within the experimental design. Blocks group plots with similar environmental conditions (soil type, slope, drainage) to reduce experimental error and improve statistical precision in blocked experimental designs.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cropVarietyCode rdf:type rdf:Property ;
    rdfs:label 'Crop Variety Code' ;
    rdfs:comment 'The standardized code identifying the crop variety or hybrid planted in this trial plot. Used to link plot-level performance data to seed lot records, variety trial databases, and IP/patent records. Aligns with seed catalog codes from SAP S/4HANA MM module and Granular Farm Management.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Narrative description of the reason this plot was excluded from statistical analysis or abandoned (e.g., flood damage, equipment malfunction, pest outbreak, contamination from adjacent treatment). Populated only when plot_status is \'excluded\' or \'abandoned\'. Required for trial integrity documentation in USDA APHIS regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentalDesignType rdf:type rdf:Property ;
    rdfs:label 'Experimental Design Type' ;
    rdfs:comment 'The statistical experimental design type applied to this trial plot\'s parent trial. RCBD = Randomized Complete Block Design; CRD = Completely Randomized Design; ALPHA = Alpha-Lattice Design; LATIN_SQUARE = Latin Square Design; SPLIT_PLOT = Split-Plot Design; STRIP_TRIAL = Strip Trial Design. Determines the statistical analysis model applied to plot-level results.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsBoundaryPolygon rdf:type rdf:Property ;
    rdfs:label 'Gps Boundary Polygon' ;
    rdfs:comment 'GIS polygon representing the precise GPS boundary coordinates of the trial plot, stored as a Well-Known Text (WKT) or GeoJSON string. Enables spatial analysis, variable rate application mapping, and integration with Esri ArcGIS and John Deere Operations Center field mapping.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBorderPlot rdf:type rdf:Property ;
    rdfs:label 'Is Border Plot' ;
    rdfs:comment 'Indicates whether this plot is designated as a border plot (True) or an interior measurement plot (False). Border plots are typically excluded from yield and performance measurements to eliminate edge effects and contamination from adjacent treatments.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCheckPlot rdf:type rdf:Property ;
    rdfs:label 'Is Check Plot' ;
    rdfs:comment 'Indicates whether this plot is a check (control) plot (True) used as a baseline reference for comparing experimental treatments. Check plots receive a standard commercial variety or untreated control and are essential for calculating relative performance metrics.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The timestamp when this trial plot record was most recently updated. Used for change tracking, data synchronization with source systems (Trimble Ag Software, Granular Farm Management), and audit compliance under FSMA and SOX requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plotCode rdf:type rdf:Property ;
    rdfs:label 'Plot Code' ;
    rdfs:comment 'Human-readable, externally-known alphanumeric code uniquely identifying the trial plot within the trial management system. Used in field documentation, data collection forms, and regulatory submissions (e.g., USDA APHIS biotech submissions). Sourced from Trimble Ag Software or Granular Farm Management field planning modules.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plotSizeAcres rdf:type rdf:Property ;
    rdfs:label 'Plot Size Acres' ;
    rdfs:comment 'Physical area of the trial plot measured in acres. Used for yield normalization, input rate calculations, and statistical analysis. Standard unit of measure in US agricultural operations per USDA reporting conventions.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plotSizeHectares rdf:type rdf:Property ;
    rdfs:label 'Plot Size Hectares' ;
    rdfs:comment 'Physical area of the trial plot measured in hectares. Used for international reporting, Codex Alimentarius submissions, and alignment with metric-standard regulatory bodies including ISO 22000 and GLOBALG.A.P.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plotStatus rdf:type rdf:Property ;
    rdfs:label 'Plot Status' ;
    rdfs:comment 'Current lifecycle status of the trial plot. \'active\' indicates the plot is under active observation; \'harvested\' indicates data collection is complete; \'abandoned\' indicates the plot was removed from the trial due to damage or contamination; \'excluded\' indicates the plot was statistically excluded from analysis; \'pending\' indicates setup is not yet complete.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangePosition rdf:type rdf:Property ;
    rdfs:label 'Range Position' ;
    rdfs:comment 'The range position (east-west axis) of the plot within the field trial layout grid. Combined with row_position to uniquely locate a plot within the trial spatial grid. Used for spatial analysis and border plot identification.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replicationNumber rdf:type rdf:Property ;
    rdfs:label 'Replication Number' ;
    rdfs:comment 'The replication number of this plot within the experimental design (e.g., Rep 1, Rep 2, Rep 3). Replications are used to account for field variability and are essential for valid statistical analysis of treatment effects in randomized complete block designs (RCBD) and other experimental layouts.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rowPosition rdf:type rdf:Property ;
    rdfs:label 'Row Position' ;
    rdfs:comment 'The row position (north-south axis) of the plot within the field trial layout grid. Used for spatial mapping, adjacency analysis, and border effect corrections in statistical models. Sourced from Trimble Ag Software field planning layouts.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seedingRateUsed rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Used' ;
    rdfs:comment 'Actual seeding rate (seeds per acre) applied for this specific variety in this trial, which may differ from the label recommendation. Belongs to the trial-variety combination, not to either entity alone.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilSeries rdf:type rdf:Property ;
    rdfs:label 'Soil Series' ;
    rdfs:comment 'The USDA NRCS soil series classification for the soil type present in this trial plot (e.g., \'Drummer\', \'Flanagan\', \'Tama\'). Soil series is a key covariate in statistical analysis of trial results and is used for site characterization in USDA APHIS regulatory submissions.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialYear rdf:type rdf:Property ;
    rdfs:label 'Trial Year' ;
    rdfs:comment 'The calendar year in which this trial plot was active. Used for multi-year trial analysis, growing season alignment, and historical performance benchmarking across crop improvement programs.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldResult rdf:type rdf:Property ;
    rdfs:label 'Yield Result' ;
    rdfs:comment 'Measured yield outcome (bushels per acre or kg/ha) for this variety in this specific trial environment. Core performance metric used in variety registration and commercial release decisions.' ;
    rdfs:domain ind:TrialPlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialProtocolId rdf:type rdf:Property ;
    rdfs:label 'Trial Protocol Id' ;
    rdfs:comment 'Unique surrogate identifier for the trial protocol record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:TrialProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaRegistrationRef rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Ref' ;
    rdfs:comment 'EPA registration number or experimental use permit (EUP) reference for pesticide or biopesticide products prescribed in this protocol. Required for Federal Insecticide, Fungicide, and Rodenticide Act (FIFRA) compliance.' ;
    rdfs:domain ind:TrialProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDescription rdf:type rdf:Property ;
    rdfs:label 'Protocol Description' ;
    rdfs:comment 'Detailed narrative description of the trial protocol scope, objectives, and key procedural requirements. Provides context for agronomists, field technicians, and regulatory reviewers.' ;
    rdfs:domain ind:TrialProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSeedingRate rdf:type rdf:Property ;
    rdfs:label 'Target Seeding Rate' ;
    rdfs:comment 'Prescribed seeding rate for the trial as defined in the protocol. Represents the number of seeds or weight of seed to be planted per unit area. Unit of measure is captured in seeding_rate_unit.' ;
    rdfs:domain ind:TrialProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nearestWeatherStationId rdf:type rdf:Property ;
    rdfs:label 'Nearest Weather Station Id' ;
    rdfs:comment 'Identifier of the nearest NOAA or DTN weather monitoring station used for climate data correlation with trial results. Supports ET calculations, growing degree day (GDD) accumulation, and weather-adjusted yield analysis.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:siteManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: trial_site has site_manager_name, site_manager_email, and site_manager_phone as plain-text denormalizations of an employee. Linking to workforce.employee enables certification checks (APHIS permit eli' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the trial site was first approved and activated for research use. Marks the start of the site\'s operational lifecycle and is used for cooperator agreement effective date alignment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail such as suite, building, or additional location descriptor for the trial site.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aphisPermitEligible rdf:type rdf:Property ;
    rdfs:label 'Aphis Permit Eligible' ;
    rdfs:comment 'Indicates whether the trial site meets USDA APHIS requirements for conducting regulated article (GMO) field trials under 7 CFR Part 340. Sites must meet isolation, containment, and monitoring criteria to be eligible.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containmentClassification rdf:type rdf:Property ;
    rdfs:label 'Containment Classification' ;
    rdfs:comment 'Regulatory containment classification for the trial site, particularly relevant for GMO and regulated article field trials under USDA APHIS 7 CFR Part 340. Determines required isolation distances, monitoring protocols, and post-trial land use restrictions.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRegistered rdf:type rdf:Property ;
    rdfs:label 'Fsma Registered' ;
    rdfs:comment 'Indicates whether the trial site is registered under the FDA Food Safety Modernization Act (FSMA) Produce Safety Rule (21 CFR Part 112). Required for sites conducting trials on covered produce commodities.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationAvailable rdf:type rdf:Property ;
    rdfs:label 'Irrigation Available' ;
    rdfs:comment 'Indicates whether irrigation infrastructure is available at the trial site. Determines eligibility for irrigated trial designs and influences water resource management planning for ET-based irrigation scheduling.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousCropHistory rdf:type rdf:Property ;
    rdfs:label 'Previous Crop History' ;
    rdfs:comment 'Summary of crops grown at the trial site in prior seasons (e.g., \'corn-soybean-corn rotation\'). Critical for trial design to account for residual herbicide carryover, disease pressure, and soil nutrient status from prior crop rotations.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the trial site across systems including Trimble Ag Software, Climate FieldView, and FMIS integrations. Used as the business key in cross-system references and regulatory submissions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the trial site (e.g., \'Ames Research Station\', \'Johnson Cooperator Farm\', \'Iowa State University Extension Site\'). Used in reports, regulatory submissions, and cooperator communications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the trial site. Controls whether new trials can be assigned to this site. \'pending_approval\' indicates the site is under review for regulatory or cooperator agreement compliance.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the trial site by operational category. Determines applicable protocols, containment requirements, and cooperator agreement types. [ENUM-REF-CANDIDATE: research_station|cooperator_farm|university_extension|commercial_farm|government_facility — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Total Area Acres' ;
    rdfs:comment 'Total land area of the trial site available for research activities, measured in acres. Used for trial plot capacity planning, cooperator agreement scope definition, and regulatory containment area calculations.' ;
    rdfs:domain ind:TrialSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedVendorId rdf:type rdf:Property ;
    rdfs:label 'Seed Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: variety.seed_company is a denormalized text reference to the seed supplier. Linking to procurement.vendor via seed_vendor_id enables seed sourcing decisions, vendor qualification checks, and contract ' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:varietyCgiarAccessionId rdf:type rdf:Property ;
    rdfs:label 'Variety Cgiar Accession Id' ;
    rdfs:comment 'Cross-reference identifier from the CGIAR (Consultative Group on International Agricultural Research) genebank system. Supports international germplasm exchange and biodiversity conservation tracking.' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accession .

ind:varietyGrinAccessionId rdf:type rdf:Property ;
    rdfs:label 'Variety Grin Accession Id' ;
    rdfs:comment 'Cross-reference identifier from the USDA Germplasm Resources Information Network (GRIN) database for germplasm accessions. Enables interoperability with national and international gene bank systems.' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accession .

ind:entryStage rdf:type rdf:Property ;
    rdfs:label 'Entry Stage' ;
    rdfs:comment 'Pipeline position of the variety or germplasm entry, distinguishing between gene bank holdings and active breeding pipeline stages. Drives workflow routing in the research and commercialization process. [ENUM-REF-CANDIDATE: accession|wild_relative|landrace|elite_line|experimental_hybrid|pre_commercial|released — promote to reference product]' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantPatentNumber rdf:type rdf:Property ;
    rdfs:label 'Plant Patent Number' ;
    rdfs:comment 'USPTO plant patent number assigned to the variety if protected under the Plant Patent Act. Distinct from PVP certificate; applies primarily to asexually reproduced varieties.' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseYear rdf:type rdf:Property ;
    rdfs:label 'Release Year' ;
    rdfs:comment 'Calendar year in which the variety was officially released for commercial sale or public distribution. Used for portfolio age analysis and variety lifecycle management.' ;
    rdfs:domain ind:Variety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Yield Measurement Id' ;
    rdfs:comment 'Unique system-generated identifier for each yield measurement record captured at the plot or field level during harvest operations.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:growingDegreeDayId rdf:type rdf:Property ;
    rdfs:label 'Growing Degree Day Id' ;
    rdfs:comment 'Foreign key linking to weather.growing_degree_day. Business justification: Yield-environment correlation in MET analysis requires linking harvest yield to the actual seasonal GDD accumulation record. yield_measurement carries growing_degree_days as a denormalized attribute; ' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrowingDegreeDay .

ind:adjustedYieldBuAc rdf:type rdf:Property ;
    rdfs:label 'Adjusted Yield Bu Ac' ;
    rdfs:comment 'Yield per acre expressed in bushels (BU) adjusted to standard moisture content. Primary YPM (Yield Per Acre Metric) used for variety performance ranking and trial benchmarking in North American markets.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedYieldMtHa rdf:type rdf:Property ;
    rdfs:label 'Adjusted Yield Mt Ha' ;
    rdfs:comment 'Yield per hectare expressed in metric tons (MT) adjusted to standard moisture content. Primary YPM (Yield Per Acre Metric) used for international variety performance benchmarking and Codex Alimentarius reporting.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grainOilPct rdf:type rdf:Property ;
    rdfs:label 'Grain Oil Pct' ;
    rdfs:comment 'Oil content of the harvested grain as a percentage of dry matter. Critical quality metric for oilseed crops (soybean, canola, sunflower) affecting processing yield and commodity value.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grainProteinPct rdf:type rdf:Property ;
    rdfs:label 'Grain Protein Pct' ;
    rdfs:comment 'Protein content of the harvested grain as a percentage of dry matter. Key quality attribute for wheat, soybean, and other protein crops affecting market grade, end-use suitability, and COA (Certificate of Analysis) reporting.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harvestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Harvest Timestamp' ;
    rdfs:comment 'Precise date and time at which the yield measurement was recorded during harvest operations. Supports intra-day harvest sequencing and equipment utilization analysis via John Deere Operations Center telematics.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:harvestedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Harvested Weight Kg' ;
    rdfs:comment 'Gross weight of crop harvested from the trial plot in kilograms, as measured at the point of harvest before moisture adjustment. Primary raw input for yield calculation.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementCode rdf:type rdf:Property ;
    rdfs:label 'Measurement Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this yield measurement record, used in field data collection systems such as Climate FieldView and Granular Farm Management for cross-system traceability.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plotAreaHa rdf:type rdf:Property ;
    rdfs:label 'Plot Area Ha' ;
    rdfs:comment 'Measured area of the trial plot in hectares at the time of harvest. Used to calculate per-unit yield (BU/acre or MT/ha) from gross harvested weight. Sourced from Esri ArcGIS field mapping.' ;
    rdfs:domain ind:YieldMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Flag' ;
    rdfs:comment 'Data quality assessment flag assigned during Silver Layer validation. Identifies records that passed automated quality checks, failed validation rules, or require manual review before inclusion in statistical yield analysis.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualVolumeTargetMt rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Target Mt' ;
    rdfs:comment 'Agreed annual commodity volume target in Metric Tons (MT) that the broker is expected to facilitate. Used for performance tracking, tiered commission threshold evaluation, and seasonal demand forecasting. Supports YPM (Yield Per Acre Metric) analytics.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerCategory rdf:type rdf:Property ;
    rdfs:label 'Broker Category' ;
    rdfs:comment 'Operational category indicating the primary commodity segment the broker specializes in. Supports routing of sales opportunities and commission rule assignment. [ENUM-REF-CANDIDATE: commodity|grain|livestock|produce|specialty_crop|multi_commodity|feed|fiber — promote to reference product if expanded]' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerCode rdf:type rdf:Property ;
    rdfs:label 'Broker Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the broker, used in SAP S/4HANA SD partner function records and Salesforce CRM for cross-system reference. Unique across all broker records.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerType rdf:type rdf:Property ;
    rdfs:label 'Broker Type' ;
    rdfs:comment 'Classification of the broker entity: individual independent agent, brokerage firm, agricultural cooperative acting as intermediary, or industry association. Drives commission structure and contract template selection.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'Primary street address of the broker\'s registered business location. Used for commission payment remittance, legal correspondence, and USDA registration verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City of the broker\'s registered business address. Used in geographic territory assignment and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the broker\'s primary business country. Determines applicable regulatory framework (USDA, FDA, COOL compliance) and currency for commission payments.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'Two-letter US state or Canadian province code for the broker\'s primary business location. Drives state licensing compliance checks and territory assignment logic.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which broker commissions are calculated and paid (e.g., USD, CAD, EUR). Supports multi-currency commission settlement for international brokers.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'Standard commission rate expressed as a percentage of the net sales order value earned by the broker for facilitating a transaction. Used as the default rate in commission calculation rules. Stored as a decimal (e.g., 0.0250 = 2.50%). Negotiated per broker agreement.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionStructureType rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Type' ;
    rdfs:comment 'Type of commission calculation structure applicable to this broker: flat rate (fixed percentage), tiered (rate varies by volume band), volume bonus (additional payment at threshold), spot-linked (tied to spot market price), or futures-linked (tied to futures contract price). Drives commission engine logic.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date on which the broker agreement expires or is terminated. Null indicates an open-ended agreement. Used to enforce commission eligibility cutoffs and trigger renewal workflows in Salesforce CRM.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date on which the broker agreement becomes legally effective and the broker is authorized to transact on behalf of the enterprise. Used for commission eligibility validation and contract lifecycle management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax Identification Number (TIN) for the broker entity. Required for IRS 1099 commission reporting and SAP FI vendor master setup for commission payments.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsPreference rdf:type rdf:Property ;
    rdfs:label 'Incoterms Preference' ;
    rdfs:comment 'Preferred International Commercial Terms (Incoterms) used by the broker in sales transactions, such as FOB (Free On Board) or CIF (Cost Insurance and Freight). Defaults to sales order Incoterms when broker is assigned. Relevant for BOL generation and logistics cost allocation.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the broker completed the enterprise onboarding process, including USDA registration verification, license validation, SAP vendor master creation, and Salesforce CRM partner record activation.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSalesChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Sales Channel' ;
    rdfs:comment 'Primary sales channel through which the broker facilitates transactions: spot market (immediate delivery pricing), forward contract, futures-linked pricing, auction, or direct negotiation. Aligns with pricing strategy configuration in SAP S/4HANA SD and DTN market data feeds.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforcePartnerCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Partner Code' ;
    rdfs:comment 'External system identifier linking this broker master record to the corresponding partner account record in Salesforce CRM. Enables bidirectional synchronization of broker profile, opportunity assignments, and relationship status between the Silver layer and Salesforce.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'SAP S/4HANA FI/MM vendor master record number assigned to the broker for commission payment processing via Accounts Payable. Required for 1099 reporting and commission disbursement through SAP FI payment runs.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriod rdf:type rdf:Property ;
    rdfs:label 'Settlement Period' ;
    rdfs:comment 'Frequency at which broker commission statements are generated and payments are settled. Determines the commission aggregation window in the commission lifecycle management process.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used by the broker in commercial transactions, if different from the legal name. Used in sales order documentation and BOL generation.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Registration Number' ;
    rdfs:comment 'Official USDA registration or license number issued to the broker under the Agricultural Marketing Act or Packers and Stockyards Act. Required for compliance with USDA AMS and APHIS regulations when brokering regulated commodities.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdVolumeFacilitatedMt rdf:type rdf:Property ;
    rdfs:label 'Ytd Volume Facilitated Mt' ;
    rdfs:comment 'Cumulative commodity volume in Metric Tons (MT) facilitated by the broker in the current calendar or fiscal year. Used for performance monitoring against annual volume targets and tiered commission threshold evaluation. Refreshed from SAP S/4HANA SD sales order data.' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Agricultural sales contracts are the formal outcome of won opportunities. contract carries salesforce_opportunity_id (STRING) as a CRM reference but has no FK to the in-domain opportunity record. Addi' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:deliveryEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery End Date' ;
    rdfs:comment 'The latest date by which all contracted commodity deliveries must be completed. Defines the closing of the contracted delivery window and triggers penalty or renegotiation clauses if unfulfilled.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Start Date' ;
    rdfs:comment 'The earliest date on which commodity deliveries may commence under this contract. Defines the opening of the contracted delivery window for call-off scheduling.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfilledVolume rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Volume' ;
    rdfs:comment 'Cumulative volume of commodity actually delivered and accepted against this contract to date, expressed in the contract volume UOM. Compared against contracted_volume to determine fulfillment percentage and open position.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureMaxPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Max Pct' ;
    rdfs:comment 'Maximum allowable moisture content (%) of the commodity at point of delivery as specified in the contract quality terms. Deliveries exceeding this threshold are subject to dockage or rejection per USDA grain standards.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'The agreed unit price per volume UOM for fixed-price and forward contracts. For basis and futures-linked contracts, this field captures the locked price once fixation occurs; otherwise null until price fixation date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceFixationDate rdf:type rdf:Property ;
    rdfs:label 'Price Fixation Date' ;
    rdfs:comment 'The date by which the buyer must fix the price on a basis or futures-linked contract. After this date, the price defaults to the prevailing market price per contract terms. Null for fixed-price contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'The SAP S/4HANA SD module contract document number (10-digit) that is the system-of-record identifier for this contract in the ERP. Used for cross-system reconciliation between the lakehouse and SAP.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which the contract was formally executed and signed by both parties. Represents the business event timestamp of contract inception. May differ from effective_date if there is a retroactive or future effective period.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text field capturing any non-standard contractual terms, addenda, or special conditions agreed between the parties (e.g., custom dockage schedules, force majeure clauses, sustainability requirements, organic certification obligations).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWeightMin rdf:type rdf:Property ;
    rdfs:label 'Test Weight Min' ;
    rdfs:comment 'Minimum test weight (lbs/bushel) required for grain commodity deliveries under this contract. Test weight is a key USDA grade determinant for corn, soybeans, and wheat. Deliveries below this threshold are subject to grade discount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAllocationId rdf:type rdf:Property ;
    rdfs:label 'Customer Allocation Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a single customer allocation record. Primary key for the customer_allocation data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAllocationCustomerAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Customer Allocation Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent allocation record from which this allocation was derived through reallocation. Null for original allocations. Enables reallocation history tracking and audit trail for customer relationship equity management during shortages.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAllocation .

ind:allocatedVolume rdf:type rdf:Property ;
    rdfs:label 'Allocated Volume' ;
    rdfs:comment 'The quantity of commodity volume assigned to this customer under this allocation record. Expressed in the unit of measure specified in volume_uom (BU — Bushel or MT — Metric Ton). Represents the committed supply quantity during constrained periods.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The business rationale or methodology used to determine how available supply is distributed to this customer. Drives equitable allocation decisions during supply-constrained periods. Values: contract_priority (contractual obligation rank), customer_tier (strategic customer classification), channel_strategy (distribution channel priority), pro_rata (proportional to historical volume), spot_market (open market availability), regulatory (government or regulatory mandate).' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingType rdf:type rdf:Property ;
    rdfs:label 'Pricing Type' ;
    rdfs:comment 'Classification of the pricing mechanism applied to this allocation. spot = current market price, forward = agreed future delivery price, futures_linked = price tied to exchange futures contract, basis = futures price plus/minus a basis differential, fixed = locked price regardless of market, index = price tied to a published index (e.g., DTN, WASDE).' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reallocationFlag rdf:type rdf:Property ;
    rdfs:label 'Reallocation Flag' ;
    rdfs:comment 'Indicates whether this allocation record was created as a result of a reallocation from another customer or contract. When True, the original_allocation_id field identifies the source allocation from which volume was transferred.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingVolume rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume' ;
    rdfs:comment 'Outstanding uncommitted or undelivered volume under this allocation (allocated_volume minus fulfilled_volume). Maintained as a stored field to support real-time supply planning and customer commitment tracking without requiring on-the-fly calculation in constrained-period dashboards.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyConstraintReason rdf:type rdf:Property ;
    rdfs:label 'Supply Constraint Reason' ;
    rdfs:comment 'The primary reason triggering the allocation management process for this record. Identifies the supply-side event causing shortfall relative to contracted volumes. Used for root cause analysis, insurance claims, and regulatory reporting. [ENUM-REF-CANDIDATE: drought|poor_harvest|logistics_disruption|quality_rejection|force_majeure|regulatory_hold|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Shipment Date' ;
    rdfs:comment 'The actual calendar date on which the commodity physically departed the ship-from location. Compared against scheduled shipment date for on-time performance KPI tracking.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The sales and distribution channel through which this delivery is executed — direct to customer, via broker/agent, through a distributor, export channel, or intercompany transfer. Supports channel performance analytics.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Number' ;
    rdfs:comment 'Externally visible, human-readable delivery order reference number used in communications with carriers, customers, and logistics partners. Follows the format DO-YYYY-NNNNNN.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightMt rdf:type rdf:Property ;
    rdfs:label 'Net Weight Mt' ;
    rdfs:comment 'Net weight of the commodity in metric tons, excluding packaging and tare. Used for commodity quantity reconciliation, invoice verification, and USDA reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'The pricing mechanism applied to this delivery — spot (current market price), forward (agreed future price), futures-linked (tied to CBOT/CME futures contract), contract fixed (pre-agreed fixed price), or basis (futures price plus/minus a basis differential).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'Indicates whether a signed Proof of Delivery (POD) document has been received from the customer or carrier, confirming physical receipt of the commodity. Triggers invoice release in SAP SD.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The planned calendar date on which the commodity is expected to arrive at the ship-to customer location. Used for customer commitment and demand planning.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Shipment Date' ;
    rdfs:comment 'The planned calendar date on which the commodity is scheduled to depart from the ship-from location. Used for carrier booking and logistics coordination.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:climateRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.climate_risk_assessment. Business justification: Agricultural demand forecasts incorporate climate risk assessments as key inputs — drought or flood risk in a supply region directly affects supply availability and thus demand fulfillment forecasting' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClimateRiskAssessment .

ind:distributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Id' ;
    rdfs:comment 'Reference to the sales and distribution channel through which the forecasted volume is expected to be sold (e.g., direct, broker, export, retail, food manufacturer). Links to the channel master in SAP S/4HANA SD.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionChannel .

ind:seedPerformanceBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Seed Performance Benchmark Id' ;
    rdfs:comment 'Foreign key linking to research.performance_benchmark. Business justification: Demand forecasters use variety performance benchmark data (yield potential, stability index, geographic performance) to set volume and revenue forecasts. This named process — \'demand planning using va' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceBenchmark .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'Actual volume of the commodity sold or delivered during the forecast period, populated after period close from SAP S/4HANA SD sales order actuals. Used to calculate forecast_accuracy_pct and support retrospective demand analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Assumed Unit Price' ;
    rdfs:comment 'Price per unit of measure assumed in the demand forecast for revenue projection purposes. May be derived from spot market prices, forward contract prices, or futures-linked pricing. Expressed in currency_code per volume_uom.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'Volume already committed through signed sales contracts, forward contracts, or confirmed customer purchase orders as of the forecast creation date. Represents the firm portion of the forecasted demand, distinct from the speculative or pipeline-based portion.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Pct' ;
    rdfs:comment 'Post-period accuracy metric comparing the forecasted volume to the actual realized volume, expressed as a percentage. Calculated after the forecast period closes. Used as a KPI for continuous improvement of the demand forecasting process. Null for future periods not yet realized.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBasis rdf:type rdf:Property ;
    rdfs:label 'Forecast Basis' ;
    rdfs:comment 'Primary data source or methodology used to generate the demand forecast. WASDE outlook = USDA World Agricultural Supply and Demand Estimates; customer_commitment = confirmed or indicative customer orders; historical_trend = statistical extrapolation from prior period actuals; market_intelligence = broker/analyst inputs; sales_pipeline = Salesforce CRM opportunity data.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConfidencePct rdf:type rdf:Property ;
    rdfs:label 'Forecast Confidence Pct' ;
    rdfs:comment 'Analyst-assigned or model-generated confidence level for the demand forecast, expressed as a percentage (0.00–100.00). Reflects the degree of certainty in the forecasted volume and revenue estimates based on data quality, market visibility, and customer commitment levels.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Created Timestamp' ;
    rdfs:comment 'Timestamp when this demand forecast record was first created in the system. Used for audit trail and version lineage tracking.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastNotes rdf:type rdf:Property ;
    rdfs:label 'Forecast Notes' ;
    rdfs:comment 'Free-text field for analyst commentary, assumptions, risk factors, or market intelligence notes associated with this demand forecast. Captures qualitative context not represented in structured fields, such as weather risk, geopolitical factors, or customer-specific intelligence.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Externally-known business identifier for the forecast record, used in SAP S/4HANA SD module and Salesforce CRM for cross-system traceability. Format: DF-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'The last calendar date of the forecast period for which demand volumes and revenues are projected. Defines the closing boundary of the planning horizon window.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'The first calendar date of the forecast period for which demand volumes and revenues are projected. Used in conjunction with forecast_period_end_date to define the planning horizon window.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodType rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Type' ;
    rdfs:comment 'Granularity of the forecast period. Annual covers the full crop year; quarterly covers a three-month period; monthly covers a single calendar month; weekly covers a seven-day period. Determines the temporal resolution of the forecasted volume and revenue.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle state of the demand forecast record. Draft indicates work-in-progress; submitted indicates pending approval; approved indicates active planning baseline; superseded indicates replaced by a newer version; cancelled indicates withdrawn.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Updated Timestamp' ;
    rdfs:comment 'Timestamp when this demand forecast record was most recently modified. Tracks revision activity for audit and data lineage purposes.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Monotonically incrementing version number for the forecast record. Enables tracking of forecast revisions over time within the same forecast period and commodity. Version 1 is the initial baseline; subsequent revisions increment the version.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastedRevenue rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue' ;
    rdfs:comment 'Projected gross revenue expected from the forecasted demand volume during the forecast period, calculated as forecasted_volume multiplied by the assumed unit price. Expressed in the currency specified by currency_code. Used for sales planning, EBITDA projections, and contract negotiation strategy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedVolume rdf:type rdf:Property ;
    rdfs:label 'Forecasted Volume' ;
    rdfs:comment 'Projected quantity of the commodity expected to be demanded during the forecast period, expressed in the unit of measure specified in volume_uom. Represents the central (base case) volume estimate used for sales planning and inventory pre-positioning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGmIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Gm Included' ;
    rdfs:comment 'Indicates whether the forecasted commodity volume includes Genetically Modified Organism (GMO) varieties. Relevant for COOL (Country of Origin Labeling) compliance, export market eligibility, and customer contract specifications that restrict GMO content.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineVolume rdf:type rdf:Property ;
    rdfs:label 'Pipeline Volume' ;
    rdfs:comment 'Volume associated with active sales opportunities in the Salesforce CRM pipeline that have not yet converted to confirmed contracts. Represents the speculative or at-risk portion of the forecasted demand, weighted by opportunity probability.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonal Index' ;
    rdfs:comment 'Multiplicative seasonal adjustment factor applied to the base demand forecast to account for known seasonal demand patterns (e.g., harvest-driven supply surges, holiday food demand peaks). A value of 1.0000 indicates no seasonal adjustment; values above 1.0 indicate above-average seasonal demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeHigh rdf:type rdf:Property ;
    rdfs:label 'Volume High' ;
    rdfs:comment 'Upper bound of the forecasted demand volume range, representing the optimistic or upside scenario. Used alongside volume_low and forecasted_volume to communicate forecast uncertainty to sales and supply chain planning teams.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLow rdf:type rdf:Property ;
    rdfs:label 'Volume Low' ;
    rdfs:comment 'Lower bound of the forecasted demand volume range, representing the pessimistic or downside scenario. Used in risk-adjusted sales planning and contract negotiation strategy alongside the base and high estimates.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasdeReferenceDate rdf:type rdf:Property ;
    rdfs:label 'Wasde Reference Date' ;
    rdfs:comment 'Publication date of the USDA World Agricultural Supply and Demand Estimates (WASDE) report used as a reference input for this forecast. Enables traceability of forecast assumptions to a specific WASDE release cycle.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:askPrice rdf:type rdf:Property ;
    rdfs:label 'Ask Price' ;
    rdfs:comment 'The price at which a seller is willing to sell the commodity per unit of measure on the price date. Used alongside bid_price to determine the bid-ask spread for market liquidity assessment and quote ceiling setting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisValue rdf:type rdf:Property ;
    rdfs:label 'Basis Value' ;
    rdfs:comment 'The difference between the local cash price and the nearby futures contract price (cash price minus futures price), expressed in the same currency and unit of measure. Basis reflects local supply/demand conditions, transportation costs, and storage premiums. Critical for sales teams performing basis calculations, forward contract pricing, and local market competitiveness analysis.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Price' ;
    rdfs:comment 'The price at which a buyer is willing to purchase the commodity per unit of measure on the price date. Used by sales teams for pricing validation, quote floor setting, and basis calculation. Expressed in the currency and unit of measure specified in this record.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closePrice rdf:type rdf:Property ;
    rdfs:label 'Close Price' ;
    rdfs:comment 'The last traded price at the close of the market session on the price date. Distinct from settlement_price which may be calculated differently by the exchange. Used for end-of-day reporting, trend analysis, and daily price comparison across periods.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPoint rdf:type rdf:Property ;
    rdfs:label 'Delivery Point' ;
    rdfs:comment 'The specific geographic delivery location or terminal associated with this price (e.g., \'Gulf of Mexico — New Orleans\', \'Pacific Northwest — Portland\', \'Chicago Delivery\', \'On-Farm — Iowa\'). Relevant for FOB and CIF price types. Used in logistics cost modeling, transportation benchmarking, and BOL generation.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTo rdf:type rdf:Property ;
    rdfs:label 'Effective To' ;
    rdfs:comment 'The timestamp until which this price record is valid. Null indicates the record is currently active (open-ended validity). Used in conjunction with effective_from for SCD Type 2 historical price tracking, enabling point-in-time price lookups for audit, contract dispute resolution, and retrospective margin analysis.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gradeOrQuality rdf:type rdf:Property ;
    rdfs:label 'Grade Or Quality' ;
    rdfs:comment 'The commodity grade, quality class, or specification standard to which this price applies (e.g., \'#2 Yellow Corn\', \'Hard Red Winter Wheat — 11% protein\', \'USDA Choice Beef\', \'No. 1 Soybeans\'). Prices vary significantly by grade; this field ensures accurate price-to-product matching for sales quotes and procurement benchmarking.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highPrice rdf:type rdf:Property ;
    rdfs:label 'High Price' ;
    rdfs:comment 'The highest price at which the commodity traded during the market session on the price date. Used for price range analysis, volatility reporting, and sales opportunity identification when prices reach favorable levels.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Indicates whether the price date falls on a market holiday or exchange closure day (True = holiday/no trading, False = regular trading day). Used to identify non-trading days in price series analysis, gap-filling logic, and seasonal demand forecasting models.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowPrice rdf:type rdf:Property ;
    rdfs:label 'Low Price' ;
    rdfs:comment 'The lowest price at which the commodity traded during the market session on the price date. Used alongside high_price for daily price range analysis, risk assessment, and procurement cost benchmarking.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketLocation rdf:type rdf:Property ;
    rdfs:label 'Market Location' ;
    rdfs:comment 'The geographic market location, elevator name, port, or exchange venue associated with this price (e.g., \'Chicago Board of Trade\', \'Gulf of Mexico Export Terminal\', \'Kansas City\', \'Minneapolis Grain Exchange\', \'Local Elevator — Ames IA\'). Used for basis calculation, regional price comparison, and logistics cost benchmarking.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openInterest rdf:type rdf:Property ;
    rdfs:label 'Open Interest' ;
    rdfs:comment 'The total number of outstanding futures or options contracts that have not been settled or closed as of the price date. A key indicator of market participation and hedging activity. Used by finance and sales teams for market sentiment analysis and forward pricing strategy.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openPrice rdf:type rdf:Property ;
    rdfs:label 'Open Price' ;
    rdfs:comment 'The price at which the commodity first traded at the opening of the market session on the price date. Used for intraday price movement analysis, volatility assessment, and sales team market briefings.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChange rdf:type rdf:Property ;
    rdfs:label 'Price Change' ;
    rdfs:comment 'The net change in price from the previous trading session\'s settlement or close price to the current session\'s settlement or close price. Expressed as a signed decimal (positive = price increase, negative = price decrease). Used for daily market movement reporting and sales team briefings.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceDate rdf:type rdf:Property ;
    rdfs:label 'Price Date' ;
    rdfs:comment 'The calendar date for which this market price record is valid. Represents the trading or reporting date of the price observation. Used by sales teams for daily pricing validation, basis calculation, and quote generation aligned with market conditions on a specific date.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceFrequency rdf:type rdf:Property ;
    rdfs:label 'Price Frequency' ;
    rdfs:comment 'The temporal frequency or granularity of this price observation. Values: intraday (tick or interval price within a trading session), daily (end-of-day or daily summary), weekly (weekly average or closing price), monthly (monthly average, used for WASDE and long-term planning). Determines how the record is used in analytics and forecasting pipelines.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceQualifier rdf:type rdf:Property ;
    rdfs:label 'Price Qualifier' ;
    rdfs:comment 'Additional qualifier describing the nature or timing of the price within its type. Values: nearby (nearest active futures contract month), deferred (future delivery month beyond nearby), spot (immediate delivery cash price), forward (agreed future delivery price), indicative (non-binding market indication), firm (binding quoted price). Used to distinguish pricing intent for quote generation and contract negotiation.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'The originating data source or market feed from which this price record was obtained. Values: DTN (Data Transmission Network market data), CME (Chicago Mercantile Exchange futures), WASDE (World Agricultural Supply and Demand Estimates — USDA monthly report), elevator_bid (local grain elevator posted bid), USDA_AMS (USDA Agricultural Marketing Service daily reports), broker (broker or dealer quote). Critical for data lineage, source credibility weighting, and audit compliance.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Lifecycle status of this price record indicating its current validity and usability. Values: active (current valid price for use), superseded (replaced by a corrected or updated record), preliminary (provisional price pending final confirmation), final (confirmed and authoritative), cancelled (withdrawn price record). Ensures sales teams only use validated prices for quote generation.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Price Timestamp' ;
    rdfs:comment 'The precise date and time of the intraday price observation or quote capture (ISO 8601 format with timezone offset). Applicable for intraday price feeds from CME futures or DTN real-time data. Null for end-of-day or daily summary records.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementPrice rdf:type rdf:Property ;
    rdfs:label 'Settlement Price' ;
    rdfs:comment 'The official end-of-day settlement price established by the exchange or market authority for the commodity on the price date. Used as the authoritative reference for daily mark-to-market, margin calculations, forward contract valuation, and revenue benchmarking by finance and procurement teams.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Total number of contracts or units traded for this commodity on the price date. Indicates market liquidity and trading activity. Used by sales and procurement teams to assess market depth and execution feasibility for large volume transactions.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasdeReportMonth rdf:type rdf:Property ;
    rdfs:label 'Wasde Report Month' ;
    rdfs:comment 'The YYYY-MM formatted month of the USDA WASDE report from which this price or supply/demand context was sourced. Applicable only when price_source = \'WASDE\'. The WASDE report is published monthly by USDA and is a primary reference for global commodity supply/demand balance sheets used in revenue benchmarking and seasonal forecasting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Date on which the opportunity was actually closed, either as won (converted to SO) or lost. Populated upon final disposition of the opportunity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Close Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this opportunity will be successfully closed and converted to a sales order (SO). Used for weighted pipeline revenue forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competing supplier or trader identified in this opportunity. Supports competitive intelligence tracking and win/loss analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedSoNumber rdf:type rdf:Property ;
    rdfs:label 'Converted So Number' ;
    rdfs:comment 'SAP S/4HANA Sales Order (SO) number generated upon successful conversion of this opportunity to a confirmed order. Provides traceability from pipeline to order execution.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Code' ;
    rdfs:comment 'External opportunity identifier sourced from Salesforce CRM, used to cross-reference and reconcile pipeline records between the lakehouse and the CRM system of record.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue' ;
    rdfs:comment 'Projected gross revenue for this opportunity, calculated as estimated volume multiplied by target price. Used for weighted pipeline revenue reporting and seasonal financial forecasting. Expressed in transaction currency.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume' ;
    rdfs:comment 'Estimated quantity of the commodity to be sold under this opportunity, expressed in the volume unit of measure (e.g., bushels, metric tons, hundredweight). Core input for revenue forecasting and supply planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Reason code explaining why a closed-lost opportunity was not won. Populated only when pipeline_stage = \'closed_lost\'. Drives win/loss analysis and commercial strategy improvement. [ENUM-REF-CANDIDATE: price|competitor|volume|timing|quality|relationship|no_decision — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned commercial action or follow-up step required to advance this opportunity (e.g., \'Send price proposal\', \'Schedule farm visit\', \'Submit COA\'). Supports sales rep activity management.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'Scheduled date for the next planned commercial action on this opportunity. Used for sales rep task management and pipeline velocity tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date on which the sales opportunity was formally opened and entered into the pipeline. Marks the start of the commercial engagement lifecycle.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Human-readable descriptive name or title of the sales opportunity, typically including the customer name, commodity, and season (e.g., \'Acme Foods – Corn Q3 2025 Forward Contract\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure against which the target price is quoted. Common agricultural units include BU (Bushel), MT (Metric Ton), CWT (Hundredweight), LB (Pound), KG (Kilogram), TON (Short Ton).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing mechanism applied to this opportunity. Spot pricing reflects current market rates; forward pricing locks in a future delivery price; futures-linked pricing ties to exchange-traded commodity futures (e.g., CBOT); basis pricing reflects the differential to a futures benchmark; contract pricing is pre-agreed; negotiated is bespoke. Integrates with DTN/WASDE market data feeds.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDivision rdf:type rdf:Property ;
    rdfs:label 'Sales Division' ;
    rdfs:comment 'Organizational sales division or business unit responsible for this opportunity (e.g., Grain Trading, Livestock, Specialty Crops, Inputs). Maps to SAP S/4HANA SD organizational structure.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Primary key for order' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentCrewId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: In agriculture (especially fresh produce), the harvest/packing crew assigned to fulfill a sales order is tracked for FSMA food safety traceability — linking a foodborne illness event back to the speci' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Sales orders in agricultural commodity trading are routinely created from accepted quotes. Adding order.quote_id → sales.quote.quote_id enables quote-to-order conversion tracking and supports revenue ' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the seller after availability check (ATP — Available to Promise) in SAP S/4HANA. May differ from the requested delivery date. Used for customer commitment management and logistics execution.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Freight and transportation charges billed to the customer as part of this order, consistent with the agreed Incoterms. Denominated in the transaction currency. Relevant for CIF orders where freight is included in the seller\'s price.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsmaTraceabilityLot rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Lot' ;
    rdfs:comment 'Lot number (LOT) or batch tracking identifier assigned to the commodity in this order for FSMA Food Traceability Rule compliance. Enables farm-to-fork traceability for covered foods listed on the Food Traceability List (FTL). Required for FDA recall readiness and HACCP documentation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futuresContractReference rdf:type rdf:Property ;
    rdfs:label 'Futures Contract Reference' ;
    rdfs:comment 'Exchange-traded futures contract identifier used as the pricing benchmark for futures-linked or basis-priced orders (e.g., \'CBOT-ZC-DEC24\' for December 2024 CBOT Corn futures). Nullable for fixed-price and index-priced orders. Supports commodity risk management and hedge accounting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the sales order was officially placed and confirmed by the customer. This is the principal commercial event date used for revenue period attribution, seasonal demand analysis, and WASDE reporting alignment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPointCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Point Code' ;
    rdfs:comment 'SAP shipping point code identifying the farm-gate, warehouse, or grain elevator from which the goods will be dispatched. Determines the outbound logistics route and BOL origin. Aligns with Manhattan Associates WMS facility codes.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soNumber rdf:type rdf:Property ;
    rdfs:label 'So Number' ;
    rdfs:comment 'Externally-known, human-readable sales order number generated by SAP S/4HANA SD module (e.g., SO-0000123456). Used for customer-facing communication, BOL references, and cross-system reconciliation with Salesforce CRM and Oracle NetSuite.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Commodity class or variety classification within the grade (e.g., Hard Red Winter, Soft Red Winter for wheat; Yellow Dent for corn; Roundup Ready for soybeans). Provides sub-grade differentiation for specialty or identity-preserved commodity sales.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity of the commodity confirmed for delivery by the seller after inventory allocation and availability check. May differ from ordered quantity due to stock availability, crop yield constraints, or partial fulfillment agreements.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of the commodity physically delivered or shipped against this sales order line, as recorded upon BOL generation or warehouse goods issue. Used for revenue recognition and invoice reconciliation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the specific delivery point or destination for this line item (e.g., elevator code, port terminal code, warehouse location code). Used for logistics planning, BOL generation, and TMS routing. May reference a grain elevator, export terminal, or customer facility.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'USDA or industry-standard grade designation for the commodity on this line (e.g., US No. 1, US No. 2, Sample Grade for grains; Choice, Select for livestock). Determines pricing differentials and buyer acceptance criteria. Sourced from Certificate of Analysis (COA) or grain inspection.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this sales order line calculated as confirmed quantity multiplied by unit price, before taxes and after applicable discounts. Used for revenue recognition, invoice generation, and financial reporting under IFRS 15 / GAAP.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phiCleared rdf:type rdf:Property ;
    rdfs:label 'Phi Cleared' ;
    rdfs:comment 'Indicates whether the mandatory Pre-Harvest Interval (PHI) — the minimum number of days between last pesticide/chemical application and harvest — has been satisfied for the commodity on this line. True = PHI interval elapsed and cleared; False = PHI not yet met. Required for food safety compliance and MRL verification.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: COOL (Country of Origin Labeling) declarations must be certified by a named, qualified employee. Regulatory audits require tracing the certifying individual. \'certifying_party_name\' is a denormalized ' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByOriginDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Origin Declaration Id' ;
    rdfs:comment 'Reference to the replacement COOL declaration that supersedes this record when a correction or amendment is issued. Enables declaration version lineage tracking for audit and compliance purposes.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OriginDeclaration .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text field capturing compliance officer notes, investigation findings, corrective actions, or regulatory correspondence related to this COOL declaration. Supports USDA AMS audit and enforcement documentation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Certifying Party Role' ;
    rdfs:comment 'Role of the certifying party in the supply chain as defined by USDA COOL regulations. Determines the level of responsibility and documentation requirements for the declaration.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Cool Regulation Reference' ;
    rdfs:comment 'Specific USDA COOL regulatory citation applicable to this declaration (e.g., \'7 CFR Part 60\', \'7 CFR Part 65\'). Part 60 covers muscle cuts of beef, pork, lamb, chicken, goat, and fish; Part 65 covers perishable agricultural commodities, peanuts, pecans, ginseng, and macadamia nuts.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the country where the covered commodity was produced, raised, or harvested (e.g., USA, CAN, MEX, BRA). Core COOL compliance field.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginName rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Name' ;
    rdfs:comment 'Full English name of the country of origin corresponding to the country_of_origin_code, for display on labels and regulatory documentation (e.g., \'United States of America\', \'Canada\', \'Mexico\').' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized Tariff Schedule code for the covered commodity, used in customs documentation and import/export declarations. Supports cross-referencing with CBP import records for origin verification.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Import Entry Number' ;
    rdfs:comment 'U.S. Customs and Border Protection (CBP) import entry number for imported or mixed-origin commodities. Required for COOL declarations involving non-domestic origin to substantiate the country of origin claim.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Origin Document Reference' ;
    rdfs:comment 'Reference number or identifier of the supporting origin documentation (e.g., phytosanitary certificate number, import entry number, supplier declaration reference). Enables audit retrieval of the underlying evidence.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDocumentationType rdf:type rdf:Property ;
    rdfs:label 'Origin Documentation Type' ;
    rdfs:comment 'Type of supporting documentation used to substantiate the country of origin claim. Examples: supplier_declaration (written supplier attestation), import_certificate (USDA/CBP import record), phytosanitary_certificate (APHIS/IPPC plant health certificate), coa (Certificate of Analysis), customs_entry (CBP entry document), affidavit (sworn statement).' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLabelText rdf:type rdf:Property ;
    rdfs:label 'Origin Label Text' ;
    rdfs:comment 'The exact label text to be displayed on the covered commodity per USDA COOL requirements (e.g., \'Product of USA\', \'Product of USA and Canada\', \'Farm-Raised, Product of Chile\'). This is the verbatim text that appears on retail packaging or point-of-sale signage.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionMethod rdf:type rdf:Property ;
    rdfs:label 'Production Method' ;
    rdfs:comment 'Classification of how the covered commodity was produced or sourced, as required by USDA COOL regulations. Values: domestic (produced entirely in the US), imported (produced entirely outside the US), mixed (combination of US and foreign origin), farm_raised (aquaculture), wild_caught (wild-harvested fish/shellfish).' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Retailer Notification Date' ;
    rdfs:comment 'Date on which the retailer was formally notified of the COOL origin information for the covered commodity. Required for audit trail under USDA COOL enforcement.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailerNotified rdf:type rdf:Property ;
    rdfs:label 'Retailer Notified' ;
    rdfs:comment 'Indicates whether the downstream retailer has been formally notified of the COOL declaration details as required by USDA COOL regulations. Retailers bear ultimate labeling responsibility and must receive origin information from suppliers.' ;
    rdfs:domain ind:OriginDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Id' ;
    rdfs:comment 'Primary key for price_agreement' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the base price for this agreement, expressed as a decimal (e.g., 0.0250 = 2.50%). Represents negotiated rebates, volume discounts, or promotional allowances. Stored as a rate; the monetary discount amount is computed at order time.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flatDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Discount Amount' ;
    rdfs:comment 'Fixed monetary discount per unit applied to the base price under this agreement (e.g., USD 0.05 per bushel). Used when the discount is a fixed amount rather than a percentage. Expressed in currency_code per price_uom.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether this pricing agreement grants the customer exclusive pricing rights for the specified commodity, grade, and channel — preventing the same terms from being offered to competing buyers during the effective period.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketReferenceIndex rdf:type rdf:Property ;
    rdfs:label 'Market Reference Index' ;
    rdfs:comment 'The external market data source or price index used as the benchmark for index-based or futures-linked pricing (e.g., DTN ProphetX, WASDE, CME CBOT, Reuters Commodities). Supports traceability of price derivation.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVolumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Volume Threshold' ;
    rdfs:comment 'The maximum quantity of the commodity covered under this pricing agreement tier. Purchases exceeding this threshold may trigger a different price tier or require renegotiation. Expressed in the price_uom.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Volume Threshold' ;
    rdfs:comment 'The minimum quantity of the commodity the customer must purchase to qualify for this pricing agreement tier. Expressed in the price_uom. Used for volume-tiered pricing and commitment enforcement.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPremium rdf:type rdf:Property ;
    rdfs:label 'Quality Premium' ;
    rdfs:comment 'Additional price premium per unit awarded for above-standard commodity quality attributes (e.g., high protein content, organic certification, non-GMO identity preservation, low moisture). Expressed in currency_code per price_uom.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Indicates how this pricing agreement is renewed upon expiry. \'manual\' = requires explicit renegotiation; \'auto_renew\' = automatically renews for the same term; \'evergreen\' = continues indefinitely until terminated; \'one_time\' = single-use agreement with no renewal.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelCode rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Code' ;
    rdfs:comment 'Reference to the distribution channel or sales channel (e.g., direct farm-gate, export, domestic wholesale, retail) under which this pricing agreement applies. Supports channel-specific pricing strategies.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapConditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Number' ;
    rdfs:comment 'The SAP S/4HANA SD condition record number (KNUMH) that corresponds to this pricing agreement. Provides direct traceability to the source system pricing master data for reconciliation and audit.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Cool Origin Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code designating the country of origin of the quoted commodity, as required by USDA Country of Origin Labeling (COOL) regulations. Mandatory for covered commodities sold in the US market.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiCommodityFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Commodity Flag' ;
    rdfs:comment 'Indicates whether this quotation covers multiple commodity types or grades across its line items. True = multi-commodity quote (common in grain trading); False = single commodity. Drives downstream processing logic for line item aggregation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The final quoted price per unit after applying all discounts, premiums, and basis adjustments. This is the price the customer will pay per unit of measure if the quote is accepted.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'The business date on which the formal price quotation was issued to the customer or broker. Represents the principal real-world event date for this transaction.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally-visible, human-readable quotation reference number used in customer communications, SAP S/4HANA SD quotation documents, and Salesforce CRM. Format: QT-YYYY-NNNNNN.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle state of the quotation. Drives workflow in SAP S/4HANA SD and Salesforce CRM: draft (being prepared), submitted (sent to customer), accepted (customer confirmed), rejected (customer declined), expired (validity lapsed), cancelled (withdrawn by seller).' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quotation by pricing basis: spot (current market price), forward (agreed future delivery price), futures_linked (price tied to exchange futures contract via DTN/WASDE), contract (against a standing supply agreement), indicative (non-binding price indication). [ENUM-REF-CANDIDATE: spot|forward|futures_linked|contract|indicative — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityRef rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Ref' ;
    rdfs:comment 'The Salesforce CRM Opportunity ID or reference number linked to this quotation, enabling cross-system traceability between the SAP S/4HANA SD quotation and the CRM sales pipeline record.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQuotationRef rdf:type rdf:Property ;
    rdfs:label 'Sap Quotation Ref' ;
    rdfs:comment 'The SAP S/4HANA Sales and Distribution (SD) module quotation document number, providing the authoritative source system reference for this record in the Silver Layer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Value' ;
    rdfs:comment 'The total monetary value of the quotation (net_price × total_quantity), expressed in the quote currency. Represents the gross revenue opportunity if the quote is fully accepted.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Standard unit of measure for quantity fields in this quotation. BU (Bushel), MT (Metric Ton), CWT (Hundredweight), LB (Pound), KG (Kilogram), TON (Short Ton). Aligned with USDA and commodity exchange standards.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderId rdf:type rdf:Property ;
    rdfs:label 'Return Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the sales return order record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Date on which the returned goods were physically received and confirmed at the designated warehouse or receiving facility. Used for reverse logistics reconciliation and GRN generation.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoTriggered rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Triggered' ;
    rdfs:comment 'Indicates whether a credit memo has been triggered in the financial system (SAP S/4HANA FI/SD) as a result of this return order. True when the return qualifies for customer credit; False when pending review or rejected for credit.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Authorized instruction specifying how the returned goods are to be handled upon receipt and inspection. Drives warehouse operations, quality management workflows, and financial treatment of the returned inventory.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Anticipated date by which the returned goods are expected to arrive at the receiving warehouse. Used for reverse logistics planning, warehouse capacity scheduling, and SLA monitoring.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityDisputeOpen rdf:type rdf:Property ;
    rdfs:label 'Quality Dispute Open' ;
    rdfs:comment 'Indicates whether a formal quality dispute is currently open between the company and the customer regarding the returned goods. True when dispute is active and pending resolution; False when resolved or no dispute raised.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for processing the return, covering handling, inspection, and restocking costs. Deducted from the credit memo value where applicable per contract terms.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally communicated return authorization number issued to the customer prior to physical return of goods. Used as the primary business-facing identifier for tracking and communication across the supply chain and with the customer.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Return Order Status' ;
    rdfs:comment 'Current lifecycle state of the return order, tracking progression from initial authorization through physical receipt, quality inspection, disposition, and financial closure. [ENUM-REF-CANDIDATE: draft|open|in_transit|received|inspected|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the customer or sales representative describing the specific circumstances of the return, including observed defects, grade discrepancies, or regulatory non-conformance details.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRequestDate rdf:type rdf:Property ;
    rdfs:label 'Return Request Date' ;
    rdfs:comment 'Calendar date on which the customer formally submitted the return request or rejection notice. Represents the principal business event date for the return lifecycle and is used for aging analysis and SLA tracking.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Return Value Amount' ;
    rdfs:comment 'Gross monetary value of the returned goods calculated at the original contract or invoice price. Used as the basis for credit memo calculation, revenue reversal, and financial reporting under GAAP/IFRS.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of the agricultural commodity or product being returned by the customer, expressed in the base unit of measure (e.g., bushels, metric tons, hundredweight). Must be reconciled against the original sales order delivery quantity.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Primary key for territory' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent territory in a hierarchical territory structure (e.g., a sub-territory rolls up to a regional territory). Enables multi-level territory hierarchy for management reporting and quota aggregation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:territoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Employee Id' ;
    rdfs:comment 'Identifier of the primary sales representative assigned to this territory. Links to the workforce/employee master for performance tracking, commission calculation, and sales force alignment reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territorySalesManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Sales Manager Employee Id' ;
    rdfs:comment 'Identifier of the sales manager responsible for overseeing this territory. Supports management hierarchy reporting, escalation routing, and regional performance roll-ups.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territorySalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Sales Rep Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target Usd' ;
    rdfs:comment 'Annual revenue target for this territory in US Dollars. Used for financial planning, sales performance measurement, and EBITDA contribution tracking. Supports GAAP and IFRS revenue recognition reporting requirements.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVolumeTargetBu rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Target Bu' ;
    rdfs:comment 'Annual sales volume target expressed in Bushels (BU) for grain commodity territories. Complements the MT target for territories where bushel-based pricing and CBOT futures-linked contracts are the primary commercial unit.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCoverage rdf:type rdf:Property ;
    rdfs:label 'Channel Coverage' ;
    rdfs:comment 'Primary distribution channel(s) served by this territory. Indicates whether the territory covers direct farm-gate sales, distributor networks, broker relationships, agricultural cooperatives, retail channels, or export markets. Integrates with SAP S/4HANA SD channel determination.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityFocus rdf:type rdf:Property ;
    rdfs:label 'Commodity Focus' ;
    rdfs:comment 'Primary agricultural commodity or commodity group that this territory specializes in (e.g., \'Corn/Soybeans\', \'Wheat\', \'Poultry\', \'Beef Cattle\', \'Specialty Crops\', \'Dairy\'). Aligns with WASDE commodity classifications and drives product portfolio assignment.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Cool Compliance Required' ;
    rdfs:comment 'Indicates whether Country of Origin Labeling (COOL) compliance is mandatory for sales in this territory. True for territories covering retail and food service channels subject to USDA AMS COOL regulations under the Agricultural Marketing Act.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countyDistrict rdf:type rdf:Property ;
    rdfs:label 'County District' ;
    rdfs:comment 'County or USDA agricultural district designation(s) within the territory. Supports precision-level geographic coverage tracking aligned with USDA NASS (National Agricultural Statistics Service) reporting districts.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Crm Territory Code' ;
    rdfs:comment 'External identifier for this territory as recorded in Salesforce CRM Territory Management module. Enables cross-system reconciliation between the lakehouse Silver Layer and the CRM system of record for opportunity pipeline and partner relationship management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Primary customer segment targeted by this territory. Classifies the dominant buyer type to align product portfolio, pricing, and service levels. Integrates with Salesforce CRM account segmentation for pipeline management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportZone rdf:type rdf:Property ;
    rdfs:label 'Export Zone' ;
    rdfs:comment 'Designated export zone or international trade region for territories covering cross-border agricultural commodity sales (e.g., \'NAFTA\', \'EU\', \'Asia-Pacific\'). Relevant for FOB/CIF pricing terms and export compliance under USDA APHIS and FDA regulations.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Standard trade terms (Incoterms) governing delivery responsibility and risk transfer for sales in this territory. FOB (Free On Board) and CIF (Cost Insurance and Freight) are most common in agricultural commodity export territories. Drives BOL generation and logistics cost allocation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExportTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Export Territory' ;
    rdfs:comment 'Flag indicating whether this territory covers international/export sales. When true, additional export compliance requirements apply including USDA APHIS phytosanitary certificates, FDA prior notice, and COOL labeling obligations.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRealignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Realignment Date' ;
    rdfs:comment 'Date of the most recent territory boundary or assignment realignment. Tracks when the territory was last restructured for sales force optimization, market coverage adjustments, or organizational changes.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPenetrationPct rdf:type rdf:Property ;
    rdfs:label 'Market Penetration Pct' ;
    rdfs:comment 'Estimated percentage of the addressable market within this territory currently served by the company. Calculated as current customer base acreage divided by total farmland acres. Used for strategic market coverage planning and sales force sizing.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic sales region to which this territory belongs (e.g., \'Midwest\', \'Southeast\', \'Great Plains\', \'Pacific Northwest\', \'International\'). Used for regional roll-up reporting and management hierarchy.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Sap Distribution Channel' ;
    rdfs:comment 'Two-character SAP S/4HANA SD Distribution Channel code for this territory. Determines pricing procedures, order types, and delivery conditions applicable to sales transactions originating from this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed narrative description of the territory\'s geographic scope, customer segments covered, and strategic purpose within the sales organization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'Midwest Grain Belt\', \'Southeast Poultry Region\'). Used in reporting, dashboards, and sales force alignment communications.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the sales territory. \'active\' indicates the territory is currently assigned and operational; \'inactive\' indicates it has been decommissioned; \'pending\' indicates it is being set up; \'suspended\' indicates temporarily paused coverage.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory by its primary segmentation basis — geographic (state/county boundary), customer segment (large grower, cooperative, distributor), commodity focus, distribution channel, or export zone. Drives sales force alignment strategy.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFarmlandAcres rdf:type rdf:Property ;
    rdfs:label 'Total Farmland Acres' ;
    rdfs:comment 'Total estimated farmland acreage within the territory boundary. Sourced from USDA FSA records and Esri ArcGIS land mapping. Used for market penetration analysis, yield potential estimation (YPM), and variable rate application (VRA) planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consigneeAccountId rdf:type rdf:Property ;
    rdfs:label 'Consignee Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: The BOL consignee is the customer account in agriculture freight. Linking BOL to customer.account enables automated consignee data population, eliminates denormalized consignee_name/consignee_address,' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Date and time when the shipment was physically delivered to and accepted by the consignee. Used for on-time delivery KPI measurement, proof of delivery, and triggering goods receipt in SAP S/4HANA MM.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Date and time when the carrier physically picked up the agricultural shipment from the origin facility. Used for transit time calculation, carrier performance KPI measurement, and FSMA traceability event recording.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bolStatus rdf:type rdf:Property ;
    rdfs:label 'Bol Status' ;
    rdfs:comment 'Current lifecycle status of the BOL document. Tracks progression from draft creation through issuance, active transit, final delivery confirmation, or cancellation. Drives workflow in TMS and SAP S/4HANA MM.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Captured electronic signature data (encoded string or reference token) from the driver or consignee acknowledging receipt of goods. Supports paperless BOL workflows and serves as legal proof of delivery for dispute resolution.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Commercial freight payment terms indicating who bears the cost and risk of transportation. FOB (Free On Board) and CIF (Cost Insurance and Freight) are standard Incoterms used in agricultural commodity trade. Determines title transfer point and insurance responsibility.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTraceabilityLotCode rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Lot Code' ;
    rdfs:comment 'FSMA Section 204 Traceability Lot Code (TLC) assigned to the food commodity on this BOL. Mandatory for foods on the Food Traceability List (FTL) under the FSMA Final Rule on Requirements for Additional Traceability Records for Certain Foods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Internal facility or location code for the shipment origin point (farm, warehouse, processing plant). Maps to the storage location master in SAP S/4HANA MM and Manhattan Associates WMS for inventory reconciliation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets included in the shipment. Used for trailer space planning, dock scheduling, and warehouse receiving operations in Manhattan Associates WMS.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number used to track the shipment within the carrier\'s system. Distinct from the BOL number; used for freight claims, shipment tracing, and carrier invoice reconciliation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Max C' ;
    rdfs:comment 'Maximum required temperature in degrees Celsius for the shipment during transit. Used for cold chain compliance monitoring and FSMA sanitary transportation rule adherence for perishable agricultural products.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTempMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Min C' ;
    rdfs:comment 'Minimum required temperature in degrees Celsius for the shipment during transit. Used for cold chain compliance monitoring and FSMA sanitary transportation rule adherence for perishable agricultural products.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Tamper-evident seal number affixed to the trailer or container at point of loading. Used for food safety integrity verification, FSMA compliance, and customs/border security. Verified at delivery against the BOL.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Full street address of the shipper/consignor origin location including street, city, state, and postal code. Required on the BOL for FSMA traceability and carrier routing.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Legal name of the party tendering the agricultural goods for shipment (the shipper/consignor). Typically the farm operation, processing facility, or distribution center. Required field on the BOL legal document.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all goods on the BOL in kilograms, including packaging and pallets. Used for freight rate calculation, carrier weight compliance (DOT limits), and inventory reconciliation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of the agricultural commodity only (excluding packaging and pallets) in kilograms. Used for commodity pricing, yield calculations, and USDA reporting.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPieceCount rdf:type rdf:Property ;
    rdfs:label 'Total Piece Count' ;
    rdfs:comment 'Total number of handling units (cases, bags, pallets, or other packaging units) included in the shipment as listed on the BOL. Used for carrier receipt verification and warehouse receiving in Manhattan Associates WMS.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Number' ;
    rdfs:comment 'Carrier vehicle or trailer identification number (license plate, DOT vehicle number, or fleet unit number) used to transport the shipment. Required for FSMA sanitary transportation compliance and carrier audit trails.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Agricultural carriers must hold operating permits (USDA, state transport, hazmat). Linking carrier to their governing operating permit supports carrier qualification, compliance verification during co' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:sapVendorId rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Id' ;
    rdfs:comment 'Vendor master record number assigned to this carrier in SAP S/4HANA MM module. Used for cross-referencing freight invoices, purchase orders (PO), and goods receipt notes (GRN) in the ERP system.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:approvedCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Types' ;
    rdfs:comment 'Comma-delimited list of agricultural commodity categories this carrier is approved to transport (e.g., \'grain\', \'fresh_produce\', \'livestock\', \'fertilizer\', \'pesticides\'). Derived from carrier certifications and equipment capabilities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScopeForCarrier rdf:type rdf:Property ;
    rdfs:label 'Audit Scope For Carrier' ;
    rdfs:comment 'Narrative description of the specific operations, routes, facilities, or practices within scope for this carrier in the context of this audit. May be a subset of the overall audit scope when the audit covers multiple carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier record within the agricultural supply chain master data. Controls whether the carrier is eligible for new shipment assignments in the TMS.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary mode of transportation the carrier operates. Drives TMS routing logic, BOL/AWB document selection, and FSMA Sanitary Transportation rule applicability. [ENUM-REF-CANDIDATE: trucking|rail|air_freight|ocean|intermodal|3pl — promote to reference product if additional modes are needed]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the carrier has certified refrigerated or temperature-controlled transport capability for cold chain agricultural commodities (e.g., fresh produce, dairy, meat). Required for perishable shipment routing in TMS.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainVerified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Verified' ;
    rdfs:comment 'Indicates whether the carrier\'s cold chain capability has been specifically verified and validated for this trial site\'s requirements. Distinct from the carrier-level cold_chain_capable flag, which is a general capability indicator. A carrier may be generally cold-chain capable but not yet verified for a specific site\'s temperature profile or containment requirements.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Composite compliance score (0-100) reflecting the carrier\'s adherence to regulatory requirements (FSMA, DOT, FMCSA) and contractual obligations. Calculated from documentation currency, audit results, and violation history.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageClaimRate rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Rate' ;
    rdfs:comment 'Rolling ratio of shipments resulting in a cargo damage claim to total shipments executed. Used to assess carrier handling quality for sensitive agricultural commodities and inform carrier tier scoring.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'USDOT number issued by the Federal Motor Carrier Safety Administration (FMCSA) to identify commercial motor carriers operating in interstate commerce. Required for FSMA Sanitary Transportation compliance verification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the carrier supports EDI transaction sets (e.g., 204 Motor Carrier Load Tender, 214 Shipment Status, 210 Freight Invoice) for automated load tendering and status updates in the agricultural supply chain.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the carrier\'s FSMA Sanitary Transportation certification. Triggers compliance alerts when approaching expiry to prevent use of non-compliant carriers for food-grade agricultural shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaSanitaryTransportCertified rdf:type rdf:Property ;
    rdfs:label 'Fsma Sanitary Transport Certified' ;
    rdfs:comment 'Indicates whether the carrier holds a valid FSMA Sanitary Transportation of Human and Animal Food certification (21 CFR Part 1, Subpart O). Mandatory for carriers transporting food-grade agricultural products to food manufacturers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsTrackingCapable rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Capable' ;
    rdfs:comment 'Indicates whether the carrier provides real-time GPS-based shipment location tracking integrated with the TMS for visibility into in-transit agricultural commodity shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carrier holds USDOT hazardous materials (HAZMAT) certification for transporting regulated agricultural inputs such as pesticides, fertilizers, and fumigants with Safety Data Sheet (SDS) requirements.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the carrier\'s current insurance certificate (cargo liability, general liability, and auto liability). Carrier is ineligible for load assignment if this date has passed. Monitored for proactive renewal alerts.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total cargo liability insurance coverage amount in USD as stated on the carrier\'s current insurance certificate. Used to validate coverage adequacy for high-value agricultural commodity shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number (MC number) issued by FMCSA to carriers transporting regulated commodities for hire in interstate commerce. Validates carrier authority to haul agricultural products.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimePickupRate rdf:type rdf:Property ;
    rdfs:label 'On Time Pickup Rate' ;
    rdfs:comment 'Rolling percentage of shipments where the carrier completed pickup within the agreed pickup window. Key performance indicator (KPI) for carrier scorecard evaluation and performance tier assignment in the agricultural supply chain.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceEvalPeriod rdf:type rdf:Property ;
    rdfs:label 'Performance Eval Period' ;
    rdfs:comment 'The fiscal quarter and year (e.g., \'2024-Q3\') for which the current rolling performance metrics (on-time rates, damage claim rate, compliance score, performance tier) were last evaluated and updated.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRatingAtSite rdf:type rdf:Property ;
    rdfs:label 'Performance Rating At Site' ;
    rdfs:comment 'Performance rating (0.00–5.00) assigned to the carrier based on observed performance specifically at this trial site. Distinct from the carrier\'s aggregate rolling performance metrics, which span all sites and shipments. Enables site managers to flag carriers that perform well globally but poorly at their specific location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Current performance tier classification assigned based on the carrier\'s rolling KPI scores (on-time rates, damage claims, compliance score). Drives TMS primary/secondary/tertiary carrier selection logic for agricultural shipment routing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLaneAssignments rdf:type rdf:Property ;
    rdfs:label 'Preferred Lane Assignments' ;
    rdfs:comment 'Comma-delimited list of preferred origin-destination lane codes (e.g., \'MIDWEST-SOUTHEAST\', \'CA-TX\') where this carrier has committed capacity or preferred routing agreements. Used by TMS for primary carrier selection in route optimization.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedLoadsCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Loads Count' ;
    rdfs:comment 'Count of loads rejected or refused by the carrier after tender acceptance within the current evaluation period. High rejection rates indicate capacity reliability issues and impact carrier tier scoring.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTrackingCapable rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Capable' ;
    rdfs:comment 'Indicates whether the carrier supports RFID-based shipment and lot (LOT) tracking for end-to-end traceability of agricultural commodities from farm to food manufacturer. Integrates with Manhattan Associates WMS RFID infrastructure.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique 2-4 character Standard Carrier Alpha Code (SCAC) assigned by the National Motor Freight Traffic Association (NMFTA) to identify the carrier in EDI transactions, BOL documents, and TMS routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModes rdf:type rdf:Property ;
    rdfs:label 'Service Modes' ;
    rdfs:comment 'Comma-delimited list of transportation service modes offered by the carrier (e.g., FTL, LTL, refrigerated, flatbed, bulk, tanker, intermodal). Used for TMS lane matching and load tendering in agricultural logistics.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionRate rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Rate' ;
    rdfs:comment 'Rolling ratio of cold chain shipments where a temperature excursion (deviation outside the specified range) was recorded to total cold chain shipments. Critical metric for FSMA compliance and food safety risk management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipmentsExecuted rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Executed' ;
    rdfs:comment 'Cumulative count of shipments executed by this carrier within the current evaluation period. Provides volume context for interpreting rate-based KPIs (on-time, damage, temperature excursion) in carrier performance analysis.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each carrier performance evaluation record in the Databricks Silver Layer.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Carrier performance evaluations in agriculture logistics are conducted by qualified logistics managers or procurement staff. Linking to the evaluating employee enables accountability reporting, evalua' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Reference to the active carrier rate agreement or 3PL contract under which the evaluated shipments were executed. Links to the contract master in SAP S/4HANA MM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:avgTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Avg Transit Time Hours' ;
    rdfs:comment 'Average actual transit time in hours across all shipments executed by the carrier during the evaluation period. Compared against contracted transit time to assess schedule adherence.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bolDocumentationAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Bol Documentation Accuracy Rate' ;
    rdfs:comment 'Percentage of Bills of Lading (BOL) submitted by the carrier that were complete, accurate, and compliant with FSMA traceability requirements during the evaluation period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of carrier freight invoices that matched the contracted rate without dispute during the evaluation period. Supports freight audit and payment (FAP) processes in SAP S/4HANA FI-AP.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainShipments rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Shipments' ;
    rdfs:comment 'Number of shipments within the evaluation period that required temperature-controlled transport (cold chain). Used as the denominator for temperature excursion rate calculations.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Composite Performance Score' ;
    rdfs:comment 'Weighted composite score (0-100) aggregating all KPI dimensions (on-time delivery, damage claims, FSMA compliance, temperature excursions, invoice accuracy) into a single carrier scorecard value. Basis for performance_tier assignment.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Contracted Transit Time Hours' ;
    rdfs:comment 'Agreed transit time in hours as specified in the carrier contract or rate agreement for the evaluated lane. Baseline for transit time variance analysis and SLA compliance.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageClaimCount rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Count' ;
    rdfs:comment 'Number of shipments for which a cargo damage claim was filed against the carrier during the evaluation period. Raw numerator for damage claim rate. Impacts food safety and HACCP compliance assessments.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'Last date of the performance evaluation window. Together with evaluation_period_start_date defines the measurement interval for all KPI metrics in this record.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'First date of the performance evaluation window (e.g., start of month, quarter, or contract review period). Used to define the measurement interval for all KPI calculations.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Granularity of the performance evaluation cycle. Determines the reporting cadence for carrier scorecards and 3PL contract renewal reviews.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaAuditDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Audit Date' ;
    rdfs:comment 'Date of the most recent FSMA sanitary transportation compliance audit conducted for this carrier. Tracks audit currency for regulatory compliance management.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Score' ;
    rdfs:comment 'Composite score (0-100) measuring the carrier\'s adherence to FSMA Sanitary Transportation of Human and Animal Food rule requirements, including vehicle sanitation, temperature control documentation, and training records. Mandatory for food-grade agricultural shipments.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementPlanActive rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Active' ;
    rdfs:comment 'Indicates whether the carrier is currently operating under a formal Carrier Improvement Plan (CIP) due to performance deficiencies. True when a corrective action plan is in force; False otherwise.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneDestinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Lane Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the destination end of the primary evaluated shipping lane. Used for cross-border compliance checks and lane performance analytics.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneOriginCountryCode rdf:type rdf:Property ;
    rdfs:label 'Lane Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the origin end of the primary evaluated shipping lane. Supports COOL (Country of Origin Labeling) compliance and lane-level performance segmentation.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Count' ;
    rdfs:comment 'Number of shipments delivered within the contracted delivery window during the evaluation period. Raw numerator for on-time delivery rate calculation.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimePickupCount rdf:type rdf:Property ;
    rdfs:label 'On Time Pickup Count' ;
    rdfs:comment 'Number of shipments where the carrier completed pickup within the contracted pickup window during the evaluation period. Raw numerator for on-time pickup rate calculation.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Previous Performance Tier' ;
    rdfs:comment 'Performance tier assigned to the carrier in the immediately preceding evaluation period. Enables tier trend analysis and escalation/de-escalation tracking for carrier management decisions.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedLoadCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Load Count' ;
    rdfs:comment 'Number of loads rejected by the carrier (carrier-caused refusals) or rejected at destination due to carrier-attributable non-conformances (e.g., temperature breach, contamination) during the evaluation period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTrackingComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Compliance Rate' ;
    rdfs:comment 'Percentage of shipments where the carrier maintained continuous RFID tag scan compliance at all required checkpoints during the evaluation period. Supports FSMA traceability lot (LOT) tracking requirements.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempExcursionCount rdf:type rdf:Property ;
    rdfs:label 'Temp Excursion Count' ;
    rdfs:comment 'Number of cold chain shipments where the carrier recorded a temperature excursion outside the contracted min/max range during the evaluation period. Raw numerator for temperature excursion rate.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tempExcursionRate rdf:type rdf:Property ;
    rdfs:label 'Temp Excursion Rate' ;
    rdfs:comment 'Percentage of cold chain shipments with a temperature excursion during the evaluation period. Calculated as (temp_excursion_count / cold_chain_shipments) * 100. Critical KPI for perishable agricultural commodity carriers under FSMA cold chain rules.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total freight charges invoiced by the carrier for all shipments executed during the evaluation period, in the reporting currency. Used for COGS allocation, carrier spend analysis, and contract benchmarking.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
    rdfs:label 'Total Shipments' ;
    rdfs:comment 'Total number of shipments executed by the carrier within the evaluation period. Serves as the denominator for all rate-based KPI calculations and statistical significance assessment.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Variance Hours' ;
    rdfs:comment 'Difference between avg_transit_time_hours and contracted_transit_time_hours. Positive values indicate the carrier is running late on average; negative values indicate early delivery. Key input for route optimization and carrier negotiations.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportUnitId rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Id' ;
    rdfs:comment 'Identifier of the transport unit (container, trailer, reefer unit, or cold storage compartment) in which the reading was captured. Supports fleet telematics correlation and carrier performance analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportUnit .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'Severity classification of the cold chain alert associated with this reading. Drives escalation routing and corrective action urgency. \'none\' = within spec; \'low\' = minor deviation; \'medium\' = moderate deviation; \'high\' = significant breach; \'critical\' = product safety risk.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyEvent rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Event' ;
    rdfs:comment 'Indicates whether this reading was captured at a chain-of-custody transfer point (True = custody handoff event, e.g., farm to carrier, carrier to warehouse, warehouse to retailer). Critical for FSMA traceability and HACCP lot tracking.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodyTransferParty rdf:type rdf:Property ;
    rdfs:label 'Custody Transfer Party' ;
    rdfs:comment 'Name or identifier of the party receiving custody at a chain-of-custody transfer event. Populated only when chain_of_custody_event is True. Supports FSMA traceability lot (LOT) tracking and food safety incident root cause investigation.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionDeviationC rdf:type rdf:Property ;
    rdfs:label 'Excursion Deviation C' ;
    rdfs:comment 'Magnitude of temperature deviation from the nearest threshold boundary in degrees Celsius at the time of this reading. Positive value indicates above max threshold; negative indicates below min threshold. Supports severity scoring and product safety risk assessment.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Cumulative duration in minutes that the temperature has been outside the required range at the time of this reading. Used for HACCP corrective action decision-making and product disposition assessment.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Indicates whether this reading breached the commodity-specific temperature threshold (True = excursion detected). Primary trigger for HACCP corrective action workflows and GFSI audit evidence generation.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Pct' ;
    rdfs:comment 'Observed relative humidity percentage inside the transport unit or storage compartment at the time of reading. Critical for fresh produce, cut flowers, and dairy commodities where moisture control prevents spoilage.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Reading Interval Seconds' ;
    rdfs:comment 'Configured polling interval in seconds at which the sensor device is programmed to capture readings. Used to validate data completeness and detect gaps in the telemetry stream.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Origin system or method by which this reading was captured: \'iot_sensor\' = direct IoT device telemetry; \'rfid_logger\' = RFID data logger; \'manual_entry\' = operator-entered; \'tms_integration\' = received via TMS feed; \'wms_integration\' = received via WMS integration.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Discriminator indicating how this reading was generated: \'periodic\' = scheduled interval reading; \'event_triggered\' = sensor threshold breach; \'manual\' = operator-entered; \'chain_of_custody\' = recorded at custody transfer point; \'alarm\' = device alarm state.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'RFID tag identifier attached to the pallet, container, or shipment unit being monitored. Enables automated chain-of-custody tracking and links physical asset movement to cold chain telemetry.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Due Date' ;
    rdfs:comment 'Date by which the sensor device is due for its next calibration verification. Readings captured after this date may be flagged as non-compliant for HACCP and GFSI audit purposes.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Unique identifier of the IoT temperature/humidity sensor or RFID-enabled data logger device that captured this reading. Used for device traceability and calibration audit trails.' ;
    rdfs:domain ind:ColdChainReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureF rdf:type rdf:Property ;
    rdfs:label 'Temperature F' ;
    rdfs:comment 'Observed ambient temperature in degrees Fahrenheit at the time of reading. Provided alongside Celsius to support US-market carrier and customer reporting requirements without unit conversion.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antiDumpingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Amount' ;
    rdfs:comment 'The additional anti-dumping duty (ADD) amount assessed on the shipment when anti_dumping_duty_flag is True. Expressed in the declared value currency. Required for accurate landed cost calculation and financial reporting.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antiDumpingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Flag' ;
    rdfs:comment 'Indicates whether an anti-dumping duty (ADD) applies to this agricultural commodity shipment under U.S. Department of Commerce or WTO anti-dumping orders. When True, additional anti_dumping_duty_amount is assessed beyond standard tariffs.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awbNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Number' ;
    rdfs:comment 'The Air Waybill (AWB) number for air freight shipments of agricultural commodities. Used in CBP entry filing, FDA Prior Notice, and USDA APHIS import documentation for air cargo.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'The date on which the customs authority officially cleared the agricultural shipment for release. Marks the completion of the customs declaration lifecycle and triggers downstream supply chain activities such as delivery scheduling and inventory receipt.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO 6346 standardized container identification number for ocean freight shipments of agricultural commodities. Used for CBP Automated Manifest System (AMS) filing, USDA APHIS inspection scheduling, and supply chain traceability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Classifies the direction and nature of the customs declaration: import (inbound agricultural commodity), export (outbound), re-import, re-export, or transit. Drives applicable regulatory requirements and documentation sets.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'The declared transaction value of the agricultural commodity shipment as reported to customs authorities, expressed in the declared currency. Used as the basis for ad valorem duty and tariff calculations. Must comply with WTO Customs Valuation Agreement (GATT Article VII).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared customs value (e.g., USD, EUR, CAD). Required for accurate duty calculation and financial reporting under GAAP/IFRS.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Import Duty Amount' ;
    rdfs:comment 'The calculated import duty amount assessed on the agricultural commodity shipment, expressed in the declared value currency. Computed by CBP based on the HS tariff code, declared value, and applicable duty rate. Recorded for financial accrual and COGS reporting.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionHoldAgency rdf:type rdf:Property ;
    rdfs:label 'Inspection Hold Agency' ;
    rdfs:comment 'The regulatory agency that placed the inspection hold on the agricultural shipment. Identifies whether the hold was initiated by USDA APHIS (phytosanitary), CBP (customs), FDA (food safety), EPA (pesticide residues), or FSIS (meat/poultry). Populated only when inspection_hold_flag is True.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Hold Flag' ;
    rdfs:comment 'Indicates whether the agricultural shipment has been placed on an inspection hold by USDA APHIS, CBP, or FDA at the port of entry/exit. When True, the shipment cannot be released until inspection is completed and hold is lifted.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfEntryExitCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Exit Code' ;
    rdfs:comment 'Official CBP port code or UN/LOCODE identifying the port of entry (for imports) or port of exit (for exports) through which the agricultural shipment crosses the border. Used for USDA APHIS inspection scheduling and FDA Prior Notice filing.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffRatePct rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Pct' ;
    rdfs:comment 'The applicable ad valorem tariff rate percentage applied to the declared value of the agricultural commodity. Derived from the HS tariff code and trade agreement provisions (e.g., USMCA, CPTPP). Used for duty calculation and trade cost analysis.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryEventId rdf:type rdf:Property ;
    rdfs:label 'Delivery Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each discrete delivery milestone event record within the supply chain execution lifecycle.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:borderCrossingPoint rdf:type rdf:Property ;
    rdfs:label 'Border Crossing Point' ;
    rdfs:comment 'Name or code of the official border crossing or port of entry where the shipment crossed an international boundary. Relevant for USDA APHIS phytosanitary inspection, FDA import screening, and COOL (Country of Origin Labeling) compliance.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainBreach rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Breach' ;
    rdfs:comment 'Indicates whether the recorded temperature at this event exceeded the allowable temperature range for the shipment, constituting a cold chain breach. Triggers food safety exception workflows and FSMA non-conformance reporting.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Status of customs clearance at the time of a border crossing or customs clearance event. Applicable for international agricultural commodity shipments subject to USDA APHIS phytosanitary inspection and FDA import controls.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Reference Number' ;
    rdfs:comment 'Official customs entry or declaration reference number assigned by the customs authority at border crossing or clearance events. Required for international agricultural trade compliance and USDA APHIS import documentation.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'The number of minutes by which this delivery event was delayed relative to the scheduled event timestamp. Populated for exception events of type \'delay\'. Used for carrier performance KPI calculation and SLA breach reporting.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Number' ;
    rdfs:comment 'Sequential count of delivery attempts made for this shipment at the destination. Increments with each failed delivery attempt. Used to trigger escalation workflows and carrier penalty clauses after maximum attempts are exceeded.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Reference' ;
    rdfs:comment 'Document reference or storage path to the captured electronic signature obtained at delivery confirmation. Serves as legally admissible proof of delivery for food safety compliance and commercial dispute resolution.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text operational notes recorded by the driver, carrier agent, or dispatcher at the time of the event. Captures contextual information such as access instructions, recipient comments, or site conditions not covered by structured fields.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Ordinal sequence number of this event within the shipment\'s delivery event chain. Enables chronological ordering of all milestone events for a given shipment to reconstruct the full delivery timeline for FSMA audit trail and analytics.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text narrative describing the nature, cause, and immediate actions taken for an exception event. Populated when exception_type is not null. Supports carrier claims, insurance documentation, and FSMA corrective action records.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the exception condition when event_type is \'exception\'. Identifies the nature of the delivery failure or deviation for root cause analysis, carrier claims, and FSMA incident reporting. [ENUM-REF-CANDIDATE: delay|damage|refusal|temperature_breach|lost|partial_delivery — promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTlcReference rdf:type rdf:Property ;
    rdfs:label 'Fsma Tlc Reference' ;
    rdfs:comment 'The FSMA Traceability Lot Code associated with the commodity at this delivery event. Required under FSMA Section 204 for Foods on the Food Traceability List (FTL) to enable rapid traceback in food safety incidents.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceCompliant rdf:type rdf:Property ;
    rdfs:label 'Geofence Compliant' ;
    rdfs:comment 'Indicates whether the GPS coordinates recorded at this event fall within the expected geofenced zone for the scheduled waypoint or facility. Used to detect route deviations and unauthorized stops in agricultural supply chain security monitoring.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Document reference or storage path to photographic evidence captured at the time of the delivery event. Used for damage documentation, delivery confirmation, and FSMA food safety incident records.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podCaptured rdf:type rdf:Property ;
    rdfs:label 'Pod Captured' ;
    rdfs:comment 'Indicates whether electronic proof of delivery has been captured for this event. True when an electronic signature, photo evidence, or digital confirmation has been recorded. Critical for FSMA transportation compliance and customer dispute resolution.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual who accepted or refused the delivery at the destination. Captured as part of proof of delivery documentation. Classified as confidential PII per GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidScanCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Scan Code' ;
    rdfs:comment 'The RFID tag code scanned at this delivery event checkpoint. Enables automated lot-level traceability and real-time inventory visibility across the agricultural supply chain without manual barcode scanning.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Event Timestamp' ;
    rdfs:comment 'The planned date and time at which this delivery milestone event was expected to occur. Compared against event_timestamp to calculate on-time performance and identify delays for carrier KPI reporting and SLA management.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureReadingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading C' ;
    rdfs:comment 'Ambient or cargo temperature in degrees Celsius recorded at the time of this delivery event. Critical for cold chain compliance monitoring of perishable agricultural commodities. Compared against shipment-level min/max temperature thresholds to detect cold chain breaches.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dockCountCrossdock rdf:type rdf:Property ;
    rdfs:label 'Dock Count Crossdock' ;
    rdfs:comment 'Number of dock doors designated for cross-docking operations where inbound shipments are transferred directly to outbound without storage. Relevant for distribution centers and cross-dock facilities in the agricultural supply chain.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockCountInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Count Inbound' ;
    rdfs:comment 'Number of dock doors designated for inbound receiving operations (GRN processing). Used for inbound logistics scheduling, carrier appointment planning, and WMS receiving capacity management.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockCountOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Count Outbound' ;
    rdfs:comment 'Number of dock doors designated for outbound shipping operations (SO fulfillment). Used for outbound logistics scheduling, carrier appointment planning, and WMS shipping capacity management.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockCountTotal rdf:type rdf:Property ;
    rdfs:label 'Dock Count Total' ;
    rdfs:comment 'Total number of loading and unloading dock doors at the facility. Used for throughput capacity planning, dock scheduling in TMS/WMS, and carrier appointment management.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the facility used across TMS, WMS, and ERP systems (e.g., SAP plant code, Manhattan WMS location code). Unique across the logistics network and referenced on BOL, shipment, and transport order documents.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the supply chain facility as registered with USDA/FDA and used in logistics documentation, carrier communications, and BOL/AWB records.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current lifecycle state of the facility within the supply chain network. Drives eligibility for shipment routing, carrier assignment, and logistics planning in TMS and WMS.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRegistrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Registration Expiry Date' ;
    rdfs:comment 'Date on which the FDA FSMA food facility registration expires. FSMA requires biennial renewal in even-numbered years (October 1 – December 31). Used for compliance monitoring and renewal workflow triggers.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Fsma Registration Status' ;
    rdfs:comment 'Current FDA FSMA food facility registration status. Facilities with suspended or cancelled registration cannot legally ship food products. Drives compliance gating in shipment and transport order processing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasRfidInfrastructure rdf:type rdf:Property ;
    rdfs:label 'Has Rfid Infrastructure' ;
    rdfs:comment 'Indicates whether the facility is equipped with RFID reader infrastructure for automated lot (LOT) tracking, pallet identification, and real-time inventory visibility. Enables FSMA traceability lot code (TLC) scanning at facility entry/exit points.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasWeighbridge rdf:type rdf:Property ;
    rdfs:label 'Has Weighbridge' ;
    rdfs:comment 'Indicates whether the facility has a certified weighbridge (truck scale) for gross and tare weight measurement of inbound and outbound agricultural commodity shipments. Required for accurate net weight determination on BOL and GRN documents.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the facility manager for operational communications, shipment exception alerts, and regulatory correspondence.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the primary facility manager responsible for day-to-day operations, regulatory compliance, and carrier coordination. Used as the operational point of contact on logistics and compliance documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerPhone rdf:type rdf:Property ;
    rdfs:label 'Manager Phone' ;
    rdfs:comment 'Direct phone number for the facility manager, used for carrier coordination, exception management, and regulatory inspection notifications.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operates24Hours rdf:type rdf:Property ;
    rdfs:label 'Operates 24 Hours' ;
    rdfs:comment 'Indicates whether the facility operates on a 24-hour, continuous basis. When true, overrides operating_hours_start and operating_hours_end for scheduling purposes. Common for major port terminals and large grain elevators during harvest season.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily closing time of the facility in HH:MM (24-hour) format. Used for carrier appointment scheduling, TMS delivery window planning, and dock availability management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily opening time of the facility in HH:MM (24-hour) format. Used for carrier appointment scheduling, TMS delivery window planning, and dock availability management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityBu rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Bu' ;
    rdfs:comment 'Maximum rated storage capacity of the facility expressed in Bushels (BU), the standard US grain trade unit of measure. Particularly relevant for grain elevators and on-farm storage. Complements MT capacity for dual-unit reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityMt rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Mt' ;
    rdfs:comment 'Maximum rated storage capacity of the facility expressed in Metric Tons (MT). Used for inventory planning, shipment routing, and capacity utilization analytics across the agricultural supply chain network.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMaxC rdf:type rdf:Property ;
    rdfs:label 'Temp Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for the facility\'s primary temperature zone. Used to validate cold chain compliance for inbound and outbound shipments and to configure IoT temperature monitoring alerts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinC rdf:type rdf:Property ;
    rdfs:label 'Temp Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for the facility\'s primary temperature zone. Used to validate cold chain compliance for inbound and outbound shipments and to configure IoT temperature monitoring alerts.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightBookingId rdf:type rdf:Property ;
    rdfs:label 'Freight Booking Id' ;
    rdfs:comment 'Unique system-generated identifier for the freight booking record. Primary key for this entity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightBooking .

ind:destinationTrialSiteId rdf:type rdf:Property ;
    rdfs:label 'Destination Trial Site Id' ;
    rdfs:comment 'Foreign key linking to research.trial_site. Business justification: Freight bookings for trial seed delivery or sample transport to research trial sites require referencing the trial site as destination. Trial sites are distinct from commercial supply.facility entitie' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrialSite .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Foreign key linking to supply.freight_rate. Business justification: A freight booking is made at a specific negotiated rate. Adding freight_rate_id to freight_booking links the booking to the rate schedule used for pricing. This enables rate audit (comparing booked ra' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightRate .

ind:primaryFreightFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Facility Id' ;
    rdfs:comment 'Reference to the origin facility, farm, warehouse, or storage location from which the freight will be picked up.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:accessorialAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Amount' ;
    rdfs:comment 'Total additional charges beyond the base freight rate, including fuel surcharges, detention, lumper fees, layover, and FSMA-required temperature monitoring fees.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Base Freight Amount' ;
    rdfs:comment 'Gross base freight charge for this booking before accessorial charges, fuel surcharges, or discounts. Core component of the freight cost monetary triplet.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedQuantity rdf:type rdf:Property ;
    rdfs:label 'Booked Quantity' ;
    rdfs:comment 'Number of units, pallets, cases, or bulk quantity (in applicable unit of measure) booked for transport. Supports lot traceability and inventory reconciliation.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Booked Volume M3' ;
    rdfs:comment 'Total cubic volume of cargo booked, expressed in cubic meters. Used alongside weight for dimensional weight calculations and equipment capacity utilization.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Booked Weight Kg' ;
    rdfs:comment 'Total gross weight of cargo booked with the carrier, expressed in kilograms. Used for freight rate calculation, weight-based compliance checks, and capacity planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Number' ;
    rdfs:comment 'Externally-known, human-readable booking confirmation number assigned upon carrier acceptance. Used for cross-system reference and carrier communication.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the freight booking. Tracks progression from initial draft through carrier confirmation, active transit, completion, or cancellation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'The date and time when the freight booking was confirmed with the carrier or 3PL. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationDeadline rdf:type rdf:Property ;
    rdfs:label 'Cancellation Deadline' ;
    rdfs:comment 'The latest date and time by which this booking can be cancelled without incurring cancellation penalties. Defined by carrier contract terms.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAppointmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Appointment Timestamp' ;
    rdfs:comment 'Confirmed date and time of the scheduled delivery appointment at the destination. Used for receiving dock scheduling and customer SLA compliance tracking.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightRate rdf:type rdf:Property ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Contracted or spot freight rate applied to this booking, expressed as a monetary amount per unit of measure (e.g., per MT, per mile, per load). Commercially sensitive pricing data.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFoodGrade rdf:type rdf:Property ;
    rdfs:label 'Is Food Grade' ;
    rdfs:comment 'Indicates whether this booking requires food-grade transport equipment and handling procedures compliant with FSMA Sanitary Transportation Rule. Critical for edible agricultural commodities.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'Primary transportation mode used for this freight booking. Determines applicable regulatory requirements, documentation (BOL vs AWB), and rate structures.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupAppointmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Appointment Timestamp' ;
    rdfs:comment 'Confirmed date and time of the scheduled pickup appointment at the origin location. Used for dock scheduling and carrier arrival coordination.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Unit basis on which the freight rate is applied. Determines how total freight charges are calculated from the rate and booked quantity or distance.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Service tier contracted for this booking, defining transit time commitments and priority handling. Spot bookings are ad-hoc market-rate engagements outside contracted lanes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold chain compliance during transport. Paired with minimum temperature to define the acceptable cold chain range for perishable goods.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for cold chain compliance during transport. Mandatory for perishable agricultural products under FSMA Sanitary Transportation Rule.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Total Freight Amount' ;
    rdfs:comment 'Net total freight cost for this booking, calculated as base freight amount plus all accessorial charges. Used for COGS allocation, OPEX reporting, and carrier invoice reconciliation.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each freight invoice record in the silver layer. Primary key for the freight_invoice data product.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Reference to the destination facility (food manufacturer, retailer DC, or processing plant) where the shipment was delivered. Used for lane-level freight cost analytics and delivery performance reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Reference to the facility (farm, grain elevator, processing plant, or distribution center) from which the shipment originated. Used for lane-level freight cost analytics and FSMA traceability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:apDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Document Number' ;
    rdfs:comment 'SAP FI accounts payable document number assigned when the freight invoice is posted in the general ledger. Links the freight invoice to the financial accounting entry for payment processing and audit trail.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'Expected freight charge based on the negotiated carrier contract or rate confirmation for this lane and service type. Used as the benchmark in three-way match and freight audit to identify billing variances.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detentionAmount rdf:type rdf:Property ;
    rdfs:label 'Detention Amount' ;
    rdfs:comment 'Charges billed for detention (truck waiting at shipper/consignee beyond free time) or demurrage (rail car or container held beyond allowed dwell time). Common in agricultural supply chains during harvest peak periods.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a freight invoice dispute was formally resolved with the carrier. Nullable; populated only when a dispute has been closed. Used to measure dispute cycle time and carrier performance.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Carrier-applied fuel surcharge billed on this invoice, typically calculated as a percentage of base freight based on the DOE diesel fuel index. A standard variable component of freight invoices in agricultural logistics.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Total Amount' ;
    rdfs:comment 'Total gross amount billed by the carrier on this invoice, representing the sum of base freight, fuel surcharge, accessorials, detention, lumper fees, stop-off charges, and any other line items. This is the amount subject to AP payment processing.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lumperFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Lumper Fee Amount' ;
    rdfs:comment 'Third-party labor charges for unloading agricultural commodities at the destination facility (lumper services). Common at food manufacturer and retailer distribution centers. Billed through the carrier on the freight invoice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Variance Amount' ;
    rdfs:comment 'Monetary difference between the carrier-invoiced amount and the contracted rate amount (invoice_total_amount minus contracted_rate_amount). Positive value indicates overbilling; negative indicates underbilling. Triggers dispute workflow when outside tolerance threshold.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVariancePct rdf:type rdf:Property ;
    rdfs:label 'Rate Variance Pct' ;
    rdfs:comment 'Rate variance expressed as a percentage of the contracted rate amount. Used to determine whether the variance falls within the acceptable tolerance threshold for auto-approval or requires manual freight audit review.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Carrier service level for this shipment. LTL (Less-Than-Truckload), FTL (Full Truckload), PTL (Partial Truckload), expedited, or spot market. Determines applicable rate tariff and service expectations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopOffChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Stop Off Charge Amount' ;
    rdfs:comment 'Additional charges billed for multi-stop shipments where the carrier makes intermediate delivery stops beyond the primary origin-destination pair. Common in agricultural distribution routes serving multiple food manufacturers.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The contracted base freight rate amount, expressed in the unit defined by rate_type (e.g., USD per mile, USD per CWT, USD per MT, USD per BU, or flat USD amount). This is the principal monetary fact for the rate record, excluding fuel surcharge and accessorial charges. Used as the foundation for freight cost estimation and carrier invoice audit.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Commitment Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the base rate when the contracted volume commitment tier is met or exceeded. Expressed as a decimal (e.g., 0.05 = 5% discount). Incentivizes volume commitment with carriers and 3PLs for agricultural commodity lanes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationZipCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zip Code' ;
    rdfs:comment 'ZIP code of the destination point for the freight lane. Used for lane-level rate matching in TMS when a specific facility ID is not available. Supports zone-based and mileage-based rate calculations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Detention Rate Per Hour' ;
    rdfs:comment 'Accessorial charge rate applied per hour when a carrier\'s equipment is detained beyond the contracted free time at origin or destination. A key component of the accessorial rate schedule for agricultural commodity shipments where loading/unloading delays are common.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeTimeHours rdf:type rdf:Property ;
    rdfs:label 'Free Time Hours' ;
    rdfs:comment 'Number of hours of free loading/unloading time included in the base rate before detention charges begin to accrue. Standard free time for agricultural commodity shipments is typically 2 hours. Critical for managing detention/demurrage cost exposure at grain elevators and processing facilities.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeFormula rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Formula' ;
    rdfs:comment 'Description or formula code defining how the fuel surcharge is calculated, typically indexed to the US Department of Energy (DOE) weekly diesel retail price index. Examples: \'DOE_TABLE_LOOKUP\', \'DOE_PERCENT_OF_BASE\', \'FIXED_CPM\' (cents per mile). Drives dynamic fuel surcharge computation in TMS freight cost estimation.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'The current or baseline fuel surcharge rate expressed as a percentage of the base rate or as a fixed amount per mile (depending on fuel_surcharge_formula). Updated periodically based on DOE index triggers. Used in freight cost estimation and carrier invoice audit.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Lane Distance Miles' ;
    rdfs:comment 'Contracted or calculated mileage for the origin-destination freight lane. Used for per-mile rate calculations, fuel surcharge computation, and route optimization analysis. Typically derived from PC*MILER or equivalent mileage engine integrated with TMS.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lumperRate rdf:type rdf:Property ;
    rdfs:label 'Lumper Rate' ;
    rdfs:comment 'Accessorial charge for lumper (third-party unloading labor) services at destination facilities such as food manufacturer warehouses and retail distribution centers. Included in the accessorial rate schedule when the carrier is responsible for arranging unloading labor.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'The minimum freight charge applicable regardless of shipment weight, volume, or distance. Ensures carrier cost recovery for small or short-haul shipments. Applied during freight cost estimation when the calculated base rate falls below this threshold.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originZipCode rdf:type rdf:Property ;
    rdfs:label 'Origin Zip Code' ;
    rdfs:comment 'ZIP code of the origin point for the freight lane. Used for lane-level rate matching in TMS when a specific facility ID is not available. Supports zone-based and mileage-based rate calculations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the freight rate record, used in carrier negotiations, freight audit, and SAP S/4HANA condition record references. Enables cross-system traceability between TMS, ERP, and carrier portals.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate record. Active rates are available for freight cost estimation and carrier selection. Expired rates are retained for freight audit variance analysis against historical invoices. Pending rates are awaiting carrier confirmation. Suspended rates are temporarily unavailable.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of how the freight rate is calculated and applied. Per mile applies to truckload movements; per CWT (Hundredweight) and per MT (Metric Ton) apply to weight-based commodity pricing; per BU (Bushel) applies to grain and oilseed movements; flat rate applies to fixed-price lane agreements. Drives freight cost estimation logic in TMS.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopOffCharge rdf:type rdf:Property ;
    rdfs:label 'Stop Off Charge' ;
    rdfs:comment 'Accessorial charge applied for each additional stop beyond the primary origin-destination pair on a multi-stop shipment. Common in agricultural distribution routes serving multiple farm locations or delivery points. Part of the accessorial rate schedule.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold chain shipments covered by this rate. Applicable to refrigerated equipment rates for perishable agricultural commodities. Enforces FSMA Sanitary Transportation Rule cold chain requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Min Celsius' ;
    rdfs:comment 'Minimum required temperature in degrees Celsius for cold chain shipments covered by this rate. Applicable to refrigerated equipment rates for perishable agricultural commodities (produce, dairy, meat). Enforces FSMA Sanitary Transportation Rule cold chain requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Contracted standard transit time in calendar days for the origin-destination lane at this rate. Used for delivery scheduling, cold chain management planning, and carrier service level evaluation. Critical for perishable agricultural commodity shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierMax rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Max' ;
    rdfs:comment 'Maximum contracted volume (in the unit defined by rate_type) applicable for this rate tier. Null indicates no upper bound. Defines the upper boundary of the volume commitment tier for tiered discount rate structures.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierMin rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Min' ;
    rdfs:comment 'Minimum contracted volume commitment (in the unit defined by rate_type, e.g., CWT, MT, BU, or number of loads) required to qualify for this rate tier. Supports volume-based discount structures in carrier contracts. Used for commitment tracking and carrier performance management.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsmaComplianceId rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Id' ;
    rdfs:comment 'Primary key for fsma_compliance' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FSMA regulatory audits require identifying the certified employee who performed each compliance assessment. The existing assessed_by column is a denormalized text field; replacing it with a proper FK ' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditReference rdf:type rdf:Property ;
    rdfs:label 'Audit Reference' ;
    rdfs:comment 'Reference number or identifier for the FDA or third-party food safety audit during which this compliance record was reviewed. Enables traceability from audit findings back to individual shipment compliance records.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkLiquidTransport rdf:type rdf:Property ;
    rdfs:label 'Bulk Liquid Transport' ;
    rdfs:comment 'Indicates whether the food commodity is transported in bulk liquid form, which triggers additional FSMA requirements for tanker cleaning, prior cargo documentation, and dedicated use declarations.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceAssessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Timestamp' ;
    rdfs:comment 'Date and time when the FSMA compliance assessment was performed for this shipment. Represents the principal business event time for this compliance record.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Record Number' ;
    rdfs:comment 'Externally-known business identifier for this FSMA compliance record, used in FDA audit submissions, regulatory correspondence, and internal traceability. Typically formatted as FSMA-YYYY-NNNNNN.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverTrainingCurrent rdf:type rdf:Property ;
    rdfs:label 'Driver Training Current' ;
    rdfs:comment 'Indicates whether the driver or carrier personnel assigned to this shipment has current, valid FSMA sanitary transportation training as required under §1.910 at the time of transport.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverTrainingRecordReference rdf:type rdf:Property ;
    rdfs:label 'Driver Training Record Reference' ;
    rdfs:comment 'Reference to the training record documenting that the driver or carrier personnel received FSMA-required sanitary transportation training per §1.910. Used to verify training compliance during FDA audits.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Description of the regulatory basis for any full or partial FSMA Sanitary Transportation exemption claimed for this shipment, such as small business exemption, farm-to-farm transport, or fully enclosed food exemption.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaRuleApplicability rdf:type rdf:Property ;
    rdfs:label 'Fsma Rule Applicability' ;
    rdfs:comment 'Indicates the extent to which the FSMA Sanitary Transportation rule (21 CFR Part 1, Subpart O) applies to this shipment. \'exempt\' applies to carriers with less than $27.5M in annual receipts or other qualifying exemptions. \'partial\' applies when only certain provisions apply.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindings rdf:type rdf:Property ;
    rdfs:label 'Inspection Findings' ;
    rdfs:comment 'Narrative description of findings from the pre-transport or in-transit inspection, including any observed sanitation deficiencies, temperature deviations, or loading condition issues.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPerformed rdf:type rdf:Property ;
    rdfs:label 'Inspection Performed' ;
    rdfs:comment 'Indicates whether a pre-transport inspection of the vehicle, container, and loading conditions was performed prior to departure, as part of FSMA sanitary transportation compliance verification.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonConformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Description' ;
    rdfs:comment 'Detailed description of the specific non-conformance(s) identified, including the regulatory requirement violated, nature of the deficiency, and affected shipment components.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceNoted rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Noted' ;
    rdfs:comment 'Indicates whether any non-conformance with FSMA Sanitary Transportation requirements was identified during inspection or compliance review for this shipment.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precoolingRequired rdf:type rdf:Property ;
    rdfs:label 'Precooling Required' ;
    rdfs:comment 'Indicates whether the vehicle or container was required to be precooled to the appropriate temperature before loading the food commodity, as specified in the temperature control plan.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precoolingVerified rdf:type rdf:Property ;
    rdfs:label 'Precooling Verified' ;
    rdfs:comment 'Indicates whether precooling of the vehicle or container was verified and documented prior to loading, confirming the required temperature was achieved before food was loaded.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousCargoDeclaration rdf:type rdf:Property ;
    rdfs:label 'Previous Cargo Declaration' ;
    rdfs:comment 'Description of the cargo previously transported in the vehicle or container before the current food shipment. Required to assess cross-contamination risk per FSMA Sanitary Transportation rules.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCargoRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Previous Cargo Risk Level' ;
    rdfs:comment 'Assessed contamination risk level based on the previous cargo carried in the vehicle or container. \'incompatible\' indicates the previous cargo is incompatible with food transport and requires additional sanitation or rejection.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Expiry Date' ;
    rdfs:comment 'Date until which this FSMA compliance record must be retained per regulatory requirements. FSMA Sanitary Transportation rule requires records to be retained for at least 12 months after the date of the activity.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Audit Flag' ;
    rdfs:comment 'Indicates whether this compliance record has been reviewed or cited during an FDA regulatory audit or inspection. Flags records requiring heightened retention and accessibility for enforcement readiness.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipperCarrierAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Shipper Carrier Agreement Status' ;
    rdfs:comment 'Status of the written agreement between shipper and carrier as required under FSMA §1.908(a), specifying which party is responsible for sanitary transportation functions. \'not_required\' applies when the carrier provides transportation equipment and the shipper loads the food.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Plan Reference' ;
    rdfs:comment 'Reference to the written temperature control plan document specifying required temperature ranges, monitoring frequency, and corrective actions for this shipment per FSMA §1.906(c).' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Indicates whether the food commodity being transported requires temperature control for safety (TCS food) under FSMA Sanitary Transportation rules, triggering additional compliance obligations.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleSanitationVerified rdf:type rdf:Property ;
    rdfs:label 'Vehicle Sanitation Verified' ;
    rdfs:comment 'Indicates whether the vehicle or transportation container was verified as sanitarily adequate prior to loading, per FSMA Sanitary Transportation requirements for preventing food contamination.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washDate rdf:type rdf:Property ;
    rdfs:label 'Wash Date' ;
    rdfs:comment 'Date on which the vehicle or container was last washed and sanitized prior to loading the food commodity. Used to verify sanitation recency relative to load date.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:washTicketReference rdf:type rdf:Property ;
    rdfs:label 'Wash Ticket Reference' ;
    rdfs:comment 'Reference number of the wash ticket or sanitation certificate documenting that the vehicle or container was cleaned and sanitized prior to loading. Critical evidence for FSMA compliance audits.' ;
    rdfs:domain ind:FsmaCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCrewId rdf:type rdf:Property ;
    rdfs:label 'Receiver Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: Agriculture receiving operations assign a specific crew to unload and inspect inbound commodity shipments. This link supports labor scheduling, dock assignment coordination, and GAP/FSMA traceability ' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:receivingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Facility Id' ;
    rdfs:comment 'Reference to the destination warehouse, processing plant, or storage facility where the inbound shipment is scheduled to be received. Drives WMS appointment scheduling in Manhattan Associates.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Foreign key linking to supply.route. Business justification: An inbound plan coordinates the arrival of agricultural inputs along a specific transportation route. Adding route_id to inbound_plan links the inbound planning record to the planned route, enabling r' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:arrivalWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Arrival Window End' ;
    rdfs:comment 'The end of the scheduled arrival time window at the receiving facility. Together with arrival_window_start, defines the acceptable delivery window for carrier compliance and dock scheduling.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalWindowStart rdf:type rdf:Property ;
    rdfs:label 'Arrival Window Start' ;
    rdfs:comment 'The start of the scheduled arrival time window at the receiving facility, used for dock appointment scheduling and carrier coordination. Enables precise receiving labor and dock door allocation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether cold chain pre-conditioning is required for this inbound shipment. True triggers cold storage dock assignment and temperature monitoring protocols at receiving. Applies to perishable commodities and temperature-sensitive inputs.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Assignment' ;
    rdfs:comment 'The specific receiving dock door or bay number pre-assigned for this inbound delivery at the receiving facility. Pre-assigned in Manhattan Associates WMS to optimize receiving throughput and cold chain integrity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTlc rdf:type rdf:Property ;
    rdfs:label 'Fsma Tlc' ;
    rdfs:comment 'FSMA Traceability Lot Code (TLC) assigned to the inbound shipment per FDA Food Safety Modernization Act (FSMA) Section 204 traceability requirements. Mandatory for foods on the Food Traceability List (FTL).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonGmo rdf:type rdf:Property ;
    rdfs:label 'Non Gmo' ;
    rdfs:comment 'Indicates whether the inbound commodity is certified as non-Genetically Modified Organism (non-GMO). True requires identity-preserved handling protocols and segregated receiving to maintain non-GMO integrity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedGrossWeightMt rdf:type rdf:Property ;
    rdfs:label 'Planned Gross Weight Mt' ;
    rdfs:comment 'Expected gross weight of the inbound shipment in Metric Tons (MT), including packaging and tare weight. Used for dock capacity planning, carrier weight compliance, and freight cost estimation.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Expected quantity of the commodity or agricultural input scheduled for receipt under this inbound plan, expressed in the base unit of measure (e.g., metric tons, bushels, liters). Drives WMS receiving task pre-creation and dock capacity planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Pre Inspection Required' ;
    rdfs:comment 'Indicates whether a pre-arrival quality inspection is required for this inbound shipment before acceptance. True triggers QM inspection lot creation in SAP S/4HANA QM upon arrival. Applies to regulated commodities and high-risk inputs.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'The planned calendar date on which the inbound shipment is expected to arrive at the receiving facility. Used for WMS appointment scheduling and receiving resource planning in Manhattan Associates WMS.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wmsAppointmentCode rdf:type rdf:Property ;
    rdfs:label 'Wms Appointment Code' ;
    rdfs:comment 'The appointment confirmation number generated by Manhattan Associates WMS for the scheduled receiving slot. Used for carrier check-in and dock coordination at the receiving facility.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsTaskCreated rdf:type rdf:Property ;
    rdfs:label 'Wms Task Created' ;
    rdfs:comment 'Indicates whether the WMS receiving task has been pre-created in Manhattan Associates WMS for this inbound plan. True when the task has been generated; False when pending task creation. Enables proactive receiving readiness tracking.' ;
    rdfs:domain ind:InboundPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loaderCrewId rdf:type rdf:Property ;
    rdfs:label 'Loader Crew Id' ;
    rdfs:comment 'Reference to the workforce crew or team responsible for executing the physical loading operation at the dock.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:actualLoadEnd rdf:type rdf:Property ;
    rdfs:label 'Actual Load End' ;
    rdfs:comment 'Actual date and time when loading operations were completed. Used to calculate loading duration and assess operational efficiency against planned targets.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLoadStart rdf:type rdf:Property ;
    rdfs:label 'Actual Load Start' ;
    rdfs:comment 'Actual date and time when loading operations commenced. Compared against planned_load_start to measure dock efficiency and on-time loading performance (KPI).' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLoadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Load Weight Kg' ;
    rdfs:comment 'Actual gross weight in kilograms of all commodities loaded onto the vehicle or container as recorded at the time of loading. Must not exceed max_load_weight_kg for road weight compliance.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityCompliant rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Compliant' ;
    rdfs:comment 'Indicates whether the load configuration meets center-of-gravity and axle weight distribution requirements for safe road transport. True = compliant; False = non-compliant, requires re-configuration before departure.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Load Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the load plan, used in operational communications with carriers, dock staff, and warehouse teams. Sourced from Manhattan Associates WMS or SAP S/4HANA MM.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load as full truckload, partial load, less-than-truckload (LTL), or bulk. Drives freight rate calculation and carrier selection.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingSequence rdf:type rdf:Property ;
    rdfs:label 'Loading Sequence' ;
    rdfs:comment 'Numeric sequence order in which commodity lots are to be loaded onto the vehicle or container. Ensures correct load order for route-based unloading (last-in, first-out) and weight distribution compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxLoadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Load Weight Kg' ;
    rdfs:comment 'Maximum permissible gross load weight in kilograms for the assigned vehicle or container, based on vehicle capacity and road weight limit regulations. Used to enforce compliance with DOT weight limits.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netLoadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Load Weight Kg' ;
    rdfs:comment 'Net weight in kilograms of the commodity payload, excluding packaging, pallets, and dunnage. Used for commodity quantity reconciliation and freight billing.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLoadEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Load End' ;
    rdfs:comment 'Scheduled date and time when loading operations are planned to be completed. Used for departure scheduling and carrier coordination.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedLoadStart rdf:type rdf:Property ;
    rdfs:label 'Planned Load Start' ;
    rdfs:comment 'Scheduled date and time when loading operations are planned to commence at the assigned dock. Used for dock scheduling and crew coordination.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanitationVerified rdf:type rdf:Property ;
    rdfs:label 'Sanitation Verified' ;
    rdfs:comment 'Indicates whether the vehicle or container was inspected and verified as clean and sanitary prior to loading, as required by FSMA Sanitary Transportation rules for food commodities.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logisticsPlanId rdf:type rdf:Property ;
    rdfs:label 'Logistics Plan Id' ;
    rdfs:comment 'Primary key for logistics_plan' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Dispatch Window End' ;
    rdfs:comment 'End of the planned dispatch time window at the origin facility. Together with dispatch_window_start defines the acceptable loading window for carrier and dock coordination.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchWindowStart rdf:type rdf:Property ;
    rdfs:label 'Dispatch Window Start' ;
    rdfs:comment 'Start of the planned dispatch time window at the origin facility. Enables precise dock slot allocation and carrier arrival coordination beyond day-level scheduling.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:phytosanitaryCertRequired rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Cert Required' ;
    rdfs:comment 'Indicates whether a phytosanitary certificate issued by USDA APHIS is required for this shipment. Applicable for international agricultural commodity exports to certify freedom from pests and diseases.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planDirection rdf:type rdf:Property ;
    rdfs:label 'Plan Direction' ;
    rdfs:comment 'Indicates whether this logistics plan governs an inbound arrival (farm inputs, raw commodities arriving at a facility) or an outbound dispatch (processed commodities, finished goods departing to food manufacturers or retailers). This is the primary discriminator for the single SSOT model.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantityBu rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity Bu' ;
    rdfs:comment 'Planned shipment quantity expressed in Bushels (BU). Used for grain commodities (corn, soybeans, wheat) where bushel is the standard US trade unit. Complements MT for dual-unit reporting.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantityMt rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity Mt' ;
    rdfs:comment 'Planned shipment quantity expressed in Metric Tons (MT). Primary quantity measure for bulk agricultural commodities. Used for capacity planning, freight rate calculation, and yield reconciliation.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Indicates whether this logistics plan requires temperature-controlled cold chain management throughout the transport and storage lifecycle. Triggers cold chain monitoring, reefer equipment assignment, and FSMA temperature compliance tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresExportDocs rdf:type rdf:Property ;
    rdfs:label 'Requires Export Docs' ;
    rdfs:comment 'Indicates whether this logistics plan requires export documentation including COOL (Country of Origin Labeling) certificates, phytosanitary certificates, or other export compliance documents. Triggers export documentation workflow.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPreArrivalInspection rdf:type rdf:Property ;
    rdfs:label 'Requires Pre Arrival Inspection' ;
    rdfs:comment 'Indicates whether a pre-arrival quality inspection is required before the shipment is received at the destination facility. Triggers QM inspection lot creation in SAP S/4HANA QM and WMS quarantine task pre-creation.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPreconditioning rdf:type rdf:Property ;
    rdfs:label 'Requires Preconditioning' ;
    rdfs:comment 'Indicates whether the commodity requires pre-conditioning (e.g., grain drying, temperature equalization, fumigation) before storage or processing at the destination facility. Drives facility resource pre-allocation.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDispatchDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Dispatch Date' ;
    rdfs:comment 'Planned date for outbound dispatch or inbound pickup from the origin facility. Used for dock scheduling, carrier booking, and WMS wave planning in Manhattan Associates.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wmsTaskPrecreated rdf:type rdf:Property ;
    rdfs:label 'Wms Task Precreated' ;
    rdfs:comment 'Indicates whether warehouse management system (WMS) tasks have been pre-created in Manhattan Associates WMS for this logistics plan. Enables proactive labor and equipment allocation before physical arrival or dispatch.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentFacilityId rdf:type rdf:Property ;
    rdfs:label 'Current Facility Id' ;
    rdfs:comment 'Reference to the facility (warehouse, processing plant, cold storage, distribution center) currently holding custody of this lot. Updated at each chain-of-custody transfer event.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originTrialId rdf:type rdf:Property ;
    rdfs:label 'Origin Trial Id' ;
    rdfs:comment 'Foreign key linking to research.trial. Business justification: Foundation seed lots and identity-preserved grain originating from research trials require traceability back to the originating trial for regulatory audit, seed multiplication chain documentation, and' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:parentLotLotTraceId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Lot Trace Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent lot_trace record from which this lot was derived through a split or merge event. Null for original lots. Enables reconstruction of the full lot genealogy tree for recall tracing.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotTrace .

ind:custodyTransferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Custody Transfer Timestamp' ;
    rdfs:comment 'The date and time of the most recent chain-of-custody transfer event for this lot. Represents the principal business event timestamp for the current custody state. Updated at each facility handoff.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'The ultimate disposition of this lot upon closure of the traceability record. \'sold\' = delivered to customer; \'consumed\' = used in internal processing; \'destroyed\' = disposed due to quality failure or recall; \'donated\' = donated to food bank or relief; \'returned\' = returned to supplier; \'pending\' = disposition not yet determined.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTlcSource rdf:type rdf:Property ;
    rdfs:label 'Fsma Tlc Source' ;
    rdfs:comment 'Identifies the point in the supply chain where the FSMA Traceability Lot Code (TLC) was first assigned. Required by FDA food traceability rule to establish the Critical Tracking Event (CTE) origin.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotEventType rdf:type rdf:Property ;
    rdfs:label 'Lot Event Type' ;
    rdfs:comment 'Classifies the nature of the lot creation or transformation event. \'original\' = first-time lot creation at harvest; \'split\' = divided from a parent lot; \'merge\' = combined from multiple parent lots; \'repack\' = repackaged without commodity change; \'reclassify\' = grade or classification change.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlTestDate rdf:type rdf:Property ;
    rdfs:label 'Mrl Test Date' ;
    rdfs:comment 'The date on which MRL testing was performed on a representative sample from this lot. Used to determine test currency and whether re-testing is required for extended storage periods.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiDaysObserved rdf:type rdf:Property ;
    rdfs:label 'Phi Days Observed' ;
    rdfs:comment 'The actual number of days elapsed between the last recorded pesticide application and the harvest date for this lot. Used to verify PHI compliance against the label-required interval.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this lot is currently subject to an active recall or withdrawal action. True = lot implicated in recall; False = no active recall. Triggers immediate operational holds and one-up/one-back notification workflows.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallReference rdf:type rdf:Property ;
    rdfs:label 'Recall Reference' ;
    rdfs:comment 'The official FDA or USDA recall reference number associated with this lot if recall_flag is True. Enables cross-referencing with regulatory recall databases and internal recall management records.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'Identifier of the preferred carrier or 3PL assigned to this route based on contracted rates, service performance, and commodity handling capabilities. Used by TMS for automated carrier selection and freight tendering.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:avgTransitDelayHours rdf:type rdf:Property ;
    rdfs:label 'Avg Transit Delay Hours' ;
    rdfs:comment 'Historical average delay in hours experienced on this route beyond the estimated transit time, calculated from actual shipment performance data. Used for realistic delivery promise date calculation, carrier performance benchmarking, and TMS transit time buffer planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total planned distance of the route in kilometers, as calculated from GPS/RTK route geometry or GIS network analysis. Used for freight cost estimation, fuel consumption planning, driver hours-of-service compliance, and carbon footprint calculation.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Total planned distance of the route in miles, the standard unit for US domestic trucking freight rate calculations, FMCSA compliance, and carrier contract negotiations. Maintained alongside kilometers for dual-unit reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Hours' ;
    rdfs:comment 'Estimated total transit time in hours for the route under standard operating conditions, accounting for transport mode, distance, and typical delays. Used for delivery scheduling, customer promise dates, and cold chain temperature exposure calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostPerKm rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Km' ;
    rdfs:comment 'Standard contracted freight cost per kilometer for this route in the base currency (USD). Used by TMS for freight cost estimation, carrier rate benchmarking, and transportation spend analytics. Derived from carrier contracts negotiated in SAP S/4HANA MM.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsGeometryReference rdf:type rdf:Property ;
    rdfs:label 'Gps Geometry Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the GPS/RTK route geometry definition stored in Esri ArcGIS or the GIS layer repository. Contains the spatial polyline representation of the route for map visualization, precision agriculture VRA delivery planning, and geofencing. Follows GeoJSON or Esri feature service reference convention.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasBorderCrossing rdf:type rdf:Property ;
    rdfs:label 'Has Border Crossing' ;
    rdfs:comment 'Indicates whether this route includes one or more international border crossings requiring customs documentation, phytosanitary certificates, APHIS import/export permits, or COOL compliance. Triggers additional documentation requirements in SAP S/4HANA GTS.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasHarvestCongestion rdf:type rdf:Property ;
    rdfs:label 'Has Harvest Congestion' ;
    rdfs:comment 'Indicates whether this route experiences significant traffic congestion during harvest season due to high agricultural vehicle volumes. Used by TMS for seasonal transit time adjustments, route optimization, and harvest logistics planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSpringWeightRestriction rdf:type rdf:Property ;
    rdfs:label 'Has Spring Weight Restriction' ;
    rdfs:comment 'Indicates whether this route is subject to seasonal spring weight limit restrictions (spring thaw load restrictions) that reduce allowable gross vehicle weight on roads during spring months. Affects load planning, carrier selection, and delivery scheduling during spring planting season.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasTollRoad rdf:type rdf:Property ;
    rdfs:label 'Has Toll Road' ;
    rdfs:comment 'Indicates whether this route includes toll roads, bridges, or tunnels that incur additional freight costs. Used for accurate freight cost estimation, carrier rate negotiations, and transportation spend analytics.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved' ;
    rdfs:comment 'Indicates whether this route is approved for transportation of hazardous agricultural materials including pesticides, fertilizers (ammonium nitrate), and fumigants under DOT/EPA hazmat regulations. Drives carrier certification requirements and routing restrictions through populated areas.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isColdChainCorridor rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain Corridor' ;
    rdfs:comment 'Indicates whether this route is designated as a cold chain corridor requiring temperature-controlled transport equipment (refrigerated trailers, insulated containers) throughout the entire route. Critical for perishable agricultural commodities, fresh produce, and dairy products under FSMA Sanitary Transportation rules.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Enabled' ;
    rdfs:comment 'Indicates whether RFID (Radio Frequency Identification) lot tracking infrastructure is available along this route for real-time shipment visibility and LOT traceability. Supports FSMA traceability requirements and Manhattan Associates WMS RFID integration.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the transportation route, used in TMS, BOL documentation, and carrier communications. Serves as the business-facing identifier across SAP S/4HANA SD/MM and Manhattan Associates WMS.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable descriptive name for the transportation route (e.g., \'Midwest Grain Corridor - Chicago to Memphis\'). Used in TMS planning screens, carrier briefings, and operational reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the route definition. \'active\' indicates the route is available for TMS planning; \'seasonal\' indicates availability limited to specific periods; \'restricted\' indicates regulatory or physical constraints are in effect; \'under_review\' indicates pending validation.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route by its supply chain function: \'inbound\' for farm inputs to storage/processing, \'outbound\' for finished goods to customers, \'inter_facility\' for transfers between company facilities, \'last_mile\' for final delivery to farm or retailer, \'backhaul\' for return load optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRestrictionEndMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal Restriction End Month' ;
    rdfs:comment 'Calendar month number (1-12) when seasonal restrictions end on this route. Used alongside seasonal_restriction_start_month for automated TMS seasonal planning windows and carrier capacity pre-booking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalRestrictionStartMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal Restriction Start Month' ;
    rdfs:comment 'Calendar month number (1-12) when seasonal restrictions (spring weight limits, harvest congestion, winter road closures) begin on this route. Used for automated TMS seasonal planning and proactive carrier notification.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vraDeliveryEligible rdf:type rdf:Property ;
    rdfs:label 'Vra Delivery Eligible' ;
    rdfs:comment 'Indicates whether this route is designated for precision agriculture VRA (Variable Rate Application) input deliveries, requiring GPS-guided last-mile delivery to specific field zones. Integrates with Trimble Ag Software and John Deere Operations Center for precision delivery coordination.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waypointCount rdf:type rdf:Property ;
    rdfs:label 'Waypoint Count' ;
    rdfs:comment 'Number of intermediate waypoints (stops, transfer points, relay stations, grain elevators) along the route between origin and destination. Used for multi-stop delivery planning, driver relay scheduling, and route complexity assessment in TMS.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentContractServiceContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Contract Service Contract Id' ;
    rdfs:comment 'Self-referencing identifier linking this contract to a master framework agreement or umbrella contract of which this is a sub-agreement or addendum. Null for standalone contracts. Enables contract hierarchy navigation.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this contract automatically renews upon expiry unless either party provides notice of termination within the notice period defined in termination_notice_days. Drives contract expiry alerting and renewal workflow in SAP S/4HANA MM.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseFreightRate rdf:type rdf:Property ;
    rdfs:label 'Base Freight Rate' ;
    rdfs:comment 'Contracted base freight rate per unit of measure (per MT, per load, per km, or per CWT as defined by freight_rate_uom). Represents the primary commercial term of the agreement. Confidential as it reflects negotiated pricing strategy.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoInsuranceMinUsd rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Min Usd' ;
    rdfs:comment 'Minimum required cargo insurance coverage amount in USD that the carrier or 3PL must maintain. Validated against certificate of insurance (COI) during contract onboarding and annual review.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoInsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Required' ;
    rdfs:comment 'Indicates whether the counterparty is contractually required to maintain cargo insurance coverage for agricultural commodities transported under this agreement. True triggers insurance certificate validation during onboarding and annual renewal.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedLoadsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Committed Loads Per Period' ;
    rdfs:comment 'Minimum number of loads (truck, rail car, container) committed per contract period (weekly, monthly, or annually as defined by volume_period_type). Complements committed_volume_mt for load-based capacity planning and take-or-pay enforcement.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedVolumeMt rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Mt' ;
    rdfs:comment 'Minimum guaranteed volume in Metric Tons (MT) per contract period that the shipper commits to tender to the carrier or 3PL. Used for take-or-pay penalty calculations and capacity planning. Aligns with SAP S/4HANA MM outline agreement target quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyLegalName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Legal Name' ;
    rdfs:comment 'Full registered legal name of the carrier, 3PL, cold storage operator, or logistics service provider as it appears on the executed contract and legal entity registration. Used for invoice matching, compliance filings, and FMCSA carrier verification.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateUom rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Uom' ;
    rdfs:comment 'Unit of measure against which the base_freight_rate is applied. Agricultural logistics commonly uses per Metric Ton (MT), per Bushel (BU), per Hundredweight (CWT), per load, or per kilometer depending on commodity and mode.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Fsma Obligation Description' ;
    rdfs:comment 'Narrative description of specific FSMA Sanitary Transportation obligations assigned to the carrier or 3PL under this contract, including vehicle cleaning and sanitization requirements, temperature monitoring, and written procedures for food safety.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/state code identifying the legal jurisdiction whose laws govern this contract (e.g., US-IL for Illinois, USA for federal US law). Determines applicable regulatory frameworks and dispute resolution venue.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Description' ;
    rdfs:comment 'Narrative description of financial incentive or bonus terms awarded for exceeding SLA targets (e.g., OTD above 98%, zero temperature exceedances, volume over-performance). Confidential commercial term used in carrier performance management.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceMinUsd rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Min Usd' ;
    rdfs:comment 'Minimum required general liability insurance coverage amount in USD. Covers third-party bodily injury and property damage claims arising from logistics operations under this contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otdTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otd Target Pct' ;
    rdfs:comment 'Contracted minimum on-time delivery (OTD) percentage the carrier must achieve over the measurement period (e.g., 95.00%). Triggers SLA penalty clauses when actual OTD falls below this threshold. Key KPI for carrier performance scorecards.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Narrative description of financial penalty terms triggered by SLA breaches (OTD failures, temperature exceedances, volume shortfalls, cargo damage). Includes penalty calculation methodology (per-load flat fee, percentage of freight charge, or liquidated damages). Confidential commercial term.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Narrative description of the logistics services covered under this contract, including lane definitions (origin-destination pairs), commodity types handled (grain, produce, livestock feed, refrigerated goods), equipment types, and any special handling requirements such as HACCP-compliant cold chain or FSMA-regulated food transport.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tempComplianceTargetPct rdf:type rdf:Property ;
    rdfs:label 'Temp Compliance Target Pct' ;
    rdfs:comment 'Contracted minimum percentage of cold chain shipments that must remain within the contracted temperature range (temp_min_celsius to temp_max_celsius) throughout transit. SLA breach triggers penalty clauses and FSMA corrective action requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days advance written notice required by either party to terminate or elect not to renew this contract. Drives contract management alerts and legal review workflows.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Target Hours' ;
    rdfs:comment 'Contracted maximum transit time in hours from pickup to delivery for standard lanes covered under this agreement. Core SLA metric used for on-time delivery (OTD) performance measurement and penalty trigger evaluation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePeriodType rdf:type rdf:Property ;
    rdfs:label 'Volume Period Type' ;
    rdfs:comment 'Time period granularity to which committed_volume_mt and committed_loads_per_period apply. Determines the cadence for take-or-pay calculations and volume shortfall penalty assessments.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the shipment arrived at the destination facility, captured via GPS telematics or gate check-in scan. Used for on-time delivery performance, dwell time analysis, and proof of delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time the shipment departed from the origin facility, captured via GPS telematics or manual confirmation. Used for on-time departure performance measurement and FSMA transport time tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerId rdf:type rdf:Property ;
    rdfs:label 'Container Id' ;
    rdfs:comment 'Unique identifier of the shipping container, railcar, trailer, or intermodal unit used for this shipment. Follows ISO 6346 standard for container identification (e.g., ABCU1234567). Used for container tracking and RFID integration.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Gps Latitude' ;
    rdfs:comment 'GPS latitude coordinate (WGS84 decimal degrees) captured at the point of delivery confirmation. Provides geospatial proof of delivery location for dispute resolution and route analytics via Esri ArcGIS.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Gps Longitude' ;
    rdfs:comment 'GPS longitude coordinate (WGS84 decimal degrees) captured at the point of delivery confirmation. Provides geospatial proof of delivery location for dispute resolution and route analytics via Esri ArcGIS.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electronicSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Captured' ;
    rdfs:comment 'Indicates whether an electronic signature was captured from the consignee at the point of delivery per 49 CFR requirements. Required for legal proof of delivery and invoice payment authorization.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight cost in US Dollars (USD) charged by the carrier for this shipment. Used for logistics cost analysis, COGS allocation, and carrier rate benchmarking. Sourced from SAP S/4HANA MM freight condition records.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Timestamp when proof of delivery was captured at the destination, including electronic signature, GPS coordinates, and/or photo evidence. Triggers invoice payment release in SAP S/4HANA FI and closes the delivery lifecycle.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Date' ;
    rdfs:comment 'Planned date on which the shipment is scheduled to depart from the origin facility. Used for transportation planning, carrier booking, and on-time departure KPI measurement.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment from planning through final delivery. Drives operational workflows in SAP S/4HANA SD and Manhattan Associates WMS. Lifecycle: planned → confirmed → in_transit → delivered (or exception/cancelled).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line record in the silver layer lakehouse. Primary key for the shipment_line data product. Entity role: TRANSACTION_LINE.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Declared monetary value of the commodity on this shipment line in the transaction currency. Used for customs declarations, insurance valuation, and financial reconciliation. Required TRANSACTION_LINE category: LINE_VALUE_OR_RESULT.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTransportFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Transport Facility Id' ;
    rdfs:comment 'Reference to the origin facility (farm, grain elevator, processing plant, or warehouse) from which the agricultural commodity shipment originates. Used for FSMA traceability and BOL generation.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:bookingConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Confirmation Number' ;
    rdfs:comment 'The carrier or 3PL-issued booking confirmation reference number acknowledging capacity commitment for this transportation order. Used for capacity management, cancellation processing, and carrier invoice reconciliation.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTerms rdf:type rdf:Property ;
    rdfs:label 'Cancellation Terms' ;
    rdfs:comment 'Free-text description of the carrier booking cancellation terms applicable to this transportation order, including notice period requirements and penalty charges. Sourced from the carrier rate agreement.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Pickup Date' ;
    rdfs:comment 'The carrier-confirmed appointment date and time for cargo pickup at the origin facility. May differ from requested pickup date due to carrier availability. Drives dock assignment and load planning execution.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fsmaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Status' ;
    rdfs:comment 'Compliance status of this transportation order against FSMA Sanitary Transportation of Human and Animal Food rule (21 CFR Part 1, Subpart O). Tracks whether required vehicle cleanliness, temperature control, and shipper/carrier agreement requirements are met.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTempC rdf:type rdf:Property ;
    rdfs:label 'Max Temp C' ;
    rdfs:comment 'Maximum allowable cargo temperature in degrees Celsius during transport. Exceedance triggers FSMA non-compliance flag and may require cargo rejection or quality hold upon delivery.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTempC rdf:type rdf:Property ;
    rdfs:label 'Min Temp C' ;
    rdfs:comment 'Minimum allowable cargo temperature in degrees Celsius during transport. Used for cold chain compliance monitoring, reefer set-point configuration, and FSMA temperature excursion alerting.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The shipper-requested date and time window start for cargo pickup at the origin facility. Used for dock scheduling, carrier appointment booking, and on-time pickup KPI measurement.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tmsOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Tms Order Number' ;
    rdfs:comment 'Externally-visible, human-readable transportation order number generated by the TMS (e.g., SAP TM or Manhattan Associates TMS). Used for carrier communication, BOL cross-reference, and customer-facing shipment tracking.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each biodiversity assessment record. Primary key for the biodiversity_assessment data product in the sustainability domain.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Assessed Area Ha' ;
    rdfs:comment 'Total land area covered by the biodiversity assessment, measured in hectares. Used to normalize biodiversity metrics per unit area and for TNFD spatial footprint reporting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessingOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessing Organization' ;
    rdfs:comment 'Name of the organization, consultancy, or internal team that conducted the biodiversity assessment. May be an accredited third-party auditor for GLOBALG.A.P. or TNFD verification purposes.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Externally-known business identifier for the assessment, formatted as BDA-{YEAR}-{SEQUENCE}. Used for cross-referencing with field teams, regulatory submissions, and TNFD/ESG disclosures.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text field for additional observations, anomalies, data quality caveats, or contextual information recorded by the assessor during the field survey. Supports audit review and methodology transparency.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityNetGainScore rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Net Gain Score' ;
    rdfs:comment 'Calculated biodiversity net gain or loss score for the assessed parcel, expressed as a habitat unit value per the applicable BNG metric (e.g., DEFRA BNG Metric). Supports biodiversity net gain commitments and TNFD nature-positive target reporting.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationProgram rdf:type rdf:Property ;
    rdfs:label 'Certification Program' ;
    rdfs:comment 'Voluntary or mandatory certification program for which this biodiversity assessment provides supporting evidence (e.g., GLOBALG.A.P., Rainforest Alliance, ISCC). Links assessment data to certification compliance records.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Conservation Priority Level' ;
    rdfs:comment 'Categorical priority rating assigned to the assessed parcel based on biodiversity findings, indicating the urgency of conservation intervention. Drives prioritization of USDA NRCS conservation program enrollment and TNFD response planning.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:habitatQualityScale rdf:type rdf:Property ;
    rdfs:label 'Habitat Quality Scale' ;
    rdfs:comment 'The scoring scale used for the habitat quality score, ensuring correct interpretation across different assessment methodologies (e.g., 0–1 for DEFRA BNG metric, 0–100 for USDA NRCS).' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:habitatQualityScore rdf:type rdf:Property ;
    rdfs:label 'Habitat Quality Score' ;
    rdfs:comment 'Quantitative score (typically 0.00–1.00 or 0–100 scale per methodology) representing the ecological condition and functional integrity of the assessed habitat. Used in biodiversity net gain calculations and TNFD state metrics.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:habitatType rdf:type rdf:Property ;
    rdfs:label 'Habitat Type' ;
    rdfs:comment 'Primary habitat classification of the assessed area per IUCN or USDA NRCS habitat classification systems. Determines applicable conservation standards and biodiversity net gain calculation pathway. [ENUM-REF-CANDIDATE: cropland|grassland|woodland|wetland|riparian|hedgerow|orchard|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invasiveSpeciesNames rdf:type rdf:Property ;
    rdfs:label 'Invasive Species Names' ;
    rdfs:comment 'Comma-separated list of invasive or non-native species identified during the assessment. Populated only when invasive_species_present is True. Used for APHIS reporting and IPM action planning.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invasiveSpeciesPresent rdf:type rdf:Property ;
    rdfs:label 'Invasive Species Present' ;
    rdfs:comment 'Indicates whether invasive or non-native species were detected during the assessment. Triggers mandatory reporting to APHIS and informs integrated pest management (IPM) and conservation action planning.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Full name of the primary ecologist or field scientist responsible for conducting and signing off on the biodiversity assessment. Required for audit trail and regulatory submission accountability.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The scientific or regulatory methodology applied during the biodiversity assessment. Determines data quality standards and comparability across assessments. [ENUM-REF-CANDIDATE: USDA_NRCS|IUCN|BirdLife|GLOBALG.A.P.|Pollard_Walk|Quadrat_Sampling|Transect_Survey|Rapid_Assessment|Point_Count|Pitfall_Trap — promote to reference product]' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeVegetationPct rdf:type rdf:Property ;
    rdfs:label 'Native Vegetation Pct' ;
    rdfs:comment 'Percentage of the assessed area covered by native or indigenous plant species. Key indicator of habitat naturalness and ecological integrity for TNFD and GLOBALG.A.P. reporting.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pollinatorIndex rdf:type rdf:Property ;
    rdfs:label 'Pollinator Index' ;
    rdfs:comment 'Composite index score measuring pollinator abundance, diversity, and habitat suitability on the assessed parcel. Supports GLOBALG.A.P. pollinator protection requirements and integrated pest management (IPM) planning.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedConservationActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Conservation Actions' ;
    rdfs:comment 'Free-text description of recommended conservation and habitat management actions identified during the assessment, such as cover crop establishment, buffer strip creation, or invasive species removal. Informs USDA NRCS conservation practice planning.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which the assessment findings were formally submitted to the relevant regulatory authority. Populated only when regulatory_submission_required is True. Supports compliance audit trail.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soilBiodiversityScore rdf:type rdf:Property ;
    rdfs:label 'Soil Biodiversity Score' ;
    rdfs:comment 'Composite score representing the diversity and abundance of soil organisms (bacteria, fungi, earthworms, nematodes) in the assessed area. Supports soil health monitoring and carbon sequestration assessments aligned with USDA NRCS soil health frameworks.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speciesRichnessCount rdf:type rdf:Property ;
    rdfs:label 'Species Richness Count' ;
    rdfs:comment 'Total number of distinct species identified during the assessment survey. A primary biodiversity metric used in TNFD disclosures and biodiversity net gain calculations.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threatenedSpeciesCount rdf:type rdf:Property ;
    rdfs:label 'Threatened Species Count' ;
    rdfs:comment 'Number of species identified during the assessment that are classified as threatened, endangered, or critically endangered per IUCN Red List criteria. Critical for TNFD nature-related risk disclosure.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threatenedSpeciesNames rdf:type rdf:Property ;
    rdfs:label 'Threatened Species Names' ;
    rdfs:comment 'Comma-separated list of common or scientific names of threatened or endangered species identified during the assessment. Supports conservation action planning and regulatory reporting to APHIS and EPA.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnfdDisclosureIncluded rdf:type rdf:Property ;
    rdfs:label 'Tnfd Disclosure Included' ;
    rdfs:comment 'Indicates whether this assessment record has been included in the enterprise\'s Taskforce on Nature-related Financial Disclosures (TNFD) annual report. Supports ESG reporting completeness tracking.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wetlandAreaHa rdf:type rdf:Property ;
    rdfs:label 'Wetland Area Ha' ;
    rdfs:comment 'Total area of wetlands identified within the assessed parcel, measured in hectares. Required for Clean Water Act Section 404 permit applications and USDA wetland conservation compliance.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetlandPresent rdf:type rdf:Property ;
    rdfs:label 'Wetland Present' ;
    rdfs:comment 'Indicates whether jurisdictional or non-jurisdictional wetlands were identified within or adjacent to the assessed parcel. Triggers Clean Water Act Section 404 compliance review and wetland delineation requirements.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdingAccountId rdf:type rdf:Property ;
    rdfs:label 'Holding Account Id' ;
    rdfs:comment 'The enterprise\'s account identifier within the carbon registry where this credit is held prior to retirement or transfer. Used for registry reconciliation and portfolio management.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:internalCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Internal Cost Center Id' ;
    rdfs:comment 'Reference to the internal cost center responsible for the carbon credit transaction, used for internal carbon pricing, OPEX/CAPEX allocation, and management accounting within SAP S/4HANA CO module.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the carbon offset project that generated or is associated with this credit (e.g., soil carbon sequestration project, avoided deforestation, methane reduction, or renewable energy project on agricultural land).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agriculture .

ind:additionalityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Additionality Confirmed' ;
    rdfs:comment 'Indicates whether the carbon credit has been confirmed as additional — meaning the emission reductions or removals would not have occurred without the carbon project incentive. Additionality is a fundamental requirement for carbon credit validity under all major registry standards.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerEntityName rdf:type rdf:Property ;
    rdfs:label 'Buyer Entity Name' ;
    rdfs:comment 'The legal name of the entity that purchased or received the carbon credit upon retirement or transfer. Relevant for voluntary market transactions, compliance transfers, and customer offset programs. Null for credits held in the enterprise\'s own portfolio.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefitType rdf:type rdf:Property ;
    rdfs:label 'Co Benefit Type' ;
    rdfs:comment 'The primary environmental or social co-benefit associated with the carbon project beyond GHG reductions (e.g., biodiversity enhancement, water quality improvement, soil health improvement, rural community development). Co-benefits can command a price premium in voluntary carbon markets and support ESG reporting.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'The contract or agreement reference number governing the purchase, sale, or transfer of this carbon credit (e.g., ISDA EFET carbon trading agreement, bilateral OTC contract number). Used for legal and financial audit trail.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current lifecycle status of the carbon credit. Issued = credit has been verified and issued by the registry; Active = credit is held in portfolio and available for use; Retired = credit has been permanently cancelled against an emissions claim; Transferred = credit has been sold or transferred to another entity; Cancelled = credit invalidated due to reversal or error; Pending Verification = awaiting registry verification.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the carbon credit by the mechanism through which greenhouse gas reductions or removals were achieved. Relevant types for agriculture include soil carbon sequestration, avoided deforestation, enteric methane reduction, manure methane capture, and renewable energy. [ENUM-REF-CANDIDATE: soil_carbon|avoided_deforestation|methane_reduction|renewable_energy|improved_forest_management|nitrous_oxide_reduction|biochar|wetland_restoration — promote to reference product]' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Period' ;
    rdfs:comment 'The ESG reporting period (fiscal year or quarter) to which this carbon credit is attributed for sustainability disclosures (e.g., \'2024\' for annual, \'2024-Q3\' for quarterly). Aligns carbon credit accounting with TCFD, IFRS S2, and SEC climate disclosure reporting cycles.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgProtocolScope rdf:type rdf:Property ;
    rdfs:label 'Ghg Protocol Scope' ;
    rdfs:comment 'The GHG Protocol scope category against which this carbon credit is applied or attributed: Scope 1 = direct emissions from owned/controlled agricultural operations (e.g., enteric fermentation, fuel combustion); Scope 2 = indirect emissions from purchased energy; Scope 3 = value chain emissions (e.g., supply chain, land use change).' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'The date on which the carbon credit was officially issued by the registry following successful third-party verification of the underlying emission reductions or removals.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:methodologyCode rdf:type rdf:Property ;
    rdfs:label 'Methodology Code' ;
    rdfs:comment 'The registry-assigned methodology or protocol code used to quantify and verify the greenhouse gas reductions or removals for this credit (e.g., VM0042 for Verra improved agricultural land management, ACR Soil Enrichment Protocol, CAR Soil Enrichment Protocol). Critical for audit and verification purposes.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period End' ;
    rdfs:comment 'The end date of the monitoring period during which the greenhouse gas reductions or removals represented by this credit were measured and verified. Together with monitoring_period_start, defines the temporal scope of the credit.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period Start' ;
    rdfs:comment 'The start date of the monitoring period during which the greenhouse gas reductions or removals represented by this credit were measured and verified. Defines the temporal boundary of the credit\'s underlying emission reductions.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permanenceBufferPct rdf:type rdf:Property ;
    rdfs:label 'Permanence Buffer Pct' ;
    rdfs:comment 'The percentage of the gross carbon credit quantity withheld in a registry buffer pool to insure against potential reversal risks (e.g., wildfire destroying sequestered soil carbon, crop failure). Expressed as a percentage of gross quantity. Particularly relevant for agricultural soil carbon and forestry credits.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerTonneUsd rdf:type rdf:Property ;
    rdfs:label 'Price Per Tonne Usd' ;
    rdfs:comment 'The transaction price paid or received per metric tonne of CO2 equivalent for this carbon credit, expressed in US dollars. Used for carbon market valuation, cost accounting, and ROI analysis of the enterprise\'s carbon portfolio. Null for internally generated credits not yet transacted.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Project Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the underlying carbon offset project is located (e.g., USA, BRA, IND). Used for geographic reporting, COOL compliance, and international carbon market eligibility.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e' ;
    rdfs:comment 'The volume of greenhouse gas reductions or removals represented by this credit, expressed in metric tonnes of carbon dioxide equivalent (tCO2e). One carbon credit typically equals one tonne CO2e. This is the principal quantitative fact for carbon market transactions.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the carbon credit registry where this credit is registered and tracked (e.g., Verra Verified Carbon Standard, Gold Standard, Climate Action Reserve, American Carbon Registry). [ENUM-REF-CANDIDATE: Verra VCS|Gold Standard|CAR|ACR|UNFCCC CDM|Chicago Climate Exchange|Plan Vivo|Social Carbon — promote to reference product]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryProjectCode rdf:type rdf:Property ;
    rdfs:label 'Registry Project Code' ;
    rdfs:comment 'The external project identifier assigned by the carbon registry (e.g., Verra VCS project number, Gold Standard project ID, CAR project ID). Used to cross-reference the credit with the public registry database for verification and audit purposes.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementBeneficiary rdf:type rdf:Property ;
    rdfs:label 'Retirement Beneficiary' ;
    rdfs:comment 'The name of the entity on whose behalf the carbon credit is retired, which may differ from the buyer entity (e.g., a food manufacturer retiring credits on behalf of a consumer brand for Scope 3 offsetting). Used in registry retirement certificates and ESG disclosures.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date on which the carbon credit was permanently retired (cancelled) in the registry, signifying that the associated emission reduction has been claimed against a specific entity\'s greenhouse gas inventory or net-zero commitment. Null if the credit has not yet been retired.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'The stated business reason for retiring the carbon credit. Voluntary Offset = retired to offset the enterprise\'s own emissions voluntarily; Compliance Obligation = retired to meet a regulatory cap-and-trade or carbon tax obligation; Internal Neutralization = retired as part of internal carbon pricing program; Customer Offset = retired on behalf of a customer; ESG Reporting = retired to support ESG disclosure targets; Net-Zero Commitment = retired toward a science-based net-zero target.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignmentCodes rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment Codes' ;
    rdfs:comment 'Comma-separated list of UN Sustainable Development Goal numbers that the underlying carbon project contributes to (e.g., \'2,13,15\' for Zero Hunger, Climate Action, Life on Land). Used for ESG reporting, investor disclosures, and voluntary carbon market premium pricing.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerEntityName rdf:type rdf:Property ;
    rdfs:label 'Seller Entity Name' ;
    rdfs:comment 'The legal name of the entity from which the carbon credit was purchased, for credits acquired on the voluntary or compliance carbon market. Null for credits generated by the enterprise\'s own agricultural projects.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Value Usd' ;
    rdfs:comment 'The total monetary value of the carbon credit transaction, calculated as quantity_tco2e multiplied by price_per_tonne_usd. Stored as a business field for financial reporting, AP/AR integration, and carbon portfolio valuation. Expressed in US dollars.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the accredited third-party auditor or verification organization that validated the greenhouse gas reductions or removals underlying this carbon credit (e.g., SCS Global Services, Bureau Veritas, DNV GL, South Pole). Required for registry issuance and GFSI/GLOBALG.A.P. sustainability compliance.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'The calendar year in which the greenhouse gas emission reductions or removals represented by this credit occurred. Vintage year is a critical pricing and eligibility factor in carbon markets — older vintages may trade at a discount.' ;
    rdfs:domain ind:CarbonCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'The reference year against which GHG emissions reductions are measured. Used for tracking progress toward science-based targets and voluntary carbon reduction commitments. Expressed as a four-digit calendar year (e.g., 2019).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biogenicCo2EmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Biogenic Co2 Emissions Mt' ;
    rdfs:comment 'Carbon dioxide emissions from biogenic sources (e.g., combustion of agricultural residues, biomass energy) reported separately from fossil-fuel-derived emissions per GHG Protocol and ISO 14064 requirements. Expressed in metric tons of CO2.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetCreditsMt rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Credits Mt' ;
    rdfs:comment 'Volume of verified carbon offset credits (in CO2e metric tons) purchased and retired against this reporting period\'s gross emissions. Includes credits from voluntary carbon markets (VCM) and compliance markets. Reported separately from biological removals.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonRemovalsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Carbon Removals Co2e Mt' ;
    rdfs:comment 'Total carbon dioxide removed from the atmosphere through biological sequestration activities such as soil carbon sequestration, cover cropping, agroforestry, and wetland restoration. Expressed in metric tons of CO2 equivalent (CO2e MT). Reported separately from emissions per GHG Protocol guidance.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdpSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Cdp Submission Reference' ;
    rdfs:comment 'Unique identifier assigned by the CDP (formerly Carbon Disclosure Project) platform for the submission in which this carbon footprint data was reported. Enables cross-referencing with CDP investor and supply chain disclosures.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ch4EmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Ch4 Emissions Co2e Mt' ;
    rdfs:comment 'Greenhouse gas emissions from methane (CH4) sources including enteric fermentation in livestock, manure management, and flooded rice cultivation, expressed in metric tons of CO2 equivalent using IPCC AR6 GWP100 factors.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Overall data quality rating for the emissions inventory, reflecting the proportion of primary measured data versus secondary estimated data used in calculations. High = predominantly primary metered/measured data; Estimated = largely modeled or default emission factors.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionIntensityPerHa rdf:type rdf:Property ;
    rdfs:label 'Emission Intensity Per Ha' ;
    rdfs:comment 'Carbon footprint intensity expressed as metric tons of CO2 equivalent per hectare of managed agricultural land. Key KPI for benchmarking land-use efficiency and comparing performance across farm units and growing seasons.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionIntensityPerMtCommodity rdf:type rdf:Property ;
    rdfs:label 'Emission Intensity Per Mt Commodity' ;
    rdfs:comment 'Carbon footprint intensity expressed as metric tons of CO2 equivalent per metric ton of commodity produced. Enables product-level carbon labeling, supply chain disclosure to food manufacturers, and comparison against industry benchmarks.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgProtocolScope2Method rdf:type rdf:Property ;
    rdfs:label 'Ghg Protocol Scope2 Method' ;
    rdfs:comment 'Indicates whether Scope 2 electricity emissions are calculated using the location-based method (average grid emission factors) or the market-based method (contractual instruments such as RECs or PPAs). Required disclosure per GHG Protocol Scope 2 Guidance.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The standard or framework used to quantify and report greenhouse gas emissions in this assessment. Determines calculation factors, emission source boundaries, and reporting format. [ENUM-REF-CANDIDATE: ghg_protocol|iso_14064|cool_farm_tool|ipcc_guidelines|usda_comet|custom — promote to reference product if additional methodologies are adopted]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:n2oEmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'N2o Emissions Co2e Mt' ;
    rdfs:comment 'Greenhouse gas emissions from nitrous oxide (N2O) sources, primarily synthetic fertilizer application and manure management, expressed in metric tons of CO2 equivalent using IPCC AR6 GWP100 factors. N2O is the dominant GHG in crop production systems.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netEmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Net Emissions Co2e Mt' ;
    rdfs:comment 'Net greenhouse gas position calculated as total gross emissions minus verified carbon removals and sequestration. Expressed in metric tons of CO2 equivalent (CO2e MT). Used for net-zero target tracking and voluntary carbon market reporting.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the GHG emissions reporting period covered by this assessment. Together with reporting_period_start_date defines the temporal boundary of the GHG inventory.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the GHG emissions reporting period covered by this assessment. Aligns with fiscal year, growing season, or calendar year boundaries as required by the applicable reporting framework.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scienceBasedTargetAligned rdf:type rdf:Property ;
    rdfs:label 'Science Based Target Aligned' ;
    rdfs:comment 'Indicates whether the emissions reduction trajectory reflected in this assessment is aligned with a Science Based Target (SBT) approved by the Science Based Targets initiative (SBTi). True = SBTi-approved target alignment confirmed.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope1EmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Scope1 Emissions Co2e Mt' ;
    rdfs:comment 'Total direct greenhouse gas emissions from sources owned or controlled by the farm enterprise (e.g., fuel combustion in farm equipment, enteric fermentation, manure management, on-farm fertilizer application). Expressed in metric tons of CO2 equivalent (CO2e MT).' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Scope2 Emissions Co2e Mt' ;
    rdfs:comment 'Total indirect greenhouse gas emissions from the generation of purchased electricity, steam, heat, or cooling consumed by the farm enterprise. Expressed in metric tons of CO2 equivalent (CO2e MT). Supports both location-based and market-based accounting methods.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3EmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Scope3 Emissions Co2e Mt' ;
    rdfs:comment 'Total indirect greenhouse gas emissions occurring in the value chain outside of Scope 1 and 2, including upstream inputs (fertilizers, pesticides, seeds, feed) and downstream processing, transport, and end-of-life. Expressed in metric tons of CO2 equivalent (CO2e MT).' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Total Emissions Co2e Mt' ;
    rdfs:comment 'Gross total greenhouse gas emissions across all applicable scopes (Scope 1 + Scope 2 + Scope 3) for the reporting period, expressed in metric tons of CO2 equivalent (CO2e MT). This is the headline figure used in ESG disclosures and regulatory filings.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLandAreaHa rdf:type rdf:Property ;
    rdfs:label 'Total Land Area Ha' ;
    rdfs:comment 'Total agricultural land area in hectares covered by this carbon footprint assessment boundary. Used as the denominator for emission intensity per hectare calculations and land-use reporting.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uncertaintyPercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percentage' ;
    rdfs:comment 'Quantified uncertainty of the total GHG emissions inventory expressed as a percentage (±%). Calculated per IPCC Tier 1 or Tier 2 uncertainty analysis methods. Required for ISO 14064 conformance and supports materiality assessments in third-party verification.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatementRef rdf:type rdf:Property ;
    rdfs:label 'Verification Statement Ref' ;
    rdfs:comment 'Reference number or document identifier of the official verification statement issued by the third-party verification body. Enables traceability to the source verification document for audit and regulatory purposes.' ;
    rdfs:domain ind:CarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of independent third-party verification of the GHG emissions inventory. Distinguishes between unverified, limited assurance (review-level), and reasonable assurance (audit-level) engagements as defined by ISO 14064-3 and ISAE 3410.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryClimateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Climate Employee Id' ;
    rdfs:comment 'Reference to the internal employee, agronomist, or sustainability officer who conducted or is responsible for this climate risk assessment. Supports accountability and TCFD governance disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adaptationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Adaptation Cost Usd' ;
    rdfs:comment 'Estimated CAPEX and OPEX cost in USD required to implement the planned adaptation measure. Supports capital planning, ROI analysis, and TCFD financial planning disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaptationMeasure rdf:type rdf:Property ;
    rdfs:label 'Adaptation Measure' ;
    rdfs:comment 'Description of the planned or implemented adaptation or mitigation measure to address this climate risk (e.g., \'Transition to drought-tolerant crop varieties\', \'Install precision irrigation to reduce water dependency\', \'Diversify supplier base to reduce transition risk exposure\').' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaptationStatus rdf:type rdf:Property ;
    rdfs:label 'Adaptation Status' ;
    rdfs:comment 'Current implementation status of the planned adaptation or mitigation measure associated with this climate risk, enabling tracking of risk response progress for ESG and TCFD reporting.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Affected Area Ha' ;
    rdfs:comment 'Total land area in hectares potentially exposed to this climate risk. Enables spatial quantification of physical risk exposure across the farm portfolio for TCFD and CSRD reporting.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedOperations rdf:type rdf:Property ;
    rdfs:label 'Affected Operations' ;
    rdfs:comment 'Description of the specific agricultural operations, assets, or supply chain segments affected by this climate risk (e.g., \'Irrigated corn production in Nebraska\', \'Cold chain logistics for perishable produce\'). Supports asset-level TCFD disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'The organizational or operational level at which this climate risk assessment is conducted: enterprise-wide, individual farm unit, specific asset (equipment/infrastructure), supply chain node, or individual field.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateScenario rdf:type rdf:Property ;
    rdfs:label 'Climate Scenario' ;
    rdfs:comment 'The climate scenario framework used to model this risk, aligned with IPCC Representative Concentration Pathways (RCP 2.6/4.5/8.5) or IEA Net Zero Emissions (NZE) / Sustainable Development Scenario (SDS) or NGFS orderly transition. Required for TCFD scenario analysis disclosure. [ENUM-REF-CANDIDATE: RCP_2.6|RCP_4.5|RCP_8.5|IEA_NZE|IEA_SDS|NGFS_orderly — promote to reference product]' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceSeverity rdf:type rdf:Property ;
    rdfs:label 'Consequence Severity' ;
    rdfs:comment 'Qualitative rating of the potential severity of impact if the climate risk materializes, covering operational disruption, financial loss, regulatory penalty, and reputational damage to the agricultural enterprise.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrdAligned rdf:type rdf:Property ;
    rdfs:label 'Csrd Aligned' ;
    rdfs:comment 'Indicates whether this climate risk assessment has been prepared in alignment with the EU Corporate Sustainability Reporting Directive (CSRD) double materiality requirements, enabling inclusion in CSRD sustainability statements.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleMaterialityType rdf:type rdf:Property ;
    rdfs:label 'Double Materiality Type' ;
    rdfs:comment 'CSRD double materiality classification: financial materiality (climate risk impacts the enterprise\'s financial position), impact materiality (enterprise\'s activities impact the climate), or both. Required for CSRD ESRS E1 disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactHighUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact High Usd' ;
    rdfs:comment 'Upper-bound estimate of the potential financial impact (in USD) if the climate risk materializes. Together with the low estimate, provides a range for TCFD quantitative financial impact disclosure and scenario analysis.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactLowUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Low Usd' ;
    rdfs:comment 'Lower-bound estimate of the potential financial impact (in USD) if the climate risk materializes, covering revenue loss, increased OPEX, asset impairment, and regulatory fines. Supports TCFD quantitative financial impact disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipccHazardCategory rdf:type rdf:Property ;
    rdfs:label 'Ipcc Hazard Category' ;
    rdfs:comment 'IPCC AR6 climate hazard category associated with this physical risk assessment (e.g., \'Heat stress\', \'Drought\', \'Flood\', \'Extreme precipitation\', \'Frost risk\', \'Wildfire\'). Enables standardized cross-portfolio hazard classification aligned with IPCC taxonomy.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Qualitative likelihood rating indicating the probability of the climate risk materializing within the stated risk horizon, using a standard five-point scale aligned with enterprise risk management frameworks.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The fiscal or calendar year to which this climate risk assessment is attributed for ESG reporting, TCFD disclosure, and CSRD sustainability statement purposes.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Risk rating remaining after the planned adaptation measure is applied, reflecting the net exposure the enterprise retains. Used in risk heat maps and TCFD residual risk disclosure.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'High-level TCFD risk category grouping: physical (acute or chronic climate hazards) or transition (risks arising from the shift to a lower-carbon economy). Enables top-level portfolio aggregation distinct from the granular risk_type.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the climate risk, including the hazard mechanism, exposure pathway, and potential consequences for agricultural operations, assets, or supply chain. Supports TCFD qualitative disclosure requirements.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskHorizon rdf:type rdf:Property ;
    rdfs:label 'Risk Horizon' ;
    rdfs:comment 'TCFD-aligned time horizon over which the climate risk is expected to materialize: short-term (0–3 years), medium-term (3–10 years), or long-term (10+ years). Drives prioritization of adaptation measures and capital planning.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskName rdf:type rdf:Property ;
    rdfs:label 'Risk Name' ;
    rdfs:comment 'Short, human-readable label identifying the specific climate risk being assessed (e.g., \'Increased drought frequency in Midwest corn belt\', \'Carbon pricing regulation impact on fertilizer costs\'). Used in ESG reports and TCFD disclosures.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite quantitative risk score derived from the combination of likelihood rating and consequence severity, used for risk prioritization, portfolio heat-mapping, and ESG KPI reporting. Typically on a 1–25 scale.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'TCFD-aligned classification of the climate risk: physical risks (acute events such as floods/droughts or chronic shifts such as temperature rise) or transition risks (policy/regulatory, technology, market, or reputational). [ENUM-REF-CANDIDATE: physical_acute|physical_chronic|transition_policy|transition_technology|transition_market|transition_reputational — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcfdPillar rdf:type rdf:Property ;
    rdfs:label 'Tcfd Pillar' ;
    rdfs:comment 'The TCFD disclosure pillar under which this risk assessment is primarily reported: Governance, Strategy, Risk Management, or Metrics and Targets. Enables structured mapping of risk records to TCFD report sections.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Payment Amount' ;
    rdfs:comment 'Annual payment amount received from the administering agency for participation in the conservation program, expressed in USD. For rental programs (CRP), this represents the annual rental rate per acre multiplied by enrolled acres. For cost-share programs (EQIP, CSP), this represents the annual incentive or cost-share payment. Critical for farm financial planning and government program revenue tracking.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationPriorityArea rdf:type rdf:Property ;
    rdfs:label 'Conservation Priority Area' ;
    rdfs:comment 'Designation of the enrolled land within a USDA-identified conservation priority area (e.g., National Water Quality Initiative (NWQI) watershed, Migratory Bird Habitat Initiative area, Sage Grouse Initiative area). Priority area enrollment may qualify for enhanced payment rates or additional program benefits.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleAcres rdf:type rdf:Property ;
    rdfs:label 'Eligible Acres' ;
    rdfs:comment 'Total acres on the field or parcel that were determined eligible for the conservation program during the agency eligibility determination process. May differ from enrolled_acres if the producer chose to enroll only a portion of eligible land.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-assigned program enrollment or contract number issued by the administering agency (e.g., USDA FSA contract number, NRCS agreement number). Used for cross-referencing with agency records and correspondence.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalBenefitIndex rdf:type rdf:Property ;
    rdfs:label 'Environmental Benefit Index' ;
    rdfs:comment 'The Environmental Benefit Index (EBI) score assigned to this CRP enrollment during the competitive signup ranking process. The EBI is a composite score used by USDA FSA to rank and select CRP offers based on environmental benefits including wildlife habitat, water quality, air quality, and soil erosion reduction. Higher scores indicate greater environmental benefit.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farmNumber rdf:type rdf:Property ;
    rdfs:label 'Farm Number' ;
    rdfs:comment 'USDA Farm Service Agency (FSA) assigned farm number for the operation associated with this enrollment. The FSA farm number is the primary identifier used by USDA agencies to track farm-level program participation and payment eligibility.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrganicTransition rdf:type rdf:Property ;
    rdfs:label 'Is Organic Transition' ;
    rdfs:comment 'Indicates whether this conservation program enrollment is associated with an organic transition initiative, qualifying the enrolled land for organic transition incentive payments or practices under programs such as EQIP Organic Initiative. True if the enrollment supports certified organic or transitioning-to-organic operations.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWetlandReserve rdf:type rdf:Property ;
    rdfs:label 'Is Wetland Reserve' ;
    rdfs:comment 'Indicates whether the enrolled land is designated as a wetland reserve easement under USDA programs such as the Agricultural Conservation Easement Program (ACEP) Wetland Reserve Easement (WRE) component. Wetland reserve designations carry permanent or 30-year easement restrictions on land use.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next compliance review or agency inspection of the enrolled field. Supports proactive compliance management and preparation for agency visits.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentRatePerAcre rdf:type rdf:Property ;
    rdfs:label 'Payment Rate Per Acre' ;
    rdfs:comment 'The per-acre payment rate established for this enrollment, expressed in USD per acre. Used to calculate total annual payments and to compare program economics across fields and enrollment periods. For CRP, this is the county-established rental rate.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practiceDescription rdf:type rdf:Property ;
    rdfs:label 'Practice Description' ;
    rdfs:comment 'Human-readable description of the primary conservation practice associated with this enrollment. Provides context for the practice_code and documents the specific conservation activity being implemented (e.g., establishment of native grass cover, installation of riparian buffer strips, implementation of nutrient management plan).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Practice Implementation Date' ;
    rdfs:comment 'Actual date on which the conservation practice was fully implemented on the enrolled field. Compared against practice_implementation_deadline to assess timeliness of compliance. Null if practice has not yet been implemented.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:practiceImplementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Practice Implementation Deadline' ;
    rdfs:comment 'The contractually required deadline by which the enrolled conservation practice must be fully implemented on the enrolled field. Missing this deadline may result in compliance violations, payment withholding, or contract termination.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programContactEmail rdf:type rdf:Property ;
    rdfs:label 'Program Contact Email' ;
    rdfs:comment 'Email address of the primary agency contact person for this conservation program enrollment. Used for electronic correspondence regarding compliance reviews, payment notifications, and program updates.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContactName rdf:type rdf:Property ;
    rdfs:label 'Program Contact Name' ;
    rdfs:comment 'Full name of the primary agency contact person (e.g., NRCS district conservationist, FSA county office representative) responsible for managing this enrollment. Used for correspondence and compliance inquiries.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContactPhone rdf:type rdf:Property ;
    rdfs:label 'Program Contact Phone' ;
    rdfs:comment 'Phone number of the primary agency contact person for this conservation program enrollment. Used for direct communication regarding compliance, payments, and program updates.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signupNumber rdf:type rdf:Property ;
    rdfs:label 'Signup Number' ;
    rdfs:comment 'The specific program signup or enrollment period number under which this enrollment was accepted (e.g., CRP Signup 62). USDA programs are offered in discrete signup periods; this field identifies which signup cohort this enrollment belongs to for program administration and reporting.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total expected payment value over the full term of the conservation program enrollment contract, expressed in USD. Calculated as annual_payment_amount multiplied by contract duration years. Used for long-term financial planning, CAPEX/OPEX analysis, and government program revenue forecasting.' ;
    rdfs:domain ind:ConservationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedBy rdf:type rdf:Property ;
    rdfs:label 'Assessed By' ;
    rdfs:comment 'Name of the individual, internal team, or third-party organization that conducted the deforestation risk assessment. Supports accountability and audit trail requirements under EUDR due diligence obligations.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdpForestsDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Forests Disclosure Flag' ;
    rdfs:comment 'Indicates whether this deforestation risk assessment data has been included in the organization\'s CDP Forests disclosure submission. Supports voluntary environmental reporting and investor transparency.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentForestCoverPct rdf:type rdf:Property ;
    rdfs:label 'Current Forest Cover Pct' ;
    rdfs:comment 'Percentage of the assessed area currently classified as forest at the time of assessment, derived from the most recent satellite imagery or remote sensing analysis. Compared against baseline to quantify deforestation.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDiligenceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Due Diligence System Ref' ;
    rdfs:comment 'Reference identifier or URL to the operator\'s due diligence system record associated with this assessment, as required under EUDR Article 8. Links the risk assessment to the formal due diligence statement submitted to EU authorities.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudrComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Eudr Compliance Status' ;
    rdfs:comment 'Compliance determination for this assessment under the EU Deforestation Regulation (EUDR) 2023/1115. Indicates whether the sourcing geography meets EUDR deforestation-free requirements as of the cutoff date.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudrCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Eudr Cutoff Date' ;
    rdfs:comment 'The EUDR reference cutoff date (31 December 2020 per regulation) before which land must have been free of deforestation for commodities to be considered compliant. Stored per assessment to accommodate future regulatory amendments.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forestCoverBaselinePct rdf:type rdf:Property ;
    rdfs:label 'Forest Cover Baseline Pct' ;
    rdfs:comment 'Percentage of the assessed area classified as forest in the baseline year, derived from Global Forest Watch or equivalent remote sensing data. Provides the reference point for measuring deforestation change.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forestCoverBaselineYear rdf:type rdf:Property ;
    rdfs:label 'Forest Cover Baseline Year' ;
    rdfs:comment 'The reference year used to establish the forest cover baseline for deforestation change detection. Typically aligned with EUDR cutoff year (2020) or the assessment methodology\'s reference period.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The spatial granularity at which this deforestation risk assessment applies — individual farm, aggregated supply shed, administrative region, or country level. Determines the resolution of risk classification and due diligence obligations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gladAlertCount rdf:type rdf:Property ;
    rdfs:label 'Glad Alert Count' ;
    rdfs:comment 'Number of Global Land Analysis and Discovery (GLAD) deforestation alerts detected within the assessed area during the monitoring period. High alert counts indicate active deforestation activity and elevate risk classification.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gladAlertPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Glad Alert Period End' ;
    rdfs:comment 'End date of the monitoring period over which GLAD deforestation alerts were counted. Together with the start date, defines the temporal window for alert aggregation.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gladAlertPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Glad Alert Period Start' ;
    rdfs:comment 'Start date of the monitoring period over which GLAD deforestation alerts were counted. Defines the temporal window for alert aggregation used in risk scoring.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:landUseChangeType rdf:type rdf:Property ;
    rdfs:label 'Land Use Change Type' ;
    rdfs:comment 'Classification of the detected or potential land use change within the assessed area. Distinguishes between outright deforestation, forest degradation, and conversion of other natural ecosystems as defined under EUDR.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the sub-national administrative region, state, province, or biome zone covered by this assessment. Supports granular risk mapping and supply chain traceability below country level.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanRef rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Ref' ;
    rdfs:comment 'Reference identifier for the remediation plan document or action plan associated with this deforestation risk assessment. Links to the formal corrective action record in the sustainability management system.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Required' ;
    rdfs:comment 'Indicates whether a remediation plan is required for this assessment based on identified deforestation risk or non-compliance findings. Triggers remediation workflow and escalation to sustainability team.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target date by which remediation actions must be completed to achieve compliance or risk reduction. Used for tracking remediation progress and escalation management.' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Overall deforestation risk rating assigned to the assessed geography, aligned with EUDR country benchmarking categories and Trase risk tiers. Drives due diligence intensity and sourcing decisions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDataSource rdf:type rdf:Property ;
    rdfs:label 'Risk Data Source' ;
    rdfs:comment 'Primary data source or methodology used to derive the deforestation risk classification. Supports data lineage, auditability, and confidence assessment of the risk rating. [ENUM-REF-CANDIDATE: global_forest_watch|trase|eudr_benchmarking|satellite_imagery|third_party_audit|self_assessment — promote to reference product]' ;
    rdfs:domain ind:DeforestationRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope3CategoryId rdf:type rdf:Property ;
    rdfs:label 'Scope3 Category Id' ;
    rdfs:comment 'Foreign key linking to sustainability.scope3_category. Business justification: Emission factors for Scope 3 emissions are often category-specific (e.g., purchased goods, transportation, waste). This FK links emission factors to the Scope 3 category they apply to, enabling catego' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scope3Category .

ind:supersededByEmissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Emission Factor Id' ;
    rdfs:comment 'Reference to the emission_factor_id of the newer record that replaces this factor when factor_status is \'superseded\'. Enables forward navigation of the factor version chain for data lineage and recalculation workflows.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionFactor .

ind:activityDataUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Data Unit' ;
    rdfs:comment 'Unit of measure for the activity data input to which this factor is applied (e.g., \'kg N\', \'head\', \'litre\', \'hectare\', \'MT dry matter\', \'kWh\'). Ensures dimensional consistency in emission calculations across crop and livestock operations.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Specific agricultural activity generating the emission (e.g., \'Enteric Fermentation\', \'Manure Management\', \'Synthetic Fertilizer Application\', \'Crop Residue Burning\', \'Fuel Combustion - Field Operations\', \'Irrigation Pumping\'). Enables granular emission attribution across farm operations.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Applicability Notes' ;
    rdfs:comment 'Free-text notes describing specific conditions, constraints, or assumptions under which this emission factor is applicable (e.g., \'Applicable only to irrigated rice paddies\', \'Valid for temperate climate zones with annual precipitation >500mm\'). Guides correct factor selection by sustainability analysts.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Description of the calculation methodology or equation used to derive this emission factor (e.g., \'IPCC 2006 Equation 10.19 - Enteric Fermentation\', \'EPA Method 19 - Stationary Combustion\', \'USDA COMET-Farm Soil Carbon Model\'). Supports methodological transparency in ESG and regulatory disclosures.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonSequestrationFactor rdf:type rdf:Property ;
    rdfs:label 'Carbon Sequestration Factor' ;
    rdfs:comment 'Soil carbon sequestration or removal factor value (negative emission coefficient) applicable to practices such as cover cropping, no-till, or agroforestry. Expressed in the same units as factor_unit. Null for non-sequestration factors. Supports soil carbon credit calculations.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying this emission factor record, used for cross-system referencing and integration with FMIS, SAP CO, and EPA/IPCC reporting tools.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Human-readable descriptive name of the emission factor (e.g., \'Enteric Fermentation - Dairy Cattle\', \'Synthetic Nitrogen Fertilizer Application - Direct N2O\'). Used in reports, dashboards, and ESG disclosures.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorStatus rdf:type rdf:Property ;
    rdfs:label 'Factor Status' ;
    rdfs:comment 'Current lifecycle status of the emission factor record. \'active\' factors are used in live calculations; \'superseded\' factors are retained for historical recalculation; \'draft\' factors are pending validation; \'retired\' factors are no longer applicable.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorUnit rdf:type rdf:Property ;
    rdfs:label 'Factor Unit' ;
    rdfs:comment 'Unit of measure for the emission factor value, expressed as a ratio of emission quantity to activity quantity (e.g., \'kg CO2e/kg N applied\', \'kg CH4/head/year\', \'kg CO2/litre diesel\', \'MT CO2e/MT crop residue\'). Must be consistent with the activity_data_unit for calculation integrity.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorValue rdf:type rdf:Property ;
    rdfs:label 'Factor Value' ;
    rdfs:comment 'The numeric emission coefficient representing the quantity of GHG emitted per unit of activity data (e.g., 0.01 kg N2O-N per kg N applied). This is the principal quantitative fact of the reference record.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gasType rdf:type rdf:Property ;
    rdfs:label 'Gas Type' ;
    rdfs:comment 'The specific greenhouse gas species this factor applies to, aligned with IPCC and Kyoto Protocol gas classifications (e.g., CO2, CH4, N2O, CO2e for aggregated factors). [ENUM-REF-CANDIDATE: CO2|CH4|N2O|HFCs|PFCs|SF6|NF3|CO2e — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwpAssessmentReport rdf:type rdf:Property ;
    rdfs:label 'Gwp Assessment Report' ;
    rdfs:comment 'IPCC Assessment Report version from which the GWP value is sourced (AR4, AR5, or AR6). Different regulatory frameworks mandate different AR versions; this field enables multi-standard compliance reporting.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwpValue rdf:type rdf:Property ;
    rdfs:label 'Gwp Value' ;
    rdfs:comment 'Global Warming Potential (GWP) multiplier used to convert the gas-specific emission to CO2-equivalent (CO2e) over a 100-year time horizon (e.g., CH4=28, N2O=265 per IPCC AR5). Required for aggregated ESG and regulatory reporting.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipccTier rdf:type rdf:Property ;
    rdfs:label 'Ipcc Tier' ;
    rdfs:comment 'IPCC methodological tier level indicating the sophistication and data intensity of the emission estimation approach. Tier 1 uses default factors; Tier 2 uses country-specific factors; Tier 3 uses facility-level measurement or modeling. Higher tiers yield more accurate estimates.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBiogenic rdf:type rdf:Property ;
    rdfs:label 'Is Biogenic' ;
    rdfs:comment 'Indicates whether the emission represented by this factor is biogenic in origin (e.g., CO2 from crop residue decomposition, CH4 from enteric fermentation). Biogenic emissions are often reported separately from fossil-fuel emissions in ESG and ISCC sustainability frameworks.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultFactor rdf:type rdf:Property ;
    rdfs:label 'Is Default Factor' ;
    rdfs:comment 'Indicates whether this is the default (recommended) emission factor to use when no more specific Tier 2 or Tier 3 factor is available for the given source category, country, and gas type combination. True = default factor; False = supplementary or country-specific factor.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livestockCategory rdf:type rdf:Property ;
    rdfs:label 'Livestock Category' ;
    rdfs:comment 'Livestock species or category to which this factor applies for animal husbandry emission calculations (e.g., \'Dairy Cattle\', \'Non-Dairy Cattle\', \'Swine\', \'Poultry - Layers\', \'Sheep\', \'Goats\'). Null for non-livestock factors. [ENUM-REF-CANDIDATE: promote to reference product for full livestock taxonomy]' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manureManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Manure Management System' ;
    rdfs:comment 'Type of manure management system to which this factor applies (e.g., \'Anaerobic Lagoon\', \'Solid Storage\', \'Dry Lot\', \'Pasture/Range/Paddock\', \'Anaerobic Digester\'). Null for non-manure factors. [ENUM-REF-CANDIDATE: promote to reference product for full manure system taxonomy]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCategory rdf:type rdf:Property ;
    rdfs:label 'Scope Category' ;
    rdfs:comment 'GHG Protocol scope classification indicating whether the emission is direct (Scope 1), indirect from purchased energy (Scope 2), or value chain indirect (Scope 3). Required for corporate ESG and CDP reporting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilDrainageType rdf:type rdf:Property ;
    rdfs:label 'Soil Drainage Type' ;
    rdfs:comment 'Soil drainage classification relevant to N2O and CH4 emission factors for managed soils (Well-drained, Poorly-drained, Flooded, Organic). Applicable to soil-based emission factors per IPCC Tier 1 methodology.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'IPCC Activity Data source category classifying the emission source (e.g., \'3A1 - Enteric Fermentation\', \'3C4 - Direct N2O Emissions from Managed Soils\', \'1A2 - Manufacturing Industries and Construction\'). Drives categorization in national GHG inventories and ESG reports. [ENUM-REF-CANDIDATE: promote to reference product for full IPCC category taxonomy]' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Specific citation or document reference for the source publication (e.g., \'IPCC 2006 Vol.4 Table 10.11\', \'EPA AP-42 Table 2.4-2\', \'USDA 2023 Ag GHG Inventory Table A-180\'). Enables direct traceability to the authoritative source for audit and regulatory review.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePublicationYear rdf:type rdf:Property ;
    rdfs:label 'Source Publication Year' ;
    rdfs:comment 'Calendar year in which the source document or dataset was published. Used to assess factor currency and to manage periodic updates as new IPCC or EPA guidance is released.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uncertaintyHighPct rdf:type rdf:Property ;
    rdfs:label 'Uncertainty High Pct' ;
    rdfs:comment 'Upper bound of the uncertainty range for this emission factor expressed as a percentage of the central factor_value (e.g., +30 for ±30% uncertainty). Required for Monte Carlo uncertainty analysis and IPCC-compliant inventory reporting.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uncertaintyLowPct rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Low Pct' ;
    rdfs:comment 'Lower bound of the uncertainty range for this emission factor expressed as a percentage of the central factor_value (e.g., -30 for ±30% uncertainty). Required for Monte Carlo uncertainty analysis and IPCC-compliant inventory reporting.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each energy consumption transaction record in the agricultural enterprise. Primary key for the energy_consumption data product.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Consumption End Date' ;
    rdfs:comment 'End date of the energy consumption measurement period (e.g., billing cycle end, shift end, or reporting interval end). Paired with consumption_start_date to define the measurement window.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionGj rdf:type rdf:Property ;
    rdfs:label 'Consumption Gj' ;
    rdfs:comment 'Energy consumption quantity normalized to gigajoules (GJ) for cross-source comparability and GRI 302 mandatory reporting. Derived from consumption_quantity using source-specific conversion factors but stored as a business field for reporting integrity.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumption Quantity' ;
    rdfs:comment 'Measured quantity of energy consumed during the reporting period, expressed in the unit defined by consumption_unit. This is the principal quantitative fact for this transaction record.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consumption Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this energy consumption record, typically derived from the utility invoice number, meter reading reference, or SAP PM/FI document number. Used for cross-system reconciliation.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Consumption Start Date' ;
    rdfs:comment 'Start date of the energy consumption measurement period (e.g., billing cycle start, shift start, or reporting interval start). Used to align consumption data with GHG reporting periods.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionUnit rdf:type rdf:Property ;
    rdfs:label 'Consumption Unit' ;
    rdfs:comment 'Unit of measure for the consumption_quantity field. Standardized to SI or industry-accepted units to enable cross-facility and cross-source aggregation for GRI 302 and CDP reporting. [ENUM-REF-CANDIDATE: GJ|MWh|kWh|liters|m3|kg|MMBtu — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Assessment of the data quality for this consumption record based on measurement method, completeness, and source reliability. High = metered/invoiced; Medium = calculated; Low = estimated. Required for GHG verification and CDP disclosure.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Greenhouse gas emission factor applied to this energy source and consumption period, expressed in kg CO2e per unit of energy (e.g., kg CO2e per GJ or per kWh). Source-specific and period-specific to reflect grid decarbonization over time.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Source' ;
    rdfs:comment 'Identifies the authoritative source of the emission factor used for GHG calculation. Required for GHG Protocol verification and CDP disclosure to demonstrate data quality and methodology transparency.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyCost rdf:type rdf:Property ;
    rdfs:label 'Energy Cost' ;
    rdfs:comment 'Total monetary cost of energy consumed during the reporting period as billed by the supplier or allocated internally, in the currency defined by currency_code. Supports OPEX tracking and energy cost per unit analysis.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyIntensityGjPerMt rdf:type rdf:Property ;
    rdfs:label 'Energy Intensity Gj Per Mt' ;
    rdfs:comment 'Energy intensity ratio expressed as gigajoules consumed per metric ton of agricultural or processed output produced during the consumption period. Key KPI for operational efficiency benchmarking and GRI 302-3 intensity reporting.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySourceType rdf:type rdf:Property ;
    rdfs:label 'Energy Source Type' ;
    rdfs:comment 'Classification of the energy source consumed. Determines GHG emission factor applicability and renewable vs. non-renewable categorization for Scope 1/Scope 2 accounting. [ENUM-REF-CANDIDATE: diesel|natural_gas|lpg|grid_electricity|solar|wind|biogas|biomass|propane|coal|geothermal|hydro — promote to reference product]' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Co2e Mt' ;
    rdfs:comment 'Calculated greenhouse gas emissions in metric tons of CO2 equivalent (CO2e) attributable to this energy consumption record. Computed as consumption_gj multiplied by emission_factor. Feeds into Scope 1 or Scope 2 totals in the carbon_footprint product.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgScope rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope' ;
    rdfs:comment 'GHG Protocol scope classification for this energy consumption record. Scope 1 covers direct combustion (diesel, natural gas, LPG, biogas on-site). Scope 2 location-based uses grid average emission factors; Scope 2 market-based uses contractual instruments (RECs, PPAs) per RE100 and GHG Protocol Scope 2 Guidance.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReference rdf:type rdf:Property ;
    rdfs:label 'Meter Reference' ;
    rdfs:comment 'Identifier of the physical utility meter or sub-meter from which the consumption reading was obtained. Enables traceability back to the metering device for audit and verification purposes.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputQuantityMt rdf:type rdf:Property ;
    rdfs:label 'Output Quantity Mt' ;
    rdfs:comment 'Volume of agricultural or processed output (in metric tons) produced during the consumption period at the associated facility. Used as the denominator for energy intensity calculations per GRI 302-3.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppaContractReference rdf:type rdf:Property ;
    rdfs:label 'Ppa Contract Reference' ;
    rdfs:comment 'Reference number of the Power Purchase Agreement (PPA) or green tariff contract associated with this electricity consumption record. Supports Scope 2 market-based accounting and RE100 contractual instrument documentation.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Rec Certificate Number' ;
    rdfs:comment 'Certificate number of the Renewable Energy Certificate (REC) or Guarantee of Origin (GO) linked to this consumption record. Required for GHG Protocol Scope 2 market-based accounting and RE100 compliance reporting.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recRegistry rdf:type rdf:Property ;
    rdfs:label 'Rec Registry' ;
    rdfs:comment 'Name of the REC registry or tracking system where the renewable energy certificate is registered. Validates the authenticity and non-double-counting of renewable energy claims for Scope 2 market-based reporting. [ENUM-REF-CANDIDATE: WREGIS|M-RETS|NEPOOL_GIS|ERCOT|TIGR|GO_Europe|I-REC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Flag' ;
    rdfs:comment 'Indicates whether the energy source is classified as renewable (True) or non-renewable (False) per RE100 and GHG Protocol definitions. Drives renewable energy percentage calculations for ESG reporting.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewablePct rdf:type rdf:Property ;
    rdfs:label 'Renewable Pct' ;
    rdfs:comment 'Percentage of the consumed energy quantity that is sourced from renewable sources (0.00–100.00). Applicable for mixed-source supply points such as grid electricity with partial renewable content. Supports RE100 progress tracking.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the utility or energy supplier providing the energy for this consumption record. Required for Scope 2 market-based accounting to identify contractual instruments and supplier-specific emission factors.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Utility tariff or rate schedule code applicable to this consumption record. Used for energy cost allocation and to identify time-of-use pricing structures relevant to demand management.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEnvironmentalReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Environmental Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who first reported or logged the environmental incident. Provides accountability trail and supports workforce compliance training analysis via SAP SuccessFactors.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:estimatedQuantityReleased rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity Released' ;
    rdfs:comment 'Estimated volume or mass of substance released or impacted during the incident. Used to assess regulatory reporting thresholds (e.g., CERCLA reportable quantities) and remediation scope.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gri307Category rdf:type rdf:Property ;
    rdfs:label 'Gri 307 Category' ;
    rdfs:comment 'Classification of the incident under GRI Standard 307 (Environmental Compliance) for ESG reporting purposes. Indicates whether the incident resulted in a significant spill, fine, sanction, or warning per GRI disclosure requirements.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate containment and response actions taken at the time of the incident (e.g., spill containment, equipment shutdown, evacuation, emergency services contacted). Documents due diligence for regulatory purposes.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The calendar date on which the environmental incident occurred or was first observed. Used as the principal business event date for regulatory reporting timelines and compliance tracking.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the environmental incident, including what happened, conditions at the time, materials or substances involved, and initial observations. Supports root cause analysis and regulatory reporting.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDiscoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the incident was first discovered or reported internally. Distinct from incident_date (when it occurred). Critical for calculating regulatory notification deadlines.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the incident at time of creation. Used for regulatory correspondence, internal tracking, and cross-system reference (e.g., SAP QM notification number). Format: ENV-YYYY-NNNNNN.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the environmental incident record. Drives workflow routing, reporting obligations, and closure eligibility. [ENUM-REF-CANDIDATE: open|under_investigation|remediation_in_progress|pending_closure|closed|regulatory_review — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the environmental incident by its primary nature. Drives regulatory notification requirements and response protocols. [ENUM-REF-CANDIDATE: chemical_spill|nutrient_runoff|air_emission_exceedance|water_discharge_violation|soil_contamination|pesticide_drift — promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaAffected rdf:type rdf:Property ;
    rdfs:label 'Media Affected' ;
    rdfs:comment 'Environmental media impacted by the incident (e.g., soil, surface water, groundwater, air). Determines applicable regulatory frameworks and remediation approach.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Reference Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory authority upon receipt of the incident notification. Provides audit trail for regulatory correspondence.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Amount' ;
    rdfs:comment 'Monetary penalty or fine assessed by the regulatory authority as a result of the incident. Expressed in the currency defined by currency_code. Used for financial reporting, ESG disclosure, and CAPEX/OPEX impact analysis.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Violation Flag' ;
    rdfs:comment 'Indicates whether the incident constitutes a formal regulatory violation (True) or is an internal near-miss or precautionary report (False). Drives mandatory external reporting and legal review workflows.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date on which all remediation activities were completed and verified. Prerequisite for incident closure and regulatory sign-off.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationCost rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost' ;
    rdfs:comment 'Total actual cost incurred for remediation activities related to the incident. Supports OPEX tracking, insurance claims, and ESG financial disclosure.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the formal remediation plan developed to address environmental damage, restore affected areas, and prevent recurrence. May reference a separate remediation project or SOP.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStartDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Start Date' ;
    rdfs:comment 'Date on which formal remediation activities commenced. Used to track remediation timeline compliance and measure response effectiveness.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the environmental incident following investigation (e.g., equipment failure, operator error, extreme weather event, inadequate containment, process deviation). Supports corrective action planning and recurrence prevention.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceInvolved rdf:type rdf:Property ;
    rdfs:label 'Substance Involved' ;
    rdfs:comment 'Name or description of the chemical, nutrient, pesticide, or other substance involved in the incident (e.g., anhydrous ammonia, atrazine, nitrogen fertilizer, diesel fuel). Supports SDS cross-reference and regulatory reporting.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgMetricId rdf:type rdf:Property ;
    rdfs:label 'Esg Metric Id' ;
    rdfs:comment 'Unique system-generated identifier for each ESG performance metric record. Primary key for the esg_metric data product in the sustainability domain.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgScopeId rdf:type rdf:Property ;
    rdfs:label 'Org Scope Id' ;
    rdfs:comment 'Identifier of the specific organizational unit (enterprise, region, farm unit, facility, or field) for which this metric is reported. Links to the corresponding organizational entity in the master data hierarchy.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganizationalScope .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'The level of third-party assurance or verification obtained for this metric: None (unverified), Limited (limited assurance engagement), Reasonable (reasonable assurance engagement), Certified (full certification e.g., GLOBALG.A.P., SQF, organic). Required for credible ESG disclosure.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Assurance Provider' ;
    rdfs:comment 'Name of the third-party organization that provided assurance or verification for this metric (e.g., \'Deloitte\', \'Bureau Veritas\', \'SGS\', \'GLOBALG.A.P. Certification Body\'). Null if no external assurance was obtained.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The reference baseline value for this metric against which progress is measured (e.g., 2019 baseline Scope 1 emissions for net-zero trajectory). Null if no formal baseline has been established.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureCode rdf:type rdf:Property ;
    rdfs:label 'Disclosure Code' ;
    rdfs:comment 'The specific framework disclosure code or indicator reference for this metric (e.g., GRI 305-1 for Scope 1 emissions, SASB FB-AG-110a.1 for water quantity, GHG Protocol Scope 2). Enables precise mapping to regulatory and voluntary reporting requirements.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorUsed rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Used' ;
    rdfs:comment 'The emission conversion factor applied to calculate GHG metric values (e.g., kg CO2e per kWh of electricity consumed, or kg CO2e per liter of diesel). Null for non-GHG metrics. Required for audit trail and methodology transparency.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgPillar rdf:type rdf:Property ;
    rdfs:label 'Esg Pillar' ;
    rdfs:comment 'The primary ESG pillar this metric belongs to: Environmental (emissions, water, land, biodiversity), Social (labor, safety, community), or Governance (ethics, compliance, board oversight).' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRestatement rdf:type rdf:Property ;
    rdfs:label 'Is Restatement' ;
    rdfs:comment 'Indicates whether this record represents a restatement of a previously reported ESG metric value (True = restatement, False = original submission). Restatements occur due to methodology changes, data corrections, or boundary adjustments.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Sub-category within the ESG pillar classifying the metric topic (e.g., Greenhouse Gas Emissions, Water Stewardship, Soil Health, Biodiversity, Labor Practices, Food Safety, Supply Chain). [ENUM-REF-CANDIDATE: Greenhouse Gas Emissions|Water Stewardship|Soil Health|Biodiversity|Labor Practices|Food Safety|Supply Chain|Energy|Waste|Community — promote to reference product]' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCode rdf:type rdf:Property ;
    rdfs:label 'Metric Code' ;
    rdfs:comment 'Externally-known unique business code identifying the specific ESG metric definition (e.g., GHG-SCOPE1-MT, WATER-WITHDRAWAL-M3, SOIL-CARBON-PCT). Used as the stable business identifier across reporting periods and frameworks.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Human-readable name of the ESG performance metric (e.g., \'Scope 1 Greenhouse Gas Emissions\', \'Total Water Withdrawal\', \'Soil Organic Carbon Percentage\'). Used in ESG reports and dashboards.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricStatus rdf:type rdf:Property ;
    rdfs:label 'Metric Status' ;
    rdfs:comment 'Current lifecycle status of this ESG metric record within the reporting workflow: Draft (data entry in progress), Submitted (submitted for review), Under Review (being verified), Approved (internally approved), Published (included in public ESG report), Restated (corrected restatement), Withdrawn (removed from reporting). [ENUM-REF-CANDIDATE: Draft|Submitted|Under Review|Approved|Published|Restated|Withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'The quantitative measured or calculated value of the ESG metric for the reporting period and organizational scope (e.g., 12500.500000 metric tons CO2e for Scope 1 emissions, 85000.000000 cubic meters for water withdrawal). The principal quantitative fact of this record.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgScopeLevel rdf:type rdf:Property ;
    rdfs:label 'Org Scope Level' ;
    rdfs:comment 'The organizational boundary at which this metric is reported: Enterprise (consolidated), Region, Farm Unit (individual farm operation), Facility (processing/storage), or Field (individual crop field). Enables hierarchical ESG roll-up reporting.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgScopeName rdf:type rdf:Property ;
    rdfs:label 'Org Scope Name' ;
    rdfs:comment 'Human-readable name of the organizational unit for which this metric is reported (e.g., \'North America Operations\', \'Corn Belt Farm Unit 12\', \'Grain Processing Facility - Iowa\'). Supports reporting without requiring a join.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'The ESG metric value from the immediately preceding comparable reporting period, included for year-over-year or period-over-period comparison in ESG disclosures. Null if no prior period data exists or if this is the baseline year.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'The mandatory regulatory program or rule requiring disclosure of this metric (e.g., \'EPA GHG Mandatory Reporting Rule 40 CFR Part 98\', \'FSMA Produce Safety Rule\', \'SEC Climate Disclosure Rule\', \'EU CSRD\'). Null if the metric is voluntary only.' ;
    rdfs:domain ind:EsgMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'The sustainability reporting framework or standard under which this metric is disclosed (e.g., GRI, SASB, TCFD, IFRS S1/S2, CDP, GHG Protocol). Determines the disclosure methodology and calculation approach.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The temporal granularity of the reporting period (Annual, Semi-Annual, Quarterly, Monthly, Crop Season, Custom). Determines aggregation and comparison logic in ESG dashboards.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Explanation of why a previously reported ESG metric value was restated (e.g., \'Methodology change to align with GHG Protocol Scope 3 Category 11\', \'Acquisition of new farm units\', \'Data correction from field sensor recalibration\'). Null if is_restatement is False.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time when this ESG metric record was submitted for review or external disclosure. Captures the principal business event time for the reporting workflow lifecycle.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The committed or aspirational target value for this ESG metric for the reporting period, as set in the enterprise sustainability strategy or science-based targets (e.g., SBTi net-zero commitments). Used to measure performance against ESG goals.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assuranceStandard rdf:type rdf:Property ;
    rdfs:label 'Assurance Standard' ;
    rdfs:comment 'The professional assurance standard applied by the assurance provider when verifying ESG disclosures (e.g., ISAE 3000 for general sustainability, ISAE 3410 for greenhouse gas statements).' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityAssessmentRef rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Assessment Ref' ;
    rdfs:comment 'Reference identifier or document code for the biodiversity impact assessment conducted for the reporting period. Supports GRI 304 (Biodiversity) disclosures and TNFD (Taskforce on Nature-related Financial Disclosures) alignment.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date on which the Board of Directors or designated governance committee formally approved the ESG report for publication. Null if board approval has not yet been obtained.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardApproved rdf:type rdf:Property ;
    rdfs:label 'Board Approved' ;
    rdfs:comment 'Indicates whether the ESG report has received formal approval from the enterprise\'s Board of Directors or designated governance committee prior to publication. Required for SOX compliance and CSRD governance disclosures.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Esg Rating Agency' ;
    rdfs:comment 'Name of the external organization that assigned the ESG rating score for this reporting period (e.g., MSCI, Sustainalytics, CDP, EcoVadis). Provides context for interpreting the rating score.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRatingScore rdf:type rdf:Property ;
    rdfs:label 'Esg Rating Score' ;
    rdfs:comment 'Composite ESG rating score assigned by a recognized external ESG rating agency (e.g., MSCI, Sustainalytics, CDP) for the reporting period. Supports investor relations and benchmarking against industry peers.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction' ;
    rdfs:comment 'Regulatory jurisdiction(s) under which this ESG report is filed (e.g., \'USA\', \'EU\', \'GBR\'). Uses ISO 3166-1 alpha-3 country codes. Supports multi-jurisdictional compliance tracking for global agricultural operations.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyIncidents rdf:type rdf:Property ;
    rdfs:label 'Food Safety Incidents' ;
    rdfs:comment 'Total number of reportable food safety incidents (recalls, contamination events, HACCP critical control point failures) recorded during the reporting period. Key social/governance KPI per FSMA and GFSI requirements.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ghgScope1EmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope1 Emissions Mt' ;
    rdfs:comment 'Total direct greenhouse gas emissions from sources owned or controlled by the agricultural enterprise (e.g., on-farm fuel combustion, livestock enteric fermentation, manure management) reported in metric tons of CO2 equivalent for the reporting period.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgScope2EmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope2 Emissions Mt' ;
    rdfs:comment 'Total indirect greenhouse gas emissions from purchased electricity, steam, heat, or cooling consumed by the agricultural enterprise, reported in metric tons of CO2 equivalent for the reporting period.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgScope3EmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope3 Emissions Mt' ;
    rdfs:comment 'Total value chain greenhouse gas emissions not directly owned or controlled by the enterprise (e.g., purchased goods, transportation, use of sold products, land use change), reported in metric tons of CO2 equivalent for the reporting period.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiSummary rdf:type rdf:Property ;
    rdfs:label 'Kpi Summary' ;
    rdfs:comment 'Structured summary or reference list of the key ESG performance indicators included in this report (e.g., \'GHG Scope 1-3, Water Intensity, TRIR, Food Safety Incidents, Biodiversity Score\'). Supports report navigation and stakeholder communication.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landAreaCertifiedHa rdf:type rdf:Property ;
    rdfs:label 'Land Area Certified Ha' ;
    rdfs:comment 'Total land area (in hectares) under active sustainability or organic certification (e.g., GLOBALG.A.P., USDA Organic NOP, ISCC, Rainforest Alliance) as of the reporting period end date.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialityAssessmentRef rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment Ref' ;
    rdfs:comment 'Reference identifier or document code for the materiality assessment that underpins the ESG report\'s topic selection and disclosure scope. Links to the formal double-materiality or impact-materiality analysis per GRI or CSRD requirements.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netZeroTargetYear rdf:type rdf:Property ;
    rdfs:label 'Net Zero Target Year' ;
    rdfs:comment 'Calendar year by which the agricultural enterprise has committed to achieving net-zero greenhouse gas emissions across its operations and value chain. Supports TCFD climate target disclosure and SBTi (Science Based Targets initiative) alignment.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date on which the ESG report was formally submitted to the applicable regulatory authority (e.g., SEC EDGAR filing date, CSRD submission date). Null if not yet filed or not required.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Status' ;
    rdfs:comment 'Current status of the ESG report\'s submission to applicable regulatory bodies (e.g., SEC, CSRD-mandated EU filing, USDA program reporting). Tracks whether the report has been filed, accepted, or requires resubmission.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyPct rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Pct' ;
    rdfs:comment 'Percentage of total energy consumed by the agricultural enterprise sourced from renewable sources (solar, wind, biogas, hydroelectric) during the reporting period. Key KPI for energy transition and net-zero commitments.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportCode rdf:type rdf:Property ;
    rdfs:label 'Report Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the ESG report for cross-system reference, regulatory filing tracking, and document management (e.g., ESG-2024-ANN01).' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Report Document Ref' ;
    rdfs:comment 'Internal document management system reference or file path for the official ESG report document (PDF or equivalent). Supports document version control and audit trail in the enterprise content management system.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the ESG report from initial drafting through publication and regulatory filing. Controls workflow approvals and disclosure governance. [ENUM-REF-CANDIDATE: draft|under_review|approved|published|filed|withdrawn — promote to reference product]' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'Official published title of the ESG disclosure report as it appears on the cover page and regulatory filings (e.g., \'FY2024 Sustainability and ESG Report\').' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the ESG report by publication cadence and scope. Annual reports cover a full fiscal year; integrated reports combine financial and sustainability disclosures; standalone reports are dedicated sustainability publications.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Publicly accessible URL where the published ESG report document can be accessed by investors, regulators, and stakeholders. Supports digital disclosure governance and audit trail.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingBoundary rdf:type rdf:Property ;
    rdfs:label 'Reporting Boundary' ;
    rdfs:comment 'Organizational boundary methodology used to determine which entities, operations, and assets are included in the ESG report\'s scope. Aligns with GHG Protocol consolidation approaches (operational control, financial control, equity share).' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryFrameworks rdf:type rdf:Property ;
    rdfs:label 'Secondary Frameworks' ;
    rdfs:comment 'Comma-separated list of additional sustainability frameworks or standards referenced in this report alongside the primary framework (e.g., \'TCFD,CDP,ISO_14001\'). Supports multi-framework alignment disclosures.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilCarbonSequestrationMt rdf:type rdf:Property ;
    rdfs:label 'Soil Carbon Sequestration Mt' ;
    rdfs:comment 'Estimated total carbon sequestered in agricultural soils through regenerative practices (cover cropping, no-till, compost application) during the reporting period, measured in metric tons of CO2 equivalent. Supports carbon credit and net-zero reporting.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterRecycledPct rdf:type rdf:Property ;
    rdfs:label 'Water Recycled Pct' ;
    rdfs:comment 'Percentage of total water used that was recycled or reused within agricultural operations during the reporting period. Supports water stewardship KPI tracking and irrigation efficiency reporting.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterWithdrawalM3 rdf:type rdf:Property ;
    rdfs:label 'Water Withdrawal M3' ;
    rdfs:comment 'Total volume of water withdrawn from all sources (groundwater, surface water, municipal supply) for agricultural operations during the reporting period, measured in cubic meters. Key water stewardship metric per SASB and GRI.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workerSafetyTrir rdf:type rdf:Property ;
    rdfs:label 'Worker Safety Trir' ;
    rdfs:comment 'Total Recordable Incident Rate (TRIR) for the agricultural workforce during the reporting period, calculated as (number of recordable incidents × 200,000) / total hours worked. Key social KPI per OSHA and GRI 403.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgEmissionId rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual greenhouse gas emission record. Primary key for the ghg_emission data product in the sustainability domain.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offsetProjectId rdf:type rdf:Property ;
    rdfs:label 'Offset Project Id' ;
    rdfs:comment 'External identifier of the carbon offset or sequestration project under which this emission record is registered (e.g., Verra VCS project ID, Gold Standard project reference). Null if carbon_credit_eligible is False or no project registration exists. Links to carbon registry records.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonProject .

ind:activityQuantity rdf:type rdf:Property ;
    rdfs:label 'Activity Quantity' ;
    rdfs:comment 'The measured or estimated activity data quantity used as the basis for emission calculation (e.g., liters of diesel consumed, kg of nitrogen fertilizer applied, number of animal head-days, hectares of flooded rice). This is the raw input to the emission factor equation: Emission = Activity Data × Emission Factor.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Unit' ;
    rdfs:comment 'Unit of measure for the activity data quantity (e.g., \'L\' for liters of fuel, \'kg N\' for nitrogen applied, \'head-days\' for livestock, \'ha\' for area, \'kWh\' for electricity). Must align with the denominator of the emission factor applied.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eQuantityMt rdf:type rdf:Property ;
    rdfs:label 'Co2e Quantity Mt' ;
    rdfs:comment 'The emission quantity expressed in metric tons of CO2-equivalent (MT CO2e), calculated as (raw_emission_quantity × gwp_factor) / unit_conversion. This is the primary normalized metric for GHG inventory aggregation, ESG reporting, carbon credit accounting, and Science Based Targets (SBTi) progress tracking.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionDate rdf:type rdf:Property ;
    rdfs:label 'Emission Date' ;
    rdfs:comment 'The calendar date on which the emission event occurred or the start date of the emission period for continuous/periodic sources. Used for temporal aggregation in annual GHG inventories and compliance reporting periods.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionFactorUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Unit' ;
    rdfs:comment 'Unit of measure for the emission factor value, expressing the ratio of gas emitted per unit of activity (e.g., \'kg CH4/head/day\', \'kg N2O-N/kg N\', \'kg CO2/L diesel\', \'kg CO2/kWh\'). Essential for dimensional analysis and calculation audit trails.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorValue rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Value' ;
    rdfs:comment 'The emission factor coefficient applied to convert activity data into raw gas quantity (e.g., kg CH4 per head per day for enteric fermentation, kg N2O-N per kg N applied for synthetic fertilizer). Sourced from IPCC default tables, USDA country-specific factors, or site-measured values depending on IPCC Tier.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Emission Period End Date' ;
    rdfs:comment 'End date of the emission measurement or estimation period for sources that emit continuously over time (e.g., manure storage, enteric fermentation over a livestock housing period). Null for point-in-time emission events. Together with emission_date defines the reporting window.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionSourceName rdf:type rdf:Property ;
    rdfs:label 'Emission Source Name' ;
    rdfs:comment 'Descriptive name or label of the specific emission source within the source type category (e.g., \'Diesel Tractor Fleet - North Fields\', \'Swine Barn 3 - Manure Lagoon\', \'Anhydrous Ammonia Application - Field 12\'). Provides operational context beyond the source type classification.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceType rdf:type rdf:Property ;
    rdfs:label 'Emission Source Type' ;
    rdfs:comment 'Classification of the agricultural emission source category as defined by IPCC Guidelines for National Greenhouse Gas Inventories. Drives selection of appropriate emission factors and IPCC Tier methodology. [ENUM-REF-CANDIDATE: enteric_fermentation|manure_management|synthetic_fertilizer|fuel_combustion|rice_cultivation|land_use_change|biomass_burning|crop_residue|refrigerants|electricity_consumption — promote to reference product]' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionStatus rdf:type rdf:Property ;
    rdfs:label 'Emission Status' ;
    rdfs:comment 'Current workflow status of the emission record within the GHG inventory management process. Draft = initial data entry; Submitted = pending internal review; Verified = third-party verification completed; Approved = included in official GHG inventory; Rejected = excluded due to data quality issues.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelQuantityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Liters' ;
    rdfs:comment 'Volume of fuel consumed in liters for combustion-related emission events. Primary activity data for calculating CO2, CH4, and N2O emissions from mobile and stationary combustion sources on-farm (tractors, combines, irrigation pumps, grain dryers). Null for non-combustion sources.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpFactor rdf:type rdf:Property ;
    rdfs:label 'Gwp Factor' ;
    rdfs:comment 'The Global Warming Potential conversion factor used to convert raw gas quantity to CO2-equivalent (CO2e). Based on IPCC Assessment Report values (e.g., CH4 GWP = 27.9 per AR6 100-year, N2O GWP = 273 per AR6). The specific AR version used should be documented in calculation_methodology.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipccCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Ipcc Category Code' ;
    rdfs:comment 'The IPCC source/sink category code from the 2006 IPCC Guidelines for National GHG Inventories (e.g., \'3.A.1\' for Enteric Fermentation, \'3.D.1.1\' for Direct N2O from Synthetic Fertilizers, \'1.A.4.c\' for Mobile Combustion in Agriculture). Enables standardized national inventory reporting and cross-country benchmarking.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landAreaHa rdf:type rdf:Property ;
    rdfs:label 'Land Area Ha' ;
    rdfs:comment 'Area of land in hectares associated with the emission event, applicable for area-based emission sources such as rice cultivation, land use change, crop residue burning, and soil N2O emissions. Used as activity data denominator for per-hectare emission intensity calculations.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livestockHeadCount rdf:type rdf:Property ;
    rdfs:label 'Livestock Head Count' ;
    rdfs:comment 'Number of animal head associated with the emission event for livestock-related sources (enteric fermentation, manure management). Used as the primary activity data input for IPCC livestock emission calculations. Null for non-livestock sources.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:livestockSpecies rdf:type rdf:Property ;
    rdfs:label 'Livestock Species' ;
    rdfs:comment 'Species of livestock associated with the emission event, applicable for enteric fermentation and manure management source types (e.g., \'Dairy Cattle\', \'Beef Cattle\', \'Swine\', \'Poultry - Broilers\', \'Sheep\', \'Goats\'). Null for non-livestock emission sources. Required for IPCC Tier 2 livestock emission calculations. [ENUM-REF-CANDIDATE: dairy_cattle|beef_cattle|swine|poultry_broilers|poultry_layers|sheep|goats|horses|buffalo — promote to reference product]' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenAppliedKg rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Applied Kg' ;
    rdfs:comment 'Total nitrogen content applied in kilograms for fertilizer-related emission events. Serves as the primary activity data for calculating direct and indirect N2O emissions from synthetic and organic nitrogen applications per IPCC Tier 1 methodology. Null for non-fertilizer sources.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawEmissionQuantity rdf:type rdf:Property ;
    rdfs:label 'Raw Emission Quantity' ;
    rdfs:comment 'The calculated emission quantity in the native gas units before conversion to CO2-equivalent (e.g., kg of CH4, kg of N2O, metric tons of CO2). Computed as activity_quantity × emission_factor_value. Stored in native units to preserve calculation transparency.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawEmissionUnit rdf:type rdf:Property ;
    rdfs:label 'Raw Emission Unit' ;
    rdfs:comment 'Unit of measure for the raw emission quantity in native gas units (e.g., \'kg CH4\', \'kg N2O\', \'MT CO2\', \'g CO2\'). Distinct from the CO2-equivalent unit to maintain calculation auditability.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierOrganization rdf:type rdf:Property ;
    rdfs:label 'Verifier Organization' ;
    rdfs:comment 'Name of the third-party organization that performed verification of this emission record (e.g., \'Bureau Veritas\', \'SGS\', \'DNV GL\', \'SCS Global Services\'). Null if verification_status is not_verified or internal_review. Required for regulatory submissions and carbon market crediting.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityImpactRating rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the net biodiversity impact resulting from the land use change, based on habitat quality evaluation and species richness analysis. Supports TNFD (Taskforce on Nature-related Financial Disclosures) reporting and GLOBALG.A.P. biodiversity requirements.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonRegistryName rdf:type rdf:Property ;
    rdfs:label 'Carbon Registry Name' ;
    rdfs:comment 'Name of the voluntary or compliance carbon market registry under which carbon credits associated with this land use change are registered or being pursued (e.g., Verra VCS, Gold Standard, ACR, CAR).' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonStockChangeCo2eT rdf:type rdf:Property ;
    rdfs:label 'Carbon Stock Change Co2e T' ;
    rdfs:comment 'Net change in carbon stocks resulting from the land use change, expressed in tonnes of CO2 equivalent (tCO2e). Negative values indicate carbon sequestration; positive values indicate emissions. Calculated per IPCC Tier methodology and used in GHG inventory and ESG reporting.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeAreaHa rdf:type rdf:Property ;
    rdfs:label 'Change Area Ha' ;
    rdfs:comment 'Total area affected by the land use change event, expressed in hectares (ha). Used as the primary quantitative basis for carbon stock change calculations, EUDR due diligence, and biodiversity impact assessments.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeDriver rdf:type rdf:Property ;
    rdfs:label 'Change Driver' ;
    rdfs:comment 'Primary driver or cause of the land use change event. Determines regulatory treatment under EUDR and informs IPCC activity data classification for GHG inventory reporting.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current workflow lifecycle status of the land use change record, tracking progression from initial capture through satellite verification and regulatory acceptance.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudrComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Eudr Compliance Flag' ;
    rdfs:comment 'Indicates whether this land use change event has been assessed and confirmed as compliant with the EU Deforestation Regulation (EUDR), which prohibits placing commodities linked to deforestation on the EU market. True = compliant; False = non-compliant or under review.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eudrRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Eudr Risk Level' ;
    rdfs:comment 'EUDR-assigned risk classification for the country or region of origin of this land use change, determining the level of due diligence required. Derived from the European Commission benchmarking system.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forestCoverPctAfter rdf:type rdf:Property ;
    rdfs:label 'Forest Cover Pct After' ;
    rdfs:comment 'Percentage of the affected area classified as forest cover immediately following the land use change event, derived from satellite analysis. Compared against forest_cover_pct_before to determine net deforestation or reforestation.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forestCoverPctBefore rdf:type rdf:Property ;
    rdfs:label 'Forest Cover Pct Before' ;
    rdfs:comment 'Percentage of the affected area classified as forest cover immediately prior to the land use change event, derived from satellite analysis. Used in EUDR deforestation determination and IPCC carbon stock baseline calculations.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newLandUseType rdf:type rdf:Property ;
    rdfs:label 'New Land Use Type' ;
    rdfs:comment 'Classification of the land use category following the change event. Used in conjunction with previous_land_use_type to determine net carbon stock change and biodiversity impact under IPCC Tier 1/2/3 methodologies. [ENUM-REF-CANDIDATE: forest|grassland|wetland|cropland|pasture|shrubland|peatland — promote to reference product]' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousLandUseType rdf:type rdf:Property ;
    rdfs:label 'Previous Land Use Type' ;
    rdfs:comment 'Classification of the land use category prior to the change event. Critical for IPCC carbon stock change calculations and EUDR deforestation risk assessment. [ENUM-REF-CANDIDATE: forest|grassland|wetland|cropland|pasture|shrubland|peatland — promote to reference product]' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectedAreaOverlap rdf:type rdf:Property ;
    rdfs:label 'Protected Area Overlap' ;
    rdfs:comment 'Indicates whether the land use change area overlaps with a legally designated protected area (e.g., national park, wildlife refuge, Ramsar wetland, UNESCO biosphere reserve). True = overlap exists; False = no overlap. Critical for EUDR compliance and EPA regulatory review.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Status' ;
    rdfs:comment 'Status of any required governmental or regulatory permit authorising the land use change, such as land conversion permits, wetland fill permits, or forestry clearance approvals from USDA, EPA, or equivalent national authority.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteImageReference rdf:type rdf:Property ;
    rdfs:label 'Satellite Image Reference' ;
    rdfs:comment 'Unique reference identifier or URL for the satellite imagery record used to verify the land use change, enabling traceability back to the source image in Global Forest Watch, Planet Labs, or equivalent platform.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Satellite Verification Date' ;
    rdfs:comment 'Date on which satellite imagery verification of the land use change was completed, establishing the temporal evidence chain for EUDR due diligence and GHG reporting.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satelliteVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Satellite Verification Source' ;
    rdfs:comment 'Name of the satellite imagery or remote sensing platform used to verify the land use change event. Supports EUDR geolocation requirements and independent third-party verification of deforestation claims.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wetlandImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Wetland Impact Flag' ;
    rdfs:comment 'Indicates whether the land use change involves conversion of or impact to wetland areas, triggering additional regulatory requirements under EPA Section 404 and USDA Wetland Conservation Provisions (Swampbuster). True = wetland impacted; False = no wetland impact.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeDate rdf:type rdf:Property ;
    rdfs:label 'Change Date' ;
    rdfs:comment 'The principal real-world date on which the land use change event occurred or was initiated, used as the primary temporal anchor for GHG accounting and regulatory compliance reporting.' ;
    rdfs:domain ind:LandUseChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carbonProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Carbon Program Enrollment Id' ;
    rdfs:comment 'Identifier linking this practice adoption record to a carbon program enrollment (e.g., Indigo Carbon, Corteva Carbon, USDA CRP). Enables traceability from field-level practice to carbon credit generation.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConservationEnrollment .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'The calendar date on which the regenerative or conservation practice was formally adopted and implementation commenced on the field. Principal business event date for this transaction.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adoptionNotes rdf:type rdf:Property ;
    rdfs:label 'Adoption Notes' ;
    rdfs:comment 'Free-text field for agronomist or operator notes regarding implementation challenges, deviations from standard practice, weather conditions at time of implementation, or other contextual observations relevant to the practice adoption record.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adoption Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this practice adoption record, used in field documentation, carbon program submissions, and regulatory reporting. Format: PA-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionStatus rdf:type rdf:Property ;
    rdfs:label 'Adoption Status' ;
    rdfs:comment 'Current lifecycle status of the practice adoption record. Tracks progression from planning through field implementation and third-party verification. [ENUM-REF-CANDIDATE: planned|in_progress|implemented|verified|rejected|cancelled — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Share Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost share amount (e.g., USD). Required for international operations and IFRS financial reporting.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Flag' ;
    rdfs:comment 'Indicates whether this practice adoption record is included in the enterprise ESG report. Enables filtering of practice adoption data for ESG disclosure preparation aligned with GRI, SASB, and CDP reporting frameworks.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCarbonSequestrationMt rdf:type rdf:Property ;
    rdfs:label 'Estimated Carbon Sequestration Mt' ;
    rdfs:comment 'Estimated quantity of carbon dioxide equivalent (CO2e) sequestered or emissions avoided as a result of this practice adoption, expressed in metric tons. Calculated per the enrolled carbon program methodology; used for carbon credit pre-issuance estimation and ESG reporting.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationAreaAc rdf:type rdf:Property ;
    rdfs:label 'Implementation Area Ac' ;
    rdfs:comment 'Total land area in acres on which the practice was implemented. Retained alongside hectares for USDA FSA reporting and domestic US farm program compliance where acres are the standard unit of measure.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationAreaHa rdf:type rdf:Property ;
    rdfs:label 'Implementation Area Ha' ;
    rdfs:comment 'Total land area in hectares on which the practice was implemented. Used for carbon credit calculation, cost-per-hectare analysis, and ESG reporting. Metric Ton (MT) and hectare (ha) are the standard units for international sustainability reporting.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'The date on which field implementation of the practice was fully completed. Distinct from adoption_date which marks commencement; used to calculate implementation duration and trigger verification workflows.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationMethod rdf:type rdf:Property ;
    rdfs:label 'Implementation Method' ;
    rdfs:comment 'Describes the specific technique or approach used to implement the practice (e.g., aerial seeding, drill seeding, broadcast application, mechanical incorporation, prescribed burn). Sourced from Trimble Ag Software field operation records and Climate FieldView application data. [ENUM-REF-CANDIDATE: aerial_seeding|drill_seeding|broadcast|mechanical_incorporation|prescribed_burn|transplanting — promote to reference product]' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantityApplied rdf:type rdf:Property ;
    rdfs:label 'Input Quantity Applied' ;
    rdfs:comment 'Total quantity of the primary input product applied during practice implementation. Used alongside input_unit_of_measure for flexible unit tracking across different practice types (seed, compost, biochar).' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Input Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the input quantity applied (e.g., kg, lbs, MT, BU, L, gal). Supports multi-unit input tracking across diverse practice types and aligns with SAP S/4HANA unit of measure configuration. [ENUM-REF-CANDIDATE: kg|lbs|mt|bu|ton|L|gal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndviPostImplementationScore rdf:type rdf:Property ;
    rdfs:label 'Ndvi Post Implementation Score' ;
    rdfs:comment 'NDVI score measured after practice implementation to confirm vegetation establishment and quantify improvement over baseline. Used in remote sensing verification workflows and carbon methodology additionality assessments.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCertificationEligible rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Eligible' ;
    rdfs:comment 'Indicates whether this practice adoption contributes to or is required for USDA National Organic Program (NOP) certification eligibility on the field. Used in organic transition planning and certification audit documentation.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seedRateKgPerHa rdf:type rdf:Property ;
    rdfs:label 'Seed Rate Kg Per Ha' ;
    rdfs:comment 'Quantity of seed applied per hectare during practice implementation, expressed in kilograms per hectare. Captures input quantity for cover crop seeding events; used for cost tracking, carbon methodology input verification, and agronomic benchmarking.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilOrganicCarbonBaselinePct rdf:type rdf:Property ;
    rdfs:label 'Soil Organic Carbon Baseline Pct' ;
    rdfs:comment 'Baseline soil organic carbon (SOC) percentage measured at the field prior to practice implementation. Serves as the reference point for measuring soil carbon sequestration outcomes and is required by most soil carbon methodology protocols.' ;
    rdfs:domain ind:PracticeAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByPracticeRegenerativePracticeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Practice Regenerative Practice Id' ;
    rdfs:comment 'Reference to the regenerative_practice_id of the newer practice version that replaces this record when deprecated. Enables forward navigation in the practice version chain for program migration and historical reporting.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegenerativePractice .

ind:applicableClimateZones rdf:type rdf:Property ;
    rdfs:label 'Applicable Climate Zones' ;
    rdfs:comment 'Comma-separated list of USDA Plant Hardiness Zones or Köppen climate classification zones where this practice is recommended (e.g., \'Zone 5-8\', \'Humid Continental\', \'Semi-Arid\'). Ensures agronomic suitability for geographic deployment.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCropTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Crop Types' ;
    rdfs:comment 'Comma-separated list of crop types or commodity groups for which this practice is agronomically applicable (e.g., \'corn, soybean, wheat\', \'all row crops\', \'perennial forages\'). Guides practice assignment in Trimble Ag Software and Climate FieldView field planning workflows.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityBenefitRating rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Benefit Rating' ;
    rdfs:comment 'Qualitative rating of the practice\'s expected benefit to on-farm biodiversity (pollinator habitat, wildlife corridors, soil microbiome diversity). Supports ESG biodiversity disclosures and TNFD (Taskforce on Nature-related Financial Disclosures) reporting.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonProgramAlignment rdf:type rdf:Property ;
    rdfs:label 'Carbon Program Alignment' ;
    rdfs:comment 'Name of the voluntary or compliance carbon market program this practice is eligible for (e.g., \'Indigo Carbon\', \'Corteva Carbon\', \'Bayer Carbon Program\', \'Verra VCS\', \'Gold Standard\', \'ACR\'). Drives carbon credit revenue potential and program enrollment decisions.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerAcreUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acre Usd' ;
    rdfs:comment 'Estimated total implementation cost per acre in US dollars, including seed, labor, equipment, and materials. Used for enterprise budget planning in Granular Farm Management and SAP CO crop enterprise budgets. Supports ROI and OPEX analysis for regenerative program adoption.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerHectareUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hectare Usd' ;
    rdfs:comment 'Estimated total implementation cost per hectare in US dollars for international operations and metric-system reporting. Complements cost_per_acre_usd for global ESG and IFRS reporting contexts.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Category' ;
    rdfs:comment 'Primary ESG (Environmental, Social, Governance) reporting category under which this practice\'s outcomes are disclosed. Aligns with GRI Standards, SASB Agribusiness Standard, and TCFD framework for sustainability reporting.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedGhgReductionCo2eTHaYr rdf:type rdf:Property ;
    rdfs:label 'Expected Ghg Reduction Co2e T Ha Yr' ;
    rdfs:comment 'Expected annual greenhouse gas emission reduction expressed in tonnes of CO2 equivalent per hectare per year (t CO2e/ha/yr), encompassing N2O, CH4, and CO2 reductions attributable to the practice. Supports carbon footprint assessment and CDP reporting.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSocBenefitTCHaYr rdf:type rdf:Property ;
    rdfs:label 'Expected Soc Benefit T C Ha Yr' ;
    rdfs:comment 'Expected annual soil organic carbon (SOC) sequestration benefit expressed in tonnes of carbon per hectare per year (t C/ha/yr). Used for carbon credit estimation, ESG reporting, and science-based target alignment. Derived from peer-reviewed literature or program-specific quantification methodologies. Satisfies MASTER_RESOURCE MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldImpactPct rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Impact Pct' ;
    rdfs:comment 'Expected percentage change in crop yield attributable to this practice relative to conventional baseline (positive = yield increase, negative = yield penalty). Critical for agronomic ROI analysis and farmer adoption decision support. Expressed as a signed percentage (e.g., -3.5 for a 3.5% yield reduction, +2.0 for a 2% yield gain).' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmoRestriction rdf:type rdf:Property ;
    rdfs:label 'Gmo Restriction' ;
    rdfs:comment 'Specifies whether this practice has restrictions on the use of genetically modified organism (GMO) seed or inputs. Relevant for organic program compliance, Non-GMO Project verification, and EU export market requirements.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationGuidanceUrl rdf:type rdf:Property ;
    rdfs:label 'Implementation Guidance Url' ;
    rdfs:comment 'URL link to the official implementation guide, SOP document, or technical specification for this practice (e.g., USDA NRCS practice standard PDF, internal SharePoint SOP). Provides practitioners with authoritative reference material.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStandard rdf:type rdf:Property ;
    rdfs:label 'Implementation Standard' ;
    rdfs:comment 'The governing standard, protocol, or methodology that defines how this practice must be implemented (e.g., \'USDA NRCS 340 Cover Crop Standard\', \'Verra VM0042 Improved Agricultural Land Management\', \'Gold Standard Land Use and Forests\'). Critical for carbon program eligibility and audit compliance.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentivePaymentPerAcreUsd rdf:type rdf:Property ;
    rdfs:label 'Incentive Payment Per Acre Usd' ;
    rdfs:comment 'Government or program incentive payment available per acre for adopting this practice (e.g., USDA EQIP payment, carbon program payment, state cost-share). Offsets implementation cost and is a key driver of farmer adoption economics.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isccEligible rdf:type rdf:Property ;
    rdfs:label 'Iscc Eligible' ;
    rdfs:comment 'Indicates whether this practice qualifies under International Sustainability and Carbon Certification (ISCC) requirements for biofuel and bio-based product supply chains. Relevant for renewable fuel standard compliance and EU sustainability reporting.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumImplementationPeriodYrs rdf:type rdf:Property ;
    rdfs:label 'Minimum Implementation Period Yrs' ;
    rdfs:comment 'Minimum number of consecutive years the practice must be maintained to qualify for carbon program credits or government incentive payments. Critical for contract term planning and farmer commitment assessment.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:practiceSubtype rdf:type rdf:Property ;
    rdfs:label 'Practice Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within the practice type (e.g., \'Legume Cover Crop\', \'Brassica Cover Crop\', \'Strip-Till\', \'Silvopasture\', \'Alley Cropping\'). Enables detailed analytics and program-specific eligibility filtering.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceType rdf:type rdf:Property ;
    rdfs:label 'Practice Type' ;
    rdfs:comment 'Primary classification of the regenerative agriculture practice category. Drives program eligibility, carbon credit calculation methodology, and reporting groupings. Satisfies MASTER_RESOURCE CLASSIFICATION_OR_TYPE category. [ENUM-REF-CANDIDATE: cover_cropping|no_till|reduced_till|crop_rotation|agroforestry|composting|ipm|managed_grazing — promote to reference product]' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilHealthBenefitRating rdf:type rdf:Property ;
    rdfs:label 'Soil Health Benefit Rating' ;
    rdfs:comment 'Qualitative rating of the practice\'s expected benefit to soil health indicators including organic matter (OM), cation exchange capacity (CEC), compaction reduction, and microbial activity. Supports USDA Soil Health Initiative reporting and GLOBALG.A.P. soil management compliance.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterQualityBenefitRating rdf:type rdf:Property ;
    rdfs:label 'Water Quality Benefit Rating' ;
    rdfs:comment 'Qualitative rating of the practice\'s expected benefit to water quality outcomes (nutrient runoff reduction, sediment reduction, groundwater recharge). Supports water stewardship reporting and EPA Clean Water Act compliance documentation.' ;
    rdfs:domain ind:RegenerativePractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agriculturalRelevanceDescription rdf:type rdf:Property ;
    rdfs:label 'Agricultural Relevance Description' ;
    rdfs:comment 'Narrative description of how this Scope 3 category applies specifically to the agricultural enterprise\'s value chain. Explains the primary emission sources within this category relevant to crop cultivation, animal husbandry, food production, and supply chain operations (e.g., for Category 1: fertilizer and agrochemical manufacturing emissions, seed production, feed ingredient sourcing).' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGasTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Gas Types' ;
    rdfs:comment 'Comma-separated list of greenhouse gas types that are relevant to this Scope 3 category in agricultural operations (e.g., \'CO2, CH4, N2O\' for Category 1 covering fertilizer production; \'CO2, CH4\' for Category 4 transportation). Aligns with IPCC AR6 Global Warming Potential (GWP) basket of gases.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryNotes rdf:type rdf:Property ;
    rdfs:label 'Category Notes' ;
    rdfs:comment 'Free-text field for additional context, methodology notes, exclusion rationale, or enterprise-specific guidance related to this Scope 3 category. May include references to specific agricultural commodities, supply chain tiers, or regulatory interpretations relevant to the enterprise\'s GHG inventory management.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryNumber rdf:type rdf:Property ;
    rdfs:label 'Category Number' ;
    rdfs:comment 'Official GHG Protocol Scope 3 category number (1 through 15) as defined in the Corporate Value Chain (Scope 3) Accounting and Reporting Standard. Used as the primary business identifier for referencing categories in emissions inventories and ESG reports (e.g., Category 1: Purchased Goods & Services, Category 4: Upstream Transportation & Distribution, Category 11: Use of Sold Products).' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdpDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Cdp Disclosure Required' ;
    rdfs:comment 'Indicates whether this Scope 3 category must be disclosed in the enterprise\'s annual CDP Climate Change questionnaire response. CDP requires disclosure of all material Scope 3 categories and explanation of exclusions for non-material ones. Drives annual CDP submission planning.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csrdDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Csrd Disclosure Required' ;
    rdfs:comment 'Indicates whether this Scope 3 category is required for disclosure under the EU Corporate Sustainability Reporting Directive (CSRD) and European Sustainability Reporting Standards (ESRS E1). Relevant for the enterprise\'s international operations and supply chain partners operating in EU markets.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'IPCC-aligned data quality tier for the activity data and emission factors used in this Scope 3 category. Tier 1 uses default emission factors; Tier 2 uses country-specific factors; Tier 3 uses facility-specific or process-level data. Higher tiers indicate greater accuracy and are preferred for material categories. Informs uncertainty quantification.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimationUncertaintyPct rdf:type rdf:Property ;
    rdfs:label 'Estimation Uncertainty Pct' ;
    rdfs:comment 'Quantified uncertainty range (as a percentage) associated with the emission estimates for this Scope 3 category, based on the data collection method and emission factor quality. Higher uncertainty is expected for spend-based Tier 1 estimates; lower uncertainty for activity-based Tier 3 data. Used in GHG inventory quality assessments and verification reports.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flagGuidanceCategory rdf:type rdf:Property ;
    rdfs:label 'Flag Guidance Category' ;
    rdfs:comment 'Indicates whether this Scope 3 category is specifically addressed in the SBTi FLAG (Forest, Land and Agriculture) sector guidance for agricultural enterprises. FLAG-relevant categories require separate land-related and fossil fuel-related emission accounting and target-setting. Critical for the enterprise\'s SBTi commitment compliance.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgProtocolChapterRef rdf:type rdf:Property ;
    rdfs:label 'Ghg Protocol Chapter Ref' ;
    rdfs:comment 'Reference to the specific chapter or section in the GHG Protocol Corporate Value Chain (Scope 3) Standard that governs the accounting methodology for this category. Used for audit trail and methodology documentation in third-party verification processes.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griStandardReference rdf:type rdf:Property ;
    rdfs:label 'Gri Standard Reference' ;
    rdfs:comment 'Reference to the applicable GRI Standard disclosure number that corresponds to this Scope 3 category for ESG reporting purposes (e.g., GRI 305-3 for Other Indirect GHG Emissions). Used to align the enterprise\'s sustainability report with GRI Standards and facilitate stakeholder communication.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionJustification rdf:type rdf:Property ;
    rdfs:label 'Inclusion Justification' ;
    rdfs:comment 'Documented rationale for including or excluding this Scope 3 category from the enterprise\'s GHG inventory. For excluded categories, must explain why the category is not material or not applicable. Required for GHG Protocol compliance, CDP disclosure, and third-party verification. Supports FSMA and GLOBALG.A.P. supply chain transparency requirements.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipccCategoryReference rdf:type rdf:Property ;
    rdfs:label 'Ipcc Category Reference' ;
    rdfs:comment 'Cross-reference to the corresponding IPCC National Greenhouse Gas Inventory category code(s) that align with this Scope 3 category for agricultural operations (e.g., IPCC 3.A for livestock, IPCC 3.C for rice cultivation and agricultural soils). Enables alignment between corporate Scope 3 reporting and national inventory methodologies.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isccRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Iscc Relevance Flag' ;
    rdfs:comment 'Indicates whether this Scope 3 category is relevant to the enterprise\'s ISCC certification requirements for sustainable biomass and agricultural commodities. ISCC requires greenhouse gas lifecycle assessments covering specific value chain stages. Supports certification compliance tracking.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landUseChangeRelevant rdf:type rdf:Property ;
    rdfs:label 'Land Use Change Relevant' ;
    rdfs:comment 'Indicates whether this Scope 3 category includes land use change (LUC) emissions, which are particularly significant in agricultural supply chains (e.g., Category 1 for deforestation-linked commodity sourcing, Category 2 for capital goods involving land conversion). Relevant for ISCC, RSPO, and GLOBALG.A.P. deforestation-free supply chain commitments.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityClassification rdf:type rdf:Property ;
    rdfs:label 'Materiality Classification' ;
    rdfs:comment 'Assessment of whether this Scope 3 category is considered material to the enterprise\'s total GHG inventory based on the GHG Protocol materiality screening criteria. Material categories require full quantification and disclosure; non-material categories may be excluded with justification. Drives prioritization of data collection efforts and ESG reporting scope.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialityRationale rdf:type rdf:Property ;
    rdfs:label 'Materiality Rationale' ;
    rdfs:comment 'Documented justification for the materiality classification of this Scope 3 category. Explains the qualitative and quantitative factors considered in the materiality determination, including estimated share of total emissions, stakeholder relevance, and data availability. Required for GHG Protocol compliance and CDP disclosure.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryActivityUnit rdf:type rdf:Property ;
    rdfs:label 'Primary Activity Unit' ;
    rdfs:comment 'The standard unit of measure for activity data collected under this Scope 3 category in agricultural contexts (e.g., \'USD spend\' for spend-based categories, \'MT\' for purchased goods by mass, \'tonne-km\' for transportation, \'ha\' for land use change). Drives data collection templates and emission factor unit alignment.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Data Collection Method' ;
    rdfs:comment 'The principal method used to collect activity data for quantifying emissions in this Scope 3 category. Options include supplier-specific surveys, spend-based estimation using economic input-output models, activity-based measurement using physical quantities, hybrid approaches, IoT sensor data from John Deere Operations Center or Climate FieldView, or third-party data providers. Informs data quality ratings and uncertainty assessments. [ENUM-REF-CANDIDATE: supplier_survey|spend_based|activity_based|hybrid|iot_sensor|third_party_data|not_collected — promote to reference product]' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Reduction Target Pct' ;
    rdfs:comment 'Enterprise-defined percentage reduction target for emissions in this Scope 3 category relative to the baseline year, expressed as a percentage (e.g., 30.00 for a 30% reduction target). Aligned with SBTi FLAG guidance and corporate net-zero commitments. Used in sustainability performance tracking and ESG reporting.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Indicates whether reporting of this Scope 3 category is mandatory under applicable regulatory frameworks (e.g., SEC climate disclosure rules, EU CSRD), voluntary under certification programs (e.g., SBTi, CDP, GLOBALG.A.P.), or not applicable to the enterprise. Drives compliance planning and ESG reporting calendar.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name of the internal business team or department responsible for data collection, quantification, and reporting for this Scope 3 category (e.g., \'Procurement\', \'Supply Chain Sustainability\', \'Agronomy\', \'Logistics\'). Supports accountability assignment in the enterprise\'s GHG inventory management process.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtAlignmentRequired rdf:type rdf:Property ;
    rdfs:label 'Sbt Alignment Required' ;
    rdfs:comment 'Indicates whether this Scope 3 category must be included in the enterprise\'s Science Based Target initiative (SBTi) commitment. SBTi FLAG-AG guidance requires inclusion of Scope 3 categories that represent more than 40% of total Scope 3 emissions. Drives target-setting and reduction pathway planning.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueChainPosition rdf:type rdf:Property ;
    rdfs:label 'Value Chain Position' ;
    rdfs:comment 'Indicates whether the Scope 3 category relates to upstream activities (before the enterprise\'s operations, e.g., purchased goods, supplier transportation), downstream activities (after the enterprise\'s operations, e.g., use of sold products, end-of-life treatment), or direct operations context. Drives segmentation in value chain emissions analysis and GLOBALG.A.P. supply chain reporting.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequired rdf:type rdf:Property ;
    rdfs:label 'Verification Required' ;
    rdfs:comment 'Indicates whether third-party verification of emission estimates for this Scope 3 category is required under applicable regulatory frameworks or voluntary certification programs (e.g., CDP, SBTi, ISCC, GLOBALG.A.P.). Drives the annual verification planning and engagement with accredited verification bodies.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soilTemperatureId rdf:type rdf:Property ;
    rdfs:label 'Soil Temperature Id' ;
    rdfs:comment 'Foreign key linking to weather.soil_temperature. Business justification: Soil carbon sampling protocols require recording soil temperature at measurement time because temperature directly affects SOC decomposition rates and measurement accuracy. Carbon credit registries (V' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoilTemperature .

ind:areaHa rdf:type rdf:Property ;
    rdfs:label 'Area Ha' ;
    rdfs:comment 'Total area of the field or management zone covered by this measurement record, expressed in hectares. Used to scale per-hectare SOC values to total carbon stock and VCU calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineSocStockTPerHa rdf:type rdf:Property ;
    rdfs:label 'Baseline Soc Stock T Per Ha' ;
    rdfs:comment 'Reference SOC stock value established at the project start date or baseline year, expressed in t C/ha. Used as the denominator for calculating SOC change and carbon credit eligibility.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bufferPoolContributionPct rdf:type rdf:Property ;
    rdfs:label 'Buffer Pool Contribution Pct' ;
    rdfs:comment 'Percentage of gross VCUs withheld and contributed to the registry\'s buffer pool (risk buffer) to account for reversal risk. Reduces net VCUs available for sale. Required by Verra VCS and other registries.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkDensityGPerCm3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density G Per Cm3' ;
    rdfs:comment 'Soil bulk density measured in grams per cubic centimetre (g/cm³) at the time of sampling. Required for converting SOC concentration (%) to SOC stock (t C/ha) and for equivalent soil mass corrections.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EquivalentT rdf:type rdf:Property ;
    rdfs:label 'Co2 Equivalent T' ;
    rdfs:comment 'SOC change expressed in tonnes of CO2 equivalent (t CO2e), converting carbon mass to CO2e using the molecular weight ratio (1 t C = 3.667 t CO2e). Standard unit for GHG reporting and carbon market transactions.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the accredited analytical laboratory that performed SOC concentration analysis on the collected soil samples. Laboratory accreditation is required for registry-compliant measurements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Report Number' ;
    rdfs:comment 'Unique report or certificate of analysis (COA) number issued by the analytical laboratory for the soil sample batch associated with this measurement event. Provides traceability to raw analytical data.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to this soil carbon measurement event, used for cross-referencing with laboratory reports, registry submissions, and audit documentation.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netVcuQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Vcu Quantity' ;
    rdfs:comment 'Net VCUs available for issuance and sale after deducting buffer pool contributions and uncertainty deductions from gross VCUs. Represents the monetizable carbon credit volume from this measurement event.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicAmendmentApplied rdf:type rdf:Property ;
    rdfs:label 'Organic Amendment Applied' ;
    rdfs:comment 'Indicates whether organic amendments (compost, manure, biochar, or other organic inputs) were applied to the field during the monitoring period. Organic amendments are a key driver of SOC stock increases.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Registry Submission Reference' ;
    rdfs:comment 'Unique reference number or project ID assigned by the carbon registry upon submission of this measurement for verification. Used for audit trail and tracking VCU issuance status in the registry system.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socChangeTPerHa rdf:type rdf:Property ;
    rdfs:label 'Soc Change T Per Ha' ;
    rdfs:comment 'Net change in SOC stock relative to the established baseline measurement, expressed in tonnes of carbon per hectare (t C/ha). Positive values indicate sequestration; negative values indicate carbon loss.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Soc Concentration Pct' ;
    rdfs:comment 'Measured SOC concentration expressed as a percentage of dry soil mass, as determined by laboratory analysis (e.g., Walkley-Black, dry combustion). Input to SOC stock calculation.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socStockTPerHa rdf:type rdf:Property ;
    rdfs:label 'Soc Stock T Per Ha' ;
    rdfs:comment 'Measured or modelled soil organic carbon stock expressed in tonnes of carbon per hectare (t C/ha) at the time of measurement. This is the principal quantitative fact for this record and the basis for carbon credit calculations.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilType rdf:type rdf:Property ;
    rdfs:label 'Soil Type' ;
    rdfs:comment 'USDA or FAO soil classification type for the sampled location (e.g., Mollisol, Vertisol, Alfisol). Influences SOC sequestration potential and model parameterisation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSocStockT rdf:type rdf:Property ;
    rdfs:label 'Total Soc Stock T' ;
    rdfs:comment 'Total SOC stock for the measured area, expressed in tonnes of carbon (t C). Calculated as soc_stock_t_per_ha multiplied by area_ha. Represents the absolute carbon pool for the management unit.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uncertaintyPct rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Pct' ;
    rdfs:comment 'Statistical uncertainty of the SOC stock or change estimate expressed as a percentage (e.g., 95% confidence interval half-width as % of mean). Required by carbon registries for conservative crediting and buffer pool contributions.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vcuQuantity rdf:type rdf:Property ;
    rdfs:label 'Vcu Quantity' ;
    rdfs:comment 'Number of Verified Carbon Units (VCUs) generated or estimated from this measurement event. One VCU represents one tonne of CO2-equivalent reduced or removed from the atmosphere. Used for carbon credit monetization.' ;
    rdfs:domain ind:SoilCarbonSequestration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'End date of the sustainability assessment period. Together with start date defines the reporting window for Scope 3 supply chain sustainability management.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'Start date of the sustainability assessment period for which supplier performance data is evaluated and scored.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdpSupplierScore rdf:type rdf:Property ;
    rdfs:label 'Cdp Supplier Score' ;
    rdfs:comment 'The supplier\'s CDP Supply Chain disclosure score for the assessment year, ranging from A (leadership) to D- (disclosure) or F (non-disclosure). Used for Scope 3 supplier engagement tracking. [ENUM-REF-CANDIDATE: A|A-|B|B-|C|C-|D|D-|F|not_disclosed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childLaborRiskRating rdf:type rdf:Property ;
    rdfs:label 'Child Labor Risk Rating' ;
    rdfs:comment 'Risk rating for child labor exposure in the supplier\'s operations and supply chain, based on country risk, commodity risk, and audit findings. Supports FSMA and ILO compliance.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deforestationCommitmentScope rdf:type rdf:Property ;
    rdfs:label 'Deforestation Commitment Scope' ;
    rdfs:comment 'Scope of the supplier\'s deforestation-free commitment, specifying whether it covers deforestation only, or extends to peat and ecosystem conversion (No Deforestation, No Peat, No Exploitation - NDPE).' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deforestationFreeCommitment rdf:type rdf:Property ;
    rdfs:label 'Deforestation Free Commitment' ;
    rdfs:comment 'Indicates whether the supplier has made a verified commitment to deforestation-free sourcing across their supply chain, aligned with EUDR and RSPO requirements.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Score' ;
    rdfs:comment 'Supplier score for the environmental pillar of the sustainability assessment, covering GHG emissions, water use, biodiversity, and pollution management.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forcedLaborRiskRating rdf:type rdf:Property ;
    rdfs:label 'Forced Labor Risk Rating' ;
    rdfs:comment 'Risk rating for forced or bonded labor exposure in the supplier\'s operations, based on country risk, sector risk, and audit findings. Supports modern slavery compliance.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Supplier score for the governance pillar of the sustainability assessment, covering ethics, anti-corruption, responsible sourcing, and management systems.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livingWageCompliance rdf:type rdf:Property ;
    rdfs:label 'Living Wage Compliance' ;
    rdfs:comment 'Assessment of whether the supplier pays all workers a living wage as defined by the applicable regional living wage benchmark, a key social sustainability indicator.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCorrectiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Open Corrective Action Count' ;
    rdfs:comment 'Number of unresolved corrective action items currently outstanding for this supplier assessment, used to prioritize supplier engagement and escalation.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Flag' ;
    rdfs:comment 'Indicates whether the supplier holds a valid organic certification (e.g., USDA NOP, EU Organic) for the products supplied, relevant to sustainable sourcing programs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallSustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Overall Sustainability Score' ;
    rdfs:comment 'Composite sustainability performance score for the supplier, typically on a 0–100 scale as defined by the questionnaire framework. Used for supplier segmentation and Scope 3 ESG reporting.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:questionnaireFramework rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Framework' ;
    rdfs:comment 'The standardized sustainability assessment framework or questionnaire platform used to evaluate the supplier. Determines scoring methodology and benchmarking peer group.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionnaireVersion rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Version' ;
    rdfs:comment 'Version number of the sustainability questionnaire framework applied during this assessment, ensuring comparability across assessment cycles.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scienceBasedTargetCommitted rdf:type rdf:Property ;
    rdfs:label 'Science Based Target Committed' ;
    rdfs:comment 'Indicates whether the supplier has committed to or validated a Science Based Target for GHG emissions reduction, aligned with the Paris Agreement 1.5°C pathway.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scorePublishedDate rdf:type rdf:Property ;
    rdfs:label 'Score Published Date' ;
    rdfs:comment 'Date on which the final sustainability score was published and made available to the procurement team for supplier management decisions.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:socialScore rdf:type rdf:Property ;
    rdfs:label 'Social Score' ;
    rdfs:comment 'Supplier score for the social pillar of the sustainability assessment, covering labor practices, human rights, health and safety, and community impact.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierGhgEmissionsCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Supplier Ghg Emissions Co2e Mt' ;
    rdfs:comment 'Total greenhouse gas emissions reported by the supplier for the assessment period, expressed in metric tons of CO2 equivalent (CO2e). Used for Scope 3 Category 1 calculations.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierWaterWithdrawalM3 rdf:type rdf:Property ;
    rdfs:label 'Supplier Water Withdrawal M3' ;
    rdfs:comment 'Total water withdrawal volume reported by the supplier for the assessment period in cubic meters, supporting water stewardship and CDP Water disclosure.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyChainScore rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Score' ;
    rdfs:comment 'Supplier score for the sustainable procurement and supply chain management pillar, assessing how the supplier manages its own upstream sustainability risks.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the supplier\'s primary sustainability certification, used to trigger re-certification alerts and maintain sourcing compliance.' ;
    rdfs:domain ind:SupplierSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Auditor Accreditation Number' ;
    rdfs:comment 'Official accreditation or registration number of the auditing organization issued by the relevant certification body or accreditation authority, used to verify legitimacy of the audit.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorComments rdf:type rdf:Property ;
    rdfs:label 'Auditor Comments' ;
    rdfs:comment 'Free-text narrative comments provided by the lead auditor summarizing key observations, commendations, areas of concern, and overall impressions from the sustainability audit.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityAssessed rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of biodiversity conservation practices, habitat management, and ecosystem impact on the farm unit or facility.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonFootprintAssessed rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of greenhouse gas (GHG) emissions and carbon footprint metrics for the farm unit or facility, relevant to carbon reporting and net-zero commitments.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceScorePct rdf:type rdf:Property ;
    rdfs:label 'Compliance Score Pct' ;
    rdfs:comment 'Overall compliance score expressed as a percentage of control points met versus total applicable control points assessed during the audit. Calculated by the certification body or auditor and recorded as a raw audit result (not a derived metric).' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for a follow-up or verification audit to confirm that corrective actions have been effectively implemented. Populated when the audit outcome is conditional_pass or fail.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gapComplianceAssessed rdf:type rdf:Property ;
    rdfs:label 'Gap Compliance Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of Good Agricultural Practices (GAP) compliance covering food safety, worker welfare, environmental stewardship, and traceability requirements.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipmComplianceAssessed rdf:type rdf:Property ;
    rdfs:label 'Ipm Compliance Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of Integrated Pest Management (IPM) practices, pesticide use records, Maximum Residue Limits (MRL) compliance, and Pre-Harvest Interval (PHI) adherence.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted by the auditor that do not constitute non-conformances but represent best practice recommendations or areas of potential risk.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soilHealthAssessed rdf:type rdf:Property ;
    rdfs:label 'Soil Health Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of soil carbon sequestration, organic matter (OM) levels, and soil health management practices as part of the sustainability evaluation.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterStewardshipAssessed rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Assessed' ;
    rdfs:comment 'Indicates whether the audit included an assessment of water use efficiency, irrigation management, and water quality compliance as part of the sustainability evaluation.' ;
    rdfs:domain ind:SustainabilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonClaimIncluded rdf:type rdf:Property ;
    rdfs:label 'Carbon Claim Included' ;
    rdfs:comment 'Indicates whether this certification includes a verified carbon footprint or greenhouse gas (GHG) emissions reduction claim (True). Relevant for ISCC PLUS, Verra VCS, Gold Standard, and similar low-carbon certification schemes.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or file path to the official certificate document stored in the enterprise document management system or data lake. Enables direct access to the certificate PDF for audit, customer, and regulatory submission purposes.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Certified Area Ha' ;
    rdfs:comment 'Total land area covered under the scope of this certification, expressed in hectares. Used for area-based compliance reporting, supply chain mass balance calculations, and ESG land stewardship metrics.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedCropTypes rdf:type rdf:Property ;
    rdfs:label 'Certified Crop Types' ;
    rdfs:comment 'Comma-separated list of crop types or commodity categories covered under the scope of this certification (e.g., \'Corn, Soybeans, Wheat\'). Defines the agricultural products to which the certification claims apply.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityName rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Name' ;
    rdfs:comment 'Human-readable name of the specific entity covered by this certification (e.g., farm unit name, facility name, enterprise legal name, or product line name). Used for reporting and supply chain documentation.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityScope rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Scope' ;
    rdfs:comment 'Defines the level at which this certification applies within the agricultural enterprise hierarchy. Enterprise = entire organization; Farm Unit = specific farm or field block; Product = specific commodity or SKU; Supply Chain Stage = a defined stage (e.g., storage, transport); Processing Facility = a specific processing or packing facility.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyModel rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Model' ;
    rdfs:comment 'Chain-of-custody model applied under this certification, defining how certified material is tracked through the supply chain. Identity Preserved = single-source traceability; Segregated = certified kept separate from non-certified; Mass Balance = certified volumes tracked by accounting; Book and Claim = certificate trading without physical segregation.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Accreditation Number' ;
    rdfs:comment 'Accreditation number of the certification body as registered with the relevant accreditation authority (e.g., ANAB, DAkkS, UKAS). Validates the legitimacy of the issuing body for regulatory and customer audit purposes.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Name' ;
    rdfs:comment 'Name of the accredited certification body or auditing organization that issued this certificate (e.g., Control Union, Bureau Veritas, SGS, NSF International, CCOF). Distinct from the scheme owner.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicClaimIncluded rdf:type rdf:Property ;
    rdfs:label 'Organic Claim Included' ;
    rdfs:comment 'Indicates whether this sustainability certification includes or is co-aligned with an organic production claim (True) or is purely an environmental/sustainability certification without organic scope (False). Prevents confusion with product-level organic certifications.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicRegistryUrl rdf:type rdf:Property ;
    rdfs:label 'Public Registry Url' ;
    rdfs:comment 'URL to the certification entry in the scheme\'s public online registry (e.g., GLOBALG.A.P. database, ISCC system, Rainforest Alliance certificate database). Enables third-party verification of certification validity.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Scheme Standard Version' ;
    rdfs:comment 'Version or revision of the certification standard under which this certificate was issued (e.g., Rainforest Alliance 2020 Standard v1.2, ISCC PLUS v3.5). Required for audit traceability and re-certification planning.' ;
    rdfs:domain ind:SustainabilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainStage rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Stage' ;
    rdfs:comment 'Stage of the agricultural supply chain to which this certification applies. Relevant for chain-of-custody certifications such as ISCC, RSPO, and Rainforest Alliance where certification scope is defined by supply chain position.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiative Employee Id' ;
    rdfs:comment 'Reference to the internal employee or manager responsible for leading and delivering the sustainability initiative. Links to the workforce domain for accountability tracking.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementBudgetId rdf:type rdf:Property ;
    rdfs:label 'Procurement Budget Id' ;
    rdfs:comment 'Foreign key linking to procurement.budget. Business justification: Sustainability initiatives in agriculture (cover crop programs, organic input transitions, biocontrol adoption) involve direct procurement spend tracked against procurement budgets. Linking sustainabi' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:actualEmissionReductionCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Actual Emission Reduction Co2e Mt' ;
    rdfs:comment 'The measured or verified actual reduction in greenhouse gas emissions in CO2e MT achieved by this initiative to date. Compared against planned_emission_reduction_co2e_mt to assess performance.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualResourceSavingValue rdf:type rdf:Property ;
    rdfs:label 'Actual Resource Saving Value' ;
    rdfs:comment 'The measured actual quantity of resource savings achieved by this initiative to date. Compared against planned_resource_saving_value to assess delivery performance. Unit of measure is captured in resource_saving_unit.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Actual expenditure incurred against this sustainability initiative to date in US dollars. Compared against budget_allocated_usd to track budget utilization and variance.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdpDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Disclosure Flag' ;
    rdfs:comment 'Indicates whether this initiative is disclosed as part of the enterprise\'s annual CDP (Carbon Disclosure Project) submission. Supports CDP scoring and investor transparency.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingRegulation rdf:type rdf:Property ;
    rdfs:label 'Governing Regulation' ;
    rdfs:comment 'Name of the specific regulation, law, or compliance framework that mandates or governs this initiative (e.g., \'FSMA Produce Safety Rule\', \'EPA Clean Water Act Section 319\', \'USDA Conservation Reserve Program\'). Null for voluntary initiatives.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationApproach rdf:type rdf:Property ;
    rdfs:label 'Implementation Approach' ;
    rdfs:comment 'Description of the primary method or practice used to implement the initiative (e.g., \'Cover cropping with no-till\', \'Drip irrigation conversion\', \'Solar panel installation\'). Supports Best Management Practices (BMP) documentation.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the initiative, used in ESG reports, partner communications, and regulatory submissions. Format: SI-{TYPE}-{YEAR}-{SEQ}.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Human-readable name of the sustainability initiative as used in internal communications, ESG reports, and stakeholder presentations (e.g., \'Midwest Cover Crop Carbon Program 2024\').' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle state of the sustainability initiative, from planning through completion or cancellation. Drives portfolio management dashboards and ESG reporting eligibility.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeType rdf:type rdf:Property ;
    rdfs:label 'Initiative Type' ;
    rdfs:comment 'Classification of the initiative by its primary sustainability objective. Drives portfolio categorization and ESG reporting alignment. [ENUM-REF-CANDIDATE: carbon_reduction|water_conservation|biodiversity_enhancement|renewable_energy|regenerative_agriculture|social_equity — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOrganizations rdf:type rdf:Property ;
    rdfs:label 'Partner Organizations' ;
    rdfs:comment 'Comma-separated list of external partner organizations collaborating on this initiative (e.g., NGOs, government agencies, research institutions, technology providers). Supports stakeholder reporting and partnership management.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEmissionReductionCo2eMt rdf:type rdf:Property ;
    rdfs:label 'Planned Emission Reduction Co2e Mt' ;
    rdfs:comment 'The planned or targeted reduction in greenhouse gas emissions expressed in metric tons of carbon dioxide equivalent (CO2e MT) attributable to this initiative. Applicable for carbon reduction and regenerative agriculture initiative types.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedResourceSavingValue rdf:type rdf:Property ;
    rdfs:label 'Planned Resource Saving Value' ;
    rdfs:comment 'The planned quantity of resource savings (e.g., water volume in m3, energy in MWh, land area in ha) targeted by this initiative. Unit of measure is captured in resource_saving_unit. Applicable for water conservation, renewable energy, and biodiversity initiatives.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressPct rdf:type rdf:Property ;
    rdfs:label 'Progress Pct' ;
    rdfs:comment 'Estimated percentage completion of the sustainability initiative as assessed by the program owner. Ranges from 0.00 to 100.00. Used for portfolio progress dashboards and milestone reporting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceSavingUnit rdf:type rdf:Property ;
    rdfs:label 'Resource Saving Unit' ;
    rdfs:comment 'Unit of measure for planned and actual resource saving values (e.g., m3 for water, MWh for energy, ha for land, MT for biomass). Ensures dimensional consistency in ESG reporting.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Name of the internal business unit or division that owns and sponsors the initiative (e.g., \'Crop Operations\', \'Livestock Division\', \'Supply Chain\'). Used for accountability and budget allocation reporting.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSustainabilityMetric rdf:type rdf:Property ;
    rdfs:label 'Target Sustainability Metric' ;
    rdfs:comment 'The primary sustainability Key Performance Indicator (KPI) that this initiative is designed to impact. Aligns initiative outcomes to enterprise ESG targets and science-based targets. [ENUM-REF-CANDIDATE: ghg_emissions_co2e|water_withdrawal_m3|soil_carbon_soc|biodiversity_score|renewable_energy_pct|social_equity_index — promote to reference product]' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignmentFramework rdf:type rdf:Property ;
    rdfs:label 'Alignment Framework' ;
    rdfs:comment 'The voluntary or regulatory framework to which this sustainability target is aligned. SBTi = Science Based Targets initiative; RE100 = 100% renewable electricity commitment; CDP = Carbon Disclosure Project; TCFD = Task Force on Climate-related Financial Disclosures; TNFD = Taskforce on Nature-related Financial Disclosures; UN_SDGs = United Nations Sustainable Development Goals; GLOBALG.A.P. = Global Good Agricultural Practices; ISCC = International Sustainability and Carbon Certification; NOP = USDA National Organic Program. [ENUM-REF-CANDIDATE: SBTi|RE100|CDP|TCFD|TNFD|UN_SDGs|GLOBALG.A.P.|ISCC|NOP|none — promote to reference product]' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardEndorsementDate rdf:type rdf:Property ;
    rdfs:label 'Board Endorsement Date' ;
    rdfs:comment 'The date on which the enterprise board of directors formally endorsed this sustainability target via board resolution. Required for TCFD governance disclosure and investor ESG reporting. Null if board endorsement has not yet occurred.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Current Period Value' ;
    rdfs:comment 'The most recently measured value of the sustainability indicator for the current reporting period, expressed in target_unit. Enables real-time progress tracking against baseline and target values without requiring aggregation from transactional tables.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Current Period Year' ;
    rdfs:comment 'The calendar year corresponding to the current_period_value measurement. Used to contextualize progress data and align with annual ESG reporting cycles and CDP submission periods.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ghgScopeCoverage rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope Coverage' ;
    rdfs:comment 'Indicates which GHG Protocol emission scopes are covered by this target. Scope 1 = direct farm/facility emissions, Scope 2 = purchased energy, Scope 3 = value chain (feed, fertilizer, transport, land use). Required for SBTi validation and CDP climate disclosure. Set to not_applicable for non-GHG targets (water, biodiversity).' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimTargetValue rdf:type rdf:Property ;
    rdfs:label 'Interim Target Value' ;
    rdfs:comment 'The quantitative milestone value to be achieved by the interim_target_year, expressed in the same unit as target_unit. Enables phased progress tracking and SBTi near-term target validation.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interimTargetYear rdf:type rdf:Property ;
    rdfs:label 'Interim Target Year' ;
    rdfs:comment 'The near-term milestone year for an intermediate progress checkpoint, typically 5-10 years before the long-term target year (e.g., 2030 interim target for a 2050 net-zero commitment). Required by SBTi Corporate Net-Zero Standard which mandates both near-term and long-term targets.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'The date of the most recent third-party independent verification of progress data for this sustainability target. Null if no verification has been completed. Required for CDP limited or reasonable assurance disclosures and SBTi progress reporting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTrackFlag rdf:type rdf:Property ;
    rdfs:label 'On Track Flag' ;
    rdfs:comment 'Indicates whether the current trajectory of progress is sufficient to achieve the target by the target_year, based on the linear or science-based reduction pathway. True = on track; False = off track. Updated at each progress_tracking_frequency cycle. Supports executive dashboards and ESG risk reporting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The enterprise business unit or division primarily responsible for executing and reporting on this sustainability target (e.g., \'Crop Operations\', \'Livestock Division\', \'Supply Chain & Logistics\', \'Corporate Sustainability\'). Aligns with SAP S/4HANA CO cost center hierarchy.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressTrackingFrequency rdf:type rdf:Property ;
    rdfs:label 'Progress Tracking Frequency' ;
    rdfs:comment 'The cadence at which progress against this sustainability target is formally measured, reviewed, and reported internally. Drives scheduling of data collection from source systems (SAP S/4HANA, Climate FieldView, John Deere Operations Center) and ESG reporting cycles.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Public Commitment Date' ;
    rdfs:comment 'The date on which the sustainability target was publicly disclosed, such as in an annual ESG report, CDP submission, press release, or GLOBALG.A.P. certification filing. Establishes the accountability start date for external stakeholders and regulators.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reductionPct rdf:type rdf:Property ;
    rdfs:label 'Reduction Pct' ;
    rdfs:comment 'The percentage reduction from baseline value required to achieve the target (e.g., 46.2% for a 1.5°C-aligned SBTi near-term target). Expressed as a positive number representing the reduction magnitude. Derived from baseline and target values but stored explicitly for reporting and SBTi submission.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sbtiCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Sbti Commitment Date' ;
    rdfs:comment 'The date on which the enterprise signed the SBTi commitment letter, pledging to set science-based targets within 24 months. Null if the target is not SBTi-aligned or commitment has not been made.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sbtiValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Sbti Validation Status' ;
    rdfs:comment 'Status of the target\'s formal validation by the Science Based Targets initiative. not_submitted = target not yet sent for SBTi review; submitted = under SBTi review; validated = SBTi has confirmed alignment with 1.5°C or well-below 2°C pathway; committed = company has signed SBTi commitment letter; not_applicable = target category not covered by SBTi (e.g., water, biodiversity).' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCategory rdf:type rdf:Property ;
    rdfs:label 'Target Category' ;
    rdfs:comment 'High-level classification of the sustainability commitment type. Drives reporting structure and alignment framework selection. Values: net_zero (full value chain decarbonization), carbon_neutral (residual offset allowed), water_positive (return more water than consumed), deforestation_free (no conversion of natural ecosystems), biodiversity_net_gain (measurable biodiversity improvement), renewable_energy (100% renewable electricity per RE100).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the sustainability target, used in ESG reports, CDP submissions, and board communications (e.g., ST-NET0001, ST-WATER02). Aligns with TCFD and CDP disclosure frameworks.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDescription rdf:type rdf:Property ;
    rdfs:label 'Target Description' ;
    rdfs:comment 'Detailed narrative description of the sustainability target, including scope boundaries, key assumptions, reduction pathways, and any exclusions. Used in ESG reports, CDP questionnaire responses, and board briefing materials. Supports TCFD strategy and metrics disclosure.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable name of the sustainability target as it appears in public commitments, ESG reports, and board presentations (e.g., \'Net-Zero Scope 1 & 2 Emissions by 2040\', \'Water Positive Operations by 2030\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Specifies whether the target is expressed as an absolute reduction (total emissions/water volume), an intensity metric (per hectare, per metric ton of commodity), a binary commitment (yes/no achievement), or an index-based measure (e.g., NDVI biodiversity index). Critical for SBTi validation and CDP reporting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unSdgGoals rdf:type rdf:Property ;
    rdfs:label 'Un Sdg Goals' ;
    rdfs:comment 'Comma-separated list of UN SDG goal numbers to which this target contributes (e.g., \'2,6,13,15\' for Zero Hunger, Clean Water, Climate Action, Life on Land). Supports ESG reporting and investor disclosure aligned with the UN 2030 Agenda.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'The unit of measurement for both the baseline_value and target_value fields. MT_CO2e = metric tons of CO2 equivalent (GHG); m3 = cubic meters (water); ha = hectares (land/biodiversity); pct = percentage (renewable energy share); MWh = megawatt-hours (energy); intensity units per hectare or per metric ton of commodity. Must align with the reporting framework unit requirements. [ENUM-REF-CANDIDATE: MT_CO2e|m3|ha|pct|MWh|tonne|kg_CO2e_per_ha|kg_CO2e_per_MT|m3_per_ha|index_score — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether third-party independent verification of progress against this target is required (True) or optional (False). Mandatory for SBTi-validated targets, CDP disclosures, and ISCC certification. Drives scheduling of external assurance engagements.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year by which the sustainability target must be achieved. Defines the commitment horizon for board endorsement, public disclosure, and regulatory compliance planning.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetProgressId rdf:type rdf:Property ;
    rdfs:label 'Target Progress Id' ;
    rdfs:comment 'Unique system-generated identifier for each sustainability target progress record. Primary key for the target_progress data product.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributingInitiativeIds rdf:type rdf:Property ;
    rdfs:label 'Contributing Initiative Ids' ;
    rdfs:comment 'Comma-separated list of sustainability initiative or program identifiers (e.g., initiative IDs from the sustainability initiative register) that contributed to the performance recorded in this period. Enables attribution analysis linking operational programs (e.g., cover cropping, precision irrigation, renewable energy procurement) to target progress outcomes.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Value' ;
    rdfs:comment 'Running total of the sustainability metric from the baseline period through the end of this reporting period, expressed in the unit_of_measure. Used for year-to-date and multi-year trend analysis in board reporting and external ESG disclosures.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Expected Period Value' ;
    rdfs:comment 'The planned or modelled value of the sustainability metric for this reporting period based on the linear or science-based reduction pathway defined in the target plan. Compared against current_period_value to determine trajectory_status and variance. Sourced from the sustainability target milestone schedule.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeCommentary rdf:type rdf:Property ;
    rdfs:label 'Narrative Commentary' ;
    rdfs:comment 'Free-text management commentary explaining the current period performance, key drivers of variance from expected values, corrective actions planned, or contextual factors (e.g., drought conditions, supply chain disruptions, new precision agriculture initiatives). Used in board reports, ESG disclosures, and CDP narrative responses.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctOfTargetAchieved rdf:type rdf:Property ;
    rdfs:label 'Pct Of Target Achieved' ;
    rdfs:comment 'Calculated percentage representing how much of the sustainability target has been achieved as of this reporting period, expressed as a decimal (e.g., 0.4250 = 42.50%). Computed as (baseline_value - cumulative_value) / (baseline_value - target_value) for reduction targets, or cumulative_value / target_value for improvement targets. Key KPI for board and ESG reporting.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodOverPeriodChange rdf:type rdf:Property ;
    rdfs:label 'Period Over Period Change' ;
    rdfs:comment 'Absolute change in the sustainability metric between the prior period and the current period (current_period_value minus prior_period_value), expressed in the unit_of_measure. Positive values indicate an increase; negative values indicate a reduction. Used for trend analysis and variance commentary in ESG reports.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressRecordCode rdf:type rdf:Property ;
    rdfs:label 'Progress Record Code' ;
    rdfs:comment 'Externally-known business identifier for this progress record, typically formatted as TP-{TARGET_CODE}-{YEAR}Q{QUARTER} or equivalent period notation. Used in board reports, ESG disclosures, and CDP submissions to uniquely reference a specific progress data point.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementFlag rdf:type rdf:Property ;
    rdfs:label 'Restatement Flag' ;
    rdfs:comment 'Indicates whether this progress record represents a restatement of a previously published value (e.g., due to methodology change, data correction, or boundary adjustment). True = restated value; False = original value. Required for GRI and CDP restatement disclosures and IFRS S1/S2 comparative period adjustments.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMetricName rdf:type rdf:Property ;
    rdfs:label 'Target Metric Name' ;
    rdfs:comment 'Human-readable name of the specific sustainability metric being tracked in this progress record (e.g., \'Scope 1 GHG Emissions\', \'Water Withdrawal Volume\', \'Soil Organic Carbon\', \'Biodiversity Score\'). Provides context for the numeric values without requiring a join to the target master.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trajectoryStatus rdf:type rdf:Property ;
    rdfs:label 'Trajectory Status' ;
    rdfs:comment 'Assessment of whether the sustainability target is on course to be achieved by its deadline based on current progress rate. Values: on_track (progressing as planned), at_risk (lagging but recoverable), off_track (significantly behind), achieved (target met), exceeded (surpassed target), not_started (no progress recorded yet). Primary status indicator for executive dashboards and ESG disclosures.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromExpected rdf:type rdf:Property ;
    rdfs:label 'Variance From Expected' ;
    rdfs:comment 'Difference between the current_period_value and the expected_period_value (current minus expected), expressed in the unit_of_measure. Negative variance for reduction targets indicates better-than-expected performance; positive variance indicates underperformance. Drives trajectory_status classification and management commentary.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationScheme rdf:type rdf:Property ;
    rdfs:label 'Certification Scheme' ;
    rdfs:comment 'Voluntary or mandatory certification program under which this waste event is tracked and reported (e.g., GLOBALG.A.P., ISO 14001, SQF, BRC, ISCC, USDA National Organic Program). Supports multi-scheme compliance management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eEmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Mt' ;
    rdfs:comment 'Estimated greenhouse gas emissions in metric tons of CO2 equivalent (CO2e) associated with this waste disposal event. Calculated based on disposal method emission factors. Feeds into Scope 1/3 GHG inventory.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compostedQuantity rdf:type rdf:Property ;
    rdfs:label 'Composted Quantity' ;
    rdfs:comment 'Quantity of organic waste material directed to composting operations, expressed in quantity_uom. Supports soil health improvement tracking and organic waste diversion reporting.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor Licence Number' ;
    rdfs:comment 'Regulatory licence or registration number of the waste management contractor, issued by the EPA or relevant state environmental agency. Validates contractor compliance for audit purposes.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the licensed waste management contractor or hauler engaged for this waste event. Retained for operational reference and audit purposes alongside the contractor ID.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Primary method used to manage or dispose of the waste material. Supports circular economy tracking and zero-waste-to-landfill commitment reporting. Values align with GRI 306 waste disposal categories.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSiteName rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Name' ;
    rdfs:comment 'Name of the facility, site, or location where the waste was ultimately disposed of, treated, or processed (e.g., composting facility name, landfill name, recycling centre name).' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Pct' ;
    rdfs:comment 'Percentage of total waste generated that was diverted from landfill disposal through composting, recycling, anaerobic digestion, or other beneficial reuse methods. Key KPI for zero-waste-to-landfill commitments and ESG reporting.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyRecoveredKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Recovered Kwh' ;
    rdfs:comment 'Kilowatt-hours of energy recovered from waste through anaerobic digestion, incineration with energy recovery, or other waste-to-energy processes. Supports renewable energy and circular economy reporting.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaWasteCode rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code' ;
    rdfs:comment 'EPA-assigned waste code identifying the specific hazardous or regulated waste stream (e.g., D001 for ignitable waste, F-listed, K-listed, P-listed, or U-listed codes). Required for regulatory manifest and reporting compliance.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the waste event, used for cross-referencing with waste manifests, regulatory submissions, and contractor invoices. Typically sourced from SAP S/4HANA Environmental Compliance module or Granular Farm Management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gri306Category rdf:type rdf:Property ;
    rdfs:label 'Gri 306 Category' ;
    rdfs:comment 'Global Reporting Initiative (GRI) Standard 306 waste disclosure category for this event. Classifies the waste event as total waste generated, diverted from disposal, or directed to disposal for standardised ESG reporting.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingMethod rdf:type rdf:Property ;
    rdfs:label 'Handling Method' ;
    rdfs:comment 'Indicates whether the waste was handled on-site (e.g., on-farm composting, land application), off-site (transported to external facility), or managed by a third-party contractor. Affects regulatory reporting obligations.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Flag' ;
    rdfs:comment 'Indicates whether this waste event is associated with an unplanned or non-compliant waste incident (e.g., spill, illegal dumping, permit exceedance). Triggers incident management workflow and regulatory notification obligations.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landApplicationAreaHa rdf:type rdf:Property ;
    rdfs:label 'Land Application Area Ha' ;
    rdfs:comment 'Area in hectares to which waste material (e.g., manure, biosolids, compost) was applied as a soil amendment. Populated only when disposal_method is land_application. Required for nutrient management planning and EPA/USDA compliance.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutrientContentNpk rdf:type rdf:Property ;
    rdfs:label 'Nutrient Content Npk' ;
    rdfs:comment 'Nitrogen, Phosphorus, and Potassium (NPK) content of organic waste material applied to land (e.g., manure, biosolids). Expressed as percentage or kg/MT. Required for nutrient management plan compliance and soil health tracking.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDisposed rdf:type rdf:Property ;
    rdfs:label 'Quantity Disposed' ;
    rdfs:comment 'Actual quantity of waste material that was disposed of through the recorded disposal method. May differ from quantity_generated if partial disposal occurred or waste was split across multiple disposal methods.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityGenerated rdf:type rdf:Property ;
    rdfs:label 'Quantity Generated' ;
    rdfs:comment 'Total quantity of waste material generated during this event, expressed in the unit of measure specified in quantity_uom. Used for diversion rate calculations, regulatory thresholds, and ESG reporting.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledQuantity rdf:type rdf:Property ;
    rdfs:label 'Recycled Quantity' ;
    rdfs:comment 'Quantity of waste material recovered and sent for recycling or material recovery, expressed in quantity_uom. Supports circular economy metrics and GRI 306 recycling disclosures.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'Regulatory classification of the waste stream indicating whether the waste is hazardous, non-hazardous, universal, or special waste per EPA RCRA definitions. Determines handling, transport, and disposal requirements.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Description' ;
    rdfs:comment 'Detailed narrative description of the waste material, including composition, source process, and any relevant physical or chemical characteristics relevant to safe handling and disposal.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Manifest Number' ;
    rdfs:comment 'Uniform Hazardous Waste Manifest number or equivalent tracking document number accompanying the waste shipment. Required for hazardous waste transport under EPA RCRA regulations.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteSourceProcess rdf:type rdf:Property ;
    rdfs:label 'Waste Source Process' ;
    rdfs:comment 'The agricultural or operational process that generated the waste (e.g., crop harvesting, food processing, packaging operations, pesticide application, irrigation system maintenance). Enables process-level waste reduction analysis.' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Classification of the agricultural waste material generated. Common types include crop residue, packaging waste, agrochemical containers, food processing waste, manure, biosolids, and plastic mulch. [ENUM-REF-CANDIDATE: crop_residue|packaging_waste|agrochemical_container|food_processing_waste|manure|biosolids|plastic_mulch|wastewater_sludge|animal_carcass|electronic_waste — promote to reference product]' ;
    rdfs:domain ind:WasteEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWaterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Water Employee Id' ;
    rdfs:comment 'Identifier of the licensed agronomist or water resource specialist accountable for developing, implementing, and monitoring this water stewardship plan. Links to the workforce/employee record in SAP SuccessFactors.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineAnnualWaterUseM3 rdf:type rdf:Property ;
    rdfs:label 'Baseline Annual Water Use M3' ;
    rdfs:comment 'Total baseline annual water withdrawal volume in cubic meters (m³) for the farm unit or watershed, measured prior to plan implementation. Serves as the denominator for calculating water reduction targets and tracking progress against ESG commitments.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdpWaterCategory rdf:type rdf:Property ;
    rdfs:label 'Cdp Water Category' ;
    rdfs:comment 'CDP (Carbon Disclosure Project) Water Security scoring category assigned to this plan\'s watershed context. Used to benchmark water risk management maturity and guide investor ESG disclosures.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationMeasures rdf:type rdf:Property ;
    rdfs:label 'Conservation Measures' ;
    rdfs:comment 'Free-text description of the specific water conservation practices and Best Management Practices (BMPs) planned under this stewardship plan (e.g., cover cropping, riparian buffers, precision irrigation, soil moisture monitoring). Supports USDA NRCS practice code documentation.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etBasedSchedulingEnabled rdf:type rdf:Property ;
    rdfs:label 'Et Based Scheduling Enabled' ;
    rdfs:comment 'Indicates whether Evapotranspiration (ET)-based irrigation scheduling is implemented for this plan. ET-based scheduling uses crop water demand models to optimize irrigation timing and volume, reducing water waste. Data sourced from Climate FieldView and CIMIS/ASCE ET networks.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hucCode rdf:type rdf:Property ;
    rdfs:label 'Huc Code' ;
    rdfs:comment 'USDA NRCS standardized Hydrologic Unit Code (HUC) identifying the watershed or sub-watershed boundary. Enables spatial joins in Esri ArcGIS and cross-referencing with USDA NRCS conservation program eligibility data.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrigationEfficiencyTargetPct rdf:type rdf:Property ;
    rdfs:label 'Irrigation Efficiency Target Pct' ;
    rdfs:comment 'Target percentage improvement in irrigation application efficiency (e.g., from flood to drip/micro-irrigation) planned under this stewardship plan. Tracked against actual irrigation event data from John Deere Operations Center and Climate FieldView.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrcsPracticeCodes rdf:type rdf:Property ;
    rdfs:label 'Nrcs Practice Codes' ;
    rdfs:comment 'Comma-separated list of USDA Natural Resources Conservation Service (NRCS) conservation practice codes applicable to this plan (e.g., \'449,587,393\' for Irrigation Water Management, Sprinkler System, and Subsurface Drain). Required for EQIP and CSP program enrollment.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedAnnualWithdrawalM3 rdf:type rdf:Property ;
    rdfs:label 'Permitted Annual Withdrawal M3' ;
    rdfs:comment 'Maximum annual water withdrawal volume in cubic meters (m³) authorized under the water use permit. Used to monitor compliance with legal water allocation limits and flag over-withdrawal risk.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the water stewardship plan, used in cross-system references, regulatory submissions, and certification documentation (e.g., WSP-2024-FARM01). Aligns with USDA NRCS and AWS certification tracking requirements.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The date on which the water stewardship plan expires or is scheduled for renewal. Nullable for open-ended plans. Used to trigger renewal workflows and certification re-audit scheduling.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The date on which the water stewardship plan becomes effective and binding for the farm unit or watershed. Marks the beginning of the planning period for target tracking and compliance measurement.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningYear rdf:type rdf:Property ;
    rdfs:label 'Planning Year' ;
    rdfs:comment 'The primary crop/fiscal year (four-digit integer, e.g., 2024) associated with this water stewardship plan. Used for annual ESG reporting cycles, USDA program enrollment, and year-over-year water use benchmarking.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWaterSource rdf:type rdf:Property ;
    rdfs:label 'Primary Water Source' ;
    rdfs:comment 'Classification of the primary water source used for irrigation and farm operations under this plan. Determines applicable regulatory permits (EPA, state water rights), monitoring requirements, and AWS water balance methodology.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riparianBufferPlanned rdf:type rdf:Property ;
    rdfs:label 'Riparian Buffer Planned' ;
    rdfs:comment 'Indicates whether establishment or maintenance of riparian buffer zones is included as a conservation measure in this plan. Riparian buffers reduce agricultural runoff, protect water quality, and support biodiversity. Eligible for USDA NRCS EQIP and CRP cost-share funding.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soilMoistureMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Monitoring Enabled' ;
    rdfs:comment 'Indicates whether real-time soil moisture monitoring via IoT sensors is deployed and active for this plan\'s farm unit. Enables precision irrigation scheduling to reduce over-application and supports Variable Rate Application (VRA) prescriptions in Trimble Ag Software.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPlanAreaHa rdf:type rdf:Property ;
    rdfs:label 'Total Plan Area Ha' ;
    rdfs:comment 'Total land area in hectares (ha) covered by this water stewardship plan. Used to normalize water use intensity metrics (m³/ha) for benchmarking and ESG reporting.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterRecyclingTargetPct rdf:type rdf:Property ;
    rdfs:label 'Water Recycling Target Pct' ;
    rdfs:comment 'Target percentage of total water use to be met through recycled or reclaimed water sources (e.g., tailwater recovery, treated effluent reuse) under this plan. Supports AWS Criterion 4.4 and EPA water reuse guidelines.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterReductionTargetM3 rdf:type rdf:Property ;
    rdfs:label 'Water Reduction Target M3' ;
    rdfs:comment 'Absolute volume of water withdrawal reduction committed under this plan, expressed in cubic meters (m³). Complements the percentage target for absolute reporting in ESG disclosures and USDA NRCS program compliance.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterReductionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Water Reduction Target Pct' ;
    rdfs:comment 'Percentage reduction in total water withdrawal committed under this plan relative to the baseline annual water use (e.g., 15.00 = 15% reduction target). Used in ESG reporting, Science Based Targets for Nature (SBTN), and AWS certification audits.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:watershedName rdf:type rdf:Property ;
    rdfs:label 'Watershed Name' ;
    rdfs:comment 'Name of the watershed, catchment, or hydrologic unit (HUC) that this plan governs. Used for geospatial analysis in Esri ArcGIS, regulatory reporting to EPA, and AWS catchment-level water balance assessments.' ;
    rdfs:domain ind:WaterStewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterUsageId rdf:type rdf:Property ;
    rdfs:label 'Water Usage Id' ;
    rdfs:comment 'Unique system-generated identifier for each water consumption and withdrawal event record in the agricultural enterprise.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evapotranspirationId rdf:type rdf:Property ;
    rdfs:label 'Evapotranspiration Id' ;
    rdfs:comment 'Foreign key linking to weather.evapotranspiration. Business justification: ET calculations are the scientific basis for irrigation water demand in Agriculture. CDP Water (GRI 303) water stewardship reporting requires linking actual water withdrawals to ET-based demand calcul' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Evapotranspiration .

ind:cdpWaterDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Water Disclosure Flag' ;
    rdfs:comment 'Indicates whether this water usage record is included in the annual CDP (Carbon Disclosure Project) Water Security questionnaire disclosure (True) or is excluded from external reporting scope (False). Supports ESG reporting governance.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptiveUseVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Consumptive Use Volume Ml' ;
    rdfs:comment 'Volume of withdrawn water that is consumed and not returned to the source watershed, expressed in megalitres (ML). Calculated as withdrawal volume minus return flow volume. Represents the net water footprint of the operation per ISO 14046.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargePointCode rdf:type rdf:Property ;
    rdfs:label 'Discharge Point Code' ;
    rdfs:comment 'Code identifying the specific location where return flow water is discharged back to the environment (e.g., drainage ditch, river reach, treatment pond outlet). Required for EPA NPDES permit compliance and return flow quality monitoring.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gri303Category rdf:type rdf:Property ;
    rdfs:label 'Gri 303 Category' ;
    rdfs:comment 'GRI Standard 303 disclosure category under which this water record is classified: 303-1 (interactions with water as a shared resource), 303-2 (management of water discharge-related impacts), 303-3 (water withdrawal), 303-4 (water discharge), 303-5 (water consumption). Enables structured ESG reporting alignment.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Meter Device Code' ;
    rdfs:comment 'Unique identifier of the physical flow meter or IoT sensor device used to measure the water withdrawal event. Populated when measurement_method is \'meter\'. Enables traceability to calibration records and device maintenance history.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitAllocationMl rdf:type rdf:Property ;
    rdfs:label 'Permit Allocation Ml' ;
    rdfs:comment 'Maximum annual or seasonal water withdrawal volume authorised under the regulatory permit, expressed in megalitres (ML). Used to track utilisation against entitlement and flag over-abstraction risk.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledWaterFlag rdf:type rdf:Property ;
    rdfs:label 'Recycled Water Flag' ;
    rdfs:comment 'Indicates whether the water used in this event was sourced from on-site or off-site water recycling or reuse systems (True) or from a primary abstraction source (False). Supports circular water economy reporting and AWS Standard water reuse metrics.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnFlowVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Return Flow Volume Ml' ;
    rdfs:comment 'Volume of water returned to the source watershed or a different water body after use, expressed in megalitres (ML). Includes treated wastewater discharge, irrigation drainage, and runoff returned to surface water. Required for net water balance accounting.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterEfficiencyTargetMlHa rdf:type rdf:Property ;
    rdfs:label 'Water Efficiency Target Ml Ha' ;
    rdfs:comment 'Target water application rate per hectare (ML/ha) set for the field or facility for the reporting period, based on crop water demand models or operational benchmarks. Used to measure actual performance against planned efficiency targets.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityClass rdf:type rdf:Property ;
    rdfs:label 'Water Quality Class' ;
    rdfs:comment 'Quality classification of the water withdrawn or used, indicating its fitness for purpose. Potable meets drinking water standards; non-potable is suitable for irrigation or industrial use; recycled is treated effluent; brackish and saline indicate elevated salinity levels relevant to soil health and crop tolerance.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStressBasinCode rdf:type rdf:Property ;
    rdfs:label 'Water Stress Basin Code' ;
    rdfs:comment 'Code identifying the hydrological basin or watershed in which the withdrawal occurred, aligned with WRI Aqueduct or HydroSHEDS basin classification. Used to assess water stress context and prioritise stewardship actions in high-stress basins.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStressLevel rdf:type rdf:Property ;
    rdfs:label 'Water Stress Level' ;
    rdfs:comment 'Categorical water stress classification for the basin where withdrawal occurred, based on WRI Aqueduct or equivalent framework. Drives ESG materiality assessment and CDP Water disclosure context. Values align with WRI Aqueduct five-tier scale.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterUseCategory rdf:type rdf:Property ;
    rdfs:label 'Water Use Category' ;
    rdfs:comment 'Functional category describing the purpose for which water was consumed or withdrawn. Irrigation covers crop field application; livestock watering covers animal husbandry needs; processing covers post-harvest and manufacturing operations; domestic covers sanitation and potable use on-site.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Volume Ml' ;
    rdfs:comment 'Total volume of water physically withdrawn from the source during the reporting period, expressed in megalitres (ML). This is the gross abstraction volume before accounting for return flows or consumptive losses. Core metric for AWS Standard and CDP Water disclosure.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFirstFrostDate rdf:type rdf:Property ;
    rdfs:label 'Avg First Frost Date' ;
    rdfs:comment '30-year average calendar date of the first autumn frost event (temperature ≤0°C) for the station or zone. Critical for determining planting windows, PHI compliance, and crop insurance documentation.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgLastFrostDate rdf:type rdf:Property ;
    rdfs:label 'Avg Last Frost Date' ;
    rdfs:comment '30-year average calendar date of the last spring frost event (temperature ≤0°C) for the station or zone. Defines the safe planting window start and is used in crop variety selection and GLOBALG.A.P. field records.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:climateZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Climate Zone Classification' ;
    rdfs:comment 'Köppen-Geiger climate classification code for the station or zone (e.g., Cfa = humid subtropical, Dfa = humid continental). Used for crop variety suitability mapping and GLOBALG.A.P. environmental risk assessments. [ENUM-REF-CANDIDATE: Af|Am|Aw|BSh|BSk|BWh|BWk|Cfa|Cfb|Cfc|Csa|Csb|Dfa|Dfb|Dfc|ET|EF — promote to reference product]' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtIndexNormal rdf:type rdf:Property ;
    rdfs:label 'Drought Index Normal' ;
    rdfs:comment '30-year average Palmer Drought Severity Index (PDSI) value for the applicable month or season. Negative values indicate drought conditions; used for irrigation planning, WASDE yield estimation inputs, and crop insurance documentation.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etNormalMm rdf:type rdf:Property ;
    rdfs:label 'Et Normal Mm' ;
    rdfs:comment '30-year average reference evapotranspiration (ET₀) in millimetres for the applicable month or season, calculated using FAO-56 Penman-Monteith method. Baseline for irrigation scheduling and water balance modelling.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extremeHeatDaysNormal rdf:type rdf:Property ;
    rdfs:label 'Extreme Heat Days Normal' ;
    rdfs:comment '30-year average number of days per month or season where maximum temperature exceeds the crop-specific heat stress threshold (typically ≥35°C). Used for climate risk scoring and crop insurance actuarial inputs.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extremePrecipDaysNormal rdf:type rdf:Property ;
    rdfs:label 'Extreme Precip Days Normal' ;
    rdfs:comment '30-year average number of days per month or season with precipitation exceeding 25 mm (heavy rain threshold). Used for flood risk assessment, field trafficability planning, and crop loss event documentation.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostFreeDaysNormal rdf:type rdf:Property ;
    rdfs:label 'Frost Free Days Normal' ;
    rdfs:comment '30-year average number of frost-free days in the growing season (between last spring frost and first autumn frost). Determines viable crop maturity window for variety selection.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddBaseTempC rdf:type rdf:Property ;
    rdfs:label 'Gdd Base Temp C' ;
    rdfs:comment 'Base temperature threshold in degrees Celsius used for GDD accumulation calculations in this record (e.g., 10°C for corn, 4.4°C for small grains). Ensures comparability across crop types.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddNormal rdf:type rdf:Property ;
    rdfs:label 'Gdd Normal' ;
    rdfs:comment '30-year average accumulated Growing Degree Days (GDD) for the applicable month or season using the standard base temperature defined in gdd_base_temp_c. Used as baseline for crop phenology prediction and variety selection.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityNormalPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Normal Pct' ;
    rdfs:comment '30-year average relative humidity percentage for the applicable month or season. Used for disease pressure modelling, spray window suitability, and ET calculations.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthNumber rdf:type rdf:Property ;
    rdfs:label 'Month Number' ;
    rdfs:comment 'Calendar month (1=January through 12=December) to which this normal record applies. Null for seasonal or annual normal_type records.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noaaClimateDivision rdf:type rdf:Property ;
    rdfs:label 'Noaa Climate Division' ;
    rdfs:comment 'NOAA-assigned climate division code (state + division number, e.g., \'IL01\') used to aggregate station data to regional climate normals. Supports WASDE regional yield estimation and USDA crop reporting district alignment.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalPeriodEndYear rdf:type rdf:Property ;
    rdfs:label 'Normal Period End Year' ;
    rdfs:comment 'The last calendar year of the 30-year baseline period used to compute this climate normal (e.g., 2020 for the 1991-2020 WMO normal period).' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:normalPeriodStartYear rdf:type rdf:Property ;
    rdfs:label 'Normal Period Start Year' ;
    rdfs:comment 'The first calendar year of the 30-year baseline period used to compute this climate normal (e.g., 1991 for the 1991-2020 WMO normal period).' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:normalStatus rdf:type rdf:Property ;
    rdfs:label 'Normal Status' ;
    rdfs:comment 'Lifecycle status of this climate normal record. Active records are used for operational decisions; superseded records are retained for historical comparison and crop insurance documentation.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalType rdf:type rdf:Property ;
    rdfs:label 'Normal Type' ;
    rdfs:comment 'Temporal granularity of this climate normal record — monthly (one record per calendar month), seasonal (DJF/MAM/JJA/SON), or annual (full-year aggregate).' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipDaysNormal rdf:type rdf:Property ;
    rdfs:label 'Precip Days Normal' ;
    rdfs:comment '30-year average number of days with measurable precipitation (≥0.25 mm) for the applicable month or season. Used for spray window planning and field operation scheduling.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipNormalMm rdf:type rdf:Property ;
    rdfs:label 'Precip Normal Mm' ;
    rdfs:comment '30-year average total precipitation in millimetres for the applicable month or season. Baseline for irrigation scheduling, water resource planning, and crop insurance actuarial calculations.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date on which this climate normal record was officially published or made available for operational use. Used for version control and regulatory audit trails under FSMA and crop insurance documentation requirements.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snowfallNormalMm rdf:type rdf:Property ;
    rdfs:label 'Snowfall Normal Mm' ;
    rdfs:comment '30-year average total snowfall expressed as water equivalent in millimetres for the applicable month or season. Relevant for soil moisture recharge estimation and spring planting window forecasting.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solarRadiationNormalMjM2 rdf:type rdf:Property ;
    rdfs:label 'Solar Radiation Normal Mj M2' ;
    rdfs:comment '30-year average incoming solar radiation in megajoules per square metre per day for the applicable month or season. Required input for FAO-56 Penman-Monteith ET calculations and NDVI baseline modelling.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMeanC rdf:type rdf:Property ;
    rdfs:label 'Temp Mean C' ;
    rdfs:comment '30-year average mean daily temperature in degrees Celsius for the applicable month or season. Core input for GDD accumulation norms and WASDE yield estimation.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedNormalMs rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Normal Ms' ;
    rdfs:comment '30-year average wind speed in metres per second at 2-metre height for the applicable month or season. Used in ET calculations, spray window assessments, and pesticide drift risk modelling per EPA REI guidelines.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmoStationNumber rdf:type rdf:Property ;
    rdfs:label 'Wmo Station Number' ;
    rdfs:comment 'Official WMO 5- or 6-digit station identifier assigned by the World Meteorological Organization. Enables cross-referencing with NOAA NCEI, DTN, and international climate databases for data lineage and audit.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfRecord rdf:type rdf:Property ;
    rdfs:label 'Years Of Record' ;
    rdfs:comment 'Actual number of years of valid observational data used to compute this normal (may be less than 30 if data gaps exist). Values below 25 indicate reduced statistical confidence per WMO guidelines.' ;
    rdfs:domain ind:ClimateNormal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaptationActionRequired rdf:type rdf:Property ;
    rdfs:label 'Adaptation Action Required' ;
    rdfs:comment 'Indicates whether this climate risk assessment has triggered a recommended capital planning or operational adaptation action (e.g., irrigation infrastructure investment, cover crop adoption, drainage improvement).' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentHorizon rdf:type rdf:Property ;
    rdfs:label 'Assessment Horizon' ;
    rdfs:comment 'Time horizon classification for this climate risk assessment, indicating whether it covers a single season, annual, multi-year, or long-range planning period. Supports capital planning and crop insurance alignment.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative confidence level assigned to this climate risk assessment, reflecting data quality, model certainty, and forecast skill. Supports risk management decision-making and insurance underwriting.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtIndexValue rdf:type rdf:Property ;
    rdfs:label 'Drought Index Value' ;
    rdfs:comment 'Standardized drought index value (e.g., Palmer Drought Severity Index or PDSI) for the assessment zone and period. Applicable when risk_type is drought; null otherwise. Supports irrigation scheduling and crop insurance documentation.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ensoPhase rdf:type rdf:Property ;
    rdfs:label 'Enso Phase' ;
    rdfs:comment 'Current El Niño–Southern Oscillation (ENSO) phase influencing the climate risk assessment. ENSO phase is a primary driver of seasonal precipitation and temperature anomalies affecting agricultural production.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedYieldImpactPct rdf:type rdf:Property ;
    rdfs:label 'Estimated Yield Impact Pct' ;
    rdfs:comment 'Estimated percentage reduction in crop yield attributable to the assessed climate risk event, based on historical loss data and agronomic models. Supports crop insurance underwriting and enterprise risk management.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etDeficitMm rdf:type rdf:Property ;
    rdfs:label 'Et Deficit Mm' ;
    rdfs:comment 'Estimated Evapotranspiration (ET) deficit in millimeters for the assessment zone and period, representing the gap between crop water demand and available supply. Supports irrigation scheduling and drought risk assessment.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostRiskDays rdf:type rdf:Property ;
    rdfs:label 'Frost Risk Days' ;
    rdfs:comment 'Number of days within the assessment window with a forecast or historical probability of frost occurrence. Applicable when risk_type is late_frost; supports planting window decisions and crop insurance documentation.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gddDeviation rdf:type rdf:Property ;
    rdfs:label 'Gdd Deviation' ;
    rdfs:comment 'Deviation of accumulated Growing Degree Days (GDD) from the historical average for the assessment period. Supports planting window decisions, crop maturity forecasting, and pest pressure prediction.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hailRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Hail Risk Index' ;
    rdfs:comment 'Composite index score quantifying hail risk for the assessment zone and period, derived from historical hail frequency and storm climatology data. Applicable when risk_type is hail; supports crop insurance underwriting.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:historicalFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Historical Frequency Years' ;
    rdfs:comment 'Average recurrence interval in years for this risk type at this geographic zone, derived from historical climate records. Supports long-term capital planning and crop insurance actuarial analysis.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Code' ;
    rdfs:comment 'Externally-known business identifier code for this climate risk indicator record, used for cross-system reference in FMIS, Granular Farm Management, and crop insurance underwriting workflows.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRelevant rdf:type rdf:Property ;
    rdfs:label 'Insurance Relevant' ;
    rdfs:comment 'Indicates whether this climate risk indicator is relevant for crop insurance claim documentation or underwriting purposes under USDA Risk Management Agency programs.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the climate risk assessment model or algorithm used to generate this indicator record. Supports reproducibility, model governance, and AI/ML lineage tracking.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Occurrence Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that the assessed climate risk event will occur within the valid assessment window. Used in crop insurance underwriting and actuarial modeling.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipAnomalyPct rdf:type rdf:Property ;
    rdfs:label 'Precip Anomaly Pct' ;
    rdfs:comment 'Percentage deviation of observed or forecast precipitation from the long-term historical average for the assessment period and zone. Positive values indicate excess; negative values indicate deficit. Supports flood and drought risk quantification.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Notes' ;
    rdfs:comment 'Free-text field for additional context, qualifications, or observations related to this climate risk indicator record. Supports analyst commentary and audit documentation.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSeverityIndex rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Index' ;
    rdfs:comment 'Quantitative index score representing the severity of the assessed climate risk, typically on a normalized scale (e.g., 0.00–100.00). Drives prioritization in enterprise risk management and capital planning for climate adaptation.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of this climate risk indicator record, indicating whether the risk is actively being monitored, elevated to alert level, resolved, or archived for historical reference.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tempAnomalyC rdf:type rdf:Property ;
    rdfs:label 'Temp Anomaly C' ;
    rdfs:comment 'Deviation of observed or forecast temperature in degrees Celsius from the long-term historical average for the assessment period and zone. Supports heat stress and late frost risk quantification.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasdeOutlookAlignment rdf:type rdf:Property ;
    rdfs:label 'Wasde Outlook Alignment' ;
    rdfs:comment 'Alignment of this climate risk assessment with the USDA World Agricultural Supply and Demand Estimates (WASDE) seasonal outlook for precipitation or temperature. Supports enterprise risk management and long-range planning.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Wind Risk Index' ;
    rdfs:comment 'Composite index score quantifying excessive wind risk for the assessment zone and period. Applicable when risk_type is excessive_wind; supports crop insurance underwriting and spray window planning.' ;
    rdfs:domain ind:ClimateRiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Start date of the period for which this climate risk indicator is considered valid and applicable. Defines the seasonal or long-range assessment window.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'End date of the period for which this climate risk indicator is considered valid. Nullable for open-ended long-range assessments. Supports crop insurance policy period alignment.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmiValue rdf:type rdf:Property ;
    rdfs:label 'Cmi Value' ;
    rdfs:comment 'Crop Moisture Index value measuring short-term moisture conditions critical to crop development. Negative values indicate moisture stress affecting crop growth. Published weekly by USDA and used to assess in-season crop moisture adequacy for irrigation scheduling.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consecutiveDryDays rdf:type rdf:Property ;
    rdfs:label 'Consecutive Dry Days' ;
    rdfs:comment 'Number of consecutive days with precipitation below the dry-day threshold (typically < 1 mm/day). A key indicator of agricultural drought onset and persistence. Used to trigger irrigation scheduling recommendations and crop insurance claim documentation.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:droughtCategory rdf:type rdf:Property ;
    rdfs:label 'Drought Category' ;
    rdfs:comment 'US Drought Monitor (USDM) drought category classification: None = No drought; D0 = Abnormally Dry; D1 = Moderate Drought; D2 = Severe Drought; D3 = Extreme Drought; D4 = Exceptional Drought. Used for USDA disaster designation documentation and federal crop insurance eligibility.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtStatus rdf:type rdf:Property ;
    rdfs:label 'Drought Status' ;
    rdfs:comment 'Current operational status of the drought condition for this record. Indicates whether drought conditions are active, trending toward improvement or deterioration, or have been resolved. Drives alert notifications and irrigation scheduling decisions.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedYieldLossPct rdf:type rdf:Property ;
    rdfs:label 'Estimated Yield Loss Pct' ;
    rdfs:comment 'Estimated percentage reduction in crop yield attributable to drought stress conditions represented by this index record. Used for crop insurance claim documentation, USDA disaster designation support, and financial loss estimation in Granular Farm Management.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etActualMm rdf:type rdf:Property ;
    rdfs:label 'Et Actual Mm' ;
    rdfs:comment 'Actual evapotranspiration in millimeters for the index period, representing the combined water loss from soil evaporation and plant transpiration. Used in soil moisture deficit calculations and drought severity assessments. Sourced from IoT field sensors or DTN weather feeds.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexDate rdf:type rdf:Property ;
    rdfs:label 'Index Date' ;
    rdfs:comment 'Calendar date for which this drought index record is valid. Represents the observation or reporting date used for drought severity assessment and USDA disaster designation documentation.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'Classification of the drought index methodology used for this record. PDSI = Palmer Drought Severity Index; SPI = Standardized Precipitation Index; CMI = Crop Moisture Index; NDVI_STRESS = Normalized Difference Vegetation Index-derived vegetation stress; SPEI = Standardized Precipitation Evapotranspiration Index; EDDI = Evaporative Demand Drought Index.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexValue rdf:type rdf:Property ;
    rdfs:label 'Index Value' ;
    rdfs:comment 'Computed numeric value of the drought index for the specified index_type. For PDSI, ranges approximately -10 (extreme drought) to +10 (extreme wet). For SPI, standardized z-score. For CMI, inches of moisture deficit or surplus. Feeds irrigation scheduling algorithms and crop insurance claim triggers.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimRelevant rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Relevant' ;
    rdfs:comment 'Indicates whether this drought index record meets the threshold criteria to support a crop insurance claim under USDA Risk Management Agency (RMA) policies. True = record qualifies as supporting evidence for an insurance claim filing.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationDeficitMm rdf:type rdf:Property ;
    rdfs:label 'Irrigation Deficit Mm' ;
    rdfs:comment 'Recommended irrigation application amount in millimeters to address the current soil moisture deficit. Computed from the soil moisture deficit adjusted for irrigation efficiency. Used to generate variable rate application (VRA) prescriptions.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrigationRecommended rdf:type rdf:Property ;
    rdfs:label 'Irrigation Recommended' ;
    rdfs:comment 'Indicates whether irrigation is recommended based on the current drought index values and soil moisture deficit. True = irrigation action recommended. Drives automated irrigation scheduling workflows in Trimble Ag Software and John Deere Operations Center.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndviStressIndex rdf:type rdf:Property ;
    rdfs:label 'Ndvi Stress Index' ;
    rdfs:comment 'NDVI-derived vegetation stress indicator computed from satellite or drone imagery. Values range from -1 to +1; lower values indicate greater vegetation stress due to moisture deficit. Integrates with Climate FieldView and Esri ArcGIS for spatial drought impact mapping.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdsiValue rdf:type rdf:Property ;
    rdfs:label 'Pdsi Value' ;
    rdfs:comment 'Palmer Drought Severity Index value for this record period. Ranges from approximately -10 (extreme drought) to +10 (extreme wet conditions). Negative values indicate moisture deficit. Used for USDA disaster designation and crop insurance documentation.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipActualMm rdf:type rdf:Property ;
    rdfs:label 'Precip Actual Mm' ;
    rdfs:comment 'Observed precipitation in millimeters accumulated over the index period. Used as the primary input for SPI and CMI calculations and for comparison against normal precipitation to quantify drought severity.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipDeparturePct rdf:type rdf:Property ;
    rdfs:label 'Precip Departure Pct' ;
    rdfs:comment 'Percentage departure of actual precipitation from the climatological normal for the index period. Negative values indicate below-normal precipitation contributing to drought conditions. Key metric for USDA disaster designation documentation.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilMoistureDeficitMm rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Deficit Mm' ;
    rdfs:comment 'Estimated soil moisture deficit in millimeters representing the amount of water needed to bring soil to field capacity. Derived from water balance calculations incorporating precipitation, evapotranspiration (ET), and runoff. Directly drives variable rate irrigation prescriptions.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spiTimeScaleMonths rdf:type rdf:Property ;
    rdfs:label 'Spi Time Scale Months' ;
    rdfs:comment 'Accumulation period in months over which the SPI value was calculated (e.g., 1, 3, 6, 12, 24 months). Short time scales reflect agricultural drought; longer scales reflect hydrological drought. Required for correct interpretation of the SPI value.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spiValue rdf:type rdf:Property ;
    rdfs:label 'Spi Value' ;
    rdfs:comment 'Standardized Precipitation Index value representing precipitation deficit or surplus as a standardized z-score relative to the historical distribution. Negative values indicate below-normal precipitation. Computed for the SPI time scale specified in spi_time_scale_months.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprayWindowOpen rdf:type rdf:Property ;
    rdfs:label 'Spray Window Open' ;
    rdfs:comment 'Indicates whether current drought and weather conditions support an open spray application window for pesticide or fertilizer application. Drought conditions may affect spray efficacy and drift risk. Integrates with IPM protocols and EPA REI compliance.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tempAvgC rdf:type rdf:Property ;
    rdfs:label 'Temp Avg C' ;
    rdfs:comment 'Mean air temperature in degrees Celsius for the index period. Elevated temperatures accelerate evapotranspiration and exacerbate drought conditions. Used in PDSI and SPEI calculations and for heat stress assessment in conjunction with drought monitoring.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaDisasterDesignation rdf:type rdf:Property ;
    rdfs:label 'Usda Disaster Designation' ;
    rdfs:comment 'Indicates whether the geographic area covered by this drought index record has received or is being considered for a USDA Secretarial Disaster Designation. True = disaster designation active or pending. Enables eligibility tracking for USDA emergency loan programs and FSA assistance.' ;
    rdfs:domain ind:DroughtIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The calendar date for which this evapotranspiration calculation was computed. Represents the real-world observation or forecast date, not the record creation date. Used for daily water balance tracking and irrigation scheduling.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The scientific method used to compute reference evapotranspiration (ETo). Penman-Monteith (FAO-56) is the USDA and FAO standard; Hargreaves is used when solar radiation data is unavailable. Drives traceability and comparability of ET values.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Lifecycle status of this ET calculation record. \'computed\' indicates automated calculation; \'validated\' indicates agronomist review; \'superseded\' indicates a newer recalculation replaced this record; \'error\' indicates a failed computation requiring review.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Precise timestamp when this ET calculation record was computed or ingested into the system. Supports audit trail and distinguishes multiple intraday recalculations for the same date.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cropCoefficient rdf:type rdf:Property ;
    rdfs:label 'Crop Coefficient' ;
    rdfs:comment 'Dimensionless crop coefficient (Kc) applied to reference ET to derive crop-specific ET. Value varies by crop growth stage (initial, mid-season, late-season) per FAO-56 tables. Sourced from crop plan or agronomist input.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropEtMm rdf:type rdf:Property ;
    rdfs:label 'Crop Et Mm' ;
    rdfs:comment 'Crop evapotranspiration (ETc) in millimetres, calculated as ETo × Kc. Represents the actual water demand of the specific crop at its current growth stage. Primary input to irrigation scheduling and water balance calculations.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeEtSeasonMm rdf:type rdf:Property ;
    rdfs:label 'Cumulative Et Season Mm' ;
    rdfs:comment 'Running cumulative crop ET (ETc) in millimetres from the start of the growing season to the calculation date. Used for seasonal water budget tracking, crop insurance documentation, and water use compliance reporting.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeIrrigationSeasonMm rdf:type rdf:Property ;
    rdfs:label 'Cumulative Irrigation Season Mm' ;
    rdfs:comment 'Running cumulative irrigation water applied in millimetres from the start of the growing season to the calculation date. Compared against cumulative ET to assess irrigation efficiency and water use compliance.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivePrecipitationMm rdf:type rdf:Property ;
    rdfs:label 'Effective Precipitation Mm' ;
    rdfs:comment 'The portion of total precipitation credited toward meeting crop ET demand after accounting for runoff, deep percolation, and interception losses. Calculated per USDA SCS method. Reduces the net irrigation requirement.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Frost Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether minimum temperature conditions on the calculation date meet or fall below the frost threshold for the crop type. Triggers frost/freeze alerts in irrigation scheduling systems and supports crop insurance documentation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Mean Temperature C' ;
    rdfs:comment 'Mean daily air temperature in degrees Celsius, calculated as the average of maximum and minimum temperatures. Used in Hargreaves ET method and growing degree day (GDD) accumulation calculations.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipitationMm rdf:type rdf:Property ;
    rdfs:label 'Precipitation Mm' ;
    rdfs:comment 'Total precipitation (rainfall) recorded or forecast for the calculation date in millimetres. Used as a credit against crop ET demand in the daily water balance calculation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedIrrigationAcreIn rdf:type rdf:Property ;
    rdfs:label 'Recommended Irrigation Acre In' ;
    rdfs:comment 'Weather-driven irrigation recommendation expressed in acre-inches per acre, derived from the ET deficit and soil water deficit. Primary output consumed by John Deere Operations Center and Trimble Ag VRA for irrigation scheduling and variable rate application prescriptions.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedIrrigationMm rdf:type rdf:Property ;
    rdfs:label 'Recommended Irrigation Mm' ;
    rdfs:comment 'Weather-driven irrigation recommendation expressed in millimetres, the SI unit equivalent of the acre-inch recommendation. Used for international reporting, water resource compliance, and integration with metric-based irrigation controllers.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceEtMm rdf:type rdf:Property ;
    rdfs:label 'Reference Et Mm' ;
    rdfs:comment 'Reference evapotranspiration (ETo) in millimetres for the calculation date, representing the ET demand of a standardised reference crop (short grass or alfalfa). The foundational output of the Penman-Monteith or Hargreaves equation. Used as the basis for crop-specific ET adjustment.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledIrrigationDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Irrigation Date' ;
    rdfs:comment 'The recommended calendar date on which irrigation should be applied based on the ET-driven water balance calculation. Populated when weather-driven scheduling is active. Null when no irrigation is currently recommended.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledIrrigationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Irrigation Timestamp' ;
    rdfs:comment 'Precise scheduled start date and time for the recommended irrigation event, used when automated irrigation controllers require time-of-day scheduling. Null when only date-level scheduling is active.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:soilMoistureTargetPct rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Target Pct' ;
    rdfs:comment 'Target soil moisture level as a percentage of field capacity for this field and crop stage. Used as the trigger threshold for irrigation scheduling. Typically set between 50–70% of available water capacity depending on crop stress tolerance.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilWaterDeficitMm rdf:type rdf:Property ;
    rdfs:label 'Soil Water Deficit Mm' ;
    rdfs:comment 'Cumulative soil water deficit in millimetres representing the difference between field capacity and current soil moisture content. Positive values indicate irrigation need. Updated daily using the FAO-56 water balance model.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solarRadiationMjM2 rdf:type rdf:Property ;
    rdfs:label 'Solar Radiation Mj M2' ;
    rdfs:comment 'Daily incoming solar radiation in megajoules per square metre (MJ/m²), a primary driver of ET demand in the Penman-Monteith equation. Sourced from weather station pyranometer or estimated from sunshine hours and cloud cover.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprayWindowSuitable rdf:type rdf:Property ;
    rdfs:label 'Spray Window Suitable' ;
    rdfs:comment 'Boolean flag indicating whether weather conditions on the calculation date are suitable for pesticide or fertilizer spray application, based on wind speed, temperature, humidity, and precipitation thresholds. Supports Integrated Pest Management (IPM) and EPA/REI compliance.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vapourPressureDeficitKpa rdf:type rdf:Property ;
    rdfs:label 'Vapour Pressure Deficit Kpa' ;
    rdfs:comment 'Vapour pressure deficit (VPD) in kilopascals, representing the difference between saturated and actual vapour pressure. A key intermediate variable in the Penman-Monteith ET calculation and an indicator of atmospheric drying demand on crops.' ;
    rdfs:domain ind:Evapotranspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterStressIndex rdf:type rdf:Property ;
    rdfs:label 'Water Stress Index' ;
    rdfs:comment 'Dimensionless water stress coefficient (Ks) ranging from 0 to 1, representing the degree of crop water stress due to soil moisture deficit. A value of 1 indicates no stress; values below 1 indicate stress-adjusted ET. Used in FAO-56 dual crop coefficient approach.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cloudCoverPct rdf:type rdf:Property ;
    rdfs:label 'Cloud Cover Pct' ;
    rdfs:comment 'Forecast percentage of sky covered by clouds for the valid period. Influences solar radiation estimates used in ET evapotranspiration calculations and NDVI Normalized Difference Vegetation Index interpretation.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Pct' ;
    rdfs:comment 'Quantitative confidence interval expressed as a percentage (e.g., 90 for a 90% confidence interval) associated with the forecast values. Supports probabilistic risk assessment for crop insurance documentation and WASDE-aligned seasonal outlooks.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dewPointC rdf:type rdf:Property ;
    rdfs:label 'Dew Point C' ;
    rdfs:comment 'Forecast dew point temperature in degrees Celsius for the valid period. Used in disease pressure models (e.g., fungal blight risk) and to assess condensation risk on crops and equipment.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etForecastMm rdf:type rdf:Property ;
    rdfs:label 'Et Forecast Mm' ;
    rdfs:comment 'Forecast reference evapotranspiration (ET) in millimeters for the valid period, calculated using the FAO Penman-Monteith method. Primary input for irrigation scheduling decisions and water resource management in Climate FieldView and Trimble Ag Software.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalForecastRef rdf:type rdf:Property ;
    rdfs:label 'External Forecast Ref' ;
    rdfs:comment 'Externally assigned identifier or reference code from the source forecast provider (e.g., NOAA NWS product ID, DTN forecast package ID, Climate FieldView forecast run ID). Enables traceability back to the originating provider record for dispute resolution and data quality audits.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Temporal resolution and horizon of the forecast record. Hourly forecasts support spray window scheduling; daily and 7-day support planting window decisions; seasonal forecasts align with WASDE outlooks and crop insurance documentation.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeRisk rdf:type rdf:Property ;
    rdfs:label 'Freeze Risk' ;
    rdfs:comment 'Boolean flag indicating whether forecast minimum temperature is at or below -2.2°C (28°F), triggering a hard freeze alert. Distinguishes from frost risk for crop damage severity classification and crop insurance loss event documentation.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frostRisk rdf:type rdf:Property ;
    rdfs:label 'Frost Risk' ;
    rdfs:comment 'Boolean flag indicating whether forecast minimum temperature is at or below 0°C, triggering a frost alert. Supports frost protection decisions including irrigation-based frost protection, smudge pot activation, and harvest acceleration.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gddForecast rdf:type rdf:Property ;
    rdfs:label 'Gdd Forecast' ;
    rdfs:comment 'Forecast growing degree day accumulation for the valid period, calculated from forecast max and min temperatures relative to a crop-specific base temperature. Supports crop development stage prediction, pest emergence timing, and planting window optimization.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:horizonHours rdf:type rdf:Property ;
    rdfs:label 'Horizon Hours' ;
    rdfs:comment 'Number of hours from the issued timestamp to the end of the forecast valid period. Indicates how far into the future the forecast extends, supporting confidence assessment and operational planning lead time.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the forecast was officially issued or published by the source provider. Used to determine forecast freshness and to sequence superseding forecast versions. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:precipAmountMm rdf:type rdf:Property ;
    rdfs:label 'Precip Amount Mm' ;
    rdfs:comment 'Forecast total precipitation amount in millimeters for the valid period. Used for irrigation scheduling decisions, soil moisture modeling, and crop insurance documentation under USDA Risk Management Agency guidelines.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Precip Probability Pct' ;
    rdfs:comment 'Forecast probability of measurable precipitation occurring during the valid period, expressed as a percentage (0–100). Key input for spray window scheduling — high probability suppresses pesticide application recommendations per IPM Integrated Pest Management protocols.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipType rdf:type rdf:Property ;
    rdfs:label 'Precip Type' ;
    rdfs:comment 'Forecast type of precipitation expected during the valid period. Distinguishes rain from snow, hail, or freezing rain, which have different implications for field operations, equipment deployment, and crop damage risk assessment.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDirectionDeg rdf:type rdf:Property ;
    rdfs:label 'Wind Direction Deg' ;
    rdfs:comment 'Forecast prevailing wind direction in meteorological degrees (0–360, where 0/360 = North). Used in spray drift modeling to protect adjacent fields, buffer zones, and sensitive areas per EPA and GLOBALG.A.P. requirements.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windGustKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Gust Kmh' ;
    rdfs:comment 'Forecast maximum wind gust speed in kilometers per hour for the valid period. Used to assess equipment safety thresholds for aerial application and tall crop operations.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Kmh' ;
    rdfs:comment 'Forecast average wind speed in kilometers per hour for the valid period. Critical for spray window determination — wind speeds above threshold trigger spray application restrictions per EPA and REI Restricted Entry Interval guidelines.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringForecastId rdf:type rdf:Property ;
    rdfs:label 'Triggering Forecast Id' ;
    rdfs:comment 'Foreign key linking to weather.forecast. Business justification: Frost alerts are generated when forecast temperatures fall below crop-critical thresholds. Linking frost_alert to the triggering forecast record provides full traceability from alert back to the sourc' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:triggeringObservationId rdf:type rdf:Property ;
    rdfs:label 'Triggering Observation Id' ;
    rdfs:comment 'Foreign key linking to weather.observation. Business justification: Frost alerts can be triggered by observed (actual) temperatures falling below critical thresholds, not just forecast data. frost_alert has observed_low_temp_c which is an observed value. Linking to th' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'Name or identifier of the farm manager, agronomist, or operations staff member who acknowledged the frost alert. Supports accountability tracking and FSMA food safety plan documentation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when a farm manager or agronomist acknowledged receipt of the frost alert. Used for operational response time tracking and compliance documentation under FSMA food safety planning requirements.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert End Timestamp' ;
    rdfs:comment 'Forecast or observed end date and time of the frost or freeze event window. Marks when temperatures are expected to rise above the critical threshold. Used for operational planning and insurance documentation.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertNotes rdf:type rdf:Property ;
    rdfs:label 'Alert Notes' ;
    rdfs:comment 'Free-text field for agronomist or farm manager observations, supplementary meteorological context, protective action outcomes, or post-event damage assessment notes associated with the frost alert.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSource rdf:type rdf:Property ;
    rdfs:label 'Alert Source' ;
    rdfs:comment 'Originating system or data provider that generated the frost alert. DTN (Data Transmission Network) and NWS (National Weather Service) are primary external sources; Climate FieldView and IoT sensors provide field-level triggers; Manual indicates agronomist-entered alerts.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Start Timestamp' ;
    rdfs:comment 'Forecast or observed start date and time of the frost or freeze event window. Used for spray window planning, irrigation frost protection scheduling, and field crew deployment timing.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle state of the frost alert. \'active\' indicates the alert is in effect; \'acknowledged\' means a farm manager has confirmed receipt; \'expired\' means the alert window has passed; \'cancelled\' means the threat did not materialize; \'superseded\' means a newer alert replaced this one.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the frost or freeze alert severity following NWS conventions. \'advisory\' indicates frost possible; \'watch\' indicates conditions favorable for frost/freeze; \'warning\' indicates frost/freeze imminent or occurring; \'freeze_warning\' indicates temperatures at or below 28°F for 2+ hours.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalThresholdTempC rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Temp C' ;
    rdfs:comment 'Crop-specific critical temperature threshold in degrees Celsius below which significant crop damage is expected. Derived from crop type and growth stage; used to determine alert severity and trigger protective actions.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropVulnerabilityRating rdf:type rdf:Property ;
    rdfs:label 'Crop Vulnerability Rating' ;
    rdfs:comment 'Assessed vulnerability of the affected crop to the forecast frost event, combining crop type, growth stage, and forecast temperature. Drives urgency of protective action recommendations and insurance claim pre-notification.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dewPointTempC rdf:type rdf:Property ;
    rdfs:label 'Dew Point Temp C' ;
    rdfs:comment 'Forecast or observed dew point temperature in degrees Celsius. When dew point falls below 0°C, frost deposition on plant surfaces is likely. Critical input for frost type determination and crop damage assessment.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCropLossPct rdf:type rdf:Property ;
    rdfs:label 'Estimated Crop Loss Pct' ;
    rdfs:comment 'Estimated percentage of crop yield loss attributable to the frost event, assessed post-event by agronomists or automated damage models. Used for insurance claim quantification and WASDE impact reporting. Null until post-event assessment is completed.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastLowTempC rdf:type rdf:Property ;
    rdfs:label 'Forecast Low Temp C' ;
    rdfs:comment 'Predicted minimum air temperature in degrees Celsius for the alert period. This is the principal quantitative measurement driving the frost alert. Used to assess crop vulnerability and determine protective action thresholds.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostDurationHours rdf:type rdf:Property ;
    rdfs:label 'Frost Duration Hours' ;
    rdfs:comment 'Expected or observed duration of sub-threshold temperatures in hours. Critical for assessing cumulative crop damage exposure; freeze warnings typically require 2+ hours below 28°F for severe damage classification.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Frost Probability Pct' ;
    rdfs:comment 'Probabilistic forecast of frost occurrence expressed as a percentage (0.00–100.00). Sourced from DTN or NWS ensemble forecast models. Used to calibrate alert urgency and protective action decisions.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostType rdf:type rdf:Property ;
    rdfs:label 'Frost Type' ;
    rdfs:comment 'Classification of the frost event mechanism. \'radiation\' frost occurs on calm, clear nights due to radiative cooling; \'advection\' frost results from cold air mass movement; \'evaporation\' frost occurs due to rapid moisture evaporation. Determines appropriate protective measures.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gddImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Gdd Impact Estimate' ;
    rdfs:comment 'Estimated reduction in Growing Degree Day (GDD) accumulation attributable to the frost event. GDD accumulation drives crop phenology and maturity timing; frost-induced GDD loss affects harvest scheduling and yield forecasting in Climate FieldView.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrigationFrostProtection rdf:type rdf:Property ;
    rdfs:label 'Irrigation Frost Protection' ;
    rdfs:comment 'Indicates whether overhead irrigation frost protection has been recommended or activated for this alert. Irrigation frost protection uses latent heat of freezing water to protect crops; relevant to irrigation scheduling systems.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nwsEventCode rdf:type rdf:Property ;
    rdfs:label 'Nws Event Code' ;
    rdfs:comment 'External reference identifier assigned by the National Weather Service (NWS) to the corresponding official frost or freeze advisory, watch, or warning. Enables cross-referencing with NWS public alert records for regulatory and insurance documentation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedLowTempC rdf:type rdf:Property ;
    rdfs:label 'Observed Low Temp C' ;
    rdfs:comment 'Actual recorded minimum air temperature in degrees Celsius as measured by the weather station or IoT sensor during the frost event. Populated post-event; used for insurance loss documentation and model validation.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skyCondition rdf:type rdf:Property ;
    rdfs:label 'Sky Condition' ;
    rdfs:comment 'Forecast or observed sky cover condition at the time of the frost event. Clear skies promote radiative cooling and increase frost severity; overcast conditions reduce frost risk by trapping longwave radiation.' ;
    rdfs:domain ind:FrostAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulationStatus rdf:type rdf:Property ;
    rdfs:label 'Accumulation Status' ;
    rdfs:comment 'Current lifecycle status of the GDD accumulation record for this crop and field. \'active\' indicates ongoing accumulation; \'paused\' indicates temporary suspension (e.g., dormancy period); \'terminated\' indicates season ended by frost or crop failure; \'completed\' indicates crop reached maturity.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Base Temperature C' ;
    rdfs:comment 'Crop-specific minimum threshold temperature in degrees Celsius below which crop development does not occur. For corn this is typically 10°C (50°F); for wheat 0°C (32°F). Used as the lower bound in GDD calculation.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeGdd rdf:type rdf:Property ;
    rdfs:label 'Cumulative Gdd' ;
    rdfs:comment 'Running total of heat units accumulated from the planting date or season start date through the record date. Used to predict crop development stage and estimate time to maturity.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentGrowthStage rdf:type rdf:Property ;
    rdfs:label 'Current Growth Stage' ;
    rdfs:comment 'Estimated crop development stage derived from cumulative GDD accumulation (e.g., VE, V6, VT, R1, R6 for corn; VC, V1, R1, R7, R8 for soybeans). Used for agronomic decision-making, spray window compliance, and PHI tracking. [ENUM-REF-CANDIDATE: VE|V1|V2|V3|V4|V5|V6|VT|R1|R2|R3|R4|R5|R6|R7|R8 — promote to reference product]' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyGdd rdf:type rdf:Property ;
    rdfs:label 'Daily Gdd' ;
    rdfs:comment 'Heat units accumulated on the record date, calculated as the average of adjusted min/max temperatures minus the base temperature. Negative values are set to zero. Expressed in degree-days (°C-days or °F-days per calculation method).' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGdd30day rdf:type rdf:Property ;
    rdfs:label 'Forecast Gdd 30day' ;
    rdfs:comment 'Projected GDD accumulation over the next 30 calendar days based on extended weather forecast data. Used for medium-term harvest planning, logistics coordination, and crop insurance monitoring.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGdd7day rdf:type rdf:Property ;
    rdfs:label 'Forecast Gdd 7day' ;
    rdfs:comment 'Projected GDD accumulation over the next 7 calendar days based on weather forecast data from DTN or Climate FieldView. Used for short-term irrigation scheduling, spray window planning, and harvest timing decisions.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostEventFlag rdf:type rdf:Property ;
    rdfs:label 'Frost Event Flag' ;
    rdfs:comment 'Indicates whether a frost or freeze event occurred on the record date (minimum temperature at or below 0°C / 32°F). Critical for crop damage assessment, insurance claims, and replanting decisions.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gddPercentileRank rdf:type rdf:Property ;
    rdfs:label 'Gdd Percentile Rank' ;
    rdfs:comment 'Percentile rank of the current cumulative GDD relative to the historical distribution for the same crop, location, and calendar date. A value of 90 means the current season is warmer than 90% of historical seasons. Supports climate risk assessment and crop insurance documentation.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddToEmergence rdf:type rdf:Property ;
    rdfs:label 'Gdd To Emergence' ;
    rdfs:comment 'Crop-specific cumulative GDD milestone required to reach the emergence (VE) growth stage. Used to predict emergence date and validate actual emergence observations against heat unit accumulation.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddToMaturity rdf:type rdf:Property ;
    rdfs:label 'Gdd To Maturity' ;
    rdfs:comment 'Crop-specific cumulative GDD milestone required to reach physiological maturity (black layer for corn, R8 for soybeans). Used for harvest timing decisions, crop insurance documentation, and logistics planning.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddToSilking rdf:type rdf:Property ;
    rdfs:label 'Gdd To Silking' ;
    rdfs:comment 'Crop-specific cumulative GDD milestone required to reach the silking (R1) or equivalent flowering growth stage. Critical for pollination timing, spray window management, and PHI compliance planning.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:historicalAvgGdd rdf:type rdf:Property ;
    rdfs:label 'Historical Avg Gdd' ;
    rdfs:comment 'Long-term historical average cumulative GDD for the same crop, field location, and calendar date, typically based on a 30-year climate normal. Used as the baseline for deviation analysis and climate risk assessment.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:killingFrostFlag rdf:type rdf:Property ;
    rdfs:label 'Killing Frost Flag' ;
    rdfs:comment 'Indicates whether a killing frost event occurred on the record date (minimum temperature at or below -2.2°C / 28°F for a sustained period). A killing frost terminates the growing season and stops GDD accumulation. Triggers crop insurance documentation requirements.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiComplianceStageReached rdf:type rdf:Property ;
    rdfs:label 'Phi Compliance Stage Reached' ;
    rdfs:comment 'Indicates whether the crop has reached the growth stage at which Pre-Harvest Interval (PHI) restrictions for applied agrochemicals become active, as determined by cumulative GDD. Critical for food safety compliance and EPA/FDA regulatory adherence.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Predicted Maturity Date' ;
    rdfs:comment 'Estimated calendar date when the crop will reach physiological maturity based on current cumulative GDD and historical or forecast temperature trends. Supports harvest scheduling and supply chain planning.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'Calendar date for which the daily Growing Degree Day (GDD) value is calculated. Represents the specific day of temperature observation.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureAvgC rdf:type rdf:Property ;
    rdfs:label 'Temperature Avg C' ;
    rdfs:comment 'Mean daily air temperature in degrees Celsius, calculated as the average of the minimum and maximum temperatures for the record date. Intermediate value used in standard GDD calculation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureUnit rdf:type rdf:Property ;
    rdfs:label 'Temperature Unit' ;
    rdfs:comment 'Unit of measure used for all temperature values and GDD calculations in this record. \'celsius\' for metric (°C-days); \'fahrenheit\' for imperial (°F-days). Ensures consistent interpretation across systems and regions.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperThresholdTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Upper Threshold Temperature C' ;
    rdfs:comment 'Crop-specific maximum temperature ceiling in degrees Celsius above which additional heat does not accelerate crop development. For corn this is typically 30°C (86°F). Temperatures above this are capped at this value in modified GDD calculations.' ;
    rdfs:domain ind:GrowingDegreeDay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRecordId rdf:type rdf:Property ;
    rdfs:label 'Insurance Record Id' ;
    rdfs:comment 'Unique surrogate identifier for the certified weather-based crop insurance record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Reference to the indemnity claim this weather record substantiates. A single claim may be supported by multiple weather records covering different event types or date ranges.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsuranceClaim .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Reference to the crop insurance policy under which this weather event record is filed. Links to the policy master for coverage terms, insured acres, and premium details.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsurancePolicy .

ind:adjusterVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjuster Verification Timestamp' ;
    rdfs:comment 'Date and time when the loss adjuster formally verified and certified the weather data in this record. Establishes the official certification date for FCIC compliance.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Free-text notes entered by the loss adjuster or data certifier documenting any qualifications, data quality issues, or special circumstances relevant to the certified weather record.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedPrecipMm rdf:type rdf:Property ;
    rdfs:label 'Certified Precip Mm' ;
    rdfs:comment 'Adjuster-verified total precipitation in millimeters recorded during the event window. This is the official certified value used for indemnity claim processing, distinct from raw station observations.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEndDate rdf:type rdf:Property ;
    rdfs:label 'Event End Date' ;
    rdfs:comment 'Calendar date on which the insured weather event concluded. Together with event_start_date defines the observation window for all certified meteorological measurements in this record.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventStartDate rdf:type rdf:Property ;
    rdfs:label 'Event Start Date' ;
    rdfs:comment 'Calendar date on which the insured weather event began. Used to establish the event window for certified precipitation totals, temperature extremes, and GDD deviation calculations.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frostFreezeFlag rdf:type rdf:Property ;
    rdfs:label 'Frost Freeze Flag' ;
    rdfs:comment 'Indicates whether a frost or freeze event was documented in this record. Activates frost-specific loss adjustment procedures and links to frost_alert records for corroboration.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gddActual rdf:type rdf:Property ;
    rdfs:label 'Gdd Actual' ;
    rdfs:comment 'Actual GDD accumulation recorded for the event period or season to date. Used to assess crop development stage at time of loss and validate indemnity eligibility.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hailEventFlag rdf:type rdf:Property ;
    rdfs:label 'Hail Event Flag' ;
    rdfs:comment 'Indicates whether a hail event was documented during the event window. Triggers hail-specific loss assessment protocols under FCIC crop insurance provisions.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hailStoneSizeCm rdf:type rdf:Property ;
    rdfs:label 'Hail Stone Size Cm' ;
    rdfs:comment 'Maximum observed hail stone diameter in centimeters during the documented hail event. Used to assess crop damage severity and validate hail indemnity claims.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indemnityAmount rdf:type rdf:Property ;
    rdfs:label 'Indemnity Amount' ;
    rdfs:comment 'Calculated indemnity payment amount in USD based on the certified weather data, estimated crop loss percentage, and policy coverage terms. Represents the gross indemnity before any premium offsets.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredAreaHa rdf:type rdf:Property ;
    rdfs:label 'Insured Area Ha' ;
    rdfs:comment 'Total insured area in hectares affected by the documented weather event. Used to calculate indemnity amounts and validate against policy coverage limits.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Insured Party Name' ;
    rdfs:comment 'Legal name of the insured producer or farming entity associated with this weather record. Required for USDA RMA reporting and adjuster correspondence.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Unit Number' ;
    rdfs:comment 'USDA Risk Management Agency unit number identifying the insured unit (basic, optional, enterprise, or whole-farm) within the policy. Required for RMA reporting and actuarial reconciliation.' ;
    rdfs:domain ind:InsuranceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationRateMmHr rdf:type rdf:Property ;
    rdfs:label 'Application Rate Mm Hr' ;
    rdfs:comment 'The rate at which water is applied during the irrigation event, expressed in millimeters per hour. Determines irrigation duration and must not exceed soil infiltration rate to prevent runoff.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationVolumeAcreIn rdf:type rdf:Property ;
    rdfs:label 'Application Volume Acre In' ;
    rdfs:comment 'The recommended volume of water to be applied during this irrigation event, expressed in acre-inches. Derived from the ET deficit calculation and soil moisture target. Standard unit for US agricultural irrigation scheduling.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationVolumeMm rdf:type rdf:Property ;
    rdfs:label 'Application Volume Mm' ;
    rdfs:comment 'The recommended volume of water to be applied during this irrigation event, expressed in millimeters depth equivalent. Metric unit for international reporting and FAO-aligned ET calculations.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Min' ;
    rdfs:comment 'The estimated duration of the irrigation event in minutes, calculated from the recommended application volume and application rate. Used for equipment scheduling and energy cost estimation.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedWaterVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Estimated Water Volume M3' ;
    rdfs:comment 'The total estimated volume of water to be applied during this irrigation event, expressed in cubic meters. Used for water use reporting, permit compliance, and cost accounting.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalScheduleRef rdf:type rdf:Property ;
    rdfs:label 'External Schedule Ref' ;
    rdfs:comment 'The reference identifier from the originating external system (e.g., John Deere Operations Center task ID, Trimble Ag prescription ID, Climate FieldView recommendation ID). Enables bidirectional traceability to source systems.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frostProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Frost Protection Flag' ;
    rdfs:comment 'Indicates whether this irrigation event is scheduled for frost/freeze protection purposes rather than crop water demand. When True, the schedule is triggered by frost alert conditions rather than ET deficit.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generationSource rdf:type rdf:Property ;
    rdfs:label 'Generation Source' ;
    rdfs:comment 'The system or data source that generated this irrigation schedule recommendation. Supports data lineage, audit, and integration traceability across Climate FieldView, Trimble Ag, John Deere Operations Center, and IoT sensor networks. [ENUM-REF-CANDIDATE: climate_fieldview|trimble_ag|john_deere_ops|granular|manual|iot_sensor|dtn_feed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipCreditMm rdf:type rdf:Property ;
    rdfs:label 'Precip Credit Mm' ;
    rdfs:comment 'The effective precipitation credit applied to reduce the irrigation requirement, accounting for forecast precipitation probability and soil infiltration capacity. Expressed in millimeters.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipForecastMm rdf:type rdf:Property ;
    rdfs:label 'Precip Forecast Mm' ;
    rdfs:comment 'The forecasted precipitation amount in millimeters for the scheduling window, sourced from DTN weather feeds or Climate FieldView. Used to calculate precipitation credit and adjust the recommended application volume.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text operational notes entered by the agronomist or farm manager regarding this irrigation schedule, such as equipment constraints, field access issues, or special instructions for the irrigation operator.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known business identifier for the irrigation schedule, used in operational communications, FMIS records, and integration with John Deere Operations Center and Trimble Ag. Format: IRSCHED-YYYY-NNNNNN.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'The projected date and time at which irrigation is scheduled to complete. Used for equipment scheduling, labor planning, and energy cost estimation.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The precise date and time at which irrigation is scheduled to begin. Critical for pivot and drip system automation, labor scheduling, and integration with John Deere Operations Center equipment dispatch.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:soilMoistureCurrentPct rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Current Pct' ;
    rdfs:comment 'The measured or estimated current volumetric soil moisture content at the time the schedule was generated, expressed as a percentage of field capacity. Sourced from IoT field sensors or modeled estimates.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprayWindowConflict rdf:type rdf:Property ;
    rdfs:label 'Spray Window Conflict' ;
    rdfs:comment 'Indicates whether this irrigation schedule conflicts with an active pesticide or fertilizer spray window. When True, irrigation timing may need to be adjusted to avoid diluting chemical applications or violating Restricted Entry Interval (REI) requirements.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterSource rdf:type rdf:Property ;
    rdfs:label 'Water Source' ;
    rdfs:comment 'The source of water used for this irrigation event. Relevant for water rights compliance, cost accounting, and environmental reporting under EPA and state water authority regulations.' ;
    rdfs:domain ind:IrrigationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherStationId rdf:type rdf:Property ;
    rdfs:label 'Weather Station Id' ;
    rdfs:comment 'FK to weather.weather_station.weather_station_id — Every weather observation is captured at a specific station. Without this FK, weather data cannot be attributed to a location — breaking all spatial weather queries and field-level weather correlation' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:barometricPressureHpa rdf:type rdf:Property ;
    rdfs:label 'Barometric Pressure Hpa' ;
    rdfs:comment 'Atmospheric pressure measured during the observation interval, in hectopascals (hPa). Used for weather front detection, storm prediction, and calibration of altitude-adjusted ET calculations. Supports short-term weather forecasting for field operations planning.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this observation record was first ingested and created in the Silver Layer lakehouse. Used for audit trail, data freshness monitoring, and SLA compliance tracking for weather data feeds.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:etMm rdf:type rdf:Property ;
    rdfs:label 'Et Mm' ;
    rdfs:comment 'Reference evapotranspiration (ET₀) calculated for the observation interval using the FAO-56 Penman-Monteith method, in millimeters. SSOT for irrigation scheduling, water balance modeling, and crop water use estimation. Integrates with Climate FieldView and Granular Farm Management irrigation modules.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frostAlert rdf:type rdf:Property ;
    rdfs:label 'Frost Alert' ;
    rdfs:comment 'Boolean flag indicating whether this observation triggered a frost or freeze alert condition (temperature at or below 0°C). Drives automated notifications for frost protection actions (e.g., wind machine activation, irrigation frost protection), crop insurance event documentation, and PHI compliance tracking.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gddBase10C rdf:type rdf:Property ;
    rdfs:label 'Gdd Base10 C' ;
    rdfs:comment 'Growing Degree Day (GDD) accumulation for the observation interval using a base temperature of 10°C, calculated as max(0, (temp_max_c + temp_min_c)/2 - 10). Used for crop phenology tracking, pest emergence prediction, and harvest timing optimization. Standard base for corn and many broadacre crops.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interval rdf:type rdf:Property ;
    rdfs:label 'Interval' ;
    rdfs:comment 'Configured measurement interval for this observation record. Determines the temporal resolution of the time-series data. Supported intervals: 5-minute, 15-minute, hourly, and daily aggregations. Drives GDD and ET calculation granularity.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leafWetnessHours rdf:type rdf:Property ;
    rdfs:label 'Leaf Wetness Hours' ;
    rdfs:comment 'Duration of leaf surface wetness during the observation interval, in hours. Critical input for fungal and bacterial disease pressure models under IPM frameworks (e.g., fire blight, late blight, botrytis). Drives spray timing recommendations and PHI (Pre-Harvest Interval) compliance tracking.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observedAt rdf:type rdf:Property ;
    rdfs:label 'Observed At' ;
    rdfs:comment 'ISO 8601 timestamp of when the meteorological measurement was captured at the sensor or station. This is the principal real-world event time used for time-series analysis, GDD accumulation, ET computation, and crop insurance documentation. Stored in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Free-text notes from the automated QC process or manual data reviewer describing the reason for a suspect, fail, or estimated quality flag. Supports audit trail requirements for crop insurance documentation and FSMA traceability.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorHeightM rdf:type rdf:Property ;
    rdfs:label 'Sensor Height M' ;
    rdfs:comment 'Height above ground level at which atmospheric measurements (temperature, humidity, wind) were captured, in meters. Standard WMO height is 2m for temperature/humidity and 10m for wind. Required for ET calculation height corrections and data quality validation.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snowfallMm rdf:type rdf:Property ;
    rdfs:label 'Snowfall Mm' ;
    rdfs:comment 'Snowfall accumulation during the observation interval expressed as millimeters of water equivalent. Used for spring soil moisture forecasting, field access planning, and crop insurance documentation in winter crop regions.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solarRadiationWm2 rdf:type rdf:Property ;
    rdfs:label 'Solar Radiation Wm2' ;
    rdfs:comment 'Incoming solar radiation (shortwave) measured during the observation interval, in watts per square meter (W/m²). Primary driver of ET (Evapotranspiration) calculations via the Penman-Monteith method and NDVI-based crop growth modeling. Also used for solar energy resource assessment on farm.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp when this observation record was last modified in the Silver Layer, such as after QC correction, status change, or data enrichment. Supports audit trail and change data capture (CDC) for downstream consumers.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windGustMs rdf:type rdf:Property ;
    rdfs:label 'Wind Gust Ms' ;
    rdfs:comment 'Maximum instantaneous wind gust speed recorded during the observation interval, in meters per second. Used for equipment safety alerts, spray application go/no-go decisions, and crop lodging risk assessment.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agronomistApproved rdf:type rdf:Property ;
    rdfs:label 'Agronomist Approved' ;
    rdfs:comment 'Indicates whether a certified agronomist has reviewed and approved this planting window recommendation before it is used for operational planting decisions. Required for compliance with GLOBALG.A.P. and internal Good Agricultural Practices (GAP) protocols.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:airTempMaxForecastC rdf:type rdf:Property ;
    rdfs:label 'Air Temp Max Forecast C' ;
    rdfs:comment 'Forecast maximum air temperature in degrees Celsius for the planting window period. Used to assess heat stress risk and optimal growing degree day (GDD) accumulation potential during early crop establishment.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airTempMinForecastC rdf:type rdf:Property ;
    rdfs:label 'Air Temp Min Forecast C' ;
    rdfs:comment 'Forecast minimum air temperature in degrees Celsius for the planting window period. Used to assess frost risk and cold stress potential for newly planted seeds and emerging seedlings.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculated Timestamp' ;
    rdfs:comment 'The date and time when this planting window record was first calculated and created in the system. Serves as the principal business event timestamp for the planting window lifecycle.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fieldAreaHa rdf:type rdf:Property ;
    rdfs:label 'Field Area Ha' ;
    rdfs:comment 'Total plantable area of the field in hectares applicable to this planting window. Used for seed quantity calculations, equipment scheduling, and labor resource planning.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPlantingDate rdf:type rdf:Property ;
    rdfs:label 'Final Planting Date' ;
    rdfs:comment 'The USDA Risk Management Agency (RMA) designated final planting date for the primary crop type in this geographic area. Planting after this date may result in reduced crop insurance coverage or late-planting payment reductions.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days ahead from the calculation timestamp that the weather forecast data covers. Shorter horizons (1–7 days) yield higher confidence planting windows; longer horizons (8–14+ days) are used for preliminary planning.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frostRiskProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Frost Risk Probability Pct' ;
    rdfs:comment 'Estimated probability (0–100%) of a frost event occurring during the planting window period. Derived from forecast minimum temperatures and historical climatological data. High frost risk may delay planting of frost-sensitive crops.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddOutlook rdf:type rdf:Property ;
    rdfs:label 'Gdd Outlook' ;
    rdfs:comment 'Forecast accumulated Growing Degree Days (GDD) expected during the planting window period, calculated using the standard base temperature method. Supports crop maturity scheduling and hybrid/variety selection decisions.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrigationRequired rdf:type rdf:Property ;
    rdfs:label 'Irrigation Required' ;
    rdfs:comment 'Indicates whether supplemental irrigation is recommended prior to or during the planting window to achieve adequate soil moisture for seed germination. Derived from soil moisture levels and evapotranspiration (ET) forecast.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCropTypes rdf:type rdf:Property ;
    rdfs:label 'Recommended Crop Types' ;
    rdfs:comment 'Comma-separated list of crop types agronomically recommended for planting during this window based on soil temperature, moisture, and forecast conditions (e.g., \'corn,soybean,wheat\'). Supports crop planning and seed procurement decisions.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilTemp2inC rdf:type rdf:Property ;
    rdfs:label 'Soil Temp 2in C' ;
    rdfs:comment 'Measured or forecast soil temperature at 2-inch (5 cm) depth in degrees Celsius at the time of window calculation. Critical threshold indicator for seed germination viability, particularly for corn (minimum 10°C) and soybean (minimum 12°C).' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilTemp4inC rdf:type rdf:Property ;
    rdfs:label 'Soil Temp 4in C' ;
    rdfs:comment 'Measured or forecast soil temperature at 4-inch (10 cm) depth in degrees Celsius at the time of window calculation. Provides a more stable and agronomically representative temperature reading for seed placement depth decisions.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficabilityScore rdf:type rdf:Property ;
    rdfs:label 'Trafficability Score' ;
    rdfs:comment 'Composite score (0.00–10.00) representing the ability of the field to support heavy planting equipment without causing soil compaction or rutting. Derived from soil moisture, soil texture, and recent precipitation data. Scores below 5.0 indicate high compaction risk.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowDurationDays rdf:type rdf:Property ;
    rdfs:label 'Window Duration Days' ;
    rdfs:comment 'Total number of calendar days in the planting window from start date to end date inclusive. Used for scheduling labor, equipment, and seed delivery logistics.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowEndDate rdf:type rdf:Property ;
    rdfs:label 'Window End Date' ;
    rdfs:comment 'The last date of the calculated optimal planting window, representing the latest date on which planting is agronomically recommended before yield penalties or crop development risks increase significantly.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowNumber rdf:type rdf:Property ;
    rdfs:label 'Window Number' ;
    rdfs:comment 'Externally-known business identifier for the planting window, used in Farm Management Information System (FMIS) references and field operations documentation. Format: PW-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStartDate rdf:type rdf:Property ;
    rdfs:label 'Window Start Date' ;
    rdfs:comment 'The first date of the calculated optimal planting window, representing the earliest date on which field conditions meet all agronomic thresholds for planting operations to commence.' ;
    rdfs:domain ind:PlantingWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle state of the planting window record, indicating whether it is in draft calculation, open for scheduling, actively being used for planting operations, closed after the window has passed, or cancelled due to adverse conditions.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Classification of the planting window quality tier. Optimal windows meet all agronomic thresholds; acceptable windows meet minimum thresholds with minor risk; marginal windows carry elevated yield risk; emergency windows are used only when seasonal deadlines force planting under suboptimal conditions.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedAcreage rdf:type rdf:Property ;
    rdfs:label 'Affected Acreage' ;
    rdfs:comment 'Estimated total acreage impacted by this precipitation event. Used for USDA disaster reporting, crop insurance claim quantification, and field-level damage assessment prioritization.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beaufortScale rdf:type rdf:Property ;
    rdfs:label 'Beaufort Scale' ;
    rdfs:comment 'Beaufort wind force scale classification (0–12) derived from sustained wind speed. Provides standardized wind severity classification for spray window invalidation, equipment operation decisions, and insurance documentation.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cropDamageSeverity rdf:type rdf:Property ;
    rdfs:label 'Crop Damage Severity' ;
    rdfs:comment 'Categorical assessment of estimated crop damage severity resulting from this precipitation event. Used for USDA disaster reporting, crop insurance claim documentation, and yield loss forecasting. Severity is assessed based on storm type, hail size, wind speed, and affected crop growth stage.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropLodgingRisk rdf:type rdf:Property ;
    rdfs:label 'Crop Lodging Risk' ;
    rdfs:comment 'Indicates whether wind speed and precipitation conditions during this event meet or exceed thresholds associated with crop lodging (stem breakage or root displacement). True triggers agronomic review and potential yield loss assessment.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalEventRef rdf:type rdf:Property ;
    rdfs:label 'External Event Ref' ;
    rdfs:comment 'External system identifier for this event as assigned by the source system (e.g., DTN event ID, NWS storm report number, Climate FieldView event key). Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hailDensityStonesSqft rdf:type rdf:Property ;
    rdfs:label 'Hail Density Stones Sqft' ;
    rdfs:comment 'Estimated number of hail stones per square foot observed during the event. Combined with hail stone size to determine crop damage severity and insurance claim trigger eligibility. Null when precip_type is not hail or mixed.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hailStoneSizeIn rdf:type rdf:Property ;
    rdfs:label 'Hail Stone Size In' ;
    rdfs:comment 'Maximum observed hail stone diameter in inches during the event. Used to assess structural damage risk to crops, equipment, and infrastructure. Null when precip_type is not hail or mixed.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimTrigger rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Trigger' ;
    rdfs:comment 'Indicates whether this precipitation event meets the threshold criteria to trigger a crop insurance claim under the applicable USDA RMA policy. True initiates the insurance claim documentation workflow and notifies the risk management team.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Irrigation Adjustment Required' ;
    rdfs:comment 'Indicates whether this precipitation event requires adjustment to the active irrigation schedule. True triggers review of ET (Evapotranspiration) balance and irrigation prescription update in the FMIS (Farm Management Information System).' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipIntensityPeakMmHr rdf:type rdf:Property ;
    rdfs:label 'Precip Intensity Peak Mm Hr' ;
    rdfs:comment 'Maximum instantaneous precipitation rate in millimeters per hour recorded during the event. High peak intensity values indicate elevated runoff risk, soil erosion potential, and spray drift invalidation conditions.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipTotalMm rdf:type rdf:Property ;
    rdfs:label 'Precip Total Mm' ;
    rdfs:comment 'Total accumulated precipitation depth in millimeters recorded during the event. Primary quantitative outcome used for irrigation scheduling adjustments, runoff estimation, soil saturation assessment, and USDA disaster reporting thresholds.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runoffEstimateMm rdf:type rdf:Property ;
    rdfs:label 'Runoff Estimate Mm' ;
    rdfs:comment 'Estimated surface water runoff depth in millimeters generated by this precipitation event, calculated using USDA NRCS curve number methodology. Used for soil erosion assessment, nutrient loss estimation, and BMP (Best Management Practices) compliance reporting.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilSaturationIndex rdf:type rdf:Property ;
    rdfs:label 'Soil Saturation Index' ;
    rdfs:comment 'Dimensionless index (0.00–1.00) representing estimated soil water saturation level following this precipitation event. Values approaching 1.00 indicate near-full saturation, triggering trafficability restrictions and irrigation suspension. Derived from precipitation total, soil type, and antecedent moisture conditions.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprayDriftRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Spray Drift Risk Level' ;
    rdfs:comment 'Categorical assessment of spray drift risk based on wind speed, wind direction, and precipitation conditions during the event. Used to invalidate spray windows and ensure compliance with EPA pesticide application restrictions and REI (Restricted Entry Interval) requirements.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprayWindowInvalidated rdf:type rdf:Property ;
    rdfs:label 'Spray Window Invalidated' ;
    rdfs:comment 'Indicates whether this precipitation event has invalidated one or more planned spray application windows. True triggers re-scheduling of pesticide or fertilizer applications and PHI (Pre-Harvest Interval) recalculation.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stormTrackPath rdf:type rdf:Property ;
    rdfs:label 'Storm Track Path' ;
    rdfs:comment 'GIS-encoded storm track path as a WKT (Well-Known Text) LineString representing the movement trajectory of the storm system across the geographic area. Used for spatial analysis of multi-field impact assessment in Esri ArcGIS.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormType rdf:type rdf:Property ;
    rdfs:label 'Storm Type' ;
    rdfs:comment 'Meteorological classification of the storm system producing the precipitation event. Convective storms are associated with thunderstorms and rapid intensity; frontal storms are associated with weather front passages; orographic storms result from terrain-forced uplift. Used for pest pressure prediction and crop insurance documentation. [ENUM-REF-CANDIDATE: convective|frontal|orographic|tropical|extratropical|monsoonal — promote to reference product]' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralDamageRisk rdf:type rdf:Property ;
    rdfs:label 'Structural Damage Risk' ;
    rdfs:comment 'Indicates whether the combination of wind gust speed, hail size, and precipitation intensity during this event poses a risk of structural damage to farm buildings, grain storage, irrigation infrastructure, or equipment. True triggers facility inspection workflow.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficabilityRestricted rdf:type rdf:Property ;
    rdfs:label 'Trafficability Restricted' ;
    rdfs:comment 'Indicates whether field trafficability is restricted following this precipitation event due to soil saturation or standing water conditions. True prevents heavy equipment entry and triggers field access hold in the John Deere Operations Center fleet management workflow.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usdaDisasterReportable rdf:type rdf:Property ;
    rdfs:label 'Usda Disaster Reportable' ;
    rdfs:comment 'Indicates whether this precipitation event qualifies for USDA disaster program reporting under FSA emergency programs. True triggers submission to the USDA Farm Service Agency disaster reporting workflow.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windGustPeakMph rdf:type rdf:Property ;
    rdfs:label 'Wind Gust Peak Mph' ;
    rdfs:comment 'Maximum instantaneous wind gust speed in miles per hour recorded during the event. Used to assess crop lodging risk, spray drift risk, structural damage risk, and Beaufort scale classification.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedSustainedMph rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Sustained Mph' ;
    rdfs:comment 'Average sustained wind speed in miles per hour over the event duration. Used alongside peak gust for Beaufort classification, spray window assessment, and crop lodging risk evaluation.' ;
    rdfs:domain ind:PrecipitationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorCalibrationId rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Id' ;
    rdfs:comment 'Unique surrogate identifier for each sensor calibration record in the weather domain. Primary key for the sensor_calibration data product.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceStandardId rdf:type rdf:Property ;
    rdfs:label 'Reference Standard Id' ;
    rdfs:comment 'Identifier of the NIST-traceable or certified reference standard instrument used during calibration. Required for ISO/IEC 17025 compliance and regulatory audit documentation.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationStandard .

ind:sensorId rdf:type rdf:Property ;
    rdfs:label 'Sensor Id' ;
    rdfs:comment 'Reference to the IoT field weather sensor or weather station instrument that was calibrated. Links to the sensor master record.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sensor .

ind:adjustmentApplied rdf:type rdf:Property ;
    rdfs:label 'Adjustment Applied' ;
    rdfs:comment 'Indicates whether a physical or electronic offset adjustment was applied to the sensor during this calibration event. Distinguishes verification-only calibrations from those requiring corrective adjustment.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'The magnitude of the offset or correction applied to the sensor during calibration. Expressed in the same unit as measurement_unit. Used to retroactively correct historical sensor readings affected by drift.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedObservationStartDate rdf:type rdf:Property ;
    rdfs:label 'Affected Observation Start Date' ;
    rdfs:comment 'The earliest date from which historical weather observations may have been affected by sensor drift, typically the date of the previous calibration. Used to scope data quality remediation and insurance claim documentation.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ambientHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Ambient Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage recorded at the calibration site at the time of the procedure. Environmental conditions are documented per ISO/IEC 17025 to validate calibration validity.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'Ambient air temperature in degrees Celsius recorded at the time and location of calibration. Environmental conditions can affect sensor readings and calibration accuracy; required for ISO/IEC 17025 calibration certificates.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationLocation rdf:type rdf:Property ;
    rdfs:label 'Calibration Location' ;
    rdfs:comment 'Indicates where the calibration was physically performed. \'field_in_situ\' means the sensor was calibrated at its installed location; \'laboratory\' means it was removed and bench-tested; \'manufacturer_depot\' means returned to the OEM.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNotes rdf:type rdf:Property ;
    rdfs:label 'Calibration Notes' ;
    rdfs:comment 'Free-text field for the calibration technician to record observations, anomalies, corrective actions taken, or any deviations from standard procedure during the calibration event.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Number' ;
    rdfs:comment 'Externally-known unique business identifier for this calibration event, formatted as CAL-YYYY-NNNNNN. Used for regulatory documentation, insurance claims, and audit trail references.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationResult rdf:type rdf:Property ;
    rdfs:label 'Calibration Result' ;
    rdfs:comment 'Overall outcome of the calibration procedure. \'pass\' indicates sensor is within tolerance without adjustment; \'pass_with_adjustment\' indicates within tolerance after correction; \'fail\' indicates sensor could not be brought within tolerance and must be decommissioned or replaced.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration Timestamp' ;
    rdfs:comment 'Precise date and time at which the calibration procedure was executed, including timezone offset. Supports audit trail and regulatory documentation requirements.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Impact Flag' ;
    rdfs:comment 'Indicates whether the pre-calibration drift was significant enough to have materially impacted the quality of historical weather observations recorded since the last calibration. True triggers a data quality review and potential retroactive correction of affected records.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Documentation Flag' ;
    rdfs:comment 'Indicates whether this calibration record is required as supporting documentation for a crop insurance claim. When True, the record must be retained per USDA Risk Management Agency documentation requirements.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Tolerance Flag' ;
    rdfs:comment 'Indicates whether the sensor reading remained outside the acceptable tolerance range after calibration adjustment. True triggers a corrective action workflow, sensor quarantine, and data quality review for affected historical observations. Critical for regulatory and insurance documentation.' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postCalibrationError rdf:type rdf:Property ;
    rdfs:label 'Post Calibration Error' ;
    rdfs:comment 'Calculated difference between the post-calibration sensor reading and the reference standard reading. Confirms whether the calibration adjustment brought the sensor within acceptable tolerance.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preCalibrationError rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Error' ;
    rdfs:comment 'Calculated difference between the pre-calibration sensor reading and the reference standard reading. Quantifies sensor drift prior to adjustment. Used for data quality assessment of historical weather observations.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorManufacturer rdf:type rdf:Property ;
    rdfs:label 'Sensor Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the sensor instrument. Used for vendor management, warranty claims, and equipment lifecycle tracking.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorModel rdf:type rdf:Property ;
    rdfs:label 'Sensor Model' ;
    rdfs:comment 'Model designation of the sensor instrument as specified by the manufacturer. Supports calibration procedure selection and spare parts management.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Sensor Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number of the sensor instrument. Used for equipment traceability, warranty management, and regulatory documentation. Aligns with SAP PM Equipment master serial number.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Classification of the IoT field sensor or weather station instrument being calibrated. Determines applicable calibration standards, tolerance ranges, and measurement units. [ENUM-REF-CANDIDATE: temperature|humidity|precipitation|wind_speed|wind_direction|soil_moisture|soil_temperature|solar_radiation|barometric_pressure|leaf_wetness — promote to reference product]' ;
    rdfs:domain ind:Weather ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Professional certification or qualification number of the calibration technician. Validates that the individual performing calibration meets required competency standards per ISO/IEC 17025.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the technician who performed the calibration. Retained for regulatory documentation and audit purposes where a named individual must be identified on calibration certificates.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'The minimum acceptable deviation from the reference standard reading. If the post-calibration reading falls below this limit, the sensor is flagged as out-of-tolerance and requires corrective action.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'The maximum acceptable deviation from the reference standard reading. If the post-calibration reading exceeds this limit, the sensor is flagged as out-of-tolerance and requires corrective action.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'SAP Plant Maintenance (PM) work order number associated with this calibration event. Provides traceability to the maintenance planning and cost tracking system.' ;
    rdfs:domain ind:SensorCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientAirTempC rdf:type rdf:Property ;
    rdfs:label 'Ambient Air Temp C' ;
    rdfs:comment 'Concurrent ambient air temperature in degrees Celsius recorded at the same station at the time of the soil temperature reading. Provides context for soil-air temperature differential analysis and frost risk assessment.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthCm rdf:type rdf:Property ;
    rdfs:label 'Depth Cm' ;
    rdfs:comment 'Depth below soil surface at which the temperature measurement was taken, expressed in centimetres. Standard agricultural depths include 5 cm (2-inch), 10 cm (4-inch), 15 cm (6-inch), and 30 cm (12-inch). Critical for seed germination prediction and soil biological activity assessment.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthInches rdf:type rdf:Property ;
    rdfs:label 'Depth Inches' ;
    rdfs:comment 'Depth below soil surface at which the temperature measurement was taken, expressed in inches (US customary). Common agricultural reference depths: 2-inch, 4-inch, 6-inch, 12-inch. Stored alongside cm value to support both US and metric reporting.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecReadingDsM rdf:type rdf:Property ;
    rdfs:label 'Ec Reading Ds M' ;
    rdfs:comment 'Electrical Conductivity (EC) co-reading captured simultaneously with the soil temperature measurement, expressed in deciSiemens per metre (dS/m). Available on multi-parameter sensors. EC indicates soil salinity and moisture levels, complementing temperature data for soil health assessment and irrigation scheduling.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gddContribution rdf:type rdf:Property ;
    rdfs:label 'Gdd Contribution' ;
    rdfs:comment 'Growing Degree Day (GDD) contribution calculated from this soil temperature reading relative to the configured base temperature. Supports cumulative GDD accumulation tracking for crop development stage prediction and planting window determination.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementIntervalMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Min' ;
    rdfs:comment 'Configured interval in minutes between successive soil temperature readings from this sensor. Common values: 15, 30, 60 minutes. Used to identify gaps in the time series and validate reading frequency against sensor configuration.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plantingWindowSuitable rdf:type rdf:Property ;
    rdfs:label 'Planting Window Suitable' ;
    rdfs:comment 'Indicates whether the soil temperature at this reading meets the minimum threshold for planting the associated crop type. Derived from crop-specific germination temperature requirements. Supports planting window determination and field operations scheduling.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Calendar date of the soil temperature reading (yyyy-MM-dd). Used for daily aggregation, GDD accumulation calculations, and planting window reporting without requiring timestamp precision.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Quality status of the soil temperature reading indicating whether the value is usable for agronomic decisions. \'valid\' = passed all QC checks; \'suspect\' = flagged for review; \'invalid\' = failed QC; \'missing\' = no data received; \'estimated\' = gap-filled or interpolated value.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilTypeCode rdf:type rdf:Property ;
    rdfs:label 'Soil Type Code' ;
    rdfs:comment 'USDA soil texture classification code for the measurement location (e.g., SaL = Sandy Loam, SiCL = Silty Clay Loam). Soil type affects thermal conductivity and temperature dynamics. Supports soil-adjusted agronomic modelling.' ;
    rdfs:domain ind:SoilTemperature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferZoneM rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone M' ;
    rdfs:comment 'Required no-spray buffer zone distance in metres from field edge to sensitive areas, as determined by product label, EPA registration, and state regulations for this spray window. Operationally enforced during application.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deltaTValue rdf:type rdf:Property ;
    rdfs:label 'Delta T Value' ;
    rdfs:comment 'Delta-T (ΔT) is the difference between dry-bulb and wet-bulb temperatures in degrees Celsius, used as the primary indicator of spray droplet evaporation rate and application suitability. Optimal Delta-T range is typically 2–8°C; values outside this range indicate poor spray conditions.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaDriftConstraint rdf:type rdf:Property ;
    rdfs:label 'Epa Drift Constraint' ;
    rdfs:comment 'Indicates whether EPA drift reduction regulatory constraints are active for this spray window, based on proximity to sensitive areas (water bodies, schools, residential zones) and product-specific drift management requirements under EPA 40 CFR Part 170.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalWindowRef rdf:type rdf:Property ;
    rdfs:label 'External Window Ref' ;
    rdfs:comment 'Reference identifier from the originating external system (Climate FieldView, DTN, Trimble Ag Software) for this spray window record. Supports data lineage, reconciliation, and audit traceability back to the source system.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastHorizonHours rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Hours' ;
    rdfs:comment 'Number of hours ahead from the calculation timestamp that this spray window is forecast for. Shorter horizons indicate higher confidence; longer horizons are used for advance planning. Null for observation-based windows.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:humidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Pct' ;
    rdfs:comment 'Maximum relative humidity percentage during the spray window. Excessively high humidity can reduce product efficacy for certain fungicides and herbicides and may indicate inversion risk conditions.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Pct' ;
    rdfs:comment 'Minimum relative humidity percentage during the spray window. Low humidity increases evaporation of spray droplets, reducing efficacy and increasing drift risk. Label compliance thresholds typically specify minimum humidity levels.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inversionRisk rdf:type rdf:Property ;
    rdfs:label 'Inversion Risk' ;
    rdfs:comment 'Indicates whether atmospheric temperature inversion conditions are present or forecast during the spray window. Temperature inversions trap spray droplets near the ground and cause unpredictable drift; most regulatory bodies and labels prohibit spraying during inversion conditions.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipmPestPressure rdf:type rdf:Property ;
    rdfs:label 'Ipm Pest Pressure' ;
    rdfs:comment 'Integrated Pest Management (IPM) pest pressure classification at the time of the spray window, used to determine application urgency and prioritise scheduling within available windows. Derived from scouting observations and GDD-based pest models.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCompliant rdf:type rdf:Property ;
    rdfs:label 'Label Compliant' ;
    rdfs:comment 'Indicates whether all meteorological conditions within this spray window satisfy the agrochemical product label requirements for application (wind speed, temperature, humidity, Delta-T, precipitation-free period). Master compliance flag for regulatory audit purposes.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipFreeHours rdf:type rdf:Property ;
    rdfs:label 'Precip Free Hours' ;
    rdfs:comment 'Minimum number of hours without precipitation required after application for the planned agrochemical product to achieve label-specified efficacy. Sourced from product label requirements and used to validate window suitability.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitiveAreaProximityM rdf:type rdf:Property ;
    rdfs:label 'Sensitive Area Proximity M' ;
    rdfs:comment 'Distance in metres from the field boundary to the nearest sensitive area (water body, school, residential zone, organic buffer zone). Used to apply appropriate buffer zone restrictions and drift management requirements.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateDriftConstraint rdf:type rdf:Property ;
    rdfs:label 'State Drift Constraint' ;
    rdfs:comment 'Indicates whether state-level pesticide drift regulations impose additional constraints on this spray window beyond federal EPA requirements. State regulations may be more restrictive than federal standards.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windSpeedMaxKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Max Kmh' ;
    rdfs:comment 'Maximum observed or forecast wind speed in kilometres per hour during the spray window period. Exceeding label-specified maximum wind speed thresholds triggers window closure to prevent off-target drift.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedMinKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Min Kmh' ;
    rdfs:comment 'Minimum observed or forecast wind speed in kilometres per hour during the spray window period. Used to assess drift risk and label compliance; most pesticide labels require a minimum wind speed to ensure adequate air movement.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowDurationMin rdf:type rdf:Property ;
    rdfs:label 'Window Duration Min' ;
    rdfs:comment 'Calculated duration of the spray window in minutes, derived from window_start and window_end. Stored for operational scheduling and equipment dispatch planning without requiring runtime calculation.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowEnd rdf:type rdf:Property ;
    rdfs:label 'Window End' ;
    rdfs:comment 'The datetime marking the close of the meteorologically permissible application window. Spray operations must cease by this time to remain within label-compliant and regulatory-compliant conditions.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Window Reference Code' ;
    rdfs:comment 'Externally-known business identifier for this spray window record, used in crop protection planning workflows, application scheduling, and audit documentation. Format: SW- followed by alphanumeric characters.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowSource rdf:type rdf:Property ;
    rdfs:label 'Window Source' ;
    rdfs:comment 'Indicates whether this spray window was calculated from forecast weather data, actual observed data, manually entered conditions, or a blended model output. Affects confidence level and audit trail for regulatory documentation.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStart rdf:type rdf:Property ;
    rdfs:label 'Window Start' ;
    rdfs:comment 'The principal business event timestamp marking the beginning of the meteorologically permissible application window. Represents the earliest datetime at which spray operations may commence under current conditions.' ;
    rdfs:domain ind:SprayWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Externally-known business identifier for the weather alert, typically assigned by the issuing authority (e.g., NWS event number, DTN alert code, or internal farm management system reference). Used for cross-system traceability and regulatory documentation.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAlertRef rdf:type rdf:Property ;
    rdfs:label 'External Alert Ref' ;
    rdfs:comment 'Reference identifier from the external source system (DTN, Climate FieldView, or state agency) that originated this alert record. Supports data lineage, deduplication, and reconciliation with upstream weather data providers.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity tier of the weather alert following NWS standard classification. Advisory indicates conditions that may cause inconvenience; Watch indicates conditions are favorable for a hazard; Warning indicates a hazard is imminent or occurring; Emergency indicates an extreme, life-threatening event.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkId rdf:type rdf:Property ;
    rdfs:label 'Network Id' ;
    rdfs:comment 'Identifier assigned by the external data provider network (e.g., DTN network node ID, Climate FieldView station UUID, NOAA COOP network ID). Used for data feed reconciliation and provider-side traceability.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StationNetwork .

ind:anemometerHeightM rdf:type rdf:Property ;
    rdfs:label 'Anemometer Height M' ;
    rdfs:comment 'Height above ground level in meters at which the wind speed sensor (anemometer) is mounted. Required for FAO-56 Penman-Monteith reference evapotranspiration (ET) calculations and wind speed standardization to the 2-meter reference height used in irrigation scheduling.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Calibration Tolerance Pct' ;
    rdfs:comment 'Acceptable measurement tolerance threshold expressed as a percentage of full-scale reading, as defined in the station\'s calibration specification. Used to evaluate pass/fail status during calibration and set the out_of_tolerance_flag.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProvider rdf:type rdf:Property ;
    rdfs:label 'Data Provider' ;
    rdfs:comment 'Organization or platform supplying meteorological data for this station. Determines data licensing, feed format, latency SLA, and applicable data quality standards. Key for WASDE and DTN market data integration traceability. [ENUM-REF-CANDIDATE: dtn|climate_fieldview|on_farm_iot|trimble|granular|noaa|private — promote to reference product]' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataTransmissionIntervalMin rdf:type rdf:Property ;
    rdfs:label 'Data Transmission Interval Min' ;
    rdfs:comment 'Configured frequency in minutes at which the station transmits observation data to the central platform. Drives data freshness expectations for real-time irrigation scheduling, spray window alerts, and frost/freeze notifications.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Eligible Flag' ;
    rdfs:comment 'Indicates whether this station meets USDA Risk Management Agency (RMA) requirements for use as an approved weather data source in crop insurance loss documentation. Requires current calibration, gold data quality rating, and WMO or NOAA network registration.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iotDeviceSerial rdf:type rdf:Property ;
    rdfs:label 'Iot Device Serial' ;
    rdfs:comment 'Manufacturer serial number of the IoT sensor node hardware for on-farm stations. Used for warranty tracking, firmware update management, and hardware replacement traceability. Null for DTN reference and cooperative network stations.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leafWetnessSensorFlag rdf:type rdf:Property ;
    rdfs:label 'Leaf Wetness Sensor Flag' ;
    rdfs:comment 'Indicates whether this station is equipped with a leaf wetness sensor. Critical for spray window determination (REI compliance), fungal disease pressure modeling under IPM programs, and GLOBALG.A.P. crop protection documentation.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensorInventory rdf:type rdf:Property ;
    rdfs:label 'Sensor Inventory' ;
    rdfs:comment 'Comma-separated list of sensor types installed on this station (e.g., \'temperature,humidity,precipitation,wind_speed,wind_direction,solar_radiation,soil_moisture,leaf_wetness\'). Defines which observation parameters are available from this station for ET, GDD, and IPM calculations.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilMoistureSensorFlag rdf:type rdf:Property ;
    rdfs:label 'Soil Moisture Sensor Flag' ;
    rdfs:comment 'Indicates whether this station includes in-ground soil moisture sensors. Enables direct soil water content measurement for irrigation scheduling decisions and supports NDVI-correlated crop stress analysis.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solarRadiationSensorFlag rdf:type rdf:Property ;
    rdfs:label 'Solar Radiation Sensor Flag' ;
    rdfs:comment 'Indicates whether this station is equipped with a pyranometer or solar radiation sensor. Required for FAO-56 Penman-Monteith ET calculations; stations without this sensor must use estimated solar radiation from sunshine hours or cloud cover data.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the station, used in field operations, DTN data feeds, Climate FieldView integrations, and regulatory/insurance documentation. Unique across the enterprise station network.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Human-readable descriptive name for the weather station, typically referencing the associated farm unit, field block, or geographic landmark (e.g., \'North Creek Field Station - Block 4\'). Used in reporting, dashboards, and operator interfaces.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the station by its physical deployment and data-provider category. Drives data ingestion pipeline routing and quality thresholds. [ENUM-REF-CANDIDATE: fixed_field|portable_iot|dtn_reference|climate_fieldview|cooperative|airport — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSensorHeightM rdf:type rdf:Property ;
    rdfs:label 'Temperature Sensor Height M' ;
    rdfs:comment 'Height above ground level in meters at which the temperature and humidity sensors are mounted. Standard WMO siting requires 1.25–2.0 m. Deviations affect GDD accumulation accuracy and frost/freeze alert thresholds.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgAnnualEtMm rdf:type rdf:Property ;
    rdfs:label 'Avg Annual Et Mm' ;
    rdfs:comment 'Long-term average annual reference evapotranspiration (ET₀) for the weather zone in millimeters, based on historical climate normals. Foundational input for irrigation district water allocation planning and seasonal crop water demand estimation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgAnnualPrecipMm rdf:type rdf:Property ;
    rdfs:label 'Avg Annual Precip Mm' ;
    rdfs:comment 'Long-term average annual precipitation for the weather zone in millimeters, derived from historical climate normals (typically 30-year NOAA Climate Normals). Used as a baseline for irrigation planning, water budget modeling, and crop insurance actuarial calculations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFirstFallFrostDate rdf:type rdf:Property ;
    rdfs:label 'Avg First Fall Frost Date' ;
    rdfs:comment 'Average calendar date of the first fall frost event (MM-DD format) for this weather zone based on historical climate normals. Defines the end of the effective growing season and is used for harvest scheduling, crop insurance documentation, and GDD accumulation period calculations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgLastSpringFrostDate rdf:type rdf:Property ;
    rdfs:label 'Avg Last Spring Frost Date' ;
    rdfs:comment 'Average calendar date of the last spring frost event (MM-DD format) for this weather zone based on historical climate normals. Used to define the earliest safe planting window for frost-sensitive crops and to configure frost alert thresholds in the weather monitoring system.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgTempAnnualC rdf:type rdf:Property ;
    rdfs:label 'Avg Temp Annual C' ;
    rdfs:comment 'Long-term average annual air temperature for the weather zone in degrees Celsius, based on NOAA 30-year climate normals. Used for climate classification validation, crop suitability analysis, and baseline calibration of GDD accumulation models.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTempSummerC rdf:type rdf:Property ;
    rdfs:label 'Avg Temp Summer C' ;
    rdfs:comment 'Long-term average summer (June–August for Northern Hemisphere) air temperature for the weather zone in degrees Celsius. Used for heat stress risk assessment, irrigation demand forecasting, and crop variety heat tolerance matching.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTempWinterC rdf:type rdf:Property ;
    rdfs:label 'Avg Temp Winter C' ;
    rdfs:comment 'Long-term average winter (December–February for Northern Hemisphere) air temperature for the weather zone in degrees Celsius. Used for winter crop survival modeling, livestock housing planning, and freeze risk baseline calibration.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateFieldviewZoneRef rdf:type rdf:Property ;
    rdfs:label 'Climate Fieldview Zone Ref' ;
    rdfs:comment 'External zone reference identifier used in the Climate FieldView platform to associate this master weather zone with FieldView field-level weather analytics, planting data, and spray window recommendations. Supports bi-directional data synchronization.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateNormalBasePeriod rdf:type rdf:Property ;
    rdfs:label 'Climate Normal Base Period' ;
    rdfs:comment 'The 30-year NOAA Climate Normal base period used to derive the long-term averages stored in this weather zone record (e.g., \'1991-2020\'). Ensures transparency in climate baseline data provenance for agronomic modeling and regulatory reporting.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtRiskClass rdf:type rdf:Property ;
    rdfs:label 'Drought Risk Class' ;
    rdfs:comment 'Categorical drought risk classification for this weather zone based on historical precipitation variability, soil water holding capacity, and USDA drought monitor data. Used for crop insurance risk rating, irrigation infrastructure investment prioritization, and USDA FSA disaster program eligibility assessment.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtnZoneCode rdf:type rdf:Property ;
    rdfs:label 'Dtn Zone Code' ;
    rdfs:comment 'DTN (Data Transmission Network) weather zone identifier used to subscribe to and ingest DTN commercial weather data feeds for this zone. Enables automated linkage between the master zone record and real-time DTN market and weather data services used in agricultural decision support.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:femaFloodZoneCode rdf:type rdf:Property ;
    rdfs:label 'Fema Flood Zone Code' ;
    rdfs:comment 'FEMA National Flood Insurance Program (NFIP) flood zone designation code for this weather zone (e.g., \'AE\', \'X\', \'VE\'). Required for crop insurance underwriting, lender compliance, and USDA FSA disaster assistance program documentation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fipsCountyCode rdf:type rdf:Property ;
    rdfs:label 'Fips County Code' ;
    rdfs:comment 'Five-digit FIPS county code (state FIPS + county FIPS) associated with this weather zone. Required for USDA FSA program reporting, crop insurance documentation under FCIC/RMA, and WASDE regional aggregation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floodRiskClass rdf:type rdf:Property ;
    rdfs:label 'Flood Risk Class' ;
    rdfs:comment 'Categorical flood risk classification for this weather zone based on FEMA flood zone designations and historical precipitation event data. Used for field drainage planning, crop insurance documentation, and USDA FSA disaster program eligibility.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frostFreeDays rdf:type rdf:Property ;
    rdfs:label 'Frost Free Days' ;
    rdfs:comment 'Average number of frost-free days per year for this weather zone, based on historical climate normals. Critical for determining viable planting windows, crop variety selection, and growing season length for annual crop planning.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gddBase10AnnualAvg rdf:type rdf:Property ;
    rdfs:label 'Gdd Base10 Annual Avg' ;
    rdfs:comment 'Long-term average annual Growing Degree Day (GDD) accumulation for this weather zone using a base temperature of 10°C (50°F), based on historical climate normals. Used for crop maturity modeling, planting window optimization, and pest pressure prediction aligned with IPM programs.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary Wkt' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the weather zone polygon boundary, compatible with Esri ArcGIS and standard OGC geometry formats. Enables spatial queries, field-to-zone assignment, and precision agriculture map overlays in the lakehouse.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisCoordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Gis Coordinate System' ;
    rdfs:comment 'Coordinate reference system (CRS) used for the GIS boundary geometry stored in gis_boundary_wkt. Ensures correct spatial interpretation when integrating with Esri ArcGIS, John Deere Operations Center, and Trimble Ag Software field mapping.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:koppenClimateClass rdf:type rdf:Property ;
    rdfs:label 'Koppen Climate Class' ;
    rdfs:comment 'Köppen-Geiger climate classification code assigned to this weather zone (e.g., \'Cfa\' for humid subtropical, \'BSk\' for cold semi-arid). Used for long-range crop planning, seed selection, and agronomic benchmarking aligned with USDA Plant Hardiness Zone mapping.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nwsZoneCode rdf:type rdf:Property ;
    rdfs:label 'Nws Zone Code' ;
    rdfs:comment 'Official National Weather Service forecast zone identifier (e.g., \'ILZ043\') used to link this weather zone to NWS Zone Forecast Products, frost/freeze watches, and severe weather alerts. Enables automated ingestion of NWS advisory feeds for spray window and frost alert processing.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIrrigationSource rdf:type rdf:Property ;
    rdfs:label 'Primary Irrigation Source' ;
    rdfs:comment 'Primary source of irrigation water available within this weather zone. Used for water resource planning, drought risk assessment, and compliance with EPA and state water rights regulations. Informs irrigation scheduling recommendations generated from ET calculations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaHardinessZone rdf:type rdf:Property ;
    rdfs:label 'Usda Hardiness Zone' ;
    rdfs:comment 'USDA Plant Hardiness Zone Map designation for this weather zone (e.g., \'6b\', \'7a\'). Defines the average annual extreme minimum temperature range and is the standard reference for crop variety selection, perennial planting decisions, and seed catalog alignment.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique system-generated identifier for each benefit enrollment record. Primary key for the benefit_enrollment data product.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborContractId rdf:type rdf:Property ;
    rdfs:label 'Labor Contract Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_contract. Business justification: H-2A labor contracts specify mandatory benefit provisions (housing value, transportation, workers comp). Linking benefit_enrollment to labor_contract enables verification that enrolled benefits match ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborContract .

ind:memberEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Member Employee Id' ;
    rdfs:comment 'Carrier-assigned member identification number for the enrolled employee. Used for claims submission, provider verification, and insurance card identification. Treated as confidential as it can be used to access health benefit information.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Reference to the position held by the employee at the time of enrollment, used to determine benefit eligibility rules and employer contribution tiers.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:acaEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Aca Eligibility Status' ;
    rdfs:comment 'ACA employer mandate eligibility determination for this employee. \'Eligible\' indicates the employee is a full-time employee (30+ hours/week average) subject to the ACA employer mandate. Used for Form 1095-C preparation and IRS ACA reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acaOfferOfCoverageCode rdf:type rdf:Property ;
    rdfs:label 'Aca Offer Of Coverage Code' ;
    rdfs:comment 'IRS-defined code indicating the type of health coverage offered to the employee for each month, as reported on Form 1095-C Line 14 (e.g., \'1A\' = minimum essential coverage offered to employee and dependents at or below federal poverty line safe harbor). Required for ACA employer mandate reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acaSafeHarborCode rdf:type rdf:Property ;
    rdfs:label 'Aca Safe Harbor Code' ;
    rdfs:comment 'IRS-defined code for the applicable Section 4980H safe harbor or other relief used by the employer, as reported on Form 1095-C Line 16 (e.g., \'2C\' = employee enrolled in coverage, \'2D\' = employee in limited non-assessment period). Required for ACA employer mandate reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualEmployeePremium rdf:type rdf:Property ;
    rdfs:label 'Annual Employee Premium' ;
    rdfs:comment 'Annualized employee premium cost for this benefit plan, calculated as employee_contribution_amount multiplied by the number of pay periods per year. Used for ACA affordability determination (employee-only coverage must not exceed 9.12% of household income) and total compensation statements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Average Hours Per Week' ;
    rdfs:comment 'Average weekly hours worked by the employee during the ACA lookback measurement period. Used to determine full-time status (30+ hours/week threshold) for ACA employer mandate compliance and seasonal worker benefit eligibility.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Carrier Code' ;
    rdfs:comment 'Unique code identifying the insurance carrier or benefit provider administering this plan (e.g., \'BCBS\', \'AETNA\', \'FIDELITY\'). Used for EDI 834 benefit enrollment file transmission to carriers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCarrierName rdf:type rdf:Property ;
    rdfs:label 'Benefit Carrier Name' ;
    rdfs:comment 'Full legal name of the insurance carrier or benefit provider (e.g., \'Blue Cross Blue Shield of Illinois\', \'Aetna Life Insurance Company\'). Used in employee benefit communications, Summary Plan Descriptions (SPDs), and carrier invoicing.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraElected rdf:type rdf:Property ;
    rdfs:label 'Cobra Elected' ;
    rdfs:comment 'Indicates whether the employee or qualified beneficiary has elected COBRA continuation coverage following termination of employment or other qualifying event. True when COBRA has been elected within the election period.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraElectionDeadline rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Deadline' ;
    rdfs:comment 'The deadline by which the qualified beneficiary must elect COBRA continuation coverage following a qualifying event (typically 60 days from the later of coverage loss date or COBRA notice date). Populated when enrollment_status transitions to \'terminated\'.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Pay period frequency at which employee and employer contributions are applied (e.g., biweekly, semimonthly). Aligns with payroll cycle and is used to annualize contributions for ACA affordability safe harbor calculations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperativePoolParticipant rdf:type rdf:Property ;
    rdfs:label 'Cooperative Pool Participant' ;
    rdfs:comment 'Indicates whether the employee\'s benefits are administered through an agricultural cooperative benefit pool arrangement rather than a direct employer plan. Cooperative pools are common in the agriculture industry for smaller farm operations to achieve group purchasing power.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage selected by the employee indicating who is covered under the plan: employee only, employee plus spouse, employee plus children, or full family. Determines premium amounts and ACA dependent coverage obligations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents (spouse, children, or other qualifying dependents) covered under this enrollment. Used for coverage tier validation, ACA dependent coverage tracking (up to age 26), and premium calculation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The per-pay-period dollar amount deducted from the employee\'s paycheck for this benefit plan. Used for payroll deduction processing, W-2 reporting, and total compensation analysis.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The per-pay-period dollar amount contributed by the employer toward this benefit plan. Used for labor cost allocation across farm operations and processing facilities, COGS reporting, and ACA affordability determination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Group Policy Number' ;
    rdfs:comment 'The employer group policy or contract number assigned by the benefit carrier. Required for claims processing, carrier EDI transmissions, and employee insurance card issuance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aBenefitType rdf:type rdf:Property ;
    rdfs:label 'H2a Benefit Type' ;
    rdfs:comment 'Indicates the type of H-2A mandated benefits provided to the employee under the H-2A temporary agricultural worker visa program. \'Housing\' indicates employer-provided housing; \'meals\' indicates employer-provided or subsidized meals; \'both\' indicates both housing and meals are provided. \'Not applicable\' for non-H-2A workers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aHousingValuePerPeriod rdf:type rdf:Property ;
    rdfs:label 'H2a Housing Value Per Period' ;
    rdfs:comment 'Fair market value of employer-provided housing per pay period for H-2A visa workers, as required to be tracked for DOL compliance and W-2 imputed income reporting. Used in H-2A housing and meals benefit compliance reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lookbackPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Lookback Period End Date' ;
    rdfs:comment 'End date of the ACA measurement/lookback period used to determine full-time employee status for seasonal and variable-hour agricultural workers. Together with lookback_period_start_date, defines the window for average hours calculation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookbackPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Start Date' ;
    rdfs:comment 'Start date of the ACA measurement/lookback period used to determine full-time employee status for seasonal and variable-hour agricultural workers. Critical for seasonal workforce benefit eligibility determination under the ACA look-back measurement method.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period' ;
    rdfs:comment 'Identifier for the annual open enrollment period during which this election was made (e.g., \'OE-2024\', \'OE-2025\'). Distinguishes open enrollment elections from qualifying life event mid-year changes.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSubtype rdf:type rdf:Property ;
    rdfs:label 'Plan Subtype' ;
    rdfs:comment 'Further classification of the benefit plan within its type (e.g., PPO, HMO, HDHP for medical; term or whole life for life insurance; traditional or Roth for 401(k)). Drives eligibility for HSA pairing and ACA minimum value determination. [ENUM-REF-CANDIDATE: PPO|HMO|EPO|HDHP|POS|term|whole_life|short_term_disability|long_term_disability|traditional|roth — promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingLifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Date' ;
    rdfs:comment 'Date on which the qualifying life event occurred that triggered a mid-year enrollment change. Must be documented for ERISA special enrollment compliance. Null when enrollment_type is open enrollment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingLifeEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Type' ;
    rdfs:comment 'Type of qualifying life event that triggered a mid-year benefit enrollment change outside of open enrollment. \'None\' indicates a standard open enrollment election. Required for ERISA and ACA compliance documentation of special enrollment rights. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death|employment_change|loss_of_coverage|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfactorsEnrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Successfactors Enrollment Code' ;
    rdfs:comment 'External enrollment record identifier from SAP SuccessFactors Benefits Administration module. Used for system-of-record reconciliation and integration traceability.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farmOperationId rdf:type rdf:Property ;
    rdfs:label 'Farm Operation Id' ;
    rdfs:comment 'Reference to the home farm operation or facility to which this crew is primarily assigned. Used for labor cost allocation, H-2A housing assignment, and field scheduling within the farm\'s operational boundary.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FarmOperation .

ind:homeFacilityId rdf:type rdf:Property ;
    rdfs:label 'Home Facility Id' ;
    rdfs:comment 'Reference to the primary facility (packing house, processing plant, or farm office) where this crew is administratively based. Used for payroll jurisdiction, workers\' compensation coverage assignment, and facility-level labor reporting.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the crew, used in field operations, payroll systems, and DOL job order references. Unique across the enterprise. Sourced from SAP SuccessFactors or Granular Farm Management FMIS.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name of the agricultural work crew (e.g., \'Harvest Crew Alpha\', \'Spray Team 3\', \'Packing Line B\'). Used in scheduling boards, field assignment reports, and safety briefing documentation.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current lifecycle status of the crew record. \'active\' indicates the crew is currently deployed or available for assignment. \'seasonal_standby\' indicates the crew exists but is outside its operational season window. \'disbanded\' indicates the crew has been permanently dissolved.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Operational classification of the crew based on its primary agricultural function. Drives labor scheduling rules, PPE requirements, piece-rate pay structures, and field assignment eligibility. [ENUM-REF-CANDIDATE: planting|harvest|spray|irrigation|livestock_handling|packing_line|equipment_maintenance — promote to reference product]' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dolDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Dol Disclosure Date' ;
    rdfs:comment 'Date on which the MSPA written disclosure of working conditions was provided to crew members. Required for DOL audit documentation and MSPA compliance recordkeeping.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dolDisclosureProvided rdf:type rdf:Property ;
    rdfs:label 'Dol Disclosure Provided' ;
    rdfs:comment 'Indicates whether the required DOL MSPA written disclosure of working conditions, wages, and housing has been provided to all crew members at the time of recruitment. Mandatory for migrant and seasonal agricultural worker crews under MSPA.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Gap Training Required' ;
    rdfs:comment 'Indicates whether all members of this crew are required to complete GAP training before deployment. Enforced for crews working in fresh produce fields subject to FSMA Produce Safety Rule and GLOBALG.A.P. certification audits.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:h2aCrewFlag rdf:type rdf:Property ;
    rdfs:label 'H2a Crew Flag' ;
    rdfs:comment 'Indicates whether this crew is composed primarily of H-2A temporary agricultural workers under a DOL-certified job order. Triggers H-2A-specific compliance workflows including housing inspection, inbound/outbound transportation reimbursement, and three-fourths guarantee hour tracking.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:h2aJobOrderNumber rdf:type rdf:Property ;
    rdfs:label 'H2a Job Order Number' ;
    rdfs:comment 'DOL-issued job order number associated with this crew\'s H-2A petition. Required for MSPA crew disclosure, housing assignment, and three-fourths guarantee hour compliance reporting. Null for domestic-only crews.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Haccp Training Required' ;
    rdfs:comment 'Indicates whether HACCP food safety training is required for all members of this crew. Mandatory for packing line crews, post-harvest handling teams, and any crew working in USDA/FDA-regulated processing facilities.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housingFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Housing Facility Code' ;
    rdfs:comment 'Code identifying the employer-provided housing facility assigned to this crew for H-2A or migrant worker housing compliance. Links to housing inspection records, OSHA housing standards compliance, and EPA housing requirements under WPS.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaderMspaRegistered rdf:type rdf:Property ;
    rdfs:label 'Leader Mspa Registered' ;
    rdfs:comment 'Indicates whether the assigned crew supervisor/leader holds a valid MSPA farm labor contractor or crew leader registration with the DOL. Required when the crew leader recruits, solicits, or hires migrant or seasonal agricultural workers.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mspaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Mspa Registration Number' ;
    rdfs:comment 'MSPA registration number of the farm labor contractor (FLC) associated with this crew, if applicable. Required for DOL compliance when a third-party FLC recruits or manages the crew. Null for directly-employed crews.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaSafetyBriefingRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Briefing Required' ;
    rdfs:comment 'Indicates whether this crew requires a documented OSHA safety briefing prior to each field deployment. Mandatory for crews operating heavy equipment, working at heights, or handling hazardous materials. Supports OSHA 300 log compliance.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideApplicatorRequired rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator Required' ;
    rdfs:comment 'Indicates whether at least one crew member must hold a valid state-issued pesticide applicator license for this crew\'s assigned tasks. Enforced for spray crews and IPM scouting teams applying restricted-use pesticides.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pieceRateEligible rdf:type rdf:Property ;
    rdfs:label 'Piece Rate Eligible' ;
    rdfs:comment 'Indicates whether this crew is eligible for piece-rate compensation in addition to or in lieu of hourly wages. Drives payroll calculation logic in SAP SuccessFactors and ensures AEWR floor compliance for H-2A workers on piece-rate pay.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pieceRateUnitType rdf:type rdf:Property ;
    rdfs:label 'Piece Rate Unit Type' ;
    rdfs:comment 'The unit of measure used for piece-rate pay calculation for this crew (e.g., \'bin\' for tree fruit harvest, \'row\' for transplanting, \'acre\' for mechanical harvest). Drives piece-rate earnings calculation in payroll and productivity reporting. [ENUM-REF-CANDIDATE: bin|bucket|flat|row|acre|box|bag|head — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code representing the primary language spoken by the majority of crew members (e.g., \'es\' for Spanish, \'en\' for English, \'ht\' for Haitian Creole). Drives language selection for safety briefings, WPS handler training, GAP training materials, and DOL MSPA disclosure documents.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiRestricted rdf:type rdf:Property ;
    rdfs:label 'Rei Restricted' ;
    rdfs:comment 'Indicates whether this crew is currently restricted from entering treated fields due to an active pesticide Restricted Entry Interval (REI). Prevents unsafe field entry and supports EPA WPS compliance enforcement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyBriefingLastDate rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Last Date' ;
    rdfs:comment 'Date of the most recent documented safety briefing conducted for this crew. Used to enforce safety briefing frequency requirements, support OSHA audit readiness, and trigger re-briefing alerts before field deployment.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Default shift schedule pattern assigned to this crew for labor scheduling and time entry generation. Drives shift start/end time defaults in work assignment records and payroll period calculations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCrewSize rdf:type rdf:Property ;
    rdfs:label 'Target Crew Size' ;
    rdfs:comment 'Planned or budgeted number of workers for this crew at full operational capacity. Used in workforce planning, H-2A petition headcount calculations, housing unit allocation, and transportation logistics.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationProvided rdf:type rdf:Property ;
    rdfs:label 'Transportation Provided' ;
    rdfs:comment 'Indicates whether the employer provides transportation for this crew between housing and the worksite. Required disclosure under H-2A program and MSPA. Drives transportation cost allocation and DOL audit compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the labor union or collective bargaining agreement (CBA) applicable to this crew, if unionized. Drives CBA-specific wage rates, grievance procedures, and overtime rules in payroll processing.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wpsHandlerTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Wps Handler Training Required' ;
    rdfs:comment 'Indicates whether crew members require EPA Worker Protection Standard pesticide handler training. Mandatory for spray crews and any crew working in fields during or after pesticide application within the REI window.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee\'s employment relationship with the enterprise. Drives access control, payroll processing, and benefits eligibility. Active = currently employed; On_Leave = approved leave of absence; Terminated = employment ended; Suspended = temporarily suspended pending investigation; Retired = formally retired.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employment arrangement. Permanent = year-round staff; Seasonal = hired for specific agricultural seasons (planting, harvest); Temporary = short-term non-seasonal; Contract = third-party contracted labor; Intern = internship program. Critical for H-2A visa tracking and MSPA compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Everify Case Number' ;
    rdfs:comment 'The case number assigned by the DHS E-Verify system upon submission of the employee\'s I-9 data for electronic employment eligibility verification. Required for federal contractors and many agricultural employers. Enables audit trail for USCIS compliance reviews.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Gap Training Completed' ;
    rdfs:comment 'Indicates whether the employee has completed required Good Agricultural Practices (GAP) training as mandated by FSMA Produce Safety Rule. Required for all workers involved in covered produce activities including harvesting, packing, and handling.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-reported gender of the employee. Used for EEO-1 reporting, workforce diversity analytics, and OSHA recordkeeping requirements.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aVisaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'H2a Visa Expiry Date' ;
    rdfs:comment 'Expiration date of the H-2A temporary agricultural worker visa. Triggers automated alerts for visa renewal or worker departure compliance. Critical for DOL and USCIS audit readiness. Null for non-H-2A employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:h2aVisaNumber rdf:type rdf:Property ;
    rdfs:label 'H2a Visa Number' ;
    rdfs:comment 'Visa document number for employees admitted under the H-2A Temporary Agricultural Worker program. Used to track visa validity, DOL job order compliance, and APHIS worker protection requirements. Null for non-H-2A employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Haccp Training Completed' ;
    rdfs:comment 'Indicates whether the employee has completed Hazard Analysis and Critical Control Points (HACCP) training. Required for employees working in food processing facilities, packing houses, and post-harvest handling operations under FDA and USDA FSIS regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The official date the employee commenced employment with the enterprise. Used for tenure calculations, benefits eligibility vesting, seniority-based scheduling, and seasonal rehire tracking.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:i9VerificationStatus rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Status' ;
    rdfs:comment 'Current status of the employee\'s Form I-9 employment eligibility verification. Mandatory for all US employees under IRCA. Tracks whether identity and work authorization documents have been reviewed and verified. Reverification_required indicates documents are approaching expiration.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSeasonalRehireEligible rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Rehire Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire in a future agricultural season based on prior performance, compliance record, and voluntary departure. Supports seasonal workforce planning and H-2A returning worker preference programs.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in the US). Used for I-9 verification, E-Verify compliance, tax reporting, and MSPA worker disclosure requirements.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Certified' ;
    rdfs:comment 'Indicates whether the employee holds a current OSHA safety certification (e.g., OSHA 10-hour or 30-hour General Industry or Construction card). Required for supervisory roles and equipment operators in farm and processing facility environments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Compensation structure for the employee. Salaried = fixed annual compensation; Hourly = paid per hour worked; Piece_Rate = paid per unit of agricultural output (e.g., per bin of fruit picked); Daily = fixed daily rate. Piece-rate is common in harvest operations and has specific FLSA compliance requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalEmail rdf:type rdf:Property ;
    rdfs:label 'Personal Email' ;
    rdfs:comment 'Personal email address of the employee. Used for communications with seasonal and H-2A workers who may not have enterprise email, and for post-termination correspondence.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideApplicatorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator License Number' ;
    rdfs:comment 'State-issued pesticide applicator license number for employees authorized to apply restricted-use pesticides (RUPs). Required by EPA and state lead agencies for compliance with FIFRA. Null for employees not performing pesticide applications.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pesticide License Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s state-issued pesticide applicator license. Triggers recertification workflows to ensure continuous compliance with EPA FIFRA and state regulations. Null for non-applicator employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the employee prefers to be called in day-to-day operations. May differ from legal name. Used in operational communications and scheduling systems.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfactorsEmployeeCode rdf:type rdf:Property ;
    rdfs:label 'Successfactors Employee Code' ;
    rdfs:comment 'The employee identifier assigned in SAP SuccessFactors HR system. Used for cross-system integration with payroll, talent management, and labor cost allocation modules. This is the system-of-record identifier from the HR platform.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationType rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Type' ;
    rdfs:comment 'Classification of the employee\'s legal authorization to work in the United States. H-2A is the primary agricultural guest worker visa program. Drives compliance workflows for USCIS, DOL, and APHIS requirements. [ENUM-REF-CANDIDATE: us_citizen|permanent_resident|h2a_visa|ead|tn_visa|other_visa|asylum|daca — promote to reference product]' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Official enterprise email address assigned to the employee. Primary digital contact channel for HR communications, system access notifications, and training assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary farm, field complex, or processing facility where the employee is assigned. Used for labor cost allocation by location, OSHA site-specific recordkeeping, and field operations scheduling. Aligns with Granular Farm Management location hierarchy.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborComplianceId rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Id' ;
    rdfs:comment 'Primary key for labor_compliance' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHourlyWage rdf:type rdf:Property ;
    rdfs:label 'Actual Hourly Wage' ;
    rdfs:comment 'The actual hourly wage rate paid to the worker during the contract period. Must meet or exceed the AEWR hourly rate and applicable state minimum wage for DOL compliance.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHoursOffered rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Offered' ;
    rdfs:comment 'Total hours of work actually offered to the H-2A worker during the contract period. Compared against three-fourths guarantee hours to determine if the employer met the wage guarantee obligation.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aewrComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Aewr Compliance Status' ;
    rdfs:comment 'Indicates whether the employer\'s actual wage payments meet the DOL-mandated Adverse Effect Wage Rate (AEWR) for this worker. Non-compliant status triggers remediation workflow and DOL reporting obligations.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aewrHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Aewr Hourly Rate' ;
    rdfs:comment 'The Adverse Effect Wage Rate (AEWR) applicable to this worker\'s job classification and state, as published annually by DOL. The minimum hourly wage the employer must pay H-2A workers to avoid adverse effect on domestic workers.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'Date the H-2A or migrant worker arrived at the work site or employer-provided housing. Used to calculate three-fourths guarantee period start and AEWR wage compliance windows.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'Date the H-2A or migrant worker departed the work site or employer-provided housing. Used to close the compliance period and finalize three-fourths guarantee hour calculations.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dolAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Dol Audit Flag' ;
    rdfs:comment 'Indicates whether this compliance record has been flagged for or is currently under a DOL Wage and Hour Division audit or investigation. Triggers enhanced documentation retention and legal review workflow.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dolJobOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dol Job Order Number' ;
    rdfs:comment 'The official job order number assigned by the U.S. Department of Labor (DOL) for the H-2A temporary agricultural worker petition. Required for all H-2A program filings and DOL audit readiness.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaHousingCompliant rdf:type rdf:Property ;
    rdfs:label 'Epa Housing Compliant' ;
    rdfs:comment 'Indicates whether the employer-provided housing facility meets EPA environmental and pesticide exposure standards applicable to agricultural worker housing. Required for DOL H-2A housing certification.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housingCapacity rdf:type rdf:Property ;
    rdfs:label 'Housing Capacity' ;
    rdfs:comment 'Maximum number of workers authorized to occupy the assigned housing unit per OSHA and DOL housing standards. Used for occupancy compliance and state inspection reporting.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingOccupancyEndDate rdf:type rdf:Property ;
    rdfs:label 'Housing Occupancy End Date' ;
    rdfs:comment 'Date the worker vacated the employer-provided housing unit. Used to close the housing assignment record and finalize rent deduction calculations.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:housingOccupancyStartDate rdf:type rdf:Property ;
    rdfs:label 'Housing Occupancy Start Date' ;
    rdfs:comment 'Date the worker began occupying the employer-provided housing unit. Used to track housing provision obligations and calculate any permissible rent deduction periods.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:housingUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Housing Unit Number' ;
    rdfs:comment 'Specific unit, room, or bunk number within the employer-provided housing facility assigned to this worker. Used for occupancy tracking and housing inspection compliance.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundTransportCost rdf:type rdf:Property ;
    rdfs:label 'Inbound Transport Cost' ;
    rdfs:comment 'Actual cost incurred by the employer for inbound transportation of the H-2A worker from the country of origin or place of recruitment to the worksite. Must be reimbursed or paid directly per DOL requirements.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mspaDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Mspa Disclosure Date' ;
    rdfs:comment 'Date on which the MSPA written disclosure document was provided to the worker. Required for DOL audit trail and MSPA compliance verification.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mspaDisclosureProvided rdf:type rdf:Property ;
    rdfs:label 'Mspa Disclosure Provided' ;
    rdfs:comment 'Indicates whether the required MSPA written disclosure of working conditions, wages, housing, and transportation was provided to the migrant or seasonal agricultural worker prior to recruitment or at time of recruitment.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaHousingCompliant rdf:type rdf:Property ;
    rdfs:label 'Osha Housing Compliant' ;
    rdfs:comment 'Indicates whether the employer-provided housing facility meets OSHA temporary labor camp standards (29 CFR 1910.142) as of the last inspection. Required for DOL H-2A housing certification.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundTransportCost rdf:type rdf:Property ;
    rdfs:label 'Outbound Transport Cost' ;
    rdfs:comment 'Actual cost incurred by the employer for return transportation of the H-2A worker from the worksite to the country of origin upon contract completion or early termination. Required by DOL H-2A regulations.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Rent Deduction Amount' ;
    rdfs:comment 'Dollar amount deducted from the worker\'s wages for employer-provided housing, if applicable. Must comply with DOL permissible deduction limits and must not reduce wages below AEWR. Reported on worker pay stubs.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suretyBondNumber rdf:type rdf:Property ;
    rdfs:label 'Surety Bond Number' ;
    rdfs:comment 'Surety bond number held by the farm labor contractor (FLC) as required under MSPA to ensure payment of wages and compliance with worker protection obligations. Applicable when a third-party FLC is involved.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeFourthsGuaranteeHours rdf:type rdf:Property ;
    rdfs:label 'Three Fourths Guarantee Hours' ;
    rdfs:comment 'The minimum number of hours the employer is obligated to offer the H-2A worker under the three-fourths guarantee rule — equal to 75% of the total workdays in the contract period multiplied by the daily hours in the job order. Critical for DOL wage compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visaPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'Visa Petition Number' ;
    rdfs:comment 'USCIS-assigned petition number (Form I-129) for the H-2A temporary agricultural worker visa. Used for USCIS and APHIS compliance tracking and audit.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaPetitionStatus rdf:type rdf:Property ;
    rdfs:label 'Visa Petition Status' ;
    rdfs:comment 'Current lifecycle status of the H-2A visa petition filed with USCIS. Drives compliance workflow and worker eligibility for employment.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompCoverage rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Coverage' ;
    rdfs:comment 'Indicates whether the H-2A or migrant worker is covered by the employer\'s workers\' compensation insurance policy as required by DOL H-2A regulations and applicable state law.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workersCompPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Policy Number' ;
    rdfs:comment 'The insurance policy number for the workers\' compensation coverage applicable to this worker. Required for DOL audit documentation and state compliance reporting.' ;
    rdfs:domain ind:LaborCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cba Reference Number' ;
    rdfs:comment 'Reference number of the Collective Bargaining Agreement (CBA) that governs this individual employment contract, when applicable. Links individual contracts to the overarching union-negotiated agreement. Null for non-union contracts.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eVerifyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'E Verify Case Number' ;
    rdfs:comment 'The DHS E-Verify system case number confirming the worker\'s employment authorization. Required for federal contractors and H-2A employers. Provides audit trail for USCIS and DOL compliance inspections.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Hours Per Week' ;
    rdfs:comment 'Minimum number of work hours per week guaranteed to the worker under the contract. For H-2A contracts, DOL requires a three-fourths guarantee (75% of the total hours in the contract period). Critical for H-2A compliance and wage obligation calculations.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:h2aPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'H2a Petition Number' ;
    rdfs:comment 'USCIS petition number (Form I-129) associated with the H-2A temporary agricultural worker visa application. Enables traceability from the labor contract to the immigration filing. Null for non-H-2A contracts.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housingAddress rdf:type rdf:Property ;
    rdfs:label 'Housing Address' ;
    rdfs:comment 'Physical address of the employer-provided housing facility for H-2A workers. Required for DOL job order disclosure and OSHA housing inspection compliance. Null when housing_provided is False.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housingProvided rdf:type rdf:Property ;
    rdfs:label 'Housing Provided' ;
    rdfs:comment 'Indicates whether the employer is obligated to provide free housing to the worker under the contract terms. Mandatory for H-2A contracts where workers are not reasonably able to return to their residence each day. Compliance requirement under DOL H-2A regulations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:i9Verified rdf:type rdf:Property ;
    rdfs:label 'I9 Verified' ;
    rdfs:comment 'Indicates whether the worker\'s employment eligibility has been verified via USCIS Form I-9 (Employment Eligibility Verification). Mandatory for all U.S. employers under the Immigration Reform and Control Act (IRCA). Must be True before contract activation.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundTransportReimbursed rdf:type rdf:Property ;
    rdfs:label 'Inbound Transport Reimbursed' ;
    rdfs:comment 'Indicates whether the employer reimburses the worker for inbound travel costs from the worker\'s home country or state of recruitment to the worksite. Mandatory reimbursement obligation under H-2A regulations after 50% of the contract period is completed.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideApplicatorLicense rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator License' ;
    rdfs:comment 'State-issued pesticide applicator license number for workers authorized to apply restricted-use pesticides (RUP). Required by EPA and state lead agencies under FIFRA. Null for workers not performing pesticide application duties.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socCode rdf:type rdf:Property ;
    rdfs:label 'Soc Code' ;
    rdfs:comment 'Bureau of Labor Statistics Standard Occupational Classification (SOC) code for the contracted job role. Required on DOL H-2A job orders to classify the agricultural occupation (e.g., 45-2092 for Farmworkers and Laborers, Crop, Nursery, and Greenhouse).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractHours rdf:type rdf:Property ;
    rdfs:label 'Total Contract Hours' ;
    rdfs:comment 'Total number of work hours specified for the entire contract period. Used to calculate the three-fourths guarantee obligation for H-2A contracts and for labor cost budgeting in Granular Farm Management.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visaType rdf:type rdf:Property ;
    rdfs:label 'Visa Type' ;
    rdfs:comment 'Immigration visa classification under which the worker is authorized to work in the United States. H-2A is the primary temporary agricultural worker visa. Drives compliance obligations and documentation requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wageRate rdf:type rdf:Property ;
    rdfs:label 'Wage Rate' ;
    rdfs:comment 'The agreed-upon base wage rate for the worker as specified in the labor contract. For H-2A contracts, must meet or exceed the Adverse Effect Wage Rate (AEWR) published annually by DOL. Used for payroll processing and compliance audits.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wageRateUnit rdf:type rdf:Property ;
    rdfs:label 'Wage Rate Unit' ;
    rdfs:comment 'The unit of measure for the contracted wage rate. Hourly is most common for H-2A and seasonal workers; piece_rate applies to harvest workers paid per unit of crop harvested (e.g., per bin, per bushel).' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDutiesDescription rdf:type rdf:Property ;
    rdfs:label 'Work Duties Description' ;
    rdfs:comment 'Detailed narrative description of the specific agricultural duties, tasks, and responsibilities the worker is contracted to perform. Must be disclosed in the DOL job order for H-2A contracts per FSMA Worker Protection Rule requirements.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each employee leave request record. Primary key for the leave_request data product in the workforce domain.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Reference to the employee submitting the leave request. Links to the workforce.employee master record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedDays rdf:type rdf:Property ;
    rdfs:label 'Approved Days' ;
    rdfs:comment 'Total number of calendar or working days officially approved. May differ from requested_days if the supervisor partially approves the leave. Used for payroll deduction calculations and FMLA entitlement balance updates.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The officially approved end date of the leave as confirmed by the supervisor or HR. Used for payroll processing, scheduling, and FMLA entitlement tracking. Null if leave has not yet been approved.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The officially approved start date of the leave as confirmed by the supervisor or HR. Used for payroll processing, scheduling, and FMLA entitlement tracking. Null if leave has not yet been approved.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationReceived rdf:type rdf:Property ;
    rdfs:label 'Certification Received' ;
    rdfs:comment 'Indicates whether the required supporting certification documentation has been received (e.g., DOL WH-380 medical certification for FMLA, military orders for military leave, jury summons for jury duty). True = certification on file.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'The date and time the supervisor or HR rendered a final approval or denial decision on the leave request. FMLA requires written notice within 5 business days of the eligibility determination (29 CFR 825.300).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Narrative explanation provided by the supervisor or HR when a leave request is denied or partially denied. Required for FMLA denial notices (29 CFR 825.300) and supports employee grievance and appeal processes. Null when approval_status is not \'denied\'.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaEligible rdf:type rdf:Property ;
    rdfs:label 'Fmla Eligible' ;
    rdfs:comment 'Indicates whether the employee meets FMLA eligibility criteria at the time of the request: 12 months of employment and 1,250 hours worked in the preceding 12-month lookback period at a covered employer location (50+ employees within 75 miles). True = eligible; False = not eligible.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmlaEntitlementUsedDays rdf:type rdf:Property ;
    rdfs:label 'Fmla Entitlement Used Days' ;
    rdfs:comment 'Cumulative FMLA leave days consumed by the employee in the current 12-month FMLA measurement period prior to this request. The FMLA entitlement is 12 weeks (84 calendar days) per year; military caregiver leave allows up to 26 weeks.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmlaHoursWorkedLookback rdf:type rdf:Property ;
    rdfs:label 'Fmla Hours Worked Lookback' ;
    rdfs:comment 'Total hours worked by the employee in the 12-month period immediately preceding the leave request date, used to determine FMLA eligibility (threshold: 1,250 hours). Sourced from SAP SuccessFactors time and attendance records.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:h2aContractImpact rdf:type rdf:Property ;
    rdfs:label 'H2a Contract Impact' ;
    rdfs:comment 'Indicates whether this leave request involves an H-2A visa worker and may impact the three-fourths guarantee calculation (the employer\'s obligation to offer at least 75% of the contracted work hours). True = H-2A contract obligations are affected by this leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:h2aEarlyDepartureDate rdf:type rdf:Property ;
    rdfs:label 'H2a Early Departure Date' ;
    rdfs:comment 'For H-2A visa workers requesting early departure before contract completion, the date the worker intends to depart. Used to calculate the impact on the three-fourths guarantee and to initiate contract completion documentation with APHIS/DOL.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:harvestCriticalWindow rdf:type rdf:Property ;
    rdfs:label 'Harvest Critical Window' ;
    rdfs:comment 'Indicates whether the requested leave dates fall within a designated harvest-critical or planting-critical operational window where discretionary leave approvals may be restricted due to operational necessity. Populated from the farm operations calendar. True = leave overlaps a critical window.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermittentFrequency rdf:type rdf:Property ;
    rdfs:label 'Intermittent Frequency' ;
    rdfs:comment 'Describes the expected frequency and duration of intermittent leave episodes as certified by a healthcare provider (e.g., \'2 episodes per month, 1-3 days each\'). Required for scheduling and FMLA certification documentation when is_intermittent = True.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether the leave is taken intermittently or on a reduced schedule rather than as a continuous block. Common for chronic conditions under FMLA. True = intermittent/reduced schedule; False = continuous leave block.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'Narrative or coded reason provided by the employee for the leave request (e.g., serious health condition, childbirth, family care, military deployment, bereavement). Treated as confidential HR data. For FMLA leaves, this field supports the qualifying reason determination per 29 CFR Part 825.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave request by policy category. Covers FMLA (Family and Medical Leave Act), state-mandated paid sick leave, personal leave, vacation/PTO (Paid Time Off), bereavement, jury duty, military leave, H-2A early departure, and agricultural seasonal layoff. [ENUM-REF-CANDIDATE: FMLA|paid_sick|personal|vacation_pto|bereavement|jury_duty|military|h2a_early_departure|seasonal_layoff — promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Received' ;
    rdfs:comment 'Indicates whether the required fitness-for-duty or medical clearance documentation has been received from the employee prior to return to work. True = clearance documentation received and on file.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required' ;
    rdfs:comment 'Indicates whether the employee must provide a fitness-for-duty certification from a healthcare provider before returning to work. Applicable for FMLA medical leaves and roles with physical demands (e.g., pesticide applicators, equipment operators). True = clearance required.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payImpactType rdf:type rdf:Property ;
    rdfs:label 'Pay Impact Type' ;
    rdfs:comment 'Indicates the payroll treatment for the approved leave period. Determines whether the employee receives full pay, no pay, partial pay, state-mandated paid leave benefits, or short-term disability benefits during the absence. Drives payroll processing in SAP S/4HANA Payroll.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDays rdf:type rdf:Property ;
    rdfs:label 'Requested Days' ;
    rdfs:comment 'Total number of calendar or working days requested by the employee, as submitted. Supports FMLA 12-week entitlement tracking and H-2A three-fourths guarantee calculations. Decimal to accommodate partial-day requests.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The date the employee requested their leave to end, as submitted in the original leave request. May differ from the approved end date.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The date the employee requested their leave to begin, as submitted in the original leave request. May differ from the approved start date if the supervisor modifies the leave window.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The actual or expected date the employee is scheduled to return to active duty following the leave. Critical for labor scheduling during planting and harvest windows. May be updated if leave is extended.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalLayoffRehireDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Layoff Rehire Date' ;
    rdfs:comment 'For seasonal agricultural workers on planned layoff, the anticipated rehire or recall date for the next growing season. Supports seasonal workforce availability forecasting and rehire eligibility tracking in SAP SuccessFactors.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successfactorsAbsenceCode rdf:type rdf:Property ;
    rdfs:label 'Successfactors Absence Code' ;
    rdfs:comment 'The native absence record identifier from SAP SuccessFactors Absence Management module. Enables bidirectional reconciliation between the Databricks Silver layer and the system of record for HR audit and payroll integration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollId rdf:type rdf:Property ;
    rdfs:label 'Payroll Id' ;
    rdfs:comment 'Primary key for payroll' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payroll .

ind:aewrCompliant rdf:type rdf:Property ;
    rdfs:label 'Aewr Compliant' ;
    rdfs:comment 'Indicates whether the effective hourly wage paid to the employee meets or exceeds the DOL Adverse Effect Wage Rate (AEWR) for the applicable state and period. Critical H-2A compliance indicator.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aewrRate rdf:type rdf:Property ;
    rdfs:label 'Aewr Rate' ;
    rdfs:comment 'The DOL-published Adverse Effect Wage Rate applicable to the employee\'s state and job classification for the pay period. Used as the minimum wage floor for H-2A guest workers and compliance benchmarking.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:farmOperationCode rdf:type rdf:Property ;
    rdfs:label 'Farm Operation Code' ;
    rdfs:comment 'Identifier for the specific farm operation or production unit (e.g., field, orchard, processing facility) where the employee worked. Enables labor cost allocation to crop enterprise budgets in Granular Farm Management.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Federal Income Tax Withheld' ;
    rdfs:comment 'Amount of federal income tax withheld from the employee\'s gross wages for the pay period per IRS withholding tables and the employee\'s W-4 elections.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWages rdf:type rdf:Property ;
    rdfs:label 'Gross Wages' ;
    rdfs:comment 'Total pre-deduction earnings for the pay period, including regular pay, overtime premium, piece-rate earnings, and any other compensation components before tax and other deductions.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:housingDeduction rdf:type rdf:Property ;
    rdfs:label 'Housing Deduction' ;
    rdfs:comment 'Amount deducted from gross wages for employer-provided housing furnished to H-2A workers or other agricultural employees. Must comply with DOL reasonable cost or fair rental value limits.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Job Classification Code' ;
    rdfs:comment 'The DOL Standard Occupational Classification (SOC) or internal job code for the employee\'s role during the pay period (e.g., crop worker, equipment operator, agronomist). Drives AEWR rate selection and compliance rule application.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicareTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Withheld' ;
    rdfs:comment 'Employee share of Medicare (HI) tax withheld under FICA for the pay period, including the Additional Medicare Tax for high earners where applicable.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'The actual take-home amount disbursed to the employee after all tax withholdings and authorized deductions are subtracted from gross wages.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Total of all other authorized deductions not separately itemized (e.g., voluntary benefit elections, garnishments, tool deductions) applied to gross wages for the pay period.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEarnings rdf:type rdf:Property ;
    rdfs:label 'Overtime Earnings' ;
    rdfs:comment 'Total overtime premium earnings for the pay period, calculated at 1.5x the regular rate for hours exceeding 40 per week per FLSA requirements.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Worked' ;
    rdfs:comment 'Total overtime hours worked beyond the FLSA 40-hour weekly threshold during the pay period. Required for FLSA overtime premium pay calculation and DOL wage and hour compliance reporting.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the employee is paid. Determines pay period boundaries and is critical for H-2A three-fourths guarantee calculations and FLSA overtime compliance.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the payroll processing period. Defines the boundary for wage calculations, overtime determination, and H-2A three-fourths guarantee assessment.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the payroll processing period. Used for DOL wage and hour compliance, H-2A three-fourths guarantee tracking, and labor cost allocation.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current workflow state of the payroll record within the SAP SuccessFactors payroll processing lifecycle, from initial calculation through final payment or reversal.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceRateEarnings rdf:type rdf:Property ;
    rdfs:label 'Piece Rate Earnings' ;
    rdfs:comment 'Total earnings derived from piece-rate compensation (harvest pay) for the pay period, calculated as piece_rate_units multiplied by piece_rate_per_unit. Supports harvest labor cost analysis.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pieceRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Piece Rate Per Unit' ;
    rdfs:comment 'The monetary rate paid per piece-rate unit (e.g., per bin, per pound, per row) for harvest or production work. Confidential compensation data used for piece-rate earnings calculation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pieceRateUnits rdf:type rdf:Property ;
    rdfs:label 'Piece Rate Units' ;
    rdfs:comment 'Total number of piece-rate units (e.g., bins picked, rows harvested, pounds collected) completed by the employee during the pay period. Drives piece-rate earnings calculation for harvest pay.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Regular Hours Worked' ;
    rdfs:comment 'Total non-overtime hours worked by the employee during the pay period. Used for FLSA compliance, H-2A three-fourths guarantee tracking, and labor cost allocation to farm operations.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapPayrollDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payroll Doc Number' ;
    rdfs:comment 'The payroll document reference number generated by SAP S/4HANA payroll processing, used for reconciliation and audit trail back to the system of record.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialSecurityTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Withheld' ;
    rdfs:comment 'Employee share of Social Security (OASDI) tax withheld under FICA for the pay period, calculated at the statutory rate on wages up to the annual wage base.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'State Income Tax Withheld' ;
    rdfs:comment 'Amount of state income tax withheld from the employee\'s gross wages for the pay period per applicable state tax authority withholding requirements.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeFourthsGuaranteeMet rdf:type rdf:Property ;
    rdfs:label 'Three Fourths Guarantee Met' ;
    rdfs:comment 'Indicates whether the employer has met the H-2A three-fourths guarantee obligation for this pay period. A False value triggers back-pay liability calculation for the shortfall hours.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportationDeduction rdf:type rdf:Property ;
    rdfs:label 'Transportation Deduction' ;
    rdfs:comment 'Amount deducted from gross wages for employer-provided transportation to/from the worksite. Subject to DOL H-2A regulations limiting deductions to actual cost and prohibiting deductions that reduce wages below AEWR.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workStateCode rdf:type rdf:Property ;
    rdfs:label 'Work State Code' ;
    rdfs:comment 'Two-letter US state code where the employee performed work during the pay period. Determines applicable state income tax withholding, state minimum wage, and H-2A AEWR rate.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique system-generated identifier for each performance review or disciplinary action record. Primary key for the performance_review data product.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Reference to the employee who is the subject of this performance review or disciplinary action record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the employee (manager, supervisor, or HR representative) who conducted and submitted this performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the employee formally acknowledged the performance review or disciplinary action document. Null if not yet acknowledged.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agronomicKnowledgeRating rdf:type rdf:Property ;
    rdfs:label 'Agronomic Knowledge Rating' ;
    rdfs:comment 'Competency rating assessing the employee\'s knowledge of crop science, soil management, GAP (Good Agricultural Practices), IPM (Integrated Pest Management), and related agronomic disciplines. Applicable to agronomists, field technicians, and farm supervisors.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether the employee has formally filed an appeal against this performance review or disciplinary action decision.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Outcome of the formal appeal process for a contested performance review or disciplinary action: upheld (original decision stands), overturned (decision reversed), modified (decision partially changed), withdrawn (employee withdrew appeal), or pending. Null if no appeal was filed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationAdjustedRating rdf:type rdf:Property ;
    rdfs:label 'Calibration Adjusted Rating' ;
    rdfs:comment 'Overall performance rating after calibration session adjustments, if the original rating was modified during the calibration process. Null if no adjustment was made or calibration is not applicable.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Documented corrective action plan (CAP) outlining specific behavioral or performance improvements required, timelines, and consequences of non-compliance. Used for both disciplinary actions and Performance Improvement Plans (PIPs).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentComments rdf:type rdf:Property ;
    rdfs:label 'Development Comments' ;
    rdfs:comment 'Reviewer\'s narrative comments identifying areas for employee development, skill gaps, and recommended training (e.g., GAP, HACCP, pesticide applicator certification) to support career growth and compliance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryLevel rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Level' ;
    rdfs:comment 'Progressive discipline level applied in a disciplinary action record: verbal_warning, written_warning, suspension, or termination_recommendation. Null for performance review records. Supports union grievance documentation and wrongful termination risk mitigation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledged' ;
    rdfs:comment 'Indicates whether the employee has formally acknowledged receipt of the performance review or disciplinary action document, either via electronic signature in SAP SuccessFactors or physical signature. Critical for legal defensibility.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeRebuttal rdf:type rdf:Property ;
    rdfs:label 'Employee Rebuttal' ;
    rdfs:comment 'Employee\'s written rebuttal or response to the performance review or disciplinary action, as captured in SAP SuccessFactors. Supports union grievance documentation and wrongful termination risk mitigation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentOperationRating rdf:type rdf:Property ;
    rdfs:label 'Equipment Operation Rating' ;
    rdfs:comment 'Competency rating assessing the employee\'s proficiency in operating farm machinery, precision agriculture equipment (GPS/RTK-guided), and processing facility equipment. Supports OEE (Overall Equipment Effectiveness) workforce planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Food Safety Compliance Rating' ;
    rdfs:comment 'Competency rating assessing the employee\'s adherence to HACCP (Hazard Analysis and Critical Control Points), GMP (Good Manufacturing Practices), FSMA (Food Safety Modernization Act), and SQF/BRC food safety protocols. Mandatory for processing facility and post-harvest handling roles.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalsAchievementPercent rdf:type rdf:Property ;
    rdfs:label 'Goals Achievement Percent' ;
    rdfs:comment 'Percentage of formally set performance goals achieved by the employee during the review period, as tracked in SAP SuccessFactors Goals module. Expressed as 0.00–100.00. Supports merit pay and promotion decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalsSummary rdf:type rdf:Property ;
    rdfs:label 'Goals Summary' ;
    rdfs:comment 'Narrative summary of the employee\'s key performance goals for the review period and the degree to which each was achieved. Captured from SAP SuccessFactors Goals module free-text fields.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Composite numeric performance rating assigned to the employee for the review period, typically on a 1.0–5.0 scale as configured in SAP SuccessFactors. Drives promotion decisions, merit increases, and seasonal rehire prioritization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRatingLabel rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Label' ;
    rdfs:comment 'Descriptive label corresponding to the overall numeric rating, as defined in the SAP SuccessFactors rating scale configuration. Used in talent calibration sessions and manager communications.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolationType rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Type' ;
    rdfs:comment 'Category of policy violation that triggered the disciplinary action. Null for performance review records. [ENUM-REF-CANDIDATE: safety|attendance|conduct|food_safety_protocol|substance_abuse|harassment|theft|insubordination — promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityRating rdf:type rdf:Property ;
    rdfs:label 'Productivity Rating' ;
    rdfs:comment 'Competency rating assessing the employee\'s output efficiency relative to established YPM (Yield Per Acre Metric) benchmarks, harvest targets, or processing throughput KPIs (Key Performance Indicators) for their role.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommendation' ;
    rdfs:comment 'Indicates whether the reviewer recommends the employee for promotion or advancement to a higher-level position based on this performance review. Feeds into SAP SuccessFactors Succession & Development planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireRecommendation rdf:type rdf:Property ;
    rdfs:label 'Rehire Recommendation' ;
    rdfs:comment 'Reviewer\'s recommendation regarding the employee\'s eligibility for rehire in the next season, specifically for seasonal and H-2A visa workers. Drives seasonal rehire prioritization lists in SAP SuccessFactors.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Externally-known business identifier for the review record, used for referencing in SAP SuccessFactors, union grievance filings, and legal documentation. Format: PR-YYYY-NNNNNN.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period being assessed. For seasonal workers, typically aligns with the end of the harvest or growing season.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period being assessed. For seasonal workers, typically aligns with the planting or harvest season start date.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewSubtype rdf:type rdf:Property ;
    rdfs:label 'Review Subtype' ;
    rdfs:comment 'Specific category of performance review: annual (year-end), mid_season (in-season check-in), probationary (new hire evaluation), end_of_season (seasonal worker close-out), or pip (Performance Improvement Plan). Supports seasonal rehire prioritization and talent management decisions. [ENUM-REF-CANDIDATE: annual|mid_season|probationary|end_of_season|pip — promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Rating' ;
    rdfs:comment 'Competency rating assessing the employee\'s adherence to OSHA safety standards, pesticide REI (Restricted Entry Interval) protocols, PPE usage, and farm safety SOPs (Standard Operating Procedures). Critical for OSHA anti-retaliation compliance documentation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthsComments rdf:type rdf:Property ;
    rdfs:label 'Strengths Comments' ;
    rdfs:comment 'Reviewer\'s narrative comments documenting the employee\'s key strengths, notable contributions, and positive performance behaviors observed during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfactorsFormCode rdf:type rdf:Property ;
    rdfs:label 'Successfactors Form Code' ;
    rdfs:comment 'The unique form instance identifier assigned by SAP SuccessFactors Performance & Goals module for this review record. Used for system-of-record traceability and integration reconciliation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Violation Incident Date' ;
    rdfs:comment 'Date on which the policy violation or performance incident that triggered the disciplinary action occurred. Null for standard performance reviews. Used for timeline documentation in grievance and legal proceedings.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the organizational unit (department, division, or cost center) to which this position is assigned within the enterprise hierarchy.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:parentPositionId rdf:type rdf:Property ;
    rdfs:label 'Parent Position Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the supervisory position directly above this position in the organizational hierarchy, enabling reporting line traversal.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:budgetedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Headcount' ;
    rdfs:comment 'Number of authorized headcount slots budgeted for this position within the current fiscal planning period. Supports workforce planning, labor budget management, and variance analysis against actual staffing levels.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'EEO-1 job category classification for this position as defined by the EEOC, required for annual EEO-1 Component 1 workforce data reporting. [ENUM-REF-CANDIDATE: executive_senior_officials|first_mid_officials|professionals|technicians|sales_workers|administrative_support|craft_workers|operatives|laborers_helpers|service_workers — promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Exemption Status' ;
    rdfs:comment 'Classification of the position under the Fair Labor Standards Act (FLSA) indicating whether the role is exempt, non-exempt, or qualifies for the agricultural exemption under FLSA Section 13(b)(12), which affects overtime pay eligibility and minimum wage requirements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Budgeted Full-Time Equivalent (FTE) allocation for this position, expressed as a decimal fraction of a standard full-time schedule (e.g., 1.00 = full-time, 0.50 = half-time). Used for headcount planning, labor cost budgeting, and workforce capacity analysis.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:h2aEligible rdf:type rdf:Property ;
    rdfs:label 'H2a Eligible' ;
    rdfs:comment 'Indicates whether this position qualifies for staffing under the DOL H-2A Temporary Agricultural Worker visa program, which allows agricultural employers to bring foreign nationals to the U.S. to fill temporary or seasonal agricultural jobs. Required for DOL H-2A job order filings.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed narrative description of the duties, responsibilities, and working conditions for this position, as published in DOL H-2A job orders, internal job postings, and USDA labor compliance documentation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad functional grouping that classifies the position into an agricultural job family for workforce planning, compensation benchmarking, and labor cost allocation. [ENUM-REF-CANDIDATE: agronomy|livestock|equipment_operations|food_processing|administration|supply_chain|quality_compliance|research_development — promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Min Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this position, used in job postings, H-2A job order filings, and candidate screening within SAP SuccessFactors Recruiting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Min Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this position, as specified in job postings and DOL H-2A job order filings.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minWageTier rdf:type rdf:Property ;
    rdfs:label 'Min Wage Tier' ;
    rdfs:comment 'Applicable minimum wage tier for this position, distinguishing between federal minimum wage, state minimum wage, DOL Adverse Effect Wage Rate (AEWR) for H-2A positions, piece-rate compensation structures common in agricultural harvesting, or negotiated collective bargaining rates.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation pay grade band assigned to this position, used for salary range management, compensation benchmarking, and labor cost budgeting within the enterprise pay structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalDemandsRating rdf:type rdf:Property ;
    rdfs:label 'Physical Demands Rating' ;
    rdfs:comment 'DOL Dictionary of Occupational Titles (DOT) physical demands rating for this position, classifying the level of physical exertion required. Used for ADA accommodation assessments, OSHA ergonomic risk evaluation, and H-2A job order physical requirements disclosure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the position within the enterprise, used in DOL H-2A job order filings, USDA labor compliance reporting, and integration with SAP SuccessFactors and payroll systems.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the authorized position indicating whether it is active and available for staffing, frozen due to budget constraints, pending organizational approval, or eliminated from the headcount plan.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Eligible' ;
    rdfs:comment 'Indicates whether this position is eligible for remote or hybrid work arrangements. Most field operations, livestock handling, and equipment operation positions are not remote-eligible; administrative and analytical roles may qualify.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCdl rdf:type rdf:Property ;
    rdfs:label 'Requires Cdl' ;
    rdfs:comment 'Indicates whether this position requires a valid Commercial Driver\'s License (CDL) for operating agricultural transport vehicles, grain trucks, or heavy equipment on public roads, as regulated by FMCSA.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresGapTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Gap Training' ;
    rdfs:comment 'Indicates whether this position requires completion of Good Agricultural Practices (GAP) training as part of USDA GAP/GHP certification requirements and FSMA Produce Safety Rule compliance. Applicable to field workers, supervisors, and food handling personnel.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHaccpCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Haccp Certification' ;
    rdfs:comment 'Indicates whether this position requires HACCP (Hazard Analysis and Critical Control Points) food safety certification, applicable to roles in food processing, packing, and quality assurance functions subject to FDA FSMA and USDA FSIS regulations.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresOshaCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Osha Certification' ;
    rdfs:comment 'Specifies the OSHA safety training certification required for this position: OSHA 10-hour General Industry or Construction, OSHA 30-hour for supervisory roles, OSHA Agriculture standard (29 CFR Part 1928), or none required. Used for workforce compliance tracking and training planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPesticideLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Pesticide License' ;
    rdfs:comment 'Indicates whether this position requires a valid state-issued pesticide applicator license as mandated by the EPA Federal Insecticide, Fungicide, and Rodenticide Act (FIFRA) and state pesticide regulations. Positions such as Pesticide Applicator and Crop Protection Specialist typically require this certification.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalEndMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Month' ;
    rdfs:comment 'Calendar month (1–12) in which seasonal positions typically conclude staffing, used for annual workforce planning, H-2A visa petition duration, and labor demand forecasting aligned with crop harvest completion and post-harvest handling.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalStartMonth rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Month' ;
    rdfs:comment 'Calendar month (1–12) in which seasonal positions typically begin staffing, used for annual workforce planning, H-2A visa petition timing, and labor demand forecasting aligned with crop planting and harvest cycles.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Classification of the standard work schedule pattern for this position, distinguishing between standard daytime schedules, rotating shifts for processing facilities, seasonally variable hours common in agricultural operations, on-call arrangements, and piece-rate flexible schedules.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Employee Id' ;
    rdfs:comment 'Reference to the primary affected employee involved in the safety incident. Links to the workforce.employee master record for demographic, job, and compliance details.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Work Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.work_assignment. Business justification: Safety incidents occur during specific work assignments. Linking safety_event to work_assignment enables analysis of which tasks, fields, and shift patterns generate the most incidents — critical for ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkAssignment .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'The body part(s) injured or affected by the safety incident (e.g., \'right hand\', \'lower back\', \'eyes\', \'respiratory system\'). Required for OSHA 300 log and workers compensation claim documentation.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Amount' ;
    rdfs:comment 'Total incurred cost of the workers compensation claim in USD, including medical expenses and indemnity payments. Used for agricultural insurance premium optimization, EMR management, and OPEX reporting.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the employee was unable to work due to the injury or illness. Key metric for OSHA 300 log, lost-time incident rate calculation, and EMR (Experience Modification Rate) management.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOnRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days On Restricted Duty' ;
    rdfs:comment 'Number of calendar days the employee worked on restricted duty or was transferred to another job due to the injury or illness. Required for OSHA 300 log and return-to-work program tracking.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentDatetime rdf:type rdf:Property ;
    rdfs:label 'Incident Datetime' ;
    rdfs:comment 'The exact date and time the safety event occurred in the field, facility, or operation. This is the principal real-world event timestamp used for OSHA 300 log reporting and EMR calculations.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuryIllnessDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Description' ;
    rdfs:comment 'Detailed narrative description of the nature of the injury or illness sustained (e.g., \'laceration to right index finger requiring 3 stitches\', \'organophosphate pesticide exposure causing nausea and dizziness\'). PHI — restricted access. Required for OSHA 300 log.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier' ;
    rdfs:comment 'Name of the workers compensation insurance carrier handling the claim. Used for insurance premium optimization, carrier performance tracking, and agricultural insurance management.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitleAtIncident rdf:type rdf:Property ;
    rdfs:label 'Job Title At Incident' ;
    rdfs:comment 'The employee\'s job title at the time of the incident. Captured as a snapshot because the employee\'s current title may change after the incident. Used for occupational injury pattern analysis.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentType rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Type' ;
    rdfs:comment 'Classification of the highest level of medical treatment received for the injury or illness. Determines OSHA recordability threshold and workers compensation claim type. First aid only incidents are generally not OSHA recordable.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300LogEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Entry Number' ;
    rdfs:comment 'The sequential case number assigned to this incident on the OSHA 300 Log of Work-Related Injuries and Illnesses. Required for OSHA recordable incidents. Used for annual OSHA 300A summary and regulatory audit.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for entry on the OSHA 300 Log of Work-Related Injuries and Illnesses. Drives annual OSHA 300A summary reporting and EMR calculation.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pesticideInvolved rdf:type rdf:Property ;
    rdfs:label 'Pesticide Involved' ;
    rdfs:comment 'Indicates whether a pesticide, herbicide, fungicide, or other agricultural chemical was involved in the incident. Triggers EPA and state pesticide regulatory reporting requirements and PHI/REI compliance review.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeDescription rdf:type rdf:Property ;
    rdfs:label 'Ppe Description' ;
    rdfs:comment 'Description of the PPE that was in use or should have been in use at the time of the incident (e.g., \'chemical-resistant gloves, face shield, Tyvek suit\'). Relevant for pesticide exposure and chemical handling incidents.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeInUse rdf:type rdf:Property ;
    rdfs:label 'Ppe In Use' ;
    rdfs:comment 'Indicates whether the employee was wearing or using required Personal Protective Equipment (PPE) at the time of the incident. Critical for root cause analysis and PPE compliance program evaluation.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'Date and time the safety incident was formally reported to the supervisor or safety officer. OSHA requires incidents to be reported within 24 hours (fatality/hospitalization within 8 hours). Used to measure reporting lag compliance.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subrogationFlag rdf:type rdf:Property ;
    rdfs:label 'Subrogation Flag' ;
    rdfs:comment 'Indicates whether the workers compensation claim has been flagged for subrogation — recovery of claim costs from a liable third party (e.g., equipment manufacturer, chemical supplier). Supports insurance cost recovery efforts.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskBeingPerformed rdf:type rdf:Property ;
    rdfs:label 'Task Being Performed' ;
    rdfs:comment 'Description of the specific agricultural task or activity the employee was performing when the incident occurred (e.g., \'pesticide application\', \'grain bin entry\', \'livestock loading\'). Critical for root cause analysis and SOP review.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Names of witnesses present at the time of the incident. Stored as a delimited string for investigation documentation. Confidential — used for internal investigation purposes only.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Filed' ;
    rdfs:comment 'Indicates whether a workers compensation claim has been filed in connection with this safety incident. Triggers the workers compensation claim tracking workflow.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workersCompClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Number' ;
    rdfs:comment 'The claim number assigned by the insurance carrier for the workers compensation claim associated with this incident. Used for claim tracking, insurance premium management, and EMR calculation.' ;
    rdfs:domain ind:SafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual time and attendance record in the agricultural workforce management system.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Reference to the employee whose time is being recorded. Links to the workforce employee master record in SAP SuccessFactors.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:successfactorsTimeEventId rdf:type rdf:Property ;
    rdfs:label 'Successfactors Time Event Id' ;
    rdfs:comment 'The native time event identifier from SAP SuccessFactors Time Management module. Enables bidirectional reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Reason code explaining why this time entry was amended. Required when is_amended is True. Supports compliance audit trails and payroll dispute resolution. [ENUM-REF-CANDIDATE: missed_punch|task_correction|hours_adjustment|pay_type_change|field_reassignment|supervisor_correction|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text notes entered by the supervisor during the approval or rejection of the time entry. Documents reasons for adjustments, exceptions, or rejections for audit purposes.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Minutes' ;
    rdfs:comment 'Total unpaid break time in minutes deducted from the shift. Includes meal breaks and rest periods as required by OSHA and applicable state labor laws.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'Exact date and time the employee clocked in to begin their work shift. Captured from time clock, mobile app, or supervisor entry in SAP SuccessFactors.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'Exact date and time the employee clocked out to end their work shift. Null if the shift is still in progress or if clock-out was not recorded.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total gross wages earned for this time entry before deductions. Calculated from regular hours, overtime hours, and/or piece-rate units. Feeds into SAP SuccessFactors payroll processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:h2aGuaranteeHours rdf:type rdf:Property ;
    rdfs:label 'H2a Guarantee Hours' ;
    rdfs:comment 'The guaranteed minimum hours applicable to H-2A workers for this period, representing 75% of the total workdays in the contract period. Used to verify employer compliance with H-2A three-fourths guarantee obligation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'Indicates whether this time entry has been amended or corrected after initial submission. Amended records require supervisor re-approval and are flagged for payroll audit review.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Indicates whether this time entry includes overtime hours subject to premium pay rates. Set to True when overtime_hours is greater than zero.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total overtime hours worked beyond the standard FLSA threshold (40 hours/week or applicable state law). Triggers overtime pay rate calculation in payroll.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'The payroll period (ISO week format YYYY-Www) to which this time entry belongs. Used for FLSA workweek aggregation, H-2A three-fourths guarantee calculations, and payroll batch processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Total regular (non-overtime) hours worked during this time entry period. Used for standard wage calculation and H-2A three-fourths guarantee tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the work shift for this time entry. Night and split shifts may carry differential pay rates. Relevant for OSHA heat illness prevention compliance during day shifts.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the agricultural work was performed. Primary date dimension for payroll period calculations and FLSA workweek compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Identifier of the employee (attendee) enrolled in or who completed this training event. Links to the workforce employee master record in SAP SuccessFactors.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Actual Attendee Count' ;
    rdfs:comment 'Actual number of employees who attended this training event session. Used for compliance reporting, cost allocation, and training effectiveness analysis.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the employee on the post-training assessment or exam, expressed as a percentage (0.00–100.00). Used to determine pass/fail status and competency level.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a training completion certificate was issued to the employee upon successful completion of this training event. True = certificate issued; False = not issued.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceuCredits rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits' ;
    rdfs:comment 'Number of Continuing Education Unit (CEU) credits awarded upon successful completion of this training event. Applicable for pesticide applicator license renewal and professional development tracking.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curriculumVersion rdf:type rdf:Property ;
    rdfs:label 'Curriculum Version' ;
    rdfs:comment 'Version identifier of the training curriculum or course materials used for this event (e.g., \'v2.3\', \'2024-Q1\'). Ensures audit trail integrity when regulatory requirements change and curriculum is updated.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Human-readable title or name of the training session (e.g., \'GAP Awareness Training\', \'HACCP Food Safety Fundamentals\', \'WPS Pesticide Safety\', \'H-2A Worker Rights Orientation\'). Used in reports, certificates, and audit documentation.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aOrientationFlag rdf:type rdf:Property ;
    rdfs:label 'H2a Orientation Flag' ;
    rdfs:comment 'Indicates whether this training event fulfills the H-2A visa program worker rights orientation requirement under DOL regulations. True = qualifies as H-2A orientation; False = does not fulfill H-2A orientation requirement.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAttendees rdf:type rdf:Property ;
    rdfs:label 'Max Attendees' ;
    rdfs:comment 'Maximum number of attendees permitted for this training event session. Used for scheduling, capacity planning, and ensuring adequate trainer-to-trainee ratios for hands-on safety training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum assessment score percentage required to pass this training event and receive credit or certification. Varies by training type and regulatory requirement.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiration Date' ;
    rdfs:comment 'Date on which the qualification, certification, or compliance credit earned from this training event expires and retraining is required. Critical for pesticide applicator CEU renewal, OSHA certifications, and GLOBALG.A.P. annual training requirements.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Retraining Due Date' ;
    rdfs:comment 'Date by which the employee must complete retraining for this training type. Populated when retraining_required is True. Used for compliance deadline tracking and workforce scheduling.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Retraining Required' ;
    rdfs:comment 'Indicates whether the employee is required to retake this training (e.g., due to failed assessment, regulatory change, incident, or qualification expiration). True = retraining required; False = no retraining needed.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainerCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Trainer Certification Number' ;
    rdfs:comment 'License or certification number of the trainer, particularly for pesticide safety and applicator training where a certified trainer is required by EPA and state regulations.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerName rdf:type rdf:Property ;
    rdfs:label 'Trainer Name' ;
    rdfs:comment 'Full name of the trainer or instructor who delivered the training. Captured for audit documentation when the trainer may be external or when trainer_id is not available. Required for GLOBALG.A.P. and EPA WPS compliance records.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerOrganization rdf:type rdf:Property ;
    rdfs:label 'Trainer Organization' ;
    rdfs:comment 'Name of the organization or company the trainer represents (e.g., internal department, external training provider, university extension service, regulatory agency). Distinguishes internal from third-party training delivery.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'Total cost incurred to deliver this training event, including trainer fees, materials, venue, and external provider charges. Used for labor cost allocation (OPEX) across farm operations and processing facilities in SAP CO module.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., \'Main Barn Conference Room\', \'Field Block 4A\', \'Online - SuccessFactors LMS\', \'Processing Facility Training Center\'). Required for GLOBALG.A.P. and FSMA audit documentation.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training by regulatory or operational category. Examples include GAP, HACCP, WPS_PESTICIDE_SAFETY, OSHA_HAZCOM, H2A_WORKER_RIGHTS, SEXUAL_HARASSMENT_PREVENTION, EQUIPMENT_OPERATION, EMERGENCY_RESPONSE, FOOD_SAFETY, PESTICIDE_APPLICATOR_CEU. [ENUM-REF-CANDIDATE: GAP|HACCP|WPS_PESTICIDE_SAFETY|OSHA_HAZCOM|H2A_WORKER_RIGHTS|SEXUAL_HARASSMENT_PREVENTION|EQUIPMENT_OPERATION|EMERGENCY_RESPONSE|FOOD_SAFETY|PESTICIDE_APPLICATOR_CEU — promote to reference product]' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wpsHandlerType rdf:type rdf:Property ;
    rdfs:label 'Wps Handler Type' ;
    rdfs:comment 'EPA Worker Protection Standard (WPS) classification of the employee for pesticide safety training purposes. Agricultural Worker = works in treated areas; Pesticide Handler = mixes/loads/applies pesticides; Early Entry Worker = enters treated areas during REI; Not Applicable = WPS training not required for this role.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWorkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Employee Id' ;
    rdfs:comment 'Reference to the individual employee assigned to this work assignment. Links to the employee master record in SAP SuccessFactors. Null when the assignment is crew-level rather than individual.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the work assignment by the nature of the agricultural task. Determines applicable compliance requirements (e.g., spray_crew triggers REI tracking, pesticide applicator license verification). [ENUM-REF-CANDIDATE: field_crew|equipment_operator|spray_crew|harvest_crew|livestock_handler|irrigation_crew|scouting|administrative|maintenance_crew|transport_driver — promote to reference product]' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of workers assigned to this work assignment. Used for labor capacity planning, field productivity analysis, and compliance with minimum crew size requirements for certain operations.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of days on which this assignment recurs within the schedule period (e.g., \'MON,TUE,WED,THU,FRI\'). Supports recurring shift scheduling and weekly labor planning.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborType rdf:type rdf:Property ;
    rdfs:label 'Labor Type' ;
    rdfs:comment 'Classification of the labor category for this assignment. Drives compliance requirements: \'h2a_visa\' triggers H-2A program compliance; \'migrant\' triggers MSPA compliance; \'contract\' triggers third-party labor tracking.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationNotes rdf:type rdf:Property ;
    rdfs:label 'Location Notes' ;
    rdfs:comment 'Free-text field for additional location details or directions relevant to the assignment (e.g., \'Enter via north gate, report to row marker 12A\', GPS waypoint reference). Supplements the field_id or facility_id reference.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaSafetyCertRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Cert Required' ;
    rdfs:comment 'Indicates whether a valid OSHA safety certification is required for the worker performing this assignment. Applies to equipment operators, chemical handlers, and confined space entry assignments.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'The hourly or piece-rate wage applicable to this work assignment. Used for labor cost calculation, OPEX reporting, and H-2A Adverse Effect Wage Rate (AEWR) compliance verification.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateUnit rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Unit' ;
    rdfs:comment 'The unit of measure for the pay rate (e.g., \'hourly\' for time-based wages, \'piece_rate\' for production-based pay such as per-bin or per-bushel). Required for accurate payroll calculation.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Description of the Personal Protective Equipment (PPE) required for this assignment (e.g., \'Chemical-resistant gloves, respirator, coveralls\'). Derived from SDS and pesticide label requirements. Supports OSHA and EPA WPS compliance.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reiExpiryTime rdf:type rdf:Property ;
    rdfs:label 'Rei Expiry Time' ;
    rdfs:comment 'The date and time after which workers may safely re-enter the field following a pesticide application. Null when rei_restricted is False. Enforces EPA Worker Protection Standard REI compliance in scheduling.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total number of hours planned for this work assignment shift or period. Used for labor budgeting, OPEX planning, and comparison against actual hours worked.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The precise date and time when the assigned shift ends. Used for overtime calculation, labor cost allocation, and compliance with FLSA agricultural hour regulations.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The precise date and time when the assigned shift begins. Used for time-and-attendance tracking, REI compliance (field re-entry after pesticide application), and labor cost calculation.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Free-text description of the specific agricultural task or operation to be performed during this assignment (e.g., \'Apply pre-emergent herbicide to corn fields 12A-12D\', \'Hand-harvest strawberries — rows 1-50\'). Supports traceability of who performed which operation.' ;
    rdfs:domain ind:WorkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlClass rdf:type rdf:Property ;
    rdfs:label 'Cdl Class' ;
    rdfs:comment 'DOT-defined class of Commercial Driver License (CDL): \'A\' (combination vehicles over 26,001 lbs), \'B\' (single vehicles over 26,001 lbs), or \'C\' (vehicles carrying 16+ passengers or hazardous materials). Applicable only when certification_type is CDL. Null for non-CDL certifications.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlEndorsements rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsements' ;
    rdfs:comment 'Comma-separated list of DOT endorsement codes on the CDL (e.g., \'H\' for hazardous materials, \'T\' for double/triple trailers, \'N\' for tank vehicles, \'X\' for tanker with hazmat). Applicable only when certification_type is CDL.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full descriptive name of the certification or license as issued by the governing authority (e.g., \'California Commercial Pesticide Applicator License — Field Crops\', \'OSHA 30-Hour General Industry Safety Card\', \'HACCP Certification — Food Safety Management\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Ceu Hours Completed' ;
    rdfs:comment 'Total number of Continuing Education Unit (CEU) hours the worker has completed toward the current renewal requirement. Compared against ceu_hours_required to determine renewal eligibility and compliance standing.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceuHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Ceu Hours Required' ;
    rdfs:comment 'Total number of Continuing Education Unit (CEU) hours required for renewal of this certification within the current certification period. Particularly relevant for pesticide applicator license renewals mandated by state departments of agriculture.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examPassScore rdf:type rdf:Property ;
    rdfs:label 'Exam Pass Score' ;
    rdfs:comment 'Minimum score required to pass the certification examination as defined by the issuing authority. Used to validate exam_score against the passing threshold and confirm certification eligibility.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRenewalRequired rdf:type rdf:Property ;
    rdfs:label 'Is Renewal Required' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal to remain valid. True = renewal required (e.g., pesticide applicator licenses, CDL, food handler permits); False = lifetime credential with no renewal requirement (e.g., some OSHA completion cards).' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedUsePesticideAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Use Pesticide Authorized' ;
    rdfs:comment 'Indicates whether this pesticide applicator license authorizes the worker to purchase and apply Restricted Use Pesticides (RUP) as defined by EPA under FIFRA. True = authorized for RUP; False = limited to general use pesticides only. Critical for EPA compliance and pesticide procurement controls.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the certification or license has been independently verified against the issuing authority\'s records (e.g., state pesticide applicator license lookup, DOT FMCSA CDL verification, OSHA card validation). True = verified; False = self-reported or pending verification.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobRoleCode rdf:type rdf:Property ;
    rdfs:label 'Job Role Code' ;
    rdfs:comment 'Code identifying the worker\'s job role or position for which this certification is required or relevant (e.g., \'PEST_APPLICATOR\', \'FORKLIFT_OPR\', \'CDL_DRIVER\', \'FOOD_HANDLER\', \'AGRONOMIST\'). Used for workforce compliance gap analysis.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaCardType rdf:type rdf:Property ;
    rdfs:label 'Osha Card Type' ;
    rdfs:comment 'Specific OSHA safety training card type: \'10_hour_general\' (OSHA 10-hour General Industry), \'30_hour_general\' (OSHA 30-hour General Industry), \'10_hour_construction\' (OSHA 10-hour Construction), or \'30_hour_construction\' (OSHA 30-hour Construction). Applicable only when certification_type is osha_10 or osha_30.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideApplicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator Category' ;
    rdfs:comment 'EPA-defined certification category for pesticide applicator licenses, specifying the type of pesticide use authorized (e.g., \'field crops\', \'ornamental and turf\', \'right-of-way\', \'aquatic\', \'seed treatment\', \'soil fumigation\'). Applicable only when certification_type is pesticide_applicator. [ENUM-REF-CANDIDATE: field_crops|ornamental_turf|right_of_way|aquatic|seed_treatment|soil_fumigation|forest|public_health|regulatory_pest_control|demonstration_research — promote to reference product]' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pesticideApplicatorClass rdf:type rdf:Property ;
    rdfs:label 'Pesticide Applicator Class' ;
    rdfs:comment 'EPA classification of the pesticide applicator license: \'private\' (applies restricted-use pesticides on own or employer\'s agricultural land), \'commercial\' (applies pesticides for hire or on others\' property), or \'public\' (applies pesticides as a government employee). Null for non-pesticide certifications.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization, institution, or accredited body that delivered the training or examination leading to this certification (e.g., \'Purdue Extension\', \'National Pesticide Safety Education Center\', \'OSHA Training Institute Education Center\', \'NSF International\').' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or employee identifier of the HR staff member, compliance officer, or supervisor who performed the credential verification. Supports audit trail requirements for GLOBALG.A.P., FSMA, and state department of agriculture audits.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the workforce plan record. Primary key for the workforce_plan data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual number of workers onboarded and active for this position type during the plan period. Compared against planned_headcount to compute headcount variance for KPI reporting and future plan calibration.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLaborCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost Usd' ;
    rdfs:comment 'Actual labor cost incurred in US dollars for this workforce plan record during the plan period. Compared against planned_labor_cost_usd to compute cost variance for EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) reporting and budget reforecasting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicantCountApplied rdf:type rdf:Property ;
    rdfs:label 'Applicant Count Applied' ;
    rdfs:comment 'Total number of applicants who have submitted applications for positions under this workforce plan. Tracks top-of-funnel recruitment pipeline volume in SAP SuccessFactors Recruiting Management.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantCountInterviewed rdf:type rdf:Property ;
    rdfs:label 'Applicant Count Interviewed' ;
    rdfs:comment 'Number of applicants who have progressed to the interview stage for positions under this workforce plan. Used to compute interview conversion rate and assess recruitment pipeline health.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantCountOffered rdf:type rdf:Property ;
    rdfs:label 'Applicant Count Offered' ;
    rdfs:comment 'Number of applicants who have received a formal job offer under this workforce plan. Used to compute offer acceptance rate and assess late-stage recruitment pipeline conversion.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cropOperationType rdf:type rdf:Property ;
    rdfs:label 'Crop Operation Type' ;
    rdfs:comment 'Agricultural operation type driving the labor demand for this plan. Aligns workforce demand with crop lifecycle phases from Granular Farm Management and Climate FieldView. [ENUM-REF-CANDIDATE: planting|cultivation|irrigation|crop_protection|harvesting|post_harvest|livestock|processing|general — promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticWorkerCount rdf:type rdf:Property ;
    rdfs:label 'Domestic Worker Count' ;
    rdfs:comment 'Number of domestic (U.S.) workers included in the planned headcount. DOL requires documented domestic recruitment effort before H-2A petition approval; this field tracks the domestic labor component to demonstrate compliance.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flcContractorName rdf:type rdf:Property ;
    rdfs:label 'Flc Contractor Name' ;
    rdfs:comment 'Name of the Farm Labor Contractor (FLC) engaged to supply workers for this workforce plan, if applicable. FLCs must be registered under MSPA (Migrant and Seasonal Agricultural Worker Protection Act). Null if direct hire or H-2A agent channel is used.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flcRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Flc Registration Number' ;
    rdfs:comment 'DOL-issued MSPA registration number for the Farm Labor Contractor (FLC) engaged under this workforce plan. Required for MSPA compliance verification and audit documentation. Null if no FLC is engaged.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aWorkerCount rdf:type rdf:Property ;
    rdfs:label 'H2a Worker Count' ;
    rdfs:comment 'Number of H-2A temporary agricultural workers included in the planned headcount. Required for DOL H-2A petition preparation and documented domestic recruitment effort compliance. H-2A (H-2A Visa Program) is the USDA/DOL program for temporary foreign agricultural workers.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountVariance rdf:type rdf:Property ;
    rdfs:label 'Headcount Variance' ;
    rdfs:comment 'Difference between planned_headcount and actual_headcount (planned minus actual). Positive value indicates understaffing; negative indicates overstaffing. Used for KPI (Key Performance Indicator) headcount variance analysis and future seasonal plan calibration.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingUnitsRequired rdf:type rdf:Property ;
    rdfs:label 'Housing Units Required' ;
    rdfs:comment 'Number of housing units required to accommodate H-2A and migrant workers under this workforce plan. H-2A regulations mandate employer-provided housing; this field supports housing procurement and DOL compliance documentation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Rate' ;
    rdfs:comment 'Percentage of job offers accepted by candidates for positions under this workforce plan (applicants accepted / applicants offered × 100). KPI for recruitment effectiveness and seasonal hiring campaign management.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Reference to the organizational unit (department, division, or cost center) responsible for this workforce plan. Supports labor cost allocation across farm operations and processing facilities in SAP SuccessFactors and SAP S/4HANA CO module.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'Total number of workers projected to be required for this position type during the plan period. Drives H-2A job order quantity, farm labor contractor (FLC) engagement scope, and CAPEX/OPEX labor budget calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLaborCostUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Cost Usd' ;
    rdfs:comment 'Total budgeted labor cost in US dollars for this workforce plan record, inclusive of wages, H-2A housing and transportation allowances, and employer-side payroll taxes. Feeds CAPEX/OPEX labor budgeting in SAP S/4HANA CO and Granular Farm Management financial planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'Classification of the planning horizon for this workforce plan. Annual plans cover full fiscal year headcount budgets; seasonal plans align with crop cycles (planting, cultivation, harvest); ad-hoc plans address unplanned labor demand spikes or emergency staffing needs.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentChannel rdf:type rdf:Property ;
    rdfs:label 'Recruitment Channel' ;
    rdfs:comment 'Primary channel through which workers for this plan are to be recruited. Drives campaign management and FLC (Farm Labor Contractor) engagement planning. Values: direct_hire, farm_labor_contractor (FLC), h2a_agent (H-2A visa agent), job_fair, referral, online_portal.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Target date by which recruited workers should be onboarded and ready to begin work. Drives backward scheduling of recruitment activities and H-2A petition filing timelines (DOL requires petition at least 45 days before need date).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Average number of calendar days from requisition opening to accepted offer for positions under this workforce plan. KPI for recruitment efficiency; critical for seasonal operations where late hiring directly impacts crop yield.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationRequired rdf:type rdf:Property ;
    rdfs:label 'Transportation Required' ;
    rdfs:comment 'Indicates whether employer-provided transportation is required for workers under this workforce plan. H-2A regulations mandate transportation from the worker\'s home country to the worksite and daily field transportation. Drives TMS (Transportation Management System) planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorProductApprovalId rdf:type rdf:Property ;
    rdfs:label 'Vendor Product Approval Id' ;
    rdfs:comment 'Primary key for the vendor_product_approval association' ;
    rdfs:domain ind:VendorProductApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedInputCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Input Categories' ;
    rdfs:comment 'Comma-delimited list of agricultural input categories this vendor is approved to supply (e.g., \'seeds,NPK_fertilizers,herbicides\'). Restricts PO creation to approved categories only. Managed as part of the vendor qualification record. [Moved from vendor: This comma-delimited string in vendor is a denormalized approximation of the vendor-product approval relationship. The structured vendor_product_approval association supersedes this field by providing proper per-product approval records with full qualification attributes. The approved_input_categories field should be deprecated in favor of querying this association.]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Rank' ;
    rdfs:comment 'Ordinal ranking of this vendor relative to other approved vendors for the same input product (1 = primary/preferred, 2 = secondary, etc.). Belongs to the pairing — the same vendor may be ranked 1 for one product and 3 for another.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days from purchase order placement to expected delivery for this specific vendor-product combination. Varies by vendor-product pairing and is used in procurement planning.' ;
    rdfs:domain ind:VendorProductApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Price' ;
    rdfs:comment 'Negotiated or catalog unit price for this input product from this specific vendor. Belongs to the pairing — the same product may have different prices from different vendors.' ;
    rdfs:domain ind:VendorProductApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRegion rdf:type rdf:Property ;
    rdfs:label 'Supply Region' ;
    rdfs:comment 'Geographic region or territory from which this vendor is approved to supply this input product. A vendor may supply the same product from different regions under different terms.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Seed Supply Agreement Id' ;
    rdfs:comment 'Primary key for the seed_supply_agreement association' ;
    rdfs:domain ind:SeedSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplySeason rdf:type rdf:Property ;
    rdfs:label 'Supply Season' ;
    rdfs:comment 'The growing or crop year season for which this supply agreement is active (e.g., \'2024_SPRING\', \'2024_FALL\'). Agreements are typically renewed or renegotiated each season.' ;
    rdfs:domain ind:SeedSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCommodityProgramId rdf:type rdf:Property ;
    rdfs:label 'Account Commodity Program Id' ;
    rdfs:comment 'Primary key for the account_commodity_program association' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCommodityProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Account Commodity Program Status' ;
    rdfs:comment 'Current lifecycle status of this account-commodity program record. Controls whether the agreement is active, pending renewal, suspended, or terminated.' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Required Flag' ;
    rdfs:comment 'Indicates whether this account requires USDA NOP organic certification for this specific commodity under this agreement. Commodity-level organic eligibility (organic_eligible_flag on commodity) is a prerequisite but this flag captures the account\'s contractual requirement.' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCommodityCategories rdf:type rdf:Property ;
    rdfs:label 'Preferred Commodity Categories' ;
    rdfs:comment 'Comma-separated list of agricultural commodity categories this customer account primarily purchases (e.g., grains, oilseeds, fresh produce, livestock, dairy). Used for demand planning, sales targeting, and product recommendation. [Moved from account: This denormalized comma-separated string field on account attempts to capture the account-commodity preference relationship but cannot enforce referential integrity, store per-commodity attributes (volume, pricing, GMO requirements), or support effective dating. It should be fully replaced by the account_commodity_program association, which properly models each account-commodity pairing as a first-class record.]' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVolumeMt rdf:type rdf:Property ;
    rdfs:label 'Preferred Volume Mt' ;
    rdfs:comment 'The committed or preferred procurement volume in metric tons for this account-commodity pairing within the effective period. Belongs to the agreement, not to the account or commodity alone.' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceTierCode rdf:type rdf:Property ;
    rdfs:label 'Price Tier Code' ;
    rdfs:comment 'The negotiated pricing tier code applicable to this account for this specific commodity. Pricing tiers vary by account-commodity combination and cannot reside on either entity alone.' ;
    rdfs:domain ind:AccountCommodityProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Enrollment Id' ;
    rdfs:comment 'Primary key for the bundle_enrollment association' ;
    rdfs:domain ind:BundleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of this bundle enrollment record. Tracks whether the enrollment is active, pending confirmation, cancelled by the account, fulfilled (all contracted volume delivered), or expired at season end.' ;
    rdfs:domain ind:BundleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Early Order Flag' ;
    rdfs:comment 'Indicates whether this enrollment was submitted under an early-order incentive program, qualifying the account for additional discounts, priority allocation, or deferred payment terms. Set at enrollment_date based on program availability_start_date thresholds.' ;
    rdfs:domain ind:BundleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingOverridePct rdf:type rdf:Property ;
    rdfs:label 'Pricing Override Pct' ;
    rdfs:comment 'Account-specific percentage adjustment to the bundle list price negotiated at enrollment time. A negative value represents a discount; a positive value represents a surcharge. Overrides the standard bundle_discount_pct for this specific account-bundle combination.' ;
    rdfs:domain ind:BundleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonYear rdf:type rdf:Property ;
    rdfs:label 'Season Year' ;
    rdfs:comment 'The crop season year to which this enrollment applies (e.g., \'2024\', \'2025\'). Scopes the enrollment to a specific agricultural production season, enabling year-over-year program tracking and renewal management.' ;
    rdfs:domain ind:BundleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualRolePartnershipId rdf:type rdf:Property ;
    rdfs:label 'Dual Role Partnership Id' ;
    rdfs:comment 'Primary key for the dual_role_partnership association' ;
    rdfs:domain ind:DualRolePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityScope rdf:type rdf:Property ;
    rdfs:label 'Commodity Scope' ;
    rdfs:comment 'Comma-delimited list of agricultural commodity categories covered under this dual-role partnership. Defines which commodities the entity buys as a customer and/or supplies as a vendor within this specific arrangement.' ;
    rdfs:domain ind:DualRolePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietyLicenseId rdf:type rdf:Property ;
    rdfs:label 'Variety License Id' ;
    rdfs:comment 'Primary key for the variety_license association' ;
    rdfs:domain ind:VarietyLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensedGeography rdf:type rdf:Property ;
    rdfs:label 'Licensed Geography' ;
    rdfs:comment 'The geographic scope within which the account is authorized to use or distribute the variety. May be expressed as country codes, state/province codes, or a named region. Unique per account-variety license agreement.' ;
    rdfs:domain ind:VarietyLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietyLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Variety License Status' ;
    rdfs:comment 'Current lifecycle status of the variety license agreement. Controls whether the account currently holds active authorization for the variety.' ;
    rdfs:domain ind:VarietyLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customHireContractId rdf:type rdf:Property ;
    rdfs:label 'Custom Hire Contract Id' ;
    rdfs:comment 'Primary key for the custom_hire_contract association' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedAcres rdf:type rdf:Property ;
    rdfs:label 'Contracted Acres' ;
    rdfs:comment 'Total number of acres of farmland agreed upon in this custom hire contract for the asset to service for the customer account. This value is specific to the asset-customer engagement and cannot reside on either master record.' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current operational and contractual performance status of this custom hire engagement. Tracks whether the service contract is being fulfilled, has been completed, or has encountered issues. Belongs to the contract lifecycle, not the asset or account.' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerHour rdf:type rdf:Property ;
    rdfs:label 'Rate Per Hour' ;
    rdfs:comment 'Agreed billing rate per engine/operating hour for this specific asset-account custom hire engagement. Rate varies by asset type, customer tier, and season — it belongs to the contract, not the asset or account master.' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date on which the contracted equipment service engagement concludes for this specific asset-account pairing. Belongs to the contract, not the asset or account, as the same asset ends on different dates for different customers.' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date on which the contracted equipment service engagement begins for this specific asset-account pairing. Belongs to the contract, not the asset or account, as the same asset starts on different dates for different customers.' ;
    rdfs:domain ind:CustomHireContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierLocationApprovalId rdf:type rdf:Property ;
    rdfs:label 'Carrier Location Approval Id' ;
    rdfs:comment 'Primary key for the carrier_location_approval association' ;
    rdfs:domain ind:CarrierLocationApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Code' ;
    rdfs:comment 'Code identifying the preferred transportation carrier for deliveries to this location. Used by TMS for carrier selection and rate tendering. Corresponds to the carrier master in SAP TMS or Manhattan Associates TMS. [Moved from delivery_location: This attribute on delivery_location captures a single preferred carrier as a soft string reference. With the CarrierLocationApproval association in place, preferred carrier designation is properly modeled via the preferred_flag on the association record, which supports multiple approved carriers per location with one flagged as preferred. The string code on delivery_location is redundant and should be retired in favor of the FK-backed association.]' ;
    rdfs:domain ind:CarrierLocationApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this carrier is the preferred (primary) carrier for deliveries to this location. A location may have one preferred carrier among multiple approved carriers.' ;
    rdfs:domain ind:CarrierLocationApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneCapability rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Capability' ;
    rdfs:comment 'The agreed temperature zone or range (e.g., AMBIENT, REFRIGERATED, FROZEN, CONTROLLED_ROOM_TEMP) that this carrier is approved to maintain for deliveries to this location. Derived from the intersection of carrier cold chain capability and location temperature control requirements.' ;
    rdfs:domain ind:CarrierLocationApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCommodityApprovalId rdf:type rdf:Property ;
    rdfs:label 'Vendor Commodity Approval Id' ;
    rdfs:comment 'Primary key for the vendor_commodity_approval association' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedGradeStandard rdf:type rdf:Property ;
    rdfs:label 'Approved Grade Standard' ;
    rdfs:comment 'The USDA or enterprise grade standard that this vendor is approved to supply for this specific commodity (e.g., US No. 2 Yellow Corn). Belongs to the approval record, not the commodity master or vendor master, because a vendor may be approved for different grade standards on different commodities.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedVolumeUom rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Uom' ;
    rdfs:comment 'The unit of measure in which contracted supply volumes are expressed for this vendor-commodity approval (e.g., BU, MT, CWT). May differ from the commodity standard UOM based on vendor contract terms.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicSupplyEligible rdf:type rdf:Property ;
    rdfs:label 'Organic Supply Eligible' ;
    rdfs:comment 'Indicates whether this vendor is approved to supply the organic-certified variant of this commodity under this approval record. Distinct from the vendor-level organic_cert_number — a vendor may hold organic certification but only be approved for organic supply on a subset of commodities.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'The pricing basis agreed with this vendor for this commodity, typically expressed as a futures market basis (e.g., CBOT +0.05/BU, flat price, or index-linked). Specific to the vendor-commodity combination and cannot reside on either master record.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Ration Ingredient Id' ;
    rdfs:comment 'Primary key for the ration_ingredient association' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dryMatterBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Dry Matter Basis Flag' ;
    rdfs:comment 'Indicates whether the inclusion_rate_pct for this ingredient in this ration is expressed on a dry matter (DM) basis (true) or as-fed basis (false). The same ingredient may be expressed differently across rations depending on nutritionist preference.' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionRatePct rdf:type rdf:Property ;
    rdfs:label 'Inclusion Rate Pct' ;
    rdfs:comment 'The percentage of this ingredient in the ration, expressed as a proportion of the total ration weight. Belongs to the ration-ingredient combination — the same ingredient may have different inclusion rates across different rations.' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredientList rdf:type rdf:Property ;
    rdfs:label 'Ingredient List' ;
    rdfs:comment 'Structured text or JSON-serialized list of feed ingredients included in the ration formulation, with inclusion rates on both as-fed and dry matter basis (e.g., \'corn silage 45%, distillers grains 15%, hay 20%\'). Applicable to formulation records. Supports feed cost analysis and ingredient traceability. [Moved from feed_ration: The ingredient_list STRING/JSON blob on feed_ration is a denormalized encoding of the ration-ingredient M:N relationship. Once the ration_ingredient association product is in place, this attribute becomes redundant and should be deprecated. The structured ration_ingredient records replace it with properly typed, queryable, and auditable individual ingredient rows.]' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientSequence rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence' ;
    rdfs:comment 'The order in which this ingredient is added to the TMR mixer or batch during ration preparation. Critical for mixing quality and nutritional homogeneity. Belongs to the ration-ingredient combination, not to the ingredient or ration alone.' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerBatchKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Batch Kg' ;
    rdfs:comment 'The physical weight in kilograms of this ingredient required per batch mix of the ration. Derived from inclusion rate and batch size but stored explicitly for feed mill operations. Belongs to the ration-ingredient combination.' ;
    rdfs:domain ind:RationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Indicates whether this ingredient in this specific ration may be substituted with an alternative ingredient when the primary ingredient is unavailable. A ration-ingredient-level flag — the same ingredient may be substitutable in one ration but not in another.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedVendorMaterialId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Material Id' ;
    rdfs:comment 'Primary key for the approved_vendor_material association' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Status' ;
    rdfs:comment 'Current qualification status of this vendor for supplying this specific material. Drives procurement system sourcing eligibility checks. Distinct from the vendor-level qualification_status on the vendor master, as a vendor may be globally approved but conditionally approved for a specific material category.' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Price' ;
    rdfs:comment 'Negotiated contracted price per base unit of measure for this vendor-material combination. Cannot reside on material_master (price varies by vendor) nor on vendor (price varies by material). Expressed in the vendor\'s invoicing currency.' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Minimum order quantity (in the material\'s base UOM) required by this vendor for this material. Relationship-specific commercial term that varies by vendor-material combination.' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Rank' ;
    rdfs:comment 'Numeric ranking of this vendor\'s preference for sourcing this material (1 = primary/preferred source, 2 = secondary, etc.). Used by procurement to determine sourcing priority when multiple approved vendors exist for the same material.' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedVendorItemId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Item Id' ;
    rdfs:comment 'Primary key for the approved_vendor_item association' ;
    rdfs:domain ind:ApprovedVendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Number' ;
    rdfs:comment 'SAP S/4HANA vendor account number or Oracle NetSuite vendor ID for the preferred/primary supplier of this input. Used to default vendor selection during purchase requisition creation and supports supplier performance analytics. [Moved from input_catalog: This attribute is the existing 1:N FK that the approved_vendor_item association replaces. It captures only a single preferred vendor per input, which is the incomplete model being upgraded. Once the association table is in place, multi-vendor sourcing is fully represented and this single-vendor reference is redundant and misleading.]' ;
    rdfs:domain ind:ApprovedVendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Status' ;
    rdfs:comment 'Current approval lifecycle status of this vendor-input sourcing relationship. Controls whether procurement can raise POs against this vendor for this input. Distinct from the vendor\'s overall qualification_status.' ;
    rdfs:domain ind:ApprovedVendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Primary key for the vendor_certification association' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gfsiCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gfsi Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the vendor\'s active GFSI-benchmarked food safety certification. Triggers re-qualification workflow when approaching expiry. [Moved from vendor: Expiry date of the vendor\'s GFSI certification instance. Belongs to the vendor_certification association record.]' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gfsiCertNumber rdf:type rdf:Property ;
    rdfs:label 'Gfsi Cert Number' ;
    rdfs:comment 'Certificate number for the vendor\'s active GFSI-benchmarked food safety certification (SQF, BRC, IFS, or FSSC 22000). Used to verify certification validity with the issuing certification body. [Moved from vendor: Vendor-specific GFSI certification number representing a specific vendor\'s holding of a GFSI-benchmarked scheme. Belongs to the vendor_certification association record.]' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalgApCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the vendor\'s GLOBALG.A.P. certification. Procurement blocks should be triggered when this date is within the re-qualification warning window. [Moved from vendor: Expiry date of a specific vendor-certification instance. Belongs to the vendor_certification association record, not the vendor master. Moving it enables proper expiry tracking across all certification types without adding new scalar columns to the vendor master for each scheme.]' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalgApCertNumber rdf:type rdf:Property ;
    rdfs:label 'Globalg Ap Cert Number' ;
    rdfs:comment 'GLOBALG.A.P. (Global Good Agricultural Practices) certification number issued to the vendor. Confirms adherence to internationally recognized GAP standards for safe and sustainable agricultural input production. [Moved from vendor: This is a vendor-specific instance of a GLOBALG.A.P. certification, not a property of the vendor master. It belongs to the vendor_certification association record linking this vendor to the GLOBALG.A.P. sustainability_certification scheme. Storing it on the vendor master prevents tracking multiple GLOBALG.A.P. certifications (e.g., different scopes or renewal cycles) and duplicates data that belongs to the association.]' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsIssueId rdf:type rdf:Property ;
    rdfs:label 'Parts Issue Id' ;
    rdfs:comment 'Primary key for the parts_issue association' ;
    rdfs:domain ind:PartsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of the part returned to inventory after work order completion (unused material). Drives inventory replenishment recalculation and OPEX cost adjustment.' ;
    rdfs:domain ind:PartsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostAtIssue rdf:type rdf:Property ;
    rdfs:label 'Unit Cost At Issue' ;
    rdfs:comment 'Unit cost of the part at the time of issue, captured from the inventory valuation at issue date. Differs from the current unit_cost on parts_inventory due to price fluctuations; belongs to this issue event for accurate historical OPEX costing.' ;
    rdfs:domain ind:PartsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grainDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Grain Delivery Id' ;
    rdfs:comment 'Primary key for the grain_delivery association' ;
    rdfs:domain ind:GrainDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedQuantityMt rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity Mt' ;
    rdfs:comment 'Quantity of grain from this yield record allocated and delivered to this specific delivery location, expressed in metric tons. Belongs to the delivery relationship — the same yield record may have different quantities allocated to different locations.' ;
    rdfs:domain ind:GrainDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolOriginVerified rdf:type rdf:Property ;
    rdfs:label 'Cool Origin Verified' ;
    rdfs:comment 'Indicates whether Country of Origin Labeling (COOL) compliance has been verified for this specific grain delivery. Required for food manufacturing and retail customers under USDA COOL regulations. Belongs to the delivery event as it is verified per shipment, not per yield record or per location.' ;
    rdfs:domain ind:GrainDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Load Ticket Number' ;
    rdfs:comment 'Bill of Lading or scale ticket reference number issued at the time of this specific delivery. Uniquely identifies the physical load movement from the farm/storage to the receiving location. Belongs to the delivery event.' ;
    rdfs:domain ind:GrainDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Moisture At Delivery' ;
    rdfs:comment 'Grain moisture content percentage as measured by the receiving location at the time of delivery. Used for moisture dockage calculations and settlement. Distinct from moisture_pct_at_harvest on the yield_record, which is measured at the field.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityGradeAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Quality Grade At Delivery' ;
    rdfs:comment 'Official grain quality grade assigned by the receiving elevator or inspection point at the time of delivery. May differ from the quality grade recorded at harvest on the yield_record due to storage, blending, or re-grading. Belongs to the delivery relationship.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropLabelRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Crop Label Registration Id' ;
    rdfs:comment 'Primary key for the crop_label_registration association' ;
    rdfs:domain ind:CropLabelRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedCropTargets rdf:type rdf:Property ;
    rdfs:label 'Approved Crop Targets' ;
    rdfs:comment 'Comma-separated list of crop types or commodity groups for which the agrochemical product is EPA-label approved for application (e.g., \'corn, soybeans, wheat, cotton\'). Drives crop-specific application compliance and MRL tracking. Sourced from the EPA-registered label. [Moved from agrochemical_product: This STRING field is a denormalized, comma-separated list of commodity crops for which the agrochemical is registered. It encodes the M:N relationship in a non-relational way. The proper model is to decompose this into individual crop_label_registration records, one per agrochemical-commodity pairing, each carrying the crop-specific application parameters. This field should be removed from agrochemical_product once the association table is populated.]' ;
    rdfs:domain ind:CropLabelRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Label Effective Date' ;
    rdfs:comment 'The date on which this specific crop use registration became effective on the EPA-registered label for this agrochemical-commodity pairing.' ;
    rdfs:domain ind:CropLabelRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Label Expiry Date' ;
    rdfs:comment 'The date on which this specific crop use registration expires or is subject to review for this agrochemical-commodity pairing.' ;
    rdfs:domain ind:CropLabelRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialTreatmentId rdf:type rdf:Property ;
    rdfs:label 'Trial Treatment Id' ;
    rdfs:comment 'Primary key for the trial_treatment association' ;
    rdfs:domain ind:TrialTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfApplications rdf:type rdf:Property ;
    rdfs:label 'Number Of Applications' ;
    rdfs:comment 'The number of times this agrochemical product was applied within this trial treatment arm. Relevant for multi-application protocols and for verifying compliance with max_seasonal_applications on the product master.' ;
    rdfs:domain ind:TrialTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotAllocationId rdf:type rdf:Property ;
    rdfs:label 'Lot Allocation Id' ;
    rdfs:comment 'Primary key for the lot_allocation association' ;
    rdfs:domain ind:LotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedQuantityBu rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity Bu' ;
    rdfs:comment 'The quantity of the commodity lot committed to this customer account under this allocation, expressed in bushels. This value belongs to the allocation relationship — not to the lot (which tracks total on-hand) nor to the account (which does not own inventory).' ;
    rdfs:domain ind:LotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerBu rdf:type rdf:Property ;
    rdfs:label 'Price Per Bu' ;
    rdfs:comment 'The negotiated or contracted price per bushel for this specific lot-account allocation. Price varies by deal, contract terms, and market conditions — it belongs to the allocation, not to the lot (which has no single price) nor to the account (which has no per-lot price).' ;
    rdfs:domain ind:LotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Lot Fulfillment Id' ;
    rdfs:comment 'Primary key for the lot_fulfillment association' ;
    rdfs:domain ind:LotFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSplitPct rdf:type rdf:Property ;
    rdfs:label 'Lot Split Pct' ;
    rdfs:comment 'The percentage of the total commodity lot quantity allocated to this specific delivery order. Supports FIFO/FEFO rotation tracking and lot consumption reporting when a single lot is split across multiple delivery orders.' ;
    rdfs:domain ind:LotFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAllocatedBu rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated Bu' ;
    rdfs:comment 'The quantity of this commodity lot allocated to this specific delivery order, expressed in bushels. Represents the planned commitment of lot inventory to the delivery at the time of allocation. Cannot reside on commodity_lot (which tracks total on-hand) or delivery_order (which tracks total ordered quantity) alone.' ;
    rdfs:domain ind:LotFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDeliveredBu rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Bu' ;
    rdfs:comment 'The actual quantity of this commodity lot that was physically delivered against this delivery order, expressed in bushels. May differ from quantity_allocated_bu due to scale tickets, shrinkage, or load adjustments. Used for quality settlement and inventory depletion.' ;
    rdfs:domain ind:LotFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotPesticideExposureId rdf:type rdf:Property ;
    rdfs:label 'Lot Pesticide Exposure Id' ;
    rdfs:comment 'Primary key for the lot_pesticide_exposure association' ;
    rdfs:domain ind:LotPesticideExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Exposure Determination Method' ;
    rdfs:comment 'The method by which this lot was determined to be exposed to this pesticide application — e.g., via GIS field boundary overlap, manual agronomist assignment, or system-derived parcel matching. Required for audit trail and regulatory defensibility.' ;
    rdfs:domain ind:LotPesticideExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Phi Clearance Date' ;
    rdfs:comment 'The earliest date on which this commodity lot may be harvested while remaining compliant with the PHI for this specific pesticide application. Calculated as application_date + phi_days from the associated PUR. This derived date belongs to the association because it is specific to the lot-application pairing.' ;
    rdfs:domain ind:LotPesticideExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiDate rdf:type rdf:Property ;
    rdfs:label 'Phi Date' ;
    rdfs:comment 'The Pre-Harvest Interval (PHI) date — the earliest date on which the commodity could have been legally harvested after the last pesticide or chemical application, per EPA label requirements. Lots harvested before this date may have MRL (Maximum Residue Limit) violations. Critical for food safety compliance and FSMA traceability. [Moved from commodity_lot: The phi_date on commodity_lot is a single scalar that cannot represent the PHI clearance dates from MULTIPLE pesticide applications. The true PHI clearance date is the MAXIMUM phi_clearance_date across all associated PURs for that lot. The lot-level phi_date should be a derived/computed field (max of association phi_clearance_dates), not a stored attribute on the lot itself. The per-application PHI clearance date belongs to the lot_pesticide_exposure association.]' ;
    rdfs:domain ind:LotPesticideExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCommodityAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Location Commodity Authorization Id' ;
    rdfs:comment 'Primary key for the location_commodity_authorization association' ;
    rdfs:domain ind:LocationCommodityAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Accepted Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity categories this location is authorized and equipped to receive (e.g., \'GRAIN,OILSEED,FRESH_PRODUCE,LIVESTOCK,DAIRY,MEAT\'). Used to validate shipment routing and prevent commodity mismatch at receiving. [Moved from delivery_location: This STRING multi-value column on delivery_location is a denormalized anti-pattern encoding what is properly a set of location_commodity_authorization records. It cannot enforce referential integrity to commodity_id, cannot carry per-pair attributes (handling_capability_code, temperature_class, max_volume_mt), and cannot be efficiently queried. It must be removed and replaced by the association table.]' ;
    rdfs:domain ind:LocationCommodityAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Accepted Flag' ;
    rdfs:comment 'Indicates whether this delivery location is currently authorized and operationally active for receiving the linked commodity. FALSE may indicate a suspended or pending authorization.' ;
    rdfs:domain ind:LocationCommodityAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingCapabilityCode rdf:type rdf:Property ;
    rdfs:label 'Handling Capability Code' ;
    rdfs:comment 'Operational handling method code indicating how this location receives and processes the linked commodity (e.g., BULK_DRY, LIQUID_BULK, REFRIGERATED, LIVE_ANIMAL). Belongs to the location-commodity pair because a location may handle different commodities via different methods.' ;
    rdfs:domain ind:LocationCommodityAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVolumeMt rdf:type rdf:Property ;
    rdfs:label 'Max Volume Mt' ;
    rdfs:comment 'Maximum volume in metric tons of this commodity that this location is authorized and physically capable of receiving per delivery or per period. Drives order splitting and routing logic. Cannot reside on delivery_location (varies by commodity) nor on commodity (varies by location).' ;
    rdfs:domain ind:LocationCommodityAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCommodityCapabilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Commodity Capability Id' ;
    rdfs:comment 'Primary key for the facility_commodity_capability association' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedCapacityMt rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Mt' ;
    rdfs:comment 'The portion of the facility\'s total storage capacity (in Metric Tons) allocated to this specific commodity. Derived from the detection-phase attribute storage_capacity_mt scoped to the facility-commodity pairing — cannot reside on facility alone (varies per commodity) nor on commodity alone (varies per facility).' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Capability Status' ;
    rdfs:comment 'Current operational status of this facility\'s capability to handle the specified commodity. SUSPENDED may indicate a failed inspection or lapsed certification. Drives logistics routing eligibility checks.' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCertCode rdf:type rdf:Property ;
    rdfs:label 'Handling Cert Code' ;
    rdfs:comment 'The handling certification code applicable to this facility for this specific commodity (e.g., USDA-AMS grain handler license for corn, FDA FSMA produce safety certification for fresh commodities). Certification requirements differ by commodity type and facility. Explicitly identified in detection-phase relationship data as commodity_specific_handling_cert.' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMoistureContentPct rdf:type rdf:Property ;
    rdfs:label 'Max Moisture Content Pct' ;
    rdfs:comment 'The maximum allowable moisture content percentage enforced at this facility for this commodity at point of acceptance or storage. May differ from the commodity-level standard due to facility-specific equipment capabilities or regional grain trade practices. Explicitly identified in detection-phase relationship data.' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicSegregationCapable rdf:type rdf:Property ;
    rdfs:label 'Organic Segregation Capable' ;
    rdfs:comment 'Indicates whether this facility is capable of physically segregating this commodity to maintain organic certification integrity under USDA NOP requirements. Capability varies by commodity (e.g., a facility may segregate organic soybeans but not organic corn due to bin configuration). Explicitly identified in detection-phase relationship data.' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCommodity rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity' ;
    rdfs:comment 'The principal agricultural commodity type handled or stored at this facility (e.g., corn, soybeans, wheat, cotton, perishable produce, livestock). Drives commodity-specific compliance requirements, temperature zone configuration, and fumigation protocols. [Moved from facility: This STRING field on facility is a denormalized label for the dominant commodity type. With the facility_commodity_capability association in place, the full commodity relationship is formally modeled with proper FK integrity. The \'primary_commodity\' label can be deprecated in favor of querying the association table, or retained as a human-readable convenience label only — but it should not serve as the authoritative commodity reference.]' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZoneAssigned rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Assigned' ;
    rdfs:comment 'The temperature zone configuration assigned at this facility for storing this commodity. A facility may have multiple temperature zones and different commodities are routed to different zones. Sourced from detection-phase attribute temperature_zone scoped to the facility-commodity pairing.' ;
    rdfs:domain ind:FacilityCommodityCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:farmVendorApprovalId rdf:type rdf:Property ;
    rdfs:label 'Farm Vendor Approval Id' ;
    rdfs:comment 'Primary key for the farm_vendor_approval association' ;
    rdfs:domain ind:FarmVendorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:farmSpecificPricing rdf:type rdf:Property ;
    rdfs:label 'Farm Specific Pricing' ;
    rdfs:comment 'Reference identifier or description of the farm-unit-level pricing agreement negotiated with this vendor, distinct from the vendor\'s standard pricing. May reference a contract number, price schedule code, or volume discount tier applicable only to this farm unit.' ;
    rdfs:domain ind:FarmVendorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Status' ;
    rdfs:comment 'Indicates whether this vendor holds preferred supplier status for the associated farm unit within the approved input categories. Preferred vendors are prioritized in purchase order generation and sourcing decisions for this farm unit.' ;
    rdfs:domain ind:FarmVendorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landFieldOperationId rdf:type rdf:Property ;
    rdfs:label 'Land Field Operation Id' ;
    rdfs:comment 'Primary key for the field_operation association' ;
    rdfs:domain ind:LandFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acresOperated rdf:type rdf:Property ;
    rdfs:label 'Acres Operated' ;
    rdfs:comment 'The number of acres (or hectares, per enterprise convention) of this field that fall under this account\'s operational responsibility. May be less than the field\'s total_area_ha in partial-field arrangements (e.g., split leases, strip farming). Belongs to the relationship — neither the field nor the account alone can hold this value.' ;
    rdfs:domain ind:LandFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorRole rdf:type rdf:Property ;
    rdfs:label 'Operator Role' ;
    rdfs:comment 'The specific operational capacity in which the account is associated with this field. Drives FSA operator declarations, crop insurance eligibility, and billing logic. Belongs to the relationship — the same account may be a tenant on one field and a custom operator on another.' ;
    rdfs:domain ind:LandFieldOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldInputRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Field Input Restriction Id' ;
    rdfs:comment 'Primary key for the field_input_restriction association' ;
    rdfs:domain ind:FieldInputRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The regulatory or policy authority underpinning this restriction. Drives compliance reporting and audit trail. Aligned with USDA NOP, EPA FIFRA, and FSA program requirements.' ;
    rdfs:domain ind:FieldInputRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Human-readable explanation of why this input product is restricted on this field. Examples: \'Organic certification prohibits synthetic inputs\', \'Groundwater advisory — sandy soil over aquifer recharge zone\', \'FSA conservation contract CRP enrollment\', \'GMO-restricted field boundary\'.' ;
    rdfs:domain ind:FieldInputRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of how the input product is restricted on this field. \'prohibited\' means no application permitted; \'rate_limited\' means application is allowed below a maximum rate; \'buffer_zone_only\' means application is excluded within a defined distance of a waterway or boundary; \'timing_restricted\' means application is only permitted outside certain windows (e.g., pre-planting only); \'conditional\' means restriction applies only under specific conditions.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldCertificationScopeId rdf:type rdf:Property ;
    rdfs:label 'Field Certification Scope Id' ;
    rdfs:comment 'Primary key for the field_certification_scope association' ;
    rdfs:domain ind:FieldCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDrugAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Protocol Drug Authorization Id' ;
    rdfs:comment 'Primary key for the protocol_drug_authorization association' ;
    rdfs:domain ind:ProtocolDrugAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-text notes from the authorizing veterinarian regarding special handling, contraindications, or clinical guidance specific to this drug within this protocol step.' ;
    rdfs:domain ind:ProtocolDrugAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequence rdf:type rdf:Property ;
    rdfs:label 'Step Sequence' ;
    rdfs:comment 'Ordinal position of this drug within the protocol treatment ladder (e.g., 1 = first-line, 2 = second-line if no response at Day 3, 3 = third-line). Drives the clinical decision sequence for pen riders and veterinary technicians.' ;
    rdfs:domain ind:ProtocolDrugAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepTriggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Step Trigger Criteria' ;
    rdfs:comment 'Clinical criteria that must be met before advancing to this treatment step (e.g., \'No response at 72 hours post Step 1\', \'Temperature >= 40.0C on Day 3\'). Captures the decision logic for multi-step treatment ladders.' ;
    rdfs:domain ind:ProtocolDrugAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlanBomId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Bom Id' ;
    rdfs:comment 'Primary key for the maintenance_plan_bom association' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionUom rdf:type rdf:Property ;
    rdfs:label 'Consumption Uom' ;
    rdfs:comment 'The unit of measure in which the part is consumed for this specific maintenance plan cycle. May differ from the stocking UOM in parts_inventory (e.g., stocked in liters but consumed in quarts for a specific OEM procedure).' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated cost of the required quantity of this part for one cycle of the maintenance plan, expressed in the plan\'s currency. Calculated as required_quantity × unit_cost at plan authoring time. Contributes to the maintenance_plan.estimated_parts_cost rollup but is tracked at line-item level here.' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPartsCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Parts Cost' ;
    rdfs:comment 'Estimated total cost of parts and materials required to complete one cycle of this maintenance plan, in the base currency. Used for OPEX budgeting and procurement planning in SAP MM. [Moved from maintenance_plan: This is a rolled-up aggregate of all part line costs in the BOM. The authoritative line-item costs now live in the association (estimated_cost per plan-part combination). The rollup can be derived by summing association records, making the denormalized field on maintenance_plan redundant. If retained on maintenance_plan, it should be treated as a computed/cached field, not a source of truth.]' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this part is mandatory for plan execution (true) or optional/conditional based on inspection findings (false). A mandatory part must be staged before the work order can be released; an optional part is staged on-demand.' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partRole rdf:type rdf:Property ;
    rdfs:label 'Part Role' ;
    rdfs:comment 'The functional role of this part within the maintenance plan. Describes how the part is used in the context of this specific plan (e.g., primary_consumable, replacement_component, lubricant, filter, sealant, fastener). Belongs to the association, not to the part master.' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'The quantity of this part required to complete one full cycle of the maintenance plan. Belongs to the plan-part combination, not to the plan or part alone — the same part may be required in different quantities across different plans.' ;
    rdfs:domain ind:MaintenancePlanBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeStopId rdf:type rdf:Property ;
    rdfs:label 'Route Stop Id' ;
    rdfs:comment 'Primary key for the route_stop association' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityTypesServed rdf:type rdf:Property ;
    rdfs:label 'Commodity Types Served' ;
    rdfs:comment 'Comma-separated list of commodity categories delivered to this specific delivery location on this specific route. A route may carry multiple commodity classes but only deliver a subset to each stop. Cannot reside on route (varies per stop) or delivery_location (varies per route).' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Window End' ;
    rdfs:comment 'Planned latest arrival time at this delivery location stop on this route, expressed in HH:MM (24-hour) format. Defines the delivery window communicated to the receiving facility. Belongs to the route-stop relationship.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalWindowStart rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Window Start' ;
    rdfs:comment 'Planned earliest arrival time at this delivery location stop on this route, expressed in HH:MM (24-hour) format. Derived from route transit time and stop sequence. Belongs to the route-stop relationship, not to either entity alone.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Service frequency indicating how often this route calls at this delivery location (e.g., DAILY, WEEKLY, BIWEEKLY, ON_DEMAND). Drives TMS scheduling and carrier capacity planning for this stop.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequence rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence' ;
    rdfs:comment 'Ordinal position of this delivery location within the route\'s stop sequence. Determines the order in which the carrier visits each stop along the route. Cannot reside on route (varies per stop) or delivery_location (varies per route).' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current operational status of this route stop assignment. ACTIVE indicates the stop is in use for TMS planning; SUSPENDED indicates a temporary hold (e.g., facility closure, seasonal restriction); INACTIVE indicates the stop has been permanently removed from the route.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCommodityCoverageId rdf:type rdf:Property ;
    rdfs:label 'Contract Commodity Coverage Id' ;
    rdfs:comment 'Primary key for the contract_commodity_coverage association' ;
    rdfs:domain ind:ContractCommodityCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityTypesCovered rdf:type rdf:Property ;
    rdfs:label 'Commodity Types Covered' ;
    rdfs:comment 'Pipe-delimited list of agricultural commodity categories covered under this contract (e.g., grain|produce|livestock_feed|refrigerated_dairy). Drives FSMA traceability obligations, temperature zone requirements, and MRL compliance checks during shipment execution. [Moved from service_contract: This pipe-delimited STRING field on service_contract is a denormalized anti-pattern that attempts to store multiple commodity references in a single column. It must be decomposed into individual contract_commodity_coverage records, each with its own commodity_id FK and commodity-specific rate/volume/SLA attributes. Retaining this field would create data integrity issues and prevent commodity-level querying.]' ;
    rdfs:domain ind:ContractCommodityCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current operational status of this commodity\'s coverage under the service contract. A commodity may be temporarily suspended from a contract (e.g., seasonal exclusion, regulatory hold) without terminating the overall contract.' ;
    rdfs:domain ind:ContractCommodityCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialStaffAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Trial Staff Assignment Id' ;
    rdfs:comment 'Primary key for the trial_staff_assignment association' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date on which the employee\'s active involvement in this trial concluded. Null if the assignment is ongoing. Used for labor cost period allocation and regulatory personnel records.' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which the employee\'s active involvement in this trial commenced. Used for labor cost period allocation and regulatory personnel records.' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Classification of the employee\'s intellectual or operational contribution to the trial. Drives publication authorship credit and regulatory submission personnel attribution (e.g., USDA APHIS, EPA). Belongs to the assignment relationship, not to the employee or trial alone.' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Hours Allocated' ;
    rdfs:comment 'Total labor hours allocated to this employee for this trial assignment. Used for SAP cost center labor allocation and research program budget tracking. Belongs to the assignment, not to the employee or trial alone.' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffRole rdf:type rdf:Property ;
    rdfs:label 'Staff Role' ;
    rdfs:comment 'The functional role the employee performs on this trial. Determines publication authorship order, regulatory submission attribution, and labor cost category. A single employee may hold different roles on different trials.' ;
    rdfs:domain ind:TrialStaffAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionZoneRateId rdf:type rdf:Property ;
    rdfs:label 'Prescription Zone Rate Id' ;
    rdfs:comment 'Primary key for the prescription_zone_rate association' ;
    rdfs:domain ind:PrescriptionZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribedRate rdf:type rdf:Property ;
    rdfs:label 'Prescribed Rate' ;
    rdfs:comment 'The specific application rate prescribed for this input product in this management zone. Varies by zone and input combination; cannot reside on vra_prescription (varies per input) or input_product (varies per prescription and zone).' ;
    rdfs:domain ind:PrescriptionZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Zone Area Acres' ;
    rdfs:comment 'The area in acres of the management zone covered by this input-prescription combination. Used to calculate total input quantity required for this zone and for cost/compliance reporting.' ;
    rdfs:domain ind:PrescriptionZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditParticipationId rdf:type rdf:Property ;
    rdfs:label 'Audit Participation Id' ;
    rdfs:comment 'Primary key for the audit_participation association' ;
    rdfs:domain ind:AuditParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeForAccount rdf:type rdf:Property ;
    rdfs:label 'Outcome For Account' ;
    rdfs:comment 'The audit outcome as it applies specifically to this customer account\'s participation. May differ from the overall audit outcome when the audit covers multiple accounts with varying results. Derived from outcome_applicable_to_account identified in detection phase.' ;
    rdfs:domain ind:AuditParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationDate rdf:type rdf:Property ;
    rdfs:label 'Participation Date' ;
    rdfs:comment 'The specific date on which this customer account\'s participation in the audit occurred or was formally recorded. Derived from audit_date identified in detection phase. Belongs to the participation record as it may differ per account when a multi-account audit spans multiple site visits.' ;
    rdfs:domain ind:AuditParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'The role of the customer account in this compliance audit. Determines the account\'s obligations, rights, and exposure to audit findings. Belongs to the participation record, not to the account or audit alone.' ;
    rdfs:domain ind:AuditParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeForAccount rdf:type rdf:Property ;
    rdfs:label 'Scope For Account' ;
    rdfs:comment 'Narrative description of the portion of the overall audit scope that is applicable to this specific customer account. Derived from audit_scope_for_account identified in detection phase. Cannot reside on compliance_audit (which has a single overall scope) or on account.' ;
    rdfs:domain ind:AuditParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agrochemicalPracticeCompatibilityId rdf:type rdf:Property ;
    rdfs:label 'Agrochemical Practice Compatibility Id' ;
    rdfs:comment 'Primary key for the agrochemical_practice_compatibility association' ;
    rdfs:domain ind:AgrochemicalPracticeCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCropType rdf:type rdf:Property ;
    rdfs:label 'Applicable Crop Type' ;
    rdfs:comment 'The specific crop type or commodity group for which this compatibility rule applies. A single agrochemical-practice pairing may have different rules depending on the crop context, making this a relationship-level attribute.' ;
    rdfs:domain ind:AgrochemicalPracticeCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Compatibility Status' ;
    rdfs:comment 'Indicates whether the agrochemical product is compatible, conditionally compatible, restricted, or prohibited for use in the context of the linked regenerative practice. This status cannot reside on either parent entity alone as it is specific to the pairing.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSource rdf:type rdf:Property ;
    rdfs:label 'Rule Source' ;
    rdfs:comment 'The authoritative source document or program that mandates or defines this compatibility rule (e.g., EPA label section, carbon program protocol version, GLOBALG.A.P. IFA checklist point). Supports audit and compliance traceability.' ;
    rdfs:domain ind:AgrochemicalPracticeCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalHoldId rdf:type rdf:Property ;
    rdfs:label 'Animal Hold Id' ;
    rdfs:comment 'Primary key for the animal_hold association' ;
    rdfs:domain ind:AnimalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:animalHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Animal Hold Status' ;
    rdfs:comment 'Current lifecycle status of this specific animal\'s hold placement. Allows querying which animals are currently under active hold versus those already released or disposed, independent of the parent hold_record status.' ;
    rdfs:domain ind:AnimalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'The date and time this specific animal was formally released from this hold. Enables per-animal hold duration tracking and supports FSMA recall readiness queries at the individual animal level.' ;
    rdfs:domain ind:AnimalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetContractAllocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Contract Allocation Id' ;
    rdfs:comment 'Primary key for the asset_contract_allocation association' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedAcreage rdf:type rdf:Property ;
    rdfs:label 'Allocated Acreage' ;
    rdfs:comment 'Total acreage harvested, planted, or applied by this asset in service of this specific sales contract. Used for per-contract cost allocation and field-level traceability required by GlobalGAP audits.' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedHours rdf:type rdf:Property ;
    rdfs:label 'Allocated Hours' ;
    rdfs:comment 'Total engine or operating hours attributed to this asset for fulfillment of this specific sales contract. Used for cost allocation (OPEX per contract) and asset utilization reporting. Cannot reside on the asset (which accumulates hours across all contracts) or the contract (which uses many assets).' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date on which this asset\'s allocation to this sales contract was completed or terminated. Used to calculate total allocation duration and close out cost allocation entries.' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date on which this asset was formally allocated to begin servicing this sales contract. Establishes the temporal boundary of the allocation for cost and compliance reporting.' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilizationCost rdf:type rdf:Property ;
    rdfs:label 'Utilization Cost' ;
    rdfs:comment 'Monetary cost (in contract currency or functional currency) allocated to this sales contract for the use of this asset. Derived from internal cost rates applied to allocated hours and acreage. Used for CAPEX/OPEX cost allocation per contract in SAP CO module.' ;
    rdfs:domain ind:AssetContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputCompatibilityId rdf:type rdf:Property ;
    rdfs:label 'Input Compatibility Id' ;
    rdfs:comment 'Primary key for the equipment_input_compatibility association' ;
    rdfs:domain ind:InputCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationRateCapability rdf:type rdf:Property ;
    rdfs:label 'Application Rate Capability' ;
    rdfs:comment 'The achievable application rate range (expressed as a min-max string with unit, e.g., \'1.5-3.0 L/ha\') for this asset when applying the linked input product. May differ from the label-specified range on input_product due to equipment-specific flow rate and nozzle constraints. Sourced directly from detection phase relationship data.' ;
    rdfs:domain ind:InputCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether a formal equipment certification or operator licence is required before this asset may be used to apply the linked input product (e.g., for Restricted Use Pesticides or specialised application equipment). Sourced directly from detection phase relationship data.' ;
    rdfs:domain ind:InputCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibleFormulationTypes rdf:type rdf:Property ;
    rdfs:label 'Compatible Formulation Types' ;
    rdfs:comment 'The specific formulation type codes (per industry-standard classification) that this asset is rated to handle for the linked input product, based on tank material compatibility, nozzle suitability, and equipment design. Sourced directly from detection phase relationship data.' ;
    rdfs:domain ind:InputCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCertificationScopeId rdf:type rdf:Property ;
    rdfs:label 'Asset Certification Scope Id' ;
    rdfs:comment 'Primary key for the asset_certification_scope association' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard Version' ;
    rdfs:comment 'The specific version or revision of the certification standard under which this asset was assessed and included in scope. May differ from the certification\'s current scheme_standard_version if the asset was onboarded under a prior audit cycle and has not yet been re-assessed under the latest version. Sourced directly from detection-phase relationship data.' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date on which the asset\'s compliance with the applicable certification standard was last formally verified for this specific certification. Belongs to the asset-certification pairing, not to either entity alone — the same asset may have different verification dates under different certifications. Sourced directly from detection-phase relationship data.' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeExclusionDate rdf:type rdf:Property ;
    rdfs:label 'Scope Exclusion Date' ;
    rdfs:comment 'Date on which the asset was formally removed from the certification\'s equipment register, if applicable. Null if the asset remains in scope. Enables historical tracking of which assets were in scope during any given certification period.' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeInclusionDate rdf:type rdf:Property ;
    rdfs:label 'Scope Inclusion Date' ;
    rdfs:comment 'Date on which the asset was formally added to the certification\'s equipment register and became part of the certified scope. Represents the start of this asset-certification relationship. Sourced from detection-phase attribute certification_scope_for_asset context.' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Per-asset status within the certification scope. Indicates whether the asset is currently active within the certification\'s equipment register, temporarily suspended (e.g., under repair during audit window), excluded from scope, or pending initial verification. Sourced from detection-phase attribute asset_certification_status.' ;
    rdfs:domain ind:AssetCertificationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCertificationVerificationId rdf:type rdf:Property ;
    rdfs:label 'Contract Certification Verification Id' ;
    rdfs:comment 'Primary key for the contract_certification_verification association' ;
    rdfs:domain ind:ContractCertificationVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Reference to the internal compliance officer or trade documentation specialist who performed the certification verification. Provides audit trail accountability for the verification event.' ;
    rdfs:domain ind:ContractCertificationVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Cert Type Required' ;
    rdfs:comment 'The specific certification type that the contract mandates (e.g., GLOBALG.A.P., FSMA, USDA Organic NOP, ISCC). Captures which of the contract\'s certification obligations this verification record addresses, since a single contract may require multiple cert types verified separately.' ;
    rdfs:domain ind:ContractCertificationVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityBrokerAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Commodity Broker Authorization Id' ;
    rdfs:comment 'Primary key for the commodity_broker_authorization association' ;
    rdfs:domain ind:CommodityBrokerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of this broker-commodity authorization. Controls whether the broker is currently permitted to facilitate sales of this commodity. Managed independently of the broker\'s overall relationship_status.' ;
    rdfs:domain ind:CommodityBrokerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySpecializations rdf:type rdf:Property ;
    rdfs:label 'Commodity Specializations' ;
    rdfs:comment 'Comma-separated list of agricultural commodity types the broker is authorized and experienced to transact (e.g., corn, soybeans, wheat, cattle, hogs, fresh produce). Used for opportunity matching and compliance with USDA commodity-specific licensing requirements. [Moved from broker: This is a denormalized multi-value string field encoding the M:N broker-commodity relationship directly on the broker master record. Once the commodity_broker_authorization association is in place, each authorized commodity is represented as a proper row in the association table. The commodity_specializations field should be deprecated and removed from the broker master to eliminate the data integrity risk of a free-text multi-value field diverging from the structured authorization records.]' ;
    rdfs:domain ind:CommodityBrokerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTargetMt rdf:type rdf:Property ;
    rdfs:label 'Volume Target Mt' ;
    rdfs:comment 'Agreed annual commodity volume target in Metric Tons that the broker is expected to facilitate for this specific commodity under this authorization. Distinct from broker.annual_volume_target_mt which is an aggregate across all commodities. Belongs to the authorization because targets are negotiated per commodity.' ;
    rdfs:domain ind:CommodityBrokerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentRequirementId rdf:type rdf:Property ;
    rdfs:label 'Parent Requirement Id' ;
    rdfs:comment 'Reference to a parent or umbrella regulatory requirement if this requirement is a sub-requirement or specific provision. Null if top-level.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:supersededByRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Id' ;
    rdfs:comment 'Reference to the regulatory requirement that supersedes this one. Null if not superseded.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Description of the business operations, facilities, or activities to which the requirement applies (e.g., all crop production, livestock operations over 1000 head, pesticide applicators).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether the requirement mandates periodic audits or inspections by the governing body (true) or not (false).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'Full legal citation or reference to the statute, regulation, or code section (e.g., 7 USC 136, 40 CFR Part 112).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline Days' ;
    rdfs:comment 'Number of days from a triggering event by which compliance must be achieved. Null if not applicable.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'Frequency at which compliance activities must be performed (e.g., one-time, daily, weekly, monthly, quarterly, annually, biennial, as needed).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Specific agriculture industry sector or sub-sector to which the requirement applies (e.g., crop cultivation, animal husbandry, food processing, distribution).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Days' ;
    rdfs:comment 'Number of days in advance that compliance teams should be notified before a compliance deadline. Used for calendar management.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyAmountMax rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Max' ;
    rdfs:comment 'Maximum monetary penalty amount for non-compliance, in USD. Null if not applicable or not monetary.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmountMin rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Min' ;
    rdfs:comment 'Minimum monetary penalty amount for non-compliance, in USD. Null if not applicable or not monetary.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulationUrl rdf:type rdf:Property ;
    rdfs:label 'Regulation Url' ;
    rdfs:comment 'Web URL linking to the official text or guidance document for the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCategory rdf:type rdf:Property ;
    rdfs:label 'Requirement Category' ;
    rdfs:comment 'Broad regulatory category or domain to which the requirement belongs (e.g., environmental, food safety, pesticide, animal welfare, trade, labor).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the regulatory requirement as assigned by the governing body (e.g., CFR 21 Part 110, EPA 40 CFR 112, USDA 9 CFR 416).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed description of the regulatory requirement, including scope, obligations, and compliance expectations.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementTitle rdf:type rdf:Property ;
    rdfs:label 'Requirement Title' ;
    rdfs:comment 'Human-readable title or name of the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Classification of the regulatory requirement by type (e.g., permit, license, certification, reporting, inspection, record keeping).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory requirement (active, superseded, pending, withdrawn, archived).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User or system identifier of the person or process that last updated the regulatory requirement record.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User or system identifier of the person or process that created the regulatory requirement record.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Active Violations Count' ;
    rdfs:comment 'Number of currently active compliance violations or non-conformances that have not been resolved or closed.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueRange rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Range' ;
    rdfs:comment 'Estimated annual revenue range bracket for the obligated entity, used for risk-based compliance resource allocation.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Secondary address line (suite, building, floor) for the obligated entity\'s principal place of business.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the obligated entity\'s principal place of business.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Bond Number' ;
    rdfs:comment 'U.S. Customs and Border Protection bond number for entities engaged in import activities. Null if not applicable.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Estimated number of employees working for the obligated entity, used for compliance complexity assessment.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'The full legal name of the obligated entity as registered with regulatory authorities.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'EPA or state environmental permit number for operations with environmental impact (water discharge, air emissions, waste management). Null if not applicable.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Flag' ;
    rdfs:comment 'Indicates whether the obligated entity is certified for Good Manufacturing Practices under FDA or equivalent standards.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Certification Flag' ;
    rdfs:comment 'Indicates whether the obligated entity has implemented and is certified for HACCP food safety management systems.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importExportFlag rdf:type rdf:Property ;
    rdfs:label 'Import Export Flag' ;
    rdfs:comment 'Indicates whether the obligated entity engages in cross-border import or export activities requiring additional trade compliance.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the primary industry classification of the obligated entity.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiration Date' ;
    rdfs:comment 'The date when the current regulatory registration expires and renewal is required. Null for perpetual registrations.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Total Violations Count' ;
    rdfs:comment 'Cumulative count of all compliance violations recorded for this obligated entity since registration, including resolved violations.' ;
    rdfs:domain ind:ObligatedEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Product Description' ;
    rdfs:comment 'Description of the product(s) subject to the recall including brand, variety, and packaging details.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Description of corrective and preventive actions implemented to prevent recurrence.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCountries rdf:type rdf:Property ;
    rdfs:label 'Distribution Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where affected product was distributed.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Level' ;
    rdfs:comment 'FDA-defined level of recall effectiveness checking required based on recall class and scope.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedQuantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity Distributed' ;
    rdfs:comment 'Estimated total quantity of affected product distributed to market.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedQuantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity Recovered' ;
    rdfs:comment 'Estimated quantity of affected product recovered through recall actions.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated financial impact.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Category of the identified hazard according to food safety classification.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchCodes rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Codes' ;
    rdfs:comment 'Comma-separated list of lot numbers, batch codes, or serial numbers identifying affected product units.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Methods used to notify customers and stakeholders of the recall (e.g., press release, direct contact, social media, website posting).' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Public Notification Required' ;
    rdfs:comment 'Indicates whether public notification through press release or media is required for this recall.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Email' ;
    rdfs:comment 'Email address of the recall coordinator for regulatory and stakeholder communications.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Name' ;
    rdfs:comment 'Name of the individual designated as the recall coordinator managing the recall execution.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Phone' ;
    rdfs:comment 'Phone number of the recall coordinator for urgent communications.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Official case or reference number assigned by the regulatory agency for tracking the recall.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause investigation findings that led to the recall event.' ;
    rdfs:domain ind:RecallPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Effective Date' ;
    rdfs:comment 'Date when the laboratory accreditation became effective.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiration Date' ;
    rdfs:comment 'Date when the current laboratory accreditation expires and requires renewal.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Unique accreditation certificate number issued by the accreditation body.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the laboratory under ISO/IEC 17025 or equivalent standards.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the laboratory facility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, building, or floor number.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Biosafety Level' ;
    rdfs:comment 'Biosafety level classification for laboratories handling biological agents.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Certificate Number' ;
    rdfs:comment 'CLIA certificate number if laboratory performs clinical testing on agricultural workers or food safety personnel.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Compliance' ;
    rdfs:comment 'Indicates whether the laboratory meets data integrity requirements under ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCalibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Equipment Calibration Frequency Days' ;
    rdfs:comment 'Standard frequency in days for calibration of laboratory testing equipment.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the laboratory was established and began operations.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Externally-known unique code for the laboratory used in regulatory filings and certifications.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryType rdf:type rdf:Property ;
    rdfs:label 'Laboratory Type' ;
    rdfs:comment 'Classification of laboratory based on operational model and ownership structure.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSystemName rdf:type rdf:Property ;
    rdfs:label 'Lims System Name' ;
    rdfs:comment 'Name of the Laboratory Information Management System used for sample tracking and data management.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the next external audit or surveillance assessment.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyTestingParticipation rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Participation' ;
    rdfs:comment 'Indicates whether the laboratory participates in proficiency testing programs to validate testing competency.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Quality Management System' ;
    rdfs:comment 'Quality management system framework the laboratory operates under.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'Primary area of laboratory specialization (e.g., microbiology, chemistry, pesticide residue, mycotoxin, allergen, GMO, nutritional analysis).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingCapacitySamplesPerDay rdf:type rdf:Property ;
    rdfs:label 'Testing Capacity Samples Per Day' ;
    rdfs:comment 'Maximum number of samples the laboratory can process per day under normal operating conditions.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingScope rdf:type rdf:Property ;
    rdfs:label 'Testing Scope' ;
    rdfs:comment 'Comprehensive description of testing capabilities and scope of accreditation including test methods and matrices.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeStandardHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Standard Hours' ;
    rdfs:comment 'Standard turnaround time in hours for routine test results from sample receipt to report delivery.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Average Flow Rate Gpm' ;
    rdfs:comment 'Typical or average flow rate through the outfall under normal operating conditions, measured in gallons per minute.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestManagementPractices rdf:type rdf:Property ;
    rdfs:label 'Best Management Practices' ;
    rdfs:comment 'Description of agricultural best management practices implemented to minimize pollutant discharge through this outfall.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate Gpm' ;
    rdfs:comment 'Maximum designed flow rate capacity of the outfall, measured in gallons per minute.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeType rdf:type rdf:Property ;
    rdfs:label 'Discharge Type' ;
    rdfs:comment 'Pattern of discharge activity: continuous flow, intermittent, seasonal, or batch discharge.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Elevation of the outfall discharge point above sea level, measured in meters.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringParameters rdf:type rdf:Property ;
    rdfs:label 'Monitoring Parameters' ;
    rdfs:comment 'List of water quality parameters that must be monitored at this outfall (e.g., pH, BOD, TSS, nitrogen, phosphorus, pesticides).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallName rdf:type rdf:Property ;
    rdfs:label 'Outfall Name' ;
    rdfs:comment 'Human-readable descriptive name or label for the outfall discharge point.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallNumber rdf:type rdf:Property ;
    rdfs:label 'Outfall Number' ;
    rdfs:comment 'Externally-known unique identifier or serial number assigned to the outfall by regulatory authority or facility management.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallStatus rdf:type rdf:Property ;
    rdfs:label 'Outfall Status' ;
    rdfs:comment 'Current operational status of the outfall discharge point in its lifecycle.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallType rdf:type rdf:Property ;
    rdfs:label 'Outfall Type' ;
    rdfs:comment 'Classification of the outfall based on the nature of discharge (point source, non-point source, stormwater, process wastewater, cooling water, or combined).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Pipe Diameter Inches' ;
    rdfs:comment 'Internal diameter of the outfall discharge pipe or conduit, measured in inches.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Pipe Material' ;
    rdfs:comment 'Material composition of the outfall discharge pipe (concrete, PVC, steel, HDPE, cast iron, or other).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterBody rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Body' ;
    rdfs:comment 'Name of the water body (river, stream, lake, ocean, groundwater) that receives the discharge from this outfall.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterClassification rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Classification' ;
    rdfs:comment 'Regulatory classification or designated use of the receiving water body (e.g., Class A, Class B, fishable/swimmable).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaximumDailyLoadApplicable rdf:type rdf:Property ;
    rdfs:label 'Total Maximum Daily Load Applicable' ;
    rdfs:comment 'Indicates whether this outfall is subject to a Total Maximum Daily Load (TMDL) allocation for the receiving water body.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentSystemType rdf:type rdf:Property ;
    rdfs:label 'Treatment System Type' ;
    rdfs:comment 'Type of wastewater treatment system upstream of this outfall (e.g., primary, secondary, tertiary, lagoon, constructed wetland).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watershedCode rdf:type rdf:Property ;
    rdfs:label 'Watershed Code' ;
    rdfs:comment 'Hydrologic unit code (HUC) identifying the watershed in which this outfall is located.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageYield rdf:type rdf:Property ;
    rdfs:label 'Average Yield' ;
    rdfs:comment 'Historical average yield for this crop expressed in the yield_unit, used for crop planning and forecasting.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropCategory rdf:type rdf:Property ;
    rdfs:label 'Crop Category' ;
    rdfs:comment 'High-level classification of the crop type based on agricultural use and market segment.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropCode rdf:type rdf:Property ;
    rdfs:label 'Crop Code' ;
    rdfs:comment 'Standardized alphanumeric code used for crop identification in Farm Management Information Systems (FMIS) and regulatory reporting. Externally-known unique identifier.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cropName rdf:type rdf:Property ;
    rdfs:label 'Crop Name' ;
    rdfs:comment 'Common name of the crop (e.g., Corn, Wheat, Soybeans, Cotton). Human-readable identifier used across all agronomic systems.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseSusceptibility rdf:type rdf:Property ;
    rdfs:label 'Disease Susceptibility' ;
    rdfs:comment 'General susceptibility of the crop to disease infections, used in IPM-based disease management strategies.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:droughtTolerance rdf:type rdf:Property ;
    rdfs:label 'Drought Tolerance' ;
    rdfs:comment 'Crop\'s ability to withstand water stress and drought conditions, critical for irrigation planning.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frostTolerance rdf:type rdf:Property ;
    rdfs:label 'Frost Tolerance' ;
    rdfs:comment 'Crop\'s ability to withstand frost conditions during growing season.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoAvailable rdf:type rdf:Property ;
    rdfs:label 'Gmo Available' ;
    rdfs:comment 'Indicates whether genetically modified varieties of this crop are available and approved for cultivation.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:growingSeason rdf:type rdf:Property ;
    rdfs:label 'Growing Season' ;
    rdfs:comment 'Primary season during which the crop is typically cultivated, used for crop planning and rotation scheduling.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Market Price Per Unit' ;
    rdfs:comment 'Current market price per yield unit (e.g., price per bushel, price per kilogram), used for revenue forecasting and crop selection decisions.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityDaysMax rdf:type rdf:Property ;
    rdfs:label 'Maturity Days Max' ;
    rdfs:comment 'Maximum number of days from planting to harvest maturity for late-maturing varieties of this crop.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maturityDaysMin rdf:type rdf:Property ;
    rdfs:label 'Maturity Days Min' ;
    rdfs:comment 'Minimum number of days from planting to harvest maturity for early-maturing varieties of this crop.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndviThresholdHealthy rdf:type rdf:Property ;
    rdfs:label 'Ndvi Threshold Healthy' ;
    rdfs:comment 'Normalized Difference Vegetation Index (NDVI) threshold value indicating healthy crop vigor, used for remote sensing and field health monitoring.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrogenRequirementKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Requirement Kg Per Hectare' ;
    rdfs:comment 'Recommended nitrogen fertilizer application rate in kilograms per hectare for optimal yield, used in Variable Rate Application (VRA) prescriptions.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pestSusceptibility rdf:type rdf:Property ;
    rdfs:label 'Pest Susceptibility' ;
    rdfs:comment 'General susceptibility of the crop to pest infestations, used in Integrated Pest Management (IPM) planning.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phosphorusRequirementKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Requirement Kg Per Hectare' ;
    rdfs:comment 'Recommended phosphorus fertilizer application rate in kilograms per hectare for optimal yield.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumRequirementKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Potassium Requirement Kg Per Hectare' ;
    rdfs:comment 'Recommended potassium fertilizer application rate in kilograms per hectare for optimal yield.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationCompatible rdf:type rdf:Property ;
    rdfs:label 'Rotation Compatible' ;
    rdfs:comment 'Indicates whether this crop is suitable for inclusion in crop rotation schedules to maintain soil health and reduce pest pressure.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scientificName rdf:type rdf:Property ;
    rdfs:label 'Scientific Name' ;
    rdfs:comment 'Scientific botanical name of the crop using binomial nomenclature (e.g., Zea mays for corn, Triticum aestivum for wheat).' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingRateKgPerHectare rdf:type rdf:Property ;
    rdfs:label 'Seeding Rate Kg Per Hectare' ;
    rdfs:comment 'Recommended seeding rate in kilograms per hectare for standard planting density.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilPhMax rdf:type rdf:Property ;
    rdfs:label 'Soil Ph Max' ;
    rdfs:comment 'Maximum soil pH level tolerated by the crop for healthy growth.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soilPhMin rdf:type rdf:Property ;
    rdfs:label 'Soil Ph Min' ;
    rdfs:comment 'Minimum soil pH level required for optimal crop growth and nutrient availability.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum temperature in Celsius tolerated by the crop before heat stress occurs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum temperature in Celsius required for crop germination and growth.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterRequirementMm rdf:type rdf:Property ;
    rdfs:label 'Water Requirement Mm' ;
    rdfs:comment 'Total seasonal water requirement in millimeters, used for Evapotranspiration (ET)-driven irrigation planning.' ;
    rdfs:domain ind:Crop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropSeasonId rdf:type rdf:Property ;
    rdfs:label 'Crop Season Id' ;
    rdfs:comment 'Reference to the specific crop season or growing period for which this zone map is applicable. Links the map to temporal crop planning cycles.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrowingSeason .

ind:attributeMeasured rdf:type rdf:Property ;
    rdfs:label 'Attribute Measured' ;
    rdfs:comment 'Specific agronomic or environmental attribute measured or represented in the zone map (e.g., soil pH, organic matter percentage, elevation above sea level, NDVI value, soil moisture content).' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationMethod rdf:type rdf:Property ;
    rdfs:label 'Classification Method' ;
    rdfs:comment 'Algorithm or methodology used to classify and delineate management zones within the map (e.g., manual delineation, k-means clustering, supervised classification, unsupervised classification, threshold-based).' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Spatial reference system or coordinate system used for the zone map (e.g., EPSG:4326 for WGS84, EPSG:32633 for UTM Zone 33N). Critical for accurate geospatial alignment.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date until which this zone map remains valid. Nullable for maps with indefinite validity. Used for version control and temporal management.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or file path where the zone map digital file is stored within the data lake or file system. Used for retrieval and access management.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the zone map file expressed in megabytes. Useful for storage management and data transfer planning.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generationDate rdf:type rdf:Property ;
    rdfs:label 'Generation Date' ;
    rdfs:comment 'Date when the zone map was generated or created from the source data. Distinct from collection date as processing may occur later.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isVraEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Vra Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this zone map is actively used for variable rate application prescriptions in field operations (True) or is for reference only (False).' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mapCode rdf:type rdf:Property ;
    rdfs:label 'Map Code' ;
    rdfs:comment 'Unique alphanumeric business identifier or code for the zone map, used for external reference and system integration.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapName rdf:type rdf:Property ;
    rdfs:label 'Map Name' ;
    rdfs:comment 'Human-readable name or title assigned to this zone map for identification and reference purposes.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapType rdf:type rdf:Property ;
    rdfs:label 'Map Type' ;
    rdfs:comment 'Classification of the zone map based on the agronomic or environmental attribute it represents (e.g., soil type, yield potential, elevation, NDVI vegetation index, soil moisture, nutrient levels).' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxValue rdf:type rdf:Property ;
    rdfs:label 'Max Value' ;
    rdfs:comment 'Maximum value of the measured attribute observed across all zones in the map. Defines the upper bound of the data range.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanValue rdf:type rdf:Property ;
    rdfs:label 'Mean Value' ;
    rdfs:comment 'Average or mean value of the measured attribute across all zones in the map. Provides a central tendency measure for the field.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minValue rdf:type rdf:Property ;
    rdfs:label 'Min Value' ;
    rdfs:comment 'Minimum value of the measured attribute observed across all zones in the map. Defines the lower bound of the data range.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionMeters rdf:type rdf:Property ;
    rdfs:label 'Resolution Meters' ;
    rdfs:comment 'Spatial resolution of the zone map expressed in meters, representing the grid cell size or minimum distinguishable feature size in the map.' ;
    rdfs:domain ind:ZoneMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Total Area Hectares' ;
    rdfs:comment 'Total area covered by the zone map expressed in hectares. Represents the spatial extent of the mapped field or region.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersedesNoticeId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Notice Id' ;
    rdfs:comment 'Reference to the previous privacy notice that this version supersedes or replaces. Null if this is the first version.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyNotice .

ind:appliesToCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applies To Customer Segment' ;
    rdfs:comment 'Customer segment or category this notice applies to (e.g., B2B_enterprise, B2C_consumer, EU_residents, California_residents, all_customers).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit customer consent is required for this privacy notice (True) or if it is informational only (False).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for privacy-related inquiries and data subject requests related to this notice.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for privacy-related inquiries and data subject requests related to this notice.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRightsDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Rights Description' ;
    rdfs:comment 'Description of customer rights under this privacy notice (e.g., right to access, rectification, erasure, data portability, objection).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesCovered rdf:type rdf:Property ;
    rdfs:label 'Data Categories Covered' ;
    rdfs:comment 'Comma-separated list of data categories this notice covers (e.g., personal_identifiers, contact_information, transaction_history, location_data, biometric_data).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric order for displaying this notice in lists or selection interfaces (lower numbers appear first).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dpoName rdf:type rdf:Property ;
    rdfs:label 'Dpo Name' ;
    rdfs:comment 'Name of the Data Protection Officer or privacy officer responsible for this notice, if applicable.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this is the default privacy notice applied when no specific notice is selected.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeCode rdf:type rdf:Property ;
    rdfs:label 'Notice Code' ;
    rdfs:comment 'Business-readable unique code for the privacy notice (e.g., GDPR_EU_2024, CCPA_US_2023).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeName rdf:type rdf:Property ;
    rdfs:label 'Notice Name' ;
    rdfs:comment 'Human-readable name of the privacy notice (e.g., \'General Data Protection Regulation Notice\', \'California Consumer Privacy Act Notice\').' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeSummary rdf:type rdf:Property ;
    rdfs:label 'Notice Summary' ;
    rdfs:comment 'Brief summary or plain-language description of the privacy notice for customer-facing displays.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeText rdf:type rdf:Property ;
    rdfs:label 'Notice Text' ;
    rdfs:comment 'Full legal text of the privacy notice as presented to customers and data subjects.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Classification of the privacy notice based on its purpose and legal requirement.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutAvailable rdf:type rdf:Property ;
    rdfs:label 'Opt Out Available' ;
    rdfs:comment 'Indicates whether customers have the option to opt out of the data practices described in this notice.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingPurposes rdf:type rdf:Property ;
    rdfs:label 'Processing Purposes' ;
    rdfs:comment 'Comma-separated list of purposes for which data is processed under this notice (e.g., order_fulfillment, marketing, analytics, compliance, customer_service).' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationUrl rdf:type rdf:Property ;
    rdfs:label 'Publication Url' ;
    rdfs:comment 'Web URL where the full privacy notice is published and accessible to customers.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Retention Period Description' ;
    rdfs:comment 'Human-readable description of how long data is retained under this notice (e.g., \'7 years from last transaction\', \'duration of customer relationship plus 2 years\').' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharing rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing' ;
    rdfs:comment 'Indicates whether customer data may be shared with third parties under this privacy notice.' ;
    rdfs:domain ind:PrivacyNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionChecklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Template Id' ;
    rdfs:comment 'Primary key for inspection_checklist_template' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Items Count' ;
    rdfs:comment 'Number of critical or mandatory inspection items that must pass for the equipment to be deemed operational or compliant.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete an inspection using this template, used for resource planning and scheduling.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Recommended frequency in days for conducting inspections using this template, supporting preventive maintenance scheduling and compliance requirements.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Name or identifier of the person or role who most recently modified this inspection checklist template.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Recommended Flag' ;
    rdfs:comment 'Indicates whether this inspection template is based on or aligned with original equipment manufacturer (OEM) recommended maintenance procedures.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precisionAgricultureFlag rdf:type rdf:Property ;
    rdfs:label 'Precision Agriculture Flag' ;
    rdfs:comment 'Indicates whether this inspection template includes checks for precision agriculture hardware such as GPS/RTK receivers, variable rate application (VRA) controllers, or telematics systems.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Certification Flag' ;
    rdfs:comment 'Indicates whether completion of this inspection requires a certified inspector or technician, supporting compliance with regulatory and safety requirements.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Notes documenting changes made in the current version of the inspection checklist template, supporting change management and audit trail requirements.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this inspection template addresses safety-critical systems or components that could pose risk to operators or farm personnel if not properly maintained.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalApplicability rdf:type rdf:Property ;
    rdfs:label 'Seasonal Applicability' ;
    rdfs:comment 'Indicates the seasonal context or agricultural cycle phase when this inspection template is most relevant, supporting seasonal maintenance planning.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of keywords or tags used for categorization, search, and filtering of inspection checklist templates within the maintenance management system.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the inspection checklist template, used for reference in maintenance management systems and operational documentation.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the inspection checklist template, including its purpose, scope, and any special instructions for inspectors.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the inspection checklist template, describing the type of inspection or equipment category it applies to.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'Total number of inspection items or checkpoints included in this template, providing a measure of inspection comprehensiveness.' ;
    rdfs:domain ind:InspectionChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Day' ;
    rdfs:comment 'Maximum available working hours per day for this work center, used for maintenance scheduling and resource planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Highest certification level held by the work center for equipment maintenance and repair, indicating technical capability and authorization.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveMaintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Maintenance Flag' ;
    rdfs:comment 'Indicates whether the work center performs corrective maintenance and breakdown repair services.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the work center\'s purpose, capabilities, and operational scope within the equipment maintenance and fleet management context.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for work center communications and service requests.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSpecialization rdf:type rdf:Property ;
    rdfs:label 'Equipment Specialization' ;
    rdfs:comment 'Types of agricultural equipment this work center specializes in servicing, such as tractors, combines, planters, sprayers, or irrigation systems.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name of the work center describing its function or location within the agricultural operation.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Authorized Flag' ;
    rdfs:comment 'Indicates whether the work center is authorized by original equipment manufacturers such as John Deere, Case IH, or New Holland for warranty and certified repairs.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Flag' ;
    rdfs:comment 'Indicates whether the work center maintains an on-site parts inventory for equipment maintenance and repairs.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the work center facility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionAgricultureSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Precision Agriculture Support Flag' ;
    rdfs:comment 'Indicates whether the work center provides support for precision agriculture hardware including GPS/RTK receivers and variable rate application (VRA) controllers.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMaintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Flag' ;
    rdfs:comment 'Indicates whether the work center performs scheduled preventive maintenance activities as part of its service offerings.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Integration Flag' ;
    rdfs:comment 'Indicates whether the work center has integration with telematics systems such as John Deere Operations Center for remote diagnostics and predictive maintenance.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center based on its primary function within the equipment domain.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total allocated break time within the shift in minutes. Includes meal breaks and rest periods as required by labor regulations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the shift in hours, including any built-in break periods. Used for labor cost calculation and compliance tracking.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Standard end time for the shift in HH:mm format (24-hour clock). Represents the scheduled conclusion of the work period.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2aVisaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'H2a Visa Eligible Flag' ;
    rdfs:comment 'Indicates whether this shift is eligible for H-2A temporary agricultural workers under U.S. Department of Labor regulations. Critical for migrant labor compliance.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardLevel rdf:type rdf:Property ;
    rdfs:label 'Hazard Level' ;
    rdfs:comment 'Risk classification for this shift based on exposure to hazards (machinery, chemicals, weather, livestock). Used for safety planning and insurance.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCategory rdf:type rdf:Property ;
    rdfs:label 'Labor Category' ;
    rdfs:comment 'Classification of labor type for cost accounting. Direct labor is production-related, indirect supports operations, administrative is overhead, supervisory is management.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCrewSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Crew Size' ;
    rdfs:comment 'Maximum number of workers that can be accommodated during this shift based on facility capacity, equipment availability, or operational constraints.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCrewSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Crew Size' ;
    rdfs:comment 'Minimum number of workers required to operate this shift safely and effectively. Used for workforce planning and scheduling.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User or system identifier that last modified this shift record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether hours worked during this shift qualify for overtime compensation under labor regulations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Minutes' ;
    rdfs:comment 'Portion of break time that is compensated. Used for payroll calculation and labor cost allocation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of required certifications or licenses for workers assigned to this shift (e.g., Pesticide Applicator License, Forklift Certification, HACCP, GAP). Used for compliance verification.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Training Required Flag' ;
    rdfs:comment 'Indicates whether workers must complete specific safety training before being assigned to this shift. Used for OSHA compliance and risk management.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftCategory rdf:type rdf:Property ;
    rdfs:label 'Shift Category' ;
    rdfs:comment 'Operational category indicating the primary work area or function for this shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Business identifier code for the shift (e.g., DAY1, NIGHT, HARVEST-A). Used for external reference and scheduling systems.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional pay rate multiplier or percentage applied to this shift (e.g., 1.15 for 15% night differential). Used for payroll calculation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift (e.g., Morning Shift, Night Harvest, Processing Day Shift).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Standard start time for the shift in HH:mm format (24-hour clock). Represents the scheduled beginning of the work period.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherDependentFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Dependent Flag' ;
    rdfs:comment 'Indicates whether this shift is subject to cancellation or modification based on weather conditions (e.g., field harvest shifts).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this payment run. Ensures segregation of duties per SOX requirements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Reference to the approval workflow instance that governed the authorization process for this payment run. Supports multi-level approval requirements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'External batch or file reference number assigned by the banking system or payment processor when the payment file was transmitted.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'System-generated error or exception message if the payment run encountered processing failures. Used for troubleshooting and operational support.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment run was executed and payments were transmitted to the banking system or payment processor.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to this payment run for processing and cash management purposes. Urgent payments may require expedited approval and same-day execution.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the payment run was reconciled with bank statements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payment run, formatted as PR-YYYYMMDD-NNNN for external reference and audit trails.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run based on payee category. Determines routing, approval workflows, and compliance requirements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deduction Amount' ;
    rdfs:comment 'The sum of all deductions applied across payments in this run, including tax withholdings, advances, and other adjustments.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Amount' ;
    rdfs:comment 'The sum of all gross payment amounts before any deductions, adjustments, or fees. Represents the total obligation to payees.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'The sum of all net payment amounts after deductions. This is the actual cash outflow from the corporate bank account.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit or division that owns and manages this profit center for strategic planning and performance evaluation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:controllingAreaId rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Id' ;
    rdfs:comment 'Reference to the controlling area (CO) organizational unit that manages cost accounting and profitability analysis for this profit center.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControllingArea .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person who created this profit center record, used for audit trail and accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this profit center record, used for audit trail and accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in the organizational hierarchy for roll-up reporting and consolidated financial analysis. Null for top-level profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:budgetAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Method' ;
    rdfs:comment 'Method used to allocate corporate overhead and shared service costs to this profit center for budgeting and variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Business justification or reason for closing this profit center, used for audit trail and organizational change tracking.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAllocationBasis rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Basis' ;
    rdfs:comment 'Basis used to allocate cost of goods sold to this profit center for gross margin calculation and profitability analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Profit Center Hierarchy Level' ;
    rdfs:comment 'Numeric level in the profit center organizational hierarchy, with 1 being the top consolidated level and higher numbers representing more granular operational units.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full business name of the profit center used for identification in financial statements and management reports.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by operational function within the agriculture business (e.g., crop production, livestock operations, processing facilities, distribution centers).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center represents a reportable segment under ASC 280 or IFRS 8 segment reporting requirements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlScope rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope' ;
    rdfs:comment 'Indicates whether this profit center is within the scope of Sarbanes-Oxley Act financial controls and audit requirements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Method used to price inter-company or inter-profit-center transactions for internal management reporting and tax compliance.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaId rdf:type rdf:Property ;
    rdfs:label 'Functional Area Id' ;
    rdfs:comment 'Reference to the functional area for cost-of-sales accounting and functional expense classification per GAAP/IFRS requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalArea .

ind:investmentProgramId rdf:type rdf:Property ;
    rdfs:label 'Investment Program Id' ;
    rdfs:comment 'Reference to the multi-year investment program or capital plan to which this WBS element contributes. Used for long-term CAPEX tracking.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Reference to the parent WBS element in the hierarchical project structure. Null for top-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:responsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center Id' ;
    rdfs:comment 'Reference to the cost center responsible for managing and executing activities under this WBS element. Used for cost center accounting and budget control.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:accountAssignmentElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Element Indicator' ;
    rdfs:comment 'Flag indicating whether this WBS element can be used as an account assignment object for purchase orders, invoices, and other financial documents. True if account-assignment-relevant, False otherwise.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Name of the person or department who requested the creation of this WBS element. Used for audit trail and approval workflows.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Billing Element Indicator' ;
    rdfs:comment 'Flag indicating whether this WBS element is used as a billing element for customer invoicing. True if billing-relevant, False otherwise.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the WBS element budget as capital expenditure (CAPEX), operational expenditure (OPEX), or mixed for financial statement categorization.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Amount' ;
    rdfs:comment 'The original approved budget amount allocated to this WBS element for planning and variance analysis purposes.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Planning Element Indicator' ;
    rdfs:comment 'Flag indicating whether this WBS element is used for project planning and scheduling activities. True if planning-relevant, False otherwise.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsAnalysisKey rdf:type rdf:Property ;
    rdfs:label 'Results Analysis Key' ;
    rdfs:comment 'Configuration key controlling revenue recognition method and work-in-progress calculation for this WBS element per GAAP/IFRS revenue recognition standards.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'The current revised budget amount after approved budget changes, supplements, or reallocations. Used for current-period budget control.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile' ;
    rdfs:comment 'Configuration key defining how costs accumulated on this WBS element are settled to receiving cost objects (assets, GL accounts, cost centers) at period-end.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Flag indicating whether this WBS element is used only for statistical reporting purposes without actual cost postings. True if statistical, False if operational.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the WBS element in project management and financial systems. Used for cost allocation and project tracking.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Detailed description of the WBS element\'s scope, purpose, and deliverables within the project hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementName rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element describing the project phase, deliverable, or cost object.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element indicating its operational state within the project execution workflow.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementType rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Type' ;
    rdfs:comment 'Classification of the WBS element by its functional purpose: planning (for project planning), billing (for customer invoicing), account_assignment (for cost allocation), or statistical (for reporting only).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Hierarchical level of the WBS element within the project structure. Level 1 represents top-level elements, with increasing numbers for deeper nesting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posting Allowed' ;
    rdfs:comment 'Indicates whether adjustment entries (journal entries, accruals, reclassifications) are allowed during soft close or after reopening. Supports controlled close process.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'The date on which external audit procedures for this period were completed and the audit opinion was issued. Null if audit is not required or not yet complete.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Required' ;
    rdfs:comment 'Indicates whether this close period requires external audit review (typically true for annual and quarterly reporting periods).' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month (1-12) in which this close period ends. Used for calendar-year reporting alignment.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The calendar quarter (1-4) in which this close period ends. Used for calendar-year reporting alignment.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which this close period ends. May differ from fiscal year for organizations with non-calendar fiscal years.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeDueDate rdf:type rdf:Property ;
    rdfs:label 'Close Due Date' ;
    rdfs:comment 'Target date by which the close process for this period must be completed. Used for close calendar planning and compliance tracking.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current lifecycle status of the close period: open (accepting transactions), soft_close (preliminary close, limited posting allowed), hard_close (final close, restricted posting), closed (finalized, no posting), reopened (closed period reopened for adjustments), locked (permanently closed per SOX controls).' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Consolidation Completion Date' ;
    rdfs:comment 'The date on which consolidation of all entities for this period was completed. Null if consolidation is not required or not yet complete.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consolidationRequired rdf:type rdf:Property ;
    rdfs:label 'Consolidation Required' ;
    rdfs:comment 'Indicates whether this period requires consolidation of subsidiary and business unit financial results into consolidated financial statements.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter within the fiscal year (1, 2, 3, or 4). Null for annual or monthly periods that do not align to quarters.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardCloseDate rdf:type rdf:Property ;
    rdfs:label 'Hard Close Date' ;
    rdfs:comment 'The date on which the period entered hard close status, restricting most posting activities and finalizing preliminary results.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which the period was permanently locked, preventing any further posting or adjustments per SOX compliance requirements.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Standardized code identifying the close period, typically used in financial systems (e.g., \'2024-01\', \'Q1-2024\', \'FY2024\').' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Business-friendly name for the accounting close period (e.g., \'January 2024 Close\', \'Q1 FY2024 Close\', \'Year-End 2023\').' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowed rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed' ;
    rdfs:comment 'Indicates whether transaction posting is currently allowed for this period. True if open or soft close, false if hard close, closed, or locked.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenDate rdf:type rdf:Property ;
    rdfs:label 'Reopen Date' ;
    rdfs:comment 'The date on which a previously closed period was reopened for adjustments. Null if the period has never been reopened.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Indicates whether this period is a formal reporting period requiring consolidated financial statements and regulatory filings (e.g., quarterly, annual). False for internal-only or special periods.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softCloseDate rdf:type rdf:Property ;
    rdfs:label 'Soft Close Date' ;
    rdfs:comment 'The date on which the period entered soft close status, allowing preliminary reporting while final adjustments are processed.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxCompliant rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant' ;
    rdfs:comment 'Indicates whether this close period has met all Sarbanes-Oxley Act internal control and audit requirements. True when all SOX controls have been executed and documented.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'The number of business working days within this close period, excluding weekends and holidays. Used for operational planning and productivity analysis.' ;
    rdfs:domain ind:CloseCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierAccessCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Access Code' ;
    rdfs:comment 'Access code or identifier used by carriers for facility entry and shipment pickup/delivery coordination.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldStorageCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Cold Storage Capacity Cubic Meters' ;
    rdfs:comment 'Cold chain storage capacity in cubic meters for temperature-controlled agricultural products.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity that owns or operates the plant facility.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the plant facility is a customs bonded warehouse for international shipments.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the plant facility, used for documentation transmission.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the plant facility is certified to handle hazardous materials such as pesticides or fertilizers.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadingDockCount rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Count' ;
    rdfs:comment 'Number of loading docks available at the plant facility for inbound and outbound logistics operations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours of the plant facility, used for shipment scheduling and carrier coordination.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Official business name of the plant facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the plant facility based on its primary operational function within the agricultural supply chain.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether the plant facility is equipped with RFID technology for lot tracking and traceability.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Meters' ;
    rdfs:comment 'Total storage capacity of the plant facility measured in cubic meters, critical for warehouse and cold storage planning.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyLogisticsProviderFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Provider Flag' ;
    rdfs:comment 'Indicates whether the plant facility is operated by a third-party logistics provider rather than owned directly.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSalesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Sales Organization Id' ;
    rdfs:comment 'Reference to the parent sales organization in a hierarchical structure, if this is a subsidiary or regional sales organization.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:billingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Block Flag' ;
    rdfs:comment 'Indicates whether billing is blocked for this sales organization pending approval or data validation.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the sales organization in business transactions and reporting. Used in SAP S/4HANA SD module as the sales organization key.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Block Flag' ;
    rdfs:comment 'Indicates whether deliveries are blocked for this sales organization pending resolution of compliance or payment issues.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Product division or business unit that this sales organization represents, such as crops, livestock, or specialty products.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterms Default' ;
    rdfs:comment 'Default International Commercial Terms (Incoterms) used by this sales organization for defining delivery responsibilities and costs.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Order Block Flag' ;
    rdfs:comment 'Indicates whether new sales orders are blocked for this sales organization due to credit, compliance, or operational reasons.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingProcedure rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure' ;
    rdfs:comment 'SAP pricing procedure code that defines the sequence of pricing conditions applied to sales orders in this organization.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code where this sales organization operates, such as state, province, or multi-country region.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesGroupCode rdf:type rdf:Property ;
    rdfs:label 'Sales Group Code' ;
    rdfs:comment 'Code identifying the sales group or team responsible for managing sales activities within this organization.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'Code identifying the primary sales office or branch location associated with this sales organization.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the sales organization by operational scope and market focus.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the cooperative business unit or division that generated the patronage activity.' ;
    rdfs:domain ind:Agriculture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPercentage rdf:type rdf:Property ;
    rdfs:label 'Cash Percentage' ;
    rdfs:comment 'Percentage of total distribution paid in cash, typically minimum 20% per IRS qualified written notice requirements.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashPortionAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Portion Amount' ;
    rdfs:comment 'Dollar amount of the patronage distribution paid to the member in cash.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Externally-known unique business identifier for the patronage distribution transaction.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRate rdf:type rdf:Property ;
    rdfs:label 'Distribution Rate' ;
    rdfs:comment 'Percentage rate applied to patronage base amount to calculate the total distribution allocation.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the patronage distribution in the approval and payment workflow.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Classification of the patronage distribution method per cooperative bylaws and IRS regulations.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Equity Certificate Number' ;
    rdfs:comment 'Certificate number issued for the equity portion of the patronage distribution allocated to member capital account.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityPercentage rdf:type rdf:Property ;
    rdfs:label 'Equity Percentage' ;
    rdfs:comment 'Percentage of total distribution retained as member equity or allocated to capital account.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPortionAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Portion Amount' ;
    rdfs:comment 'Dollar amount of the patronage distribution retained as member equity or allocated to capital account.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:form1099PatrIssueDate rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Patr Issue Date' ;
    rdfs:comment 'Date when IRS Form 1099-PATR was issued to the member for tax reporting.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:form1099PatrIssued rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Patr Issued' ;
    rdfs:comment 'Indicates whether IRS Form 1099-PATR has been issued to the member for this distribution.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netCashPaid rdf:type rdf:Property ;
    rdfs:label 'Net Cash Paid' ;
    rdfs:comment 'Net cash amount paid to member after withholding and any other deductions.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonQualifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Non Qualified Amount' ;
    rdfs:comment 'Portion of distribution that does not qualify for cooperative tax deduction and is taxed at corporate level.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patronageBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Patronage Base Amount' ;
    rdfs:comment 'Total dollar value of member patronage activity (purchases, sales, or services) used as the basis for distribution calculation.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Qualified Amount' ;
    rdfs:comment 'Portion of distribution that qualifies for tax deduction by the cooperative under IRS Subchapter T qualified written notice rules.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Eligible Date' ;
    rdfs:comment 'Date when the equity portion becomes eligible for redemption to the member per revolving fund schedule.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revolvingPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Revolving Period Years' ;
    rdfs:comment 'Number of years the equity portion will be retained before redemption per cooperative revolving fund policy.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Tax year for which the patronage distribution is reported on IRS Form 1099-PATR.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Distribution Amount' ;
    rdfs:comment 'Total patronage distribution amount allocated to the member before cash/equity split.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Federal and state tax withholding amount deducted from cash portion per member W-9 status and backup withholding rules.' ;
    rdfs:domain ind:PatronageDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingArrangementId rdf:type rdf:Property ;
    rdfs:label 'Financing Arrangement Id' ;
    rdfs:comment 'Primary key for financing_arrangement' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment Code' ;
    rdfs:comment 'Code indicating the accounting classification and treatment under GAAP or IFRS standards.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Human-readable descriptive name of the financing arrangement for business reference.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the financing arrangement, used in contracts and communications.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle status of the financing arrangement indicating its operational state.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementType rdf:type rdf:Property ;
    rdfs:label 'Arrangement Type' ;
    rdfs:comment 'Classification of the financing arrangement based on structure and purpose.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the legal contract document for this financing arrangement.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'Method used to calculate interest charges on the outstanding balance.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanToValueRatio rdf:type rdf:Property ;
    rdfs:label 'Loan To Value Ratio' ;
    rdfs:comment 'Ratio of the principal amount to the collateral value, expressed as a decimal (e.g., 0.8000 for 80%).' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Prepayment Allowed Flag' ;
    rdfs:comment 'Indicates whether early repayment of principal is permitted under the arrangement terms.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prepaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Penalty Rate' ;
    rdfs:comment 'Penalty rate applied to prepayments if early repayment is subject to fees, expressed as a decimal percentage.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purposeCode rdf:type rdf:Property ;
    rdfs:label 'Purpose Code' ;
    rdfs:comment 'Classification code indicating the business purpose for which the financing was obtained.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this arrangement must be included in regulatory financial filings and disclosures.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this financing arrangement is subject to SOX internal control requirements and audit procedures.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Total duration of the financing arrangement expressed in months from effective date to maturity.' ;
    rdfs:domain ind:FinancingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBirthWeightKg rdf:type rdf:Property ;
    rdfs:label 'Average Birth Weight Kg' ;
    rdfs:comment 'Typical birth weight in kilograms for offspring of this breed, used for calving/farrowing management and health monitoring.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyGainKg rdf:type rdf:Property ;
    rdfs:label 'Average Daily Gain Kg' ;
    rdfs:comment 'Expected daily weight gain in kilograms during the growth phase, used for performance benchmarking and feed efficiency calculations.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLitterSize rdf:type rdf:Property ;
    rdfs:label 'Average Litter Size' ;
    rdfs:comment 'Expected number of offspring per birth event for the breed, used for production planning and facility capacity management.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageMatureWeightKg rdf:type rdf:Property ;
    rdfs:label 'Average Mature Weight Kg' ;
    rdfs:comment 'Typical adult body weight in kilograms for the breed at maturity, used for feed planning and facility design.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breedCategory rdf:type rdf:Property ;
    rdfs:label 'Breed Category' ;
    rdfs:comment 'Primary production purpose classification of the breed, indicating its intended agricultural use and economic function.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedName rdf:type rdf:Property ;
    rdfs:label 'Breed Name' ;
    rdfs:comment 'Official common name of the breed as recognized by breed associations and industry standards.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedStatus rdf:type rdf:Property ;
    rdfs:label 'Breed Status' ;
    rdfs:comment 'Current lifecycle status of the breed indicating its availability and conservation state within breeding programs.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breedingSeason rdf:type rdf:Property ;
    rdfs:label 'Breeding Season' ;
    rdfs:comment 'Natural or managed breeding cycle pattern for the breed, indicating optimal reproductive timing for breeding program management.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carcassYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Carcass Yield Percentage' ;
    rdfs:comment 'Expected dressed carcass weight as a percentage of live weight for meat breeds, used for harvest planning and economic valuation.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateAdaptability rdf:type rdf:Property ;
    rdfs:label 'Climate Adaptability' ;
    rdfs:comment 'Environmental climate conditions to which the breed is best suited, used for facility design and geographic placement decisions.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coatColorPattern rdf:type rdf:Property ;
    rdfs:label 'Coat Color Pattern' ;
    rdfs:comment 'Characteristic coat color and pattern description for the breed, used for visual identification and breed verification.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationPriority rdf:type rdf:Property ;
    rdfs:label 'Conservation Priority' ;
    rdfs:comment 'Conservation status classification indicating the urgency of genetic preservation efforts for the breed.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossbreedingCompatibility rdf:type rdf:Property ;
    rdfs:label 'Crossbreeding Compatibility' ;
    rdfs:comment 'Notes on breeds commonly crossed with this breed and expected hybrid vigor outcomes, used for breeding program design.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eggProductionPotentialPerYear rdf:type rdf:Property ;
    rdfs:label 'Egg Production Potential Per Year' ;
    rdfs:comment 'Average annual egg production count for poultry layer breeds, used for production forecasting and flock management. Null for non-poultry breeds.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedConversionRatio rdf:type rdf:Property ;
    rdfs:label 'Feed Conversion Ratio' ;
    rdfs:comment 'Average feed conversion efficiency expressed as kilograms of feed required per kilogram of weight gain, used for economic analysis and ration planning.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geneticMarkerProfile rdf:type rdf:Property ;
    rdfs:label 'Genetic Marker Profile' ;
    rdfs:comment 'Summary of key genetic markers or DNA characteristics used for breed verification and parentage validation in breeding programs.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gestationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Gestation Period Days' ;
    rdfs:comment 'Average length of pregnancy in days for the breed, used for breeding program scheduling and calving/farrowing date estimation.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCertifiedOrganicEligible rdf:type rdf:Property ;
    rdfs:label 'Is Certified Organic Eligible' ;
    rdfs:comment 'Indicates whether the breed meets eligibility criteria for certified organic production programs.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHeritageBreed rdf:type rdf:Property ;
    rdfs:label 'Is Heritage Breed' ;
    rdfs:comment 'Indicates whether the breed is classified as a heritage or traditional breed eligible for conservation programs and specialty marketing.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketAgeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Market Age Target Days' ;
    rdfs:comment 'Typical age in days at which animals of this breed reach market readiness, used for production cycle planning and facility turnover scheduling.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketWeightTargetKg rdf:type rdf:Property ;
    rdfs:label 'Market Weight Target Kg' ;
    rdfs:comment 'Optimal live weight in kilograms at which animals of this breed are typically marketed or harvested, used for production scheduling and economic planning.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milkProductionPotentialKgPerYear rdf:type rdf:Property ;
    rdfs:label 'Milk Production Potential Kg Per Year' ;
    rdfs:comment 'Average annual milk yield in kilograms for dairy breeds, used for production forecasting and economic analysis. Null for non-dairy breeds.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Physical Characteristics' ;
    rdfs:comment 'Detailed description of distinguishing physical traits and conformation standards for the breed, used for breed verification and selection.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryAssociationName rdf:type rdf:Property ;
    rdfs:label 'Registry Association Name' ;
    rdfs:comment 'Name of the official breed registry or association that maintains pedigree records and breed standards for this breed.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restrictions' ;
    rdfs:comment 'Any import/export restrictions, quarantine requirements, or regulatory limitations applicable to this breed, used for compliance and trade planning.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Any unique care, housing, or management requirements specific to this breed, used for facility design and staff training.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperament rdf:type rdf:Property ;
    rdfs:label 'Temperament' ;
    rdfs:comment 'Typical behavioral disposition of the breed, used for handler safety planning and animal welfare management.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barnId rdf:type rdf:Property ;
    rdfs:label 'Barn Id' ;
    rdfs:comment 'Reference to the specific barn or building structure where the bulk tank is physically located within the facility.' ;
    rdfs:domain ind:Livestock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Barn .

ind:agitatorInstalled rdf:type rdf:Property ;
