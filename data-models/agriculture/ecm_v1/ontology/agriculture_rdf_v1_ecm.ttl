    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master reference table for plant. Referenced by plant_id.' .

ind:SalesOrganization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'Master reference table for sales_organization. Referenced by sales_org_id.' .

ind:PatronageDistribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
