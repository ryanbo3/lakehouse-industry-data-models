    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Functional Area Description' ;
    rdfs:comment 'Detailed description of the functional area\'s purpose, scope, and responsibilities within the agricultural enterprise.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaName rdf:type rdf:Property ;
    rdfs:label 'Functional Area Name' ;
    rdfs:comment 'Full descriptive name of the functional area (e.g., Crop Production, Livestock Operations, Equipment Maintenance, Sales & Marketing).' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaType rdf:type rdf:Property ;
    rdfs:label 'Functional Area Type' ;
    rdfs:comment 'Classification of the functional area by its primary business function within the agricultural enterprise.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapReportingSegment rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Segment' ;
    rdfs:comment 'GAAP reporting segment classification for consolidated financial statement reporting and segment disclosure requirements.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Id' ;
    rdfs:comment 'Reference to the default general ledger account used for posting transactions related to this functional area.' ;
    rdfs:domain ind:FunctionalArea ;
