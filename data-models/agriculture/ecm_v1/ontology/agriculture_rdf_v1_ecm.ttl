ind:isCapexEligible rdf:type rdf:Property ;
    rdfs:label 'Is Capex Eligible' ;
    rdfs:comment 'Indicates whether this functional area is eligible to incur and track capital expenditures (CAPEX) for asset acquisition and improvement projects.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Indicates whether this functional area directly generates revenue for the enterprise (true) or is a cost center only (false).' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentFunctionalAreaId rdf:type rdf:Property ;
    rdfs:label 'Parent Functional Area Id' ;
    rdfs:comment 'Reference to the parent functional area in a hierarchical organizational structure. Null for top-level functional areas.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleManagerId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Id' ;
    rdfs:comment 'Reference to the employee who is the designated manager or owner responsible for this functional area\'s performance and budget.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roiTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percentage' ;
    rdfs:comment 'Target return on investment percentage for this functional area, expressed as a percentage of invested capital.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Control Required' ;
    rdfs:comment 'Indicates whether this functional area is subject to Sarbanes-Oxley Act (SOX) financial controls and audit requirements.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:animalWelfareCertified rdf:type rdf:Property ;
    rdfs:label 'Animal Welfare Certified' ;
    rdfs:comment 'Indicates whether the barn has achieved third-party animal welfare certification such as GAP, Certified Humane, or similar programs.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aphisPremisesId rdf:type rdf:Property ;
    rdfs:label 'Aphis Premises Id' ;
    rdfs:comment 'USDA APHIS-assigned unique premises identification number for regulatory traceability and disease control compliance.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barnCode rdf:type rdf:Property ;
    rdfs:label 'Barn Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the barn for operational reference and facility identification across systems.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barnName rdf:type rdf:Property ;
    rdfs:label 'Barn Name' ;
    rdfs:comment 'Human-readable name or designation of the barn facility for identification and communication purposes.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barnType rdf:type rdf:Property ;
    rdfs:label 'Barn Type' ;
    rdfs:comment 'Classification of the barn based on its primary operational purpose within the livestock production cycle.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityHeadCount rdf:type rdf:Property ;
    rdfs:label 'Capacity Head Count' ;
    rdfs:comment 'Maximum number of animals (head count) that the barn is designed to house simultaneously under optimal conditions.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:climateControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Climate Control Enabled' ;
    rdfs:comment 'Indicates whether the barn is equipped with automated climate control systems for temperature and humidity management.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Date' ;
    rdfs:comment 'Date when the barn construction was completed and the facility became operational.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentOccupancyCount rdf:type rdf:Property ;
    rdfs:label 'Current Occupancy Count' ;
    rdfs:comment 'Current number of animals housed in the barn at the time of record.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:farmId rdf:type rdf:Property ;
    rdfs:label 'Farm Id' ;
    rdfs:comment 'Reference to the parent farm or production site where this barn is located.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'Total usable floor area of the barn measured in square feet, used for space planning and animal welfare compliance.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent major renovation or structural upgrade to the barn facility.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penCount rdf:type rdf:Property ;
    rdfs:label 'Pen Count' ;
    rdfs:comment 'Total number of individual pens or enclosures within the barn for animal grouping and management.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ventilationSystemType rdf:type rdf:Property ;
    rdfs:label 'Ventilation System Type' ;
    rdfs:comment 'Type of ventilation system installed in the barn to maintain air quality and temperature control for animal health.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Waste Management System' ;
    rdfs:comment 'Type of manure and waste management system employed at the barn for environmental compliance and operational efficiency.' ;
    rdfs:domain ind:Barn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Externally-known unique batch number assigned during production. Used for traceability across supply chain and regulatory reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch in the quality management workflow.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of batch purpose: full production run, pilot test, rework of rejected material, or quality sample batch.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssued rdf:type rdf:Property ;
    rdfs:label 'Coa Issued' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis has been issued for this batch documenting quality test results.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCompliant rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliant' ;
    rdfs:comment 'Indicates whether the batch was produced in compliance with HACCP critical control point requirements.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorId rdf:type rdf:Property ;
    rdfs:label 'Inspector Id' ;
    rdfs:comment 'Reference to the quality inspector who performed the batch inspection and released or rejected the batch.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotCode rdf:type rdf:Property ;
    rdfs:label 'Lot Code' ;
    rdfs:comment 'Production lot code printed on packaging for consumer traceability and recall management.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlTested rdf:type rdf:Property ;
    rdfs:label 'Mrl Tested' ;
    rdfs:comment 'Indicates whether the batch was tested for pesticide and chemical residue levels against regulatory MRL limits.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pathogenResult rdf:type rdf:Property ;
    rdfs:label 'Pathogen Result' ;
    rdfs:comment 'Result of pathogen testing: negative (safe), positive (contaminated), pending, or not tested.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathogenTested rdf:type rdf:Property ;
    rdfs:label 'Pathogen Tested' ;
    rdfs:comment 'Indicates whether the batch was tested for foodborne pathogens (Salmonella, E. coli, Listeria, etc.).' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the product master record that this batch represents.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line or equipment used to manufacture this batch.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Timestamp' ;
    rdfs:comment 'Precise timestamp when batch production was completed, including time zone. Used for HACCP critical control point documentation.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'Total quantity of product manufactured in this batch, measured in the product\'s base unit of measure.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'Quantity of the batch that failed quality inspection and was rejected or quarantined.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReleased rdf:type rdf:Property ;
    rdfs:label 'Quantity Released' ;
    rdfs:comment 'Quantity of the batch that passed quality inspection and was released for distribution.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when a recall was initiated for this batch, if applicable.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Reference to the supplier who provided raw materials for this batch, for upstream traceability.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of product units successfully manufactured and accepted.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issued Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was issued for this production batch.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Issued Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis has been issued for this production batch.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Audit Status' ;
    rdfs:comment 'Status of GAP audit compliance for this production order, applicable to farm-level operations.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Audit Status' ;
    rdfs:comment 'Status of GMP audit compliance for this production order, applicable to processing facilities.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrlTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mrl Testing Required Flag' ;
    rdfs:comment 'Indicates whether pesticide or chemical residue testing is required for this production batch.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrlTestingStatus rdf:type rdf:Property ;
    rdfs:label 'Mrl Testing Status' ;
    rdfs:comment 'Current status of pesticide and chemical residue testing for this production batch.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Total number of quality non-conformances identified during production of this order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Current quality inspection and approval status of the production batch.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this production batch is under regulatory hold pending inspection or approval.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date when production is scheduled to be completed for this order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production is scheduled to begin for this order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Id' ;
    rdfs:comment 'Reference to the production supervisor responsible for overseeing this production order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualComplianceCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Compliance Cost Usd' ;
    rdfs:comment 'Estimated annual cost in USD to maintain compliance with this quality standard, including audit fees, certification fees, testing costs, training expenses, and internal labor. Used for budgeting and cost-benefit analysis of quality programs.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableFacilityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Facility Types' ;
    rdfs:comment 'Comma-separated list of facility or operation types to which this quality standard applies (e.g., farm, packing house, processing plant, cold storage, distribution center, retail). Defines the scope of operations covered.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required frequency for third-party audits or internal assessments against this quality standard, expressed in months (e.g., 12 for annual, 24 for biennial). Null if no periodic audit is required.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Duration Months' ;
    rdfs:comment 'Validity period of certification issued under this quality standard, expressed in months (e.g., 12, 24, 36). After this period, recertification audit is required. Null for non-certification standards.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timeframe Days' ;
    rdfs:comment 'Maximum number of days allowed to implement corrective actions for non-conformances identified during audits or assessments under this quality standard. Timeframe varies by severity of finding (e.g., 30 days for major, 90 days for minor).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this quality standard is applicable or recognized (e.g., USA, CAN, MEX, DEU, GBR, CHN). Null for global standards applicable everywhere.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectThreshold rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Threshold' ;
    rdfs:comment 'Maximum number of critical non-conformances allowed before automatic failure of audit or assessment. Critical defects are findings that pose immediate food safety risk or regulatory violation. Zero tolerance is common for many food safety standards.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'Description of mandatory documentation, records, and evidence that must be maintained to demonstrate compliance with this quality standard (e.g., HACCP plans, SOPs, training records, COA files, corrective action logs, supplier approvals).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Recognized Flag' ;
    rdfs:comment 'Indicates whether this quality standard is benchmarked and recognized by the Global Food Safety Initiative (GFSI). GFSI recognition is a key requirement for many global retailers and food manufacturers. True if GFSI-recognized, false otherwise.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Department' ;
    rdfs:comment 'Name of the internal department or business unit responsible for managing compliance with this quality standard (e.g., Quality Assurance, Food Safety, Regulatory Affairs, Operations). Used for accountability and audit coordination.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Regulatory or governing body that mandates or oversees the standard (e.g., USDA, FDA, FSIS, European Commission, Codex Alimentarius, state agriculture departments). Applicable for regulatory and industry standards.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectThreshold rdf:type rdf:Property ;
    rdfs:label 'Major Defect Threshold' ;
    rdfs:comment 'Maximum number of major non-conformances allowed before failure of audit or assessment. Major defects are significant deviations from standard requirements that could lead to food safety issues if not corrected.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumScoreRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Score Required' ;
    rdfs:comment 'Minimum audit score or compliance percentage required to achieve certification or pass assessment under this quality standard (e.g., 80.00 for 80% compliance). Null if the standard does not use numeric scoring.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Document Url' ;
    rdfs:comment 'Web URL link to the official published standard document, guidance materials, or certification body website where the full standard text and requirements can be accessed.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether compliance with this quality standard is legally required by government regulation (e.g., FSMA Preventive Controls, HACCP for seafood and juice). True if mandated by law, false if voluntary or industry-driven.' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Primary functional category of the quality standard. Food safety covers pathogen control and contamination prevention (HACCP, FSMA), quality management covers systematic quality assurance (ISO 9001, SQF), good agricultural practices cover on-farm production (GLOBALG.A.P.), good manufacturing practices cover processing facility operations (GMP, cGMP), hazard analysis covers risk assessment methodologies (HACCP principles), and traceability covers supply chain tracking (PTI, FSMA 204).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierApprovalRequirements rdf:type rdf:Property ;
    rdfs:label 'Supplier Approval Requirements' ;
    rdfs:comment 'Description of supplier qualification, approval, and monitoring requirements mandated by this quality standard (e.g., supplier audits, COA review, risk-based supplier verification, FSMA Foreign Supplier Verification Program requirements).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingProtocolRequirements rdf:type rdf:Property ;
    rdfs:label 'Testing Protocol Requirements' ;
    rdfs:comment 'Description of mandatory testing, sampling, and analytical methods required by this quality standard (e.g., pathogen testing frequency, MRL testing protocols, environmental monitoring programs, finished product testing specifications).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Traceability Requirements' ;
    rdfs:comment 'Description of traceability and supply chain tracking requirements mandated by this quality standard (e.g., one-up/one-back traceability, lot coding requirements, recall readiness, FSMA 204 Key Data Elements for high-risk foods).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Description of mandatory training programs and competency requirements for personnel involved in activities covered by this quality standard (e.g., HACCP training for food safety team, GMP training for production staff, auditor qualification requirements).' ;
    rdfs:domain ind:QualityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Parent Audit Finding Id' ;
    rdfs:comment 'Self-referencing FK on audit_finding (parent_audit_finding_id)' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:parentBioterrorismRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Parent Bioterrorism Registration Id' ;
    rdfs:comment 'Self-referencing FK on bioterrorism_registration (parent_bioterrorism_registration_id)' ;
    rdfs:domain ind:BioterrorismRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioterrorismRegistration .

ind:parentComplianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Parent Compliance Audit Id' ;
    rdfs:comment 'Self-referencing FK on compliance_audit (parent_compliance_audit_id)' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:parentCalendarEntryId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Entry Id' ;
    rdfs:comment 'Self-referencing FK on calendar_entry (parent_calendar_entry_id)' ;
    rdfs:domain ind:CalendarEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalendarEntry .

ind:parentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Parent Document Id' ;
    rdfs:comment 'Self-referencing FK on document (parent_document_id)' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:parentObligationId rdf:type rdf:Property ;
    rdfs:label 'Parent Obligation Id' ;
    rdfs:comment 'Self-referencing FK on obligation (parent_obligation_id)' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:parentCorrectiveActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Parent Corrective Action Plan Id' ;
    rdfs:comment 'Self-referencing FK on corrective_action_plan (parent_corrective_action_plan_id)' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveActionPlan .

ind:parentFoodSafetyPlanId rdf:type rdf:Property ;
    rdfs:label 'Parent Food Safety Plan Id' ;
    rdfs:comment 'Self-referencing FK on food_safety_plan (parent_food_safety_plan_id)' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyPlan .

ind:parentInspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Parent Inspection Record Id' ;
    rdfs:comment 'Self-referencing FK on inspection_record (parent_inspection_record_id)' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRecord .

ind:parentLicenseId rdf:type rdf:Property ;
    rdfs:label 'Parent License Id' ;
