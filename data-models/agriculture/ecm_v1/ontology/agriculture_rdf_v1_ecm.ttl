    rdfs:comment 'Total approved annual operating budget for the business unit in functional currency for crop enterprise budgeting and variance analysis.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Annual revenue target or goal for the business unit in functional currency for performance tracking and ROI analysis.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexBudgetAmount rdf:type rdf:Property ;
