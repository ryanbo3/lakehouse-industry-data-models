ind:feedConversionRatio rdf:type rdf:Property ;
    rdfs:label 'Feed Conversion Ratio' ;
    rdfs:comment 'Average feed conversion efficiency expressed as kilograms of feed required per kilogram of weight gain, used for economic analysis and ration planning.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
