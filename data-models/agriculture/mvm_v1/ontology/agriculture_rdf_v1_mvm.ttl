    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodGradeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified Flag' ;
    rdfs:comment 'Indicates whether the transport unit meets food safety certification standards for transporting agricultural products and food.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled Flag' ;
    rdfs:comment 'Indicates whether the transport unit is equipped with GPS tracking capability for real-time location monitoring.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'External height dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Home Location Code' ;
    rdfs:comment 'Code representing the primary or home base location where the transport unit is normally stationed when not in use.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthM rdf:type rdf:Property ;
    rdfs:label 'Length M' ;
    rdfs:comment 'External length dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureYear rdf:type rdf:Property ;
    rdfs:label 'Manufacture Year' ;
    rdfs:comment 'Year in which the transport unit was manufactured.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on the transport unit.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification indicating the ownership model of the transport unit.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the transport unit was retired from active service and removed from the operational fleet.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Status' ;
    rdfs:comment 'Current lifecycle status of the transport unit indicating its operational state.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Externally-known unique identifier or registration number for the transport unit (e.g., container number, trailer number, railcar number).' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the transport unit by physical form factor and mode of transport.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthM rdf:type rdf:Property ;
    rdfs:label 'Width M' ;
    rdfs:comment 'External width dimension of the transport unit measured in meters.' ;
    rdfs:domain ind:TransportUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentFarmOperationId rdf:type rdf:Property ;
    rdfs:label 'Parent Farm Operation Id' ;
    rdfs:comment 'Self-referencing FK on farm_operation (parent_farm_operation_id)' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FarmOperation .

ind:bmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Bmp Compliance Status' ;
    rdfs:comment 'Current compliance status with agricultural best management practices for environmental stewardship.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationPlanDate rdf:type rdf:Property ;
    rdfs:label 'Conservation Plan Date' ;
    rdfs:comment 'Date when the current conservation plan was approved or last updated.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conservationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Conservation Plan Status' ;
    rdfs:comment 'Current status of the farm conservation plan required for environmental compliance and best management practices.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cultivatedAcreage rdf:type rdf:Property ;
    rdfs:label 'Cultivated Acreage' ;
    rdfs:comment 'Total acreage actively used for crop cultivation within the farm operation.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the farm operation holds ISO 14001 environmental management system certification.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityType rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Type' ;
    rdfs:comment 'Legal structure under which the farm operation is organized and registered.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCode rdf:type rdf:Property ;
    rdfs:label 'Operation Code' ;
    rdfs:comment 'Externally-known unique business identifier or registration code for the farm operation, often used in regulatory filings and government programs.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionAgricultureEnabled rdf:type rdf:Property ;
    rdfs:label 'Precision Agriculture Enabled' ;
    rdfs:comment 'Indicates whether the farm operation utilizes precision agriculture technologies such as GPS guidance, variable rate application, or yield monitoring.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the farm operation was registered in the system or with regulatory authorities.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtkGpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Rtk Gps Enabled' ;
    rdfs:comment 'Indicates whether the farm operation uses RTK-accurate GPS positioning for field operations and mapping.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAcreage rdf:type rdf:Property ;
    rdfs:label 'Total Acreage' ;
    rdfs:comment 'Total land area in acres managed by this farm operation, including cultivated, pasture, and non-productive land.' ;
    rdfs:domain ind:FarmOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cropUseRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Crop Use Registration Id' ;
    rdfs:comment 'Primary key for the crop_use_registration association' ;
    rdfs:domain ind:CropUseRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedUseDate rdf:type rdf:Property ;
    rdfs:label 'Approved Use Date' ;
    rdfs:comment 'The date on which this agrochemical product was formally approved for use on this commodity in the specified jurisdiction. Required for regulatory audit trails and GLOBALG.A.P. compliance documentation.' ;
    rdfs:domain ind:CropUseRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of this crop-use registration record. Tracks whether the registration is currently active, suspended by a regulatory authority, cancelled, or pending renewal. Belongs to the registration, not to either parent entity.' ;
    rdfs:domain ind:CropUseRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Primary key for the training_enrollment association' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Gap Training Completed' ;
    rdfs:comment 'Indicates whether the employee has completed required Good Agricultural Practices (GAP) training as mandated by FSMA Produce Safety Rule. Required for all workers involved in covered produce activities including harvesting, packing, and handling. [Moved from employee: This boolean on employee is a denormalized summary flag. The authoritative per-event completion record now lives in training_enrollment.completion_status. This flag can be derived from enrollment records and should be removed from employee to avoid data inconsistency.]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Haccp Training Completed' ;
    rdfs:comment 'Indicates whether the employee has completed Hazard Analysis and Critical Control Points (HACCP) training. Required for employees working in food processing facilities, packing houses, and post-harvest handling operations under FDA and USDA FSIS regulations. [Moved from employee: Same as gap_training_completed — this is a denormalized summary flag on employee that duplicates what is now tracked per-enrollment in training_enrollment.completion_status. Should be derived, not stored on the employee master.]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Certified' ;
    rdfs:comment 'Indicates whether the employee holds a current OSHA safety certification (e.g., OSHA 10-hour or 30-hour General Industry or Construction card). Required for supervisory roles and equipment operators in farm and processing facility environments. [Moved from employee: Denormalized certification flag on employee that duplicates per-enrollment certificate_issued and completion_status in training_enrollment. Should be derived from enrollment records for OSHA-type training events.]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
