    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the distribution channel in the sales lifecycle. Controls whether new orders can be placed through this channel.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the distribution channel by business model. Determines pricing strategy, contract terms, and fulfillment processes.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
