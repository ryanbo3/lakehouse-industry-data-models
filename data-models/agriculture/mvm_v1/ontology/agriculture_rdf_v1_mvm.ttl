    rdfs:comment 'Any unique care, housing, or management requirements specific to this breed, used for facility design and staff training.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperament rdf:type rdf:Property ;
    rdfs:label 'Temperament' ;
    rdfs:comment 'Typical behavioral disposition of the breed, used for handler safety planning and animal welfare management.' ;
    rdfs:domain ind:Breed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Distribution channels (direct farm sales, export, co-op) are managed by a named internal employee. channel_manager_name and channel_manager_email are denormalized representations of this employee. Rep' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentDistributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Parent Distribution Channel Id' ;
    rdfs:comment 'Self-referencing FK on distribution_channel (parent_distribution_channel_id)' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionChannel .

ind:bolGenerationRequired rdf:type rdf:Property ;
    rdfs:label 'Bol Generation Required' ;
    rdfs:comment 'Indicates whether Bill of Lading documents must be automatically generated for shipments in this channel. Typically true for wholesale and export channels.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the distribution channel in external systems and business documents. Used in SAP S/4HANA SD module for channel classification.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
