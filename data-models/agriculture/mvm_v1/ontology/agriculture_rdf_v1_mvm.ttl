    rdfs:comment 'Standard commission percentage paid to brokers, distributors, or sales representatives for transactions in this channel. Business-sensitive pricing information.' ;
    rdfs:domain ind:DistributionChannel ;
    rdf:type owl:DatatypeProperty ;
