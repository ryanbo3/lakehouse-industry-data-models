ind:litigationHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Flag' ;
    rdfs:comment 'Indicator that workspace contents are subject to litigation hold, suspending normal retention and destruction processes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workspaceName rdf:type rdf:Property ;
    rdfs:label 'Workspace Name' ;
    rdfs:comment 'Human-readable name or title of the workspace, typically representing a matter, client, or project.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Business date when the workspace was officially opened and made available for use, distinct from system creation timestamp.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workspaceStatus rdf:type rdf:Property ;
    rdfs:label 'Workspace Status' ;
    rdfs:comment 'Current lifecycle state of the workspace indicating its operational availability and access permissions.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Total Document Count' ;
    rdfs:comment 'Current count of documents contained within this workspace, used for capacity planning and billing purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStorageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Total Storage Size Mb' ;
    rdfs:comment 'Total storage space consumed by all documents in this workspace, measured in megabytes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workspaceNumber rdf:type rdf:Property ;
    rdfs:label 'Workspace Number' ;
    rdfs:comment 'Business-facing unique identifier or code for the workspace, used for external reference and user navigation.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workspaceType rdf:type rdf:Property ;
    rdfs:label 'Workspace Type' ;
    rdfs:comment 'Classification of the workspace by its primary purpose or organizational structure within the legal practice.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProductionSetId rdf:type rdf:Property ;
    rdfs:label 'Parent Production Set Id' ;
    rdfs:comment 'Self-referencing FK on production_set (parent_production_set_id)' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSet .

ind:approvingAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Approving Attorney Name' ;
    rdfs:comment 'Name of the attorney who approved the production set for delivery.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceCount rdf:type rdf:Property ;
    rdfs:label 'Data Source Count' ;
    rdfs:comment 'Number of distinct data sources from which documents in this production set were collected.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash value for the entire production set, ensuring integrity and chain of custody.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataFieldsProduced rdf:type rdf:Property ;
    rdfs:label 'Metadata Fields Produced' ;
    rdfs:comment 'Comma-separated list of metadata fields included in the production load file.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeFilesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Native Files Included Flag' ;
    rdfs:comment 'Indicates whether native file formats are included in the production.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeLogRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Privilege Log Required Flag' ;
    rdfs:comment 'Indicates whether a privilege log must accompany this production set for withheld documents.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Production Deadline Date' ;
    rdfs:comment 'Court-ordered or agreed-upon deadline for delivering this production set.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Production Protocol Version' ;
    rdfs:comment 'Version identifier of the production protocol or agreement governing this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSetName rdf:type rdf:Property ;
    rdfs:label 'Production Set Name' ;
    rdfs:comment 'Descriptive name for the production set, typically reflecting the production phase, recipient, or content scope.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSetNumber rdf:type rdf:Property ;
    rdfs:label 'Production Set Number' ;
    rdfs:comment 'Business identifier for the production set, typically assigned by the eDiscovery platform or case management system. Externally visible reference number.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeNumber rdf:type rdf:Property ;
    rdfs:label 'Production Volume Number' ;
    rdfs:comment 'Sequential volume number if the production is split across multiple deliveries.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Completed Date' ;
    rdfs:comment 'Date on which quality control review was completed.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityControlReviewerName rdf:type rdf:Property ;
    rdfs:label 'Quality Control Reviewer Name' ;
    rdfs:comment 'Name of the individual who performed the quality control review.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Status of quality control review for the production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPartyName rdf:type rdf:Property ;
    rdfs:label 'Recipient Party Name' ;
    rdfs:comment 'Name of the party or organization receiving the production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redactionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Redaction Applied Flag' ;
    rdfs:comment 'Indicates whether redactions have been applied to documents in this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Total File Size Gb' ;
    rdfs:comment 'Total file size of the production set in gigabytes.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductionVolumes rdf:type rdf:Property ;
    rdfs:label 'Total Production Volumes' ;
    rdfs:comment 'Total number of volumes planned for this production set.' ;
    rdfs:domain ind:ProductionSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:masterFamilyGroupId rdf:type rdf:Property ;
    rdfs:label 'Master Family Group Id' ;
    rdfs:comment 'Reference to the master family group when this family group has been identified as a duplicate or near-duplicate.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FamilyGroup .

ind:parentFamilyGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Group Id' ;
    rdfs:comment 'Self-referencing FK on family_group (parent_family_group_id)' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FamilyGroup .

ind:parentLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Document Id' ;
    rdfs:comment 'Reference to the primary or parent document within the family group, typically the root email or master document from which other family members derive.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:processingBatchId rdf:type rdf:Property ;
    rdfs:label 'Processing Batch Id' ;
    rdfs:comment 'Identifier for the processing batch or ingestion run during which the family group was created or updated, supporting data lineage.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessingBatch .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of attachments within the family group, typically associated with email families.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deduplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Deduplication Status' ;
    rdfs:comment 'Indicates whether the family group has been identified as unique, duplicate, or near-duplicate during deduplication processing.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Discovery Status' ;
    rdfs:comment 'Current status of the family group within the eDiscovery workflow, tracking review and production decisions.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Eligible Date' ;
    rdfs:comment 'The calculated date on which the family group becomes eligible for disposition (archival or destruction) based on retention policy.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Document Date' ;
    rdfs:comment 'The earliest creation or sent date among all documents within the family group, establishing the temporal origin of the family.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:familyGroupCode rdf:type rdf:Property ;
    rdfs:label 'Family Group Code' ;
    rdfs:comment 'Business-assigned unique code for the family group used for external reference and reporting.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyGroupName rdf:type rdf:Property ;
    rdfs:label 'Family Group Name' ;
    rdfs:comment 'Human-readable name or label for the family group, used for identification and display purposes.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyGroupType rdf:type rdf:Property ;
    rdfs:label 'Family Group Type' ;
    rdfs:comment 'Classification of the family group indicating the nature of the relationship between grouped documents (e.g., email thread, document family, attachment cluster, version set, related correspondence, discovery family).' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyRelationshipBasis rdf:type rdf:Property ;
    rdfs:label 'Family Relationship Basis' ;
    rdfs:comment 'The criterion or methodology used to establish the family grouping (e.g., attachment relationship, version lineage, email thread, custodian grouping, matter association, privilege log grouping, near-duplicate analysis, conceptual clustering).' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Document Date' ;
    rdfs:comment 'The most recent creation or sent date among all documents within the family group, establishing the temporal endpoint of the family.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Status' ;
    rdfs:comment 'Indicates whether the family group is currently subject to a legal hold, preventing disposition pending litigation or investigation.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of documents included in this family group.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redactionRequired rdf:type rdf:Property ;
    rdfs:label 'Redaction Required' ;
    rdfs:comment 'Indicates whether documents in the family group require redaction of privileged, confidential, or personally identifiable information prior to production.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Date' ;
    rdfs:comment 'The date from which the retention period begins, typically the date of document creation, matter closure, or regulatory event.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Identifier' ;
    rdfs:comment 'The native identifier or reference key for the family group in the source system, supporting traceability and reconciliation.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Family Group Status' ;
    rdfs:comment 'Current lifecycle status of the family group record within the document management system.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyAssistedReviewScore rdf:type rdf:Property ;
    rdfs:label 'Technology Assisted Review Score' ;
    rdfs:comment 'Predictive coding or continuous active learning (CAL) relevance score assigned to the family group by machine learning algorithms, ranging from 0.0000 to 1.0000.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionCount rdf:type rdf:Property ;
    rdfs:label 'Version Count' ;
    rdfs:comment 'Number of distinct versions of documents within the family group, tracking document evolution.' ;
    rdfs:domain ind:FamilyGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Id' ;
    rdfs:comment 'Reference to the review team responsible for this batch.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:parentReviewBatchId rdf:type rdf:Property ;
    rdfs:label 'Parent Review Batch Id' ;
    rdfs:comment 'Self-referencing FK on review_batch (parent_review_batch_id)' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewBatch .

ind:reviewCaseMatterId rdf:type rdf:Property ;
    rdfs:label 'Review Case Matter Id' ;
    rdfs:comment 'Reference to the litigation case or investigation this review batch supports.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:reviewLastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Review Last Modified By User Id' ;
    rdfs:comment 'Reference to the user who last modified this review batch record.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:reviewProtocolId rdf:type rdf:Property ;
    rdfs:label 'Review Protocol Id' ;
    rdfs:comment 'Reference to the review protocol or guidelines governing how documents in this batch should be reviewed.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewProtocol .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when review of this batch was completed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchName rdf:type rdf:Property ;
    rdfs:label 'Batch Name' ;
    rdfs:comment 'Descriptive name for the review batch, often indicating the document set or review focus area.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Business-facing unique identifier for the review batch, typically used in communications and reporting.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the review batch indicating the review methodology or purpose (e.g., first pass review, quality control, Technology Assisted Review seed set, Continuous Active Learning training).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calRoundNumber rdf:type rdf:Property ;
    rdfs:label 'Cal Round Number' ;
    rdfs:comment 'The CAL training round number this batch belongs to, if part of an iterative machine learning review workflow.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the batch review was marked as complete.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityControlPassCount rdf:type rdf:Property ;
    rdfs:label 'Quality Control Pass Count' ;
    rdfs:comment 'Number of documents that passed quality control review without discrepancies.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewRateDocumentsPerHour rdf:type rdf:Property ;
    rdfs:label 'Review Rate Documents Per Hour' ;
    rdfs:comment 'Average number of documents reviewed per hour for this batch, used for productivity tracking.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Review Batch Status' ;
    rdfs:comment 'Current lifecycle status of the review batch.' ;
    rdfs:domain ind:ReviewBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or required date by which this batch review should be completed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentProductionBatchId rdf:type rdf:Property ;
    rdfs:label 'Parent Production Batch Id' ;
    rdfs:comment 'Self-referencing FK on production_batch (parent_production_batch_id)' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:productionSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Production Specification Id' ;
    rdfs:comment 'Reference to the production specification or protocol document that defines the technical and legal requirements for this production batch.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSpecification .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date on which the production batch was delivered or transmitted to the requesting party or recipient.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encryptionApplied rdf:type rdf:Property ;
    rdfs:label 'Encryption Applied' ;
    rdfs:comment 'Indicates whether encryption was applied to the production batch files for secure transmission and storage.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Cryptographic algorithm or method used to encrypt the production batch (e.g., AES-256, RSA, PGP).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageFormat rdf:type rdf:Property ;
    rdfs:label 'Image Format' ;
    rdfs:comment 'Image file format used for document renderings in this production batch (single-page TIFF, multi-page PDF, or other image formats).' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'Physical or digital media type used to deliver the production batch.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producingParty rdf:type rdf:Property ;
    rdfs:label 'Producing Party' ;
    rdfs:comment 'Name of the party or organization producing and delivering this batch of documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlDate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Date' ;
    rdfs:comment 'Date on which quality control validation was completed for this production batch.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityControlNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Control Notes' ;
    rdfs:comment 'Free-text notes documenting quality control findings, issues identified, and remediation actions taken for this production batch.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlPerformed rdf:type rdf:Property ;
    rdfs:label 'Quality Control Performed' ;
    rdfs:comment 'Indicates whether quality control validation was performed on this production batch prior to delivery.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redactedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Redacted Document Count' ;
    rdfs:comment 'Number of documents in this batch that contain redactions for privilege, confidentiality, or privacy protection.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestingParty rdf:type rdf:Property ;
    rdfs:label 'Requesting Party' ;
    rdfs:comment 'Name of the party, organization, or entity that requested this production batch (opposing counsel, regulatory agency, or internal stakeholder).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textExtractionMethod rdf:type rdf:Property ;
    rdfs:label 'Text Extraction Method' ;
    rdfs:comment 'Method used to extract searchable text from documents in this batch (native text extraction, OCR processing, hybrid approach, or no text extraction).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment or transmission tracking number for physical or electronic delivery of the production batch.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedTarModelId rdf:type rdf:Property ;
    rdfs:label 'Seed Tar Model Id' ;
    rdfs:comment 'Self-referencing FK on tar_model (seed_tar_model_id)' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TarModel .

ind:accuracyScore rdf:type rdf:Property ;
    rdfs:label 'Accuracy Score' ;
    rdfs:comment 'Overall proportion of correct classifications (both relevant and non-relevant) made by the model, expressed as a decimal between 0 and 1.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'The specific machine learning algorithm employed by the TAR model for document classification and relevance prediction.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceInterval rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval' ;
    rdfs:comment 'Statistical confidence level for the models performance metrics, typically expressed as a percentage (e.g., 0.95 for 95% confidence).' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlSetSize rdf:type rdf:Property ;
    rdfs:label 'Control Set Size' ;
    rdfs:comment 'Number of documents in the control set used for ongoing validation and quality assurance of model performance.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffThreshold rdf:type rdf:Property ;
    rdfs:label 'Cutoff Threshold' ;
    rdfs:comment 'The relevance score threshold above which documents are classified as relevant for review or production, expressed as a decimal between 0 and 1.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defensibilityDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Defensibility Documentation Url' ;
    rdfs:comment 'URL reference to the comprehensive defensibility documentation package supporting the TAR models methodology and results for potential court challenges.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment Timestamp' ;
    rdfs:comment 'Date and time when the TAR model was deployed to production and made available for document classification.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deprecationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deprecation Timestamp' ;
    rdfs:comment 'Date and time when the TAR model was deprecated and removed from active use.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentsClassified rdf:type rdf:Property ;
    rdfs:label 'Documents Classified' ;
    rdfs:comment 'Total number of documents that have been scored and classified by this TAR model during its operational use.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:f1Score rdf:type rdf:Property ;
    rdfs:label 'F1 Score' ;
    rdfs:comment 'Harmonic mean of precision and recall providing a single balanced measure of model performance, expressed as a decimal between 0 and 1.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureEngineeringApproach rdf:type rdf:Property ;
    rdfs:label 'Feature Engineering Approach' ;
    rdfs:comment 'Description of the feature extraction and engineering methodology applied to prepare document data for model training.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of languages supported by the TAR model for multilingual document collections.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Training Timestamp' ;
    rdfs:comment 'Date and time when the most recent training round was completed for this TAR model.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Semantic version number of the TAR model following the pattern vX.Y.Z to track iterations and updates.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionScore rdf:type rdf:Property ;
    rdfs:label 'Precision Score' ;
    rdfs:comment 'Statistical measure of the proportion of documents classified as relevant by the model that are actually relevant, expressed as a decimal between 0 and 1.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privilegeDetectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Privilege Detection Enabled' ;
    rdfs:comment 'Indicator of whether the TAR model includes specialized detection capabilities for attorney-client privilege and work product protection.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallScore rdf:type rdf:Property ;
    rdfs:label 'Recall Score' ;
    rdfs:comment 'Statistical measure of the proportion of actually relevant documents that were correctly identified by the model, expressed as a decimal between 0 and 1.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:richnessEstimate rdf:type rdf:Property ;
    rdfs:label 'Richness Estimate' ;
    rdfs:comment 'Estimated proportion of relevant documents within the entire document collection, used for sampling and review planning.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedSetStrategy rdf:type rdf:Property ;
    rdfs:label 'Seed Set Strategy' ;
    rdfs:comment 'The methodology used to select the initial seed documents for model training, balancing representativeness and efficiency.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilizationAchieved rdf:type rdf:Property ;
    rdfs:label 'Stabilization Achieved' ;
    rdfs:comment 'Indicator of whether the TAR model has reached a stable state where additional training produces minimal performance improvement.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tarModelStatus rdf:type rdf:Property ;
    rdfs:label 'Tar Model Status' ;
    rdfs:comment 'Current lifecycle state of the TAR model indicating its operational readiness and usage authorization.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRoundsCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Rounds Completed' ;
    rdfs:comment 'Number of iterative training cycles completed in the development and refinement of the TAR model.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingSetSize rdf:type rdf:Property ;
    rdfs:label 'Training Set Size' ;
    rdfs:comment 'Total number of documents used in the training dataset to build and refine the TAR models classification capabilities.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name of the senior attorney or eDiscovery expert who performed and certified the model validation.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'The statistical validation approach used to assess and verify the TAR models performance and reliability.' ;
    rdfs:domain ind:TarModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentReviewProjectId rdf:type rdf:Property ;
    rdfs:label 'Parent Review Project Id' ;
    rdfs:comment 'Self-referencing FK on review_project (parent_review_project_id)' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewProject .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Cumulative actual costs incurred for the review project to date, including all labor and technology expenses.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyMaintained rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Maintained' ;
    rdfs:comment 'Indicates whether formal chain of custody documentation has been maintained for evidentiary integrity and admissibility.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrProcessingApplied rdf:type rdf:Property ;
    rdfs:label 'Ocr Processing Applied' ;
    rdfs:comment 'Indicates whether Optical Character Recognition was applied to extract text from image-based documents.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeProtocolApplied rdf:type rdf:Property ;
    rdfs:label 'Privilege Protocol Applied' ;
    rdfs:comment 'Indicates whether a formal privilege review protocol or agreement has been applied to this project.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the review project scope, objectives, and special considerations.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectEndDate rdf:type rdf:Property ;
    rdfs:label 'Project End Date' ;
    rdfs:comment 'Date when the review project was completed or is scheduled to be completed. Nullable for ongoing projects.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name or title of the review project, typically reflecting the matter or case name.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Externally-known unique business identifier for the review project, used for client communication and billing.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Date when the review project officially commenced or was initiated.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the review project indicating its operational state.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the review project based on its legal purpose and workflow requirements.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Control Percentage' ;
    rdfs:comment 'Percentage of reviewed documents subject to secondary quality control review, typically ranging from 5% to 100%.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDataVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Total Data Volume Gb' ;
    rdfs:comment 'Total volume of electronically stored information (ESI) collected for the review project, measured in gigabytes.' ;
    rdfs:domain ind:ReviewProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Id' ;
    rdfs:comment 'Foreign key to workforce.user.user_id' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:parentProductionSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Parent Production Specification Id' ;
    rdfs:comment 'Self-referencing FK on production_specification (parent_production_specification_id)' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSpecification .

ind:batesNumberingRequired rdf:type rdf:Property ;
    rdfs:label 'Bates Numbering Required' ;
    rdfs:comment 'Indicates whether Bates numbering (sequential document identification) is required for this production.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batesStartingNumber rdf:type rdf:Property ;
    rdfs:label 'Bates Starting Number' ;
    rdfs:comment 'Starting sequential number for Bates numbering in this production specification.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clawbackProvisionApplies rdf:type rdf:Property ;
    rdfs:label 'Clawback Provision Applies' ;
    rdfs:comment 'Indicates whether a clawback provision allowing retrieval of inadvertently produced privileged documents is in effect.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodianScope rdf:type rdf:Property ;
    rdfs:label 'Custodian Scope' ;
    rdfs:comment 'Comma-separated list of custodian names or identifiers whose documents are included in this production specification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationScope rdf:type rdf:Property ;
    rdfs:label 'Deduplication Scope' ;
    rdfs:comment 'Scope of deduplication to be applied: global (across all custodians), per custodian, family-level (email threads), or none.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyRelationshipPreserved rdf:type rdf:Property ;
    rdfs:label 'Family Relationship Preserved' ;
    rdfs:comment 'Indicates whether parent-child document relationships (e.g., email and attachments) must be preserved in the production.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hashValidationRequired rdf:type rdf:Property ;
    rdfs:label 'Hash Validation Required' ;
    rdfs:comment 'Indicates whether cryptographic hash values (MD5, SHA-256) must be provided for file integrity validation.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeLogRequired rdf:type rdf:Property ;
    rdfs:label 'Privilege Log Required' ;
    rdfs:comment 'Indicates whether a privilege log documenting withheld privileged documents must be produced.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Production Cost Estimate' ;
    rdfs:comment 'Estimated total cost in USD for completing the document production under this specification, including review, processing, and delivery.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDeadline rdf:type rdf:Property ;
    rdfs:label 'Production Deadline' ;
    rdfs:comment 'Court-ordered or agreed-upon deadline by which the production must be completed and delivered.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionVolumeEstimate rdf:type rdf:Property ;
    rdfs:label 'Production Volume Estimate' ;
    rdfs:comment 'Estimated number of document pages or files to be produced under this specification.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlSamplingRate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Sampling Rate' ;
    rdfs:comment 'Percentage of documents subject to quality control review to ensure production accuracy and completeness.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rollingProductionAllowed rdf:type rdf:Property ;
    rdfs:label 'Rolling Production Allowed' ;
    rdfs:comment 'Indicates whether documents may be produced in multiple batches over time (rolling production) rather than a single delivery.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name or title of the production specification, typically describing the matter or production scope.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business-facing unique identifier for the production specification, used in legal discovery and document production workflows.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the production specification.' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tarProtocolUsed rdf:type rdf:Property ;
    rdfs:label 'Tar Protocol Used' ;
    rdfs:comment 'Technology-Assisted Review protocol applied for document review and responsiveness determination (CAL, SPL, or none).' ;
    rdfs:domain ind:ProductionSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProcessingBatchId rdf:type rdf:Property ;
    rdfs:label 'Parent Processing Batch Id' ;
    rdfs:comment 'Self-referencing FK on processing_batch (parent_processing_batch_id)' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessingBatch .

ind:processingCreatedByUserId rdf:type rdf:Property ;
    rdfs:label 'Processing Created By User Id' ;
    rdfs:comment 'BIGINT' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:processingEsiCustodianId rdf:type rdf:Property ;
    rdfs:label 'Processing Esi Custodian Id' ;
    rdfs:comment 'BIGINT' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsiCustodian .

ind:processingModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Processing Modified By User Id' ;
    rdfs:comment 'BIGINT' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:processingRetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Processing Retention Schedule Id' ;
    rdfs:comment 'BIGINT' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the processing batch indicating its state in the workflow.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationEnabled rdf:type rdf:Property ;
    rdfs:label 'Deduplication Enabled' ;
    rdfs:comment 'Indicates whether deduplication logic was applied to identify and remove duplicate documents in this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extractionMethod rdf:type rdf:Property ;
    rdfs:label 'Extraction Method' ;
    rdfs:comment 'The method used to extract content from documents in this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Document Count' ;
    rdfs:comment 'Number of documents that failed processing within this batch due to errors or exceptions.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageDetectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Language Detection Enabled' ;
    rdfs:comment 'Indicates whether automatic language detection was performed on documents in this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nlpEnabled rdf:type rdf:Property ;
    rdfs:label 'Nlp Enabled' ;
    rdfs:comment 'Indicates whether natural language processing was applied to documents in this batch for entity extraction or classification.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrEnabled rdf:type rdf:Property ;
    rdfs:label 'Ocr Enabled' ;
    rdfs:comment 'Indicates whether optical character recognition was applied to documents in this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'The predominant language of documents in this batch, represented as ISO 639-1 two-letter code.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Processed Document Count' ;
    rdfs:comment 'Number of documents that have been successfully processed within this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from start to completion of batch processing.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingEngine rdf:type rdf:Property ;
    rdfs:label 'Processing Engine' ;
    rdfs:comment 'The software engine or tool used to execute the processing workflow for this batch.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the processing batch, including special handling instructions or observations.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to this batch determining its position in the processing queue.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingProfile rdf:type rdf:Property ;
    rdfs:label 'Processing Profile' ;
    rdfs:comment 'The configuration profile or template applied to this batch defining processing parameters and rules.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this batch has been retried after initial processing failure.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total File Size Bytes' ;
    rdfs:comment 'Aggregate file size of all documents in the batch measured in bytes.' ;
    rdfs:domain ind:ProcessingBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededReviewProtocolId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded Review Protocol Id' ;
    rdfs:comment 'Self-referencing FK on review_protocol (superseded_review_protocol_id)' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewProtocol .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'Statistical confidence level target for the review protocol, expressed as a percentage (e.g., 95.00 for 95% confidence).' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deduplicationMethod rdf:type rdf:Property ;
    rdfs:label 'Deduplication Method' ;
    rdfs:comment 'Method used to identify and handle duplicate documents within the review protocol (hash-based, near-duplicate detection, email threading).' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewProtocolDescription rdf:type rdf:Property ;
    rdfs:label 'Review Protocol Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and methodology of the review protocol.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Percent' ;
    rdfs:comment 'Percentage threshold of disagreement or uncertainty that triggers escalation to senior reviewers or subject matter experts.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginOfErrorPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Of Error Percent' ;
    rdfs:comment 'Acceptable margin of error for the review protocol, expressed as a percentage (e.g., 2.50 for ±2.5%).' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nlpProcessingRequired rdf:type rdf:Property ;
    rdfs:label 'Nlp Processing Required' ;
    rdfs:comment 'Indicates whether the protocol requires NLP techniques such as entity extraction, sentiment analysis, or topic modeling.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrProcessingRequired rdf:type rdf:Property ;
    rdfs:label 'Ocr Processing Required' ;
    rdfs:comment 'Indicates whether the protocol requires OCR processing for image-based documents to enable text searchability.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeDesignationRequired rdf:type rdf:Property ;
    rdfs:label 'Privilege Designation Required' ;
    rdfs:comment 'Indicates whether the review protocol mandates explicit privilege designation (attorney-client privilege, work product) for documents.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolCode rdf:type rdf:Property ;
    rdfs:label 'Protocol Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the review protocol for reference in legal systems and workflows.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolName rdf:type rdf:Property ;
    rdfs:label 'Protocol Name' ;
    rdfs:comment 'Human-readable name or title of the review protocol used to identify it in business operations.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'Classification of the review protocol methodology. TAR = Technology Assisted Review, CAL = Continuous Active Learning.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlRatePercent rdf:type rdf:Property ;
    rdfs:label 'Quality Control Rate Percent' ;
    rdfs:comment 'Percentage of reviewed documents subject to secondary quality control review to ensure consistency and accuracy.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewObjective rdf:type rdf:Property ;
    rdfs:label 'Review Objective' ;
    rdfs:comment 'Primary business or legal objective the review protocol is designed to achieve, such as privilege identification, responsiveness determination, or issue coding.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewRoundsPlanned rdf:type rdf:Property ;
    rdfs:label 'Review Rounds Planned' ;
    rdfs:comment 'Number of iterative review rounds planned in the protocol, particularly relevant for TAR and CAL workflows.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:richnessAssumptionPercent rdf:type rdf:Property ;
    rdfs:label 'Richness Assumption Percent' ;
    rdfs:comment 'Estimated prevalence of responsive or relevant documents in the collection, expressed as a percentage, used for sample size calculation.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of documents included in the sample set for training, validation, or quality control purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Statistical or judgmental sampling approach used within the review protocol for quality control or training set selection.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewProtocolStatus rdf:type rdf:Property ;
    rdfs:label 'Review Protocol Status' ;
    rdfs:comment 'Current lifecycle status of the review protocol indicating its operational state.' ;
    rdfs:domain ind:ReviewProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each timekeeper rate record in the master rate card. Primary key for the timekeeper_rate data product.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Id' ;
    rdfs:comment 'Reference to the parent rate schedule or rate card under which this individual timekeeper rate is governed. Enables grouping of rates into named schedules (e.g., Standard 2024, Client ABC Negotiated).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateSchedule .

ind:supersededByTimekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Timekeeper Rate Id' ;
    rdfs:comment 'Reference to the newer timekeeper_rate record that replaced this one when a rate was updated or renegotiated. Enables full rate history chain traversal for audit and billing dispute resolution.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:afaArrangementCode rdf:type rdf:Property ;
    rdfs:label 'Afa Arrangement Code' ;
    rdfs:comment 'Reference code linking this rate to a specific Alternative Fee Arrangement (AFA) structure such as a fixed fee, capped fee, success fee, or retainer. Populated when rate_type is afa or flat_fee.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingIncrementMins rdf:type rdf:Property ;
    rdfs:label 'Billing Increment Mins' ;
    rdfs:comment 'Minimum time increment in minutes used for rounding time entries billed at this rate (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Governs WIP calculation granularity.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendedRatePoolCode rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Pool Code' ;
    rdfs:comment 'Identifier for the blended rate pool to which this timekeeper rate contributes. Applicable when rate_type is blended; allows multiple timekeepers at different levels to be billed at a single agreed blended rate.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAgreed rdf:type rdf:Property ;
    rdfs:label 'Client Agreed' ;
    rdfs:comment 'Indicates whether the client has formally agreed to or acknowledged this rate (True) or whether it is a firm-proposed rate pending client acceptance (False). Critical for billing disputes and engagement letter compliance.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Client Agreement Date' ;
    rdfs:comment 'Date on which the client formally agreed to or acknowledged this rate, as documented in the engagement letter or rate agreement. Null if client_agreed is False.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this rate becomes effective and may be applied to time entries. Defines the start of the rate validity period for WIP calculation and billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this rate ceases to be effective (inclusive). Null indicates an open-ended rate with no scheduled expiry. Enables rate history tracking and audit compliance.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledesTimekeeperClass rdf:type rdf:Property ;
    rdfs:label 'Ledes Timekeeper Class' ;
    rdfs:comment 'LEDES-standard timekeeper classification code used in electronic billing submissions to corporate clients and insurers (e.g., PT for Partner, AS for Associate, PL for Paralegal). Required for LEDES 1998B and LEDES XML format compliance.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoFlag rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Flag' ;
    rdfs:comment 'Indicates whether this rate record applies to pro bono work (True), where the hourly_rate may be zero or nominal. Used for pro bono hour tracking and ABA 50-hour pro bono reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The unit of measure or billing basis against which the rate is applied. Most commonly per hour for standard timekeeping, but may be per day, per matter, per month, or fixed for AFA structures.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Business classification indicating the commercial basis of the rate: standard firm rate, client-negotiated rate, preferred panel rate, pro bono (zero or reduced), or secondment arrangement.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this rate record within the billing system (e.g., STD-PRTNR-2024, CLI-ABC-ASSOC). Used for LEDES electronic billing submissions and rate reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Rate Discount Pct' ;
    rdfs:comment 'Percentage discount applied from the standard rate to arrive at the negotiated hourly rate for this client or matter. Used for rate realization analysis and profitability reporting (RPE, PPP, PEP KPIs).' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Rate Increase Pct' ;
    rdfs:comment 'Percentage change in the hourly rate compared to the prior rate record for this timekeeper/client/matter combination. Used for rate increase tracking, client notification compliance, and year-over-year rate analytics.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rate Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this rate. Supports annual rate increase cycles and client rate negotiation planning.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle state of the rate record. Rates must be approved before being applied to time entries. Superseded rates are replaced by a newer version; expired rates have passed their effective end date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRateCode rdf:type rdf:Property ;
    rdfs:label 'Source System Rate Code' ;
    rdfs:comment 'The native primary key or identifier of this rate record in the originating operational system (Elite 3E or Aderant Expert). Enables traceability and reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperLevel rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Level' ;
    rdfs:comment 'Professional classification or seniority tier of the timekeeper at the time this rate was set. Used for rate benchmarking, PPP/PEP analytics, and UTBMS task-based billing. [ENUM-REF-CANDIDATE: equity_partner|non_equity_partner|of_counsel|senior_associate|associate|paralegal|legal_assistant|staff_attorney|trainee — promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipRateFlag rdf:type rdf:Property ;
    rdfs:label 'Wip Rate Flag' ;
    rdfs:comment 'Indicates whether this rate is the currently active rate used for WIP (Work in Progress) valuation on time entries. Only one rate per timekeeper/client/matter combination should be flagged True at any point in time.' ;
    rdfs:domain ind:TimekeeperRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliedTimekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Applied Timekeeper Rate Id' ;
    rdfs:comment 'FK to billing.timekeeper_rate.timekeeper_rate_id — Every time entry must reference the applicable billing rate at time of capture. This is critical for WIP valuation and ensures rate integrity. Without this FK, there is no way to trace how a time entr' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:primaryTimekeeperRateId rdf:type rdf:Property ;
    rdfs:label 'Primary Timekeeper Rate Id' ;
    rdfs:comment 'Foreign key linking to billing.timekeeper_rate. Business justification: Time entries are billed using specific rate card entries. Currently time_entry has billing_rate (amount) and timekeeper_level (string) but no FK to the authoritative rate record. Adding timekeeper_rat' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimekeeperRate .

ind:billableHours rdf:type rdf:Property ;
    rdfs:label 'Billable Hours' ;
    rdfs:comment 'Hours approved for billing to the client after any reductions, write-downs, or non-billable designations applied during the prebilling review process. May differ from hours_worked due to courtesy reductions, write-downs, or billing guidelines. Used as the basis for WIP value calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billed Timestamp' ;
    rdfs:comment 'Date and time when this time entry was included in a finalized invoice and transitioned to billed status. Used for WIP clearance, revenue recognition timing, and billing cycle reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'Method by which the time entry was captured in the system. Manual entries are typed directly; timer entries are captured via running timer tools; mobile entries are submitted via mobile app; bulk_import entries are loaded from external sources; api entries are submitted programmatically.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the time entry as it progresses through the WIP management and billing workflow. Draft entries are in progress; submitted entries await approval; approved entries are ready for invoicing; billed entries have been included on an invoice; written_off entries have been removed from WIP; rejected entries require correction. [ENUM-REF-CANDIDATE: draft|submitted|approved|billed|written_off|rejected — promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Actual hours spent performing the work as recorded by the timekeeper, prior to any billing adjustments. Typically recorded in tenths of an hour (0.1 increments) per standard legal billing practice. Serves as the raw input before billable hours are determined.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingency rdf:type rdf:Property ;
    rdfs:label 'Is Contingency' ;
    rdfs:comment 'Indicates whether this time entry is recorded under a contingency fee arrangement (True), where billing is conditional on case outcome. Contingency entries accumulate WIP but are not invoiced until the contingency event occurs. Supports AFA tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Ledes Line Item Number' ;
    rdfs:comment 'The line item number assigned to this time entry in the LEDES electronic billing file submitted to the client or client billing system. Required for LEDES 1998B and LEDES XML format compliance and for reconciliation of electronic billing submissions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppProtected rdf:type rdf:Property ;
    rdfs:label 'Lpp Protected' ;
    rdfs:comment 'Indicates whether the narrative or details of this time entry are subject to Legal Professional Privilege (LPP) or attorney-client privilege protections (True). LPP-protected entries require restricted access controls and must be handled in compliance with privilege preservation obligations during eDiscovery and regulatory inquiries.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text description of the legal work performed, as entered by the timekeeper. Appears on client invoices and prebilling reports. Subject to Legal Professional Privilege (LPP) protections. Must be sufficiently detailed to satisfy ABA Model Rule 1.5 billing transparency requirements and client billing guidelines.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noCharge rdf:type rdf:Property ;
    rdfs:label 'No Charge' ;
    rdfs:comment 'Indicates whether this time entry has been designated as no-charge (True), meaning the work was performed but will not be billed to the client. Distinct from non-billable entries; no-charge entries may appear on invoices at zero value for transparency.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End date of the billing period or billing cycle to which this time entry is allocated. Defines the cutoff for WIP inclusion in a billing run and supports period-close reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start date of the billing period or billing cycle to which this time entry is allocated. Used for period-based WIP reporting, billing cutoff management, and monthly/quarterly revenue recognition.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proBonoCategory rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Category' ;
    rdfs:comment 'Classification of the pro bono service type when the time entry is designated as pro bono (e.g., access to justice, nonprofit representation, government service). Null for non-pro-bono entries. Supports ABA pro bono reporting requirements and firm CSR metrics.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the timekeeper formally submitted the time entry for approval. Marks the transition from draft to submitted status. Used for timekeeping compliance monitoring and late submission reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wipAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Amount' ;
    rdfs:comment 'The monetary value of unbilled work represented by this time entry, calculated as billable_hours multiplied by billing_rate. Represents the WIP balance contribution of this entry. Reduced to zero when the entry is billed or written off.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the legal work was actually performed. This is the principal business event date for the time entry, distinct from the date the entry was created or submitted in the system. Critical for WIP aging, billing period cutoffs, and matter chronology.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Down Amount' ;
    rdfs:comment 'The monetary amount by which the original WIP value of this entry was reduced during prebilling review or billing adjustment. Represents the difference between the originally recorded WIP value and the amount actually billed. Used for realization rate analysis and partner performance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeDownReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Down Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any write-down applied to this time entry (e.g., client discount, billing guideline non-compliance, courtesy reduction, duplicate entry). Required for realization analysis and billing adjustment reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipLedgerId rdf:type rdf:Property ;
    rdfs:label 'Wip Ledger Id' ;
    rdfs:comment 'Unique surrogate identifier for each WIP ledger entry. Primary key for the wip_ledger data product in the billing domain.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLedger .

ind:originatingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Originating Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner who originated (brought in) the client relationship for this matter. Used for origination credit allocation in partner compensation models and business development reporting.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Entry Id' ;
    rdfs:comment 'FK to billing.time_entry.time_entry_id — WIP ledger entries accumulate from time entries. This FK enables WIP drill-down to source transactions and supports WIP aging analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:primaryWipMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Wip Matter Id' ;
    rdfs:comment 'Reference to the matter against which this WIP entry is recorded. Matters are the primary billing unit in legal practice management.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:primaryWipTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Wip Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or other fee earner) who generated this WIP entry. Drives timekeeper-level WIP analysis and RPE calculations.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:wipApprovedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Wip Approved By Timekeeper Id' ;
    rdfs:comment 'Reference to the partner or billing manager who approved this WIP entry for billing or authorised a write-off or write-down adjustment. Supports billing governance, approval workflow audit trails, and SOX compliance controls.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorical aging classification of the WIP entry based on wip_age_days. Used in WIP aging reports for financial management, partner reviews, and collections strategy. Buckets align with standard legal industry WIP aging reporting conventions.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Billing Office Code' ;
    rdfs:comment 'Reference to the firm office responsible for billing this WIP entry. Used for office-level revenue attribution, PPP/PEP calculations by office, and financial reporting segmentation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'The standard billing rate per hour applied to this WIP entry, expressed in the matter currency. Reflects the timekeepers rate for the applicable billing period and client rate agreement. Confidential as it reflects negotiated client pricing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Id' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — WIP ledger entries also accumulate from disbursements. This link enables complete WIP composition analysis showing both time and expense components.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert the WIP entry amount from the matter currency to the firms functional reporting currency at the time of entry. Used for consolidated financial reporting and multi-currency WIP analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingencyAccrual rdf:type rdf:Property ;
    rdfs:label 'Is Contingency Accrual' ;
    rdfs:comment 'Indicates whether this WIP entry represents an accrued contingency fee amount (True) that is not yet realised pending case outcome. Contingency WIP is tracked separately for financial reporting and is only recognised as revenue upon successful resolution.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodId rdf:type rdf:Property ;
    rdfs:label 'Period Id' ;
    rdfs:comment 'Reference to the billing period (month, quarter, or custom cycle) in which this WIP entry was accumulated. Used for period-over-period WIP aging and financial close reporting.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Amount' ;
    rdfs:comment 'The WIP value calculated at the timekeepers standard rack rate (hours_worked multiplied by standard_rate). Used to measure the variance between standard and billed value, supporting write-up/write-down analysis and profitability reporting.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipAccumulatesDisbursement rdf:type rdf:Property ;
    rdfs:label 'Wip Accumulates Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — WIP ledger entries also accumulate from disbursements. This FK enables complete WIP composition analysis.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipAgeDays rdf:type rdf:Property ;
    rdfs:label 'Wip Age Days' ;
    rdfs:comment 'Number of calendar days elapsed since the work_date of this WIP entry. Used to populate WIP aging buckets (0-30, 31-60, 61-90, 90+ days) for financial reporting, collections prioritisation, and partner performance reviews.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipAmountFirmCurrency rdf:type rdf:Property ;
    rdfs:label 'Wip Amount Firm Currency' ;
    rdfs:comment 'The WIP amount converted to the firms functional reporting currency using the exchange_rate. Enables consolidated WIP reporting, PPP, PEP, and RPE calculations across matters billed in multiple currencies.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Wip Entry Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this WIP ledger entry as assigned by the practice management system (e.g., Elite 3E transaction number). Used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipType rdf:type rdf:Property ;
    rdfs:label 'Wip Type' ;
    rdfs:comment 'Classification of the WIP entry by nature of the charge. time represents billable hours; disbursement represents client-chargeable out-of-pocket costs; expense represents firm expenses; fixed_fee represents flat-fee milestone charges; contingency represents contingency-based accruals.' ;
    rdfs:domain ind:WipLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Narrative description of the work performed or disbursement incurred as entered by the timekeeper. Appears on prebill and client invoice. Subject to billing guidelines review and may be edited during the prebilling process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Standardised reason code explaining why the WIP entry was written off (e.g., client dispute, fee cap exceeded, courtesy write-off, uncollectable). Populated when wip_status is written_off. Used in write-off analysis and partner performance reporting. [ENUM-REF-CANDIDATE: client_dispute|fee_cap_exceeded|courtesy|uncollectable|billing_error|matter_closed — promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeUpDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Up Down Amount' ;
    rdfs:comment 'The monetary adjustment applied to the WIP entry representing the difference between the standard amount and the billed amount. Positive values indicate a write-up (billing above standard); negative values indicate a write-down (billing below standard). Critical for realisation rate analysis and partner performance reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prebillId rdf:type rdf:Property ;
    rdfs:label 'Prebill Id' ;
    rdfs:comment 'Unique system-generated identifier for the prebill record. Primary key for the prebill data product in the billing domain.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prebill .

ind:originatingAttorneyTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Originating Attorney Timekeeper Id' ;
    rdfs:comment 'Reference to the originating attorney who brought the client relationship to the firm. Used for origination credit allocation and Revenue Per Equity Partner (RPE) reporting.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:prebillApprovedByAttorneyTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Prebill Approved By Attorney Timekeeper Id' ;
    rdfs:comment 'Reference to the attorney who formally approved this prebill. May differ from the billing attorney if approval was delegated. Required for audit trail and professional responsibility compliance.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:prebillLedesMatterId rdf:type rdf:Property ;
    rdfs:label 'Prebill Ledes Matter Id' ;
    rdfs:comment 'Client-assigned matter identifier formatted per LEDES electronic billing standards. Required for electronic invoice submission to corporate clients and insurance carriers using LEDES-compliant billing systems.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:primaryPrebillMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Prebill Matter Id' ;
    rdfs:comment 'Reference to the matter against which this prebill is generated. Links the prebill to the specific legal matter or case being billed.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:primaryPrebillTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Prebill Timekeeper Id' ;
    rdfs:comment 'Reference to the responsible billing attorney (partner or supervising timekeeper) who owns the prebill review and approval process for this matter.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryPrebillWipLedgerId rdf:type rdf:Property ;
    rdfs:label 'Primary Prebill Wip Ledger Id' ;
    rdfs:comment 'FK to billing.wip_ledger.wip_ledger_id — Prebills are generated from WIP balances. This link enables the prebilling workflow to pull unbilled WIP for attorney review and ensures WIP-to-invoice traceability.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLedger .

ind:sourceWipLedgerId rdf:type rdf:Property ;
    rdfs:label 'Source Wip Ledger Id' ;
    rdfs:comment 'FK to billing.wip_ledger.wip_ledger_id — Prebills are generated from WIP balances. This FK establishes the billing pipeline from accumulated WIP to draft invoice. Critical for WIP-to-bill reconciliation.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLedger .

ind:billingGuidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Version' ;
    rdfs:comment 'Version identifier of the client billing guidelines applied during prebill review and compliance checking. Corporate clients and insurers issue versioned billing guidelines that restrict rates, timekeepers, task codes, and narrative formats.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Adjustment Amount' ;
    rdfs:comment 'Net adjustment applied to disbursements on this prebill. Positive values indicate write-up; negative values indicate write-down or non-billable disbursement exclusions.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWritedownAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Writedown Amount' ;
    rdfs:comment 'Negative adjustment applied to WIP fees to reduce the billed amount below the standard rate value. Reflects billing guideline compliance, client relationship management, or billing attorney discretion. Stored as a positive number representing the reduction.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWriteupAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Writeup Amount' ;
    rdfs:comment 'Positive adjustment applied to WIP fees to increase the billed amount above the standard rate value. Reflects premium billing for exceptional work, complexity, or successful outcomes. A zero value indicates no write-up was applied.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatedDate rdf:type rdf:Property ;
    rdfs:label 'Generated Date' ;
    rdfs:comment 'Calendar date on which the prebill draft was generated from the WIP ledger. Represents the principal business event timestamp for the prebill lifecycle.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guidelineViolationCount rdf:type rdf:Property ;
    rdfs:label 'Guideline Violation Count' ;
    rdfs:comment 'Number of individual billing guideline violations detected on this prebill during automated compliance checking. A count of zero indicates full compliance. Used to prioritize prebill review effort.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeEdited rdf:type rdf:Property ;
    rdfs:label 'Narrative Edited' ;
    rdfs:comment 'Indicates whether any time entry or disbursement narrative was edited during the prebill review process. True = narratives were modified; False = original narratives retained. Supports billing quality audit and Legal Professional Privilege (LPP) review.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onAccountCreditApplied rdf:type rdf:Property ;
    rdfs:label 'On Account Credit Applied' ;
    rdfs:comment 'Amount of retainer or on-account funds applied against this prebill to reduce the net amount due. Relevant for matters operating under a retainer or advance payment arrangement. Zero if no on-account funds are applied.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last date of the billing period covered by this prebill. Defines the inclusive end of the Work in Progress (WIP) window extracted for review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First date of the billing period covered by this prebill. Defines the inclusive start of the Work in Progress (WIP) window extracted for review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prebillNumber rdf:type rdf:Property ;
    rdfs:label 'Prebill Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the prebill draft. Used by billing staff and attorneys to reference the prebill during review and approval workflows. Format: PB-YYYY-NNNNNN.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prebillStatus rdf:type rdf:Property ;
    rdfs:label 'Prebill Status' ;
    rdfs:comment 'Current workflow state of the prebill in the billing quality control process. Drives routing logic: draft (initial WIP extraction), under_review (sent to billing attorney), approved (ready for invoice generation), rejected (returned for correction), on_hold (pending client instruction), cancelled (abandoned). [ENUM-REF-CANDIDATE: draft|under_review|approved|rejected|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Balance Amount' ;
    rdfs:comment 'Outstanding accounts receivable balance from prior invoices for this matter as of the prebill generation date. Displayed on the prebill for attorney awareness and collections follow-up context.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Disbursements Amount' ;
    rdfs:comment 'Net disbursement amount proposed for invoicing after applying disbursement adjustments. Represents the billable expense total to be carried forward to the final invoice.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Fees Amount' ;
    rdfs:comment 'Net fee amount proposed for invoicing after applying write-up and write-down adjustments to WIP fees. Equals wip_fees_amount plus fee_writeup_amount minus fee_writedown_amount.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Total Amount' ;
    rdfs:comment 'Total proposed invoice value combining adjusted fees and adjusted disbursements. This is the gross amount that will appear on the final invoice if the prebill is approved without further changes.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sentForReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent For Review Timestamp' ;
    rdfs:comment 'Timestamp when the prebill was dispatched to the billing attorney for review. Marks the transition from draft to under_review status. Used to measure prebill review cycle time.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalHoursBilled rdf:type rdf:Property ;
    rdfs:label 'Total Hours Billed' ;
    rdfs:comment 'Aggregate billable hours included in this prebill across all timekeepers and time entries within the billing period. Applicable for hourly and blended-rate fee arrangements.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Disbursements Amount' ;
    rdfs:comment 'Total gross value of unbilled disbursement and expense entries extracted for this prebill before any adjustments. Includes hard costs (court fees, filing fees, expert witness fees) and soft costs (photocopying, postage).' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Fees Amount' ;
    rdfs:comment 'Total gross value of unbilled fee time entries (Work in Progress) extracted for this prebill before any adjustments. Represents the raw billable fees from timekeeper entries within the billing period.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Total Amount' ;
    rdfs:comment 'Combined gross value of all WIP fees and disbursements extracted for this prebill prior to any write-up, write-down, or adjustment. Equals wip_fees_amount plus wip_disbursements_amount.' ;
    rdfs:domain ind:Prebill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingOfficeId rdf:type rdf:Property ;
    rdfs:label 'Billing Office Id' ;
    rdfs:comment 'Foreign key to billing.billing_office.billing_office_id' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingOffice .

ind:originatingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Id' ;
    rdfs:comment 'For credit notes and adjustment invoices, the invoice_id of the original invoice being credited, reversed, or adjusted. Null for standard invoices. Enables full credit note lineage tracing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryInvoicePrebillId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Prebill Id' ;
    rdfs:comment 'FK to billing.prebill.prebill_id — Invoices are generated from approved prebills. This link closes the prebill-to-invoice lifecycle and enables tracking of which prebills have been finalized.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prebill .

ind:sourcePrebillId rdf:type rdf:Property ;
    rdfs:label 'Source Prebill Id' ;
    rdfs:comment 'FK to billing.prebill.prebill_id — Invoices are generated from approved prebills. This FK completes the billing pipeline (WIP→prebill→invoice) and enables prebill-to-invoice reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prebill .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Cumulative amount received against this invoice to date. Used to calculate the outstanding balance and determine partially_paid vs paid status.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Application Status' ;
    rdfs:comment 'Tracks whether a credit note has been applied against outstanding invoices. Pending means unapplied; applied means fully offset; partially_applied means partially offset; voided means the credit was cancelled. Populated only for credit notes.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReason rdf:type rdf:Property ;
    rdfs:label 'Credit Reason' ;
    rdfs:comment 'Narrative explanation for the issuance of a credit note, including the business justification (e.g., billing error, fee reduction, client dispute resolution, write-off). Populated only when invoice_type = credit_note.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursements Amount' ;
    rdfs:comment 'Total of all client disbursements (hard costs and soft costs) billed on this invoice, including court filing fees, expert witness fees, travel, and photocopying charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this invoice, including courtesy discounts, volume discounts, and write-downs negotiated under AFA or client billing guidelines. Reduces the gross fees amount.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Client-provided reason for disputing the invoice (e.g., rate discrepancy, unapproved timekeeper, excessive hours, duplicate charge). Populated when invoice_status = disputed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed invoice was resolved, either through client agreement, write-down, or credit note issuance. Used to measure dispute cycle time and collections effectiveness.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebillingPortal rdf:type rdf:Property ;
    rdfs:label 'Ebilling Portal' ;
    rdfs:comment 'Name or identifier of the clients e-billing portal to which the LEDES invoice was submitted (e.g., TyMetrix 360, Legal Tracker, BillingPoint, Passport). Null if not submitted electronically.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebillingRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Ebilling Rejection Reason' ;
    rdfs:comment 'Reason code or narrative returned by the clients e-billing portal when an invoice submission is rejected (e.g., invalid UTBMS task code, rate not approved, timekeeper not enrolled). Populated only when ebilling_submission_status = rejected.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebillingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ebilling Submission Date' ;
    rdfs:comment 'Date the LEDES-formatted invoice was submitted to the clients e-billing portal. Used to track submission timeliness and SLA compliance with client billing guidelines.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebillingSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Ebilling Submission Status' ;
    rdfs:comment 'Current status of the LEDES e-billing portal submission. Tracks the full submission lifecycle from initial upload through acceptance or rejection by the clients billing system.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feesAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Amount' ;
    rdfs:comment 'Gross total of all professional fees (time charges) billed on this invoice before discounts, taxes, or write-downs. Represents the sum of all timekeeper hours multiplied by applicable rates.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally visible, human-readable invoice reference number assigned by the billing system (e.g., Elite 3E or Aderant Expert). Used on all client-facing documents, LEDES e-billing submissions, and payment remittances.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Drives AR aging, collections workflow, and revenue recognition. Valid states: draft (prebill stage), issued (sent to client), disputed (client raised objection), paid (fully settled), partially_paid (partial remittance received), written_off (uncollectable balance removed), credited (credit note applied). [ENUM-REF-CANDIDATE: draft|issued|disputed|paid|partially_paid|written_off|credited — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document. Standard is a regular bill; credit_note is a negative invoice reversing or adjusting a prior bill; proforma is a preliminary estimate; interim is a progress bill on a long-running matter; final closes out all WIP on a matter.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isElectronicBilling rdf:type rdf:Property ;
    rdfs:label 'Is Electronic Billing' ;
    rdfs:comment 'Indicates whether this invoice is subject to electronic billing via a LEDES-compliant e-billing portal. True = invoice must be submitted electronically; False = paper or email delivery.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Total amount due from the client after applying fees, disbursements, discounts, and taxes. This is the amount the client is expected to remit: (fees_amount + disbursements_amount - discount_amount + tax_amount).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice (net_amount minus amount_paid). Drives AR aging buckets and collections prioritisation. Updated upon each payment application.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this invoice has been resubmitted to the e-billing portal following a rejection. Tracks resubmission history for operational efficiency and client relationship management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'ISO country or state/province code identifying the tax jurisdiction governing the tax calculation on this invoice. Determines applicable VAT, GST, or sales tax rules.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate (as a decimal fraction, e.g., 0.2000 for 20% VAT) used to calculate the tax_amount on this invoice. Varies by jurisdiction and service type.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each invoice line item within the billing domain. Primary key for the invoice_line data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:fromTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'From Time Entry Id' ;
    rdfs:comment 'FK to billing.time_entry.time_entry_id — Invoice lines that represent billed time must trace back to their originating time entry for audit trail, LEDES compliance, and dispute resolution. This is the core traceability link in legal billing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:primaryInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Id' ;
    rdfs:comment 'Reference to the parent invoice header to which this line item belongs. Establishes the header/detail relationship for invoice line aggregation and LEDES electronic billing submissions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'The gross amount billed to the client for this line item after applying the billing rate to the quantity, and before any write-up or write-down adjustments. Expressed in the invoice currency. Core monetary fact for revenue recognition and AR reporting.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingGuidelineExceptionReason rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Exception Reason' ;
    rdfs:comment 'Free-text description of the reason this line item was flagged as non-compliant with client billing guidelines. Populated when billing_guideline_compliant is False. Used by billing coordinators to resolve exceptions before invoice submission.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRejected rdf:type rdf:Property ;
    rdfs:label 'Client Rejected' ;
    rdfs:comment 'Indicates whether this line item was rejected by the client or their legal spend management system after invoice submission. Rejected lines require resolution (write-off, resubmission, or dispute) and are excluded from collected revenue until resolved.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Client Rejection Reason' ;
    rdfs:comment 'The reason provided by the client or their e-billing platform for rejecting this line item. Populated when client_rejected is True. Used to identify systemic billing guideline compliance issues and improve future billing quality.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromDisbursement rdf:type rdf:Property ;
    rdfs:label 'From Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — Invoice lines representing expenses must trace back to the originating disbursement record. Required for LEDES compliance and client billing guideline validation.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledesExportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ledes Export Timestamp' ;
    rdfs:comment 'The date and time at which this line item was last exported in a LEDES electronic billing file for submission to the client or their e-billing platform. Null if the line has not yet been exported. Used to track LEDES submission status and prevent duplicate submissions.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent invoice. Used to maintain the presentation order of line items on the invoice as rendered to the client and in LEDES output files.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the invoice line item indicating whether it represents a time charge, a disbursement/expense, a flat fee component, an Alternative Fee Arrangement (AFA) component, a tax charge, or a credit adjustment. Drives downstream billing logic and LEDES field mapping.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalNarrative rdf:type rdf:Property ;
    rdfs:label 'Original Narrative' ;
    rdfs:comment 'The unedited narrative text from the originating time entry or disbursement record before any prebilling edits were applied. Retained for audit trail purposes and to support billing guideline compliance reviews comparing original versus billed descriptions.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity or unit count for this line item. For time lines this mirrors hours_worked; for disbursement lines it represents the number of units (e.g., pages copied, miles travelled). Used in conjunction with billing_rate to derive the billed amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcesDisbursement rdf:type rdf:Property ;
    rdfs:label 'Sources Disbursement' ;
    rdfs:comment 'FK to billing.disbursement.disbursement_id — Invoice lines that represent billed disbursements must trace back to the originating disbursement record for cost recovery tracking and LEDES compliance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to this line item identifying the applicable tax rate and jurisdiction rule (e.g., VAT20, EXEMPT, ZERO). Drives automated tax calculation in Elite 3E and supports VAT/GST return preparation and audit compliance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment allocation record. Primary key for the payment_allocation data product in the billing domain.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentAllocation .

ind:billingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Billing Timekeeper Id' ;
    rdfs:comment 'Reference to the responsible billing timekeeper (attorney or legal professional) associated with the matter for which this allocation is being applied. Used for revenue attribution and RPE (Revenue Per Equity Partner) reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:retainerId rdf:type rdf:Property ;
    rdfs:label 'Retainer Id' ;
    rdfs:comment 'Reference to the retainer account from which funds were drawn when allocation_type is retainer_drawdown. Tracks the drawdown of pre-paid retainer balances against earned fees.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Retainer .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment being applied to the referenced invoice or invoice line. Core financial field for AR aging, cash application, and revenue recognition. Must be positive and not exceed the payments unapplied balance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountBase rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Base' ;
    rdfs:comment 'The allocated amount expressed in the firms functional (base) currency after applying the exchange rate. Used for consolidated financial reporting, PPP, PEP, and RPE KPI calculations.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible business identifier for this payment allocation record, used in client communications, remittance advice reconciliation, and audit trails. Typically follows firm-defined numbering conventions in Elite 3E or Aderant Expert.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of how the payment is being applied. full covers the entire outstanding balance; partial covers a portion; retainer_drawdown applies funds held in a retainer account; trust_transfer applies funds from an IOLTA trust account; write_off_offset offsets a previously written-off amount; credit_memo applies a credit note against the invoice balance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostDate rdf:type rdf:Property ;
    rdfs:label 'Gl Post Date' ;
    rdfs:comment 'The date on which this allocation was posted to the General Ledger. May differ from allocation_date due to period-end cutoff rules or delayed GL posting. Critical for financial period reconciliation and SOX compliance.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance After' ;
    rdfs:comment 'The remaining outstanding invoice balance immediately after this allocation is applied. Enables real-time AR aging bucket calculation and identifies fully satisfied versus partially paid invoices.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance Before' ;
    rdfs:comment 'The outstanding invoice balance immediately prior to this allocation being applied. Provides a point-in-time snapshot for audit trail purposes and supports AR aging reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutoAllocated rdf:type rdf:Property ;
    rdfs:label 'Is Auto Allocated' ;
    rdfs:comment 'Indicates whether this allocation was applied automatically by the billing system (True) or manually by a billing administrator (False). Supports audit trail requirements and cash application workflow quality monitoring.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTrustCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Trust Compliant' ;
    rdfs:comment 'Indicates whether this allocation has been reviewed and confirmed as compliant with applicable trust accounting rules (True) or flagged for review (False). Required for IOLTA compliance and state bar regulatory reporting.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Period' ;
    rdfs:comment 'The billing period (YYYY-MM) associated with the invoice to which this allocation is applied, formatted per LEDES standards. Supports electronic billing reconciliation with corporate clients and insurance carriers.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Reference to the parent payment record from which funds are being allocated. Links this allocation to the originating payment transaction.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'The reference number or description provided by the client on their remittance advice, used to match the payment to the correct invoice(s). Critical for automated cash application and reconciliation in LEDES-compliant billing workflows.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The business reason for reversing this payment allocation (e.g., returned check, incorrect invoice, client dispute). Populated only when allocation_status is reversed. Supports collections and dispute resolution workflows.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversed Timestamp' ;
    rdfs:comment 'The date and time at which this payment allocation was reversed. Populated only when allocation_status is reversed. Used for AR aging correction and period-end reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native identifier of this payment allocation record in the originating source system (e.g., Elite 3E transaction ID or Aderant Expert allocation key). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'The portion of the payment that remains unallocated after this allocation record is processed. A non-zero value indicates funds on account that require further application to outstanding invoices or return to the client.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which the funds were considered cleared and available, as confirmed by the bank or payment processor. Used for trust accounting reconciliation and IOLTA compliance reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wipClearedAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Cleared Amount' ;
    rdfs:comment 'The amount of WIP (Work in Progress) cleared from the matters WIP ledger as a result of this payment allocation. Relevant for revenue recognition and matter profitability reporting.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arBalanceId rdf:type rdf:Property ;
    rdfs:label 'Ar Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each accounts receivable balance record in the AR aging ledger. Primary key for the ar_balance data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArBalance .

ind:primaryArMatterId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Matter Id' ;
    rdfs:comment 'Reference to the specific legal matter against which the outstanding balance is recorded. Enables matter-level AR aging and WIP reconciliation.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:primaryArTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Timekeeper Id' ;
    rdfs:comment 'Reference to the equity or non-equity partner responsible for the client relationship and accountable for collections on this AR balance. Used in PPP and PEP reporting.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:trackedInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Tracked Invoice Id' ;
    rdfs:comment 'FK to billing.invoice.invoice_id — AR balances are maintained at the invoice level. This FK enables AR aging drill-down to specific invoices and supports collections prioritization.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Foreign key linking to billing.write_off. Business justification: AR balances may be partially or fully written off when deemed uncollectible. Currently ar_balance has write_off_amount, write_off_date, and write_off_approved_by as denormalized attributes, but no FK ' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:arNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to this AR balance record. Used in client statements, collection correspondence, and LEDES electronic billing submissions.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bucket030Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 0 30 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 0 to 30 days from the invoice date. Used in the standard AR aging report for partner financial reviews and PPP/PEP calculations.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucket3160Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 31 60 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 31 to 60 days from the invoice date. Elevated aging bucket that may trigger initial collection outreach per firm collections policy.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucket6190Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket 61 90 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged 61 to 90 days from the invoice date. Triggers escalated collection action and partner notification under standard firm collections protocols.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bucketOver90Amount rdf:type rdf:Property ;
    rdfs:label 'Bucket Over 90 Amount' ;
    rdfs:comment 'Portion of the outstanding balance aged more than 90 days from the invoice date. Highest-risk aging bucket; typically triggers write-off evaluation, external collections referral, or matter suspension.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Client Matter Number' ;
    rdfs:comment 'Combined client-matter reference code (e.g., 12345.001) as used in Elite 3E and on client invoices. Standard identifier for cross-referencing billing records with matter management systems.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionsNotes rdf:type rdf:Property ;
    rdfs:label 'Collections Notes' ;
    rdfs:comment 'Free-text notes recorded by the collections team or responsible partner regarding collection activity, client commitments, payment plans, or dispute context for this AR balance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditTermsDays rdf:type rdf:Property ;
    rdfs:label 'Credit Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is contractually due, as specified in the Letter of Engagement (LOE) or client billing agreement (e.g., 30, 45, 60). Drives due date calculation and overdue determination.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The net outstanding amount currently owed by the client on this AR record after applying all payments, credits, and write-offs to date. The authoritative balance figure for collections management and financial reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of calendar days elapsed since the invoice date. Used as the primary aging metric for AR bucket assignment and collections prioritisation. Recalculated daily during Silver layer processing.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the client has formally disputed this invoice or AR balance. When true, collections activity is paused pending resolution and the record is flagged for billing partner review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestAccrued rdf:type rdf:Property ;
    rdfs:label 'Interest Accrued' ;
    rdfs:comment 'Contractual interest amount accrued on the overdue AR balance where the Letter of Engagement (LOE) provides for late payment interest. Tracked separately from the principal balance for financial reporting.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Flag' ;
    rdfs:comment 'Indicates whether this AR balance is associated with funds held in an IOLTA trust account. When true, payment processing must comply with IOLTA rules and state bar trust accounting regulations.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCollectionContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Collection Contact Date' ;
    rdfs:comment 'Date of the most recent collections outreach activity (call, email, or letter) made to the client regarding this outstanding balance. Supports collections workflow management and SLA compliance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date the most recent client account statement was generated and dispatched for this AR balance. Used to track statement cycle compliance and client communication history.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The gross billed amount on the original invoice before any payments, credits, or write-offs are applied. Denominated in the billing currency. Forms the basis for AR aging and revenue recognition.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Credits Applied' ;
    rdfs:comment 'Cumulative value of credit notes, billing adjustments, and courtesy discounts applied against this AR balance. Distinct from write-offs; represents negotiated or corrective reductions.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsApplied rdf:type rdf:Property ;
    rdfs:label 'Total Payments Applied' ;
    rdfs:comment 'Cumulative amount of all client payments applied against this AR balance record to date. Reconciles original invoice amount to current outstanding balance.' ;
    rdfs:domain ind:ArBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWriteTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Write Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or other fee earner) whose time or expense entry is being written off. Used for individual realization rate analysis and productivity reporting. Null for matter-level or invoice-level write-offs not attributable to a single timekeeper.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reversedWriteOffId rdf:type rdf:Property ;
    rdfs:label 'Reversed Write Off Id' ;
    rdfs:comment 'Reference to the original write-off record that this entry reverses. Populated only when is_reversal is True. Enables audit trail linking between original write-offs and their reversals for GL reconciliation and financial period close.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:writeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Write Invoice Id' ;
    rdfs:comment 'Reference to the invoice from which an AR write-off or billing guideline reduction originates. Null for WIP write-offs that have not yet been billed. Links write-off to the originating billing event for AR aging and collections reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:writtenAgainstInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Written Against Invoice Id' ;
    rdfs:comment 'FK to billing.invoice.invoice_id — AR write-offs reference the specific invoice being written off. Essential for AR reconciliation and realization rate calculation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:clientAgreedRate rdf:type rdf:Property ;
    rdfs:label 'Client Agreed Rate' ;
    rdfs:comment 'The negotiated or agreed billing rate for the timekeeper applicable to this client/matter at the time of the write-off. Enables analysis of rate realization versus standard rates and identification of billing guideline-driven write-offs.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The firms fiscal year and month in which the write-off is recognized for financial reporting purposes, formatted as YYYY-MM. Derived from gl_posting_date but stored explicitly to support period-based aggregation and financial close reporting without date arithmetic.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The write-off amount converted to the firms functional (home) currency using the exchange_rate. Used for consolidated financial reporting, partner compensation calculations (PPP/PEP), and firm-wide realization rate analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting date on which the write-off is posted to the General Ledger. Determines the financial period (month/quarter/year) in which the write-off impacts the firms P&L and balance sheet. May differ from write_off_date due to period-end cut-off rules.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hoursWrittenOff rdf:type rdf:Property ;
    rdfs:label 'Hours Written Off' ;
    rdfs:comment 'The number of billable hours associated with the write-off, applicable when the write-off relates to time entries. Null for expense or disbursement write-offs. Used to calculate effective realization rates and to measure the volume of written-off effort.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this write-off record is a reversal of a previously posted write-off (True) or an original write-off entry (False). Reversals restore WIP or AR balances and must be tracked separately for accurate net write-off reporting and GL reconciliation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'The gross value of the WIP or AR balance before the write-off is applied, expressed in the billing currency. Represents the full amount at standard rates prior to any reduction. Used as the denominator in realization rate calculations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for the write-off (e.g., client billing guideline non-compliance, rate cap exceeded, duplicate entry, uncollectable debt, client relationship courtesy, matter budget overrun). Sourced from Elite 3E or Aderant Expert reason code tables. [ENUM-REF-CANDIDATE: billing_guideline|rate_cap|duplicate_entry|bad_debt|courtesy|budget_overrun|staffing_level|task_not_approved — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative explanation provided by the billing timekeeper or approving partner describing the specific circumstances justifying the write-off. Supplements the structured reason_code with contextual detail for audit and partner review purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSecondaryApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Secondary Approval' ;
    rdfs:comment 'Indicates whether the write-off amount exceeds the firms threshold requiring secondary approval (e.g., managing partner or finance committee sign-off in addition to the billing partner). Supports tiered approval workflow governance and write-off policy compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Secondary Approval Date' ;
    rdfs:comment 'The date on which secondary approval was granted for the write-off. Null when secondary approval is not required or not yet obtained. Supports tiered approval audit trails and governance compliance reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'The native identifier or transaction reference of this write-off record in the originating source system (Elite 3E or Aderant Expert). Enables reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipEntryDate rdf:type rdf:Property ;
    rdfs:label 'Wip Entry Date' ;
    rdfs:comment 'The date on which the original WIP time or expense entry being written off was recorded. Used to calculate WIP aging at the time of write-off and to assess how long unbilled time was carried before being written off. Null for AR (post-billing) write-offs.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffCategory rdf:type rdf:Property ;
    rdfs:label 'Write Off Category' ;
    rdfs:comment 'Distinguishes whether the write-off applies to professional fees (timekeeper charges), disbursements (client-incurred costs), firm expenses, accrued interest on overdue AR, or tax components. Drives GL account mapping and realization rate segmentation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The business event date on which the write-off was formally approved and recorded. This is the principal real-world event date used for financial period close, WIP aging, and realization rate calculations. Distinct from the system audit timestamps.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally-known business identifier for the write-off transaction, typically generated by Elite 3E or Aderant Expert. Used in partner approval workflows, GL postings, and audit trails. Format: WO-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle state of the write-off transaction. Tracks the workflow from initial submission through partner approval, GL posting, and potential reversal. [ENUM-REF-CANDIDATE: pending_approval|approved|rejected|reversed|posted|cancelled — promote to reference product]' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffType rdf:type rdf:Property ;
    rdfs:label 'Write Off Type' ;
    rdfs:comment 'Classification of the write-off by its business nature. WIP write-off reduces unbilled time/expense value; bad debt eliminates uncollectable AR; courtesy discount reflects client relationship adjustments; billing guideline reduction reflects client-mandated rate or task reductions. [ENUM-REF-CANDIDATE: wip_write_off|bad_debt|courtesy_discount|billing_guideline_reduction|fee_waiver|expense_write_off — promote to reference product]' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerLedesClientMatterId rdf:type rdf:Property ;
    rdfs:label 'Retainer Ledes Client Matter Id' ;
    rdfs:comment 'The client-assigned matter identifier formatted per the Legal Electronic Data Exchange Standard (LEDES) specification. Required for electronic billing submissions to corporate clients and insurance carriers that mandate LEDES-format invoices.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:retainerMatterId rdf:type rdf:Property ;
    rdfs:label 'Retainer Matter Id' ;
    rdfs:comment 'Reference to the specific matter associated with this retainer. Null for general retainers that span all matters for a client; populated for matter-specific retainers.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:sarFilingId rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.sar_filing. Business justification: Retainer receipts are screened for AML red flags and may trigger SAR (large cash retainers, third-party funding, high-risk jurisdictions). Real business process: client funds acceptance and AML compli' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:autoApplyToInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply To Invoice Flag' ;
    rdfs:comment 'Indicates whether retainer funds should be automatically applied to reduce the outstanding balance of invoices upon generation, without requiring manual partner approval for each drawdown.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawdownAuthorizationRule rdf:type rdf:Property ;
    rdfs:label 'Drawdown Authorization Rule' ;
    rdfs:comment 'The rule governing when and how funds may be drawn from the retainer balance against earned fees or disbursements. Automatic drawdown applies retainer funds upon invoice generation; manual approval requires explicit partner sign-off; threshold-triggered drawdown applies when WIP reaches a defined level; periodic scheduled drawdown occurs on a fixed calendar basis.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawdownViaPayment rdf:type rdf:Property ;
    rdfs:label 'Drawdown Via Payment' ;
    rdfs:comment 'FK to billing.payment.payment_id — Retainer drawdowns are processed as payment applications. This FK connects retainer balance management to the payment/AR cycle.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evergreenFlag rdf:type rdf:Property ;
    rdfs:label 'Evergreen Flag' ;
    rdfs:comment 'Indicates whether this retainer is structured as an evergreen arrangement, meaning the client is contractually obligated to replenish the balance to the target amount whenever it falls below the replenishment threshold. Drives automated replenishment demand workflows.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing Flag' ;
    rdfs:comment 'Indicates whether the retainer funds held in the associated trust account are subject to interest accrual under IOLTA or client-specific interest arrangements. True if interest is earned and must be reported or remitted.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether the client associated with this retainer has completed Know Your Client (KYC) and Anti-Money Laundering (AML) verification checks prior to the retainer being activated. Mandatory for regulatory compliance before funds are accepted.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDrawdownDate rdf:type rdf:Property ;
    rdfs:label 'Last Drawdown Date' ;
    rdfs:comment 'The date on which the most recent drawdown was applied against this retainer. Used for activity monitoring, dormancy detection, and collections follow-up.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'The date on which the most recent replenishment payment was received and applied to this retainer balance. Used for cash flow monitoring and client payment behaviour analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundableFlag rdf:type rdf:Property ;
    rdfs:label 'Refundable Flag' ;
    rdfs:comment 'Indicates whether any unused retainer balance is refundable to the client upon matter closure or retainer termination. Governs the treatment of residual balances in the billing close-out process.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentDemandDate rdf:type rdf:Property ;
    rdfs:label 'Replenishment Demand Date' ;
    rdfs:comment 'The date on which the most recent replenishment demand was issued to the client. Used to track outstanding replenishment requests and calculate days outstanding for collections follow-up.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Replenishment Due Date' ;
    rdfs:comment 'The contractual due date by which the client must remit the replenishment amount following a demand. Drives collections escalation workflows when payment is not received by this date.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Target Amount' ;
    rdfs:comment 'The amount to which the retainer balance should be restored upon replenishment. May equal the original_amount or a separately negotiated top-up level. Used to calculate the replenishment demand sent to the client.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold' ;
    rdfs:comment 'The minimum balance level at which a replenishment request is automatically triggered and sent to the client. When current_balance falls at or below this threshold, the firm initiates a top-up demand. Critical for evergreen retainer management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerNumber rdf:type rdf:Property ;
    rdfs:label 'Retainer Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the retainer arrangement. Used in client correspondence, billing statements, and engagement letters. Format: RET-YYYY-NNNNNN.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerStatus rdf:type rdf:Property ;
    rdfs:label 'Retainer Status' ;
    rdfs:comment 'Current lifecycle state of the retainer arrangement. Active indicates funds are available for drawdown; exhausted indicates the balance has been fully applied; replenishment_pending indicates a top-up request has been issued to the client; closed indicates the arrangement has been formally terminated.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerType rdf:type rdf:Property ;
    rdfs:label 'Retainer Type' ;
    rdfs:comment 'Classification of the retainer arrangement by its commercial structure. General retainers cover all matters for a client; matter-specific retainers are scoped to a single matter; evergreen retainers auto-replenish; security retainers are held as collateral; advance payment retainers are pre-payments for future services.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the fees drawn against this retainer are exempt from applicable taxes (e.g., VAT, GST, sales tax) based on the clients tax status or the nature of the legal services provided.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDrawnToDate rdf:type rdf:Property ;
    rdfs:label 'Total Drawn To Date' ;
    rdfs:comment 'Cumulative monetary amount drawn down from this retainer since its establishment. Represents the sum of all drawdown transactions applied against earned fees and disbursements. Used for retainer utilisation reporting and client billing transparency.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReplenishedToDate rdf:type rdf:Property ;
    rdfs:label 'Total Replenished To Date' ;
    rdfs:comment 'Cumulative monetary amount received from the client as retainer replenishments since the arrangement was established. Tracks all top-up receipts to support reconciliation and client account management.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Under Fee Arrangement' ;
    rdfs:comment 'FK to billing.fee_arrangement.fee_arrangement_id — Retainers are a component of the overall fee arrangement with a client. Linking retainer to fee_arrangement ensures the retainer terms are governed by the broader commercial agreement.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipDrawdownLimit rdf:type rdf:Property ;
    rdfs:label 'Wip Drawdown Limit' ;
    rdfs:comment 'The maximum Work in Progress (WIP) amount that may accumulate before a mandatory drawdown against the retainer is triggered. Prevents unbilled WIP from exceeding the retainer balance and ensures timely billing.' ;
    rdfs:domain ind:Retainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionActionId rdf:type rdf:Property ;
    rdfs:label 'Collection Action Id' ;
    rdfs:comment 'Unique surrogate identifier for each collections activity record within the AR recovery workflow. Primary key for the collection_action data product.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionArBalanceId rdf:type rdf:Property ;
    rdfs:label 'Collection Ar Balance Id' ;
    rdfs:comment 'Foreign key linking to billing.ar_balance. Business justification: Collection actions target specific AR balance records to recover outstanding amounts. Currently collection_action has ar_balance_at_action (amount snapshot) and links to invoice, but no direct FK to t' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArBalance .

ind:payingOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Paying Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Collection escalation often targets parent organisations when client_profile is a subsidiary. Tracking the ultimate paying organisation (distinct from client_profiles organisation) enables corporate-' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryArBalanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Balance Id' ;
    rdfs:comment 'FK to billing.ar_balance.ar_balance_id — Collection actions are taken against outstanding AR balances. This link enables the collections workflow to track which balances have been actioned and their outcomes.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArBalance .

ind:primaryCollectionsCounselTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Collections Counsel Timekeeper Id' ;
    rdfs:comment 'Reference to the external collections counsel or law firm engaged to pursue recovery when the matter has been escalated beyond internal collections efforts.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:targetedArBalanceId rdf:type rdf:Property ;
    rdfs:label 'Targeted Ar Balance Id' ;
    rdfs:comment 'FK to billing.ar_balance.ar_balance_id — Collection actions are taken against specific AR balances. This FK enables collections workflow tracking and outcome analysis.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArBalance .

ind:tertiaryCollectionResponsiblePartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Collection Responsible Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the billing or originating partner accountable for the matter and client relationship, who may need to approve write-offs or escalations.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'The calendar date on which the collections action was performed or initiated (e.g., date a demand letter was sent, date a payment plan was agreed). This is the principal real-world business event date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNotes rdf:type rdf:Property ;
    rdfs:label 'Action Notes' ;
    rdfs:comment 'Free-text narrative notes recorded by the collections coordinator documenting the details, context, and outcome of this collections action. Supports audit trail and handover continuity.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise date and time at which the collections action was recorded in the system, capturing the exact moment of entry for audit and sequencing purposes.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:afaFlag rdf:type rdf:Property ;
    rdfs:label 'Afa Flag' ;
    rdfs:comment 'Indicates whether the matter subject to this collections action is governed by an alternative fee arrangement (AFA) rather than standard hourly billing. Affects collections strategy and write-off treatment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amountRecovered rdf:type rdf:Property ;
    rdfs:label 'Amount Recovered' ;
    rdfs:comment 'The monetary amount actually recovered as a direct result of this collections action (e.g., payment received following a demand letter). Zero if no payment was collected.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientContactName rdf:type rdf:Property ;
    rdfs:label 'Client Contact Name' ;
    rdfs:comment 'Name of the specific individual at the client organisation contacted during this collections action (e.g., accounts payable manager, CFO). Supports relationship-aware collections management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientResponse rdf:type rdf:Property ;
    rdfs:label 'Client Response' ;
    rdfs:comment 'The clients response or reaction to this collections action. Captures the outcome of client engagement to inform next-step workflow decisions. [ENUM-REF-CANDIDATE: no_response|payment_promised|disputed|partial_payment_offered|payment_plan_requested|paid_in_full|referred_to_counsel|acknowledged|uncontactable — promote to reference product]' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'The communication channel used to deliver or execute this collections action (e.g., email, phone call, formal letter, in-person meeting, client portal message).' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date by which the collections coordinator must take the next action or review the client response. Drives the collections workflow queue and SLA monitoring.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionType rdf:type rdf:Property ;
    rdfs:label 'Next Action Type' ;
    rdfs:comment 'The planned or recommended next collections action to be taken if this action does not result in full resolution. Drives the collections workflow queue and coordinator task assignment.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether a formal payment plan or instalment arrangement has been agreed with the client as part of this collections action. True if a payment plan is in place.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Frequency' ;
    rdfs:comment 'The agreed frequency of instalment payments under a payment plan arrangement (e.g., monthly, weekly). Populated only when payment_plan_flag is True.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanInstalmentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Instalment Amount' ;
    rdfs:comment 'The agreed periodic instalment amount under a payment plan arrangement. Populated only when payment_plan_flag is True. Used to track expected cash flow from structured repayment agreements.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Approval Flag' ;
    rdfs:comment 'Indicates whether the write-off associated with this collections action has received the required partner or management approval. True if formally approved.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Guideline Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer billing_guideline record that replaces this one when guideline_status is superseded. Enables version chain traceability for audit and historical billing compliance review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:appliesToExpenses rdf:type rdf:Property ;
    rdfs:label 'Applies To Expenses' ;
    rdfs:comment 'Indicates whether this billing guideline applies to expense/disbursement entries in addition to or instead of time entries. When True, expense line items are subject to the same rule enforcement during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToTimeEntries rdf:type rdf:Property ;
    rdfs:label 'Applies To Time Entries' ;
    rdfs:comment 'Indicates whether this billing guideline applies to time entries. When True, time entry records are subject to the rule enforcement during prebilling review and LEDES submission validation.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetCapAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Cap Amount' ;
    rdfs:comment 'Total matter-level or phase-level budget ceiling imposed by the client under this guideline. When WIP (Work in Progress) approaches or exceeds this cap, alerts are triggered for partner review before further billing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'The system action triggered when a non-compliant entry is detected during prebilling review or LEDES submission validation. hard_block prevents invoice issuance; soft_warning alerts the billing team; write_off automatically reduces the entry; require_approval routes to partner; flag_for_review marks for manual review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text field capturing any agreed exceptions or carve-outs to this billing guideline, such as approved deviations negotiated with the client or specific matter circumstances where the rule does not apply.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Limit Amount' ;
    rdfs:comment 'Maximum allowable disbursement or expense amount per transaction or per category as defined by this guideline. Populated when rule_type is expense_limit. Used to flag non-compliant expense entries during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guidelineDescription rdf:type rdf:Property ;
    rdfs:label 'Guideline Description' ;
    rdfs:comment 'Full narrative description of the billing rule, including any conditions, exceptions, or qualifications. Provides the complete business context for the guideline as communicated by the client or as agreed in the engagement letter.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineSource rdf:type rdf:Property ;
    rdfs:label 'Guideline Source' ;
    rdfs:comment 'Identifies the originating document or instrument from which this billing guideline derives its authority. Values: ocg (client-issued Outside Counsel Guidelines), engagement_letter (Letter of Engagement / LOE), standing_instruction (ongoing client instruction), matter_specific_agreement (matter-level side agreement), court_order (court-mandated billing restriction).' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineStatus rdf:type rdf:Property ;
    rdfs:label 'Guideline Status' ;
    rdfs:comment 'Current lifecycle state of the billing guideline. Active guidelines are enforced during prebilling review. Superseded guidelines are retained for historical audit. Pending_approval guidelines are awaiting client or partner sign-off before enforcement.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSubmissionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Invoice Submission Deadline Days' ;
    rdfs:comment 'Maximum number of days after the billing period end date within which the firm must submit an invoice to the client. Late submissions beyond this threshold may be subject to write-off or rejection per the OCG.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceSubmissionFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Submission Frequency' ;
    rdfs:comment 'The required frequency at which invoices must be submitted to the client under this guideline. Governs billing cycle compliance and WIP (Work in Progress) management cadence.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesBillingFormat rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Format' ;
    rdfs:comment 'The required LEDES electronic billing format version mandated by the client for invoice submission under this guideline. Governs the file format used when submitting invoices electronically to the client or their e-billing platform.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTimeIncrementMins rdf:type rdf:Property ;
    rdfs:label 'Minimum Time Increment Mins' ;
    rdfs:comment 'The minimum billable time increment in minutes permitted under this guideline (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Time entries rounded to increments larger than this value may be flagged as non-compliant.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeMinLength rdf:type rdf:Property ;
    rdfs:label 'Narrative Min Length' ;
    rdfs:comment 'Minimum number of characters required in a time entry or expense narrative to satisfy the clients narrative requirement under this guideline. Entries with narratives shorter than this threshold are flagged during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newTimekeeperRateFreeze rdf:type rdf:Property ;
    rdfs:label 'New Timekeeper Rate Freeze' ;
    rdfs:comment 'Indicates whether the client has imposed a rate freeze on newly introduced timekeepers, requiring them to bill at the same rate as the timekeeper they replace or at a pre-agreed rate. Common OCG provision to control staffing cost escalation.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocgSectionReference rdf:type rdf:Property ;
    rdfs:label 'Ocg Section Reference' ;
    rdfs:comment 'Specific section, clause, or paragraph number within the OCG document that contains the rule captured by this guideline record. Supports precise audit trail and dispute resolution when a billing entry is challenged.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the rate_cap_amount (e.g., USD, GBP, EUR). Required when rate_cap_amount is populated to ensure multi-currency billing compliance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateIncreaseNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Rate Increase Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice the firm must provide to the client before implementing a rate increase under this guideline. Enforces the clients OCG requirement for rate change notification.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timekeeperApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Approval Required' ;
    rdfs:comment 'Indicates whether timekeepers must be pre-approved by the client before their time can be billed under this guideline. When True, any time entry from a non-approved timekeeper is flagged as non-compliant during prebilling review.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wipAgingLimitDays rdf:type rdf:Property ;
    rdfs:label 'Wip Aging Limit Days' ;
    rdfs:comment 'Maximum number of days that unbilled WIP (Work in Progress) may remain outstanding before it must be billed or written off per the clients guideline. Supports WIP management and collections compliance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDisputeId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dispute Id' ;
    rdfs:comment 'Unique system-generated identifier for each invoice dispute record. Primary key for the invoice_dispute data product within the billing domain.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditNoteId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_note. Business justification: Invoice disputes often result in credit notes being issued to adjust the disputed amount. Currently invoice_dispute has credit_note_number (string) but no FK to the credit_note record. Adding credit_n' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditNote .

ind:disputedTimeEntryId rdf:type rdf:Property ;
    rdfs:label 'Disputed Time Entry Id' ;
    rdfs:comment 'Reference to the specific time entry record being disputed, where the dispute is at the line-item level. Null when the dispute applies to multiple entries or the full invoice. Enables granular WIP (Work in Progress) and realization analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:primaryInvoiceDisputedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Disputed Timekeeper Id' ;
    rdfs:comment 'Reference to the specific timekeeper (attorney, paralegal, or other fee earner) whose time entries are the subject of the dispute, where the dispute is timekeeper-specific. Null when the dispute applies to the invoice as a whole.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Invoice Id' ;
    rdfs:comment 'FK to billing.invoice.invoice_id — Disputes are raised against specific invoices. This FK enables dispute tracking, resolution workflow, and realization impact analysis.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:tertiaryInvoiceResponsiblePartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Invoice Responsible Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the equity or non-equity partner responsible for the matter on which the disputed invoice was raised. Supports PPP (Profit Per Partner) and PEP (Profit Per Equity Partner) impact analysis at the partner level.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreedReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Reduction Amount' ;
    rdfs:comment 'The monetary amount agreed between the firm and the client as the final reduction to the invoice following dispute resolution. May be less than, equal to, or zero relative to the disputed amount. Feeds write-off and realization rate calculations.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingGuidelineReference rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Reference' ;
    rdfs:comment 'Reference to the specific client billing guideline clause or section that the client alleges was violated. Supports billing guideline compliance tracking and AFA (Alternative Fee Arrangement) governance.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Client Contact Email' ;
    rdfs:comment 'Email address of the client-side contact managing the dispute. Used for dispute correspondence and resolution workflow notifications. Classified as restricted PII under GDPR and applicable data protection regulations.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToResolve rdf:type rdf:Property ;
    rdfs:label 'Days To Resolve' ;
    rdfs:comment 'Number of calendar days elapsed between the dispute_date and the resolution_date. Null while the dispute remains open. Supports SLA compliance measurement and dispute cycle time benchmarking. Note: this is a stored operational field populated at resolution, not a real-time derived metric.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The calendar date on which the client formally raised the invoice dispute. Serves as the principal business event date for aging calculations, SLA tracking, and realization rate analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the dispute at the time of creation. Used in client correspondence, billing guideline audit trails, and LEDES-compliant dispute tracking. Format: DISP-YYYY-NNNNNN.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized UTBMS-aligned code categorizing the primary reason the client raised the dispute. Drives root-cause analytics and billing guideline compliance reporting. [ENUM-REF-CANDIDATE: billing_guideline_violation|rate_discrepancy|duplicate_entry|unauthorized_timekeeper|narrative_deficiency|block_billing|excessive_time|staffing_objection — promote to reference product]' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the client or billing team elaborating on the specific grounds for the dispute. Supplements the structured reason code with contextual detail for resolution workflow and knowledge management.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current workflow state of the invoice dispute. Drives the dispute resolution lifecycle from initial submission through final resolution or withdrawal. [ENUM-REF-CANDIDATE: open|under_review|pending_client|resolved|withdrawn|escalated — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute by the category of charge being contested: fees, disbursements, rates, specific timekeeper entries, or the entire invoice. Enables segmented dispute analytics by charge type.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The gross monetary amount the client is disputing on the invoice, expressed in the invoice currency. Represents the clients claimed reduction before any negotiation or resolution. Core input to realization rate and write-off analytics.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'The total billed amount on the original invoice at the time the dispute was raised. Provides denominator context for calculating the dispute percentage and realization rate impact.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time at which the dispute was received and logged in the billing system. Used for SLA (Service Level Agreement) response-time measurement and audit trail purposes.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text narrative documenting the rationale, negotiation outcome, and any conditions agreed during dispute resolution. Supports knowledge management, precedent tracking, and future billing guideline refinement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorizes the outcome of the dispute resolution process: whether the firm accepted the full disputed amount, a partial reduction, rejected the dispute, issued a credit note, wrote off the amount, or the client withdrew the dispute.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffApproved rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved' ;
    rdfs:comment 'Indicates whether the agreed reduction amount has been formally approved as a write-off in the firms financial system. True when write-off approval has been granted; False when pending or not applicable. Feeds write-off analytics and PPP/PEP impact reporting.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved Date' ;
    rdfs:comment 'The date on which the write-off of the agreed reduction amount was formally approved by the authorized approver (e.g., managing partner, billing committee). Null if write-off has not been approved. Supports financial period close and SOX controls.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledesSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ledes Submission Id' ;
    rdfs:comment 'Unique system-generated identifier for each LEDES e-billing submission record. Primary key for the ledes_submission data product.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSubmissionLedesSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Ledes Submission Id' ;
    rdfs:comment 'Reference to the original LEDES submission record when this record is a resubmission. Enables full resubmission chain traceability and history tracking. Null for original submissions.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedesSubmission .

ind:acceptedAmount rdf:type rdf:Property ;
    rdfs:label 'Accepted Amount' ;
    rdfs:comment 'Total monetary amount accepted by the client e-billing portal from this submission. For partially accepted submissions, this is less than total_amount. Used for accounts receivable posting and WIP clearance.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptedInvoiceCount rdf:type rdf:Property ;
    rdfs:label 'Accepted Invoice Count' ;
    rdfs:comment 'Number of invoices within this submission that were fully accepted by the client e-billing portal. Used for reconciliation against invoice_count to identify partial acceptance scenarios.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingGuidelineValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Validation Status' ;
    rdfs:comment 'Result of pre-submission validation against the clients outside counsel billing guidelines (OCG). Passed = fully compliant; Failed = violations blocking submission; Warnings = non-blocking guideline issues; Not_validated = validation not performed.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingGuidelineViolationCount rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Violation Count' ;
    rdfs:comment 'Number of billing guideline violations detected during pre-submission validation. A count greater than zero with a passed status indicates warnings were overridden. Used for compliance reporting and client relationship management.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'Number of invoices included in this LEDES submission file. A single LEDES file may bundle multiple invoices for the same client portal. Supports reconciliation between submitted invoice count and portal-acknowledged count.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceNumbers rdf:type rdf:Property ;
    rdfs:label 'Invoice Numbers' ;
    rdfs:comment 'Comma-delimited list of invoice numbers included in this LEDES submission file. Provides a human-readable reference to all invoices bundled in the submission without requiring a child line table for simple lookups.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this submission is a resubmission of a previously rejected or partially accepted LEDES file. True if this is a corrected resubmission; False if this is the original submission attempt.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalCode rdf:type rdf:Property ;
    rdfs:label 'Portal Code' ;
    rdfs:comment 'Reference to the client e-billing portal to which this submission was directed (e.g., TyMetrix 360, Legal Tracker, Passport, BillerXpert). Portal-specific rules govern accepted LEDES versions, UTBMS codes, and billing guideline enforcement.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalName rdf:type rdf:Property ;
    rdfs:label 'Portal Name' ;
    rdfs:comment 'Human-readable name of the client e-billing portal to which this submission was directed (e.g., TyMetrix 360, Legal Tracker, Passport). Retained for reporting and troubleshooting without requiring a portal lookup join.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalResponseCode rdf:type rdf:Property ;
    rdfs:label 'Portal Response Code' ;
    rdfs:comment 'Machine-readable response code returned by the client e-billing portal upon processing the submission (e.g., ACK-200, REJ-401, PARTIAL-206). Portal-specific codes used for automated workflow routing and rejection handling.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Response Timestamp' ;
    rdfs:comment 'Date and time when the client e-billing portal returned a processing response (acceptance, rejection, or partial acceptance) for this submission. Used to measure portal processing SLA compliance.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portalSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Portal Submission Reference' ;
    rdfs:comment 'The unique confirmation or tracking reference number assigned by the client e-billing portal upon receipt of the submission. Used for reconciliation and dispute resolution with the client.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedAmount rdf:type rdf:Property ;
    rdfs:label 'Rejected Amount' ;
    rdfs:comment 'Total monetary amount rejected by the client e-billing portal from this submission. For partially accepted submissions, this is the difference between total_amount and accepted_amount. Drives write-off or resubmission decisions.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedInvoiceCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Invoice Count' ;
    rdfs:comment 'Number of invoices within this submission that were rejected by the client e-billing portal. Used for collections workflow prioritization and billing guideline compliance reporting.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code identifying the primary reason for rejection or partial rejection by the client e-billing portal (e.g., INVALID_UTBMS_CODE, RATE_EXCEEDS_GUIDELINE, MISSING_TIMEKEEPER_ID, DUPLICATE_INVOICE). Drives resubmission workflow and billing guideline compliance remediation. [ENUM-REF-CANDIDATE: INVALID_UTBMS_CODE|RATE_EXCEEDS_GUIDELINE|MISSING_TIMEKEEPER_ID|DUPLICATE_INVOICE|INVALID_MATTER_ID|BILLING_GUIDELINE_VIOLATION|MISSING_NARRATIVE|INVALID_DATE_FORMAT|UNAUTHORIZED_TIMEKEEPER|EXCEEDS_BUDGET — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text description of the rejection or partial rejection reason as returned by the client e-billing portal. Supplements the rejection_reason_code with human-readable detail for billing team remediation.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Resubmission Attempt Number' ;
    rdfs:comment 'Sequential count of submission attempts for the same invoice set to the same portal (1 = original, 2 = first resubmission, 3 = second resubmission, etc.). Used to track persistent rejection patterns and escalation triggers.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this LEDES submission (e.g., SUB-2024-001234). Used for tracking and reconciliation with client e-billing portals and internal billing teams.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDisbursementsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Disbursements Amount' ;
    rdfs:comment 'Aggregate disbursements (expenses) amount across all invoices included in this LEDES submission, expressed in the submission currency. Supports financial reconciliation with portal-acknowledged disbursement totals.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fees Amount' ;
    rdfs:comment 'Aggregate fees amount across all invoices included in this LEDES submission, expressed in the submission currency. Supports financial reconciliation between submitted amounts and portal-acknowledged amounts.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Aggregate tax amount across all invoices included in this LEDES submission. Relevant for VAT/GST-applicable jurisdictions and cross-border billing compliance.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Transmission Method' ;
    rdfs:comment 'Method used to transmit the LEDES file to the client e-billing portal (e.g., API integration, SFTP, email, manual portal upload, EDI). Relevant for troubleshooting transmission failures and portal integration management.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Utbms Validation Status' ;
    rdfs:comment 'Result of pre-submission UTBMS code validation against the clients approved task and activity code set. Passed = all codes valid; Failed = one or more invalid codes blocking submission; Warnings = non-blocking code issues; Not_validated = validation not performed.' ;
    rdfs:domain ind:LedesSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationMethod rdf:type rdf:Property ;
    rdfs:label 'Application Method' ;
    rdfs:comment 'Describes how the credit note value was or will be applied. applied_to_ar — offset against an existing outstanding AR balance on the client account; cash_refund — disbursed as a cash payment back to the client; held_on_account — retained as a credit balance for future invoices; offset_future_invoice — earmarked to reduce a specific forthcoming invoice.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'The date on which the credit note was applied against an outstanding AR balance or processed as a cash refund. Null if the credit note has not yet been applied (status is issued or held). Used for AR ageing and cash flow reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingGuidelineRef rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Ref' ;
    rdfs:comment 'Reference identifier for the client billing guideline or outside counsel guidelines (OCG) provision that triggered or justified this credit note (e.g., a specific guideline clause number). Supports billing guideline compliance tracking and dispute resolution documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for the credit note as printed on the document issued to the client. Follows the firms sequential numbering convention (e.g., CN-2024-000123). Used in client correspondence, remittance matching, and LEDES electronic billing submissions.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Note Status' ;
    rdfs:comment 'Current lifecycle state of the credit note. draft — prepared but not yet issued; issued — sent to client; applied — offset against an outstanding AR balance; refunded — cash refund disbursed to client; held — held on account for future application; voided — cancelled and reversed.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardised classification of the business reason for issuing the credit note. overbilling — fees or disbursements billed in excess of agreed rates; dispute_resolution — credit issued as part of a formal billing dispute settlement; goodwill_adjustment — discretionary reduction to maintain client relationship; fee_cap_correction — invoice exceeded an agreed AFA (Alternative Fee Arrangement) or matter budget cap; billing_error — administrative or data entry error on the original invoice; write_off — uncollectable amount formally written off. [ENUM-REF-CANDIDATE: overbilling|dispute_resolution|goodwill_adjustment|fee_cap_correction|billing_error|write_off — promote to reference product]' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonNarrative rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Narrative' ;
    rdfs:comment 'Free-text description providing the detailed business justification for the credit note, supplementing the structured credit_reason_code. May reference specific time entries, disbursements, or billing guideline violations. Classified confidential as it may contain commercially sensitive negotiation details or LPP (Legal Professional Privilege) adjacent information.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Credit Amount' ;
    rdfs:comment 'The amount of disbursements and client-chargeable expenses being credited on this credit note. Includes hard costs (court filing fees, expert witness fees) and soft costs (photocopying, courier). Expressed in the billing currency.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number or identifier for the formal billing dispute, client complaint, or ADR (Alternative Dispute Resolution) proceeding that gave rise to this credit note. Populated when credit_reason_code is dispute_resolution. Classified confidential due to commercially sensitive negotiation context.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Credit Amount' ;
    rdfs:comment 'The gross amount of professional fees being credited or reversed on this credit note, expressed in the billing currency. Represents the pre-tax fee reduction. Used in realization rate analysis and WIP (Work in Progress) reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Date' ;
    rdfs:comment 'The issuance date of the original invoice being credited. Used to calculate the elapsed time between invoice issuance and credit note issuance for billing dispute analytics and SLA (Service Level Agreement) compliance reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Invoice Number' ;
    rdfs:comment 'The human-readable invoice number of the original invoice being reversed or reduced by this credit note. Stored as a denormalised reference to support client-facing documents and LEDES electronic billing submissions without requiring a join.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'The tax component (e.g., VAT, GST, sales tax) being reversed or adjusted on this credit note. Must be reported separately for tax authority compliance and VAT/GST return reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'ISO country or sub-national jurisdiction code identifying the tax authority under which the VAT, GST, or sales tax credit is calculated and reported. Required for multi-jurisdictional tax compliance and VAT/GST return reconciliation.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePct rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Pct' ;
    rdfs:comment 'The applicable tax rate (as a percentage) used to calculate the tax_credit_amount on this credit note. Stored for audit trail purposes as tax rates may change over time.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total gross value of the credit note inclusive of fees, disbursements, and tax adjustments (fee_credit_amount + disbursement_credit_amount + tax_credit_amount). This is the net amount by which the clients AR balance is reduced or refunded. Core field for AR reconciliation and financial reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedDate rdf:type rdf:Property ;
    rdfs:label 'Voided Date' ;
    rdfs:comment 'The date on which the credit note was voided or cancelled. Populated only when credit_note_status is voided. Required for audit trail and period-end reversal processing.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Approved Flag' ;
    rdfs:comment 'Indicates whether the credit note has been formally approved as a write-off (True) by the authorised partner or finance committee. Relevant when credit_reason_code is write_off. Required for bad debt provisioning, GL (General Ledger) write-off posting, and SOX (Sarbanes-Oxley Act) internal controls.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBillingOfficeId rdf:type rdf:Property ;
    rdfs:label 'Parent Billing Office Id' ;
    rdfs:comment 'Self-referencing FK on billing_office (parent_billing_office_id)' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingOffice .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the billing office.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information such as suite or floor number.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barAssociationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Bar Association Jurisdiction' ;
    rdfs:comment 'Primary bar association jurisdiction governing this office for regulatory compliance.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPaymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Default Payment Terms Days' ;
    rdfs:comment 'Standard number of days for payment terms applied to invoices generated by this office.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmOfficeName rdf:type rdf:Property ;
    rdfs:label 'Firm Office Name' ;
    rdfs:comment 'Full legal name of the billing office.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmOfficeType rdf:type rdf:Property ;
    rdfs:label 'Firm Office Type' ;
    rdfs:comment 'Classification of the billing office based on its operational role within the firm.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicePrefix rdf:type rdf:Property ;
    rdfs:label 'Invoice Prefix' ;
    rdfs:comment 'Prefix code used in invoice numbering for invoices generated by this office.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Enabled' ;
    rdfs:comment 'Indicates whether this office supports LEDES electronic billing format for client invoicing.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method used by this office for recognizing revenue from legal services.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFirmOfficeId rdf:type rdf:Property ;
    rdfs:label 'Service Firm Office Id' ;
    rdfs:comment 'Foreign key to service.firm_office.firm_office_id' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingOfficeStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Office Status' ;
    rdfs:comment 'Current operational status of the billing office in the revenue cycle.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustAccountingEnabled rdf:type rdf:Property ;
    rdfs:label 'Trust Accounting Enabled' ;
    rdfs:comment 'Indicates whether this office maintains client trust accounts and IOLTA compliance.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utbmsCodeSet rdf:type rdf:Property ;
    rdfs:label 'Utbms Code Set' ;
    rdfs:comment 'Version of UTBMS task and activity codes used by this office for matter management and billing.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Threshold Amount' ;
    rdfs:comment 'Monetary threshold for work in progress that triggers prebilling review at this office.' ;
    rdfs:domain ind:BillingOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySupersededByRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rate Schedule Id' ;
    rdfs:comment 'Reference to the rate schedule that supersedes or replaces this schedule. Supports rate schedule succession tracking.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateSchedule .

ind:blendedRateFlag rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Flag' ;
    rdfs:comment 'Indicates whether this schedule uses a blended rate structure where a single rate applies across multiple timekeeper levels.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Description' ;
    rdfs:comment 'Detailed description of the rate schedule including its purpose, applicability, and any special terms or conditions.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Firm Office Location' ;
    rdfs:comment 'Geographic office location to which this rate schedule applies. Supports location-based rate differentiation for multi-office firms.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Rate Amount' ;
    rdfs:comment 'Maximum billable rate amount enforced by this schedule. Used for rate ceiling enforcement in capped fee arrangements.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRateAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Rate Amount' ;
    rdfs:comment 'Minimum billable rate amount enforced by this schedule. Used for rate floor enforcement in alternative fee arrangements.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the rate indicating how the rate is applied in billing calculations.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the rate schedule for system identification and external reference.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business name or title of the rate schedule used for identification and reporting purposes.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule indicating the fee arrangement structure.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule indicating whether it is available for use in billing operations.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkEthicsPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Check Ethics Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the ethics partner or conflicts committee member assigned to provide oversight and final approval on complex or escalated conflict matters.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:checkSupervisingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Check Supervising Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the supervising partner who will oversee the matter if the conflict check is cleared, often required for approval in lateral hire or sensitive matter scenarios.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:checkTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Check Timekeeper Id' ;
    rdfs:comment 'Reference to the individual (typically a partner, business development professional, or lateral hire candidate) who initiated the conflict check request.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:conflictExceptionId rdf:type rdf:Property ;
    rdfs:label 'Conflict Exception Id' ;
    rdfs:comment 'Foreign key linking to conflict.exception. Business justification: Links conflict checks processed under exception frameworks. Some conflict checks may be fast-tracked or have modified screening scope under pre-approved exceptions. This FK enables tracking which chec' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictException .

ind:primaryReviewerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Reviewer Timekeeper Id' ;
    rdfs:comment 'Reference to the primary conflicts analyst or attorney assigned to review and analyze the conflict check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Regulatory changes (new conflict rules) trigger updates to conflict check workflows and screening scope. Regulatory change management includes impact assessment on conflict procedures. Links check to ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:trainingProgrammeId rdf:type rdf:Property ;
    rdfs:label 'Training Programme Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_programme. Business justification: Conflict check process is a mandatory training topic for all fee-earners. Compliance training programmes include conflict identification and clearance procedures. Links check process to training progr' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgramme .

ind:actualTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Hours' ;
    rdfs:comment 'Actual elapsed time in hours from submission to final disposition, used for Service Level Agreement (SLA) compliance monitoring and process improvement.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the conflict check was assigned to the primary reviewer for analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Business-facing unique identifier for the conflict check request, typically displayed to users and referenced in communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Classification of the conflict check based on the triggering event and applicable American Bar Association (ABA) Model Rules of Professional Conduct. ABA Rule 1.7 addresses concurrent conflicts of interest with current clients, Rule 1.9 addresses conflicts with former clients, and Rule 1.10 addresses imputed disqualification within the firm.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current lifecycle status of the conflict check indicating whether the matter or engagement has been cleared to proceed, rejected due to conflicts, or is pending further review.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cleared Timestamp' ;
    rdfs:comment 'Date and time when the conflict check received final clearance approval, allowing the matter or engagement to proceed.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clientWaiverObtained rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Obtained' ;
    rdfs:comment 'Indicates whether the required client waiver has been obtained and documented in accordance with professional conduct rules.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientWaiverRequired rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Required' ;
    rdfs:comment 'Indicates whether informed consent and waiver from affected clients is required to proceed with the engagement despite identified conflicts.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethicsPartnerDisposition rdf:type rdf:Property ;
    rdfs:label 'Ethics Partner Disposition' ;
    rdfs:comment 'Final recommendation or decision rendered by the ethics partner regarding clearance of the conflict check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsPartnerName rdf:type rdf:Property ;
    rdfs:label 'Ethics Partner Name' ;
    rdfs:comment 'Full name of the ethics partner responsible for final review and approval authority.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Description of measures implemented to mitigate identified conflicts, such as ethical walls, client waivers, or engagement scope limitations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReviewerDisposition rdf:type rdf:Property ;
    rdfs:label 'Primary Reviewer Disposition' ;
    rdfs:comment 'Recommendation or decision rendered by the primary reviewer regarding clearance of the conflict check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReviewerName rdf:type rdf:Property ;
    rdfs:label 'Primary Reviewer Name' ;
    rdfs:comment 'Full name of the primary reviewer assigned to conduct the conflict analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time when the conflict check was formally rejected due to unresolvable conflicts or failure to obtain required waivers.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the conflict check requestor for communication and notification purposes.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the conflict check request.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the primary reviewer completed their analysis and rendered a disposition.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes and analysis documented by the conflicts review team during the screening and clearance process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the conflict check was completed within the target Service Level Agreement (SLA) timeframe.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the conflict check should be completed, based on firm Service Level Agreement (SLA) policies and priority level.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisingPartnerDisposition rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Disposition' ;
    rdfs:comment 'Recommendation or decision rendered by the supervising partner regarding acceptance of the engagement subject to conflict clearance.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisingPartnerName rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Name' ;
    rdfs:comment 'Full name of the supervising partner who will manage the engagement if approved.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Detailed description of the business event that initiated the conflict check, such as new matter intake, lateral hire onboarding, merger or acquisition activity, or client relationship change.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Obtained Date' ;
    rdfs:comment 'Date on which the client waiver was formally obtained and documented.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_risk_assessment. Business justification: Conflict party data (jurisdiction, entity type, PEP status) feeds into firm-wide AML risk assessments. AML risk assessment aggregates conflict party risk indicators. Links party to AML risk assessment' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlRiskAssessment .

ind:ccpaSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Subject Flag' ;
    rdfs:comment 'Indicates whether this party is a consumer under CCPA (California resident). True indicates CCPA applies, requiring compliance with consumer rights (right to know, right to delete, right to opt-out of sale). False indicates CCPA does not apply. Used to enforce data governance policies for California-based parties.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSearchIndexedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Search Indexed Flag' ;
    rdfs:comment 'Indicates whether this party record has been indexed in the conflict search engine and is available for conflict checking. True indicates the party is searchable; false indicates indexing is pending or failed. Used to ensure data quality and completeness of the conflict search universe.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataResidencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Residency Jurisdiction' ;
    rdfs:comment 'The jurisdiction in which this partys data must be stored and processed to comply with data protection regulations. For EU/UK natural persons, this must be an EU/UK region per GDPR Article 44-50 (cross-border data transfers). For parties in other jurisdictions, this reflects applicable data localization laws. Critical for multi-jurisdictional firms to ensure compliant data storage and processing.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartyReference rdf:type rdf:Property ;
    rdfs:label 'External Party Reference' ;
    rdfs:comment 'An external reference identifier for this party, such as a client-provided reference number, a court case number, or a third-party system identifier. Used for cross-referencing with external systems and documents. Optional field for additional context.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Subject Flag' ;
    rdfs:comment 'Indicates whether this party is a data subject under GDPR (EU/UK natural person or entity operating in EU/UK). True indicates GDPR applies, requiring compliance with data subject rights (access, rectification, erasure, portability) and cross-border transfer restrictions. False indicates GDPR does not apply. Used to enforce data governance policies and access controls.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type of official identifier associated with this party. Tax_id represents a tax identification number (EIN, SSN, VAT); company_registration represents a corporate registry number; passport represents a passport number; national_id represents a government-issued ID; duns_number represents a Dun & Bradstreet identifier; LEI (Legal Entity Identifier) represents an ISO 17442 identifier for financial entities. Used in conjunction with party_identifier_value for KYC/AML verification.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value corresponding to the party_identifier_type. For example, the EIN number, company registration number, passport number, or LEI code. This field is restricted due to PII sensitivity and is used for definitive party matching and KYC/AML verification. Must be encrypted at rest and subject to access controls per firm data governance policy.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionOfPrimaryOperations rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Primary Operations' ;
    rdfs:comment 'The primary geographic jurisdiction where the party conducts business operations or resides. May differ from jurisdiction of incorporation for multinational entities. Used for conflict analysis when parties operate across multiple jurisdictions and for assessing cross-border data transfer requirements.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant1 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 1' ;
    rdfs:comment 'First alternate name or alias for the party. Used to capture DBA (Doing Business As) names, trade names, former legal names, or common abbreviations. Critical for comprehensive conflict search coverage to ensure all name variations are indexed.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant2 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 2' ;
    rdfs:comment 'Second alternate name or alias for the party. Captures additional name variations such as translated names, historical names, or subsidiary brand names to ensure thorough conflict screening.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameVariant3 rdf:type rdf:Property ;
    rdfs:label 'Name Variant 3' ;
    rdfs:comment 'Third alternate name or alias for the party. Provides additional name variant coverage for complex entities with multiple operating names or jurisdictional variations.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'The version number of this party record, incremented with each modification. Used for optimistic locking and change tracking. Starts at 1 when the record is created.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleClassification rdf:type rdf:Property ;
    rdfs:label 'Role Classification' ;
    rdfs:comment 'The role this party plays in conflict analysis. Client indicates a current or former client of the firm; adverse_party indicates an opposing party in litigation or transaction; related_entity indicates a corporate affiliate, subsidiary, or parent; guarantor indicates a party providing financial backing; beneficial_owner indicates the ultimate controlling individual; witness indicates a party who may provide testimony. This classification drives conflict rule application per ABA Model Rules 1.7, 1.9, and 1.10.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPartyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Party Reference' ;
    rdfs:comment 'The unique identifier for this party in the source system (e.g., the client ID in Elite 3E, the account ID in CRM). Used for cross-system reconciliation and data lineage tracking. Null if the party was created directly in the conflict system.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateBeneficialOwnerName rdf:type rdf:Property ;
    rdfs:label 'Ultimate Beneficial Owner Name' ;
    rdfs:comment 'The name of the ultimate beneficial owner (UBO) — the natural person(s) who ultimately own or control the entity, typically defined as owning 25% or more of the entity or exercising control through other means. Required for KYC/AML compliance and for identifying individual-level conflicts when representing corporate entities. Restricted due to PII sensitivity.' ;
    rdfs:domain ind:ConflictParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchExecutionId rdf:type rdf:Property ;
    rdfs:label 'Search Execution Id' ;
    rdfs:comment 'Primary key for search_execution' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:ethicalWallConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Consideration Flag' ;
    rdfs:comment 'Indicates whether this search execution considered existing ethical walls (information barriers) in the conflict analysis. When true, conflicts may be waivable if an effective ethical wall can be established per ABA Rule 1.10.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exactMatchCount rdf:type rdf:Property ;
    rdfs:label 'Exact Match Count' ;
    rdfs:comment 'The number of hits that were exact string matches (case-insensitive). Subset of total hit_count. Exact matches typically require immediate escalation.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuzzyMatchApplied rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Applied' ;
    rdfs:comment 'Indicates whether fuzzy matching algorithms were applied to capture approximate string matches, accounting for typos, abbreviations, and minor variations.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuzzyMatchCount rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Count' ;
    rdfs:comment 'The number of hits that were fuzzy matches (approximate string similarity). Subset of total hit_count. Requires review to determine relevance.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuzzyMatchThreshold rdf:type rdf:Property ;
    rdfs:label 'Fuzzy Match Threshold' ;
    rdfs:comment 'The similarity threshold percentage (0-100) used for fuzzy matching. Higher values require closer matches. Typically set between 70-90% depending on firm policy.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hitCount rdf:type rdf:Property ;
    rdfs:label 'Hit Count' ;
    rdfs:comment 'The total number of potential conflict matches returned by this search execution. A hit count of zero indicates no conflicts found; non-zero requires human review.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includeFormerNamesFlag rdf:type rdf:Property ;
    rdfs:label 'Include Former Names Flag' ;
    rdfs:comment 'Indicates whether the search included historical names and aliases (e.g., maiden names, previous corporate names, DBA names). Essential for comprehensive conflict detection.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeSubsidiariesFlag rdf:type rdf:Property ;
    rdfs:label 'Include Subsidiaries Flag' ;
    rdfs:comment 'Indicates whether the search included subsidiary and affiliate entities of the searched organization. Critical for corporate family conflict detection.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryFilter rdf:type rdf:Property ;
    rdfs:label 'Industry Filter' ;
    rdfs:comment 'Optional industry sector filter applied to narrow the search scope to specific client industries (e.g., Financial Services, Healthcare, Technology). May contain comma-separated industry codes.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateralHireScreenFlag rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Screen Flag' ;
    rdfs:comment 'Indicates whether this search was executed as part of a lateral hire screening process. Lateral hire searches require broader scope to identify conflicts the incoming attorney may bring from their previous firm.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneticMatchCount rdf:type rdf:Property ;
    rdfs:label 'Phonetic Match Count' ;
    rdfs:comment 'The number of hits that were phonetic matches (sound-alike names). Subset of total hit_count. Requires review to determine if they represent the same entity.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneticVariantApplied rdf:type rdf:Property ;
    rdfs:label 'Phonetic Variant Applied' ;
    rdfs:comment 'Indicates whether phonetic matching algorithms (e.g., Soundex, Metaphone) were applied to capture names that sound similar but are spelled differently.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDepth rdf:type rdf:Property ;
    rdfs:label 'Relationship Depth' ;
    rdfs:comment 'The number of relationship hops traversed during the search. Depth of 1 searches direct relationships; depth of 2+ searches related entities (e.g., subsidiaries, affiliates, beneficial owners). Higher depth increases search comprehensiveness but also processing time.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Search Algorithm Version' ;
    rdfs:comment 'The version identifier of the conflict search algorithm used for this execution. Enables audit trail and reproducibility when algorithms are updated or tuned.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchDurationMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Search Duration Milliseconds' ;
    rdfs:comment 'The elapsed time in milliseconds from search initiation to result return. Used for performance monitoring and system optimization.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Execution Timestamp' ;
    rdfs:comment 'The precise date and time when this search was executed in the conflict system. Critical for audit trail and establishing the temporal context of conflict clearance.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchParentCheck rdf:type rdf:Property ;
    rdfs:label 'Search Parent Check' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Each search execution belongs to exactly one conflict check. This is the header-to-line relationship that enables reconstructing the full search scope of a check.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchResultHash rdf:type rdf:Property ;
    rdfs:label 'Search Result Hash' ;
    rdfs:comment 'Cryptographic hash of the search result set. Enables detection of result changes if the same search is re-executed later, supporting audit and change tracking.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchString rdf:type rdf:Property ;
    rdfs:label 'Search String' ;
    rdfs:comment 'The exact name or entity string submitted for conflict search. This is the raw input text used to query the conflict database for potential matches.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchType rdf:type rdf:Property ;
    rdfs:label 'Search Type' ;
    rdfs:comment 'The category of entity being searched. Determines which conflict rules and matching algorithms are applied.' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toConflictCheck rdf:type rdf:Property ;
    rdfs:label 'To Conflict Check' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Every search execution is spawned by a specific conflict check — this is the core parent-child relationship in the screening workflow. Without this FK, you cannot reconstruct which searches belong to ' ;
    rdfs:domain ind:SearchExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchHitId rdf:type rdf:Property ;
    rdfs:label 'Search Hit Id' ;
    rdfs:comment 'Primary key for search_hit' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dpiaId rdf:type rdf:Property ;
    rdfs:label 'Dpia Id' ;
    rdfs:comment 'Foreign key linking to compliance.dpia. Business justification: Conflict search hits involving special category data (e.g., health information in medical malpractice matters) may trigger DPIA requirements. DPO reviews conflict hits for special category data proces' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dpia .

ind:ethicalWallId rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Id' ;
    rdfs:comment 'Reference to the ethical wall configuration established to address this conflict. Null if no ethical wall is required.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:hitConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Hit Conflict Party Id' ;
    rdfs:comment 'Reference to the party record that matched the search criteria. Links to the intake_party product.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:matchedConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Matched Conflict Party Id' ;
    rdfs:comment 'FK to conflict.party.party_id — Each search hit references the matched party record from the conflict party index. Critical for resolving what entity was matched.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:matchedIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Matched Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Search hits identify conflicts arising from prior representation on specific IP assets (firm prosecuted Patent A for Client X, now adverse party in litigation). Critical for IP conflict analysis and c' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:primarySearchExecutionId rdf:type rdf:Property ;
    rdfs:label 'Primary Search Execution Id' ;
    rdfs:comment 'Reference to the parent conflict search that generated this hit. Links to the conflict_search product.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:primarySearchTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Search Timekeeper Id' ;
    rdfs:comment 'Reference to the attorney who was responsible for the historical matter. Used for personal conflict assessment and ethical wall configuration.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Foreign key linking to conflict.rule. Business justification: Links each conflict hit to the specific rule it potentially violates. search_hit currently has conflict_severity and initial_assessment but no reference to which rule is triggered. This FK enables rul' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:toSearchExecutionId rdf:type rdf:Property ;
    rdfs:label 'To Search Execution Id' ;
    rdfs:comment 'FK to conflict.search_execution.search_execution_id — Each hit is produced by a specific search execution. This is the fundamental lineage link from hit back to the search that produced it.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SearchExecution .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes recorded by the reviewing attorney explaining the rationale for the initial assessment. Critical for audit trail and ethics compliance.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToPartner rdf:type rdf:Property ;
    rdfs:label 'Escalated To Partner' ;
    rdfs:comment 'Indicates whether this conflict hit has been escalated to a partner for senior-level review. Required for high-severity conflicts.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hitMatchedParty rdf:type rdf:Property ;
    rdfs:label 'Hit Matched Party' ;
    rdfs:comment 'FK to conflict.party.party_id — Each search hit identifies a matched party from the party index. This FK enables navigating from a hit to the full party record for review.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Hit Source Record Reference' ;
    rdfs:comment 'The unique identifier of the source record in the originating system. Used for drill-back and data reconciliation.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Hit Source System' ;
    rdfs:comment 'The system or database that provided the data for this conflict hit. Used for data lineage and quality assessment.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialAssessment rdf:type rdf:Property ;
    rdfs:label 'Initial Assessment' ;
    rdfs:comment 'The reviewing attorneys initial assessment of the conflict hit. Drives the clearance workflow and escalation path.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFalsePositive rdf:type rdf:Property ;
    rdfs:label 'Is False Positive' ;
    rdfs:comment 'Indicates whether this conflict hit has been determined to be a false positive (e.g., name collision, unrelated entity). Used for machine learning model training.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lppRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Risk Flag' ;
    rdfs:comment 'Indicates whether this conflict hit presents a risk to Legal Professional Privilege (attorney-client privilege). High-risk hits require senior partner review.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Algorithmic confidence score (0.00 to 100.00) indicating the likelihood that the matched party is the same entity as the search subject. Based on name similarity, identifier matching, and relationship graph analysis.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'The matching technique that surfaced this hit (exact name match, fuzzy name match, identifier match, corporate family relationship, etc.). Used for quality assessment and false-positive filtering. [ENUM-REF-CANDIDATE: exact_name|fuzzy_name|identifier|alias|corporate_family|address|email|phone — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedClientName rdf:type rdf:Property ;
    rdfs:label 'Matched Client Name' ;
    rdfs:comment 'The name of the client on the historical matter where the conflict was found. Critical for assessing current vs. former client conflicts under ABA Rule 1.9.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedPartyName rdf:type rdf:Property ;
    rdfs:label 'Matched Party Name' ;
    rdfs:comment 'The name of the party as recorded in the historical matter or party index. Denormalized for display and review efficiency.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Matter Open Date' ;
    rdfs:comment 'The date the historical matter was opened. Used to determine recency and relevance of the conflict.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Specific role the matched party played in the historical matter (e.g., plaintiff, defendant, guarantor, shareholder). Provides context for conflict assessment.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresWaiver rdf:type rdf:Property ;
    rdfs:label 'Requires Waiver' ;
    rdfs:comment 'Indicates whether this conflict hit requires a formal conflict waiver from the affected client(s) under ABA Rule 1.7. Drives waiver workflow.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current resolution status of the conflict hit within the clearance workflow. Drives matter opening approval.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the conflict hit was resolved (cleared, declined, or waived). Null if still pending.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Attorney Name' ;
    rdfs:comment 'Name of the attorney who was responsible for the historical matter. Denormalized for display and conflict review.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Attorney Name' ;
    rdfs:comment 'Name of the attorney who performed the initial review. Denormalized for display and reporting.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiallyRelatedMatter rdf:type rdf:Property ;
    rdfs:label 'Substantially Related Matter' ;
    rdfs:comment 'Indicates whether the historical matter is substantially related to the proposed new matter under ABA Rule 1.9. Substantially related matters create a presumption of conflict.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverObtained rdf:type rdf:Property ;
    rdfs:label 'Waiver Obtained' ;
    rdfs:comment 'Indicates whether a formal conflict waiver has been obtained from the affected client(s). Required before matter opening can proceed.' ;
    rdfs:domain ind:SearchHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceCreatedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clearance Created By User Timekeeper Id' ;
    rdfs:comment 'The system user ID of the person who created this clearance record, typically the conflicts analyst or intake coordinator who initiated the clearance workflow.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clearanceLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clearance Last Modified By User Timekeeper Id' ;
    rdfs:comment 'The system user ID of the person who last modified this clearance record, typically the authorizing partner, conflicts counsel, or conflicts analyst.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clearanceResponsiblePartyTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clearance Responsible Party Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (partner, associate, or conflicts counsel) responsible for monitoring compliance with clearance conditions and conducting periodic reviews.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clearanceReviewingCounselTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clearance Reviewing Counsel Timekeeper Id' ;
    rdfs:comment 'Reference to the conflicts counsel or ethics officer who conducted the detailed conflict review and prepared the clearance recommendation.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clearanceTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clearance Timekeeper Id' ;
    rdfs:comment 'Reference to the partner or general counsel who authorized the clearance decision. Typically the conflicts partner, managing partner, or practice group leader with authority to approve new matters.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:restrictedIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Restricted Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Clearances impose asset-specific scope restrictions (approved for Trademark B prosecution but not Patent C due to adverse representation). Enables granular conflict management in IP portfolios with pa' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:adversePartyIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Party Identified Flag' ;
    rdfs:comment 'Boolean indicator whether an adverse party (opposing party in litigation or transaction) has been identified that creates a conflict with an existing client. True if adverse party conflict exists; False otherwise.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Number' ;
    rdfs:comment 'Business-facing unique identifier for the clearance decision, typically formatted as CLR-YYYY-NNNNNN. Used in correspondence and audit trails.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientWaiverObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Waiver Obtained Flag' ;
    rdfs:comment 'Boolean indicator whether informed written consent (waiver) has been obtained from all affected clients. True if all required waivers are on file; False if waivers are pending or not obtained.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionDueDate rdf:type rdf:Property ;
    rdfs:label 'Condition Due Date' ;
    rdfs:comment 'The date by which all clearance conditions must be fulfilled before the matter may proceed. Null if no conditions or no specific due date.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionFulfilledDate rdf:type rdf:Property ;
    rdfs:label 'Condition Fulfilled Date' ;
    rdfs:comment 'The date on which all clearance conditions were confirmed as fulfilled and the matter was authorized to proceed. Null if conditions are not yet fulfilled.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Fulfillment Status' ;
    rdfs:comment 'Overall status of compliance with all imposed clearance conditions. Not Applicable: no conditions imposed; Pending: conditions not yet started; In Progress: conditions being implemented; Fulfilled: all conditions satisfied; Overdue: one or more conditions past due date.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsImposedFlag rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed Flag' ;
    rdfs:comment 'Boolean indicator whether the clearance was granted subject to conditions (ethical wall, scope restriction, client notification, periodic review). True if conditions exist; False if unconditional clearance or denial.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Explanation of why the clearance decision was deferred, including what additional information or client waiver is required before a final decision can be made. Empty if clearance was not deferred.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Detailed explanation of why the clearance was denied, including the specific conflict identified, the parties involved, and the ethical rule violated. Empty if clearance was approved. Confidential business information protected by Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forCheck rdf:type rdf:Property ;
    rdfs:label 'For Check' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Each clearance decision concludes exactly one conflict check. This is the terminal state record for the check lifecycle.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imputedConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Imputed Conflict Flag' ;
    rdfs:comment 'Boolean indicator whether the conflict is imputed to the entire firm under ABA Rule 1.10 (conflicts of interest imputed to all lawyers in the firm). True if conflict is firm-wide; False if conflict is limited to specific timekeepers.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateralHireScreeningFlag rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Screening Flag' ;
    rdfs:comment 'Boolean indicator whether this clearance is part of a lateral hire conflict screening process (evaluating conflicts that a new attorney would bring to the firm). True if lateral hire screening; False for standard new matter clearance.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodicReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Periodic Review Required Flag' ;
    rdfs:comment 'Boolean indicator whether the clearance decision requires periodic re-evaluation (e.g., quarterly review of ongoing conflict status). True if periodic review is mandated; False for one-time clearance.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipMappingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Mapping Completed Flag' ;
    rdfs:comment 'Boolean indicator whether comprehensive relationship mapping (identifying all corporate affiliates, subsidiaries, beneficial owners, and related parties) has been completed as part of the clearance process. True if mapping is complete; False if pending.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date the clearance request was formally submitted for review, typically following completion of the conflict search.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Restriction Description' ;
    rdfs:comment 'Detailed description of any scope restrictions imposed as a condition of clearance. Examples: matter limited to specific transaction phase, prohibited from representing client in certain jurisdictions, restricted to advisory role only. Empty if no scope restrictions.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toCheck rdf:type rdf:Property ;
    rdfs:label 'To Check' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Every clearance decision is the terminal outcome of a conflict check. This is the most critical business relationship — clearance gates matter opening and must trace back to the check that produced it' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Document Reference' ;
    rdfs:comment 'Reference identifier or document management system (DMS) path to the signed client waiver or informed consent letter. Typically an iManage or NetDocuments document ID. Empty if no waiver required or not yet obtained.' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverId rdf:type rdf:Property ;
    rdfs:label 'Waiver Id' ;
    rdfs:comment 'Unique identifier for the conflict waiver record. Primary key.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Waiver .

ind:governingClearanceId rdf:type rdf:Property ;
    rdfs:label 'Governing Clearance Id' ;
    rdfs:comment 'FK to conflict.clearance.clearance_id — A waiver is obtained when clearance identifies a waivable conflict. The waiver must reference the clearance record that triggered the need for informed consent.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:regulatoryReturnId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Return Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_return. Business justification: Waivers obtained during the reporting period are counted in regulatory returns (e.g., SRA annual information report). Compliance team extracts waiver counts for regulatory filings. Links waiver to reg' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryReturn .

ind:toClearanceId rdf:type rdf:Property ;
    rdfs:label 'To Clearance Id' ;
    rdfs:comment 'FK to conflict.clearance.clearance_id — A waiver is obtained in response to a conflict identified during clearance. The waiver record must link to the clearance that required it for audit trail completeness.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:waiverApprovingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Waiver Approving Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner or conflicts committee member who approved the waiver request.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:waiverClearanceId rdf:type rdf:Property ;
    rdfs:label 'Waiver Clearance Id' ;
    rdfs:comment 'Reference to the conflict clearance record that identified the conflict requiring this waiver.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:waiverConflictsCounselTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Waiver Conflicts Counsel Timekeeper Id' ;
    rdfs:comment 'Reference to the conflicts counsel or ethics partner who reviewed and approved the waiver.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:waiverLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Waiver Last Modified By User Timekeeper Id' ;
    rdfs:comment 'User ID of the individual who last modified the waiver record.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:waiverSubjectTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Waiver Subject Timekeeper Id' ;
    rdfs:comment 'User ID of the individual who created the waiver record in the conflicts system.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:waiverTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Waiver Timekeeper Id' ;
    rdfs:comment 'Reference to the partner who requested the waiver on behalf of the matter team.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:adversePartyName rdf:type rdf:Property ;
    rdfs:label 'Adverse Party Name' ;
    rdfs:comment 'Name of the adverse party or conflicted party disclosed in the waiver, if applicable.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Chronological record of all actions taken on the waiver record, including creation, approvals, modifications, and revocations.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictNatureDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Nature Description' ;
    rdfs:comment 'Detailed description of the nature of the conflict disclosed to the client, including the parties involved and the relationship creating the conflict.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictType rdf:type rdf:Property ;
    rdfs:label 'Conflict Type' ;
    rdfs:comment 'Classification of the conflict requiring waiver under ABA Model Rules (e.g., current client conflict per Rule 1.7, former client conflict per Rule 1.9). [ENUM-REF-CANDIDATE: current_client|former_client|personal_interest|third_party|positional|issue|transactional|litigation|lateral_hire|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentPath rdf:type rdf:Property ;
    rdfs:label 'Consent Document Path' ;
    rdfs:comment 'Full path or URL to the consent document in the DMS for retrieval and audit purposes.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormType rdf:type rdf:Property ;
    rdfs:label 'Consent Form Type' ;
    rdfs:comment 'The form in which informed consent was obtained from the client.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isScopeLimited rdf:type rdf:Property ;
    rdfs:label 'Is Scope Limited' ;
    rdfs:comment 'Indicates whether the waiver contains scope limitations or conditions.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the waiver was revoked by the client or the firm, if applicable.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation for why the waiver was revoked, if applicable.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeLimitationDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Limitation Description' ;
    rdfs:comment 'Description of any limitations or conditions placed on the scope of the waiver (e.g., limited to specific matters, specific time periods, or specific adverse parties).' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'Email address of the signatory for correspondence and confirmation purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual who signed the waiver on behalf of the client.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Title or role of the signatory within the client organization (e.g., General Counsel, Chief Legal Officer, Authorized Representative).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalClearanceId rdf:type rdf:Property ;
    rdfs:label 'Ethical Clearance Id' ;
    rdfs:comment 'Identifier of the conflict clearance record that triggered the creation of this ethical wall, establishing audit trail linkage.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:ethicalLateralScreeningId rdf:type rdf:Property ;
    rdfs:label 'Ethical Lateral Screening Id' ;
    rdfs:comment 'Identifier of the lateral hire screening record that triggered the creation of this ethical wall, if applicable.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LateralScreening .

ind:toLateralScreeningId rdf:type rdf:Property ;
    rdfs:label 'To Lateral Screening Id' ;
    rdfs:comment 'FK to conflict.lateral_screening.lateral_screening_id — Ethical walls may also be triggered by lateral screening outcomes. Description explicitly references this linkage.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LateralScreening .

ind:acknowledgmentCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Completion Rate' ;
    rdfs:comment 'The percentage of screened timekeepers who have completed the required acknowledgment of the ethical wall, expressed as a decimal (e.g., 0.95 for 95%).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether screened timekeepers are required to formally acknowledge their understanding of and compliance with the ethical wall (True) or not (False).' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Breach Incident Count' ;
    rdfs:comment 'The total number of documented breach or violation incidents associated with this ethical wall, tracked for compliance and risk management.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolutionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Dissolution Approved By' ;
    rdfs:comment 'Name or identifier of the partner or conflicts committee member who approved the dissolution of the ethical wall.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionReason rdf:type rdf:Property ;
    rdfs:label 'Dissolution Reason' ;
    rdfs:comment 'The business or ethical reason for dissolving or expiring the ethical wall (e.g., matter concluded, lateral hire departed, conflict resolved, time-based expiration).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Elite Enforcement Flag' ;
    rdfs:comment 'Indicates whether matter and timekeeper access restrictions for this ethical wall are actively enforced in the Elite 3E practice management system.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'The primary method or combination of methods used to enforce the ethical wall (e.g., system access controls in iManage and Elite 3E, physical office separation, document access restrictions).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imanageEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Imanage Enforcement Flag' ;
    rdfs:comment 'Indicates whether document access restrictions for this ethical wall are actively enforced in the iManage Work Document Management System (DMS).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Specific citation or reference to the regulatory rule, statute, or court order that mandates or governs this ethical wall (e.g., ABA Rule 1.10, court docket number).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedTimekeeperCount rdf:type rdf:Property ;
    rdfs:label 'Screened Timekeeper Count' ;
    rdfs:comment 'The total number of timekeepers (attorneys, paralegals, staff) who are subject to this ethical wall and restricted from accessing the protected information.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'System Enforcement Flag' ;
    rdfs:comment 'Indicates whether the ethical wall is enforced through automated system access controls in practice management and document management systems (True) or relies on manual compliance (False).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggeringReason rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason' ;
    rdfs:comment 'The business or ethical circumstance that necessitated the creation of this information barrier (e.g., lateral hire with prior client relationships, adverse party representation, regulatory mandate).' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances, parties, or matters that required the establishment of this ethical wall.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallCode rdf:type rdf:Property ;
    rdfs:label 'Wall Code' ;
    rdfs:comment 'Unique business identifier or reference code for the ethical wall, typically used in system integrations and reporting.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallName rdf:type rdf:Property ;
    rdfs:label 'Wall Name' ;
    rdfs:comment 'Business-friendly name or title assigned to this ethical screen for identification and reference purposes.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallStatus rdf:type rdf:Property ;
    rdfs:label 'Wall Status' ;
    rdfs:comment 'Current lifecycle status of the ethical screen indicating whether it is currently enforced or has been terminated.' ;
    rdfs:domain ind:EthicalWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallMembershipId rdf:type rdf:Property ;
    rdfs:label 'Wall Membership Id' ;
    rdfs:comment 'Unique identifier for the ethical wall membership record. Primary key.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'Primary Ethical Wall Id' ;
    rdfs:comment 'Reference to the ethical wall (information barrier) to which this membership record applies. Links to the ethical_wall product.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:tertiaryEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ethical Wall Id' ;
    rdfs:comment 'FK to conflict.ethical_wall.ethical_wall_id — Each wall membership record belongs to exactly one ethical wall. This is the master-detail relationship enabling wall enforcement.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:tertiaryReviewedByPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Reviewed By Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner who conducted the most recent review of this ethical wall membership. Links to the timekeeper product. Nullable if no review has been conducted.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:toEthicalWallId rdf:type rdf:Property ;
    rdfs:label 'To Ethical Wall Id' ;
    rdfs:comment 'FK to conflict.ethical_wall.ethical_wall_id — Each wall membership record belongs to a specific ethical wall. This is the classic header-line relationship for screen enforcement.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicalWall .

ind:wallLastModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Wall Last Modified By Timekeeper Id' ;
    rdfs:comment 'The user ID or system account that most recently modified this ethical wall membership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:walledTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Walled Timekeeper Id' ;
    rdfs:comment 'The user ID or system account that created this ethical wall membership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Granular specification of the type and scope of access restrictions enforced by this membership, such as full block (no access to any information), document block (DMS restrictions), matter block (Elite 3E restrictions), client block (all client matters), or no restriction.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date on which the authorizing partner approved the ethical wall membership change.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmsEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Dms Enforcement Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this ethical wall membership triggers automated access control enforcement in the document management system (iManage Work or NetDocuments).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOverrideDate rdf:type rdf:Property ;
    rdfs:label 'Last Override Date' ;
    rdfs:comment 'The most recent date on which an ethical wall access restriction was temporarily overridden for this timekeeper. Nullable if no overrides have occurred.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the ethical wall membership record indicating whether the membership is currently enforced, pending approval, terminated, or temporarily suspended.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Designation indicating whether the timekeeper is included within the ethical wall (restricted from accessing matter information), excluded from the wall (permitted access), restricted (partial access with conditions), or observer (read-only monitoring role).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideCount rdf:type rdf:Property ;
    rdfs:label 'Override Count' ;
    rdfs:comment 'The cumulative number of times that ethical wall access restrictions have been temporarily overridden for this timekeeper membership. Used for audit and compliance monitoring.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overridePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Permitted Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether temporary overrides of the ethical wall restrictions are permitted under specific circumstances (e.g., emergency access, partner approval).' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceManagementEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Practice Management Enforcement Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this ethical wall membership triggers automated access control enforcement in the practice management system (Elite 3E or Aderant Expert) to prevent time entry, billing, or matter visibility.' ;
    rdfs:domain ind:WallMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateralCandidateId rdf:type rdf:Property ;
    rdfs:label 'Lateral Candidate Id' ;
    rdfs:comment 'Reference to the candidate being screened in the recruitment system. Links to the SAP SuccessFactors recruitment workflow.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LateralCandidate .

ind:lateralCreatedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Lateral Created By Timekeeper Id' ;
    rdfs:comment 'Reference to the user who initiated the lateral screening record, typically a recruitment coordinator or conflicts analyst.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:lateralLastModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Lateral Last Modified By Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified the lateral screening record. Supports audit trail and accountability.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:priorFirmIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Prior Firm Ip Asset Id' ;
    rdfs:comment 'Foreign key linking to ip.asset. Business justification: Lateral hire screening must identify specific IP assets candidate worked on at prior firm (prosecuted Patents X, Y, Z for Competitor A). Critical for assessing portability conflicts and ethical wall r' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:priorJudgeId rdf:type rdf:Property ;
    rdfs:label 'Prior Judge Id' ;
    rdfs:comment 'Foreign key linking to court.judge. Business justification: Lateral hire screening checks for prior appearances before specific judges. Real process: candidate disclosure forms ask list judges youve appeared before for recusal analysis and relationship mapp' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Judge .

ind:screeningOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Screening Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner sponsoring the lateral hire. Responsible for reviewing screening results and making the clearance decision.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:candidateEmail rdf:type rdf:Property ;
    rdfs:label 'Candidate Email' ;
    rdfs:comment 'Primary email address of the lateral hire candidate. Used for screening communications and questionnaire distribution.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateFullName rdf:type rdf:Property ;
    rdfs:label 'Candidate Full Name' ;
    rdfs:comment 'Full legal name of the lateral hire candidate as provided in the application. Used for conflict search and clearance documentation.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidatePhone rdf:type rdf:Property ;
    rdfs:label 'Candidate Phone' ;
    rdfs:comment 'Primary contact phone number for the lateral hire candidate during the screening process.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision Date' ;
    rdfs:comment 'Date when the final clearance decision was made. Establishes the completion of the screening process.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision Rationale' ;
    rdfs:comment 'Detailed explanation of the clearance decision, including analysis of conflicts, ethical considerations, and mitigation measures. Protected by Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether required client consent has been obtained and documented. Must be true before clearance can be granted if consent is required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Consent Required Flag' ;
    rdfs:comment 'Indicates whether informed client consent is required to proceed with the hire due to identified conflicts under ABA Rule 1.7.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSearchPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Search Performed Date' ;
    rdfs:comment 'Date when the automated and manual conflict search was executed against firm client and matter databases.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Severity Level' ;
    rdfs:comment 'Highest severity level of conflicts identified. Disqualifying conflicts prevent hiring without client consent or ethical wall implementation.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictsCommitteeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Conflicts Committee Review Date' ;
    rdfs:comment 'Date when the conflicts committee reviewed the lateral screening case. Null if no committee review was required.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictsCommitteeReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Conflicts Committee Review Flag' ;
    rdfs:comment 'Indicates whether the screening was escalated to the firm conflicts committee for review due to complexity or severity of identified conflicts.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Conflicts Identified Count' ;
    rdfs:comment 'Number of potential conflicts of interest identified during the screening process. Zero indicates no conflicts found.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the candidate provided informed consent for processing their personal data during the screening process under GDPR Article 6.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethicalWallDescription rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Description' ;
    rdfs:comment 'Detailed description of the ethical wall procedures and restrictions to be implemented if the candidate is hired. Includes matter access restrictions and communication protocols.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalCounselNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'General Counsel Notification Flag' ;
    rdfs:comment 'Indicates whether the firm General Counsel (GC) or Chief Legal Officer (CLO) was notified of the screening due to high-risk conflicts or regulatory concerns.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateralParentCheck rdf:type rdf:Property ;
    rdfs:label 'Lateral Parent Check' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Lateral screening is a specialized form of conflict check. The lateral_screening record should reference the parent conflict_check that governs its lifecycle and clearance.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mattersDisclosedCount rdf:type rdf:Property ;
    rdfs:label 'Matters Disclosed Count' ;
    rdfs:comment 'Number of matters or cases the candidate disclosed from their prior firm employment. Indicates the scope of conflict review required.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partiesDisclosedCount rdf:type rdf:Property ;
    rdfs:label 'Parties Disclosed Count' ;
    rdfs:comment 'Number of parties (clients, adverse parties, co-counsel) disclosed by the candidate from prior matters. Used to assess relationship conflicts.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Job title or role the candidate held at the prior firm (e.g., Partner, Associate, Counsel, Paralegal). Influences the scope and depth of conflict analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorEmploymentEndDate rdf:type rdf:Property ;
    rdfs:label 'Prior Employment End Date' ;
    rdfs:comment 'Date when the candidate ended employment at the prior firm. Establishes the recency of potential conflicts.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorEmploymentStartDate rdf:type rdf:Property ;
    rdfs:label 'Prior Employment Start Date' ;
    rdfs:comment 'Date when the candidate began employment at the prior firm. Defines the temporal scope for matter conflict analysis.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorFirmJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Prior Firm Jurisdiction' ;
    rdfs:comment 'Primary jurisdiction or state bar where the prior firm operates. Used to assess applicable conflict rules and ethical obligations.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFirmName rdf:type rdf:Property ;
    rdfs:label 'Prior Firm Name' ;
    rdfs:comment 'Name of the law firm or legal organization where the candidate was previously employed. Critical for conflict identification and imputed disqualification analysis.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Prior Practice Group' ;
    rdfs:comment 'Practice area or department where the candidate worked at their prior firm (e.g., Corporate M&A, Litigation, IP, Employment). Used to scope conflict search.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Proposed Office Location' ;
    rdfs:comment 'Office or geographic location where the candidate will be based if hired. Relevant for jurisdiction-specific conflict rules.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Proposed Practice Group' ;
    rdfs:comment 'Practice area or department where the candidate will work if hired. Used to assess potential future conflicts and ethical wall requirements.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionnaireReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Received Date' ;
    rdfs:comment 'Date when the completed conflict questionnaire was received from the candidate. Triggers the conflict analysis phase.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:questionnaireSentDate rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Sent Date' ;
    rdfs:comment 'Date when the lateral hire conflict questionnaire was sent to the candidate. Establishes the start of the candidate disclosure period.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Date' ;
    rdfs:comment 'Date until which the lateral screening record must be retained per regulatory and professional responsibility requirements. Typically 7-10 years post-decision.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Notes' ;
    rdfs:comment 'Free-text notes and observations recorded during the screening process. May include analyst comments, follow-up actions, and additional context. Protected by LPP.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Business identifier for the lateral screening record. Human-readable unique reference number used in communications and reporting.' ;
    rdfs:domain ind:LateralScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipMapId rdf:type rdf:Property ;
    rdfs:label 'Relationship Map Id' ;
    rdfs:comment 'Unique identifier for the relationship mapping record.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipId rdf:type rdf:Property ;
    rdfs:label 'Ownership Id' ;
    rdfs:comment 'Foreign key linking to ip.ownership. Business justification: Party relationship mapping traces IP ownership chains for conflict expansion (Parent Corp owns Patent A, Subsidiary B is adverse party). Essential for identifying imputed conflicts through IP asset ow' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:primaryRelationshipConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Conflict Party Id' ;
    rdfs:comment 'Identifier for the first party in the relationship. References the party entity in the conflict universe (client, organisation, individual, or adverse party).' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:sourceConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Source Conflict Party Id' ;
    rdfs:comment 'FK to conflict.party.party_id — Each relationship record connects two parties. This FK references the first party (source/parent side of the relationship).' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:conflictExpansionFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Expansion Flag' ;
    rdfs:comment 'Indicates whether this relationship should be included in conflict search expansion logic. If true, conflicts identified for Party A will also flag Party B and vice versa.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name of the system or platform from which the relationship data was ingested (e.g., Intapp Conflicts, Companies House API, KYC platform). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalWallApplicable rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Applicable' ;
    rdfs:comment 'Indicates whether an ethical wall (information barrier) can be applied to manage conflicts arising from this relationship. Used in conflict clearance workflows.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'Name or identifier of the user, system, or process that last updated the relationship record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateralHireFlag rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Flag' ;
    rdfs:comment 'Indicates whether this relationship was identified as part of a lateral hire screening process. Used to track conflicts introduced by new attorneys joining the firm.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipPartyA rdf:type rdf:Property ;
    rdfs:label 'Relationship Party A' ;
    rdfs:comment 'FK to conflict.party.party_id — Each relationship record connects two parties. This FK identifies the first party (or parent in directional relationships).' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipRoleA rdf:type rdf:Property ;
    rdfs:label 'Relationship Role A' ;
    rdfs:comment 'The role that Party A plays in the relationship (e.g., parent, subsidiary, beneficial owner, joint venture partner, adverse party). Provides semantic context for the relationship.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRoleB rdf:type rdf:Property ;
    rdfs:label 'Relationship Role B' ;
    rdfs:comment 'The role that Party B plays in the relationship (e.g., parent, subsidiary, beneficial owner, joint venture partner, adverse party). Provides semantic context for the relationship.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the document or filing that evidences the relationship (e.g., Companies House filing number, KYC document ID, client disclosure form). Used for audit trail and verification purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'The date on which the relationship was verified. Used for audit trail and to determine when re-verification may be required.' ;
    rdfs:domain ind:RelationshipMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliesToLateralHires rdf:type rdf:Property ;
    rdfs:label 'Applies To Lateral Hires' ;
    rdfs:comment 'Indicates whether this conflict rule applies to lateral hire screening (i.e., checking for conflicts when a lawyer joins the firm from another firm). True if the rule governs imputed conflicts from prior representation; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProspectiveClients rdf:type rdf:Property ;
    rdfs:label 'Applies To Prospective Clients' ;
    rdfs:comment 'Indicates whether this conflict rule applies to prospective clients (i.e., individuals or organizations who consult with the firm but do not retain the firm). True if the rule governs duties to prospective clients; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedCheckEnabled rdf:type rdf:Property ;
    rdfs:label 'Automated Check Enabled' ;
    rdfs:comment 'Indicates whether automated conflict checking logic in Intapp Conflicts is enabled for this rule. True if the system automatically flags potential conflicts based on this rule; False if manual review is required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkLogicDescription rdf:type rdf:Property ;
    rdfs:label 'Check Logic Description' ;
    rdfs:comment 'Description of the automated conflict checking logic or algorithm used to detect violations of this rule in Intapp Conflicts. Includes the data elements checked (e.g., client relationships, matter types, adverse parties, practice areas) and the matching criteria.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citation rdf:type rdf:Property ;
    rdfs:label 'Citation' ;
    rdfs:comment 'The formal legal citation or reference to the source document for this conflict rule (e.g., ABA Model Rules of Professional Conduct Rule 1.7, SRA Standards and Regulations 2019, Rule 6.1, New York Rules of Professional Conduct Rule 1.7).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityObligation rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Obligation' ;
    rdfs:comment 'The level of confidentiality obligation imposed by this conflict rule. Absolute: no disclosure permitted; Qualified: disclosure permitted with consent or under specific circumstances; Limited: disclosure permitted for certain purposes; None: no confidentiality obligation.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Form Required' ;
    rdfs:comment 'Indicates whether a written consent form is required from the client(s) to waive the conflict governed by this rule. True if written consent is mandatory; False if oral consent is sufficient or if the conflict is non-waivable.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureRequirements rdf:type rdf:Property ;
    rdfs:label 'Disclosure Requirements' ;
    rdfs:comment 'Description of the disclosure requirements that must be met when seeking a waiver or managing a conflict under this rule. Includes the information that must be disclosed to clients, the form of disclosure (written, oral), and the timing of disclosure.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'Description of the documentation that must be maintained when managing a conflict under this rule. Includes conflict check records, waiver forms, ethical wall memos, client communications, and any other records required for compliance and audit purposes.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWaivable rdf:type rdf:Property ;
    rdfs:label 'Is Waivable' ;
    rdfs:comment 'Indicates whether the conflict governed by this rule may be waived by informed client consent. True if waivable under certain conditions; False if non-waivable (e.g., direct adverse representation in the same matter).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Description of the parties who must be notified when a conflict governed by this rule is identified (e.g., All affected clients, Opposing counsel, Tribunal, Firm management). Null if no notification is required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether notification to affected parties (clients, opposing counsel, tribunal) is required when a conflict governed by this rule is identified. True if notification is mandatory; False otherwise.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedRules rdf:type rdf:Property ;
    rdfs:label 'Related Rules' ;
    rdfs:comment 'Comma-separated list of related conflict rule codes that should be considered in conjunction with this rule (e.g., ABA_1.9,ABA_1.10 for a rule that interacts with former client and imputed conflict rules). Used for cross-referencing and comprehensive conflict analysis.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEthicalWall rdf:type rdf:Property ;
    rdfs:label 'Requires Ethical Wall' ;
    rdfs:comment 'Indicates whether this conflict rule requires the establishment of an ethical wall (information barrier, Chinese wall) to screen conflicted individuals from the matter. True if an ethical wall is a permissible or required mitigation; False otherwise.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningScope rdf:type rdf:Property ;
    rdfs:label 'Screening Scope' ;
    rdfs:comment 'The organizational scope at which conflict screening must be performed for this rule (e.g., Individual timekeeper, Practice Group, Office, Firm-Wide). Determines the breadth of relationship and matter checks required.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverConditions rdf:type rdf:Property ;
    rdfs:label 'Waiver Conditions' ;
    rdfs:comment 'Detailed description of the conditions under which the conflict may be waived, if applicable. Includes requirements for informed consent, written disclosure, independent legal advice, and any other conditions mandated by the governing body. Null if the conflict is non-waivable.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyAliasId rdf:type rdf:Property ;
    rdfs:label 'Party Alias Id' ;
    rdfs:comment 'Unique identifier for the party alias record. Primary key.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliasedConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Aliased Conflict Party Id' ;
    rdfs:comment 'FK to conflict.party.party_id — Each alias links to its canonical party record. Description explicitly states this linkage. Without it, aliases cannot be resolved to parties during search.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:lastModifiedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timekeeper Id' ;
    rdfs:comment 'Identifier of the user or system account that created this alias record. Links to the user or system entity responsible for the initial data entry.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:partyLastModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Party Last Modified By Timekeeper Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this alias record. Links to the user or system entity responsible for the most recent update.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Party Id' ;
    rdfs:comment 'Foreign key reference to the canonical conflict_party record to which this alias belongs. Links the alias to the authoritative party entity in the conflict search universe.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:aliasCanonicalParty rdf:type rdf:Property ;
    rdfs:label 'Alias Canonical Party' ;
    rdfs:comment 'FK to conflict.party.party_id — Each alias record links to its canonical party record. This FK is essential for the fuzzy matching engine to resolve aliases back to the master party.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliasName rdf:type rdf:Property ;
    rdfs:label 'Alias Name' ;
    rdfs:comment 'The alternate name, former name, trade name, DBA (Doing Business As) designation, or transliterated variant of the party. This is the searchable alias string used during conflict searches to identify potential matches.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasSource rdf:type rdf:Property ;
    rdfs:label 'Alias Source' ;
    rdfs:comment 'The origin or source from which the alias was obtained. Values: client_disclosure (provided by client during intake), public_registry (obtained from government or corporate registry), prior_matter (identified in historical matter records), lateral_hire_screening (discovered during lateral attorney conflict check), third_party_database (sourced from external data provider), manual_entry (manually added by conflicts team).' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasType rdf:type rdf:Property ;
    rdfs:label 'Alias Type' ;
    rdfs:comment 'Classification of the alias indicating the nature of the alternate name. Values: legal_name (official registered name), former_name (historical name prior to change), trade_name (commercial operating name), dba (Doing Business As designation), transliteration (name rendered in different script or alphabet), phonetic_variant (phonetically similar name for fuzzy matching).' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryAlias rdf:type rdf:Property ;
    rdfs:label 'Is Primary Alias' ;
    rdfs:comment 'Boolean flag indicating whether this alias is the primary or preferred alternate name for the party in conflict searches. True if this is the main alias to be used; False otherwise.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneticEncoding rdf:type rdf:Property ;
    rdfs:label 'Phonetic Encoding' ;
    rdfs:comment 'Phonetic encoding of the alias name using algorithms such as Soundex, Metaphone, or Double Metaphone. Enables fuzzy matching and phonetic similarity searches during conflict checks to identify parties with similar-sounding names.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The authoritative source or registry used to verify the alias. Examples: Companies House (UK), SEC EDGAR (USA), state business registry, corporate charter, court records, client-provided documentation.' ;
    rdfs:domain ind:PartyAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual or committee chair who approved this exception.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'The role or body that approved this exception: managing partner, ethics committee, general counsel, conflicts counsel, or risk management committee.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text field for recording audit notes, review comments, or historical context related to the exception approval and usage.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientCategory rdf:type rdf:Property ;
    rdfs:label 'Client Category' ;
    rdfs:comment 'Category or classification of clients covered by this exception (e.g., Fortune 500 financial institutions, approved nonprofit organizations, government entities).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictExceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception: active (in force), suspended (temporarily inactive), expired (past review date), revoked (terminated), pending review (awaiting approval), or draft (not yet approved).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Business identifier code for the exception, used for reference in conflict clearance workflows and audit trails.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative describing the scope, rationale, and conditions under which this exception applies to conflict clearance requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionName rdf:type rdf:Property ;
    rdfs:label 'Exception Name' ;
    rdfs:comment 'Human-readable name or title of the exception for identification in conflict management systems and reporting.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the exception category: pre-approved engagement categories, standing institutional client waivers, regulatory safe harbors, de minimis thresholds, pro bono matter categories for approved nonprofits, or institutional client blanket waivers.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCovered rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Covered' ;
    rdfs:comment 'Geographic or regulatory jurisdictions in which this exception is valid (e.g., USA, GBR, DEU, or specific state bars).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent formal review of this exception by the approving authority.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Most recent date on which this exception was applied to a conflict clearance decision.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mandatory Review Date' ;
    rdfs:comment 'Date by which this exception must be reviewed by the approving authority, regardless of expiration status, to ensure continued appropriateness.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterTypeCovered rdf:type rdf:Property ;
    rdfs:label 'Matter Type Covered' ;
    rdfs:comment 'Types of legal matters or engagement categories to which this exception applies (e.g., pro bono immigration matters, routine corporate filings, regulatory compliance advisory).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroupCovered rdf:type rdf:Property ;
    rdfs:label 'Practice Group Covered' ;
    rdfs:comment 'Practice groups or departments within the firm to which this exception applies (e.g., Corporate, Litigation, Intellectual Property, Employment).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDefinition rdf:type rdf:Property ;
    rdfs:label 'Scope Definition' ;
    rdfs:comment 'Detailed specification of the scope covered by this exception, including client categories, matter types, practice groups, jurisdictions, or transaction thresholds to which the exception applies prospectively.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Amount' ;
    rdfs:comment 'Monetary threshold value for de minimis exceptions (e.g., matters below USD 50,000 may be pre-approved). Nullable if exception is not amount-based.' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the threshold amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ConflictException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogId rdf:type rdf:Property ;
    rdfs:label 'Audit Log Id' ;
    rdfs:comment 'Primary key for audit_log' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Acting Timekeeper Id' ;
    rdfs:comment 'Identifier of the reviewer assigned to or responding to a conflict hit, if the action_type is reviewer_assigned or reviewer_response. Null for other action types.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:auditActorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Audit Actor Timekeeper Id' ;
    rdfs:comment 'Identifier of the individual or system account that performed the action. References timekeeper or system user record.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:auditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_engagement. Business justification: Conflict system audit logs are reviewed during compliance audit engagements to verify access controls and process adherence. External auditors sample conflict audit logs as evidence for SOC 2 / ISO 27' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEngagement .

ind:auditSessionId rdf:type rdf:Property ;
    rdfs:label 'Audit Session Id' ;
    rdfs:comment 'Unique identifier of the user session or system transaction in which the action occurred. Enables correlation of related audit events.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditSession .

ind:abaEthicsAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Aba Ethics Audit Flag' ;
    rdfs:comment 'Indicates whether this audit event is required for American Bar Association (ABA) ethics audit and compliance review. True if required, False otherwise.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actorName rdf:type rdf:Property ;
    rdfs:label 'Actor Name' ;
    rdfs:comment 'Full name of the individual or system account that performed the action. Denormalized for audit trail readability and GDPR Article 15 data subject access requests.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Category of actor who performed the action: timekeeper (lawyer or staff), system (automated process), or administrator (privileged user).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'Identifier of the specific entity instance affected by this action. Interpreted in conjunction with affected_entity_type.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of business entity affected by this action (e.g., conflict_check, conflict_hit, ethical_wall). Provides context for the affected_entity_id. [ENUM-REF-CANDIDATE: conflict_check|conflict_search|conflict_hit|reviewer_assignment|clearance|waiver|ethical_wall|exception — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCheckReference rdf:type rdf:Property ;
    rdfs:label 'Audit Check Reference' ;
    rdfs:comment 'FK to conflict.conflict_check.conflict_check_id — Most audit log entries relate to a specific conflict check lifecycle event. FK enables filtering audit trail by check for compliance review.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the action was initiated. Supports security audit and forensic investigation. May be IPv4 or IPv6 format.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasisForProcessing rdf:type rdf:Property ;
    rdfs:label 'Legal Basis For Processing' ;
    rdfs:comment 'GDPR Article 6 legal basis under which this personal data is processed and retained. Required for EU/UK personal data.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'State or value of the affected entity immediately after this action. Captured as JSON or delimited string for complex state. May be null for deletion events.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'State or value of the affected entity immediately before this action. Captured as JSON or delimited string for complex state. May be null for creation events.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalIndemnityRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Relevant Flag' ;
    rdfs:comment 'Indicates whether this audit event is relevant to professional indemnity insurance audit requirements. True if relevant, False otherwise.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerResponse rdf:type rdf:Property ;
    rdfs:label 'Reviewer Response' ;
    rdfs:comment 'Response provided by the reviewer regarding a conflict hit, if the action_type is reviewer_response. Null for other action types.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchQueryText rdf:type rdf:Property ;
    rdfs:label 'Search Query Text' ;
    rdfs:comment 'Text of the search query executed, if the action_type is search_executed. Null for other action types. Supports audit trail reconstruction.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sraAccountabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sra Accountability Flag' ;
    rdfs:comment 'Indicates whether this audit event is required for Solicitors Regulation Authority (SRA) accountability and ethics audit. True if required, False otherwise.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Name of the system or module that generated this audit event (e.g., Intapp Conflicts, Elite 3E, custom workflow engine). Supports multi-system audit consolidation.' ;
    rdfs:domain ind:AuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterPartyRoleId rdf:type rdf:Property ;
    rdfs:label 'Matter Party Role Id' ;
    rdfs:comment 'Unique identifier for the matter party role record. Primary key for conflict-domain tracking of party-matter relationships.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMatterConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Matter Conflict Party Id' ;
    rdfs:comment 'Reference to the party (individual or organization) holding this role on the matter. Links to client domain party master data.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:tertiaryMatterDisclosedByPartyConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Matter Disclosed By Party Conflict Party Id' ;
    rdfs:comment 'Reference to the party (typically the client) who disclosed this relationship during intake or KYC (Know Your Client) process.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:billingResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Responsibility Flag' ;
    rdfs:comment 'Indicates whether this party role carries billing responsibility for the matter. True for client and co-client roles that are financially responsible.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Clearance Status' ;
    rdfs:comment 'Outcome of conflict screening for this party role. Ethical_wall_required indicates LPP (Legal Professional Privilege) protection measures are in place.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Date' ;
    rdfs:comment 'Date on which the conflict waiver was executed by the affected parties. Null if no waiver was required or obtained.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastConflictCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Conflict Check Date' ;
    rdfs:comment 'Date of the most recent conflict check performed against this party role. Used for periodic re-screening and compliance audits.' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterOpeningApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Matter Opening Approval Required' ;
    rdfs:comment 'Indicates whether this party role requires additional approval before the matter can be opened. True for high-risk conflict scenarios.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleAssignmentSource rdf:type rdf:Property ;
    rdfs:label 'Role Assignment Source' ;
    rdfs:comment 'Origin of the role assignment. Tracks whether the relationship was disclosed at intake, discovered in court filings, or identified during lateral hire screening.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolePriority rdf:type rdf:Property ;
    rdfs:label 'Role Priority' ;
    rdfs:comment 'Numeric ranking of this roles priority on the matter. Lower numbers indicate higher priority. Used when a party holds multiple roles (e.g., client and guarantor).' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the party role assignment. Active roles populate the conflict search index; conflicted_out roles trigger ethical wall enforcement.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Classification of the partys role on the matter. Determines conflict screening rules and ethical wall requirements. [ENUM-REF-CANDIDATE: client|co-client|adverse_party|third_party_witness|guarantor|related_entity|regulatory_counterparty|opposing_counsel|expert_witness|beneficiary|trustee|secured_creditor — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchIndexIncluded rdf:type rdf:Property ;
    rdfs:label 'Search Index Included' ;
    rdfs:comment 'Indicates whether this party role is included in the conflict search index. False for terminated roles or roles behind ethical walls.' ;
    rdfs:domain ind:MatterPartyRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyJudgeAppearanceId rdf:type rdf:Property ;
    rdfs:label 'Party Judge Appearance Id' ;
    rdfs:comment 'Unique identifier for this party-judge appearance history record. Primary key for the association.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appearingConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Appearing Conflict Party Id' ;
    rdfs:comment 'Foreign key to conflict_party. Identifies which party appeared before the judge.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:firstAppearanceDate rdf:type rdf:Property ;
    rdfs:label 'First Appearance Date' ;
    rdfs:comment 'Date of the first recorded appearance of this party before this judge. Establishes the start of the relationship history for conflict screening purposes.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterCount rdf:type rdf:Property ;
    rdfs:label 'Matter Count' ;
    rdfs:comment 'Number of distinct matters in which this party appeared before this judge. Distinct from appearance_count, which may include multiple appearances within the same matter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partyRoleInAppearances rdf:type rdf:Property ;
    rdfs:label 'Party Role In Appearances' ;
    rdfs:comment 'The predominant role this party played when appearing before this judge. Client indicates the party was represented by the firm; Adverse_Party indicates opposition; Mixed indicates the party appeared in different roles across matters. Used for conflict and relationship risk assessment.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recusalDate rdf:type rdf:Property ;
    rdfs:label 'Recusal Date' ;
    rdfs:comment 'Date of the most recent recusal by this judge involving this party. Null if no recusal history exists. Used for conflict screening and relationship intelligence.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recusalReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Recusal Reason Notes' ;
    rdfs:comment 'Free-text notes capturing the reason for recusal, if applicable. Used to inform future conflict assessments and lateral hire screening decisions.' ;
    rdfs:domain ind:PartyJudgeAppearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyPracticeConflictId rdf:type rdf:Property ;
    rdfs:label 'Party Practice Conflict Id' ;
    rdfs:comment 'Unique identifier for this party-practice area conflict relationship record. Primary key.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictedConflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Conflicted Conflict Party Id' ;
    rdfs:comment 'Foreign key to conflict_party. Part of the composite business key.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:activeMatterCount rdf:type rdf:Property ;
    rdfs:label 'Active Matter Count' ;
    rdfs:comment 'The current count of active matters in this practice area involving this party (either as client or adverse). Used to assess the recency and intensity of the relationship.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalMatterCount rdf:type rdf:Property ;
    rdfs:label 'Historical Matter Count' ;
    rdfs:comment 'The total historical count of all matters (active and closed) in this practice area involving this party. Provides context for the depth of the relationship.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastConflictCheckResult rdf:type rdf:Property ;
    rdfs:label 'Last Conflict Check Result' ;
    rdfs:comment 'The outcome of the most recent conflict check. Clear indicates no conflict found; conflict_identified indicates a conflict was detected; waiver_required indicates client waiver is needed; escalation_required indicates the conflict requires conflicts committee review.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'The date on which this partys relationship with the firm in this practice area ended or was resolved. Null for ongoing relationships. For client relationships, typically the matter close date; for adverse relationships, the date the adversity was resolved or the matter concluded.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'The date on which this partys relationship with the firm in this practice area began. For client relationships, typically the date of the first engagement; for adverse relationships, the date the party was first identified as adverse in this practice area.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'The date on which the current conflict waiver expires, if applicable. Null if no waiver is on file or if the waiver has no expiration.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver On File Flag' ;
    rdfs:comment 'Indicates whether a signed conflict waiver is on file for this party in this practice area. True if a waiver has been obtained and is currently valid; false otherwise.' ;
    rdfs:domain ind:PartyPracticeConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wallEnforcementId rdf:type rdf:Property ;
    rdfs:label 'Wall Enforcement Id' ;
    rdfs:comment 'Primary key for the wall_enforcement association' ;
    rdfs:domain ind:WallEnforcement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Enforced By Timekeeper Id' ;
    rdfs:comment 'Foreign key to workforce.timekeeper.timekeeper_id' ;
    rdfs:domain ind:WallEnforcement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:applicabilityReason rdf:type rdf:Property ;
    rdfs:label 'Applicability Reason' ;
    rdfs:comment 'Specific reason why this ethical wall applies to this particular agreement (e.g., Agreement involves former client of lateral hire, Counterparty is adverse party in screened matter)' ;
    rdfs:domain ind:WallEnforcement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDecisionMakerUserId rdf:type rdf:Property ;
    rdfs:label 'Audit Decision Maker User Id' ;
    rdfs:comment 'Identifier of the user who made the final clearance decision.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:auditEscalatedToUserId rdf:type rdf:Property ;
    rdfs:label 'Audit Escalated To User Id' ;
    rdfs:comment 'Identifier of the user to whom the session was escalated.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:auditInitiatedByUserId rdf:type rdf:Property ;
    rdfs:label 'Audit Initiated By User Id' ;
    rdfs:comment 'Identifier of the user who initiated the audit session.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:auditLastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Audit Last Modified By User Id' ;
    rdfs:comment 'Identifier of the user who last modified this audit session record.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:priorAuditSessionId rdf:type rdf:Property ;
    rdfs:label 'Prior Audit Session Id' ;
    rdfs:comment 'Self-referencing FK on audit_session (prior_audit_session_id)' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditSession .

ind:reviewerUserId rdf:type rdf:Property ;
    rdfs:label 'Reviewer User Id' ;
    rdfs:comment 'Identifier of the user who reviewed the conflict screening results.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:clearanceDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision Timestamp' ;
    rdfs:comment 'Date and time when the clearance decision was made.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conflictDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Detected Flag' ;
    rdfs:comment 'Indicates whether a conflict of interest was detected during this audit session.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Conflict Rule Applied' ;
    rdfs:comment 'The specific American Bar Association (ABA) Model Rule or custom conflict rule applied during this audit session.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the audit session measured in seconds from initiation to completion.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitiesScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Entities Screened Count' ;
    rdfs:comment 'Total number of entities (clients, matters, parties) screened during this audit session.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the audit session was first initiated by a user or system process.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Description of the strategy or measures implemented to mitigate identified conflicts.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipMappingPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Mapping Performed Flag' ;
    rdfs:comment 'Indicates whether relationship mapping analysis was performed during this audit session.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Session Identifier' ;
    rdfs:comment 'Business-facing unique session identifier used for tracking and reference across conflict screening workflows.' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSessionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Session Code' ;
    rdfs:comment 'The unique session identifier from the source system (e.g., Intapp Conflicts session ID).' ;
    rdfs:domain ind:AuditSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Amount' ;
    rdfs:comment 'Monetary amount due for the next annuity or maintenance fee payment.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annuityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Annuity Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annuity payment amount.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Due Date' ;
    rdfs:comment 'Next scheduled date for payment of maintenance fees or annuities to keep the IP asset in force.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Official application number assigned by the intellectual property office upon filing.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the IP asset, often used in client communications and docketing systems.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the intellectual property asset type.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationCode rdf:type rdf:Property ;
    rdfs:label 'Classification Code' ;
    rdfs:comment 'International Patent Classification (IPC), Cooperative Patent Classification (CPC), or Nice Classification code assigned to the IP asset.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Docketing System Code' ;
    rdfs:comment 'External identifier used in the IP docketing or deadline management system for tracking prosecution milestones.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryPath rdf:type rdf:Property ;
    rdfs:label 'Document Repository Path' ;
    rdfs:comment 'File path or URI reference to the location in the document management system (DMS) where IP asset documents are stored.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandDeclarationFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Declaration Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to a FRAND declaration to a standards-setting organization.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventorNames rdf:type rdf:Property ;
    rdfs:label 'Inventor Names' ;
    rdfs:comment 'Comma-separated list of inventor names credited on the patent or IP asset application.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Asset Description' ;
    rdfs:comment 'Detailed business description of the intellectual property asset, including its purpose, scope, and key features.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Asset Status' ;
    rdfs:comment 'Current lifecycle status of the intellectual property asset in the prosecution or registration process. [ENUM-REF-CANDIDATE: pending|registered|granted|abandoned|expired|lapsed|opposed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOfficeName rdf:type rdf:Property ;
    rdfs:label 'Ip Office Name' ;
    rdfs:comment 'Name of the intellectual property office or authority responsible for examining and granting the IP asset (e.g., USPTO, EPO, JPO).' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Current licensing arrangement status for the IP asset, including Fair Reasonable and Non-Discriminatory (FRAND) commitments.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Opposition Filed Flag' ;
    rdfs:comment 'Indicates whether a third-party opposition or challenge has been filed against the IP asset.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Legal name of the entity or individual who holds ownership rights to the intellectual property asset.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Pct Application Flag' ;
    rdfs:comment 'Indicates whether the IP asset was filed under the Patent Cooperation Treaty (PCT) international application process.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioCategory rdf:type rdf:Property ;
    rdfs:label 'Portfolio Category' ;
    rdfs:comment 'Business classification or grouping of the IP asset within the clients portfolio (e.g., core technology, defensive, licensing).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pphRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Pph Request Flag' ;
    rdfs:comment 'Indicates whether a Patent Prosecution Highway (PPH) request has been filed to accelerate examination based on a related application.' ;
    rdfs:domain ind:IpAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest filing date claimed for priority purposes under the Paris Convention or Patent Cooperation Treaty (PCT).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the intellectual property asset was officially registered or granted by the IP office.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Broad technology or industry domain to which the IP asset relates (e.g., pharmaceuticals, software, telecommunications).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Estimated or appraised monetary value of the intellectual property asset for portfolio management and financial reporting.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the valuation amount.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date on which the IP asset valuation was performed or last updated.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:litigationDocketId rdf:type rdf:Property ;
    rdfs:label 'Litigation Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: Patent infringement and validity litigation requires direct tracking from patent to court docket. Essential for monitoring enforcement actions, calculating patent portfolio risk, and coordinating pros' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:primaryPatentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Family Id' ;
    rdfs:comment 'Identifier linking this patent to its patent family - a group of related patent applications filed in multiple jurisdictions claiming the same priority. Enables portfolio-level analysis and management.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:primaryPatentIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Ip Asset Id' ;
    rdfs:comment 'Reference to the parent IP asset record. Links this patent to the broader IP asset portfolio.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:toIpAssetId rdf:type rdf:Property ;
    rdfs:label 'To Ip Asset Id' ;
    rdfs:comment 'FK to ip.ip_asset.ip_asset_id — Patent extends ip_asset — every patent record MUST reference its parent ip_asset record. This is the fundamental inheritance/extension FK that connects the type-specific detail to the master asset rec' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:toPatentFamilyId rdf:type rdf:Property ;
    rdfs:label 'To Patent Family Id' ;
    rdfs:comment 'FK to ip.patent_family.patent_family_id — Every patent belongs to a patent family (or is a singleton family). This FK enables family-level portfolio analysis and prosecution strategy.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'A concise summary of the invention disclosed in the patent, typically 150-250 words, providing a high-level overview of the technical problem and solution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'The name of the registered patent agent or patent attorney who is prosecuting the patent application before the patent office.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Status' ;
    rdfs:comment 'Current status of the patent maintenance fee (annuity) payment. Tracks whether fees are current, overdue, or if the patent has lapsed due to non-payment.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'The current legal owner of the patent rights. This is typically the organization or individual to whom the inventors have assigned their rights.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentChain rdf:type rdf:Property ;
    rdfs:label 'Assignment Chain' ;
    rdfs:comment 'A chronological record of all ownership transfers (assignments) of the patent rights, tracking the chain of title from original assignee to current owner.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification Codes' ;
    rdfs:comment 'Classification codes assigned under the Cooperative Patent Classification system, jointly developed by the EPO and USPTO. Provides more granular technology classification than IPC.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPortfolioValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Portfolio Value' ;
    rdfs:comment 'The estimated monetary value of this patent asset based on valuation methodologies such as cost approach, market approach, or income approach. Used for portfolio management and financial reporting.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'The name of the patent office examiner who examined the patent application.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendsAsset rdf:type rdf:Property ;
    rdfs:label 'Extends Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Patent is a subtype extension of the ip_asset master. Every patent record MUST reference its parent asset record for portfolio-level queries, ownership inheritance, and docketing. This is the core inh' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frandObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Obligation Flag' ;
    rdfs:comment 'Indicates whether this patent is subject to FRAND licensing obligations, typically because it is essential to a technical standard. FRAND patents must be licensed on fair, reasonable, and non-discriminatory terms.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'The date the patent was officially granted by the patent office, conferring exclusive rights to the patent holder.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claims Count' ;
    rdfs:comment 'The number of independent claims in the patent. Independent claims stand alone and define the broadest scope of protection, making them particularly valuable for enforcement.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipcClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification Codes' ;
    rdfs:comment 'Hierarchical classification codes assigned to the patent based on the International Patent Classification system. Multiple codes may be present, separated by semicolons (e.g., H04L29/06; G06F21/60).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether this patent is currently involved in litigation, opposition, or other legal proceedings. Critical for risk assessment and portfolio management.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAssigneeName rdf:type rdf:Property ;
    rdfs:label 'Original Assignee Name' ;
    rdfs:comment 'The initial assignee of the patent at the time of filing or grant. Tracks the original owner before any subsequent assignments or transfers.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'The official patent number assigned by the granting patent office (e.g., US10123456B2, EP3456789A1). This is the externally-known unique identifier for the granted patent.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'The classification of patent: utility (functional inventions), design (ornamental designs), or plant (new plant varieties).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'The PCT international application number if this patent was filed under the Patent Cooperation Treaty, enabling a single application to seek protection in multiple jurisdictions.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pphEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pph Eligible Flag' ;
    rdfs:comment 'Indicates whether this patent application is eligible for accelerated examination under the Patent Prosecution Highway program, which allows applicants to fast-track examination based on positive results from another participating patent office.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorArtReferences rdf:type rdf:Property ;
    rdfs:label 'Prior Art References' ;
    rdfs:comment 'A list of prior art references cited during patent examination that were considered relevant to patentability. Multiple references are separated by semicolons.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Current lifecycle status of the patent in the prosecution process. Tracks the patent from initial drafting through grant, maintenance, or abandonment. [ENUM-REF-CANDIDATE: draft|filed|pending|published|granted|abandoned|expired|lapsed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date the patent application was published and made publicly available, typically 18 months after the priority date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'The official publication number assigned when the patent application was published (typically 18 months after filing).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardEssentialPatentFlag rdf:type rdf:Property ;
    rdfs:label 'Standard Essential Patent Flag' ;
    rdfs:comment 'Indicates whether this patent has been declared as essential to implementing a technical standard (e.g., telecommunications, wireless, video compression standards).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Count' ;
    rdfs:comment 'The total number of claims in the patent. Claims define the legal scope of patent protection and are critical for enforcement and valuation.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrademarkIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Trademark Ip Asset Id' ;
    rdfs:comment 'Reference to the parent IP asset record. Links this trademark to the broader IP portfolio management system.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:applicationSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Application Serial Number' ;
    rdfs:comment 'The official serial number assigned by the trademark office upon filing. Unique identifier for the trademark application in the jurisdictions registry.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyDocketNumber rdf:type rdf:Property ;
    rdfs:label 'Attorney Docket Number' ;
    rdfs:comment 'Internal docket or reference number assigned by the law firm for tracking this trademark matter. Links to internal matter management and billing systems.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyOfRecord rdf:type rdf:Property ;
    rdfs:label 'Attorney Of Record' ;
    rdfs:comment 'The name of the attorney or law firm representing the applicant/registrant in the trademark prosecution. Links to internal timekeeper records.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorClaim rdf:type rdf:Property ;
    rdfs:label 'Color Claim' ;
    rdfs:comment 'Description of any color(s) claimed as a feature of the trademark. Relevant for marks where color is a distinguishing element.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Text of any disclaimer filed with the trademark application, disclaiming exclusive rights to certain descriptive or generic elements of the mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingBasis rdf:type rdf:Property ;
    rdfs:label 'Filing Basis' ;
    rdfs:comment 'The legal basis under which the trademark application was filed (US-specific): actual use in commerce (Section 1(a)), intent to use (Section 1(b)), foreign application (Section 44(d)), or foreign registration (Section 44(e)).' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstUseAnywhereDate rdf:type rdf:Property ;
    rdfs:label 'First Use Anywhere Date' ;
    rdfs:comment 'The date the trademark was first used anywhere in the world, regardless of jurisdiction. May predate use in commerce date.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Services Description' ;
    rdfs:comment 'Detailed description of the goods and/or services for which the trademark is registered or applied. Must conform to acceptable identification standards per the trademark office.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridDesignatedCountries rdf:type rdf:Property ;
    rdfs:label 'Madrid Designated Countries' ;
    rdfs:comment 'Comma-separated list of country codes (ISO 3166-1 alpha-3) designated for protection under a Madrid Protocol international registration.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridProtocolIndicator rdf:type rdf:Property ;
    rdfs:label 'Madrid Protocol Indicator' ;
    rdfs:comment 'Indicates whether this trademark was filed under the Madrid Protocol for international registration. True if filed via WIPO Madrid System.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:madridRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Madrid Registration Number' ;
    rdfs:comment 'The international registration number assigned by WIPO under the Madrid Protocol. Null if not a Madrid Protocol filing.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markDescription rdf:type rdf:Property ;
    rdfs:label 'Mark Description' ;
    rdfs:comment 'Detailed description of the trademark, especially for device marks, trade dress, or composite marks. Describes visual elements, colors, design features, and overall appearance.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markText rdf:type rdf:Property ;
    rdfs:label 'Mark Text' ;
    rdfs:comment 'The literal text of the trademark for word marks. Null for device marks or design-only marks. Core identifier for the trademark asset.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markType rdf:type rdf:Property ;
    rdfs:label 'Mark Type' ;
    rdfs:comment 'Classification of the trademark by its form: word mark (text only), device mark (logo/design), composite mark (text and design), trade dress (product appearance), certification mark, or collective mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiClassIndicator rdf:type rdf:Property ;
    rdfs:label 'Multi Class Indicator' ;
    rdfs:comment 'Indicates whether this trademark application covers multiple Nice Classification classes. True if filed under more than one class.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:niceClassificationCodes rdf:type rdf:Property ;
    rdfs:label 'Nice Classification Codes' ;
    rdfs:comment 'Comma-separated list of Nice Classification class numbers (1-45) under which the trademark is registered. Classes 1-34 cover goods; classes 35-45 cover services.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Period End Date' ;
    rdfs:comment 'The deadline by which third parties may file an opposition to the trademark application. Typically 30 days after publication in the Official Gazette (US) or similar publication.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionStatus rdf:type rdf:Property ;
    rdfs:label 'Opposition Status' ;
    rdfs:comment 'Status of any opposition proceedings filed against this trademark application. Tracks whether the mark is under challenge by third parties.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerAddress rdf:type rdf:Property ;
    rdfs:label 'Owner Address' ;
    rdfs:comment 'The full address of the trademark owner as recorded in the trademark registry. Required for official correspondence and ownership verification.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Portfolio Valuation Amount' ;
    rdfs:comment 'The estimated financial value of this trademark asset as part of the overall IP portfolio. Used for portfolio management and financial reporting.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityClaimCountry rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Country' ;
    rdfs:comment 'The country code (ISO 3166-1 alpha-3) of the jurisdiction where the priority application was filed. Used for Paris Convention priority claims.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimDate rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Date' ;
    rdfs:comment 'The priority date claimed under the Paris Convention or other treaty, based on an earlier foreign filing. Establishes earlier effective filing date.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The next deadline for renewing the trademark registration to maintain its active status. Critical for IP docketing and annuity payment management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specimenOfUseDescription rdf:type rdf:Property ;
    rdfs:label 'Specimen Of Use Description' ;
    rdfs:comment 'Description of the specimen submitted to demonstrate actual use of the trademark in commerce. Required for US trademark applications.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkStatus rdf:type rdf:Property ;
    rdfs:label 'Trademark Status' ;
    rdfs:comment 'Current lifecycle status of the trademark application or registration. Tracks progression through prosecution and maintenance phases. [ENUM-REF-CANDIDATE: pending|published|registered|opposed|cancelled|abandoned|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationText rdf:type rdf:Property ;
    rdfs:label 'Translation Text' ;
    rdfs:comment 'English translation of any foreign wording in the mark, as required by trademark offices for non-English marks.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transliterationText rdf:type rdf:Property ;
    rdfs:label 'Transliteration Text' ;
    rdfs:comment 'Transliteration of any non-Latin characters in the mark into Latin characters, as required by trademark offices.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useInCommerceDate rdf:type rdf:Property ;
    rdfs:label 'Use In Commerce Date' ;
    rdfs:comment 'The date the trademark was first used in commerce (for US applications). Critical for establishing trademark rights and priority in use-based jurisdictions.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Prosecution Event Id' ;
    rdfs:comment 'Unique identifier for the prosecution event record. Primary key for the prosecution event entity.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prosecutionModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Prosecution Modified By Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who last modified this prosecution event record in the system.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:artUnit rdf:type rdf:Property ;
    rdfs:label 'Art Unit' ;
    rdfs:comment 'USPTO art unit or technology center code to which the examiner belongs. Indicates the technical classification area for patent examination.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsAllowedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Allowed Count' ;
    rdfs:comment 'Number of claims allowed by the examiner in this prosecution event. Relevant for notices of allowance and final dispositions.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsRejectedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Rejected Count' ;
    rdfs:comment 'Number of claims rejected by the examiner in this prosecution event. Relevant for office actions and final rejections.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:docketingTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Docketing Trigger Flag' ;
    rdfs:comment 'Indicates whether this prosecution event triggers an automated docketing action or deadline alert in the IP management system.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estoppelRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Estoppel Risk Flag' ;
    rdfs:comment 'Indicates whether this prosecution event may create prosecution history estoppel risk, limiting claim scope interpretation in future litigation.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a deadline extension was granted by the patent or trademark office for this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether a deadline extension was requested for this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the fee amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmOfficeActionType rdf:type rdf:Property ;
    rdfs:label 'Firm Office Action Type' ;
    rdfs:comment 'Specific type of office action issued by the patent or trademark office. Distinguishes between non-final, final, restriction, and other action types.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forAsset rdf:type rdf:Property ;
    rdfs:label 'For Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Every prosecution event occurs in the context of a specific IP asset (patent or trademark application). This FK is essential for prosecution history reconstruction and estoppel analysis.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Interview Conducted Flag' ;
    rdfs:comment 'Indicates whether an examiner interview was conducted as part of this prosecution event.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialDeadline rdf:type rdf:Property ;
    rdfs:label 'Official Deadline' ;
    rdfs:comment 'Statutory or official deadline imposed by the patent or trademark office for responding to this event. Critical for docketing and deadline management.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage of the prosecution lifecycle at the time of this event. Provides context for the event within the overall application timeline.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionBasis rdf:type rdf:Property ;
    rdfs:label 'Rejection Basis' ;
    rdfs:comment 'Legal or technical basis for rejection cited by the examiner. May reference prior art, statutory sections (e.g., 35 USC 102, 103, 112), or formality issues.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Internal or client-agreed deadline for filing a response to this prosecution event. May be earlier than the official deadline to allow for review and preparation.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseFiledDate rdf:type rdf:Property ;
    rdfs:label 'Response Filed Date' ;
    rdfs:comment 'Date on which the applicant or attorney filed a response to the prosecution event with the patent or trademark office.' ;
    rdfs:domain ind:ProsecutionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Brief summary of the applicants response or the substance of the office action. Captures key arguments, amendments, or examiner positions for quick reference.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketDeadlineId rdf:type rdf:Property ;
    rdfs:label 'Docket Deadline Id' ;
    rdfs:comment 'Unique identifier for the docket deadline record. Primary key for the docket deadline entity.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Deadline Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the docketing clerk or paralegal responsible for monitoring and managing this deadline in the docketing system.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryIpAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Ip Asset Id' ;
    rdfs:comment 'FK to ip.ip_asset.ip_asset_id — Every docketed deadline relates to a specific IP asset. This is critical for deadline management — you must know which asset a deadline belongs to.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAsset .

ind:primaryProsecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Prosecution Event Id' ;
    rdfs:comment 'FK to ip.prosecution_event.prosecution_event_id — Many deadlines are triggered by prosecution events (e.g., office action response deadline). This FK enables deadline calculation from triggering events.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProsecutionEvent .

ind:triggeringProsecutionEventId rdf:type rdf:Property ;
    rdfs:label 'Triggering Prosecution Event Id' ;
    rdfs:comment 'FK to ip.prosecution_event.prosecution_event_id — Many deadlines are triggered by prosecution events (e.g., office action received triggers response deadline). This FK enables automated deadline calculation from prosecution events.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProsecutionEvent .

ind:calculatedDueDate rdf:type rdf:Property ;
    rdfs:label 'Calculated Due Date' ;
    rdfs:comment 'Rule-based calculated due date for the deadline, derived from statutory rules, office action issuance date, priority date, or other triggering event. This is the baseline due date before any extensions.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientInstructionReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Client Instruction Received Date' ;
    rdfs:comment 'Date on which client instructions regarding this deadline were received (e.g., instruction to file response, instruction to abandon, instruction to pay annuity). Nullable if client instruction is not yet received or not required.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientInstructionSummary rdf:type rdf:Property ;
    rdfs:label 'Client Instruction Summary' ;
    rdfs:comment 'Summary of client instructions regarding this deadline. Confidential and subject to Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date on which the client was notified of this deadline. Used to demonstrate compliance with duty to inform client and for Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Confirmation Number' ;
    rdfs:comment 'Confirmation or receipt number issued by the patent office or payment processor upon completion of the required action (e.g., filing receipt number, payment transaction ID).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Deadline Description' ;
    rdfs:comment 'Detailed textual description of the deadline, including the specific action required (e.g., Respond to Office Action - Claim Rejection, Pay 5th Year Annuity, Enter National Phase in USA).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineForAsset rdf:type rdf:Property ;
    rdfs:label 'Deadline For Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Every docketed deadline relates to a specific IP asset. This is mission-critical — deadline management without asset linkage is operationally useless.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineType rdf:type rdf:Property ;
    rdfs:label 'Deadline Type' ;
    rdfs:comment 'Classification of the deadline. Indicates whether it is a statutory deadline, office action response, annuity/renewal payment, Patent Cooperation Treaty (PCT) national phase entry (30/31 month), opposition filing window, or other IP-specific deadline type. [ENUM-REF-CANDIDATE: statutory|office_action_response|annuity_payment|renewal_payment|pct_national_phase_entry|opposition_filing|priority_claim|divisional_filing|continuation_filing|appeal_filing|hearing_date|examination_request — promote to reference product]' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketSystemCode rdf:type rdf:Property ;
    rdfs:label 'Docket System Code' ;
    rdfs:comment 'External identifier for this deadline in the IP docketing system of record (e.g., CPI, Anaqua, PatSnap). Used for system integration and reconciliation.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationNotes rdf:type rdf:Property ;
    rdfs:label 'Escalation Notes' ;
    rdfs:comment 'Confidential notes documenting the circumstances of a missed deadline, remediation actions taken, and communications with client or insurance carrier. Subject to Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Extended due date if an extension of time has been requested and granted. Nullable if no extension applies. Represents the final enforceable deadline.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Amount' ;
    rdfs:comment 'Monetary amount of the extension fee required to extend the deadline, if applicable. Nullable if no extension fee applies.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the extension fee amount (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionFeeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Fee Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether an extension fee must be paid to obtain the extended due date. True if fee is required, False otherwise.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedDeadlineEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Missed Deadline Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether a missed deadline has been escalated to management, risk committee, or malpractice insurance carrier. True if escalated, False otherwise.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedDeadlineFlag rdf:type rdf:Property ;
    rdfs:label 'Missed Deadline Flag' ;
    rdfs:comment 'Boolean flag indicating whether this deadline was missed. True if the deadline passed without completion, False otherwise. Mission-critical for malpractice risk tracking.' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSchedule rdf:type rdf:Property ;
    rdfs:label 'Reminder Schedule' ;
    rdfs:comment 'Cascade schedule for deadline reminders, typically expressed as days before due date (e.g., 90,60,30,14,7,3,1 indicating reminders at 90 days, 60 days, 30 days, 14 days, 7 days, 3 days, and 1 day before the deadline).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryRuleReference rdf:type rdf:Property ;
    rdfs:label 'Statutory Rule Reference' ;
    rdfs:comment 'Citation to the statutory rule, regulation, or patent office practice that defines this deadline (e.g., 37 CFR 1.136, EPC Rule 71(3), PCT Article 22(1)).' ;
    rdfs:domain ind:DocketDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ip Payment Id' ;
    rdfs:comment 'Primary key for payment' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipCreatedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Ip Created By User Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who created the payment record in the system.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:ipModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Ip Modified By User Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who last modified the payment record in the system.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:ledgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_ledger_entry. Business justification: Annuity and royalty payments for IP assets are commonly disbursed from trust accounts. Links IP payment records to specific trust ledger entries for three-way reconciliation, regulatory compliance (IO' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:paymentOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Payment Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user or timekeeper who approved the payment for processing.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:auditAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Adjustment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this payment record has been adjusted as a result of an audit review or correction. True if adjusted, False otherwise.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Audit Adjustment Reason' ;
    rdfs:comment 'Explanation or reason for any audit adjustment made to the payment record. Populated only when audit_adjustment_flag is True.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Ip Office Code' ;
    rdfs:comment 'Code or identifier of the IP office or jurisdiction where the payment was submitted (e.g., USPTO, EPO, JPO, WIPO).' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction where the IP asset is registered and the payment is applicable.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Late Payment Flag' ;
    rdfs:comment 'Boolean flag indicating whether the payment was made after the official due date. True if late, False if on time. Used for lapse risk monitoring and performance tracking.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Payment Surcharge Amount' ;
    rdfs:comment 'Additional surcharge or penalty amount assessed for late payment beyond the official due date. Common for annuity and maintenance fee payments.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net payment amount after deducting withholding tax and adding any surcharges. Represents the actual amount paid or received.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date the payment was made or received. Used for reconciliation, revenue recognition, and audit trail.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction. Pending: awaiting processing. Scheduled: scheduled for future payment. Paid: successfully completed. Failed: payment attempt failed. Cancelled: payment cancelled before execution. Refunded: payment reversed and refunded. Disputed: payment under dispute or audit review. [ENUM-REF-CANDIDATE: pending|scheduled|paid|failed|cancelled|refunded|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment transaction type. Annuity: periodic fee to maintain IP rights. Maintenance fee: official fee to keep IP registration active. Renewal fee: fee to renew IP registration. Royalty inbound: royalty received from licensee. Royalty outbound: royalty paid to licensor. Surcharge: late payment penalty or official surcharge. Milestone: contractual milestone payment. FRAND commitment: Fair Reasonable and Non-Discriminatory licensing payment. Filing fee: initial application fee. Examination fee: substantive examination fee. [ENUM-REF-CANDIDATE: annuity|maintenance_fee|renewal_fee|royalty_inbound|royalty_outbound|surcharge|milestone|frand_commitment|filing_fee|examination_fee — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of payment reconciliation against bank statements, IP office receipts, or license agreement terms. Unreconciled: not yet matched. Reconciled: fully matched and verified. Partially reconciled: partial match requiring further review. Disputed: discrepancy identified requiring resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Amount' ;
    rdfs:comment 'Base amount (e.g., net sales, gross revenue, units sold) upon which the royalty rate is applied. Applicable only for royalty payment types.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Royalty Period End Date' ;
    rdfs:comment 'End date of the reporting period for which royalty is calculated and paid. Applicable only for royalty payment types.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Royalty Period Start Date' ;
    rdfs:comment 'Start date of the reporting period for which royalty is calculated and paid. Applicable only for royalty payment types.' ;
    rdfs:domain ind:IpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Percentage rate applied to the royalty base to calculate the royalty payment amount. Applicable only for royalty payment types.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the payment, typically applicable to cross-border royalty payments. Used for tax compliance and net payment calculation.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Agreement Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this IP license agreement record in the system.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:disputeDocketId rdf:type rdf:Property ;
    rdfs:label 'Dispute Docket Id' ;
    rdfs:comment 'Foreign key linking to court.docket. Business justification: License disputes (breach, royalty calculation, scope interpretation, FRAND obligations) frequently result in litigation. Direct link from license_agreement to court docket tracks these disputes, enabl' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Docket .

ind:escrowArrangementId rdf:type rdf:Property ;
    rdfs:label 'Escrow Arrangement Id' ;
    rdfs:comment 'Foreign key linking to trust.escrow_arrangement. Business justification: High-value IP licenses frequently use escrow for source code deposits, technology transfer security, or payment guarantees. Links license agreements to escrow arrangements for tracking release conditi' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EscrowArrangement .

ind:licenseModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'License Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this IP license agreement record in the system.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the IP license agreement, used for client communication and filing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Discriminator classifying the type of IP agreement. [ENUM-REF-CANDIDATE: exclusive_license|non_exclusive_license|sole_license|cross_license|compulsory_license|frand_license|invention_assignment|co_ownership_agreement|joint_development_agreement|technology_transfer_agreement|ip_indemnification_agreement|confidentiality_agreement_with_ip_terms|settlement_agreement_with_ip_covenants — promote to reference product]' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Description of the licensors rights to audit the licensees records to verify royalty calculations and compliance.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Summary of confidentiality obligations related to proprietary information exchanged under the agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Method specified in the agreement for resolving disputes between the parties.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Reference to the location in the Document Management System (DMS) where the executed agreement and related documents are stored.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of any exclusivity provisions, including exclusive territories, fields of use, or time periods during which the licensee has exclusive rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOfUse rdf:type rdf:Property ;
    rdfs:label 'Field Of Use' ;
    rdfs:comment 'Specific industry, application, or market segment in which the licensee is permitted to use the licensed IP.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Royalty Amount' ;
    rdfs:comment 'Fixed monetary amount payable under the license agreement, if applicable. Nullable for non-fixed structures.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementRights rdf:type rdf:Property ;
    rdfs:label 'Improvement Rights' ;
    rdfs:comment 'Terms governing ownership and licensing of improvements, modifications, or derivative works created under the agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationTerms rdf:type rdf:Property ;
    rdfs:label 'Indemnification Terms' ;
    rdfs:comment 'Summary of indemnification obligations, including IP infringement indemnities and liability caps.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyObligations rdf:type rdf:Property ;
    rdfs:label 'Key Obligations' ;
    rdfs:comment 'Summary of the principal obligations of each party under the agreement, including performance milestones, reporting requirements, and quality standards.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseCoversAsset rdf:type rdf:Property ;
    rdfs:label 'License Covers Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — License agreements grant rights to specific IP assets. This is a many-to-many relationship but the FK from license to asset (or junction) is essential for portfolio encumbrance analysis.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensedIpAssets rdf:type rdf:Property ;
    rdfs:label 'Licensed Ip Assets' ;
    rdfs:comment 'Description or enumeration of the specific IP assets covered by this agreement (patents, trademarks, copyrights, trade secrets). May reference IP asset identifiers.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the party receiving the IP license or acquiring IP rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Legal name of the party granting the IP license or assigning IP rights.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMilestones rdf:type rdf:Property ;
    rdfs:label 'Performance Milestones' ;
    rdfs:comment 'Key performance milestones or deliverables required under the agreement, particularly relevant for joint development or technology transfer agreements.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Description of the conditions and process for renewing the license agreement upon expiry, including notice periods and renewal fees.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Royalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for royalty payments.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStructure rdf:type rdf:Property ;
    rdfs:label 'Royalty Structure' ;
    rdfs:comment 'Type of royalty or payment structure governing compensation under the license agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted Flag' ;
    rdfs:comment 'Indicates whether the licensee is permitted to grant sublicenses to third parties under this agreement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationProvisions rdf:type rdf:Property ;
    rdfs:label 'Termination Provisions' ;
    rdfs:comment 'Summary of the conditions under which either party may terminate the agreement, including breach, insolvency, or convenience termination clauses.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic scope of the license, specifying countries or regions where the licensed IP may be used. Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Summary of warranties provided by the licensor regarding IP ownership, validity, and non-infringement.' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique identifier for the royalty payment transaction. Primary key for the royalty payment record.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRoyaltyOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Primary Royalty Organisation Id' ;
    rdfs:comment 'Reference to the party making the royalty payment (the licensee using the IP).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:receiptId rdf:type rdf:Property ;
    rdfs:label 'Receipt Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_receipt. Business justification: When royalty payments are received into trust accounts (common in IP licensing), links the royalty payment record to the trust receipt for AML/KYC compliance, source-of-funds verification, and reconci' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receipt .

ind:royaltyModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Royalty Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user or system account that last modified the royalty payment record.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:royaltyReportId rdf:type rdf:Property ;
    rdfs:label 'Royalty Report Id' ;
    rdfs:comment 'Reference to the royalty report submitted by the licensee that supports this royalty payment.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyReport .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any adjustment amount applied to the calculated royalty (e.g., audit adjustments, true-up adjustments, credits, or penalties).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date on which the royalty payment or underlying royalty calculation was audited.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings from the royalty audit, including any discrepancies, adjustments, or compliance issues identified.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Boolean indicator of whether this royalty payment has been subject to audit or requires audit review.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'The gross royalty amount calculated by applying the royalty rate to the royalty base, before any adjustments, withholdings, or deductions.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether the royalty payment is inbound (received by the firm) or outbound (paid by the firm).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual due date by which the royalty payment should be made according to the license agreement.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the royalty payment, including special circumstances, disputes, or clarifications.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'End date of the reporting period for which royalties are calculated and paid.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'Start date of the reporting period for which royalties are calculated and paid.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number or transaction identifier for the royalty payment, used for reconciliation and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the royalty payment was reconciled with the royalty report and license agreement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyBaseType rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Type' ;
    rdfs:comment 'The basis on which royalty is calculated (e.g., net sales, gross sales, units sold, revenue, profit, fixed fee, or minimum guarantee). [ENUM-REF-CANDIDATE: net_sales|gross_sales|units_sold|revenue|profit|fixed_fee|minimum_guarantee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'The percentage or per-unit rate applied to the royalty base to calculate the royalty amount. Expressed as a decimal (e.g., 0.05 for 5%).' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The percentage rate of withholding tax applied to the royalty payment, as per tax treaty or domestic law.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predecessorOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Ownership Id' ;
    rdfs:comment 'Reference to the previous ownership record in the chain of title. Enables reconstruction of the complete ownership history for due diligence purposes.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:assignmentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Document Reference' ;
    rdfs:comment 'Reference identifier or document management system (DMS) link to the legal assignment agreement or deed of assignment that evidences the ownership transfer.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Legal basis or mechanism by which ownership was acquired. Distinguishes between original application, assignment, merger/acquisition, inheritance, court order, license conversion, or other mechanisms. [ENUM-REF-CANDIDATE: original_applicant|assignment|merger_acquisition|inheritance|court_order|license_conversion|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Identifier' ;
    rdfs:comment 'Unique identifier for the beneficial owner (e.g., tax ID, national ID, passport number). Required for KYC and AML compliance.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerName rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Name' ;
    rdfs:comment 'Name of the ultimate beneficial owner if different from the legal owner. Required for Anti-Money Laundering (AML) and Know Your Client (KYC) compliance.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:considerationAmount rdf:type rdf:Property ;
    rdfs:label 'Consideration Amount' ;
    rdfs:comment 'Monetary consideration paid for the assignment or transfer of ownership rights. May be zero for assignments without monetary consideration (e.g., employment agreements).' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationCurrency rdf:type rdf:Property ;
    rdfs:label 'Consideration Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the consideration amount. Required when consideration_amount is non-zero.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandCommitmentReference rdf:type rdf:Property ;
    rdfs:label 'Frand Commitment Reference' ;
    rdfs:comment 'Reference to the FRAND commitment or declaration made to the relevant standards development organization (SDO).' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentOwner rdf:type rdf:Property ;
    rdfs:label 'Is Current Owner' ;
    rdfs:comment 'Flag indicating whether this record represents the current owner of the IP asset. True for the active ownership record, false for historical records.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Ownership Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to joint ownership by multiple parties. True if multiple ownership records exist for the same IP asset.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseBackFlag rdf:type rdf:Property ;
    rdfs:label 'License Back Flag' ;
    rdfs:comment 'Indicates whether the assignment includes a license-back provision allowing the assignor to continue using the IP. Common in employment and M&A contexts.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseBackTerms rdf:type rdf:Property ;
    rdfs:label 'License Back Terms' ;
    rdfs:comment 'Summary of the license-back terms if applicable, including scope, duration, and any royalty obligations.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofAsset rdf:type rdf:Property ;
    rdfs:label 'Of Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Ownership records establish chain of title for specific IP assets. Essential for assignment tracking and M&A due diligence.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Email' ;
    rdfs:comment 'Primary email address for correspondence with the owner regarding this IP ownership record.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
    rdfs:comment 'Primary telephone number for contacting the owner regarding this IP ownership record.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country of domicile or incorporation of the owner entity.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEntityName rdf:type rdf:Property ;
    rdfs:label 'Owner Entity Name' ;
    rdfs:comment 'Full legal name of the entity or individual that holds ownership rights in the IP asset. May be an individual inventor, corporate assignee, joint owner, or government entity.' ;
    rdfs:domain ind:Ip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of the ownership entity type. Distinguishes between individual inventors, corporate assignees, joint owners, government entities, universities, and trusts.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of the ownership record. Tracks whether ownership is active, pending recordal, transferred to another party, terminated, under dispute, or lapsed.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage of ownership interest held by this owner in the IP asset. For sole ownership, this is 100.00. For joint ownership, reflects the proportional share.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordalDate rdf:type rdf:Property ;
    rdfs:label 'Recordal Date' ;
    rdfs:comment 'Date on which the ownership assignment was officially recorded with the relevant IP office or registry. Critical for establishing priority and chain of title.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordalNumber rdf:type rdf:Property ;
    rdfs:label 'Recordal Number' ;
    rdfs:comment 'Official recordal or registration number issued by the IP office when the ownership assignment was recorded. Used for verification and audit purposes.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Security Interest Description' ;
    rdfs:comment 'Description of any security interest, lien, or encumbrance affecting the IP ownership. Includes details of the secured party and nature of the security.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Security Interest Flag' ;
    rdfs:comment 'Indicates whether the IP asset is subject to a security interest, lien, or encumbrance that affects ownership rights. True if security interest exists.' ;
    rdfs:domain ind:Ownership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Assignment Executed Flag' ;
    rdfs:comment 'Indicates whether the inventor has executed a formal assignment of patent rights to the employer or assignee. Critical for chain of title verification.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Execution Date' ;
    rdfs:comment 'Date on which the inventor signed the patent assignment document transferring rights to the assignee.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentRecordationNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Recordation Number' ;
    rdfs:comment 'USPTO or patent office recordation number for the assignment document. Used to verify chain of title in patent prosecution and litigation.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptionDate rdf:type rdf:Property ;
    rdfs:label 'Conception Date' ;
    rdfs:comment 'Date on which the inventor conceived the complete and operative invention. Used for priority determination in interference and derivation proceedings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionDescription rdf:type rdf:Property ;
    rdfs:label 'Contribution Description' ;
    rdfs:comment 'Detailed description of the inventors specific contribution to the conception of the claimed invention. Used for inventorship determination and correction of inventorship proceedings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'Date of death of the inventor, if applicable. Triggers substitute statement requirements for pending applications.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:derivationProceedingNumber rdf:type rdf:Property ;
    rdfs:label 'Derivation Proceeding Number' ;
    rdfs:comment 'USPTO Patent Trial and Appeal Board (PTAB) proceeding number for any derivation proceeding involving this inventor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerAtInvention rdf:type rdf:Property ;
    rdfs:label 'Employer At Invention' ;
    rdfs:comment 'Name of the organization employing the inventor at the time the invention was conceived. Critical for determining assignment rights and work-for-hire status.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Employment Agreement Reference' ;
    rdfs:comment 'Reference identifier or document number for the employment agreement containing IP assignment provisions. Used to verify pre-invention assignment obligations.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Last or family name of the inventor. Used for structured name parsing in international patent filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullLegalName rdf:type rdf:Property ;
    rdfs:label 'Full Legal Name' ;
    rdfs:comment 'Complete legal name of the inventor as it appears on patent applications and grants. Used for inventorship determination and official USPTO/EPO/WIPO filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'First or given name of the inventor. Used for structured name parsing in international patent filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Invention Disclosure Date' ;
    rdfs:comment 'Date on which the inventor formally disclosed the invention to the employer or patent counsel. Establishes priority date for derivation proceedings and assignment chain.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventorStatus rdf:type rdf:Property ;
    rdfs:label 'Inventor Status' ;
    rdfs:comment 'Current lifecycle status of the inventor record. Affects ability to obtain signatures for continuation applications and assignment documents.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorshipDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Inventorship Dispute Flag' ;
    rdfs:comment 'Indicates whether this inventor is involved in an inventorship dispute, derivation proceeding, or correction of inventorship petition.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointInventorFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Inventor Flag' ;
    rdfs:comment 'Indicates whether this inventor is one of multiple joint inventors on one or more patent applications. Joint inventors must each contribute to the conception of at least one claim.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Name' ;
    rdfs:comment 'Name of the legal representative (executor, administrator, guardian) authorized to act on behalf of a deceased or incapacitated inventor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the inventors nationality. Required for PCT applications and determines eligibility for certain patent prosecution highways.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oathDeclarationDate rdf:type rdf:Property ;
    rdfs:label 'Oath Declaration Date' ;
    rdfs:comment 'Date on which the inventor executed the oath or declaration for the patent application.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oathDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Oath Declaration Status' ;
    rdfs:comment 'Status of the inventors oath or declaration required for patent application filing. Indicates whether the inventor has sworn to the accuracy of the application.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidIdentifier rdf:type rdf:Property ;
    rdfs:label 'Orcid Identifier' ;
    rdfs:comment 'Unique persistent digital identifier for the inventor as a researcher. Facilitates disambiguation of inventor names across patent offices and academic publications.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtDisclosureObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Art Disclosure Obligation Flag' ;
    rdfs:comment 'Indicates whether the inventor has an ongoing duty to disclose known prior art material to patentability under the duty of candor.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residenceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Residence Address Line 1' ;
    rdfs:comment 'Primary street address line of the inventors residence. Required for inventor oath or declaration filings.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Residence Address Line 2' ;
    rdfs:comment 'Secondary street address line of the inventors residence (apartment, suite, building number).' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceCity rdf:type rdf:Property ;
    rdfs:label 'Residence City' ;
    rdfs:comment 'City or municipality of the inventors residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Residence Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the inventors country of residence at time of invention. Determines applicable patent law jurisdiction and filing requirements.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residencePostalCode rdf:type rdf:Property ;
    rdfs:label 'Residence Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the inventors residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Residence State Province' ;
    rdfs:comment 'State, province, or administrative region of the inventors residence address.' ;
    rdfs:domain ind:Inventor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abstractText rdf:type rdf:Property ;
    rdfs:label 'Abstract Text' ;
    rdfs:comment 'Brief technical summary of the invention from the priority or representative application. Typically 150-300 words describing the technical problem, solution, and key features.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIndicator rdf:type rdf:Property ;
    rdfs:label 'Active Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family record is currently active in the system. True for active records, False for archived or soft-deleted records. Used for data retention and reporting filters.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Legal name of the applicant (assignee) for the priority application. Typically the corporate entity owning the IP rights. Business-confidential.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuationChainIndicator rdf:type rdf:Property ;
    rdfs:label 'Continuation Chain Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes continuation, continuation-in-part, or divisional applications. True if continuation chain exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpcClass rdf:type rdf:Property ;
    rdfs:label 'Cpc Class' ;
    rdfs:comment 'Primary CPC classification code. Joint classification system developed by EPO and USPTO providing more granular technical categorization than IPC.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionalChainIndicator rdf:type rdf:Property ;
    rdfs:label 'Divisional Chain Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes divisional applications filed to pursue distinct inventions disclosed in a parent application. True if divisional chain exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:docketingSystemReference rdf:type rdf:Property ;
    rdfs:label 'Docketing System Reference' ;
    rdfs:comment 'External reference identifier in the IP docketing system (e.g., CPI, Foundation IP, Alt Legal) used for deadline management and prosecution tracking. Enables cross-system reconciliation.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Family Identifier' ;
    rdfs:comment 'Externally-known unique identifier for the patent family, typically assigned by the IP management system or patent office. Used for cross-system reference and client communication.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current overall status of the patent family. Active (at least one granted and in-force patent), Pending (applications under prosecution), Expired (all patents reached end of term), Abandoned (all applications withdrawn or rejected), Lapsed (all patents lapsed due to non-payment).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the patent family structure. Simple (Paris Convention family sharing same priority), Extended (INPADOC family including all related applications), Complete (all documents sharing technical content).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandObligationIndicator rdf:type rdf:Property ;
    rdfs:label 'Frand Obligation Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family is subject to FRAND (Fair, Reasonable, and Non-Discriminatory) licensing obligations due to standard-essential patent (SEP) declarations. True if FRAND-encumbered, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Status of freedom-to-operate analysis for this patent family. Clear (no blocking patents identified), Risk_identified (potential infringement risk found), Under_review (FTO analysis in progress), Not_assessed (no FTO performed). Business-confidential strategic information.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionTitle rdf:type rdf:Property ;
    rdfs:label 'Invention Title' ;
    rdfs:comment 'The title of the invention as disclosed in the priority or representative application. Used for quick identification and portfolio reporting.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClass rdf:type rdf:Property ;
    rdfs:label 'Ipc Class' ;
    rdfs:comment 'Primary IPC classification code assigned to this patent family. Hierarchical classification system used worldwide for categorizing patent documents by technical field.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationInvolvementIndicator rdf:type rdf:Property ;
    rdfs:label 'Litigation Involvement Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family is currently or has been involved in patent litigation, opposition, or inter partes review proceedings. True if litigation history exists, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberJurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Member Jurisdiction Count' ;
    rdfs:comment 'Total number of distinct jurisdictions (countries or patent offices) where patent applications or grants exist as members of this family. Indicates geographic breadth of protection.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAnnuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Annuity Due Date' ;
    rdfs:comment 'Earliest upcoming annuity or maintenance fee due date across all active family members. Critical for IP docketing and cash flow planning.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionCount rdf:type rdf:Property ;
    rdfs:label 'Opposition Count' ;
    rdfs:comment 'Total number of opposition or post-grant review proceedings filed against patents in this family. Indicator of competitive interest and patent strength.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctApplicationIndicator rdf:type rdf:Property ;
    rdfs:label 'Pct Application Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family includes a PCT international application. True if PCT route was used, False otherwise. Critical for understanding prosecution strategy and timeline.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pphEligibilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Pph Eligibility Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this family is eligible for accelerated examination under Patent Prosecution Highway agreements based on allowance in a participating office. True if eligible, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Priority Application Number' ;
    rdfs:comment 'The application number of the earliest filing (priority application) that establishes the priority date for this patent family. Format typically includes country code and serial number.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Priority Country Code' ;
    rdfs:comment 'ISO country code of the jurisdiction where the priority application was filed. Three-letter ISO 3166-1 alpha-3 format.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system from which this patent family record originated (e.g., Elite 3E, IP docketing system, patent office data feed). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardEssentialPatentIndicator rdf:type rdf:Property ;
    rdfs:label 'Standard Essential Patent Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this patent family has been declared as essential to one or more technical standards. True if declared as SEP, False otherwise.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicImportanceRating rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Rating' ;
    rdfs:comment 'Business assessment of the strategic value of this patent family to the clients IP portfolio. Used for prioritization of prosecution spend, licensing strategy, and portfolio pruning decisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'Primary key for valuation' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appraiserCredentials rdf:type rdf:Property ;
    rdfs:label 'Appraiser Credentials' ;
    rdfs:comment 'Professional credentials of the appraiser (e.g., ASA, CFA, ABV, CVA) demonstrating qualification to perform IP valuations.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserFirm rdf:type rdf:Property ;
    rdfs:label 'Appraiser Firm' ;
    rdfs:comment 'Name of the valuation firm or organization that performed the IP valuation (e.g., Big Four accounting firm, boutique IP valuation consultancy).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserName rdf:type rdf:Property ;
    rdfs:label 'Appraiser Name' ;
    rdfs:comment 'Full name of the lead valuation professional who conducted the appraisal.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Key assumptions underlying the valuation (e.g., revenue growth rates, market penetration, competitive landscape, technology obsolescence risk). Critical for understanding valuation limitations.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparableTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Comparable Transaction Count' ;
    rdfs:comment 'Number of comparable market transactions used in market approach valuation. Nullable if market approach was not used.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The discount rate (expressed as a percentage) applied in income-based valuation methods to present-value future cash flows. Reflects risk-adjusted cost of capital.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frandConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Consideration Flag' ;
    rdfs:comment 'Indicates whether FRAND licensing obligations were factored into the valuation (relevant for standard-essential patents).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitations rdf:type rdf:Property ;
    rdfs:label 'Limitations' ;
    rdfs:comment 'Documented limitations or caveats of the valuation (e.g., limited market data, pending litigation, regulatory uncertainty, technology disruption risk).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationImpactAdjustment rdf:type rdf:Property ;
    rdfs:label 'Litigation Impact Adjustment' ;
    rdfs:comment 'Adjustment amount (positive or negative) applied to valuation to account for pending or threatened litigation affecting the IP asset. Nullable if no litigation impact.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Portfolio Allocation Percentage' ;
    rdfs:comment 'Percentage of total IP portfolio value represented by this asset, used for portfolio strategy and risk management.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'The business reason for conducting the valuation (M&A due diligence, licensing negotiation, litigation damages assessment, balance sheet reporting under ASC 350, portfolio strategy, tax planning, bankruptcy proceedings, or financing collateral). [ENUM-REF-CANDIDATE: mergers_and_acquisitions|licensing_negotiation|litigation_damages|balance_sheet_reporting|portfolio_strategy|tax_planning|bankruptcy|financing — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPath rdf:type rdf:Property ;
    rdfs:label 'Report Path' ;
    rdfs:comment 'File path or document management system (DMS) reference to the full valuation report (typically stored in iManage Work or NetDocuments).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueProjectionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Revenue Projection Period Years' ;
    rdfs:comment 'Number of years over which revenue projections were modeled in income approach valuation (typically 5-10 years).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxAmortizationBenefitFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Amortization Benefit Flag' ;
    rdfs:comment 'Indicates whether the valuation incorporated tax amortization benefits (relevant for certain IP acquisitions under IRC Section 197).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalValueMethod rdf:type rdf:Property ;
    rdfs:label 'Terminal Value Method' ;
    rdfs:comment 'Method used to calculate terminal value in discounted cash flow analysis: perpetuity growth model, exit multiple, or none (if asset has finite life).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'The estimated remaining useful economic life of the IP asset in years, used for amortization and valuation projections.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Number' ;
    rdfs:comment 'Business identifier for the valuation engagement, typically assigned by the valuation firm or internal finance team.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle status of the valuation: draft (in preparation), under_review (submitted for partner or client review), approved (finalized and accepted), rejected (not accepted), superseded (replaced by a newer valuation).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionProceedingId rdf:type rdf:Property ;
    rdfs:label 'Opposition Proceeding Id' ;
    rdfs:comment 'Unique identifier for the opposition proceeding record. Primary key.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oppositionModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Opposition Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this opposition proceeding record.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:proceedingOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Proceeding Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this opposition proceeding record.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actualCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the actual cost amount.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmendmentsProposedFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Amendments Proposed Flag' ;
    rdfs:comment 'Indicates whether the patent owner has proposed amendments to the challenged claims during the proceeding.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsAtIssue rdf:type rdf:Property ;
    rdfs:label 'Claims At Issue' ;
    rdfs:comment 'Specific patent claims or trademark goods/services classes being challenged in the opposition.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated total cost to defend or prosecute the opposition proceeding.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundsOfChallenge rdf:type rdf:Property ;
    rdfs:label 'Grounds Of Challenge' ;
    rdfs:comment 'Legal grounds cited for challenging the IP asset (e.g., anticipation, obviousness, non-use, descriptiveness, likelihood of confusion).' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionDate rdf:type rdf:Property ;
    rdfs:label 'Institution Date' ;
    rdfs:comment 'Date the tribunal formally instituted the proceeding (applicable to IPR, PGR, CBM reviews).' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadCounselName rdf:type rdf:Property ;
    rdfs:label 'Lead Counsel Name' ;
    rdfs:comment 'Name of the lead counsel representing the client in this opposition proceeding.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionAgainstAsset rdf:type rdf:Property ;
    rdfs:label 'Opposition Against Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Opposition proceedings challenge specific IP assets. Essential for portfolio risk assessment and defensive strategy.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oppositionProceedingStatus rdf:type rdf:Property ;
    rdfs:label 'Opposition Proceeding Status' ;
    rdfs:comment 'Current lifecycle status of the opposition proceeding. [ENUM-REF-CANDIDATE: filed|instituted|pending|settled|decided|appealed|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:petitionerName rdf:type rdf:Property ;
    rdfs:label 'Petitioner Name' ;
    rdfs:comment 'Name of the party challenging the IP asset (petitioner in IPR/PGR, opponent in EPO opposition, opposer in trademark opposition).' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proceedingNumber rdf:type rdf:Property ;
    rdfs:label 'Proceeding Number' ;
    rdfs:comment 'Official proceeding number assigned by the tribunal or board (e.g., IPR2023-00123, Opposition No. 91234567).' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentName rdf:type rdf:Property ;
    rdfs:label 'Respondent Name' ;
    rdfs:comment 'Name of the party defending the IP asset (patent owner, trademark registrant).' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Level' ;
    rdfs:comment 'Internal risk assessment level for the potential impact of this opposition on the IP portfolio.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Strategic importance rating of the IP asset subject to opposition for the clients business or portfolio.' ;
    rdfs:domain ind:OppositionProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secretOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Secret Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this trade secret record in the system.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tradeModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Trade Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this trade secret record in the system.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:accessControlMeasures rdf:type rdf:Property ;
    rdfs:label 'Access Control Measures' ;
    rdfs:comment 'Detailed description of technical and administrative access control measures in place, including access control lists, role-based permissions, multi-factor authentication, and need-to-know protocols.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtsaProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Dtsa Protection Flag' ;
    rdfs:comment 'Indicates whether this trade secret qualifies for protection under the federal Defend Trade Secrets Act (DTSA). True if DTSA protection applies, false otherwise.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:economicValueAmount rdf:type rdf:Property ;
    rdfs:label 'Economic Value Amount' ;
    rdfs:comment 'Estimated economic value or competitive advantage derived from this trade secret, expressed in monetary terms. Used for portfolio valuation and litigation damages assessment.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Economic Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the economic value amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAccessCount rdf:type rdf:Property ;
    rdfs:label 'Employee Access Count' ;
    rdfs:comment 'Number of employees or contractors who currently have authorized access to this trade secret under need-to-know protocols.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptionFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Flag' ;
    rdfs:comment 'Indicates whether the trade secret information is stored and transmitted using encryption. True if encryption is applied, false otherwise.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent security audit or compliance review conducted for this trade secret to verify that reasonable protective measures are in place and effective.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:misappropriationIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Misappropriation Incident Count' ;
    rdfs:comment 'Number of documented incidents of attempted or actual misappropriation, unauthorized disclosure, or security breaches involving this trade secret.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:misappropriationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Misappropriation Risk Level' ;
    rdfs:comment 'Assessment of the risk that this trade secret could be misappropriated, stolen, or improperly disclosed: low (minimal risk), medium (moderate risk), high (elevated risk), or critical (imminent or severe risk).' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiJurisdictionFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Jurisdiction Flag' ;
    rdfs:comment 'Indicates whether this trade secret is protected under the laws of multiple jurisdictions. True if multi-jurisdictional protection applies, false if single jurisdiction only.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaCount rdf:type rdf:Property ;
    rdfs:label 'Nda Count' ;
    rdfs:comment 'Number of executed NDA agreements currently in force that cover access to this trade secret.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndaCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Coverage Flag' ;
    rdfs:comment 'Indicates whether access to this trade secret is governed by executed NDA agreements with all parties having access. True if NDA coverage is in place, false otherwise.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic security audit or compliance review of protective measures for this trade secret.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Physical Security Measures' ;
    rdfs:comment 'Description of physical security controls protecting the trade secret, including locked storage, restricted access areas, surveillance systems, and visitor controls.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Risk Flag' ;
    rdfs:comment 'Indicates whether there is a known risk that this trade secret may become publicly disclosed through reverse engineering, independent discovery, or other means. True if disclosure risk exists, false otherwise.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonableMeasuresDocumentation rdf:type rdf:Property ;
    rdfs:label 'Reasonable Measures Documentation' ;
    rdfs:comment 'Comprehensive documentation of all reasonable measures taken to maintain the secrecy of this information, as required for trade secret protection under DTSA and UTSA. Includes policies, procedures, training records, and enforcement actions.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyAccessCount rdf:type rdf:Property ;
    rdfs:label 'Third Party Access Count' ;
    rdfs:comment 'Number of external third parties (vendors, partners, consultants) who have been granted access to this trade secret under NDA or other contractual protections.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeSecretDescription rdf:type rdf:Property ;
    rdfs:label 'Trade Secret Description' ;
    rdfs:comment 'Detailed narrative description of the trade secret, including its nature, scope, and business application. May include proprietary formulas, processes, algorithms, customer lists, pricing methodologies, or other confidential business information.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeSecretStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Secret Status' ;
    rdfs:comment 'Current lifecycle status of the trade secret: active (currently protected and in use), inactive (no longer in active use but still protected), compromised (protection breached), disputed (subject to ownership or misappropriation dispute), under review (being evaluated for continued protection), or retired (no longer considered a trade secret).' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utsaProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Utsa Protection Flag' ;
    rdfs:comment 'Indicates whether this trade secret is protected under state-level Uniform Trade Secrets Act (UTSA) or equivalent state law. True if UTSA protection applies, false otherwise.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the trade secret was first created, developed, or came into existence. Critical for establishing priority and duration of protection under DTSA and state UTSA equivalents.' ;
    rdfs:domain ind:TradeSecret ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipAgreementId rdf:type rdf:Property ;
    rdfs:label 'Ip Agreement Id' ;
    rdfs:comment 'Unique identifier for the IP agreement record. Primary key.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arbitrationVenue rdf:type rdf:Property ;
    rdfs:label 'Arbitration Venue' ;
    rdfs:comment 'The location or institution designated for arbitration proceedings, if applicable.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRights rdf:type rdf:Property ;
    rdfs:label 'Assignment Rights' ;
    rdfs:comment 'Description of rights to assign or transfer IP ownership or interests under the agreement.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityObligations rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Obligations' ;
    rdfs:comment 'Specific confidentiality and non-disclosure obligations imposed by the agreement.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty entity type.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Agreement Description' ;
    rdfs:comment 'Detailed narrative description of the IP agreement purpose, scope, and key terms.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the IP agreement, indicating its operational state. [ENUM-REF-CANDIDATE: draft|pending_execution|executed|active|suspended|terminated|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssetsCovered rdf:type rdf:Property ;
    rdfs:label 'Ip Assets Covered' ;
    rdfs:comment 'Comma-separated list or description of the IP assets (patents, trademarks, copyrights, trade secrets) covered by this agreement.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Flag' ;
    rdfs:comment 'Indicates whether this agreement includes or is a Non-Disclosure Agreement.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyNames rdf:type rdf:Property ;
    rdfs:label 'Party Names' ;
    rdfs:comment 'Comma-separated list of all parties to the IP agreement, including legal entity names.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Pct Related Flag' ;
    rdfs:comment 'Indicates whether the agreement relates to PCT patent applications or filings.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationTerms rdf:type rdf:Property ;
    rdfs:label 'Termination Terms' ;
    rdfs:comment 'Conditions and procedures under which the agreement may be terminated by either party.' ;
    rdfs:domain ind:IpAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightId rdf:type rdf:Property ;
    rdfs:label 'Copyright Id' ;
    rdfs:comment 'Primary key for copyright' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copyrightModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Copyright Modified By User Timekeeper Id' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last modified this copyright record. Audit trail for accountability.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:copyrightOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Copyright Owner Timekeeper Id' ;
    rdfs:comment 'The user ID or system identifier of the person or process that created this copyright record. Audit trail for accountability.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the copyright registration application was filed with the copyright office. Establishes priority and filing date for registration purposes.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorNames rdf:type rdf:Property ;
    rdfs:label 'Author Names' ;
    rdfs:comment 'The name(s) of the individual(s) or entity(ies) who created the work. May include multiple authors separated by delimiters. Author information is critical for determining copyright ownership and duration.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositCopyStatus rdf:type rdf:Property ;
    rdfs:label 'Deposit Copy Status' ;
    rdfs:comment 'Status of the deposit copy requirement for copyright registration. Indicates whether the required copy of the work has been submitted to the copyright office.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivativeWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Derivative Work Flag' ;
    rdfs:comment 'Indicates whether this work is a derivative work based on one or more preexisting works. Affects copyright scope and registration requirements.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationYears rdf:type rdf:Property ;
    rdfs:label 'Duration Years' ;
    rdfs:comment 'The calculated duration of copyright protection in years from the date of creation or publication. Varies by jurisdiction and work type.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementActionCount rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Count' ;
    rdfs:comment 'The total number of enforcement actions (cease and desist letters, litigation, takedown notices) taken to protect this copyright. Used for portfolio risk assessment.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fairUseAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Use Analysis Flag' ;
    rdfs:comment 'Indicates whether a fair use analysis has been conducted for this work in relation to potential infringement claims. Relevant for enforcement strategy.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infringementDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Infringement Detected Flag' ;
    rdfs:comment 'Indicates whether any copyright infringement has been detected for this work. True if infringement monitoring has identified unauthorized use.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preexistingWorkReference rdf:type rdf:Property ;
    rdfs:label 'Preexisting Work Reference' ;
    rdfs:comment 'Reference to the preexisting work(s) upon which this derivative work is based. Includes title, author, and registration information of the underlying work.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Registration Certificate Reference' ;
    rdfs:comment 'Document reference or file path to the official copyright registration certificate issued by the copyright office. Links to the document management system (DMS).' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current status of the copyright registration with the relevant copyright office. Indicates whether the work has formal registration protection.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workMadeForHireFlag rdf:type rdf:Property ;
    rdfs:label 'Work Made For Hire Flag' ;
    rdfs:comment 'Indicates whether the work was created as a work made for hire, affecting copyright ownership and duration. True if the work was created by an employee within the scope of employment or under a written agreement.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workTitle rdf:type rdf:Property ;
    rdfs:label 'Work Title' ;
    rdfs:comment 'The title or name of the copyrighted work as registered or claimed. This is the primary human-readable identifier for the work.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'The category or type of copyrighted work. Classifies the work according to copyright law categories for registration and enforcement purposes. [ENUM-REF-CANDIDATE: literary|musical|dramatic|artistic|audiovisual|software|architectural|sound_recording|choreographic|pictorial_graphic_sculptural|compilation|derivative — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOfCreation rdf:type rdf:Property ;
    rdfs:label 'Year Of Creation' ;
    rdfs:comment 'The year in which the work was created or fixed in tangible form. Critical for determining copyright duration and term calculations.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearOfFirstPublication rdf:type rdf:Property ;
    rdfs:label 'Year Of First Publication' ;
    rdfs:comment 'The year in which the work was first published or made available to the public. Affects copyright duration and registration requirements.' ;
    rdfs:domain ind:Copyright ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementActionId rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Id' ;
    rdfs:comment 'Primary key for enforcement_action' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this enforcement action record. Audit trail field.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:enforcementModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Enforcement Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this enforcement action record. Audit trail field.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:settlementTrustAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Trust Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: Settlement proceeds from IP infringement enforcement actions must be held in trust pending distribution to clients or resolution of disputes. Role-prefixed to distinguish from other trust account rela' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:enforcementCostAmount rdf:type rdf:Property ;
    rdfs:label 'Enforcement Cost Amount' ;
    rdfs:comment 'Total cost incurred for this enforcement action, including legal fees, filing fees, investigation costs, and other related expenses.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Enforcement Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for enforcement costs.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementProtectsAsset rdf:type rdf:Property ;
    rdfs:label 'Enforcement Protects Asset' ;
    rdfs:comment 'FK to ip.asset.asset_id — Enforcement actions are initiated to protect specific IP assets. FK enables enforcement history tracking per asset.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementType rdf:type rdf:Property ;
    rdfs:label 'Enforcement Type' ;
    rdfs:comment 'Type of enforcement action initiated. Includes cease-and-desist letters, customs recordal actions, domain name dispute filings (UDRP - Uniform Domain-Name Dispute-Resolution Policy), takedown notices (DMCA - Digital Millennium Copyright Act), and infringement litigation referrals.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementVenue rdf:type rdf:Property ;
    rdfs:label 'Enforcement Venue' ;
    rdfs:comment 'Specific venue, forum, or authority where the enforcement action is filed or pursued (e.g., WIPO Arbitration Center, USPTO, specific customs authority, domain registrar).' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infringementType rdf:type rdf:Property ;
    rdfs:label 'Infringement Type' ;
    rdfs:comment 'Category of IP right being infringed. Aligns with the type of IP asset being protected.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infringingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Infringing Activity Description' ;
    rdfs:comment 'Detailed description of the alleged infringing activity, including nature of infringement, products or services involved, and evidence of unauthorized use of client IP.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationReferralDate rdf:type rdf:Property ;
    rdfs:label 'Litigation Referral Date' ;
    rdfs:comment 'Date when the enforcement action was formally referred to litigation. Null if not escalated to litigation.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:litigationReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Referral Flag' ;
    rdfs:comment 'Indicates whether this enforcement action was escalated and referred to formal litigation proceedings. Distinguishes pre-litigation enforcement from filed court cases.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'Date when a response was received from the target party, if any. Null if no response has been received.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the settlement amount.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms Summary' ;
    rdfs:comment 'High-level summary of settlement terms, including monetary compensation, licensing arrangements, cessation commitments, or other negotiated outcomes. Detailed terms stored in settlement agreement documents.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Target Party Address' ;
    rdfs:comment 'Physical or registered address of the target party for service of enforcement notices and legal correspondence.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPartyEmail rdf:type rdf:Property ;
    rdfs:label 'Target Party Email' ;
    rdfs:comment 'Email address of the target party used for electronic service of enforcement notices and communications.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPartyName rdf:type rdf:Property ;
    rdfs:label 'Target Party Name' ;
    rdfs:comment 'Name of the individual or organization alleged to be infringing the clients IP rights and targeted by this enforcement action.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetPrecedentUsageId rdf:type rdf:Property ;
    rdfs:label 'Asset Precedent Usage Id' ;
    rdfs:comment 'Primary key for the asset_precedent_usage association' ;
    rdfs:domain ind:AssetPrecedentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaptationType rdf:type rdf:Property ;
    rdfs:label 'Adaptation Type' ;
    rdfs:comment 'Classification of how extensively the precedent was modified for this specific IP asset usage (used as-is, minor edits, substantial customization, reference only). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyName rdf:type rdf:Property ;
    rdfs:label 'Attorney Name' ;
    rdfs:comment 'Name of the attorney who applied this precedent to this IP asset, for knowledge management attribution and feedback loop purposes.' ;
    rdfs:domain ind:AssetPrecedentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionsUsed rdf:type rdf:Property ;
    rdfs:label 'Sections Used' ;
    rdfs:comment 'Comma-separated list or structured reference to which sections, clauses, or components of the precedent were utilized for this IP asset (e.g., claims template, abstract, background section). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetPrecedentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDate rdf:type rdf:Property ;
    rdfs:label 'Usage Date' ;
    rdfs:comment 'The date on which this precedent was applied or referenced during the IP asset lifecycle (e.g., filing date, prosecution response date, assignment execution date). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetPrecedentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetContactAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Contact Assignment Id' ;
    rdfs:comment 'Unique identifier for this contact-to-asset assignment record. Primary key.' ;
    rdfs:domain ind:AssetContactAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'The level of decision-making authority this contact has for instructions and approvals related to this IP asset.' ;
    rdfs:domain ind:AssetContactAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryForRole rdf:type rdf:Property ;
    rdfs:label 'Is Primary For Role' ;
    rdfs:comment 'Indicates whether this contact is the primary contact for this specific role on this IP asset (e.g., primary billing contact vs. secondary billing contact).' ;
    rdfs:domain ind:AssetContactAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentProsecutionAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Patent Prosecution Assignment Id' ;
    rdfs:comment 'Unique identifier for this patent prosecution assignment record. Primary key.' ;
    rdfs:domain ind:PatentProsecutionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Responsibility Flag' ;
    rdfs:comment 'Indicates whether this timekeeper holds primary responsibility for this patent prosecution matter. Distinguishes the lead attorney or primary contact from supporting team members. This attribute was explicitly identified in the detection reasoning.' ;
    rdfs:domain ind:PatentProsecutionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prosecutionRole rdf:type rdf:Property ;
    rdfs:label 'Prosecution Role' ;
    rdfs:comment 'The specific role the timekeeper plays in this patent prosecution matter. Defines responsibility level and work type (e.g., Lead Attorney, Associate Attorney, Patent Agent, Paralegal). This attribute was explicitly identified in the detection reasoning.' ;
    rdfs:domain ind:PatentProsecutionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRoyaltyReportId rdf:type rdf:Property ;
    rdfs:label 'Prior Royalty Report Id' ;
    rdfs:comment 'Self-referencing FK on royalty_report (prior_royalty_report_id)' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyReport .

ind:reportingOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Reporting Organisation Id' ;
    rdfs:comment 'Reference to the party obligated to pay royalties under the license agreement.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:royaltyLicensorOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Royalty Licensor Organisation Id' ;
    rdfs:comment 'Reference to the party entitled to receive royalties under the license agreement.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'The date on which the audit of this royalty report was completed, if applicable.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated from the licensed intellectual property during the reporting period, before any deductions.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Royalty Amount' ;
    rdfs:comment 'The contractual minimum royalty payment guaranteed per the license agreement, regardless of actual usage or sales.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue amount after contractually permitted deductions (returns, allowances, taxes) used as the royalty calculation base.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportNotes rdf:type rdf:Property ;
    rdfs:label 'Report Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the licensee to explain report details, unusual circumstances, or clarifications.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier for the royalty report, typically used for external reference and tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the royalty report indicating its position in the review and payment workflow.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the period covered by this royalty report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this royalty report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date on which the internal review of the royalty report was completed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyAmountDue rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount Due' ;
    rdfs:comment 'The calculated royalty payment amount owed by the licensee for the reporting period.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'The percentage rate applied to the royalty base to calculate the royalty amount owed, as specified in the license agreement.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Geographic territory or jurisdiction code where the licensed IP was exploited and royalties were generated.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of units sold or licensed that generated royalty obligations during the reporting period.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withholdingTaxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Percentage' ;
    rdfs:comment 'The percentage rate of withholding tax applied to the royalty payment.' ;
    rdfs:domain ind:RoyaltyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAgreementContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Contract Agreement Id' ;
    rdfs:comment 'Reference to the parent or master agreement if this is a subsidiary agreement, amendment, or SOW. Nullable for standalone agreements.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAgreement .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the contract template from which this agreement was generated. Nullable for bespoke agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the agreement within the CLM pipeline. [ENUM-REF-CANDIDATE: Draft|Under Review|Pending Execution|Executed|Active|Suspended|Terminated|Expired|Cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether AML and KYC checks have been completed and verified for the counterparty prior to agreement execution.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level assigned to the agreement document and its contents.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the agreement as stated in the contract terms. Nullable for non-monetary agreements.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indemnityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Indemnity Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains an indemnity or hold-harmless clause.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitationOfLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Limitation Of Liability Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a limitation of liability clause.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingOffice rdf:type rdf:Property ;
    rdfs:label 'Originating Office' ;
    rdfs:comment 'Firm office or practice location that originated and owns this agreement.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPricingModelId rdf:type rdf:Property ;
    rdfs:label 'Default Pricing Model Id' ;
    rdfs:comment 'Foreign key linking to service.pricing_model. Business justification: Agreement types have default pricing models that auto-populate during engagement letter generation. Supports template configuration, new matter intake automation, and ensures consistent fee arrangemen' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingModel .

ind:agreementTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Category' ;
    rdfs:comment 'High-level classification of the agreement type by business function: client engagement (LOE, retainer), vendor/supplier (MSA, SOW), internal administrative, regulatory compliance, intellectual property (IP licensing, PCT filings), or dispute resolution (ADR, arbitration).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycRequired rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Required' ;
    rdfs:comment 'Indicates whether agreements of this type require Anti-Money Laundering (AML) and Know Your Client (KYC) checks before execution. True if AML/KYC is mandatory; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultDisputeResolution rdf:type rdf:Property ;
    rdfs:label 'Default Dispute Resolution' ;
    rdfs:comment 'Standard dispute resolution mechanism for this agreement type: litigation (court proceedings), arbitration (binding arbitration under ICC, LCIA, or other rules), mediation (facilitated negotiation), or negotiation (direct party-to-party resolution).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultGoverningLaw rdf:type rdf:Property ;
    rdfs:label 'Default Governing Law' ;
    rdfs:comment 'Default jurisdiction whose laws govern agreements of this type (e.g., New York, England and Wales, Delaware). Null if no standard governing law applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Notice Period Days' ;
    rdfs:comment 'Standard number of days required for termination or non-renewal notice for this agreement type. Null if no standard notice period applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultTermMonths rdf:type rdf:Property ;
    rdfs:label 'Default Term Months' ;
    rdfs:comment 'Standard duration in months for this agreement type. Null if the agreement type does not have a standard term (e.g., perpetual agreements or one-time transactions).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureAllowed rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Allowed' ;
    rdfs:comment 'Indicates whether agreements of this type can be executed using electronic signatures (e.g., DocuSign, Adobe Sign). True if electronic signature is legally acceptable; False if wet signature is required.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Threshold Usd' ;
    rdfs:comment 'Monetary threshold in USD above which agreements of this type require additional approval or review (e.g., partner sign-off for engagements over $100,000). Null if no financial threshold applies.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frandApplicable rdf:type rdf:Property ;
    rdfs:label 'Frand Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type are subject to Fair Reasonable and Non-Discriminatory (FRAND) licensing terms, typically for standard-essential patents. True if FRAND terms apply; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type typically involve processing of personal data subject to GDPR. True if GDPR compliance clauses are standard; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesBillingCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Code' ;
    rdfs:comment 'LEDES billing code associated with this agreement type for electronic invoice submission. Null if no specific LEDES code applies.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Milestone Tracking Required' ;
    rdfs:comment 'Indicates whether agreements of this type require milestone and obligation tracking (e.g., deliverable dates, payment schedules, renewal dates). True if milestone tracking is standard; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCountersignature rdf:type rdf:Property ;
    rdfs:label 'Requires Countersignature' ;
    rdfs:comment 'Indicates whether agreements of this type require countersignature by the counterparty to be legally binding. True if countersignature is required; False if unilateral execution is sufficient.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Indicates whether agreements of this type are subject to Sarbanes-Oxley Act compliance requirements (e.g., financial controls, audit trails). True if SOX compliance is required; False otherwise.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateAvailable rdf:type rdf:Property ;
    rdfs:label 'Template Available' ;
    rdfs:comment 'Indicates whether a standard template is available for this agreement type in the firms document management system (DMS). True if template exists; False if agreements are drafted from scratch.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Short alphanumeric code representing the agreement type (e.g., LOE, NDA, SPA, POA, MSA, SOW). Used for system integration and UTBMS alignment.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed description of the agreement type, including its purpose, typical use cases, and key characteristics within the legal services context.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Full business name of the agreement type (e.g., Letter of Engagement, Non-Disclosure Agreement, Share Purchase Agreement, Power of Attorney, Master Services Agreement, Statement of Work, Vendor Agreement, Retainer Agreement, Alternative Dispute Resolution (ADR) Arbitration Agreement).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTemplateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Template Id' ;
    rdfs:comment 'Reference to the contract_template_id of the newer template version that replaces this one. Null if this is the current active version.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Access control classification determining which users or groups can view and use this template within the firm.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of compliance frameworks and regulatory requirements this template addresses (e.g., GDPR, SOX, AML, CCPA, FRAND).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsFolderPath rdf:type rdf:Property ;
    rdfs:label 'Dms Folder Path' ;
    rdfs:comment 'Hierarchical folder path or workspace location in the DMS where the template is stored for organizational and access control purposes.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageLocale rdf:type rdf:Property ;
    rdfs:label 'Language Locale' ;
    rdfs:comment 'Language and locale code for the template content following ISO 639-1 and ISO 3166-1 standards (e.g., en-US, en-GB, fr-FR, de-DE).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryUseFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Use Flag' ;
    rdfs:comment 'Indicates whether use of this template is mandatory for the specified agreement type and jurisdiction (True) or optional (False). Enforces firm policy and risk management standards.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalClausesCount rdf:type rdf:Property ;
    rdfs:label 'Optional Clauses Count' ;
    rdfs:comment 'Number of optional or conditional clauses in the template that may be included or excluded based on the specific engagement requirements.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between scheduled reviews of the template (e.g., 12 for annual review, 24 for biennial review).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Type of transaction or matter this template is designed to support (e.g., M&A, Financing, Licensing, Employment, Real Estate, Dispute Resolution).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableFieldsCount rdf:type rdf:Property ;
    rdfs:label 'Variable Fields Count' ;
    rdfs:comment 'Number of variable fields or merge fields in the template that require customization for each specific engagement or transaction.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractPartyId rdf:type rdf:Property ;
    rdfs:label 'Contract Party Id' ;
    rdfs:comment 'Unique identifier for the contract party record. Primary key.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'The full name of the individual authorized to sign the contract on behalf of this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Obligation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this party is bound by confidentiality or Non-Disclosure Agreement (NDA) obligations under the contract (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'The primary email address for the party organization or individual for contract-related communications.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Indemnity Obligation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this party has indemnity obligations under the contract (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClient rdf:type rdf:Property ;
    rdfs:label 'Is Client' ;
    rdfs:comment 'Boolean flag indicating whether this party is a client of the firm (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirmEntity rdf:type rdf:Property ;
    rdfs:label 'Is Firm Entity' ;
    rdfs:comment 'Boolean flag indicating whether this party represents the law firm itself (True) or an external counterparty (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOpposingCounsel rdf:type rdf:Property ;
    rdfs:label 'Is Opposing Counsel' ;
    rdfs:comment 'Boolean flag indicating whether this party represents opposing counsel or an adverse party in a matter (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendor rdf:type rdf:Property ;
    rdfs:label 'Is Vendor' ;
    rdfs:comment 'Boolean flag indicating whether this party is a vendor or supplier to the firm (True) or not (False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycAmlClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Clearance Date' ;
    rdfs:comment 'The date on which KYC and AML clearance was obtained or last verified for this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Clearance Status' ;
    rdfs:comment 'The current status of KYC and AML compliance checks for this party (cleared, pending review, failed, not required, expired).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'The maximum liability amount applicable to this party under the contract terms, if specified.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the liability cap amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Notary Expiration Date' ;
    rdfs:comment 'The expiration date of the notary publics commission at the time of notarization, if applicable.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyOnAgreement rdf:type rdf:Property ;
    rdfs:label 'Party On Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — contract_party is a junction/detail record linking parties to agreements. Without this FK, party records are orphaned with no agreement context.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partyToAgreement rdf:type rdf:Property ;
    rdfs:label 'Party To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Every contract_party record identifies a party TO a specific agreement. This is a mandatory associative relationship — parties are meaningless without their agreement context.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'The primary contact phone number for the party organization or individual.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryCapacity rdf:type rdf:Property ;
    rdfs:label 'Signatory Capacity' ;
    rdfs:comment 'The legal capacity in which the signatory is executing the contract (individual, corporate officer, attorney-in-fact under Power of Attorney (POA), trustee, executor, guardian).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPhone rdf:type rdf:Property ;
    rdfs:label 'Signatory Phone' ;
    rdfs:comment 'The primary contact phone number for the authorized signatory.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureLocation rdf:type rdf:Property ;
    rdfs:label 'Signature Location' ;
    rdfs:comment 'The city, state, or country where the party executed the contract, as stated in the signature block.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateBeneficialOwner rdf:type rdf:Property ;
    rdfs:label 'Ultimate Beneficial Owner' ;
    rdfs:comment 'The name of the ultimate beneficial owner (UBO) of the party entity, as required for KYC and AML compliance.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Unique system identifier for the contractual obligation record. Primary key.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:dependentObligationId rdf:type rdf:Property ;
    rdfs:label 'Dependent Obligation Id' ;
    rdfs:comment 'Reference to another obligation that must be fulfilled before this obligation becomes active. Null if no dependency exists.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:beneficiaryPartyName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Name' ;
    rdfs:comment 'Legal name of the entity or individual entitled to receive the benefit or performance of the obligation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachConsequence rdf:type rdf:Property ;
    rdfs:label 'Breach Consequence' ;
    rdfs:comment 'Description of the contractual consequences if the obligation is breached (e.g., liquidated damages, termination right, indemnity trigger, regulatory penalty).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Breach Notice Required' ;
    rdfs:comment 'Indicates whether the contract requires formal written notice before a breach is deemed to have occurred (True) or if breach is automatic upon deadline passage (False).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clauseReference rdf:type rdf:Property ;
    rdfs:label 'Clause Reference' ;
    rdfs:comment 'Section, clause, or paragraph reference in the source contract where this obligation is defined (e.g., Section 5.3, Clause 12(a), Schedule B Item 4).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionPrecedentFlag rdf:type rdf:Property ;
    rdfs:label 'Condition Precedent Flag' ;
    rdfs:comment 'Indicates whether this obligation is a condition precedent (True) that must be satisfied before other contract terms become effective, or a standard ongoing obligation (False).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Number of days allowed to remedy a breach after notice is given, as specified in the contract. Null if no cure period is granted.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromAgreement rdf:type rdf:Property ;
    rdfs:label 'From Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Obligations are extracted from executed agreements. This is the core parent-child relationship enabling obligation tracking per contract.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Percentage completion of the obligation (0.00 to 100.00). Used for tracking partial fulfillment of multi-step or phased obligations.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle state of the obligation: pending (not started), in_progress (work underway), fulfilled (completed), partially_fulfilled (incomplete), breached (deadline missed), waived (obligation released), terminated (contract ended). [ENUM-REF-CANDIDATE: pending|in_progress|fulfilled|partially_fulfilled|breached|waived|terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Financial value associated with the obligation (e.g., payment amount, penalty exposure, indemnity cap). Null for non-monetary obligations.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'High-level classification of the obligation type: payment (financial settlement), delivery (goods/services), reporting (disclosure/notification), confidentiality (NDA terms), regulatory (compliance duty), IP assignment (intellectual property transfer).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationText rdf:type rdf:Property ;
    rdfs:label 'Obligation Text' ;
    rdfs:comment 'Full verbatim text of the contractual obligation, covenant, representation, warranty, or condition precedent as extracted from the source agreement.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rule' ;
    rdfs:comment 'Detailed recurrence pattern specification for custom schedules, expressed in iCalendar RRULE format or plain text description.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceSchedule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Schedule' ;
    rdfs:comment 'Frequency pattern for recurring obligations: one_time (single event), daily, weekly, monthly, quarterly, annually, custom (irregular pattern defined in recurrence_rule). [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|annually|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Flag' ;
    rdfs:comment 'Indicates whether this obligation is mandated by law or regulation (True) versus being a purely contractual commitment (False). Used for compliance reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Legal name of the entity or individual responsible for fulfilling the obligation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Indicates which party bears the obligation: client (counterparty), firm (law firm), third_party (external vendor/agent), joint (shared responsibility).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toAgreement rdf:type rdf:Property ;
    rdfs:label 'To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Every obligation is extracted from a specific executed agreement. This is the fundamental parent-child relationship in CLM obligation tracking. Without this FK, obligations float without context and c' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverAuthority rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority' ;
    rdfs:comment 'Name and title of the individual who authorized the waiver of this obligation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationEventId rdf:type rdf:Property ;
    rdfs:label 'Obligation Event Id' ;
    rdfs:comment 'Unique identifier for the obligation event record. Primary key for the obligation event entity.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventActorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Event Actor Timekeeper Id' ;
    rdfs:comment 'Identifier of the specific individual, organization, or system that performed or triggered the obligation event. The interpretation depends on actor_type (e.g., attorney ID, client ID, counterparty ID).' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:obligationActorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Obligation Actor Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Tracks which timekeeper performed obligation fulfillment, breach notification, or waiver actions. Essential for performance reviews, matter staffing decisions, and client service quality tracking. Act' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:breachNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Breach Notice Date' ;
    rdfs:comment 'The date on which formal notice of the breach was provided to the breaching party, if applicable. Critical for calculating cure periods and contractual remedies.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'The percentage of the obligation that has been completed as of this event. Used for tracking partial fulfillment (e.g., 50.00 indicates 50% completion). Range: 0.00 to 100.00.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this obligation event has compliance or regulatory reporting implications. True if the event must be included in regulatory reports, False otherwise.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cureDeadline rdf:type rdf:Property ;
    rdfs:label 'Cure Deadline' ;
    rdfs:comment 'The deadline by which the breaching party must cure the breach to avoid further consequences. Derived from contract terms and breach notice date.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'The monetary value associated with this obligation event, if applicable. May represent payment made, penalty incurred, or financial consequence of the event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, GBP, EUR). Null if no financial impact.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientList rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers who received notification of this obligation event. Provides audit trail of communication.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Obligation Status' ;
    rdfs:comment 'The status of the parent obligation immediately before this event occurred. Enables tracking of status transitions and audit trail reconstruction.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultingObligationStatus rdf:type rdf:Property ;
    rdfs:label 'Resulting Obligation Status' ;
    rdfs:comment 'The status of the parent obligation immediately after this event was processed. Captures the state transition caused by the event (e.g., from active to fulfilled, or from active to breached).' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The unique identifier of this obligation event in the source operational system. Enables traceability back to the originating system.' ;
    rdfs:domain ind:ObligationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the document that evidences or supports this obligation event. May point to a document in the Document Management System (DMS) such as iManage Work or NetDocuments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique identifier for the contract milestone record. Primary key.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone event actually occurred or was completed. Null if the milestone has not yet been completed. Used for performance tracking and compliance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Alert Lead Time Days' ;
    rdfs:comment 'Number of days before the scheduled milestone date that an automated alert or notification should be triggered. Configurable per milestone to support proactive management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractualClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contractual Clause Reference' ;
    rdfs:comment 'Reference to the specific clause, section, or article number in the contract document that defines this milestone obligation. Supports traceability to source agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemReference rdf:type rdf:Property ;
    rdfs:label 'External System Reference' ;
    rdfs:comment 'Reference identifier or key from an external Contract Lifecycle Management (CLM) system, practice management system, or client portal. Supports system integration and data lineage tracking.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path Flag' ;
    rdfs:comment 'Boolean indicator of whether this milestone is on the critical path for transaction completion or contract effectiveness. Used for prioritization in Mergers and Acquisitions (M&A) and complex transactions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Milestone Flag' ;
    rdfs:comment 'Boolean indicator of whether this milestone is driven by regulatory or statutory requirements (e.g., filing deadlines, compliance notice periods). Used for regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed textual description of the milestone event, including any specific contractual obligations, conditions precedent, or actions required to satisfy the milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone. Tracks whether the milestone is pending, approaching its due date, completed, missed, or waived. [ENUM-REF-CANDIDATE: pending|approaching|due|completed|missed|waived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone event type. Categorizes the nature of the contractual milestone for reporting and workflow automation. [ENUM-REF-CANDIDATE: execution|effective_date|condition_precedent|notice_period|option_exercise|renewal_decision|expiry|termination_window|payment_due|deliverable_due|regulatory_filing — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'For recurring milestones, the date of the next scheduled occurrence. Null for one-time milestones. Used to generate future milestone records automatically.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when the automated notification or alert was sent to the responsible party. Null if no notification has been sent. Supports audit trail for milestone management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Triggered Flag' ;
    rdfs:comment 'Boolean indicator of whether an automated notification or alert has been triggered for this milestone. Used to track alert delivery and prevent duplicate notifications.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal record. Primary key.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRenewalContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Renewal Contract Agreement Id' ;
    rdfs:comment 'Reference to the parent contract subject to renewal. Links to the contract master record.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAgreement .

ind:clientApprovalReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Client Approval Received Date' ;
    rdfs:comment 'Date on which client approval for the renewal was formally received. Null if approval not yet received or not required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required' ;
    rdfs:comment 'Indicates whether explicit client approval is required for the renewal to proceed (true) or if the renewal is automatic per contract terms (false).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Final decision outcome for the renewal: renew (proceed with renewal as-is or with minor adjustments), terminate (end the contract), renegotiate (material terms require negotiation), pending (decision not yet made).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Reason' ;
    rdfs:comment 'Business rationale for any fee adjustment applied during renewal (e.g., inflation adjustment, scope expansion, client loyalty discount, competitive pressure).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Party that initiated the renewal process: client (client requested renewal), firm (firm proactively proposed renewal), auto_trigger (system-generated based on contract terms).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeToCancelDeadline rdf:type rdf:Property ;
    rdfs:label 'Notice To Cancel Deadline' ;
    rdfs:comment 'Last date by which either party must provide written notice to prevent automatic renewal or to terminate the agreement. Critical for proactive renewal pipeline management.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofAgreement rdf:type rdf:Property ;
    rdfs:label 'Of Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Renewals manage the continuation lifecycle of a specific agreement. The FK to agreement is mandatory for renewal pipeline management.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing identifier for the renewal event, typically formatted as contract number plus renewal sequence (e.g., LOE-2024-001-R2).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism: auto_renew (automatic rollover per contract terms), opt_in (requires affirmative client election), renegotiate (new terms required), extend (one-time extension without full renewal), terminate (non-renewal decision).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termLength rdf:type rdf:Property ;
    rdfs:label 'Term Length' ;
    rdfs:comment 'Duration of the renewal term in months. For example, a 12-month renewal or a 36-month multi-year extension.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termUnit rdf:type rdf:Property ;
    rdfs:label 'Term Unit' ;
    rdfs:comment 'Unit of measure for the renewal term length: month, year, or quarter.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Amendment Id' ;
    rdfs:comment 'Self-referencing foreign key to a prior amendment that this amendment further modifies or supersedes. Enables tracking of amendment chains (e.g., Amendment 2.1 amends Amendment 2).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:primaryAmendmentApprovedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Amendment Approved By Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (typically partner or senior counsel) who approved the amendment for execution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryAmendmentCleanLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Amendment Clean Legal Document Id' ;
    rdfs:comment 'Reference identifier to the clean (final executed) version of the amendment document stored in the Document Management System (DMS).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:primarySupersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a later amendment that supersedes or replaces this amendment. Used to maintain the chain of agreement versions for audit and enforceability.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Comma-separated list or structured reference to the specific clauses, sections, or articles of the parent agreement that are modified by this amendment (e.g., Section 3.2, Exhibit A, Schedule 1).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Name' ;
    rdfs:comment 'Name of the individual who signed the amendment on behalf of the counterparty.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Title' ;
    rdfs:comment 'Job title or role of the counterparty signatory (e.g., Chief Legal Officer, General Counsel, Authorized Signatory).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newExpirationDate rdf:type rdf:Property ;
    rdfs:label 'New Expiration Date' ;
    rdfs:comment 'Revised expiration or termination date of the agreement as a result of this amendment. Null if amendment does not change the expiration date.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Primary business driver for the amendment: scope_change (work scope modification), fee_adjustment (rate or billing changes), term_extension (duration change), party_change (novation or assignment), compliance_update (regulatory requirement), error_correction (fix to original agreement), commercial_renegotiation (business terms revision), force_majeure (unforeseen event accommodation), other. [ENUM-REF-CANDIDATE: scope_change|fee_adjustment|term_extension|party_change|compliance_update|error_correction|commercial_renegotiation|force_majeure|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the agreement term is extended by this amendment. Null if amendment does not affect term duration.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationRoundId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Id' ;
    rdfs:comment 'Unique identifier for the negotiation round. Primary key for this entity.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this negotiation round record. Links to workforce or user management entity for audit purposes.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:negotiationOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this negotiation round record. Links to workforce or user management entity for audit purposes.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreedIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Agreed Issues Count' ;
    rdfs:comment 'Number of negotiation points or issues that were resolved and agreed upon during this round. Indicates progress toward final agreement.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientApprovalReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approval Received Flag' ;
    rdfs:comment 'Indicates whether client approval has been obtained for this negotiation round. True if approved, False if pending or not required.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required Flag' ;
    rdfs:comment 'Indicates whether client approval is required before proceeding with the next negotiation round. True if client sign-off is needed, False otherwise.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Primary method of communication used for this negotiation round. Tracks how the negotiation was conducted.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyNegotiatorEmail rdf:type rdf:Property ;
    rdfs:label 'Counterparty Negotiator Email' ;
    rdfs:comment 'Email address of the counterparty negotiator for this round. Used for communication tracking and audit trail.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyNegotiatorName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Negotiator Name' ;
    rdfs:comment 'Name of the individual representing the counterparty in this negotiation round. May be external counsel, in-house counsel, or business representative.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Organization Name' ;
    rdfs:comment 'Name of the organization the counterparty negotiator represents. May be the client, vendor, or opposing party depending on contract type.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Days' ;
    rdfs:comment 'Calculated duration in days from when the round was sent to when the counterparty response was returned. Critical metric for Legal Project Management (LPM) and Alternative Fee Arrangement (AFA) scoping.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalatedIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Escalated Issues Count' ;
    rdfs:comment 'Number of issues that required escalation to senior attorneys, partners, or client stakeholders during this round. Indicates negotiation difficulty.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalReviewDurationHours rdf:type rdf:Property ;
    rdfs:label 'Internal Review Duration Hours' ;
    rdfs:comment 'Time spent by the firm in internal review and preparation before sending this round to the counterparty. Used for time tracking and efficiency analysis.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Terms Summary' ;
    rdfs:comment 'Summary of the key contractual terms under negotiation in this round. May include pricing, liability caps, indemnification, termination rights, and other material provisions.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationForAgreement rdf:type rdf:Property ;
    rdfs:label 'Negotiation For Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Negotiation rounds track the back-and-forth for a specific agreement under drafting. FK required for cycle time analytics and LPM reporting.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationStrategy rdf:type rdf:Property ;
    rdfs:label 'Negotiation Strategy' ;
    rdfs:comment 'Description of the negotiation approach or strategy employed for this round. May include tactics, priorities, and fallback positions. Confidential attorney work product.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationToAgreement rdf:type rdf:Property ;
    rdfs:label 'Negotiation To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Each negotiation round tracks a cycle for a specific agreement under drafting or renegotiation.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newIssuesCount rdf:type rdf:Property ;
    rdfs:label 'New Issues Count' ;
    rdfs:comment 'Number of new negotiation points or issues raised by either party during this round. Tracks scope expansion or complexity increase.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Open Issues Count' ;
    rdfs:comment 'Number of unresolved negotiation points or issues remaining at the conclusion of this round. Key metric for tracking negotiation progress and complexity.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redlineVersionReference rdf:type rdf:Property ;
    rdfs:label 'Redline Version Reference' ;
    rdfs:comment 'Reference identifier or version number for the redlined document associated with this negotiation round. Links to Document Management System (DMS) such as iManage Work or NetDocuments.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedDate rdf:type rdf:Property ;
    rdfs:label 'Returned Date' ;
    rdfs:comment 'Date when the counterparty returned their response or redline for this negotiation round. Used to calculate turnaround time.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Returned Timestamp' ;
    rdfs:comment 'Precise timestamp when the counterparty response was received. Enables granular cycle time measurement for Alternative Fee Arrangement (AFA) scoping.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roundNotes rdf:type rdf:Property ;
    rdfs:label 'Round Notes' ;
    rdfs:comment 'Free-text notes capturing observations, counterparty positions, internal discussions, and other contextual information for this negotiation round. Attorney work product.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Sequential number identifying this negotiation cycle within the contract negotiation process. Starts at 1 for the initial round and increments with each subsequent round.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundOutcome rdf:type rdf:Property ;
    rdfs:label 'Round Outcome' ;
    rdfs:comment 'Final outcome classification for this negotiation round. Indicates whether the round resulted in agreement, required escalation, reached impasse, or was withdrawn.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundStatus rdf:type rdf:Property ;
    rdfs:label 'Round Status' ;
    rdfs:comment 'Current lifecycle status of this negotiation round. Tracks progression from draft through to final outcome. [ENUM-REF-CANDIDATE: draft|sent|under_review|agreed|escalated|impasse|withdrawn|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Date when the negotiation draft or redline was sent to the counterparty for this round. Key milestone for cycle time tracking.' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Precise timestamp when the negotiation draft was transmitted to the counterparty. Enables detailed velocity analysis for Legal Project Management (LPM).' ;
    rdfs:domain ind:NegotiationRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionRecordId rdf:type rdf:Property ;
    rdfs:label 'Execution Record Id' ;
    rdfs:comment 'Unique identifier for the execution record. Primary key.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bindingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Binding Effective Date' ;
    rdfs:comment 'The date on which the executed agreement became legally effective and binding. May differ from execution date if the agreement specifies a delayed effective date.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Execution Date' ;
    rdfs:comment 'The date on which the counterparty executed the agreement. May differ from the primary execution date in counterpart execution scenarios.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electronicSignatureCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Certificate Reference' ;
    rdfs:comment 'Digital certificate identifier associated with the electronic signature, providing cryptographic proof of authenticity.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignaturePlatform rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Platform' ;
    rdfs:comment 'Name of the electronic signature platform or service used for execution (e.g., DocuSign, Adobe Sign, HelloSign), if applicable.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Transaction Reference' ;
    rdfs:comment 'Unique transaction or envelope identifier assigned by the electronic signature platform, used for audit trail and verification.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedDocumentVersion rdf:type rdf:Property ;
    rdfs:label 'Executed Document Version' ;
    rdfs:comment 'Version number or identifier of the executed document in the DMS, ensuring traceability to the exact document version that was signed.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executingPartyName rdf:type rdf:Property ;
    rdfs:label 'Executing Party Name' ;
    rdfs:comment 'Legal name of the party (organization or individual) on whose behalf the agreement was executed.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionOfAgreement rdf:type rdf:Property ;
    rdfs:label 'Execution Of Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — The execution record captures when and how a specific agreement became binding. This is the legally authoritative link between the execution event and the agreement.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of execution events for the same contract, used to track amendments, renewals, and counterpart executions.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionToAgreement rdf:type rdf:Property ;
    rdfs:label 'Execution To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Each execution record captures the formal execution event for a specific agreement. One-to-one or one-to-many (multi-party sequential execution) relationship.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBindingFlag rdf:type rdf:Property ;
    rdfs:label 'Is Binding Flag' ;
    rdfs:comment 'Indicates whether this execution event resulted in a legally binding agreement. False if execution was conditional, incomplete, or subsequently invalidated.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOriginalExecutionFlag rdf:type rdf:Property ;
    rdfs:label 'Is Original Execution Flag' ;
    rdfs:comment 'Indicates whether this is the original execution record for the agreement (true) or a subsequent execution event such as an amendment or counterpart (false).' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionOfExecution rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Execution' ;
    rdfs:comment 'The legal jurisdiction (state, province, country) in which the execution took place. Relevant for determining applicable execution formalities and legal validity.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarySealAffixedFlag rdf:type rdf:Property ;
    rdfs:label 'Notary Seal Affixed Flag' ;
    rdfs:comment 'Indicates whether the notary publics official seal was affixed to the executed document.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOfAttorneyReference rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Reference' ;
    rdfs:comment 'Reference to the Power of Attorney document or authorization under which the signatory executed the agreement, if applicable.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessAddress rdf:type rdf:Property ;
    rdfs:label 'Witness Address' ;
    rdfs:comment 'Address of the witness, required in certain jurisdictions for deed execution and notarization.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full legal name of the witness who attested to the execution, if applicable. Required for certain deed and notarized executions.' ;
    rdfs:domain ind:ExecutionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationId rdf:type rdf:Property ;
    rdfs:label 'Termination Id' ;
    rdfs:comment 'Unique identifier for the contract termination record. Primary key.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Effective Termination Date' ;
    rdfs:comment 'The date on which the contract termination becomes legally effective and the agreement ceases to bind the parties (except for surviving obligations).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groundsForTermination rdf:type rdf:Property ;
    rdfs:label 'Grounds For Termination' ;
    rdfs:comment 'Detailed narrative explanation of the legal, contractual, or business grounds cited for the termination, including reference to specific contract clauses or breaches.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'The date on which formal notice of termination was given to the counterparty, triggering any contractual notice period.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Any contractual penalty, liquidated damages, or early termination fee payable as a result of the termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTerminationObligations rdf:type rdf:Property ;
    rdfs:label 'Post Termination Obligations' ;
    rdfs:comment 'Description of contractual obligations that survive termination, such as confidentiality, non-compete, indemnity, data return, or wind-down duties.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Any refund or reimbursement due to the client or counterparty as a result of the termination (e.g., unused retainer, prepaid fees).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Summary of the key terms and conditions agreed upon in the settlement of the termination dispute, including any financial or performance obligations.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivingClauses rdf:type rdf:Property ;
    rdfs:label 'Surviving Clauses' ;
    rdfs:comment 'List or citation of specific contract clauses that expressly survive termination (e.g., Sections 8 (Confidentiality), 10 (Indemnity), 14 (Governing Law)).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatingPartyName rdf:type rdf:Property ;
    rdfs:label 'Terminating Party Name' ;
    rdfs:comment 'The legal name of the party or entity that initiated or triggered the termination.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatingPartyType rdf:type rdf:Property ;
    rdfs:label 'Terminating Party Type' ;
    rdfs:comment 'Classification of the party that initiated the termination: client (client-initiated), firm (law firm-initiated), vendor (supplier-initiated), mutual (both parties agreed), third_party (external event or regulator).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current lifecycle status of the termination: pending (notice given but not yet effective), effective (termination complete), disputed (contested by one or more parties), settled (dispute resolved), withdrawn (termination notice retracted).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the termination event: expiry (natural end of term), termination for convenience (voluntary exit without cause), termination for cause (breach or default), mutual rescission (agreed cancellation), frustration (impossibility of performance), or breach (material violation).' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDownCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Wind Down Completion Date' ;
    rdfs:comment 'The date by which all wind-down activities, handovers, and post-termination obligations are expected to be completed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windDownPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Wind Down Period Days' ;
    rdfs:comment 'The number of days allowed or required for orderly wind-down of services, handover of work product, or transition activities following the effective termination date.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Clause Library Id' ;
    rdfs:comment 'Primary key for clause_library' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clauseModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clause Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this clause library entry.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clauseOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clause Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user or knowledge management professional who created this clause library entry.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryClauseAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Clause Attorney Profile Id' ;
    rdfs:comment 'Identifier of the attorney or knowledge management professional who is the designated owner and subject matter expert for this clause. Responsible for updates, approvals, and guidance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:supersededByClauseClauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Clause Clause Library Id' ;
    rdfs:comment 'Identifier of the clause that supersedes this one when this clause is deprecated or replaced. Maintains version lineage and ensures users are directed to the current approved version.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClauseLibrary .

ind:amlKycRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Required Flag' ;
    rdfs:comment 'Indicates whether the clause includes or requires Anti-Money Laundering (AML) and Know Your Client (KYC) provisions for client identification and due diligence.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedText rdf:type rdf:Property ;
    rdfs:label 'Approved Text' ;
    rdfs:comment 'The full approved legal text of the clause as vetted and authorized by the knowledge management team, practice group leaders, and General Counsel (GC). This is the primary version for use in client-facing agreements.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseCategory rdf:type rdf:Property ;
    rdfs:label 'Clause Category' ;
    rdfs:comment 'High-level business category grouping clauses by strategic purpose: risk allocation, compliance, operational, commercial, dispute resolution, or termination provisions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryDescription rdf:type rdf:Property ;
    rdfs:label 'Clause Library Description' ;
    rdfs:comment 'Detailed description of the clause purpose, legal effect, and guidance on when and how to use it. Includes notes on negotiation strategy and common counterparty objections.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Library Status' ;
    rdfs:comment 'Current lifecycle status of the clause: active (approved for use), under review (being evaluated), deprecated (no longer recommended), archived (historical reference only), or draft (not yet approved).' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the clause by legal function. Common types include indemnity, limitation of liability, governing law, force majeure, Intellectual Property (IP) assignment, confidentiality, Fair Reasonable and Non-Discriminatory (FRAND), and Alternative Dispute Resolution (ADR) arbitration provisions. [ENUM-REF-CANDIDATE: indemnity|limitation_of_liability|governing_law|force_majeure|ip_assignment|confidentiality|frand|arbitration|termination|warranty|data_protection|audit_rights|insurance|severability|entire_agreement|amendment|waiver|notice|assignment|subcontracting — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSourceReference rdf:type rdf:Property ;
    rdfs:label 'External Source Reference' ;
    rdfs:comment 'Reference to external standard clause guidance sources such as Thomson Reuters Practical Law, LexisNexis, American Bar Association (ABA) model clauses, or International Chamber of Commerce (ICC) standard terms.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackText rdf:type rdf:Property ;
    rdfs:label 'Fallback Text' ;
    rdfs:comment 'Alternative or fallback clause text to be used when the approved text is not acceptable to the counterparty or when negotiation requires a softer position. Provides flexibility during contract negotiation.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Applicable Flag' ;
    rdfs:comment 'Indicates whether the clause is designed for or applicable to Fair Reasonable and Non-Discriminatory (FRAND) licensing scenarios common in Intellectual Property (IP) and standards-essential patent agreements.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionApplicability rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Applicability' ;
    rdfs:comment 'Comma-separated list of jurisdictions or legal systems where this clause is applicable and enforceable. Uses ISO 3166-1 alpha-3 country codes (e.g., USA, GBR, DEU) or legal system identifiers (e.g., Common Law, Civil Law, Sharia).' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedClauseIds rdf:type rdf:Property ;
    rdfs:label 'Related Clause Ids' ;
    rdfs:comment 'Comma-separated list of contract_clause_library_id values for related or complementary clauses that are often used together or serve similar purposes. Supports clause recommendation and bundling.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether the clause meets Sarbanes-Oxley Act (SOX) requirements for financial controls, audit rights, and corporate governance in contracts with public companies.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Template Integration Flag' ;
    rdfs:comment 'Indicates whether this clause is integrated into automated contract templates within the Contract Lifecycle Management (CLM) or Document Management System (DMS) for automated document assembly.' ;
    rdfs:domain ind:ClauseLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageTier rdf:type rdf:Property ;
    rdfs:label 'Usage Tier' ;
    rdfs:comment 'Designation of the clause usage priority within the firm: mandatory (must be included), preferred (strongly recommended), fallback (use when primary is rejected), optional (discretionary), or deprecated (no longer recommended).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseDeviationId rdf:type rdf:Property ;
    rdfs:label 'Clause Deviation Id' ;
    rdfs:comment 'Unique identifier for the clause deviation record. Primary key.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Deviation Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this clause deviation record.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryClauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Primary Clause Library Id' ;
    rdfs:comment 'FK to contract.contract_clause_library.contract_clause_library_id — Each deviation references the approved standard clause it departs from. This FK enables tracking which clauses are most frequently deviated from.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClauseLibrary .

ind:approvedPosition rdf:type rdf:Property ;
    rdfs:label 'Approved Position' ;
    rdfs:comment 'The firms approved standard or fallback clause language or position as documented in the clause library or playbook.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseSectionReference rdf:type rdf:Property ;
    rdfs:label 'Clause Section Reference' ;
    rdfs:comment 'Specific section, article, or clause number within the contract document where the deviation appears.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseTypeCode rdf:type rdf:Property ;
    rdfs:label 'Clause Type Code' ;
    rdfs:comment 'Standardized code identifying the type of clause that was deviated from (e.g., indemnity, limitation of liability, confidentiality, termination, governing law, dispute resolution, intellectual property, warranty, force majeure).' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseTypeName rdf:type rdf:Property ;
    rdfs:label 'Clause Type Name' ;
    rdfs:comment 'Human-readable name of the clause type that was deviated from.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Category' ;
    rdfs:comment 'Classification of the deviation based on its materiality and impact on the firms risk profile.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationInAgreement rdf:type rdf:Property ;
    rdfs:label 'Deviation In Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Clause deviations track departures from standard positions in a specific negotiated agreement. FK required for risk aggregation per contract.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationRationale rdf:type rdf:Property ;
    rdfs:label 'Deviation Rationale' ;
    rdfs:comment 'Detailed business and legal rationale explaining why the deviation from the approved clause position was necessary or acceptable.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationSummary rdf:type rdf:Property ;
    rdfs:label 'Deviation Summary' ;
    rdfs:comment 'Brief summary of the nature and extent of the deviation from the approved clause position.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationToAgreement rdf:type rdf:Property ;
    rdfs:label 'Deviation To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Each clause deviation records a departure from standard position in a specific negotiated agreement.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether external counsel or Alternative Legal Service Provider (ALSP) was involved in negotiating or approving this deviation.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCounselName rdf:type rdf:Property ;
    rdfs:label 'External Counsel Name' ;
    rdfs:comment 'Name of the external law firm or ALSP involved in this clause deviation, if applicable.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Indemnity Exposure Amount' ;
    rdfs:comment 'Estimated financial exposure amount associated with this clause deviation for professional indemnity purposes.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedPosition rdf:type rdf:Property ;
    rdfs:label 'Negotiated Position' ;
    rdfs:comment 'The actual clause language or position agreed upon in the negotiated contract, representing the deviation from the approved position.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatingAttorneyName rdf:type rdf:Property ;
    rdfs:label 'Negotiating Attorney Name' ;
    rdfs:comment 'Full name of the attorney who negotiated the clause deviation.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playbookUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Playbook Update Required Flag' ;
    rdfs:comment 'Indicates whether this deviation requires an update to the firms clause playbook or negotiation guidelines.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playbookUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Playbook Update Status' ;
    rdfs:comment 'Current status of any required playbook or clause library update resulting from this deviation.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentFlag rdf:type rdf:Property ;
    rdfs:label 'Precedent Flag' ;
    rdfs:comment 'Indicates whether this deviation sets a precedent that should be considered for incorporation into the firms standard clause library or playbook.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalIndemnityExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Exposure Flag' ;
    rdfs:comment 'Indicates whether this clause deviation creates potential professional indemnity insurance exposure for the firm.' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this clause deviation has implications for regulatory compliance (e.g., GDPR, AML, SOX, FRAND).' ;
    rdfs:domain ind:ClauseDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afaArrangementId rdf:type rdf:Property ;
    rdfs:label 'Afa Arrangement Id' ;
    rdfs:comment 'Unique identifier for the Alternative Fee Arrangement record. Primary key.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAfaAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Afa Attorney Profile Id' ;
    rdfs:comment 'Reference to the equity partner or relationship partner responsible for managing this AFA arrangement and ensuring compliance with its terms.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:afaInAgreement rdf:type rdf:Property ;
    rdfs:label 'Afa In Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — AFA terms are embedded in specific engagement letters/retainer agreements. FK required to link fee commitments to their governing contract.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:afaToAgreement rdf:type rdf:Property ;
    rdfs:label 'Afa To Agreement' ;
    rdfs:comment 'FK to contract.agreement.agreement_id — Each AFA arrangement is defined within a specific engagement letter or retainer agreement. The fee terms are contractual commitments embedded in the agreement.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Descriptive name or title for this AFA arrangement, often reflecting the scope or project name (e.g., M&A Transaction Fixed Fee, IP Portfolio Subscription).' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedAmountToDate rdf:type rdf:Property ;
    rdfs:label 'Collected Amount To Date' ;
    rdfs:comment 'The cumulative amount collected (cash received) under this AFA arrangement to date. Used for tracking cash realization and outstanding Accounts Receivable (AR).' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementCapAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Cap Amount' ;
    rdfs:comment 'The maximum amount of disbursements that can be billed under this AFA arrangement, if a disbursement cap applies. Null if no cap or disbursements are included in fee.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmountToDate rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount To Date' ;
    rdfs:comment 'The cumulative amount invoiced under this AFA arrangement to date, across all invoices. Used for tracking revenue recognition and remaining balance.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageHandlingMethod rdf:type rdf:Property ;
    rdfs:label 'Overage Handling Method' ;
    rdfs:comment 'Defines how work exceeding the agreed scope or budget cap is handled. No overage: firm absorbs excess. Client approval required: additional work requires written approval. Automatic billing: overage billed at standard rates. Write-off: firm writes off excess. Renegotiate: parties renegotiate terms.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageRateAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Rate Amount' ;
    rdfs:comment 'The hourly rate or fee rate applied to work that exceeds the agreed scope or budget cap, if overage billing is permitted. Null if no overage billing allowed.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'Description of the key performance indicators (KPIs) or success criteria used to measure performance under this AFA arrangement (e.g., matter outcome, time to resolution, client satisfaction score, cost savings achieved).' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to effective end date by which either party must provide notice to prevent auto-renewal or to terminate the arrangement. Null if no auto-renewal or no notice requirement.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAllocationNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Allocation Notes' ;
    rdfs:comment 'Narrative description of how financial and performance risk is allocated between the firm and client under this AFA arrangement (e.g., firm bears risk of scope creep, client bears risk of third-party costs).' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Success Fee Percentage' ;
    rdfs:comment 'The percentage uplift or bonus fee applied upon achieving defined success criteria (e.g., winning case, closing transaction). Null for non-success-fee arrangements.' ;
    rdfs:domain ind:AfaArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementTypeClausePolicyId rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Clause Policy Id' ;
    rdfs:comment 'Primary key for the agreement_type_clause_policy association' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementCreatedByAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Agreement Created By Attorney Profile Id' ;
    rdfs:comment 'Identifier of the attorney or knowledge management professional who created this clause policy rule.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:agreementLastModifiedByAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Agreement Last Modified By Attorney Profile Id' ;
    rdfs:comment 'Identifier of the attorney or knowledge management professional who last modified this clause policy rule.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:contractClauseLibraryId rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Library Id' ;
    rdfs:comment 'Foreign key linking to the clause library entry governed by this policy' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClauseLibrary .

ind:fallbackClauseId rdf:type rdf:Property ;
    rdfs:label 'Fallback Clause Id' ;
    rdfs:comment 'Reference to an alternative clause from the clause library to use if this clause is rejected during negotiation. Null if no fallback is defined.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clause .

ind:agreementTypeClausePolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Clause Policy Status' ;
    rdfs:comment 'Current lifecycle status of this clause policy rule: active (in use), under_review (being evaluated), deprecated (phasing out), superseded (replaced by newer policy).' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Required' ;
    rdfs:comment 'Level of approval authority required to deviate from this clause policy (omit mandatory clause or modify non-negotiable clause): none, partner, practice_group_lead, general_counsel, clo.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultFlag rdf:type rdf:Property ;
    rdfs:label 'Is Default Flag' ;
    rdfs:comment 'Indicates whether this clause should be pre-populated by default when creating a new agreement of this type in the CLM system.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Flag' ;
    rdfs:comment 'Indicates whether this clause must be included in all agreements of this type. Mandatory clauses cannot be omitted during contract drafting.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationFlexibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Negotiation Flexibility Level' ;
    rdfs:comment 'Guidance on how much flexibility attorneys have to modify or remove this clause during negotiation for this agreement type: non-negotiable, low, medium, high.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyRationale rdf:type rdf:Property ;
    rdfs:label 'Policy Rationale' ;
    rdfs:comment 'Business or legal justification for why this clause is required, recommended, or optional for this agreement type. May reference regulatory requirements, risk management policies, or court precedents.' ;
    rdfs:domain ind:AgreementTypeClausePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateClauseId rdf:type rdf:Property ;
    rdfs:label 'Template Clause Id' ;
    rdfs:comment 'Unique identifier for this template-clause composition record. Primary key.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Approved By Timekeeper Id' ;
    rdfs:comment 'Foreign key to workforce.timekeeper.timekeeper_id' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryTemplateId rdf:type rdf:Property ;
    rdfs:label 'Primary Template Id' ;
    rdfs:comment 'Foreign key linking to the contract template that includes this clause' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:approvedByAttorney rdf:type rdf:Property ;
    rdfs:label 'Approved By Attorney' ;
    rdfs:comment 'Name or identifier of the attorney or knowledge management professional who approved the inclusion of this clause in this template.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Clause Sequence Order' ;
    rdfs:comment 'Ordinal position of this clause within the template document structure. Determines the sequence in which clauses appear in contracts generated from this template.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'Date when this clause was added to this template composition.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isOptionalFlag rdf:type rdf:Property ;
    rdfs:label 'Is Optional Flag' ;
    rdfs:comment 'Indicates whether this clause is optional and may be included or excluded by the attorney during contract generation based on deal-specific requirements.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Specific Flag' ;
    rdfs:comment 'Indicates whether this clause inclusion is specific to certain jurisdictions covered by the template. Used when templates support multiple jurisdictions with jurisdiction-conditional clauses.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageTierOverride rdf:type rdf:Property ;
    rdfs:label 'Usage Tier Override' ;
    rdfs:comment 'Template-specific override of the clause library usage tier. Allows a clause marked as preferred in the library to be mandatory in a specific template context.' ;
    rdfs:domain ind:TemplateClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAccountAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney who has primary fiduciary responsibility for this trust account. This attorney is accountable for compliance with trust accounting rules and ethical obligations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The legal name of the trust account as registered with the financial institution. Typically includes firm name, client name, and trust designation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The bank account number assigned by the financial institution for this trust account. Externally-known identifier used for banking transactions and reconciliations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the trust account. Active accounts are operational and accepting transactions; inactive accounts are dormant but not closed; closed accounts have been formally terminated; suspended accounts are temporarily frozen pending investigation or resolution; pending closure accounts are in the process of being wound down.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the trust account based on regulatory and operational purpose. IOLTA (Interest on Lawyers Trust Accounts) pooled accounts hold commingled client funds with interest benefiting legal aid; individual client trust accounts segregate funds for a single client; escrow accounts hold transaction funds; retainer accounts hold advance fee deposits; settlement accounts hold litigation proceeds; qualified settlement funds hold structured settlement amounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlKycStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Status' ;
    rdfs:comment 'Status of Anti-Money Laundering and Know Your Client verification for this trust account. Trust accounts holding client funds must comply with AML regulations and verify client identity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Frequency at which this trust account is subject to internal or external audit. High-value or high-risk accounts may require more frequent audits.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Physical address of the bank branch where the trust account is maintained. Required for regulatory filings and audit documentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the specific branch location where the trust account is maintained. May be required for regulatory reporting in some jurisdictions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Financial Institution Code' ;
    rdfs:comment 'Routing number, SWIFT code, or other standard identifier for the financial institution holding the trust account. Used for electronic funds transfers and reconciliation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Financial Institution Name' ;
    rdfs:comment 'Name of the bank or financial institution where the trust account is maintained. Must be an approved institution per jurisdiction-specific trust accounting regulations.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBeneficiary rdf:type rdf:Property ;
    rdfs:label 'Interest Beneficiary' ;
    rdfs:comment 'Entity that receives interest earned on the trust account. For IOLTA accounts, interest goes to the state IOLTA foundation or legal aid programs. For individual client trust accounts, interest typically belongs to the client.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioltaReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this trust account is subject to IOLTA reporting requirements. IOLTA accounts must report interest earned and remit it to the designated legal aid foundation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditResult rdf:type rdf:Property ;
    rdfs:label 'Last Audit Result' ;
    rdfs:comment 'Outcome of the most recent audit. Pass indicates full compliance; pass with observations indicates minor issues noted; fail indicates material deficiencies requiring remediation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent three-way reconciliation performed for this trust account. Trust accounts must be reconciled monthly, comparing bank statement balance, trust ledger balance, and client ledger balances.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'Minimum balance that must be maintained in the trust account per bank requirements or firm policy. Some jurisdictions or account types require a minimum balance to remain open.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'Date by which the next three-way reconciliation must be completed. Typically set to the end of the following month after the last reconciliation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purposeOfAccount rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Account' ;
    rdfs:comment 'Business purpose for which this trust account was established. Examples include holding litigation settlement funds, managing real estate transaction escrow, holding retainer for ongoing legal services, managing estate administration funds.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Classification of the trust account for regulatory reporting purposes. Different classifications may have different reporting requirements, audit frequencies, and compliance obligations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLedgerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Ledger Timekeeper Id' ;
    rdfs:comment 'Reference to the system user who created this trust ledger entry. Required for accountability and audit trail.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reversedEntryLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Entry Ledger Entry Id' ;
    rdfs:comment 'Reference to the original trust ledger entry that this transaction reverses. Null for non-reversal entries.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Client authorization document reference or approval identifier. Required for disbursements and transfers.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementDate rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Date' ;
    rdfs:comment 'Date of the bank statement on which this transaction appeared. Used for three-way reconciliation matching.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'Bank account number of the counterparty. Required for wire transfers and ACH transactions.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementCategory rdf:type rdf:Property ;
    rdfs:label 'Disbursement Category' ;
    rdfs:comment 'UTBMS expense code or disbursement classification for payments. Used for client billing and matter cost tracking.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDirection rdf:type rdf:Property ;
    rdfs:label 'Entry Direction' ;
    rdfs:comment 'Double-entry accounting direction. Debit increases trust liability to client; credit decreases it.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Code' ;
    rdfs:comment 'LEDES billing code for trust transactions that will be billed to clients. Enables electronic invoice submission.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Description' ;
    rdfs:comment 'Detailed narrative description of the trust transaction purpose. Required for client reporting and regulatory audit.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeAddress rdf:type rdf:Property ;
    rdfs:label 'Payee Address' ;
    rdfs:comment 'Mailing address of the disbursement recipient. Required for cheque mailing and wire transfer compliance.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the recipient for disbursement transactions. Required for cheque printing and payment audit trail.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment identifier such as cheque number, wire confirmation, or ACH trace number. Used for bank reconciliation.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToGlFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Flag' ;
    rdfs:comment 'Indicates whether this trust transaction has been posted to the firm general ledger. Used for financial close process.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this transaction must be included in regulatory trust account reports to bar associations or oversight bodies.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this entry is a reversal of a previous transaction. True for correction entries.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'Cumulative client trust balance after this transaction. Used for real-time balance verification and overdraft prevention.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date on which the trust transaction occurred. Used for ledger sequencing and regulatory reporting periods.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction reference number for audit trail and client reporting. Sequentially assigned per trust account.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the trust transaction was recorded in the system. Used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:LedgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clientTrustBalanceId rdf:type rdf:Property ;
    rdfs:label 'Client Trust Balance Id' ;
    rdfs:comment 'Unique identifier for the client trust balance record. Primary key for this entity.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingsNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Notes' ;
    rdfs:comment 'Summary of findings from the last trust account audit for this balance. Documents any discrepancies, corrective actions, or compliance issues identified.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Available Balance Amount' ;
    rdfs:comment 'Net available balance for immediate disbursement, calculated as current_balance_amount minus held_balance_amount. Represents funds that can be disbursed without restriction.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'Date as of which the current_balance_amount is accurate. Represents the effective date of the balance snapshot.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle status of the trust balance record. Active indicates ongoing trust activity; dormant indicates no recent activity but positive balance; closed indicates zero balance and matter closure; reconciliation_pending indicates awaiting three-way reconciliation; under_review indicates regulatory or internal audit review.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAuthorizationOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Client Authorization On File Flag' ;
    rdfs:comment 'Indicator of whether written client authorization for trust fund handling is on file. Required for compliance with engagement letter and trust accounting requirements.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current available trust balance for the client-matter combination as of the balance_as_of_date. Represents funds available for authorized disbursements.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dormancyThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Dormancy Threshold Days' ;
    rdfs:comment 'Number of days without activity after which the trust balance is considered dormant and subject to escheatment review. Varies by jurisdiction (typically 180-365 days).' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Indicator of whether the trust balance is eligible for escheatment to the state due to dormancy and inability to locate the client. True triggers escheatment reporting and remittance process.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escheatmentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Review Date' ;
    rdfs:comment 'Date when the trust balance was last reviewed for escheatment eligibility. Required for compliance with unclaimed property reporting deadlines.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heldBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Held Balance Amount' ;
    rdfs:comment 'Amount of trust funds held pending disbursement authorization or clearance. Represents funds committed but not yet disbursed (e.g., checks issued but not cleared, pending wire transfers).' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestDisbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Disbursed Amount' ;
    rdfs:comment 'Total interest disbursed to the client from this trust balance. Used to reconcile interest earned vs. interest paid out.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Earned Amount' ;
    rdfs:comment 'Total interest earned on this client trust balance if held in an individual interest-bearing account (not pooled IOLTA). Interest belongs to the client and must be tracked separately.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent trust activity (deposit, disbursement, or transfer) for this client-matter. Used to identify dormant accounts subject to escheatment or closure.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDepositDate rdf:type rdf:Property ;
    rdfs:label 'Last Deposit Date' ;
    rdfs:comment 'Date of the most recent deposit into trust for this client-matter. Used to identify dormant accounts and trigger escheatment reviews.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Last Disbursement Date' ;
    rdfs:comment 'Date of the most recent disbursement from trust for this client-matter. Used to identify dormant accounts and assess matter closure readiness.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReconciledBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Balance Amount' ;
    rdfs:comment 'Trust balance amount as of the last completed three-way reconciliation (bank statement, trust ledger, client sub-ledger). Used to detect discrepancies and ensure compliance.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required Amount' ;
    rdfs:comment 'Minimum trust balance amount required to be maintained for this client-matter per engagement terms or regulatory requirements. Used to trigger alerts for low balance conditions.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negativeBalanceDate rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Date' ;
    rdfs:comment 'Date when the trust balance first went negative, if applicable. Used for regulatory reporting and disciplinary investigation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negativeBalanceFlag rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Flag' ;
    rdfs:comment 'Indicator of whether the trust balance has ever gone negative, which is a serious ethical violation. True indicates a historical or current negative balance condition requiring immediate remediation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Amount' ;
    rdfs:comment 'Initial trust balance amount when the client-matter trust sub-ledger was established. Represents the first deposit or transfer into trust for this matter.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDepositsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deposits Amount' ;
    rdfs:comment 'Cumulative total of all deposits into trust for this client-matter since inception. Used for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trustAccountType rdf:type rdf:Property ;
    rdfs:label 'Trust Account Type' ;
    rdfs:comment 'Type of trust account holding the funds: pooled IOLTA account for multiple clients, individual client trust account, or escrow account for specific transactions.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustAccountingNotes rdf:type rdf:Property ;
    rdfs:label 'Trust Accounting Notes' ;
    rdfs:comment 'Free-text notes regarding special trust accounting considerations, client instructions, or regulatory exceptions applicable to this balance. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:ClientTrustBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptApprovedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Receipt Approved By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the supervising attorney or trust accounting manager who approved the receipt for deposit. Required for segregation of duties.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:receiptModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Receipt Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this record. Required for audit trail and accountability.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:receiptOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Receipt Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the firm user (attorney, paralegal, or accounting staff) who recorded the receipt. Required for accountability and audit trail.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:amlRiskScore rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the AML screening system. Higher scores indicate elevated risk requiring additional review.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementLineReference rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Line Reference' ;
    rdfs:comment 'Reference to the corresponding line item on the trust account bank statement. Used for three-way reconciliation (firm records, client ledger, bank statement).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'Date on which the deposited funds cleared and became available in the trust account. Critical for three-way reconciliation and disbursement authorization.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Client Authorization Reference' ;
    rdfs:comment 'Reference to the clients written authorization or engagement letter permitting the firm to receive and hold these funds in trust. Required for compliance and dispute resolution.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date on which the funds were deposited into the trust account. Must comply with jurisdiction-specific prompt deposit rules (typically within 1-3 business days of receipt).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioltaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Eligible Flag' ;
    rdfs:comment 'Indicates whether this receipt is eligible for deposit into an IOLTA account (typically small or short-term client funds where individual interest accounting is impractical).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payor Account Number' ;
    rdfs:comment 'Bank account number or payment instrument identifier from which the funds originated. Masked for security; used for reconciliation and AML screening.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payorBankName rdf:type rdf:Property ;
    rdfs:label 'Payor Bank Name' ;
    rdfs:comment 'Name of the financial institution from which the funds were sent. Supports AML due diligence and wire transfer verification.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payorName rdf:type rdf:Property ;
    rdfs:label 'Payor Name' ;
    rdfs:comment 'Name of the individual or entity that provided the funds. May differ from the client in third-party payment scenarios.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Detailed narrative describing the purpose for which the funds were received (e.g., Advance retainer for litigation services in Smith v. Jones, Settlement proceeds from mediation on 2024-01-15).' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which the client funds were received by the firm. Critical for trust accounting reconciliation and interest calculation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally visible unique receipt number assigned to this trust receipt for audit trail and client communication purposes.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the trust receipt. Tracks the receipt from initial recording through deposit, clearing, and any subsequent reversals.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the trust receipt based on the purpose and source of the funds. Determines handling and disbursement rules.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the receipt was reversed (e.g., due to bounced cheque, wire recall, or client request). Nullable; populated only if a reversal occurred.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartyPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Payment Flag' ;
    rdfs:comment 'Indicates whether the funds were provided by a third party (not the client). Triggers additional conflict checking and client consent requirements.' ;
    rdfs:domain ind:Receipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disbursementAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Authorization Id' ;
    rdfs:comment 'Foreign key linking to trust.disbursement_authorization. Business justification: Every disbursement should reference the authorization that approved it. This creates the governance link between the authorization workflow (disbursement_authorization) and the actual payment transact' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisbursementAuthorization .

ind:reversedByDisbursementTrustDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Reversed By Disbursement Trust Disbursement Id' ;
    rdfs:comment 'Reference to the reversing disbursement transaction if this disbursement was reversed. Creates audit trail for corrections.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustDisbursement .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current approval and execution status of the disbursement. Tracks the disbursement through its lifecycle from request to completion.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'The date on which the disbursement was executed and funds left the trust account. Core business event timestamp for trust fund outflows.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementDescription rdf:type rdf:Property ;
    rdfs:label 'Disbursement Description' ;
    rdfs:comment 'Detailed narrative description of the purpose and nature of the disbursement. Required for client reporting and audit trail.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIoltaReportable rdf:type rdf:Property ;
    rdfs:label 'Is Iolta Reportable' ;
    rdfs:comment 'Flag indicating whether this disbursement must be included in IOLTA regulatory reporting. Determined by jurisdiction rules.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Flag indicating whether the disbursement is subject to tax reporting requirements. Determines 1099 reporting obligations.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isThreeWayReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Three Way Reconciled' ;
    rdfs:comment 'Flag indicating whether this disbursement has been reconciled across trust ledger, bank statement, and client ledger. Required for compliance.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payeeType rdf:type rdf:Property ;
    rdfs:label 'Payee Type' ;
    rdfs:comment 'Classification of the payee receiving the disbursement. Used for segregation of duties and conflict checking.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedDate rdf:type rdf:Property ;
    rdfs:label 'Processed Date' ;
    rdfs:comment 'The date on which the disbursement was processed and submitted for payment. May differ from disbursement date due to clearing time.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax classification code for the disbursement. Used for 1099 reporting and tax compliance when disbursements are made to vendors or experts.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'The wire transfer reference or confirmation number if payment method is wire transfer. Used for bank reconciliation.' ;
    rdfs:domain ind:TrustDisbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationChecklistId rdf:type rdf:Property ;
    rdfs:label 'Authorization Checklist Id' ;
    rdfs:comment 'Foreign key linking to knowledge.checklist. Business justification: Disbursement authorization workflows follow documented approval checklists (dual signatory requirements, AML screening steps, client consent verification). Ensures regulatory compliance and risk manag' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:creditLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Credit Ledger Entry Id' ;
    rdfs:comment 'FK to trust.trust_ledger_entry.trust_ledger_entry_id — Each authorization governs a specific disbursement transaction recorded in the ledger. Required for audit trail and compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:debitLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Debit Ledger Entry Id' ;
    rdfs:comment 'FK to trust.trust_ledger_entry.trust_ledger_entry_id — Each authorization governs a specific disbursement transaction (now a ledger entry of disbursement type). Without this link, authorizations are disconnected from the transactions they approve.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:primaryDisbursementAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Disbursement Attorney Profile Id' ;
    rdfs:comment 'Reference to the supervising partner responsible for first-level authorization. Required for dual-control framework.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Ledger Entry Id' ;
    rdfs:comment 'Reference to the trust ledger entry that this authorization governs. Links to the specific trust transaction requiring authorization.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:requestingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Requesting Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper who initiated the disbursement authorization request. Establishes accountability in the authorization chain.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryDisbursementRejectingApproverAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disbursement Rejecting Approver Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper who rejected the disbursement authorization. Null if not rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date after which the authorization becomes invalid if disbursement has not been executed. Enforces time-bound authorization controls.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique business identifier for the disbursement authorization. Human-readable reference number used in audit trails and regulatory reporting.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConsentDate rdf:type rdf:Property ;
    rdfs:label 'Client Consent Date' ;
    rdfs:comment 'Date on which client consent was obtained for the disbursement. Null if consent not required or not yet obtained.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientConsentMethod rdf:type rdf:Property ;
    rdfs:label 'Client Consent Method' ;
    rdfs:comment 'Method by which client consent was obtained. Required for audit trail and regulatory compliance when consent is mandatory.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference1 rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference 1' ;
    rdfs:comment 'Reference identifier or hash of the first digital signature applied to the authorization. Used for non-repudiation and regulatory compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference2 rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference 2' ;
    rdfs:comment 'Reference identifier or hash of the second digital signature applied when dual signatory is required. Null if single signature sufficient.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursement Amount' ;
    rdfs:comment 'The monetary amount being authorized for disbursement from the client trust account. Must not exceed available trust balance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementCurrency rdf:type rdf:Property ;
    rdfs:label 'Disbursement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disbursement amount. Required for multi-currency trust accounting.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementPurpose rdf:type rdf:Property ;
    rdfs:label 'Disbursement Purpose' ;
    rdfs:comment 'Detailed business justification and purpose for the trust fund disbursement. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualSignatoryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Signatory Required Flag' ;
    rdfs:comment 'Indicates whether dual signatory approval is required for this disbursement based on amount threshold or disbursement type. True if managing partner approval is mandatory.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualSignatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dual Signatory Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which dual signatory approval is required. Captured at time of authorization for audit purposes.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Final Authorization Date' ;
    rdfs:comment 'Date on which the disbursement received final authorization and became executable. Represents completion of approval workflow.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalAuthorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Authorization Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement authorization workflow was completed and funds became available for disbursement.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managingPartnerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Managing Partner Approval Date' ;
    rdfs:comment 'Date on which the managing partner approved the disbursement. Null if not required, not yet approved, or rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managingPartnerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Managing Partner Approval Timestamp' ;
    rdfs:comment 'Precise date and time of managing partner approval. Required for high-value disbursements exceeding dual-signatory threshold.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time when the disbursement authorization request was submitted. Required for audit trail and workflow tracking.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisingPartnerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Approval Date' ;
    rdfs:comment 'Date on which the supervising partner approved the disbursement. Null if not yet approved or if rejected.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisingPartnerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervising Partner Approval Timestamp' ;
    rdfs:comment 'Precise date and time of supervising partner approval. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:DisbursementAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeWayReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Three Way Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the three-way reconciliation record. Primary key for the reconciliation entity.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThreeWayReconciliation .

ind:approverTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Approver Timekeeper Id' ;
    rdfs:comment 'Reference to the partner or designated trust account signatory who provided final approval and sign-off on the reconciliation. Required under most jurisdictions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:bankStatementId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Id' ;
    rdfs:comment 'FK to trust.bank_statement.bank_statement_id — Each reconciliation references the specific bank statement used as the external balance source. Critical for audit trail.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatement .

ind:primaryThreeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Three Timekeeper Id' ;
    rdfs:comment 'Reference to the staff member (typically accounting staff or trust accountant) who performed the reconciliation. Links to workforce.attorney_profile or staff record.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reconciledAccountId rdf:type rdf:Property ;
    rdfs:label 'Reconciled Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Each reconciliation is performed for a specific trust account. Without this FK, reconciliation records cannot be associated with the account they validate.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:reconciliationChecklistId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Checklist Id' ;
    rdfs:comment 'Foreign key linking to knowledge.checklist. Business justification: Three-way reconciliation procedures follow standardized process checklists (bank statement matching, ledger verification, client balance confirmation). Critical for regulatory compliance and audit rea' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:bankErrorsTotal rdf:type rdf:Property ;
    rdfs:label 'Bank Errors Total' ;
    rdfs:comment 'Total amount of errors identified on the bank statement (incorrect charges, duplicate transactions, posting errors). Requires bank correction and documentation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementBalance rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Balance' ;
    rdfs:comment 'The ending balance reported on the bank statement for the trust account as of the reconciliation period end date. First leg of the three-way reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookBalance rdf:type rdf:Property ;
    rdfs:label 'Book Balance' ;
    rdfs:comment 'The trust ledger balance per the firms accounting system (Elite 3E GL trust account) as of the reconciliation period end date. Second leg of the three-way reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientLedgerTotal rdf:type rdf:Property ;
    rdfs:label 'Client Ledger Total' ;
    rdfs:comment 'The sum of all individual client sub-ledger balances as of the reconciliation period end date. Third leg of the three-way reconciliation. Must equal book_balance when no variances exist.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositsInTransitTotal rdf:type rdf:Property ;
    rdfs:label 'Deposits In Transit Total' ;
    rdfs:comment 'Total amount of deposits recorded in the trust ledger but not yet reflected on the bank statement as of the reconciliation date. Reconciling item between book and bank balances.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'The number of reconciling items (outstanding checks, deposits in transit, errors) identified during this reconciliation. Zero indicates clean reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledgerErrorsTotal rdf:type rdf:Property ;
    rdfs:label 'Ledger Errors Total' ;
    rdfs:comment 'Total amount of errors identified in the firms trust ledger (posting errors, incorrect amounts, duplicate entries). Requires correcting journal entries and audit trail.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingChecksTotal rdf:type rdf:Property ;
    rdfs:label 'Outstanding Checks Total' ;
    rdfs:comment 'Total amount of checks issued from the trust account that have not yet cleared the bank as of the reconciliation date. Reconciling item between book and bank balances.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodUnresolvedVariance rdf:type rdf:Property ;
    rdfs:label 'Prior Period Unresolved Variance' ;
    rdfs:comment 'The unresolved variance amount carried forward from the previous reconciliation period. Should be resolved in current period or escalated.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'The method used to perform the reconciliation: manual (spreadsheet-based), semi_automated (system-assisted with manual review), fully_automated (system-generated with exception-only review).' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business identifier for the reconciliation record, typically formatted as RECON-YYYYMM-NNNN for monthly reconciliations.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Performed Date' ;
    rdfs:comment 'The date on which the reconciliation work was completed by the preparer. Must be within regulatory timeframes (typically within 30 days of period end).' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End Date' ;
    rdfs:comment 'The last day of the period covered by this reconciliation, typically the last day of the month. Mandatory monthly reconciliation under most jurisdictions.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start Date' ;
    rdfs:comment 'The first day of the period covered by this reconciliation, typically the first day of the month.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'The date on which this reconciliation was submitted to the regulatory authority, if required. Null if no filing is required or filing is pending.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this reconciliation must be submitted to the regulatory authority (e.g., annual IOLTA report, SRA accountants report). True if filing is required.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'The date on which the reviewer completed their review of the reconciliation. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timingDifferencesTotal rdf:type rdf:Property ;
    rdfs:label 'Timing Differences Total' ;
    rdfs:comment 'Total amount of legitimate timing differences between book and bank that will self-resolve in subsequent periods (e.g., end-of-month transactions posted next business day).' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'The net difference between the three reconciliation legs. Calculated as (bank_statement_balance + outstanding_items) - book_balance. Zero indicates perfect reconciliation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unresolvedExceptionCount rdf:type rdf:Property ;
    rdfs:label 'Unresolved Exception Count' ;
    rdfs:comment 'The number of reconciling items that remain unresolved as of the current date. Non-zero values require follow-up and escalation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unresolvedVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Unresolved Variance Amount' ;
    rdfs:comment 'Amount of variance that remains unexplained after all reconciling items have been identified and documented. Non-zero values require escalation and investigation.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Resolution Notes' ;
    rdfs:comment 'Detailed narrative explaining identified variances, root cause analysis, corrective actions taken, and resolution status. Required for regulatory examination audit trail.' ;
    rdfs:domain ind:ThreeWayReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationItemId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Item Id' ;
    rdfs:comment 'Unique identifier for the reconciliation item. Primary key for the reconciliation item entity.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReconciliationTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Reconciliation Timekeeper Id' ;
    rdfs:comment 'Reference to the trust accounting staff member or attorney responsible for investigating and resolving this reconciliation item. Enables workload tracking and accountability.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actualClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Actual Clearance Date' ;
    rdfs:comment 'Date when this reconciliation item was actually resolved or cleared. Null until item status moves to resolved. Used for reconciliation cycle time analysis.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required' ;
    rdfs:comment 'Indicates whether this reconciliation item requires a correcting journal entry or ledger adjustment. True for ledger errors; false for timing differences that will self-resolve.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days since this reconciliation item was first identified. Calculated as current date minus identified date. Used for aging reports and escalation of overdue items.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chequeNumber rdf:type rdf:Property ;
    rdfs:label 'Cheque Number' ;
    rdfs:comment 'Cheque number for outstanding cheque reconciliation items. Enables tracking of uncleared cheques and matching with bank clearances.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositReference rdf:type rdf:Property ;
    rdfs:label 'Deposit Reference' ;
    rdfs:comment 'Reference number or identifier for deposits in transit. Links to deposit slip or wire transfer confirmation for clearance tracking.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Detailed narrative description of the reconciliation item, including the nature of the discrepancy, root cause analysis, and any corrective actions required. Critical for audit trail and regulatory examination.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Expected Clearance Date' ;
    rdfs:comment 'Anticipated date when this reconciliation item is expected to clear or resolve. Used for aging reports and escalation triggers for overdue items.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the reconciliation item. Tracks progression from identification through resolution and regulatory clearance.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the reconciling item that explains the variance between trust ledger, client sub-ledger, or bank statement. Determines the nature of the discrepancy and the required resolution action.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerEntryDate rdf:type rdf:Property ;
    rdfs:label 'Ledger Entry Date' ;
    rdfs:comment 'Date of the corresponding trust ledger entry related to this reconciliation item. Used to calculate timing differences between ledger and bank.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Originating Transaction Reference' ;
    rdfs:comment 'Reference number or identifier of the underlying trust transaction that caused this reconciliation item. May reference a cheque number, deposit slip, wire transfer ID, or ledger entry number.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationSide rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Side' ;
    rdfs:comment 'Indicates which side of the three-way reconciliation this item affects. Determines whether the variance is a bank-side or ledger-side adjustment.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this reconciliation item must be reported to the state bar or IOLTA oversight authority. True for material discrepancies, unresolved items exceeding aging thresholds, or suspected misappropriation.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresClientNotification rdf:type rdf:Property ;
    rdfs:label 'Requires Client Notification' ;
    rdfs:comment 'Indicates whether this reconciliation item requires notification to the affected client under ethical rules or firm policy. True for material discrepancies affecting client funds.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The monetary value of the discrepancy identified during reconciliation. Positive values indicate amounts on bank statement not yet in ledger; negative values indicate ledger entries not yet cleared by bank.' ;
    rdfs:domain ind:ReconciliationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Bank Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this bank statement record. Required for audit trail and compliance.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reconciliationPeriodId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Id' ;
    rdfs:comment 'Foreign key to trust.reconciliation_period.reconciliation_period_id' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReconciliationPeriod .

ind:statementOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Statement Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who performed and approved the reconciliation of this bank statement. Required for audit trail and compliance.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:averageDailyBalance rdf:type rdf:Property ;
    rdfs:label 'Average Daily Balance' ;
    rdfs:comment 'The average daily balance for the trust account during the statement period as calculated by the financial institution. Used for interest calculation verification.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The branch or office code of the financial institution where the trust account is held. May be used for multi-branch reconciliation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The account balance at the end of the statement period as reported by the financial institution. This is the external reference balance for three-way reconciliation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'The net difference between the bank statement closing balance and the trust ledger balance at the end of the statement period. Zero indicates a balanced reconciliation.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importTimestamp rdf:type rdf:Property ;
    rdfs:label 'Import Timestamp' ;
    rdfs:comment 'The date and time when this bank statement was imported or entered into the trust accounting system.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interestEarned rdf:type rdf:Property ;
    rdfs:label 'Interest Earned' ;
    rdfs:comment 'The total interest earned on the trust account during this statement period. Critical for IOLTA reporting and remittance to state bar foundations.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Iolta Reporting Period' ;
    rdfs:comment 'The IOLTA reporting period identifier (e.g., Q1-2024, 2024-01) to which this statement belongs. Used for regulatory reporting aggregation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalStatement rdf:type rdf:Property ;
    rdfs:label 'Is Final Statement' ;
    rdfs:comment 'Indicates whether this is the final statement for a closed trust account. Used for account closure workflows and compliance reporting.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The account balance at the beginning of the statement period as reported by the financial institution.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The nine-digit ABA routing number for the financial institution. Used for electronic funds transfer and account identification.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCharges rdf:type rdf:Property ;
    rdfs:label 'Service Charges' ;
    rdfs:comment 'The total bank fees and service charges deducted during the statement period. Must be tracked separately for IOLTA compliance.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The official statement date as printed on the bank statement by the financial institution. Typically the same as the statement period end date.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFileHash rdf:type rdf:Property ;
    rdfs:label 'Statement File Hash' ;
    rdfs:comment 'The cryptographic hash (e.g., SHA-256) of the original statement file. Ensures document integrity and detects tampering for compliance purposes.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFilePath rdf:type rdf:Property ;
    rdfs:label 'Statement File Path' ;
    rdfs:comment 'The storage location or document management system path where the original bank statement file is archived. Used for audit retrieval.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'The file format or data standard of the original statement document. Used for parsing and validation logic.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this bank statement. May include reconciliation notes, exception explanations, or special instructions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'The unique statement number or reference assigned by the financial institution for this statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date covered by this bank statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date covered by this bank statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementSource rdf:type rdf:Property ;
    rdfs:label 'Statement Source' ;
    rdfs:comment 'The method by which this bank statement was imported or entered into the system. Indicates data provenance for audit purposes.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditCount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Count' ;
    rdfs:comment 'The number of credit transactions posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'The sum of all credit transactions (deposits, interest, reversals) posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitCount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Count' ;
    rdfs:comment 'The number of debit transactions posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDebits rdf:type rdf:Property ;
    rdfs:label 'Total Debits' ;
    rdfs:comment 'The sum of all debit transactions (withdrawals, fees, disbursements) posted during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Transaction Count' ;
    rdfs:comment 'The number of bank statement line items that have not been matched to a corresponding trust ledger entry. Used to identify reconciliation exceptions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Line Id' ;
    rdfs:comment 'Unique identifier for the bank statement line item. Primary key for this entity.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankReconciledByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Bank Reconciled By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who marked this bank statement line as reconciled. Supports audit trail and accountability for trust account reconciliation sign-off.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:bankVoidedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Bank Voided By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who voided this bank statement line. Supports audit trail and accountability.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:duplicateOfLineBankStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Duplicate Of Line Bank Statement Line Id' ;
    rdfs:comment 'Reference to the original bank statement line if this line is marked as a duplicate. Null if not a duplicate. Supports duplicate resolution and audit trail.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatementLine .

ind:lineOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Line Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who manually matched or approved the match for this bank statement line. Null for automatic matches. Supports audit trail and accountability.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:matchedTrustLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Matched Trust Ledger Entry Id' ;
    rdfs:comment 'Reference to the trust ledger entry that has been matched to this bank statement line during reconciliation. Null if unmatched or under review.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:bankTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Code' ;
    rdfs:comment 'The bank-specific transaction type code (e.g., CHK for check, DEP for deposit, FEE for bank fee, INT for interest). Used to classify transaction types during import.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The amount debited from the trust account for this transaction. Null if the transaction is a credit. Represents outflows such as disbursements, fees, or transfers out.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating why this bank statement line is flagged as an exception or remains unmatched. Used for exception reporting and root cause analysis. [ENUM-REF-CANDIDATE: amount_mismatch|date_mismatch|missing_ledger_entry|duplicate_bank_entry|unidentified_transaction|bank_error|timing_difference — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importBatchReference rdf:type rdf:Property ;
    rdfs:label 'Import Batch Reference' ;
    rdfs:comment 'Identifier for the batch import process that loaded this bank statement line. Used for traceability, error investigation, and re-import scenarios.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importSourceFileName rdf:type rdf:Property ;
    rdfs:label 'Import Source File Name' ;
    rdfs:comment 'The name of the source file (e.g., bank statement CSV, BAI2, or OFX file) from which this line was imported. Supports audit trail and source verification.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDuplicate rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate' ;
    rdfs:comment 'Indicates whether this bank statement line has been identified as a duplicate of another line (e.g., due to overlapping statement imports). Used to prevent double-counting in reconciliation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Indicates whether this bank statement line has been fully reconciled and approved as part of the three-way reconciliation process. True when reconciliation is complete and signed off.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoid rdf:type rdf:Property ;
    rdfs:label 'Is Void' ;
    rdfs:comment 'Indicates whether this bank statement line has been voided (e.g., due to bank error correction or reversal). Voided lines are excluded from reconciliation totals.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this line within the parent bank statement. Used to preserve the original bank statement line order for audit and reconciliation purposes.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matched Timestamp' ;
    rdfs:comment 'The date and time when this bank statement line was matched to a trust ledger entry. Used for reconciliation audit trail and performance metrics.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Matching Confidence Score' ;
    rdfs:comment 'Automated matching algorithm confidence score (0.00 to 100.00) indicating the likelihood that the matched trust ledger entry is correct. Used to prioritize manual review of low-confidence matches.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingMethod rdf:type rdf:Property ;
    rdfs:label 'Matching Method' ;
    rdfs:comment 'The method by which this bank statement line was matched to a trust ledger entry. Supports audit trail and matching algorithm performance analysis.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingStatus rdf:type rdf:Property ;
    rdfs:label 'Matching Status' ;
    rdfs:comment 'Indicates whether this bank statement line has been successfully matched to a trust ledger entry during reconciliation. Unmatched lines require investigation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeePayorName rdf:type rdf:Property ;
    rdfs:label 'Payee Payor Name' ;
    rdfs:comment 'The name of the party to or from whom the funds were transferred. Extracted from bank transaction description or provided as a structured field. Used in matching and audit trails.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the bank posted the transaction to the account ledger. Used for reconciliation timing differences and float analysis.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'The date and time when this bank statement line was marked as reconciled. Used for compliance reporting and audit trail.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for this transaction. Typically matches the trust account base currency but may differ for foreign currency transactions.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'The narrative description of the transaction as provided by the bank. Contains payee/payor information, check numbers, wire references, and other identifying details used in matching.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'The unique reference or confirmation number assigned by the bank to this transaction. Used for tracing and dispute resolution.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Explanation for why this bank statement line was voided. Supports audit trail and compliance documentation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'The date and time when this bank statement line was voided. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ioltaInterestRemittanceId rdf:type rdf:Property ;
    rdfs:label 'Iolta Interest Remittance Id' ;
    rdfs:comment 'Unique identifier for the IOLTA interest remittance record. Primary key.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIoltaTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Iolta Timekeeper Id' ;
    rdfs:comment 'Reference to the user or staff member who prepared and submitted the remittance.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:sourceAccountId rdf:type rdf:Property ;
    rdfs:label 'Source Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Each interest remittance is generated from a specific IOLTA pooled trust account. Required for regulatory reporting.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:bankServiceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Service Charge Amount' ;
    rdfs:comment 'Total bank service charges, fees, or administrative costs deducted from gross interest during the remittance period.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date on which compliance certification was completed for this remittance.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether the remittance has been certified as compliant with all applicable IOLTA program rules and ABA Model Rules.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form1099IssuedDate rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Issued Date' ;
    rdfs:comment 'Date on which IRS Form 1099-INT was issued to the recipient organization for this remittance, if applicable.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:form1099RequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Required Flag' ;
    rdfs:comment 'Indicates whether this remittance requires IRS Form 1099-INT reporting to the recipient organization.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossInterestEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Interest Earned Amount' ;
    rdfs:comment 'Total interest earned on the pooled IOLTA account during the remittance period before any deductions.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRemittanceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Remittance Amount' ;
    rdfs:comment 'Net amount remitted to the IOLTA program after deducting bank service charges from gross interest earned.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipientOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Recipient Organization Name' ;
    rdfs:comment 'Full legal name of the state IOLTA program, legal aid foundation, or designated recipient organization receiving the remittance.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax Identification Number of the recipient organization for IRS reporting purposes.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes documenting reconciliation findings, discrepancies, or adjustments related to this remittance.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'Date on which the net remittance amount was paid or transferred to the recipient IOLTA program.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Number' ;
    rdfs:comment 'Business identifier for the remittance transaction, typically assigned by the firm or trust accounting system.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Period End Date' ;
    rdfs:comment 'Last day of the period for which interest was earned and is being remitted.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Period Start Date' ;
    rdfs:comment 'First day of the period for which interest was earned and is being remitted.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Current lifecycle status of the remittance transaction (pending, submitted, confirmed, reconciled, or disputed).' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingQuarter rdf:type rdf:Property ;
    rdfs:label 'Reporting Quarter' ;
    rdfs:comment 'Calendar quarter (Q1, Q2, Q3, Q4) for which this remittance is reported, if quarterly reporting is required.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Calendar year for which this remittance is reported to the IOLTA program and IRS.' ;
    rdfs:domain ind:IoltaInterestRemittance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the trust transfer transaction. Primary key.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAccountId rdf:type rdf:Property ;
    rdfs:label 'Destination Account Id' ;
    rdfs:comment 'Identifier of the trust account or operating account to which funds are being transferred. Links to the account master record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryReversalOfTransferId rdf:type rdf:Property ;
    rdfs:label 'Primary Reversal Of Transfer Id' ;
    rdfs:comment 'If this transfer is a reversal or correction of a prior transfer, this field contains the trust_transfer_id of the original transaction being reversed. Null for original transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transfer .

ind:sourceLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Source Ledger Entry Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_ledger_entry. Business justification: Links the trust transfer to the ledger entry representing the debit from the source account. Every transfer generates at least two ledger entries (debit source, credit destination) for double-entry ac' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:transferCreatedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Transfer Created By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this trust transfer record. Required for segregation of duties and audit trail.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:transferModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Transfer Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this trust transfer record. Required for audit trail and change tracking.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:transferOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Transfer Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user (typically a partner or trust account administrator) who authorized this trust transfer. Required for segregation of duties and fiduciary accountability.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:transferReconciledByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Transfer Reconciled By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who performed or approved the reconciliation of this transfer. Part of the audit trail for trust account governance.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'Date and time when the trust transfer was authorized by the responsible user. Part of the audit trail for trust account governance.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'The external bank transaction reference, confirmation number, or trace ID provided by the financial institution for this transfer. Used for three-way reconciliation between firm ledger, bank statement, and client ledger.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Fee Amount' ;
    rdfs:comment 'The portion of the transfer amount that represents earned legal fees being moved from trust to operating account. Null for non-fee transfers.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Applicable Flag' ;
    rdfs:comment 'Indicates whether this transfer involves an IOLTA account and is subject to IOLTA reporting and interest allocation rules. True if IOLTA rules apply, false otherwise.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The business date on which the trust transfer was executed or is scheduled to be executed. This is the effective date for trust ledger posting and three-way reconciliation purposes.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-visible business identifier for the trust transfer, formatted as TT-YYYYMMDD-NNNN for audit trail and reference purposes.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the trust transfer: draft (being prepared), pending_approval (awaiting authorization), approved (authorized but not yet executed), in_transit (processing), completed (successfully executed), failed (execution error), reversed (unwound), or cancelled (voided before execution). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|failed|reversed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Precise date and time when the trust transfer transaction was executed in the system, used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the trust transfer movement: inter-trust (between client trust accounts), trust-to-operating (earned fees transferred to firm operating account), operating-to-trust (replenishment or correction), trust-to-client (disbursement to client), client-to-trust (initial deposit), or trust-refund (return of unearned funds).' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retainer Agreement Id' ;
    rdfs:comment 'Unique identifier for the retainer agreement record. Primary key. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementPrecedentId rdf:type rdf:Property ;
    rdfs:label 'Agreement Precedent Id' ;
    rdfs:comment 'Foreign key linking to knowledge.precedent. Business justification: Retainer agreements are drafted from approved precedent templates (evergreen retainers, matter-specific retainers, security retainers). Ensures consistent terms, regulatory compliance, and risk manage' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Precedent .

ind:retainerAccountId rdf:type rdf:Property ;
    rdfs:label 'Retainer Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Retainer agreement governs funds held in a specific trust account. Required for replenishment threshold monitoring.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:retainerLastModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Retainer Last Modified By Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this retainer agreement record.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreedRetainerAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Retainer Amount' ;
    rdfs:comment 'The total retainer amount agreed upon in the retainer agreement, representing the initial or target balance to be held in trust.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automatic replenishment is enabled for this retainer agreement. True for evergreen retainers with automatic replenishment; false otherwise.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date of the most recent compliance review of this retainer agreement against IOLTA rules and jurisdiction-specific trust accounting regulations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialDepositDate rdf:type rdf:Property ;
    rdfs:label 'Initial Deposit Date' ;
    rdfs:comment 'The date on which the initial retainer deposit was received and posted to the trust account.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestBearing rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing' ;
    rdfs:comment 'Indicates whether the retainer funds are held in an interest-bearing trust account (IOLTA) or a non-interest-bearing account, per jurisdiction-specific trust accounting rules.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundDueAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Due Amount' ;
    rdfs:comment 'The amount due to be refunded to the client upon termination or conclusion of the retainer agreement, representing unused retainer funds.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'The date on which any refund of unused retainer funds was processed and returned to the client. Null if no refund has been processed.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Amount' ;
    rdfs:comment 'The amount to be deposited when the retainer balance falls below the replenishment threshold (applicable to evergreen retainers). Null for non-evergreen retainers.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold Amount' ;
    rdfs:comment 'The minimum balance threshold below which the retainer must be replenished (applicable to evergreen retainers). Null for non-evergreen retainers.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Retainer Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the retainer agreement: draft (not yet executed), active (in force and available for draw), suspended (temporarily inactive), depleted (balance exhausted), expired (past end date), terminated (closed by client or firm).' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerDescription rdf:type rdf:Property ;
    rdfs:label 'Retainer Description' ;
    rdfs:comment 'Detailed description of the retainer agreement, including the scope of work covered, any special terms, and client-specific arrangements.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeposits rdf:type rdf:Property ;
    rdfs:label 'Total Deposits' ;
    rdfs:comment 'The cumulative total of all deposits made to this retainer agreement since inception, including initial deposit and all replenishments.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisbursements rdf:type rdf:Property ;
    rdfs:label 'Total Disbursements' ;
    rdfs:comment 'The cumulative total of all disbursements drawn from this retainer agreement since inception, representing work performed and billed against the retainer.' ;
    rdfs:domain ind:RetainerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retainerReplenishmentId rdf:type rdf:Property ;
    rdfs:label 'Retainer Replenishment Id' ;
    rdfs:comment 'Unique identifier for the retainer replenishment transaction. Primary key for this product.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRetainerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Retainer Agreement Id' ;
    rdfs:comment 'FK to trust.retainer_agreement.retainer_agreement_id — Each replenishment event is triggered by and governed by a specific retainer agreements threshold rules.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetainerAgreement .

ind:toRetainerAgreementId rdf:type rdf:Property ;
    rdfs:label 'To Retainer Agreement Id' ;
    rdfs:comment 'FK to trust.retainer_agreement.retainer_agreement_id — Each replenishment event is triggered by and references a specific retainer agreement. Without this link, replenishment records cannot be associated with their governing agreement.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetainerAgreement .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'The date on which the replenishment funds were actually received and posted to the client trust account.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceAtTrigger rdf:type rdf:Property ;
    rdfs:label 'Balance At Trigger' ;
    rdfs:comment 'The trust account balance at the moment the replenishment threshold was breached, expressed in the retainer currency.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientResponseDate rdf:type rdf:Property ;
    rdfs:label 'Client Response Date' ;
    rdfs:comment 'The date on which the client acknowledged or responded to the replenishment request.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the replenishment has been outstanding beyond the expected receipt date.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'The date by which the client committed to provide the replenishment funds, based on client communication or payment terms.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpCount rdf:type rdf:Property ;
    rdfs:label 'Follow Up Count' ;
    rdfs:comment 'Number of follow-up communications sent to the client regarding this replenishment request.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Last Follow Up Date' ;
    rdfs:comment 'The date of the most recent follow-up communication sent to the client regarding this replenishment.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Indicates whether the replenishment request has exceeded the expected receipt date without being fulfilled.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the replenishment request, used in client communications and internal tracking.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment request, tracking progress from initial request through final resolution. [ENUM-REF-CANDIDATE: requested|acknowledged|received|partially_received|overdue|waived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSentDate rdf:type rdf:Property ;
    rdfs:label 'Request Sent Date' ;
    rdfs:comment 'The date on which the replenishment request was formally communicated to the client.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestSentMethod rdf:type rdf:Property ;
    rdfs:label 'Request Sent Method' ;
    rdfs:comment 'The communication channel used to send the replenishment request to the client.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredReplenishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Required Replenishment Amount' ;
    rdfs:comment 'The amount requested from the client to restore the retainer balance to the agreed target level.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBalanceAfterReplenishment rdf:type rdf:Property ;
    rdfs:label 'Target Balance After Replenishment' ;
    rdfs:comment 'The intended trust account balance after the replenishment is received, as defined in the retainer agreement.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trigger Timestamp' ;
    rdfs:comment 'The precise date and time when the retainer balance threshold breach was detected by the system.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trustAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Trust Account Number' ;
    rdfs:comment 'The specific IOLTA or client trust account number into which the replenishment funds are to be deposited.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'The date on which the replenishment waiver was formally approved by authorized personnel.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the partner or authorized personnel who approved the replenishment waiver.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipExposureAtTrigger rdf:type rdf:Property ;
    rdfs:label 'Wip Exposure At Trigger' ;
    rdfs:comment 'The total unbilled work in progress amount for the matter at the time the replenishment was triggered, indicating the firms financial exposure.' ;
    rdfs:domain ind:RetainerReplenishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escrowAccountId rdf:type rdf:Property ;
    rdfs:label 'Escrow Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Each escrow arrangement is held within a specific trust account. Required for fund segregation and balance tracking.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:beneficiaryPartyRole rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Role' ;
    rdfs:comment 'Role of the beneficiary party in the underlying transaction.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositorPartyName rdf:type rdf:Property ;
    rdfs:label 'Depositor Party Name' ;
    rdfs:comment 'Name of the party or entity that deposited funds into escrow (e.g., buyer, seller, borrower).' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositorPartyRole rdf:type rdf:Property ;
    rdfs:label 'Depositor Party Role' ;
    rdfs:comment 'Role of the depositor party in the underlying transaction.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAgentName rdf:type rdf:Property ;
    rdfs:label 'Escrow Agent Name' ;
    rdfs:comment 'Name of the law firm, attorney, or third-party institution acting as escrow agent and fiduciary holder of the funds.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Escrow Agreement Reference' ;
    rdfs:comment 'Document reference or identifier for the governing escrow agreement that defines terms, conditions, and release triggers.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowAmount rdf:type rdf:Property ;
    rdfs:label 'Escrow Amount' ;
    rdfs:comment 'Total monetary amount held in escrow at establishment, representing the initial deposit or holdback amount.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escrowPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Escrow Period End Date' ;
    rdfs:comment 'Scheduled end date of the escrow holding period, after which remaining funds may be released per agreement terms or extended by mutual consent.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escrowPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Escrow Period Start Date' ;
    rdfs:comment 'Start date of the escrow holding period as defined in the escrow agreement, from which release conditions and timelines are measured.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escrowPurpose rdf:type rdf:Property ;
    rdfs:label 'Escrow Purpose' ;
    rdfs:comment 'Detailed description of the business purpose for which the escrow was established (e.g., M&A purchase price holdback, indemnity reserve, real estate deposit, earnout payment reserve).' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escrowStatus rdf:type rdf:Property ;
    rdfs:label 'Escrow Status' ;
    rdfs:comment 'Current lifecycle status of the escrow arrangement indicating its operational state and release progress.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date on which the escrow arrangement was formally established and funds were initially deposited into escrow.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Allocation Method' ;
    rdfs:comment 'Method by which accrued interest on escrowed funds is allocated, in compliance with IOLTA regulations and escrow agreement.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date of the most recent release or disbursement event from this escrow arrangement.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Detailed description of the conditions, milestones, or events that must be satisfied before funds can be released from escrow (e.g., completion of due diligence, satisfaction of indemnity claims, passage of time).' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseScheduleType rdf:type rdf:Property ;
    rdfs:label 'Release Schedule Type' ;
    rdfs:comment 'Classification of the release mechanism governing how and when escrowed funds are disbursed.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Released Amount' ;
    rdfs:comment 'Cumulative total amount released from escrow to date across all release events. Calculated field maintained for reporting and reconciliation.' ;
    rdfs:domain ind:EscrowArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryEscrowAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Escrow Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney who authorized the escrow release. Must be a qualified signatory per the escrow agreement and trust account rules.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:amlReviewDate rdf:type rdf:Property ;
    rdfs:label 'Aml Review Date' ;
    rdfs:comment 'The date on which AML compliance review was completed for this escrow release.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Review Status' ;
    rdfs:comment 'Status of AML compliance review for this escrow release. Large releases or releases to high-risk jurisdictions require AML clearance.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Number' ;
    rdfs:comment 'Bank account number or payment account identifier for the beneficiary receiving the escrow release.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Code' ;
    rdfs:comment 'Bank identifier code (BIC/SWIFT code or routing number) for the beneficiary financial institution.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Name' ;
    rdfs:comment 'Name of the financial institution where the beneficiary account is held.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Full legal name of the party receiving the escrow release. May be an individual or organization.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'Classification of the beneficiary receiving the escrow release (individual, organization, government entity, trust, estate, or other).' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netReleaseAmount rdf:type rdf:Property ;
    rdfs:label 'Net Release Amount' ;
    rdfs:comment 'Net amount disbursed to the beneficiary after deducting any tax withholding or fees. Equals release_amount minus tax_withholding_amount.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postReleaseEscrowBalance rdf:type rdf:Property ;
    rdfs:label 'Post Release Escrow Balance' ;
    rdfs:comment 'The residual balance remaining in the escrow account after this release was executed. Used for three-way reconciliation.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preReleaseEscrowBalance rdf:type rdf:Property ;
    rdfs:label 'Pre Release Escrow Balance' ;
    rdfs:comment 'The total balance in the escrow account immediately before this release was executed.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseAmount rdf:type rdf:Property ;
    rdfs:label 'Release Amount' ;
    rdfs:comment 'The monetary amount released from escrow to the beneficiary. Represents the gross disbursement before any fees or adjustments.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Release Condition Description' ;
    rdfs:comment 'Detailed description of the escrow release condition that was satisfied, triggering the release (e.g., closing of M&A transaction, satisfaction of regulatory approval, completion of due diligence milestone).' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditionSatisfiedDate rdf:type rdf:Property ;
    rdfs:label 'Release Condition Satisfied Date' ;
    rdfs:comment 'The date on which the escrow release condition was satisfied, making the funds eligible for release.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Business-facing unique identifier for the escrow release transaction. Used in client communications and audit trails.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasePurpose rdf:type rdf:Property ;
    rdfs:label 'Release Purpose' ;
    rdfs:comment 'Business purpose or reason for the escrow release (e.g., M&A closing payment, indemnity claim settlement, milestone payment, dispute resolution settlement).' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the escrow release transaction (pending authorization, approved, executed/completed, cancelled, failed, or reversed).' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the escrow release was executed and funds were disbursed. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'Amount withheld from the escrow release for tax purposes, if applicable (e.g., withholding tax on cross-border payments).' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxWithholdingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Jurisdiction' ;
    rdfs:comment 'Jurisdiction code for the tax authority requiring withholding on this escrow release.' ;
    rdfs:domain ind:EscrowRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Id' ;
    rdfs:comment 'Unique identifier for the trust regulatory report. Primary key.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRegulatoryAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney or compliance officer who prepared the regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:acknowledgmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference Number' ;
    rdfs:comment 'Reference number or confirmation code issued by the regulatory body upon receipt or acknowledgment of the report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference number or identifier of the external audit report accompanying this regulatory submission, if applicable.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the certifying attorney signed and certified the report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discrepancyExplanation rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Explanation' ;
    rdfs:comment 'Detailed explanation of any discrepancies or irregularities identified in the trust account reconciliation.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external auditor or accounting firm that reviewed or audited the trust account records for this report, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioltaInterestEarned rdf:type rdf:Property ;
    rdfs:label 'Iolta Interest Earned' ;
    rdfs:comment 'Total interest earned on IOLTA accounts during the reporting period, if applicable.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioltaInterestRemitted rdf:type rdf:Property ;
    rdfs:label 'Iolta Interest Remitted' ;
    rdfs:comment 'Total interest remitted to the IOLTA program or designated beneficiary during the reporting period.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether the report submission is past its regulatory due date.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfClientAccounts rdf:type rdf:Property ;
    rdfs:label 'Number Of Client Accounts' ;
    rdfs:comment 'Count of individual client trust accounts included in this regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTransactions rdf:type rdf:Property ;
    rdfs:label 'Number Of Transactions' ;
    rdfs:comment 'Total count of trust transactions (receipts and disbursements) during the reporting period.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedDate rdf:type rdf:Property ;
    rdfs:label 'Prepared Date' ;
    rdfs:comment 'Date on which the regulatory report was prepared and finalized internally.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queryDetails rdf:type rdf:Property ;
    rdfs:label 'Query Details' ;
    rdfs:comment 'Details of any queries or follow-up requests issued by the regulatory body in response to this report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Name' ;
    rdfs:comment 'Name of the regulatory authority or oversight body to which this report is submitted (e.g., State Bar Association, Solicitors Regulation Authority, Law Society).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryQueryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Query Flag' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory body has raised queries or requested additional information regarding this report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportFormat rdf:type rdf:Property ;
    rdfs:label 'Report Format' ;
    rdfs:comment 'File format or medium in which the report was prepared and submitted.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the regulatory report type as required by the governing jurisdiction or regulatory body.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTrustBalanceReported rdf:type rdf:Property ;
    rdfs:label 'Total Trust Balance Reported' ;
    rdfs:comment 'Total balance of client trust funds reported for the period, as declared in the regulatory report.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountAuditId rdf:type rdf:Property ;
    rdfs:label 'Account Audit Id' ;
    rdfs:comment 'Unique identifier for the trust account audit record. Primary key.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditMethodologyPrecedentId rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology Precedent Id' ;
    rdfs:comment 'Foreign key linking to knowledge.precedent. Business justification: Audit procedures follow standardized methodologies documented as precedents (audit programs, testing procedures, sampling frameworks). Auditors reference these precedents to ensure consistent, complia' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Precedent .

ind:controlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Trust audits test controls within specific frameworks (SRA Accounts Rules, ABA Model Rules, state bar rules). Framework scope defines audit procedures and control objectives. Links audit to framework ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:auditCost rdf:type rdf:Property ;
    rdfs:label 'Audit Cost' ;
    rdfs:comment 'Total cost of the audit engagement, including auditor fees, travel expenses, and internal resource costs. Tracked for budgeting and cost management.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'Primary audit methodology employed: risk-based, substantive testing, controls testing, analytical review, full population review, or sampling approach.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique identifier for this audit engagement, assigned by the auditor or compliance department.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'Ending date of the period under audit examination. Defines the temporal scope of transactions and balances reviewed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'Beginning date of the period under audit examination. Defines the temporal scope of transactions and balances reviewed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific accounts, transaction types, controls, and compliance areas examined. May reference specific IOLTA rules, three-way reconciliation procedures, or segregation requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: scheduled, in progress, fieldwork complete, draft report, final report issued, closed, or remediation pending. [ENUM-REF-CANDIDATE: scheduled|in_progress|fieldwork_complete|draft_report|final_report_issued|closed|remediation_pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement: bar association spot examination, annual external accountant review (required in many jurisdictions), internal compliance audit, regulatory examination, three-way reconciliation audit, or IOLTA compliance review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Email' ;
    rdfs:comment 'Primary email address for the lead auditor or audit firm contact.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Phone' ;
    rdfs:comment 'Primary phone number for the lead auditor or audit firm contact.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Auditor License Number' ;
    rdfs:comment 'Professional license or registration number of the auditor or audit firm. For CPAs, this is the state board license number.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the individual auditor or audit firm conducting the examination. For external audits, this is the CPA firm name; for internal audits, the compliance officer name.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor conducting the examination: internal compliance officer, external CPA firm, bar association examiner, regulatory authority, or independent consultant.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of deficiencies or exceptions identified during the audit. Includes both material and non-material findings.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldworkCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Completion Date' ;
    rdfs:comment 'Date when on-site or remote audit fieldwork was completed. Marks the end of evidence gathering.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of audit findings, including key observations, deficiencies identified, and areas of non-compliance. Detailed findings are typically stored in a separate findings detail table.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up audit to verify remediation completion.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify remediation of identified deficiencies. True if re-examination is mandated.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Material Deficiency Count' ;
    rdfs:comment 'Number of material deficiencies identified that represent significant compliance risks or control weaknesses requiring immediate remediation.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditResult rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Result' ;
    rdfs:comment 'Summary conclusion of the audit: pass, pass with observations, fail, qualified opinion, adverse opinion, or disclaimer. Reflects the auditors overall assessment of trust account compliance.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date when all required remediation actions were completed and verified by the auditor or compliance officer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Date by which all remediation actions must be completed. Set by the auditor or regulatory authority based on the severity of findings.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the final audit report was formally issued to management or the regulatory body.' ;
    rdfs:domain ind:AccountAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustExceptionId rdf:type rdf:Property ;
    rdfs:label 'Trust Exception Id' ;
    rdfs:comment 'Unique identifier for the trust exception record. Primary key.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Trust exceptions identified during audits (unreconciled items, authorization failures, negative balances) become audit findings requiring management response and remediation. Direct audit trail from e' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:exceptionAccountId rdf:type rdf:Property ;
    rdfs:label 'Exception Account Id' ;
    rdfs:comment 'FK to trust.trust_account.trust_account_id — Each exception is identified within the context of a specific trust account. Required for exception investigation and resolution tracking.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:previousExceptionTrustExceptionId rdf:type rdf:Property ;
    rdfs:label 'Previous Exception Trust Exception Id' ;
    rdfs:comment 'Reference to the prior trust exception record if this is a recurrence.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustException .

ind:relatedTransactionLedgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Related Transaction Ledger Entry Id' ;
    rdfs:comment 'Reference to the specific trust ledger entry, receipt, or disbursement that triggered the exception, if applicable.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerEntry .

ind:amlScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Result' ;
    rdfs:comment 'Result of AML screening if the exception involves suspicious activity: clear (no sanctions or PEP match), potential_match (requires manual review), confirmed_match (positive match to sanctions list), not_screened (AML screening not applicable).' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the exception was identified: automated_rule (system control triggered), manual_review (discovered during manual inspection), reconciliation_process (found during three-way reconciliation), aml_screening (flagged by AML system), external_audit (identified by external auditor), client_inquiry (raised by client question).' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Precise timestamp when the exception was detected, including time zone information.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level categorization of the exception for reporting and workflow routing purposes.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business-facing unique identifier for the trust exception, formatted as TE-YYYYMMDD sequence.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception: open (newly detected, awaiting assignment), under_investigation (assigned and being investigated), pending_resolution (investigation complete, awaiting corrective action), resolved (corrective action taken), closed (resolved and verified), escalated (elevated to senior management or regulator).' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Indemnity Notification Date' ;
    rdfs:comment 'Date when the professional indemnity insurer was notified of the exception.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Detailed notes documenting the investigation process, findings, and analysis. May contain attorney work product and privileged information.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when active investigation of the exception commenced.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalIndemnityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Notified Flag' ;
    rdfs:comment 'Indicates whether the firms professional indemnity insurer has been notified of this exception due to potential claim risk.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this exception is a repeat occurrence of a previously resolved exception for the same account or matter.' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory body upon submission of the exception report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this exception must be reported to a regulatory body (state bar, IOLTA authority, or other governing body).' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of the corrective action taken to resolve the exception (e.g., journal entry posted, client contacted for clarification, disbursement voided, authorization obtained).' ;
    rdfs:domain ind:TrustException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the exception after investigation (e.g., data entry error, system configuration issue, process gap, client action).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unclaimedFundsRecordId rdf:type rdf:Property ;
    rdfs:label 'Unclaimed Funds Record Id' ;
    rdfs:comment 'Unique identifier for the unclaimed funds record. Primary key for tracking client trust funds subject to escheatment under state abandoned property laws.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientLastKnownAddress rdf:type rdf:Property ;
    rdfs:label 'Client Last Known Address' ;
    rdfs:comment 'Last known mailing address for the client. Used for outreach attempts and escheatment filing. May be outdated if client has moved.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOutreachAttempts rdf:type rdf:Property ;
    rdfs:label 'Client Outreach Attempts' ;
    rdfs:comment 'Number of documented attempts made to contact the client and return the unclaimed funds. Required due diligence before escheatment filing.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Response Received Flag' ;
    rdfs:comment 'Indicates whether the client responded to any outreach attempts. True if client contact was successfully established.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dormancyPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dormancy Period Days' ;
    rdfs:comment 'Number of days elapsed since the dormancy start date. Used to determine when funds become subject to escheatment under jurisdiction-specific rules.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dormancyStartDate rdf:type rdf:Property ;
    rdfs:label 'Dormancy Start Date' ;
    rdfs:comment 'Date when the trust funds were first identified as dormant based on last client activity or matter closure. Marks the beginning of the dormancy period calculation.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dormancyStatus rdf:type rdf:Property ;
    rdfs:label 'Dormancy Status' ;
    rdfs:comment 'Current lifecycle status of the unclaimed funds record. Tracks progression from identification through escheatment or resolution. [ENUM-REF-CANDIDATE: identified|under_review|outreach_in_progress|escheatment_pending|escheated|resolved|exempted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Filing Date' ;
    rdfs:comment 'Date when the unclaimed funds were reported to the state unclaimed property authority. Marks the formal escheatment filing submission.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentFilingReference rdf:type rdf:Property ;
    rdfs:label 'Escheatment Filing Reference' ;
    rdfs:comment 'Reference number or confirmation code from the state unclaimed property authority for the escheatment filing. Used for tracking and audit purposes.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escheatment Threshold Days' ;
    rdfs:comment 'Jurisdiction-mandated dormancy period (in days) after which unclaimed funds must be reported and remitted to the state. Varies by jurisdiction, typically 3-5 years.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Date' ;
    rdfs:comment 'Date when the exemption from escheatment was granted or determined. Marks the point when the record was removed from escheatment processing.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstOutreachDate rdf:type rdf:Property ;
    rdfs:label 'First Outreach Date' ;
    rdfs:comment 'Date of the first documented attempt to contact the client regarding the unclaimed funds. Part of the due diligence trail required for escheatment compliance.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioltaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Iolta Reportable Flag' ;
    rdfs:comment 'Indicates whether the unclaimed funds originated from an IOLTA account and require special reporting to the state IOLTA program in addition to escheatment filing.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOutreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Outreach Date' ;
    rdfs:comment 'Date of the most recent attempt to contact the client regarding the unclaimed funds. Demonstrates ongoing due diligence efforts.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outreachMethod rdf:type rdf:Property ;
    rdfs:label 'Outreach Method' ;
    rdfs:comment 'Primary method used to contact the client regarding unclaimed funds. Certified mail is typically required for escheatment due diligence.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remittance Amount' ;
    rdfs:comment 'Actual amount remitted to the state unclaimed property authority. May differ from unclaimed amount if interest accrued or administrative fees were deducted.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Confirmation Number' ;
    rdfs:comment 'Confirmation or transaction reference number for the funds transfer to the state. Provides proof of remittance for audit and compliance purposes.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'Method by which the unclaimed funds were resolved. Indicates the final disposition of the funds.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unclaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Unclaimed Amount' ;
    rdfs:comment 'Total amount of client trust funds that remain unclaimed and are subject to escheatment. Represents the balance at the time of dormancy determination.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unclaimedFundsNumber rdf:type rdf:Property ;
    rdfs:label 'Unclaimed Funds Number' ;
    rdfs:comment 'Business identifier for the unclaimed funds record. Used for tracking and referencing in escheatment filings and regulatory correspondence.' ;
    rdfs:domain ind:UnclaimedFundsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustControlTestId rdf:type rdf:Property ;
    rdfs:label 'Trust Control Test Id' ;
    rdfs:comment 'Primary key for trust_control_test' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceControlTestId rdf:type rdf:Property ;
    rdfs:label 'Compliance Control Test Id' ;
    rdfs:comment 'Unique identifier for this control test execution record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceControlTest .

ind:sampleSelectionMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Selection Method' ;
    rdfs:comment 'Method used to select this trust account for testing within the control sample. Corresponds to sample_selection_method from detection data.' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Test Evidence Reference' ;
    rdfs:comment 'Reference to supporting documentation or evidence collected during this control test (e.g., document ID, file path, workpaper reference).' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Additional notes or observations recorded by the tester during execution of this control test on this trust account.' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the control test execution for this trust account. Corresponds to control_test_result from detection data.' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testerName rdf:type rdf:Property ;
    rdfs:label 'Tester Name' ;
    rdfs:comment 'Name of the individual who performed this control test on this trust account. Corresponds to tester_name from detection data.' ;
    rdfs:domain ind:TrustControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorReconciliationPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Reconciliation Period Id' ;
    rdfs:comment 'Self-referencing FK on reconciliation_period (prior_reconciliation_period_id)' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReconciliationPeriod .

ind:reconciliationApprovedByUserId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Approved By User Id' ;
    rdfs:comment 'Identifier of the partner, compliance officer, or authorized user who approved the reconciliation. Required for regulatory audit trail.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:reconciliationPreparedByUserId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Prepared By User Id' ;
    rdfs:comment 'Identifier of the accounting staff member or trust accountant who prepared the reconciliation.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:bankAdjustmentsTotal rdf:type rdf:Property ;
    rdfs:label 'Bank Adjustments Total' ;
    rdfs:comment 'Total amount of bank-initiated adjustments (fees, interest, corrections, NSF charges) identified during reconciliation that require corresponding trust ledger entries.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementEndingBalance rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Ending Balance' ;
    rdfs:comment 'The ending balance reported on the bank statement for the trust account as of the statement date. First component of the three-way reconciliation.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookAdjustmentsTotal rdf:type rdf:Property ;
    rdfs:label 'Book Adjustments Total' ;
    rdfs:comment 'Total amount of book-side adjustments (posting errors, reclassifications, corrections) identified during reconciliation that require trust ledger corrections.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientLedgerTotalBalance rdf:type rdf:Property ;
    rdfs:label 'Client Ledger Total Balance' ;
    rdfs:comment 'The sum of all individual client subsidiary ledger balances as of the period end date. Third component of the three-way reconciliation. Must equal bank and trust ledger balances when reconciled.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the reconciliation period was formally closed and locked from further modifications.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month (1-12) to which this reconciliation period belongs, used for monthly reconciliation cycles.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) to which this reconciliation period belongs, used for quarterly regulatory reporting where required.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBalanced rdf:type rdf:Property ;
    rdfs:label 'Is Balanced' ;
    rdfs:comment 'Boolean flag indicating whether the three-way reconciliation is balanced (all three components agree after adjustments). True when reconciliation_variance equals zero.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when the reconciliation period was opened and made available for reconciliation work.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingDepositsTotal rdf:type rdf:Property ;
    rdfs:label 'Outstanding Deposits Total' ;
    rdfs:comment 'Total amount of deposits recorded in the trust ledger but not yet reflected on the bank statement as of the reconciliation date. Reconciling item between book and bank balances.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business identifier code for the reconciliation period, typically formatted as YYYY-MM or YYYY-QN for monthly or quarterly periods.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name for the reconciliation period (e.g., January 2024, Q1 2024).' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the reconciliation period frequency: monthly for standard monthly reconciliations, quarterly for jurisdictions requiring quarterly cycles, annual for year-end reconciliations, ad_hoc for unscheduled reconciliations triggered by events, or special for regulatory audits.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationVariance rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance' ;
    rdfs:comment 'The net variance (if any) between the three reconciliation components after adjustments. Must be zero for a completed reconciliation. Non-zero values indicate unresolved discrepancies requiring investigation.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresRegulatoryFiling rdf:type rdf:Property ;
    rdfs:label 'Requires Regulatory Filing' ;
    rdfs:comment 'Boolean flag indicating whether this reconciliation period requires submission of a regulatory report to the state bar, IOLTA program, or other governing body. Typically true for annual or quarterly periods in certain jurisdictions.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Status' ;
    rdfs:comment 'Current lifecycle status of the reconciliation period: draft (period defined but not started), open (available for reconciliation entries), in_progress (reconciliation work underway), pending_review (awaiting partner or compliance review), completed (three-way reconciliation balanced and approved), closed (finalized and locked), archived (moved to long-term storage per retention policy).' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustLedgerEndingBalance rdf:type rdf:Property ;
    rdfs:label 'Trust Ledger Ending Balance' ;
    rdfs:comment 'The ending balance in the firms trust ledger (general ledger trust account) as of the period end date. Second component of the three-way reconciliation.' ;
    rdfs:domain ind:ReconciliationPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalSourceId rdf:type rdf:Property ;
    rdfs:label 'External Source Id' ;
    rdfs:comment 'FK to knowledge.external_source.external_source_id — Knowledge assets sourced from external platforms (Practical Law, LexisNexis) must reference their source for licensing compliance, update tracking, and provenance governance.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExternalSource .

ind:parentKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Knowledge Asset Id' ;
    rdfs:comment 'Reference to the parent knowledge asset if this asset is a derivative, version, or child of another asset. Supports hierarchical asset relationships. Nullable for root assets.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:taxonomyId rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Id' ;
    rdfs:comment 'Foreign key linking to knowledge.knowledge_taxonomy. Business justification: Knowledge assets should have a primary taxonomy classification for governance and retrieval. Currently has taxonomy_tags STRING for multi-valued tags, but needs FK for primary classification node. One' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:accessClassification rdf:type rdf:Property ;
    rdfs:label 'Access Classification' ;
    rdfs:comment 'Data classification level governing who may access this knowledge asset. Aligns with firm information security policy.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalOutcome rdf:type rdf:Property ;
    rdfs:label 'Approval Outcome' ;
    rdfs:comment 'Final outcome of the review process indicating whether the knowledge asset was approved for publication, rejected, or conditionally approved pending revisions.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Business-readable unique code for the knowledge asset, typically formatted as KA-{TYPE}-{SEQUENCE}. Used for cross-system referencing and citation.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'The title or name of the knowledge asset as it appears in the knowledge management system and search results.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTaxonomyNode rdf:type rdf:Property ;
    rdfs:label 'Asset Taxonomy Node' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — All knowledge assets must be classifiable under the taxonomy. This is the universal classification FK that enables cross-asset-type search and retrieval.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLppProtected rdf:type rdf:Property ;
    rdfs:label 'Is Lpp Protected' ;
    rdfs:comment 'Indicates whether this knowledge asset is subject to legal professional privilege and must be protected from disclosure. Critical for eDiscovery and regulatory requests.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this knowledge asset is intended to be used as a reusable template for creating new documents or work products.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWorkProduct rdf:type rdf:Property ;
    rdfs:label 'Is Work Product' ;
    rdfs:comment 'Indicates whether this asset qualifies as attorney work product, providing additional protection from discovery under work product doctrine.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knowledgeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Knowledge Asset Description' ;
    rdfs:comment 'Detailed business description of the knowledge asset, its purpose, scope, and intended use cases. Used for search and discovery.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the knowledge asset within the knowledge management workflow. [ENUM-REF-CANDIDATE: draft|under_review|approved|published|archived|deprecated|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlpEmbeddingVersion rdf:type rdf:Property ;
    rdfs:label 'Nlp Embedding Version' ;
    rdfs:comment 'Version identifier of the NLP model used to generate semantic embeddings for this knowledge asset, enabling AI-driven search and retrieval.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionSchedule rdf:type rdf:Property ;
    rdfs:label 'Retention Schedule' ;
    rdfs:comment 'Records retention schedule applicable to this knowledge asset, determining minimum retention period before eligible for destruction.' ;
    rdfs:domain ind:KnowledgeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'The unique identifier or document ID of this asset in the source system (e.g., iManage document number, NetDocuments GUID, Practical Law resource ID).' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyTags rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Tags' ;
    rdfs:comment 'Comma-separated list of taxonomy terms and keywords applied to this asset for classification, search, and NLP-driven retrieval. Supports multi-dimensional tagging.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Guidance and instructions for timekeepers on how to properly use, adapt, or apply this knowledge asset in client matters.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionId rdf:type rdf:Property ;
    rdfs:label 'Contribution Id' ;
    rdfs:comment 'Unique identifier for the knowledge contribution record. Primary key.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionContributorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Contribution Contributor Timekeeper Id' ;
    rdfs:comment 'Reference to the attorney or staff member who submitted the contribution.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:sourceMatterId rdf:type rdf:Property ;
    rdfs:label 'Source Matter Id' ;
    rdfs:comment 'Reference to the client matter from which the contribution originated, if applicable.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:supersedesContributionId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Contribution Id' ;
    rdfs:comment 'Reference to a prior contribution that this submission replaces or updates.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contribution .

ind:cleCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Cle Credit Eligible' ;
    rdfs:comment 'Indicates whether the contribution qualifies the contributor for CLE or CPD credit hours.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleCreditHours rdf:type rdf:Property ;
    rdfs:label 'Cle Credit Hours' ;
    rdfs:comment 'Number of CLE or CPD credit hours awarded for the contribution, if eligible.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Type of knowledge asset contributed to the firms knowledge base.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributorNotes rdf:type rdf:Property ;
    rdfs:label 'Contributor Notes' ;
    rdfs:comment 'Notes or context provided by the contributor at the time of submission explaining the contributions purpose and applicability.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Cpd Credit Eligible' ;
    rdfs:comment 'Indicates whether the contribution qualifies the contributor for CPD credit under UK or international standards.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpdCreditHours rdf:type rdf:Property ;
    rdfs:label 'Cpd Credit Hours' ;
    rdfs:comment 'Number of CPD or CLE credit hours awarded for contributing or completing training on this knowledge asset. Nullable if not CPD-eligible. [Moved from knowledge_asset: CPD credit hours are awarded to individual contributors for their specific contributions, not to the knowledge asset itself. Different contributors receive different credit amounts.]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Document Reference Code' ;
    rdfs:comment 'External reference identifier linking the contribution to the source document in the Document Management System (DMS) such as iManage Work or NetDocuments.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationFlag rdf:type rdf:Property ;
    rdfs:label 'Innovation Flag' ;
    rdfs:comment 'Indicates whether the contribution represents a novel approach, innovative solution, or best practice worthy of special recognition.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCpdEligible rdf:type rdf:Property ;
    rdfs:label 'Is Cpd Eligible' ;
    rdfs:comment 'Indicates whether contribution or use of this knowledge asset qualifies for CPD or CLE credit hours under applicable bar association requirements. [Moved from knowledge_asset: CPD eligibility may vary by contribution type and individual contributor circumstances, so it belongs to the contribution record rather than the asset itself.]' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when the approved contribution was published and made available in the firms knowledge base.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numerical quality rating assigned by the reviewer (scale 0.00 to 5.00).' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewAssignedDate rdf:type rdf:Property ;
    rdfs:label 'Review Assigned Date' ;
    rdfs:comment 'Date when the contribution was assigned to a reviewer.' ;
    rdfs:domain ind:Contribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:researchRequestId rdf:type rdf:Property ;
    rdfs:label 'Research Request Id' ;
    rdfs:comment 'Unique identifier for the legal research request. Primary key.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedPrecedentId rdf:type rdf:Property ;
    rdfs:label 'Identified Precedent Id' ;
    rdfs:comment 'Foreign key linking to knowledge.precedent. Business justification: Research requests often identify relevant firm precedents as research output. Tracking identified precedents enables research effectiveness measurement, precedent discovery analytics, and researcher p' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Precedent .

ind:primaryAssignedResearcherTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Assigned Researcher Timekeeper Id' ;
    rdfs:comment 'Identifier of the research professional or librarian assigned to fulfill this request.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryResearchMemoId rdf:type rdf:Property ;
    rdfs:label 'Primary Research Memo Id' ;
    rdfs:comment 'FK to knowledge.research_memo.research_memo_id — A research request produces a research memo as its deliverable. This FK links the request to its output for workflow completion tracking.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchMemo .

ind:resultingResearchMemoId rdf:type rdf:Property ;
    rdfs:label 'Resulting Research Memo Id' ;
    rdfs:comment 'FK to knowledge.research_memo.research_memo_id — Research requests produce research memos as deliverables. This FK links the request to its output for workflow completion tracking.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchMemo .

ind:clientBillableFlag rdf:type rdf:Property ;
    rdfs:label 'Client Billable Flag' ;
    rdfs:comment 'Indicates whether the research time and costs are billable to the client or absorbed as internal overhead.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyTerms rdf:type rdf:Property ;
    rdfs:label 'Key Terms' ;
    rdfs:comment 'Comma-separated list of key legal terms, concepts, or search terms relevant to the research question, used for indexing and retrieval.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Review Flag' ;
    rdfs:comment 'Indicates whether the research output underwent a formal quality review or peer review process before delivery.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedCaseLaw rdf:type rdf:Property ;
    rdfs:label 'Related Case Law' ;
    rdfs:comment 'References to relevant case law or precedents identified during the research process.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTitle rdf:type rdf:Property ;
    rdfs:label 'Request Title' ;
    rdfs:comment 'Brief title or subject line summarizing the research request topic.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the type of legal research being requested (e.g., case law analysis, statutory interpretation, regulatory guidance).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Department or practice group of the requesting attorney, used for cost allocation and workload analysis.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchNotes rdf:type rdf:Property ;
    rdfs:label 'Research Notes' ;
    rdfs:comment 'Internal notes or comments from the researcher regarding the research process, findings, or challenges encountered.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchQuestion rdf:type rdf:Property ;
    rdfs:label 'Research Question' ;
    rdfs:comment 'Detailed description of the legal research question or issue to be investigated. May contain confidential matter details.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchScope rdf:type rdf:Property ;
    rdfs:label 'Research Scope' ;
    rdfs:comment 'Detailed description of the scope and boundaries of the research to be conducted, including any specific sources, time periods, or constraints.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority or urgency classification of the research request, indicating how quickly the research is needed.' ;
    rdfs:domain ind:ResearchRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessUrl rdf:type rdf:Property ;
    rdfs:label 'Access Url' ;
    rdfs:comment 'Primary web URL used by firm personnel to access the external source platform.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCost rdf:type rdf:Property ;
    rdfs:label 'Annual Cost' ;
    rdfs:comment 'Total annual subscription cost for this external source in the firms base currency. Used for cost center allocation and vendor spend analysis.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for the external sources API endpoint used for programmatic access and data retrieval.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Api Integration Status' ;
    rdfs:comment 'Status of technical integration between the firms knowledge management system and the external sources API.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Method used to authenticate access to the external source (OAuth, API Key, SAML Single Sign-On, Basic Authentication, Certificate-based, or None for public sources).' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCategories rdf:type rdf:Property ;
    rdfs:label 'Content Categories' ;
    rdfs:comment 'Comma-separated list of content types or practice areas covered by the source (e.g., Case Law, Statutes, Secondary Sources, Corporate, Litigation, IP, Employment).' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the current subscription contract or license agreement expires. Null for perpetual licenses.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the subscription contract or license agreement became effective.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'Internal cost center or department code to which the subscription expense is allocated for financial reporting and budgeting.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Coverage Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdictions or countries covered by this external source (e.g., USA, GBR, CAN, AUS). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Level' ;
    rdfs:comment 'Highest data classification level of content accessible through this external source, governing access controls and usage policies.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSourceDescription rdf:type rdf:Property ;
    rdfs:label 'External Source Description' ;
    rdfs:comment 'Detailed description of the external sources purpose, content scope, and primary use cases within the firms knowledge management ecosystem.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsageAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Audit Date' ;
    rdfs:comment 'Date when usage statistics for this external source were last reviewed or audited by the knowledge management team.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensedUserCount rdf:type rdf:Property ;
    rdfs:label 'Licensed User Count' ;
    rdfs:comment 'Number of concurrent or named user licenses purchased under the current subscription agreement.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next compliance review of this external source.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Scheduled date for contract renewal or subscription extension. Used for vendor management and budget planning.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Contractually guaranteed uptime percentage for the external source platform as specified in the service level agreement (e.g., 99.9%).' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used internally to reference the external source (e.g., LEXIS, TRPL, WLAW, PACER).' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the subscription to this external source.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Level or tier of subscription purchased (e.g., Basic, Professional, Enterprise, Premium). Determines feature access and user limits.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Usage Tracking Enabled' ;
    rdfs:comment 'Indicates whether the firm tracks usage metrics and analytics for this external source to measure return on investment and user adoption.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorAccountManager rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Manager' ;
    rdfs:comment 'Name of the account manager or sales representative at the vendor organization assigned to the firms account.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupportEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Support Email' ;
    rdfs:comment 'Email address for technical support or customer service inquiries to the vendor.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupportPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Support Phone' ;
    rdfs:comment 'Phone number for technical support or customer service inquiries to the vendor.' ;
    rdfs:domain ind:ExternalSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetUsageId rdf:type rdf:Property ;
    rdfs:label 'Asset Usage Id' ;
    rdfs:comment 'Unique identifier for the knowledge asset usage transaction. Primary key for the asset usage record.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Knowledge Asset Id' ;
    rdfs:comment 'Reference to the knowledge asset that was accessed or used. Links to the knowledge asset master record.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:tertiaryKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Knowledge Asset Id' ;
    rdfs:comment 'FK to knowledge.knowledge_asset.knowledge_asset_id — Every usage event must reference the knowledge_asset it pertains to. This is the core transactional FK enabling usage analytics.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:citationLocation rdf:type rdf:Property ;
    rdfs:label 'Citation Location' ;
    rdfs:comment 'The specific location within a document where the knowledge asset was cited or referenced (e.g., section number, page number, paragraph identifier). Relevant for usage_type of cite or link.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Amount' ;
    rdfs:comment 'Estimated cost savings achieved by using the knowledge asset, calculated based on time saved and timekeeper billing rates. Supports financial justification of knowledge management programs.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device from which the knowledge asset was accessed. Supports user experience optimization and mobile-first knowledge delivery strategies.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'System error code if the usage event failed or encountered an issue. Supports troubleshooting and knowledge platform reliability monitoring.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComment rdf:type rdf:Property ;
    rdfs:label 'Feedback Comment' ;
    rdfs:comment 'Optional free-text feedback provided by the user regarding the knowledge assets quality, applicability, or suggested improvements. Supports continuous knowledge asset refinement.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceRating rdf:type rdf:Property ;
    rdfs:label 'Relevance Rating' ;
    rdfs:comment 'User-provided rating of the knowledge assets relevance to the task or matter, typically on a scale of 1 to 5. Enables feedback-driven curation and quality assessment of knowledge assets.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchQuery rdf:type rdf:Property ;
    rdfs:label 'Search Query' ;
    rdfs:comment 'The search query or keywords used to discover the knowledge asset, if applicable. Supports Natural Language Processing (NLP)-driven search optimization and taxonomy refinement.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSavedMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Saved Minutes' ;
    rdfs:comment 'Estimated time saved by using the knowledge asset instead of creating content from scratch, measured in minutes. User-provided or system-calculated estimate. Supports knowledge management Return on Investment (ROI) measurement.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'The status of the usage event. Completed indicates successful access and use, in_progress indicates an ongoing session, abandoned indicates the user left without completing the action, failed indicates a technical or access error.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Timestamp' ;
    rdfs:comment 'The precise date and time when the knowledge asset was accessed or used. Principal business event timestamp for usage analytics and temporal pattern analysis.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'The type of interaction with the knowledge asset. View indicates read-only access, download indicates local copy, adapt indicates modification or customization, cite indicates reference in a document, apply indicates direct use in matter work, link indicates hyperlink or cross-reference.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentUpdateId rdf:type rdf:Property ;
    rdfs:label 'Precedent Update Id' ;
    rdfs:comment 'Unique identifier for the precedent update event. Primary key for this entity.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalUpdateId rdf:type rdf:Property ;
    rdfs:label 'Legal Update Id' ;
    rdfs:comment 'Foreign key linking to knowledge.legal_update. Business justification: Precedent updates are triggered by legal developments (legislation changes, case law, regulatory updates). This FK links the precedent review event to the specific legal update that triggered it. One ' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalUpdate .

ind:primaryPrecedentTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Precedent Timekeeper Id' ;
    rdfs:comment 'Identifier of the legal professional or knowledge management specialist assigned to review and update the precedent.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:triggeringRegisterId rdf:type rdf:Property ;
    rdfs:label 'Triggering Register Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_register. Business justification: Precedent updates are often triggered by risk events (PI claims, regulatory breaches, client complaints). When a risk materializes, firms update precedents to prevent recurrence. This link captures wh' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Register .

ind:changeDetail rdf:type rdf:Property ;
    rdfs:label 'Change Detail' ;
    rdfs:comment 'Detailed description of all changes made to the precedent, including clause-by-clause modifications, rationale for changes, and references to supporting legal authorities.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newVersionNumber rdf:type rdf:Property ;
    rdfs:label 'New Version Number' ;
    rdfs:comment 'Version number assigned to the precedent after this update was applied and approved.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method or channel used to notify stakeholders of the precedent update, such as email, intranet posting, knowledge portal alert, or practice group meeting.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether notification of the precedent update was sent to relevant stakeholders, practice groups, or the broader firm.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Version Number' ;
    rdfs:comment 'Version number of the precedent immediately prior to this update, enabling version history tracking.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Review Initiated By' ;
    rdfs:comment 'Name or identifier of the person who initiated the precedent review process.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Review Initiated Date' ;
    rdfs:comment 'Date when the precedent review process was formally initiated in response to the triggering event.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerPracticeArea rdf:type rdf:Property ;
    rdfs:label 'Reviewer Practice Area' ;
    rdfs:comment 'Practice area or department of the reviewer, ensuring subject matter expertise alignment with the precedent content.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'List or description of specific sections, clauses, or paragraphs within the precedent that were modified during this update.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date when this precedent update was itself superseded by a subsequent update, marking the end of its active lifecycle.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventDate rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Date' ;
    rdfs:comment 'Date when the triggering event occurred (e.g., date of court judgment, date of statute enactment, date of regulatory guidance publication).' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Categorical classification of the triggering event that necessitated the precedent update.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Update Reference Number' ;
    rdfs:comment 'Business-facing reference number or code assigned to this precedent update event for tracking and audit purposes.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateStatus rdf:type rdf:Property ;
    rdfs:label 'Update Status' ;
    rdfs:comment 'Current lifecycle status of the precedent update. Tracks the approval workflow from initial draft through review, approval, publication, or rejection.' ;
    rdfs:domain ind:PrecedentUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateType rdf:type rdf:Property ;
    rdfs:label 'Update Type' ;
    rdfs:comment 'Classification of the type of update performed on the precedent. Major revisions involve substantive legal changes, minor revisions are editorial improvements, technical corrections fix errors, and regulatory/case law/legislative updates reflect external legal developments.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedKnowledgeManagerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Assigned Knowledge Manager Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Legal updates require explicit timekeeper assignment for regulatory change monitoring and precedent update workflows. Normalizes assigned_knowledge_manager text field to enable workload tracking, CPD ' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:impactedChecklists rdf:type rdf:Property ;
    rdfs:label 'Impacted Checklists' ;
    rdfs:comment 'A comma-separated list or structured reference to the procedural checklists or workflow templates that require modification to incorporate this legal update.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedPracticeNotes rdf:type rdf:Property ;
    rdfs:label 'Impacted Practice Notes' ;
    rdfs:comment 'A comma-separated list or structured reference to the practice notes, guidance documents, or internal memoranda that require revision to reflect this legal update.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedPrecedents rdf:type rdf:Property ;
    rdfs:label 'Impacted Precedents' ;
    rdfs:comment 'A comma-separated list or structured reference to the precedent documents, standard forms, or template agreements that require review or amendment as a result of this legal update.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedMatters rdf:type rdf:Property ;
    rdfs:label 'Related Matters' ;
    rdfs:comment 'A comma-separated list or structured reference to active client matters that may be affected by this legal update, enabling proactive matter management and client advisory.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'The date on which the knowledge management team commenced formal review of this legal update and its implications for the firms knowledge assets.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceCitation rdf:type rdf:Property ;
    rdfs:label 'Source Citation' ;
    rdfs:comment 'The full bibliographic citation or reference to the original source document, including case name, statute number, regulation identifier, or publication reference for traceability and verification.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'The web address or hyperlink to the original source document or official publication where the legal update can be accessed for detailed review.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toTaxonomy rdf:type rdf:Property ;
    rdfs:label 'To Taxonomy' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — Legal updates must reference impacted taxonomy nodes (practice areas, jurisdictions) to enable automated identification of affected knowledge assets.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updateNumber rdf:type rdf:Property ;
    rdfs:label 'Update Number' ;
    rdfs:comment 'The business identifier or reference number assigned to this legal update for tracking and citation purposes within the firms knowledge management system.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateTitle rdf:type rdf:Property ;
    rdfs:label 'Update Title' ;
    rdfs:comment 'The descriptive title or headline of the legal update, summarizing the legislative, regulatory, or case law development.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateToTaxonomy rdf:type rdf:Property ;
    rdfs:label 'Update To Taxonomy' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — Legal updates must reference taxonomy nodes (practice area, jurisdiction) to enable automated routing to impacted knowledge assets and responsible knowledge managers.' ;
    rdfs:domain ind:LegalUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Id' ;
    rdfs:comment 'Unique identifier for this impact assessment record. Primary key.' ;
    rdfs:domain ind:ImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Assessed By Timekeeper Id' ;
    rdfs:comment 'Foreign key to workforce.timekeeper.timekeeper_id' ;
    rdfs:domain ind:ImpactAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'The specific remediation action taken on this practice note in response to this legal update.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedKnowledgeManager rdf:type rdf:Property ;
    rdfs:label 'Assigned Knowledge Manager' ;
    rdfs:comment 'The name or identifier of the knowledge manager assigned to review and update this specific practice note in response to this legal update.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSectionsModified rdf:type rdf:Property ;
    rdfs:label 'Content Sections Modified' ;
    rdfs:comment 'A comma-separated list or structured reference to the specific sections, paragraphs, or content blocks within the practice note that were modified as a result of this legal update.' ;
    rdfs:domain ind:ImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentText rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Text' ;
    rdfs:comment 'A detailed analysis of how this specific legal update impacts this specific practice note, including the nature and extent of changes required.' ;
    rdfs:domain ind:ImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Precedent Impact Assessment Id' ;
    rdfs:comment 'Unique identifier for this precedent impact assessment record. Primary key.' ;
    rdfs:domain ind:PrecedentImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlMappingId rdf:type rdf:Property ;
    rdfs:label 'Control Mapping Id' ;
    rdfs:comment 'Unique surrogate identifier for each control mapping record in the knowledge-risk control matrix' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mappedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Mapped By Timekeeper Id' ;
    rdfs:comment 'Reference to the risk owner, compliance officer, or knowledge professional who established this control mapping' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines the organizational or operational scope within which this knowledge asset serves as a control for the risk category (e.g., firm-wide DPA template vs. jurisdiction-specific conflicts checklist)' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMappingStatus rdf:type rdf:Property ;
    rdfs:label 'Control Mapping Status' ;
    rdfs:comment 'Current lifecycle status of this control mapping within the risk management framework. Active mappings contribute to residual risk calculations; deprecated mappings indicate control gaps requiring remediation.' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Deployment Frequency' ;
    rdfs:comment 'Frequency with which this knowledge asset is deployed or applied as a control measure for the risk category (e.g., conflicts checklist deployed per-matter, AML policy reviewed annually)' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeploymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Deployment Date' ;
    rdfs:comment 'Most recent date on which this knowledge asset was actively deployed or applied as a control for the risk category, used to monitor control currency and identify dormant controls' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEffectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Effectiveness Review Date' ;
    rdfs:comment 'Date on which the effectiveness rating of this control mapping was most recently assessed or validated by the risk owner or auditor' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mappedDate rdf:type rdf:Property ;
    rdfs:label 'Mapped Date' ;
    rdfs:comment 'Date on which this knowledge asset was formally mapped to the risk category in the control matrix, establishing the control relationship' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextEffectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Effectiveness Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this control mappings effectiveness, driven by the risk categorys review frequency and regulatory requirements' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryMappingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mapping Reference' ;
    rdfs:comment 'Reference to the specific regulatory requirement, ISO 27001 control, or professional indemnity condition that this control mapping satisfies (e.g., ISO 27001 A.18.1.4, SRA Code para 6.3)' ;
    rdfs:domain ind:ControlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentRiskMitigationId rdf:type rdf:Property ;
    rdfs:label 'Precedent Risk Mitigation Id' ;
    rdfs:comment 'Unique surrogate identifier for each precedent-risk mitigation mapping record. Primary key for the association.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCategoryId rdf:type rdf:Property ;
    rdfs:label 'Risk Category Id' ;
    rdfs:comment 'Foreign key linking to the risk category that this precedent is designed to mitigate or control' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:clauseCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Clause Coverage Percentage' ;
    rdfs:comment 'Percentage of the precedent documents clauses that directly address or mitigate the associated risk category. Calculated during precedent review and used to assess comprehensiveness of risk coverage.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyMitigatingClauses rdf:type rdf:Property ;
    rdfs:label 'Key Mitigating Clauses' ;
    rdfs:comment 'Comma-separated list or narrative description of the specific clauses, sections, or provisions within the precedent document that directly mitigate the associated risk category. Used for clause-level risk analysis.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Risk Review Date' ;
    rdfs:comment 'Date on which the risk mitigation effectiveness of this precedent-risk mapping was most recently reviewed and validated by the knowledge management or risk team. Drives review cycle governance.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mappedBy rdf:type rdf:Property ;
    rdfs:label 'Mapped By' ;
    rdfs:comment 'Name or identifier of the knowledge manager, risk officer, or attorney who created or last validated this precedent-risk mitigation mapping. Supports audit and accountability.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Lifecycle status of this precedent-risk mitigation mapping. Active mappings are used in matter risk profiling; Deprecated or Superseded mappings indicate the precedent no longer adequately addresses the risk.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Effectiveness' ;
    rdfs:comment 'Qualitative assessment of how effectively this precedent document mitigates the associated risk category, as determined by risk and knowledge management review. Used in precedent selection and matter risk profiling.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingWhenUsed rdf:type rdf:Property ;
    rdfs:label 'Risk Rating When Used' ;
    rdfs:comment 'The typical risk severity rating (Critical, High, Medium, Low) of the associated risk category in matters where this precedent is deployed. Contextualizes the precedents role in high-stakes vs. routine risk scenarios.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageInRiskContextCount rdf:type rdf:Property ;
    rdfs:label 'Usage In Risk Context Count' ;
    rdfs:comment 'Number of times this precedent has been selected or used in matters where the associated risk category was flagged as relevant. Tracks operational usage patterns for precedent effectiveness analysis.' ;
    rdfs:domain ind:PrecedentRiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPrecedentId rdf:type rdf:Property ;
    rdfs:label 'Parent Precedent Id' ;
    rdfs:comment 'Foreign key reference to the previous version of this precedent, establishing version lineage and amendment history.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Precedent .

ind:precedentKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Precedent Knowledge Asset Id' ;
    rdfs:comment 'Foreign key reference to the parent knowledge asset for unified cross-asset catalog governance.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:sourceLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Source Legal Document Id' ;
    rdfs:comment 'The unique identifier of this document in the source system (e.g., iManage document ID, Practical Law resource ID).' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:toKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'To Knowledge Asset Id' ;
    rdfs:comment 'FK to knowledge.knowledge_asset.knowledge_asset_id — Every precedent must have a corresponding knowledge_asset catalog entry for cross-asset search, access classification, and lifecycle governance. This is the core catalog-detail FK that implements the ' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'Specific access control rules or restrictions limiting which practice groups, offices, or individuals may use this precedent.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentSummary rdf:type rdf:Property ;
    rdfs:label 'Amendment Summary' ;
    rdfs:comment 'A summary of the changes, updates, or amendments made in this version compared to the previous version.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Author Practice Group' ;
    rdfs:comment 'The practice group or department of the original author at the time of creation.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'The size of the precedent document file in kilobytes for storage and retrieval management.' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyClauses rdf:type rdf:Property ;
    rdfs:label 'Key Clauses' ;
    rdfs:comment 'A summary or list of the critical legal clauses, provisions, or sections contained in this precedent document.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedentDescription rdf:type rdf:Property ;
    rdfs:label 'Precedent Description' ;
    rdfs:comment 'A detailed narrative description of the precedent document, its purpose, scope, and recommended use cases.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedLegislation rdf:type rdf:Property ;
    rdfs:label 'Related Legislation' ;
    rdfs:comment 'References to statutes, regulations, or legislative frameworks that are relevant to or govern the use of this precedent.' ;
    rdfs:domain ind:Precedent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyClassification rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Classification' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — Every precedent must be classified under the firms taxonomy for retrieval. This is a production-critical FK - without it, precedents cannot be found via taxonomy navigation which is the primary disco' ;
    rdfs:domain ind:Knowledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressesCategoryId rdf:type rdf:Property ;
    rdfs:label 'Addresses Category Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_category. Business justification: Practice notes provide operational guidance for managing specific risk categories (e.g., Managing Conflicts of Interest, GDPR Compliance in M&A). This link enables risk-driven knowledge retrieval ' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:practiceKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Practice Knowledge Asset Id' ;
    rdfs:comment 'Foreign key reference to the knowledge asset catalog entry for unified cross-asset governance and taxonomy management.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:supersededByPracticeNoteId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Practice Note Id' ;
    rdfs:comment 'Foreign key reference to the newer practice note that supersedes this one, supporting version lineage and ensuring users are directed to the most current guidance.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeNote .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The timestamp when this practice note was archived or removed from active use, supporting lifecycle management and historical record retention.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorEmail rdf:type rdf:Property ;
    rdfs:label 'Author Email' ;
    rdfs:comment 'The email address of the primary author for contact and collaboration purposes.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'The average user rating for this practice note on a scale of 0.00 to 5.00, reflecting user satisfaction and content quality.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseLawReferences rdf:type rdf:Property ;
    rdfs:label 'Case Law References' ;
    rdfs:comment 'A list of judicial decisions, case citations, or precedents referenced in this practice note, supporting litigation and dispute resolution processes.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'The classification of the practice note content type, distinguishing between guidance notes, procedural checklists, statute summaries, case law analyses, regulatory updates, and standard clauses.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingAuthors rdf:type rdf:Property ;
    rdfs:label 'Contributing Authors' ;
    rdfs:comment 'A comma-separated list of additional authors or contributors who participated in the creation or review of this practice note.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyDate rdf:type rdf:Property ;
    rdfs:label 'Currency Date' ;
    rdfs:comment 'The date as of which the legal content in this practice note is current and accurate, critical for ensuring users rely on up-to-date legal guidance.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:downloadCount rdf:type rdf:Property ;
    rdfs:label 'Download Count' ;
    rdfs:comment 'The cumulative number of times this practice note has been downloaded or accessed by users, supporting usage analytics and knowledge asset valuation.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalUrl rdf:type rdf:Property ;
    rdfs:label 'External Url' ;
    rdfs:comment 'The external URL or hyperlink to the original source of this practice note if sourced from Thomson Reuters Practical Law, LexisNexis, or another external platform.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTextContent rdf:type rdf:Property ;
    rdfs:label 'Full Text Content' ;
    rdfs:comment 'The complete text content of the practice note, including detailed legal analysis, guidance, procedural steps, and references to statutes, regulations, and case law.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillableReference rdf:type rdf:Property ;
    rdfs:label 'Is Billable Reference' ;
    rdfs:comment 'Boolean flag indicating whether time spent reviewing or using this practice note can be billed to client matters under Alternative Fee Arrangement (AFA) or standard billing arrangements.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Note Status' ;
    rdfs:comment 'The current lifecycle status of the practice note, indicating whether it is in draft, under review, approved, published, archived, or superseded by a newer version.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCount rdf:type rdf:Property ;
    rdfs:label 'Rating Count' ;
    rdfs:comment 'The total number of user ratings submitted for this practice note, supporting statistical confidence in the average rating.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulationReferences rdf:type rdf:Property ;
    rdfs:label 'Regulation References' ;
    rdfs:comment 'A list of regulations, rules, or administrative codes referenced in this practice note, supporting regulatory compliance counseling.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPracticeNotes rdf:type rdf:Property ;
    rdfs:label 'Related Practice Notes' ;
    rdfs:comment 'A comma-separated list of related practice note identifiers that provide complementary or supplementary guidance on related legal topics.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statuteReferences rdf:type rdf:Property ;
    rdfs:label 'Statute References' ;
    rdfs:comment 'A list of statutes, acts, or legislative provisions referenced in this practice note, supporting legal research and cross-referencing.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicTags rdf:type rdf:Property ;
    rdfs:label 'Topic Tags' ;
    rdfs:comment 'A comma-separated list of topic tags or keywords extracted via Natural Language Processing (NLP) or manually assigned, enabling semantic search and topic-based retrieval.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'The cumulative number of times this practice note has been viewed online by users, supporting usage analytics and content effectiveness measurement.' ;
    rdfs:domain ind:PracticeNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clauseAuthorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Clause Author Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney or knowledge management professional) who authored or contributed this clause to the library.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clauseKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Clause Knowledge Asset Id' ;
    rdfs:comment 'Reference to the parent knowledge asset catalog entry for unified cross-asset governance and taxonomy management.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:primaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Category Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_category. Business justification: Clause types map to risk categories: indemnity clauses mitigate PI risk, data processing clauses address data breach risk, limitation clauses manage financial exposure. This link enables risk-aware dr' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:clauseText rdf:type rdf:Property ;
    rdfs:label 'Clause Text' ;
    rdfs:comment 'Full text of the clause as approved by the knowledge management team. May include placeholders for variable terms (e.g., [PARTY_NAME], [AMOUNT], [DATE]).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Clm System Reference' ;
    rdfs:comment 'External reference identifier or URL linking this clause to its representation in the firms CLM system for document assembly and contract automation.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Contract Type Applicability' ;
    rdfs:comment 'Comma-separated list of contract types where this clause is commonly applicable (e.g., NDA, SPA, MSA, SOW, License Agreement, Employment Agreement).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deprecated Timestamp' ;
    rdfs:comment 'Timestamp when this clause was deprecated or archived, indicating it is no longer recommended for use in new contracts.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fallbackPositionText rdf:type rdf:Property ;
    rdfs:label 'Fallback Position Text' ;
    rdfs:comment 'Alternative clause text representing the firms fallback negotiating position if the primary clause is rejected by the counterparty.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawReference rdf:type rdf:Property ;
    rdfs:label 'Governing Law Reference' ;
    rdfs:comment 'Specific legal framework, statute, or body of law that governs the interpretation of this clause (e.g., New York UCC, English Contract Law, CISG).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Business-readable unique identifier or code for the clause (e.g., INDEM-001, GOV-LAW-UK-STD). Used for cross-referencing in document assembly and CLM systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryApplicability rdf:type rdf:Property ;
    rdfs:label 'Industry Applicability' ;
    rdfs:comment 'Comma-separated list of industries or sectors where this clause is particularly relevant (e.g., technology, healthcare, financial_services, manufacturing, energy).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStandardForm rdf:type rdf:Property ;
    rdfs:label 'Is Standard Form' ;
    rdfs:comment 'Indicates whether this clause is part of the firms standard form library (True) or a custom/negotiated variant (False).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiability Flag' ;
    rdfs:comment 'Indicates whether this clause is typically negotiable (True) or non-negotiable (False) in standard engagements.' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precedentSource rdf:type rdf:Property ;
    rdfs:label 'Precedent Source' ;
    rdfs:comment 'Source or origin of the clause precedent (e.g., internal template, Thomson Reuters Practical Law, client-provided, opposing counsel, industry standard form).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceTags rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Tags' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks or compliance requirements addressed by this clause (e.g., GDPR, SOX, HIPAA, CCPA, FRAND, AML).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedClauses rdf:type rdf:Property ;
    rdfs:label 'Related Clauses' ;
    rdfs:comment 'Comma-separated list of clause identifiers for related or dependent clauses that are commonly used together (e.g., indemnity clauses paired with limitation of liability).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semanticTags rdf:type rdf:Property ;
    rdfs:label 'Semantic Tags' ;
    rdfs:comment 'Comma-separated list of NLP-extracted semantic tags and keywords for advanced search and retrieval (e.g., liability_cap, mutual_obligation, unilateral, time_limit).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantLabel rdf:type rdf:Property ;
    rdfs:label 'Variant Label' ;
    rdfs:comment 'Label identifying the specific variant or version of the clause (e.g., Standard, Client-Favorable, Vendor-Favorable, Fallback Position, Aggressive, Conservative).' ;
    rdfs:domain ind:Clause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigatesRiskCategoryId rdf:type rdf:Property ;
    rdfs:label 'Mitigates Risk Category Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_category. Business justification: Court/regulatory forms map to compliance risk categories - filing the correct form on time mitigates regulatory breach risk. This link enables risk-aware form management: risk teams track whether requ' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:applicableStatute rdf:type rdf:Property ;
    rdfs:label 'Applicable Statute' ;
    rdfs:comment 'Citation of the statute, regulation, or rule that mandates or governs the use of this form (e.g., Federal Rule of Civil Procedure 26, 17 CFR § 240.14a-101).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtTribunalName rdf:type rdf:Property ;
    rdfs:label 'Court Tribunal Name' ;
    rdfs:comment 'Name of the specific court, tribunal, or adjudicative body for which this form is designed (e.g., U.S. District Court Southern District of New York, International Chamber of Commerce).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'URL or hyperlink to the official source, court website, or regulatory portal where the authoritative version of this form is published.' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI of the form template file within the Document Management System (DMS) (iManage Work or NetDocuments).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingInstructions rdf:type rdf:Property ;
    rdfs:label 'Filing Instructions' ;
    rdfs:comment 'Detailed procedural instructions for completing, submitting, or filing the form, including deadlines, required attachments, and submission channels.' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formCategory rdf:type rdf:Property ;
    rdfs:label 'Form Category' ;
    rdfs:comment 'Secondary classification or practice area grouping (e.g., civil litigation, criminal defense, corporate transactions, intellectual property, employment law, family law).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formCode rdf:type rdf:Property ;
    rdfs:label 'Form Code' ;
    rdfs:comment 'Unique business identifier or code for the form template (e.g., court form number, regulatory form designation, internal reference code).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formTemplateStatus rdf:type rdf:Property ;
    rdfs:label 'Form Template Status' ;
    rdfs:comment 'Current lifecycle status of the form template (active, draft, archived, superseded, under review, deprecated).' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formTitle rdf:type rdf:Property ;
    rdfs:label 'Form Title' ;
    rdfs:comment 'Full official title or name of the form template as recognized by the issuing authority or internal practice group.' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Classification of the form template by its primary business purpose (court filing, regulatory submission, transactional document, internal administrative, client intake, discovery, motion, pleading). [ENUM-REF-CANDIDATE: court_filing|regulatory_submission|transactional|internal_administrative|client_intake|discovery|motion|pleading — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Flag indicating whether this form template contains confidential or privileged content subject to Legal Professional Privilege (LPP) or attorney work product protections.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proceduralRequirements rdf:type rdf:Property ;
    rdfs:label 'Procedural Requirements' ;
    rdfs:comment 'Summary of procedural rules, deadlines, service requirements, or compliance obligations associated with the use of this form.' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredAttachments rdf:type rdf:Property ;
    rdfs:label 'Required Attachments' ;
    rdfs:comment 'List or description of mandatory supporting documents or exhibits that must accompany this form when filed or submitted.' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementsRiskMitigationActionId rdf:type rdf:Property ;
    rdfs:label 'Implements Risk Mitigation Action Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_mitigation_action. Business justification: Checklists are procedural controls deployed as risk mitigation actions. When a mitigation plan requires implement enhanced due diligence checklist or enforce conflict check procedure, the checklis' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MitigationAction .

ind:parentChecklistId rdf:type rdf:Property ;
    rdfs:label 'Parent Checklist Id' ;
    rdfs:comment 'Foreign key reference to a parent checklist if this checklist is a derived or specialized version of another checklist. Nullable for root-level checklists.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:primaryChecklistKnowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Checklist Knowledge Asset Id' ;
    rdfs:comment 'Foreign key linking this checklist to the unified knowledge asset catalog for cross-asset governance and retrieval.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Unique business identifier or reference code for the checklist, used for cataloging and retrieval within the knowledge management system.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'A detailed textual description of the checklists purpose, scope, and intended use cases.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'The business-friendly name or title of the checklist (e.g., M&A Due Diligence Checklist, IP Prosecution Checklist).' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistStatus rdf:type rdf:Property ;
    rdfs:label 'Checklist Status' ;
    rdfs:comment 'Current lifecycle status of the checklist (e.g., draft, active, archived, under review, deprecated).' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'The category or type of checklist, indicating its primary business purpose (e.g., due diligence, compliance, prosecution, litigation readiness). [ENUM-REF-CANDIDATE: due_diligence|compliance|prosecution|litigation_readiness|transaction|regulatory|risk_assessment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryStepsCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Steps Count' ;
    rdfs:comment 'The number of steps in this checklist that are marked as mandatory or required.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionalStepsCount rdf:type rdf:Property ;
    rdfs:label 'Optional Steps Count' ;
    rdfs:comment 'The number of steps in this checklist that are marked as optional or discretionary.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'The total number of steps or tasks included in this checklist.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResearchAuthorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Research Author Timekeeper Id' ;
    rdfs:comment 'Foreign key to the attorney or paralegal who authored this research memorandum. Tracks authorship for expertise directories and knowledge attribution.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:accessControlList rdf:type rdf:Property ;
    rdfs:label 'Access Control List' ;
    rdfs:comment 'Comma-separated list of user IDs or group IDs with access to this research memo. Supports granular access control and ethical walls.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseLawCitations rdf:type rdf:Property ;
    rdfs:label 'Case Law Citations' ;
    rdfs:comment 'List of case law citations analyzed in this research memo. Supports precedent tracking and legal reasoning analysis.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conclusion rdf:type rdf:Property ;
    rdfs:label 'Conclusion' ;
    rdfs:comment 'The legal conclusion or recommendation provided in this research memo. Captures the attorneys professional judgment on the issue.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrecedent rdf:type rdf:Property ;
    rdfs:label 'Is Precedent' ;
    rdfs:comment 'Boolean flag indicating whether this research memo has been designated as a precedent document for reuse in future matters.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublishedToKnowledgeBase rdf:type rdf:Property ;
    rdfs:label 'Is Published To Knowledge Base' ;
    rdfs:comment 'Boolean flag indicating whether this research memo has been published to the firm-wide knowledge base for broader access and reuse.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyLegalConcepts rdf:type rdf:Property ;
    rdfs:label 'Key Legal Concepts' ;
    rdfs:comment 'NLP-extracted key legal concepts, doctrines, and principles identified in this research memo. Supports semantic search and knowledge graph construction.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lexisnexisSourceCitations rdf:type rdf:Property ;
    rdfs:label 'Lexisnexis Source Citations' ;
    rdfs:comment 'Structured list of LexisNexis source citations referenced in this research memo. Supports provenance tracking and citation analysis.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoStatus rdf:type rdf:Property ;
    rdfs:label 'Memo Status' ;
    rdfs:comment 'Current lifecycle status of the research memorandum. Tracks progression from draft through approval to archival.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoSummary rdf:type rdf:Property ;
    rdfs:label 'Memo Summary' ;
    rdfs:comment 'Executive summary or abstract of the research memo, providing a high-level overview of the analysis and conclusions.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoTitle rdf:type rdf:Property ;
    rdfs:label 'Memo Title' ;
    rdfs:comment 'The title or subject line of the research memorandum, providing a concise summary of the legal issue addressed.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlpProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Nlp Processing Date' ;
    rdfs:comment 'Timestamp when NLP processing was last executed on this research memo. Tracks currency of semantic metadata.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nlpProcessingStatus rdf:type rdf:Property ;
    rdfs:label 'Nlp Processing Status' ;
    rdfs:comment 'Status of NLP processing for key concept extraction and semantic indexing. Supports AI-driven knowledge retrieval.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationCitations rdf:type rdf:Property ;
    rdfs:label 'Regulation Citations' ;
    rdfs:comment 'List of regulatory provisions cited in this research memo. Supports regulatory compliance and administrative law analysis.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedMemoIds rdf:type rdf:Property ;
    rdfs:label 'Related Memo Ids' ;
    rdfs:comment 'Comma-separated list of related research memo IDs. Supports knowledge graph construction and cross-referencing.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchHours rdf:type rdf:Property ;
    rdfs:label 'Research Hours' ;
    rdfs:comment 'Total billable hours spent on researching and drafting this memo. Supports cost tracking and matter budgeting.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reuseCount rdf:type rdf:Property ;
    rdfs:label 'Reuse Count' ;
    rdfs:comment 'Number of times this research memo has been referenced or reused in subsequent matters. Tracks knowledge asset value.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondarySourceCitations rdf:type rdf:Property ;
    rdfs:label 'Secondary Source Citations' ;
    rdfs:comment 'List of secondary sources (treatises, law review articles, practice guides) cited in this research memo. Supports comprehensive legal analysis.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statuteCitations rdf:type rdf:Property ;
    rdfs:label 'Statute Citations' ;
    rdfs:comment 'List of statutory provisions cited in this research memo. Supports legislative analysis and compliance tracking.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:westlawSourceCitations rdf:type rdf:Property ;
    rdfs:label 'Westlaw Source Citations' ;
    rdfs:comment 'Structured list of Westlaw source citations referenced in this research memo. Supports provenance tracking and citation analysis.' ;
    rdfs:domain ind:ResearchMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Parent Taxonomy Id' ;
    rdfs:comment 'Reference to the parent node in the taxonomy hierarchy. Null for root-level nodes. Enables hierarchical navigation from practice areas to sub-practices to topics.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:primaryReplacementTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Taxonomy Id' ;
    rdfs:comment 'Reference to the taxonomy node that replaces this deprecated node. Used for automated migration of knowledge asset classifications and user query redirection.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:alternateTerms rdf:type rdf:Property ;
    rdfs:label 'Alternate Terms' ;
    rdfs:comment 'Comma-separated list of synonyms, abbreviations, and alternative names for this taxonomy node. Used for Natural Language Processing (NLP) search expansion and query matching. Example: M&A, Mergers & Acquisitions, Corporate Combinations.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTaxonomyMapping rdf:type rdf:Property ;
    rdfs:label 'External Taxonomy Mapping' ;
    rdfs:comment 'Mapping to external taxonomy systems such as Thomson Reuters Practical Law, LexisNexis Practice Areas, or UTBMS codes. Format: system_name:code. Example: PracticalLaw:CORP-MA, UTBMS:C101.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Indicates whether this taxonomy node has been deprecated and replaced by a newer node. Deprecated nodes are retained for historical classification but hidden from new asset tagging.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this taxonomy node is a terminal leaf (true) or has child nodes (false). Leaf nodes are the most granular classification level and are directly assigned to knowledge assets.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nlpKeywords rdf:type rdf:Property ;
    rdfs:label 'Nlp Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and phrases used by NLP-driven retrieval engines to match user queries to this taxonomy node. Includes legal terminology, common misspellings, and colloquial terms.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the taxonomy owner. Used for governance workflows, change requests, and taxonomy review notifications.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTerm rdf:type rdf:Property ;
    rdfs:label 'Preferred Term' ;
    rdfs:comment 'The authoritative term to use when referring to this taxonomy concept. Standardizes vocabulary across the firm and ensures consistent knowledge asset tagging.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTaxonomyIds rdf:type rdf:Property ;
    rdfs:label 'Related Taxonomy Ids' ;
    rdfs:comment 'Comma-separated list of knowledge_taxonomy_id values for related or cross-referenced taxonomy nodes. Supports lateral navigation and knowledge graph traversal. Example: linking Corporate Governance to both Corporate and Compliance practice areas.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeNotes rdf:type rdf:Property ;
    rdfs:label 'Scope Notes' ;
    rdfs:comment 'Guidance on what content should and should not be classified under this node. Includes examples of in-scope and out-of-scope matters to reduce misclassification.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this taxonomy node. Used for system integration and knowledge asset tagging. Example: CORP-MA for Corporate Mergers and Acquisitions.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyDescription rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Description' ;
    rdfs:comment 'Detailed explanation of the taxonomy node scope, coverage, and usage guidelines. Helps knowledge contributors classify assets correctly and users understand search results.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyName rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Name' ;
    rdfs:comment 'Human-readable name of the taxonomy node. Example: Mergers and Acquisitions, Employment Law, Intellectual Property Prosecution.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyStatus rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Status' ;
    rdfs:comment 'Current lifecycle status of the taxonomy node. Active nodes are in use, inactive are hidden but retained for historical classification, deprecated are replaced by newer nodes, under review are being evaluated, proposed are pending approval.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyType rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Type' ;
    rdfs:comment 'Classification of the taxonomy node type. Practice areas are top-level categories, sub-practices are specializations, jurisdictions are geographic/legal systems, matter types are case categories, topic tags are granular subjects, and document types classify knowledge asset formats.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expertiseDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Expertise Directory Id' ;
    rdfs:comment 'Unique identifier for the expertise directory record. Primary key for the expertise directory product.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Cle Hours Completed' ;
    rdfs:comment 'Total number of Continuing Legal Education hours completed by the timekeeper, demonstrating ongoing professional development and knowledge currency.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Client Feedback Score' ;
    rdfs:comment 'Average client satisfaction or feedback score for the timekeepers work, used to assess quality and client service excellence. Scale typically 0-10 or 0-5.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpdHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Completed' ;
    rdfs:comment 'Total number of Continuing Professional Development hours completed, used in jurisdictions outside the US such as UK and Commonwealth countries.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expertIdentificationRank rdf:type rdf:Property ;
    rdfs:label 'Expert Identification Rank' ;
    rdfs:comment 'Ranking of the timekeeper within their practice area or expertise domain for expert identification and knowledge routing purposes. Lower numbers indicate higher expertise.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expertiseLevel rdf:type rdf:Property ;
    rdfs:label 'Expertise Level' ;
    rdfs:comment 'Classification of the timekeepers expertise level based on experience, credentials, and recognition within their practice area.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expertiseTaxonomyAlignment rdf:type rdf:Property ;
    rdfs:label 'Expertise Taxonomy Alignment' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — Expertise profiles must align to taxonomy nodes so that knowledge routing (matching questions to experts) works via the same classification scheme used for assets.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expertiseToTaxonomy rdf:type rdf:Property ;
    rdfs:label 'Expertise To Taxonomy' ;
    rdfs:comment 'FK to knowledge.knowledge_taxonomy.knowledge_taxonomy_id — Expertise profiles reference taxonomy nodes (practice areas, jurisdictions) for consistent classification and knowledge routing.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industrySectorExpertise rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Expertise' ;
    rdfs:comment 'Industry sectors in which the timekeeper has specialized knowledge and experience, such as Financial Services, Healthcare, Technology, Energy, Manufacturing, or Government. Stored as delimited list.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionAdmissions rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Admissions' ;
    rdfs:comment 'List of jurisdictions where the timekeeper is admitted to practice law, including state bars, federal courts, and international jurisdictions. Stored as delimited string of jurisdiction codes.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeAssetCount rdf:type rdf:Property ;
    rdfs:label 'Knowledge Asset Count' ;
    rdfs:comment 'Total number of knowledge assets (precedent documents, practice notes, legal research memoranda, standard clauses) authored or contributed to by the timekeeper.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageCapabilities rdf:type rdf:Property ;
    rdfs:label 'Language Capabilities' ;
    rdfs:comment 'Languages in which the timekeeper is proficient for legal work, stored as delimited list of ISO 639-1 language codes or language names.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCleCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Cle Completion Date' ;
    rdfs:comment 'Date when the timekeeper most recently completed a CLE or CPD course, indicating currency of professional development.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastProfileUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Profile Update Date' ;
    rdfs:comment 'Date when the expertise profile was last updated or reviewed, indicating currency of the information.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterStaffingScore rdf:type rdf:Property ;
    rdfs:label 'Matter Staffing Score' ;
    rdfs:comment 'Calculated score used for intelligent matter staffing recommendations, based on expertise match, availability, and historical performance. Scale typically 0-100.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matterTypeExpertise rdf:type rdf:Property ;
    rdfs:label 'Matter Type Expertise' ;
    rdfs:comment 'Specific types of legal matters in which the timekeeper has specialized experience, such as M&A transactions, patent prosecution, employment disputes, or regulatory investigations. Stored as delimited list.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nlpExpertiseTags rdf:type rdf:Property ;
    rdfs:label 'Nlp Expertise Tags' ;
    rdfs:comment 'Machine-generated expertise tags extracted from the timekeepers authored knowledge assets, documents, and research memoranda using Natural Language Processing and text analytics. Stored as delimited keyword list.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notableMatters rdf:type rdf:Property ;
    rdfs:label 'Notable Matters' ;
    rdfs:comment 'Summary or list of significant matters, cases, or transactions the timekeeper has worked on, demonstrating expertise and experience. Stored as concatenated text.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerRecognitionScore rdf:type rdf:Property ;
    rdfs:label 'Peer Recognition Score' ;
    rdfs:comment 'Score reflecting recognition by peers within the firm or legal community, based on internal reviews, peer nominations, or external rankings.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPracticeArea rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Area' ;
    rdfs:comment 'The main legal practice area in which the timekeeper has expertise, such as Corporate Transactions, Litigation, Intellectual Property, Employment Law, or Regulatory Compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalCertifications rdf:type rdf:Property ;
    rdfs:label 'Professional Certifications' ;
    rdfs:comment 'Specialized legal certifications, board certifications, or professional designations held by the timekeeper, such as Certified Specialist in Intellectual Property Law or Chartered Legal Executive.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Profile Completeness Percentage' ;
    rdfs:comment 'Percentage indicating how complete the expertise profile is, based on the presence of key fields and data quality. Used to prioritize profile maintenance.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Free-text narrative describing the timekeepers expertise, background, notable achievements, and areas of specialization in detail.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Display name for the expertise profile, typically the timekeepers full name or professional designation.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileVisibility rdf:type rdf:Property ;
    rdfs:label 'Profile Visibility' ;
    rdfs:comment 'Access level controlling who can view the expertise profile, supporting confidentiality and information governance requirements.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationCount rdf:type rdf:Property ;
    rdfs:label 'Publication Count' ;
    rdfs:comment 'Total number of legal publications, articles, white papers, or treatises authored or co-authored by the timekeeper, indicating thought leadership.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recentPublications rdf:type rdf:Property ;
    rdfs:label 'Recent Publications' ;
    rdfs:comment 'List or summary of the timekeepers most recent or notable publications, stored as delimited text or concatenated string.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPracticeAreas rdf:type rdf:Property ;
    rdfs:label 'Secondary Practice Areas' ;
    rdfs:comment 'Additional legal practice areas in which the timekeeper has demonstrable expertise, stored as a delimited list or concatenated string.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakingEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Speaking Engagement Count' ;
    rdfs:comment 'Total number of professional speaking engagements, conferences, seminars, or webinars where the timekeeper has presented, indicating external recognition.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionTypeExpertise rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Expertise' ;
    rdfs:comment 'Specific transaction types the timekeeper has handled, such as Share Purchase Agreements (SPA), Mergers and Acquisitions (M&A), joint ventures, or debt financing. Stored as delimited list.' ;
    rdfs:domain ind:ExpertiseDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years the timekeeper has practiced law or provided professional legal services.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Applicable Flag' ;
    rdfs:comment 'Indicates whether the firm qualifies for any exemption or waiver from this obligation. True if an exemption applies, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionDetails rdf:type rdf:Property ;
    rdfs:label 'Exemption Details' ;
    rdfs:comment 'Details of any exemption or waiver that applies to the firm for this obligation, including the basis and expiry date of the exemption.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Required Flag' ;
    rdfs:comment 'Indicates whether an external audit or third-party assessment is required to verify compliance with this obligation. True if external audit is required, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingFrequency rdf:type rdf:Property ;
    rdfs:label 'Filing Frequency' ;
    rdfs:comment 'Frequency at which regulatory filings or submissions are required for this obligation. Not applicable for ongoing conduct obligations.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExternalAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last External Audit Date' ;
    rdfs:comment 'Date when the most recent external audit or third-party assessment was conducted for this obligation. Null if no external audit has been performed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine that can be imposed for non-compliance with this obligation, in the currency of the jurisdiction.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextExternalAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next External Audit Date' ;
    rdfs:comment 'Scheduled date for the next external audit or third-party assessment of compliance with this obligation. Null if not applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'Due date for the next regulatory filing or submission required under this obligation. Null if not applicable.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory obligation, used for external reference and reporting.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the regulatory obligation, including scope, requirements, and applicability to the firm.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full name or title of the regulatory obligation as defined by the governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its nature: periodic filing (regular submissions), ongoing conduct (continuous compliance), event-triggered (specific event response), registration, disclosure, or reporting.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the maximum penalty amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of penalties, sanctions, or consequences that may result from non-compliance with this obligation (e.g., fines, license suspension, disciplinary action).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Related Policy Reference' ;
    rdfs:comment 'Reference to the internal firm policy or procedure document that addresses compliance with this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or business unit within the firm responsible for managing compliance with this obligation (e.g., Compliance, Risk Management, Legal Operations).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer' ;
    rdfs:comment 'Name or title of the individual responsible for ensuring compliance with this obligation (e.g., Data Protection Officer, Chief Legal Officer, Compliance Partner).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLegislationUrl rdf:type rdf:Property ;
    rdfs:label 'Source Legislation Url' ;
    rdfs:comment 'URL or hyperlink to the official source legislation, regulation, or guidance document that defines this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Frequency at which compliance training must be completed for this obligation. Not applicable if training is not required.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether mandatory training is required for personnel to ensure compliance with this obligation. True if training is required, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'Date on which the firm formally adopted this control framework for compliance purposes. Marks the start of internal applicability.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification or audit body that conducts third-party assessments for this framework (e.g., BSI, UKAS, Big Four Audit Firm). Null if no certification is required.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether the firm is required to obtain third-party certification or attestation for compliance with this framework (e.g., ISO 27001 certification, SOC 2 audit). True if certification is mandatory or pursued; False otherwise.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Current percentage of framework controls that are fully implemented and compliant, calculated as (compliant_controls / total_controls) * 100. Used for compliance dashboards and reporting.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlCount rdf:type rdf:Property ;
    rdfs:label 'Control Count' ;
    rdfs:comment 'Total number of individual controls or requirements defined within this framework that the firm must implement and monitor. Derived from framework documentation.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlDomainMapping rdf:type rdf:Property ;
    rdfs:label 'Control Domain Mapping' ;
    rdfs:comment 'Mapping of this framework to internal control domains or categories (e.g., Information Security, Data Privacy, Financial Controls, Ethical Conduct, Client Confidentiality). Pipe-separated if multiple domains.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used to reference the framework internally (e.g., ISO27001, FATF40, SRA-CODE, GDPR-A32, SOX-COSO).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkDescription rdf:type rdf:Property ;
    rdfs:label 'Framework Description' ;
    rdfs:comment 'Detailed narrative description of the frameworks purpose, objectives, and key requirements. Provides business context for compliance teams.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'Official name of the compliance control framework (e.g., ISO 27001, FATF 40 Recommendations, SRA Code of Conduct, GDPR Article 32 Technical and Organizational Measures, SOX COSO Framework).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkStatus rdf:type rdf:Property ;
    rdfs:label 'Framework Status' ;
    rdfs:comment 'Current lifecycle status of the framework within the firm: active (in force), superseded (replaced by newer version), retired (no longer applicable), under_review (being evaluated for adoption), pending_adoption (approved but not yet effective).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the framework origin and authority: regulatory (mandated by law), industry_standard (voluntary consensus standard), internal (firm-developed), best_practice (guidance), certification (third-party audit), contractual (client-imposed).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkUrl rdf:type rdf:Property ;
    rdfs:label 'Framework Url' ;
    rdfs:comment 'Web link to the official framework documentation, standard text, or regulatory guidance published by the issuing body.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'Version or edition of the control framework (e.g., 2013, 2022, v4.0). Tracks updates and revisions to the framework standard.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the regulatory authority, standards organization, or governing body that published and maintains the framework (e.g., International Organization for Standardization, Financial Action Task Force, Solicitors Regulation Authority, European Commission).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Date' ;
    rdfs:comment 'Date of the most recent successful certification or audit for this framework. Null if never certified or certification not required.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Due Date' ;
    rdfs:comment 'Scheduled date for the next certification audit or recertification cycle. Used for compliance planning and audit scheduling.' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfApplicability rdf:type rdf:Property ;
    rdfs:label 'Scope Of Applicability' ;
    rdfs:comment 'Description of the business functions, departments, practice areas, or data domains to which this framework applies (e.g., All Client Data Processing, Information Security, AML/KYC Program, Financial Reporting, Data Privacy for EU Clients).' ;
    rdfs:domain ind:ControlFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'Summary of findings and recommendations from the most recent independent audit of the AML/KYC program.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date when the firms board or governing body approved the AML/KYC program.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientRiskRating rdf:type rdf:Property ;
    rdfs:label 'Client Risk Rating' ;
    rdfs:comment 'Overall risk rating for client-related AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelRiskRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Risk Rating' ;
    rdfs:comment 'Overall risk rating for delivery channel-related AML/KYC risks (e.g., remote onboarding, in-person) based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRiskRating rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Rating' ;
    rdfs:comment 'Overall risk rating for geographic/jurisdictional AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Risk Assessment Date' ;
    rdfs:comment 'Date when the most recent enterprise-wide AML/KYC risk assessment was completed.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlroEmail rdf:type rdf:Property ;
    rdfs:label 'Mlro Email' ;
    rdfs:comment 'Official email address of the Money Laundering Reporting Officer for regulatory communications.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroName rdf:type rdf:Property ;
    rdfs:label 'Mlro Name' ;
    rdfs:comment 'Full name of the designated Money Laundering Reporting Officer responsible for the AML/KYC program.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroPhone rdf:type rdf:Property ;
    rdfs:label 'Mlro Phone' ;
    rdfs:comment 'Direct contact phone number for the Money Laundering Reporting Officer.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRiskAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Risk Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory enterprise-wide AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productServiceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Product Service Risk Rating' ;
    rdfs:comment 'Overall risk rating for product and service-related AML/KYC risks based on the most recent assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDocumentationLocation rdf:type rdf:Property ;
    rdfs:label 'Program Documentation Location' ;
    rdfs:comment 'Reference to the storage location or document management system path where the full AML/KYC program documentation is maintained.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name or title of the AML/KYC program as registered with regulatory authorities.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Detailed description of the scope of the AML/KYC program, including covered business lines, matter types, and jurisdictions.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the AML/KYC program indicating its operational state.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version identifier for the AML/KYC program, tracking iterations and updates over time.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when the AML/KYC program received regulatory approval or acknowledgment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval or acknowledgment of the AML/KYC program by relevant authorities.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteStatement rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Statement' ;
    rdfs:comment 'Formal statement defining the firms tolerance for AML/KYC risk across client types, geographies, and service lines.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentFindings rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Findings' ;
    rdfs:comment 'Summary of key findings, observations, and recommendations from the most recent AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Frequency' ;
    rdfs:comment 'Frequency at which enterprise-wide AML/KYC risk assessments are conducted.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessorName rdf:type rdf:Property ;
    rdfs:label 'Risk Assessor Name' ;
    rdfs:comment 'Name of the individual or team responsible for conducting the most recent AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Methodology' ;
    rdfs:comment 'Description of the methodology, framework, or standard used to conduct the AML/KYC risk assessment.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspiciousActivityReportsFiled rdf:type rdf:Property ;
    rdfs:label 'Suspicious Activity Reports Filed' ;
    rdfs:comment 'Total number of Suspicious Activity Reports filed under this program during the current reporting period.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Rate' ;
    rdfs:comment 'Percentage of required staff who have completed mandatory AML/KYC training as of the last assessment date.' ;
    rdfs:domain ind:AmlKycProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adverseMediaScreeningCoverage rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Coverage' ;
    rdfs:comment 'Extent to which adverse media screening is performed within the assessed risk category: full, partial, or none.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Description of the methodology, framework, or approach used to conduct the AML risk assessment, such as FATF-based risk matrix, scenario analysis, or third-party framework.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the AML risk assessment, used for tracking and reporting purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'The scope and level of the AML risk assessment: firm-wide enterprise assessment, matter-type-level assessment, client segment assessment, geographic risk assessment, product/service risk assessment, or delivery channel assessment.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'The name of the individual or team who conducted the AML risk assessment, typically the Money Laundering Reporting Officer (MLRO) or compliance team member.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'The role or title of the assessor within the firm, such as MLRO, Compliance Officer, or Risk Manager.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Board Presentation Date' ;
    rdfs:comment 'The date on which the AML risk assessment was presented to the firms board or senior management for review and governance oversight.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'List or description of the data sources and inputs used in the assessment, such as client intake data, transaction monitoring reports, regulatory guidance, and industry benchmarks.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditDate rdf:type rdf:Property ;
    rdfs:label 'External Audit Date' ;
    rdfs:comment 'The date of the most recent external audit or independent review of this AML risk assessment, if applicable.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highRiskJurisdictionsIdentified rdf:type rdf:Property ;
    rdfs:label 'High Risk Jurisdictions Identified' ;
    rdfs:comment 'List of high-risk or non-cooperative jurisdictions identified in the assessment that pose elevated AML risk to the firm, based on FATF lists or internal risk criteria.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRiskIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Risk Indicators' ;
    rdfs:comment 'Summary of the key risk indicators or metrics evaluated during the assessment, such as high-risk jurisdiction exposure percentage, PEP client count, or cash transaction volume.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlroApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Mlro Approval Date' ;
    rdfs:comment 'The date on which the Money Laundering Reporting Officer formally approved the AML risk assessment.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlroApprovalName rdf:type rdf:Property ;
    rdfs:label 'Mlro Approval Name' ;
    rdfs:comment 'The name of the Money Laundering Reporting Officer who approved the assessment.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Exposure Flag' ;
    rdfs:comment 'Indicates whether the assessment identified material exposure to Politically Exposed Persons (PEPs) requiring enhanced due diligence.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Recommended actions or control enhancements to address identified risks and improve the firms AML posture, such as enhanced due diligence procedures or additional training.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'The date on which the AML risk assessment was submitted to the regulatory authority, if applicable.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this AML risk assessment was submitted to a regulatory authority as part of compliance reporting obligations.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAppetiteAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Alignment' ;
    rdfs:comment 'Indicates whether the residual risk is within the firms stated AML risk appetite: within appetite, near limit (requires monitoring), or exceeds appetite (requires remediation).' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningCoverage rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Coverage' ;
    rdfs:comment 'Extent to which sanctions screening controls are applied within the assessed risk category: full (all clients/matters screened), partial (selective screening), or none.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionMonitoringCoverage rdf:type rdf:Property ;
    rdfs:label 'Transaction Monitoring Coverage' ;
    rdfs:comment 'Extent to which transaction monitoring controls are applied within the assessed risk category: full, partial, or none.' ;
    rdfs:domain ind:AmlRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAmlKycProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Aml Kyc Program Id' ;
    rdfs:comment 'FK to compliance.aml_kyc_program.aml_kyc_program_id — SAR filings are made under the authority of the AML programme and by the MLRO designated in that programme. This link is essential for programme-level reporting on SAR activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlKycProgram .

ind:primarySarTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Sar Timekeeper Id' ;
    rdfs:comment 'Reference to the Money Laundering Reporting Officer who authorized and submitted the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:triggeringSanctionsCheckId rdf:type rdf:Property ;
    rdfs:label 'Triggering Sanctions Check Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_check. Business justification: Suspicious Activity Reports are often triggered by sanctions screening hits. The sar_filing table has suspicion_category which may include sanctions-related categories. Linking the SAR to the specific' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsCheck .

ind:acknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference' ;
    rdfs:comment 'Reference number or confirmation code provided by the financial intelligence unit upon acknowledgment of the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentOutcome rdf:type rdf:Property ;
    rdfs:label 'Consent Outcome' ;
    rdfs:comment 'Outcome of the Defence Against Money Laundering (DAML) consent request: granted, refused, or no response within statutory period.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentOutcomeDate rdf:type rdf:Property ;
    rdfs:label 'Consent Outcome Date' ;
    rdfs:comment 'Date on which the consent outcome was received or the statutory notice period expired.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRequestDate rdf:type rdf:Property ;
    rdfs:label 'Consent Request Date' ;
    rdfs:comment 'Date on which consent was requested from the financial intelligence unit to proceed with the transaction.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Request Flag' ;
    rdfs:comment 'Indicates whether the SAR includes a request for consent to proceed with the transaction (Defence Against Money Laundering - DAML).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingAuthority rdf:type rdf:Property ;
    rdfs:label 'Filing Authority' ;
    rdfs:comment 'Name of the financial intelligence unit or regulatory authority to which the SAR was submitted (e.g., National Crime Agency, FinCEN).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction to which the SAR was filed (e.g., GBR for UK NCA, USA for FinCEN). [ENUM-REF-CANDIDATE: GBR|USA|CAN|AUS|DEU|FRA|NLD|CHE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionDescription rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Description' ;
    rdfs:comment 'Description of any follow-up actions taken or required by the firm in response to the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'Indicates whether follow-up action is required by the firm (e.g., enhanced due diligence, relationship termination).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Number' ;
    rdfs:comment 'Internal tracking reference number assigned by the firm for SAR management and audit purposes.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReportDate rdf:type rdf:Property ;
    rdfs:label 'Internal Report Date' ;
    rdfs:comment 'Date on which the suspicious activity was first reported internally to the MLRO or compliance team.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipTerminatedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Terminated Flag' ;
    rdfs:comment 'Indicates whether the client or matter relationship was terminated as a result of the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Termination Date' ;
    rdfs:comment 'Date on which the client or matter relationship was terminated following the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Full name of the individual who initially identified and reported the suspicious activity internally.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Type' ;
    rdfs:comment 'Type of identifier used to identify the subject of the SAR (e.g., passport number, company registration number).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifierValue rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Value' ;
    rdfs:comment 'The actual identifier value for the subject (e.g., passport number, company registration number), stored securely.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectNameAnonymised rdf:type rdf:Property ;
    rdfs:label 'Subject Name Anonymised' ;
    rdfs:comment 'Anonymised or pseudonymised name of the individual or organisation that is the subject of the SAR, for internal audit trail purposes.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Type of entity that is the subject of the suspicious activity report.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspicionCategory rdf:type rdf:Property ;
    rdfs:label 'Suspicion Category' ;
    rdfs:comment 'Primary category of suspicious activity being reported (e.g., money laundering, terrorist financing, fraud).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspicionGrounds rdf:type rdf:Property ;
    rdfs:label 'Suspicion Grounds' ;
    rdfs:comment 'Detailed narrative describing the grounds for suspicion, including red flags, unusual patterns, and rationale for filing the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingOffRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Tipping Off Risk Flag' ;
    rdfs:comment 'Indicates whether there is a risk of tipping off the subject if certain actions are taken, requiring special handling.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the suspicious transaction or cumulative value of related transactions.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction amount (e.g., GBP, USD, EUR).' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Reference number or identifier of the specific transaction or series of transactions that triggered the SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Controller Contact Email' ;
    rdfs:comment 'Email address of the data controller contact person.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerContactName rdf:type rdf:Property ;
    rdfs:label 'Controller Contact Name' ;
    rdfs:comment 'Name of the representative or contact person for the data controller.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerName rdf:type rdf:Property ;
    rdfs:label 'Controller Name' ;
    rdfs:comment 'Legal name of the data controller responsible for determining the purposes and means of processing. Typically the law firm or its legal entity.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Register Status' ;
    rdfs:comment 'Current lifecycle status of the register entry: draft (being prepared), active (in force), under_review (periodic review or audit), suspended (temporarily inactive), archived (historical record).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCategories rdf:type rdf:Property ;
    rdfs:label 'Data Subject Categories' ;
    rdfs:comment 'Categories of individuals whose personal data is processed (e.g., clients, employees, opposing parties, witnesses, vendors, job applicants). Pipe-separated list.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Dpia Completion Date' ;
    rdfs:comment 'Date on which the DPIA was completed, if applicable.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpiaMitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Dpia Mitigation Measures' ;
    rdfs:comment 'Measures envisaged to address the identified risks, including safeguards, security measures, and mechanisms to ensure protection of personal data, as required under GDPR Article 35(7)(d).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaNecessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Dpia Necessity Assessment' ;
    rdfs:comment 'Assessment of the necessity and proportionality of the processing operations in relation to the purposes, as required under GDPR Article 35(7)(b).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dpia Required Flag' ;
    rdfs:comment 'Indicates whether a DPIA is required for this processing activity under GDPR Article 35 (high risk to rights and freedoms of data subjects).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpiaRiskIdentification rdf:type rdf:Property ;
    rdfs:label 'Dpia Risk Identification' ;
    rdfs:comment 'Identification of risks to the rights and freedoms of data subjects arising from the processing, as required under GDPR Article 35(7)(c).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Dpia Trigger Reason' ;
    rdfs:comment 'Reason why a DPIA is required, if dpia_required_flag is true (e.g., systematic monitoring, large-scale processing of special category data, automated decision-making with legal effects).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date on which the Data Protection Officer was consulted regarding the DPIA, as required under GDPR Article 35(2).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsultationOutcome rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Outcome' ;
    rdfs:comment 'Summary of the DPOs advice and recommendations following consultation on the DPIA.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoContactEmail rdf:type rdf:Property ;
    rdfs:label 'Dpo Contact Email' ;
    rdfs:comment 'Email address of the Data Protection Officer for inquiries and consultation.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoName rdf:type rdf:Property ;
    rdfs:label 'Dpo Name' ;
    rdfs:comment 'Name of the Data Protection Officer responsible for overseeing this processing activity and ensuring GDPR compliance.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of privacy register entry: Record of Processing Activities (RoPA) under GDPR Article 30, Data Protection Impact Assessment (DPIA) under GDPR Article 35, or combined entry covering both.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 for processing personal data: consent, contract performance, legal obligation, vital interests, public task, or legitimate interests.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legitimateInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Legitimate Interest Description' ;
    rdfs:comment 'Detailed explanation of the legitimate interests pursued by the controller or third party, if legal_basis is legitimate_interests. Required under GDPR Article 6(1)(f).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Organizational Security Measures' ;
    rdfs:comment 'Description of organizational security measures implemented to protect personal data (e.g., staff training, access policies, data breach response procedures, confidentiality agreements).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalDataCategories rdf:type rdf:Property ;
    rdfs:label 'Personal Data Categories' ;
    rdfs:comment 'Categories of personal data being processed (e.g., identification data, contact details, financial information, employment records, legal case details). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityCode rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Code' ;
    rdfs:comment 'Unique business identifier or reference code for the processing activity, used for cross-referencing with operational systems and audit trails.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityName rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Name' ;
    rdfs:comment 'Human-readable name of the data processing activity (e.g., Client Onboarding KYC, Matter Document Management, Employee Performance Review).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the purposes of the data processing activity (e.g., client conflict checking, matter billing, employee recruitment, regulatory reporting).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCategories rdf:type rdf:Property ;
    rdfs:label 'Recipient Categories' ;
    rdfs:comment 'Categories of recipients to whom personal data may be disclosed (e.g., courts, regulators, external counsel, IT service providers, cloud storage vendors). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionJustification rdf:type rdf:Property ;
    rdfs:label 'Retention Justification' ;
    rdfs:comment 'Business or legal justification for the retention period, including references to applicable statutes of limitation, regulatory requirements, or legitimate business needs.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Retention Period' ;
    rdfs:comment 'The time period for which personal data will be retained, or the criteria used to determine that period (e.g., 7 years post-matter closure, duration of employment plus 6 years).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataTypes rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Types' ;
    rdfs:comment 'Specific types of special category data processed, if special_category_data_flag is true (e.g., health, racial origin, criminal convictions). Pipe-separated list.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted, if supervisory_authority_consultation_required_flag is true.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required Flag' ;
    rdfs:comment 'Indicates whether prior consultation with the supervisory authority is required under GDPR Article 36 (when DPIA indicates high residual risk).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityResponse rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response' ;
    rdfs:comment 'Summary of the supervisory authoritys response and any conditions or recommendations provided.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Technical Security Measures' ;
    rdfs:comment 'Description of technical security measures implemented to protect personal data (e.g., encryption at rest and in transit, access controls, multi-factor authentication, pseudonymization).' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdCountryNames rdf:type rdf:Property ;
    rdfs:label 'Third Country Names' ;
    rdfs:comment 'Names of third countries or international organizations to which data is transferred, if third_country_transfer_flag is true. Pipe-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdCountryTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Third Country Transfer Flag' ;
    rdfs:comment 'Indicates whether personal data is transferred to a third country or international organization outside the EEA.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferSafeguardDetails rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguard Details' ;
    rdfs:comment 'Additional details about the transfer safeguard mechanism, including reference to documentation or approval decisions.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSafeguardMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguard Mechanism' ;
    rdfs:comment 'The safeguard mechanism used for third country transfers: adequacy decision, standard contractual clauses (SCCs), binding corporate rules (BCRs), certification, code of conduct, or other approved mechanism.' ;
    rdfs:domain ind:DataPrivacyRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryComplianceTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Timekeeper Id' ;
    rdfs:comment 'Reference to the individual (partner, director, or manager) responsible for the design, implementation, and ongoing effectiveness of the control. Typically links to workforce or employee product.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Primary Control Framework Id' ;
    rdfs:comment 'FK to compliance.control_framework.control_framework_id — Every control must reference its parent framework — this is the fundamental structural relationship in control management. Without this FK, you cannot answer which controls implement ISO 27001? whic' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:primaryRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Obligation Id' ;
    rdfs:comment 'FK to compliance.regulatory_obligation.regulatory_obligation_id — Controls are designed to satisfy specific regulatory obligations. This FK enables the critical compliance mapping: obligation → control → test evidence. Required for any regulatory audit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:toControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'To Control Framework Id' ;
    rdfs:comment 'FK to compliance.control_framework.control_framework_id — Every control must belong to a control framework. This is the fundamental parent-child relationship in control management — controls are designed WITHIN a framework. Without this FK, the control inven' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:toRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'To Regulatory Obligation Id' ;
    rdfs:comment 'FK to compliance.regulatory_obligation.regulatory_obligation_id — Controls exist to satisfy regulatory obligations. This many-to-many relationship (or FK to primary obligation) is essential for demonstrating regulatory coverage and identifying gaps. Required for any' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control for another control that is ineffective or not feasible. True if this control mitigates risk in lieu of a primary control; false otherwise.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current operational status of the control within the firms control framework. Active controls are currently enforced; inactive controls are not operational; suspended controls are temporarily paused; under_review indicates controls being assessed for effectiveness; retired controls are no longer applicable.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference to supporting documentation for the control, including policies, procedures, system configurations, and evidence repositories. May include document management system (DMS) identifiers or file paths.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency at which the control is executed or reviewed. Continuous controls operate in real-time; event-driven controls are triggered by specific business events (e.g., new client intake, matter opening). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprArticleReference rdf:type rdf:Property ;
    rdfs:label 'Gdpr Article Reference' ;
    rdfs:comment 'Reference to the specific GDPR article(s) that this control addresses (e.g., Article 32 for Security of Processing, Article 25 for Data Protection by Design). Used for GDPR compliance documentation and Data Protection Officer (DPO) reporting.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001ControlReference rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Control Reference' ;
    rdfs:comment 'Reference to the corresponding ISO 27001:2013 Annex A control (e.g., A.9.2.1 for User Registration, A.18.1.1 for Identification of Applicable Legislation). Used for ISO 27001 certification and audit mapping.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this control is designated as a key control within the firms control framework. Key controls are those that directly address significant risks and require enhanced monitoring and testing.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestConclusion rdf:type rdf:Property ;
    rdfs:label 'Last Test Conclusion' ;
    rdfs:comment 'Outcome of the most recent control test. Effective indicates the control operated as designed with no exceptions; ineffective indicates control failures or design deficiencies; partially_effective indicates minor exceptions that do not materially impact control objective.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nature rdf:type rdf:Property ;
    rdfs:label 'Nature' ;
    rdfs:comment 'Indicates whether the control is executed manually by personnel, automated through system processes, or a hybrid combination requiring both human and system intervention.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control test based on control frequency, risk rating, and regulatory requirements. Used for test planning and resource allocation.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Detailed statement of the controls intended outcome and the risk it is designed to mitigate. Describes what the control is meant to achieve in terms of regulatory compliance, risk reduction, or operational assurance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedure rdf:type rdf:Property ;
    rdfs:label 'Procedure' ;
    rdfs:comment 'Step-by-step procedural instructions for executing the control, including specific actions, system interactions, approval workflows, and documentation requirements. Used by control operators and auditors.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed plan for addressing identified control deficiencies, including specific corrective actions, responsible parties, timelines, and success criteria. Used to track remediation progress and closure.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopingFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scoping Flag' ;
    rdfs:comment 'Indicates whether this control is in scope for SOX Section 404 compliance testing. True if the control is material to financial reporting and requires annual testing; false if out of scope.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sraStandardReference rdf:type rdf:Property ;
    rdfs:label 'Sra Standard Reference' ;
    rdfs:comment 'Reference to the SRA Standards and Regulations that this control supports (e.g., SRA Accounts Rules, SRA Code of Conduct for Firms). Used for SRA regulatory returns and compliance reporting.' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'Method used to test the controls design and operating effectiveness. Walkthrough involves tracing a transaction through the control process; reperformance involves independently executing the control; sample testing involves examining a subset of control instances. [ENUM-REF-CANDIDATE: walkthrough|inquiry|observation|inspection|reperformance|sample_testing|analytical_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'Date on which the DPIA assessment was completed and submitted for review.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentConductedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Conducted By' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for conducting the DPIA.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the DPIA assessment process was initiated.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentTitle rdf:type rdf:Property ;
    rdfs:label 'Assessment Title' ;
    rdfs:comment 'Descriptive title of the DPIA identifying the processing activity or project being assessed.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategories rdf:type rdf:Property ;
    rdfs:label 'Data Categories' ;
    rdfs:comment 'Categories of personal data involved in the processing activity (e.g., contact details, financial data, special category data, criminal conviction data). Comma-separated list.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataControllerName rdf:type rdf:Property ;
    rdfs:label 'Data Controller Name' ;
    rdfs:comment 'Name of the legal entity acting as data controller for the processing activity under assessment (typically the firm itself or a client).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataMinimizationMeasures rdf:type rdf:Property ;
    rdfs:label 'Data Minimization Measures' ;
    rdfs:comment 'Description of measures implemented to ensure only the minimum necessary personal data is collected and processed.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessorName rdf:type rdf:Property ;
    rdfs:label 'Data Processor Name' ;
    rdfs:comment 'Name of any third-party data processor involved in the processing activity, if applicable.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectsConsultedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Consulted Flag' ;
    rdfs:comment 'Indicates whether data subjects or their representatives were consulted regarding the processing, where appropriate.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoAdvice rdf:type rdf:Property ;
    rdfs:label 'Dpo Advice' ;
    rdfs:comment 'Summary of advice and recommendations provided by the DPO during consultation.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultedFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Consulted Flag' ;
    rdfs:comment 'Indicates whether the Data Protection Officer was consulted during the DPIA process as required under GDPR Article 35(2).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Lawful Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 that justifies the processing activity.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of whether the processing is necessary to achieve the stated purpose, and whether the purpose could be achieved through less intrusive means.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Assessed risk level remaining after mitigation measures have been applied.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIdentificationSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Identification Summary' ;
    rdfs:comment 'Summary of identified risks to the rights and freedoms of data subjects arising from the processing activity, including likelihood and severity assessment.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityDecision rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Decision' ;
    rdfs:comment 'Summary of the decision or guidance provided by the supervisory authority following consultation.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the supervisory authority for the consultation, if applicable.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'The specific criterion under GDPR Article 35(3) or supervisory authority guidance that triggered the requirement to conduct this DPIA. [ENUM-REF-CANDIDATE: systematic_monitoring|automated_decision_making|large_scale_special_category|large_scale_criminal_data|innovative_technology|data_matching|profiling|biometric_data|genetic_data|location_tracking|vulnerable_data_subjects|cross_border_transfer — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerableDataSubjectsFlag rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Data Subjects Flag' ;
    rdfs:comment 'Indicates whether the processing involves vulnerable data subjects such as children, elderly, mentally incapacitated individuals, or employees in an imbalanced power relationship.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedDpoOfficerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Assigned Dpo Officer Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Data subject requests (GDPR SARs, erasure requests) are assigned to specific DPO team timekeepers for handling. Linking to timekeeper enables workload balancing, response time tracking by handler, and' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryDataPrivacyRegisterId rdf:type rdf:Property ;
    rdfs:label 'Primary Data Privacy Register Id' ;
    rdfs:comment 'FK to compliance.data_privacy_register.data_privacy_register_id — Data subject requests relate to specific processing activities documented in the RoPA. Linking DSRs to the relevant processing activity enables the DPO to assess scope and respond accurately.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataPrivacyRegister .

ind:authorizedRepresentativeFlag rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Flag' ;
    rdfs:comment 'Indicates whether the request is being made by an authorized representative on behalf of the data subject (e.g., parent, guardian, attorney, executor).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintLodgedFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Lodged Flag' ;
    rdfs:comment 'Indicates whether the data subject has lodged a formal complaint with the supervisory authority (ICO, CNIL, etc.) regarding the handling of their request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintReference rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference' ;
    rdfs:comment 'Reference number of the complaint lodged with the supervisory authority, if applicable.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectAddress rdf:type rdf:Property ;
    rdfs:label 'Data Subject Address' ;
    rdfs:comment 'Postal address of the data subject. Used for identity verification and postal correspondence.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Data Subject Identifier' ;
    rdfs:comment 'Internal firm identifier for the data subject (e.g., client ID, contact ID, employee ID) if the individual is known to the firm.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumePages rdf:type rdf:Property ;
    rdfs:label 'Data Volume Pages' ;
    rdfs:comment 'Total number of pages of personal data provided to the data subject in response to the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataVolumeRecords rdf:type rdf:Property ;
    rdfs:label 'Data Volume Records' ;
    rdfs:comment 'Total number of database records or data entries provided to the data subject in response to the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionApplied rdf:type rdf:Property ;
    rdfs:label 'Exemption Applied' ;
    rdfs:comment 'Legal exemption applied to withhold or redact certain data from the response, such as Legal Professional Privilege (LPP), third-party rights, or ongoing litigation.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline Date' ;
    rdfs:comment 'Extended deadline date if an extension has been granted. GDPR allows up to 2 additional months; CCPA allows up to 45 additional days.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Applied Flag' ;
    rdfs:comment 'Indicates whether the firm has applied for and communicated an extension to the statutory deadline due to complexity or volume.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Reason provided to the data subject for extending the statutory deadline, such as complexity or volume of requests.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'Date on which the data subjects identity was successfully verified.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the data subject making the request. [ENUM-REF-CANDIDATE: government_id|passport|utility_bill|credit_reference|knowledge_based|biometric|existing_client_records — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of identity verification process to confirm the requestor is the legitimate data subject or authorized representative.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Exemption Flag' ;
    rdfs:comment 'Indicates whether Legal Professional Privilege exemption was applied to withhold privileged communications between lawyer and client.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Time Days' ;
    rdfs:comment 'Total number of calendar days taken to process and respond to the data subject request, from receipt to response.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptChannel rdf:type rdf:Property ;
    rdfs:label 'Receipt Channel' ;
    rdfs:comment 'Channel through which the data subject request was received by the firm.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise timestamp when the data subject request was received, including time zone. Used for audit trail and SLA tracking.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refusalReason rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason' ;
    rdfs:comment 'Detailed reason for refusing the data subject request, if applicable. Must be communicated to the data subject with information about complaint rights.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary regulatory jurisdiction governing this data subject request (e.g., UK for GDPR/DPA, California for CCPA). ISO 3166-1 alpha-3 country code. [ENUM-REF-CANDIDATE: GBR|USA|DEU|FRA|IRL|NLD|ESP|ITA|AUS|CAN — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeName rdf:type rdf:Property ;
    rdfs:label 'Representative Name' ;
    rdfs:comment 'Full name of the authorized representative making the request on behalf of the data subject, if applicable.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeRelationship rdf:type rdf:Property ;
    rdfs:label 'Representative Relationship' ;
    rdfs:comment 'Relationship of the authorized representative to the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-facing unique reference number provided to the data subject for tracking purposes. Format: DSR-YYYYMMDD-XXXXXX.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Request Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the data subject request, including specific data categories, time periods, or systems requested by the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date on which the firm provided its response to the data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Statutory Deadline Date' ;
    rdfs:comment 'Statutory deadline by which the firm must respond to the data subject request. Typically 30 calendar days from receipt under GDPR, 45 days under CCPA.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemsSearched rdf:type rdf:Property ;
    rdfs:label 'Systems Searched' ;
    rdfs:comment 'Comma-separated list of internal systems and databases searched to fulfill the data subject request (e.g., Elite 3E, iManage, Relativity, email archives).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyDataFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Data Flag' ;
    rdfs:comment 'Indicates whether the request involves personal data of third parties that must be redacted or exempted from disclosure.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachedDataPrivacyRegisterId rdf:type rdf:Property ;
    rdfs:label 'Breached Data Privacy Register Id' ;
    rdfs:comment 'FK to compliance.data_privacy_register.data_privacy_register_id — Privacy breaches relate to specific processing activities. The breach assessment requires knowing what data categories and subjects are affected, which is documented in the RoPA entry.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataPrivacyRegister .

ind:privacyCreatedByUserId rdf:type rdf:Property ;
    rdfs:label 'Privacy Created By User Id' ;
    rdfs:comment 'User identifier of the person who created this breach incident record. Audit trail field.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:privacyLastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Privacy Last Modified By User Id' ;
    rdfs:comment 'User identifier of the person who last modified this breach incident record. Audit trail field.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:riskDataBreachIncidentId rdf:type rdf:Property ;
    rdfs:label 'Risk Data Breach Incident Id' ;
    rdfs:comment 'Foreign key linking to risk.data_breach_incident. Business justification: Privacy breaches (GDPR/ICO perspective) and data breach incidents (risk management perspective) represent the same event. Compliance record must reference canonical risk incident for unified breach re' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataBreachIncident .

ind:affectedDataCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Data Categories' ;
    rdfs:comment 'Comma-separated list or structured description of the categories of personal data affected by the breach (e.g., names, contact details, financial information, special category data under GDPR Article 9).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystemName rdf:type rdf:Property ;
    rdfs:label 'Affected System Name' ;
    rdfs:comment 'Name of the IT system, application, or platform from which the breach originated or which was compromised.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCause rdf:type rdf:Property ;
    rdfs:label 'Breach Cause' ;
    rdfs:comment 'Root cause category of the breach incident. Used for trend analysis and preventive control design. [ENUM-REF-CANDIDATE: human_error|system_failure|malicious_attack|third_party_failure|physical_loss|unauthorised_access|misconfiguration — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDescription rdf:type rdf:Property ;
    rdfs:label 'Breach Description' ;
    rdfs:comment 'Detailed narrative description of the nature of the breach, including circumstances, systems affected, and how the breach occurred.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachLocation rdf:type rdf:Property ;
    rdfs:label 'Breach Location' ;
    rdfs:comment 'Physical or logical location where the breach occurred (e.g., office location, system name, third-party processor).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the breach incident in the firms incident response workflow.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachType rdf:type rdf:Property ;
    rdfs:label 'Breach Type' ;
    rdfs:comment 'Classification of the breach according to GDPR Article 4(12) categories: accidental or unlawful destruction, loss, alteration, unauthorised disclosure of, or access to, personal data.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentMeasuresTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Measures Taken' ;
    rdfs:comment 'Description of immediate actions taken to contain the breach and prevent further data loss or unauthorised access.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecordsCount rdf:type rdf:Property ;
    rdfs:label 'Data Records Count' ;
    rdfs:comment 'Approximate or exact number of personal data records affected by the breach. May differ from data subjects count if multiple records per subject exist.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectsCount rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Count' ;
    rdfs:comment 'Approximate or exact number of data subjects (individuals) whose personal data was affected by the breach. Required for regulatory notification under GDPR Article 33(3)(b).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'How the breach was identified: through internal monitoring, external notification, audit, or other means.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Notification Date' ;
    rdfs:comment 'Date and time when the DPO was notified of the breach incident.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dpoNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Notified Flag' ;
    rdfs:comment 'Indicates whether the firms Data Protection Officer (DPO) was notified of the breach. True if DPO was notified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postIncidentReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Completed Flag' ;
    rdfs:comment 'Indicates whether a post-incident review or lessons-learned analysis has been completed. True if review is complete.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postIncidentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Date' ;
    rdfs:comment 'Date when the post-incident review was completed and findings documented.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postIncidentReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Outcome' ;
    rdfs:comment 'Summary of findings, lessons learned, and recommendations from the post-incident review. Used to improve controls and prevent recurrence.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveControlsImplemented rdf:type rdf:Property ;
    rdfs:label 'Preventive Controls Implemented' ;
    rdfs:comment 'Description of new or enhanced controls implemented as a result of the breach to prevent similar incidents in the future.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Amount' ;
    rdfs:comment 'Monetary penalty or fine imposed by the supervisory authority as a result of the breach, if any. Null if no penalty was imposed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the regulatory penalty amount (e.g., GBP, EUR, USD).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Rationale' ;
    rdfs:comment 'Detailed explanation of the risk assessment conclusion, including factors considered such as nature of data, likelihood of misuse, and potential consequences to data subjects.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentToDataSubjects rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment To Data Subjects' ;
    rdfs:comment 'Assessment of the likely risk to the rights and freedoms of data subjects as a result of the breach. Determines notification obligations under GDPR Article 34.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Involved Flag' ;
    rdfs:comment 'Indicates whether the breach involved special categories of personal data as defined in GDPR Article 9 (racial/ethnic origin, political opinions, religious beliefs, health data, biometric data, etc.). True if special category data was affected.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Name' ;
    rdfs:comment 'Name of the supervisory authority to which the breach was notified (e.g., Information Commissioners Office (ICO), CNIL, BfDI).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Date' ;
    rdfs:comment 'Date and time when the breach was notified to the supervisory authority. Must be within 72 hours of discovery unless delay is justified under GDPR Article 33(1).' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisoryAuthorityNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Required Flag' ;
    rdfs:comment 'Indicates whether notification to the supervisory authority (ICO in UK, or relevant EU DPA) is required under GDPR Article 33. True if notification is mandatory.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the supervisory authority upon receipt of the breach notification.' ;
    rdfs:domain ind:PrivacyBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Preparer Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Regulatory returns (SRA, SolicitorConnect, AML returns) require named timekeeper as preparer for audit trails, quality control, and regulatory accountability. Firms track who prepared each filing for ' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reportedRegulatoryBreachId rdf:type rdf:Property ;
    rdfs:label 'Reported Regulatory Breach Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_breach. Business justification: Regulatory returns are often filed to report breaches to governing bodies (SRA, ICO, etc.). The return_type attribute includes breach_type, and breach_indicator is a boolean flag. Linking the return' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBreach .

ind:accountantName rdf:type rdf:Property ;
    rdfs:label 'Accountant Name' ;
    rdfs:comment 'Name of the external accountant or accounting firm that prepared or certified the accountants report (applicable for SRA Accountants Report and similar filings).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountantRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Accountant Registration Number' ;
    rdfs:comment 'Professional registration or license number of the external accountant or accounting firm (e.g., ICAEW membership number, CPA license number).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Job title or role of the individual who approved the return for submission (e.g., Managing Partner, COFA, Board Chair).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDiscoveryDate rdf:type rdf:Property ;
    rdfs:label 'Breach Discovery Date' ;
    rdfs:comment 'Date on which the regulatory breach or compliance incident was first discovered or identified by the firm. Applicable only when breach_indicator is True.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachIndicator rdf:type rdf:Property ;
    rdfs:label 'Breach Indicator' ;
    rdfs:comment 'Flag indicating whether this return is related to a regulatory breach or compliance incident (True if breach-related, False otherwise).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Breach Occurrence Date' ;
    rdfs:comment 'Date on which the regulatory breach or compliance incident actually occurred (may differ from discovery date). Applicable only when breach_indicator is True.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparerRole rdf:type rdf:Property ;
    rdfs:label 'Preparer Role' ;
    rdfs:comment 'Job title or role of the individual who prepared the return (e.g., Compliance Officer for Legal Practice (COLP), Compliance Officer for Finance and Administration (COFA), DPO).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryResponseDate rdf:type rdf:Property ;
    rdfs:label 'Query Response Date' ;
    rdfs:comment 'Actual date on which the firm submitted its response to regulatory queries or requests for additional information.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queryResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Query Response Due Date' ;
    rdfs:comment 'Deadline by which the firm must respond to regulatory queries or requests for additional information.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acknowledgement Date' ;
    rdfs:comment 'Date on which the regulatory body formally acknowledged receipt of the return or filing.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFindings rdf:type rdf:Property ;
    rdfs:label 'Regulatory Findings' ;
    rdfs:comment 'Summary of any findings, observations, or concerns raised by the regulatory body during review of the return.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryQueries rdf:type rdf:Property ;
    rdfs:label 'Regulatory Queries' ;
    rdfs:comment 'Record of any queries, questions, or requests for additional information issued by the regulatory body in relation to the return.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActions rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions' ;
    rdfs:comment 'Description of corrective and preventive actions taken or planned to address the breach and prevent recurrence. Applicable only when breach_indicator is True.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'External reference number or identifier assigned to the regulatory return by the firm or regulatory body (e.g., SRA Annual Report 2024-001).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the regulatory return or filing (e.g., SRA Annual Report, COFA Certificate, Accountants Report, Regulatory Breach Notification, Remediation Plan). [ENUM-REF-CANDIDATE: annual_report|accountants_report|cofa_certificate|regulatory_breach_notification|remediation_plan|compliance_certificate|financial_return|practice_information_return|diversity_report|client_money_report — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerRole rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role' ;
    rdfs:comment 'Job title or role of the individual who reviewed the return (e.g., Managing Partner, General Counsel (GC), Chief Legal Officer (CLO)).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'Regulatory deadline by which the return must be submitted to the governing body.' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocuments rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents' ;
    rdfs:comment 'List or reference to supporting documentation submitted with the regulatory return (e.g., accountants report, financial statements, audit reports, evidence of remediation).' ;
    rdfs:domain ind:RegulatoryReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditProgramId rdf:type rdf:Property ;
    rdfs:label 'Audit Program Id' ;
    rdfs:comment 'Reference to the broader audit program or compliance assurance program under which this test is being conducted.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:controlDeficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Control Deficiency Severity' ;
    rdfs:comment 'Classification of the severity of any control deficiency identified during testing. Material weakness is a deficiency that results in a reasonable possibility of material misstatement. Significant deficiency is less severe than a material weakness but important enough to merit attention. Deficiency is a control shortcoming that does not rise to the level of significant deficiency.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDetails rdf:type rdf:Property ;
    rdfs:label 'Exception Details' ;
    rdfs:comment 'Detailed description of any exceptions or control failures identified during testing, including root cause analysis and potential impact.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Percentage' ;
    rdfs:comment 'The calculated percentage of exceptions relative to the sample size. Expressed as a percentage (e.g., 2.50 for 2.5%). Used to assess control effectiveness and project population error rates.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified Count' ;
    rdfs:comment 'The number of exceptions, deviations, or control failures identified during testing. An exception occurs when the control did not operate as designed or was not performed.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Flag' ;
    rdfs:comment 'Indicates whether this test was performed by an external auditor (True) or internal compliance/audit team (False).' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'The total number of items or transactions in the population from which the sample was drawn. Used to calculate sampling risk and exception rates.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'The date on which all testing procedures were completed and results were finalized.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testConclusion rdf:type rdf:Property ;
    rdfs:label 'Test Conclusion' ;
    rdfs:comment 'The overall conclusion reached by the tester regarding the effectiveness of the control based on test results. Effective means the control is operating as designed with no material exceptions. Ineffective means the control has failed or has material exceptions. Partially effective indicates some deficiencies but not material failures.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testObjective rdf:type rdf:Property ;
    rdfs:label 'Test Objective' ;
    rdfs:comment 'A description of the specific objective or assertion being tested. Defines what the test is intended to validate about the control (e.g., completeness, accuracy, authorization, existence).' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Test Period End Date' ;
    rdfs:comment 'The ending date of the period covered by this control test. For operating effectiveness tests, defines the end of the observation window.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Period Start Date' ;
    rdfs:comment 'The beginning date of the period covered by this control test. For operating effectiveness tests, defines the start of the observation window.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testProcedureDescription rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Description' ;
    rdfs:comment 'Detailed narrative description of the specific procedures performed during the test, including steps taken, evidence examined, and criteria applied.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Test Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the control test, used in audit documentation and reporting.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Summary narrative of the test findings, including observations, exceptions identified, and overall assessment of control performance.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the control test activity.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the control test methodology. Design effectiveness tests evaluate whether the control is properly designed to prevent or detect errors. Operating effectiveness tests evaluate whether the control is functioning as designed over a period of time. [ENUM-REF-CANDIDATE: design_effectiveness|operating_effectiveness|walkthrough|inquiry|observation|inspection|reperformance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'The planned frequency at which this control is tested as part of the compliance assurance program.' ;
    rdfs:domain ind:ComplianceControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedComplianceControlId rdf:type rdf:Property ;
    rdfs:label 'Failed Compliance Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_control. Business justification: Regulatory breaches often result from control failures. Linking the breach to the failed control provides root cause traceability and supports remediation planning. This FK is optional (nullable) as n' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceControl .

ind:primaryRelatedObligationRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Primary Related Obligation Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key reference to the regulatory obligation that was breached. Links to the compliance.regulatory_obligation product.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:responsibleOfficerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Regulatory breaches require assignment to a responsible timekeeper for remediation, client notification, and regulator liaison. Linking to timekeeper enables tracking of breach remediation workload an' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:violatedPolicyId rdf:type rdf:Property ;
    rdfs:label 'Violated Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Regulatory breaches often constitute violations of internal compliance policies. This provides traceability from the breach to the policy that was violated, supporting root cause analysis and remediat' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:actualRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Date' ;
    rdfs:comment 'Actual date on which all remediation actions were completed and the breach was fully resolved. Null if remediation is still in progress.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedMatterCount rdf:type rdf:Property ;
    rdfs:label 'Affected Matter Count' ;
    rdfs:comment 'Number of legal matters or cases impacted by the breach. Relevant for assessing operational and reputational impact.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachCategory rdf:type rdf:Property ;
    rdfs:label 'Breach Category' ;
    rdfs:comment 'High-level categorization of the breach by business domain: financial controls, data privacy, professional conduct, operational compliance, regulatory reporting, or client funds management.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the breach for tracking and reporting purposes. Format: BRH-YYYYNNNN.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToExecutiveFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated To Executive Flag' ;
    rdfs:comment 'Indicates whether the breach was escalated to executive leadership (e.g., Managing Partner, General Counsel, Chief Legal Officer). True = executive escalation occurred.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial impact amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedRegulator rdf:type rdf:Property ;
    rdfs:label 'Notified Regulator' ;
    rdfs:comment 'Name of the regulatory body or supervisory authority to which the breach was reported (e.g., ICO, SRA, State Bar, SEC).' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Actual or estimated date when the breach occurred. May differ from discovery date if the breach was historical or latent.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalIndemnityClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Claim Flag' ;
    rdfs:comment 'Indicates whether the breach has triggered or may trigger a professional indemnity insurance claim. True = claim filed or anticipated.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalIndemnityClaimReference rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Claim Reference' ;
    rdfs:comment 'Reference number for the professional indemnity insurance claim associated with this breach. Null if no claim filed.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulator Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the regulatory authority upon receipt of the breach notification. Used for tracking regulatory correspondence and follow-up.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Deadline' ;
    rdfs:comment 'Deadline by which the breach must be reported to the regulator. GDPR requires notification within 72 hours of discovery; other frameworks have varying timelines.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryPenaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the regulatory penalty amount.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for executing the remediation plan and ensuring corrective actions are completed.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Department' ;
    rdfs:comment 'Department or business unit to which the remediation owner belongs (e.g., Compliance, Risk, IT, Finance, Legal Operations).' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Assessment of the breach severity based on impact to the firm, clients, and regulatory standing. Critical = immediate regulatory notification and senior leadership escalation required.' ;
    rdfs:domain ind:RegulatoryBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Target Remediation Date' ;
    rdfs:comment 'Planned or committed date by which all remediation actions will be completed and the breach fully resolved.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Premium Amount' ;
    rdfs:comment 'The total annual premium paid or payable for this professional indemnity insurance policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for the insurance broker handling this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary telephone number for the insurance broker handling this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'Name of the insurance broker or intermediary who arranged the professional indemnity policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsMadeBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Made Basis Flag' ;
    rdfs:comment 'Indicates whether the policy operates on a claims-made basis (true) or occurrence basis (false), determining when coverage is triggered.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsNotificationEmail rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Email' ;
    rdfs:comment 'Email address to which claims and potential claims must be notified under the terms of this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsNotificationPhone rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Phone' ;
    rdfs:comment 'Telephone number for notifying claims and potential claims to the insurer.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a certificate of compliance or certificate of insurance has been issued confirming the policy meets regulatory minimum requirements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveragePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period End Date' ;
    rdfs:comment 'The date on which the professional indemnity insurance coverage expires or terminates.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveragePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Start Date' ;
    rdfs:comment 'The date on which the professional indemnity insurance coverage becomes effective and binding.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Geographic scope of coverage defining where claims arising from professional services will be covered (e.g., worldwide, UK only, EU, excluding USA).' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionsSummary rdf:type rdf:Property ;
    rdfs:label 'Exclusions Summary' ;
    rdfs:comment 'Summary of key exclusions, limitations, and circumstances under which coverage does not apply.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedReportingPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Extended Reporting Period Months' ;
    rdfs:comment 'Number of months of extended reporting period (tail coverage) included in the policy, allowing claims to be reported after the policy expiration date for incidents that occurred during the coverage period.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Insurer Reference Number' ;
    rdfs:comment 'Internal reference number assigned by the insurer for tracking and correspondence purposes.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitOfIndemnityAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Of Indemnity Amount' ;
    rdfs:comment 'The maximum amount the insurer will pay for all claims and associated costs during the policy period, representing the aggregate coverage limit.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitPerClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Per Claim Amount' ;
    rdfs:comment 'The maximum amount the insurer will pay for any single claim or related series of claims, representing the per-occurrence limit.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPremiumDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Premium Due Date' ;
    rdfs:comment 'The date on which the next premium payment is due for this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Policy Document Reference' ;
    rdfs:comment 'Reference identifier or document management system location for the full policy wording, schedule, and endorsements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the professional indemnity insurance policy.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the professional indemnity policy indicating whether it is primary coverage, excess layer, run-off coverage for closed practices, top-up coverage, or successor practice coverage.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreasCovered rdf:type rdf:Property ;
    rdfs:label 'Practice Areas Covered' ;
    rdfs:comment 'Description of the legal practice areas and service types covered under this professional indemnity policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Frequency' ;
    rdfs:comment 'The frequency at which premium payments are made for this policy.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Status' ;
    rdfs:comment 'Current status of premium payment obligations for this policy period.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingInsurerFlag rdf:type rdf:Property ;
    rdfs:label 'Qualifying Insurer Flag' ;
    rdfs:comment 'Indicates whether the insurer is a qualifying insurer as defined by the SRA or relevant regulatory authority, meeting minimum financial strength and regulatory requirements.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Sent Date' ;
    rdfs:comment 'The date on which the renewal notice was sent to the firm by the insurer or broker.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retroactiveDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Date' ;
    rdfs:comment 'The earliest date from which claims arising from professional services will be covered under this policy, establishing the backward coverage limit for claims-made policies.' ;
    rdfs:domain ind:IndemnityPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryIndemnityTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Indemnity Timekeeper Id' ;
    rdfs:comment 'Reference to the fee earner (associate, solicitor, or other timekeeper) who performed the work that is the subject of the alleged negligence.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:allegedNegligenceDescription rdf:type rdf:Property ;
    rdfs:label 'Alleged Negligence Description' ;
    rdfs:comment 'Detailed narrative description of the alleged professional negligence, error, omission, or breach of duty that forms the basis of the claim. Includes circumstances, timeline, and alleged impact.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimClosureDate rdf:type rdf:Property ;
    rdfs:label 'Claim Closure Date' ;
    rdfs:comment 'Date on which the claim was formally closed by the insurer and the firm, either through settlement, withdrawal, or dismissal.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the nature of the professional indemnity claim based on the type of alleged error or omission. [ENUM-REF-CANDIDATE: negligence|breach_of_duty|conflict_of_interest|missed_deadline|inadequate_advice|document_error|fraud|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Email' ;
    rdfs:comment 'Primary email address for correspondence with the claimant or their legal representative.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Phone' ;
    rdfs:comment 'Primary telephone number for the claimant or their legal representative.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsHandlerName rdf:type rdf:Property ;
    rdfs:label 'Claims Handler Name' ;
    rdfs:comment 'Name of the individual at the insurer or third-party administrator responsible for managing this claim.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmation Date' ;
    rdfs:comment 'Date on which the insurer confirmed or denied coverage for the claim.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmation Status' ;
    rdfs:comment 'Status of the insurers determination regarding whether the claim is covered under the professional indemnity policy.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defenceCostsAmount rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Amount' ;
    rdfs:comment 'Total costs incurred in defending the claim, including legal fees, expert witness fees, and other litigation expenses. May be covered by the insurer depending on policy terms.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defenceCostsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the defence costs amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Exposure Amount' ;
    rdfs:comment 'Initial estimate of the firms potential financial exposure or liability for this claim, including damages, costs, and interest. Updated as the claim progresses.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedExposureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estimated Exposure Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated exposure amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Insurer Acknowledgement Date' ;
    rdfs:comment 'Date on which the insurer formally acknowledged receipt of the claim notification.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reserveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reserve Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the reserve amount.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Reserve Last Updated Date' ;
    rdfs:comment 'Date on which the reserve amount was last reviewed and updated by the insurer or claims handler.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sraReportDate rdf:type rdf:Property ;
    rdfs:label 'Sra Report Date' ;
    rdfs:comment 'Date on which the claim was reported to the Solicitors Regulation Authority, if applicable.' ;
    rdfs:domain ind:IndemnityClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Content Owner Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Compliance training programmes require a named timekeeper as content owner for accountability, version control, and regulatory audit trails. Legal firms track who is responsible for maintaining each c' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the professional body or regulatory authority that has accredited or approved this training programme (e.g., SRA, Law Society, ABA, IBA).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationReference rdf:type rdf:Property ;
    rdfs:label 'Accreditation Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the accreditation body for this training programme.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether participants must complete a formal assessment or examination to pass the training programme.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a completion certificate is issued to participants who successfully complete the training.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost per participant (e.g., GBP, USD, EUR).' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Cost charged per participant for completing the training programme, used for budget planning and cost allocation. Null for internally developed free training.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpdCredits rdf:type rdf:Property ;
    rdfs:label 'Cpd Credits' ;
    rdfs:comment 'Number of CPD or CLE credits awarded upon successful completion of the training programme.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Format in which the training is made available to participants, distinct from delivery method.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalSystemReference rdf:type rdf:Property ;
    rdfs:label 'Internal System Reference' ;
    rdfs:comment 'Reference identifier or course code in the internal Learning Management System (LMS) or Human Resources Management (HRM) system.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContentUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Update Date' ;
    rdfs:comment 'Date when the training programme content was last substantively updated or revised.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the training programme was first made available to participants.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passMarkPercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Mark Percentage' ;
    rdfs:comment 'Minimum percentage score required to successfully complete the training programme and receive credit. Null if no assessment is required.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practiceGroupScope rdf:type rdf:Property ;
    rdfs:label 'Practice Group Scope' ;
    rdfs:comment 'Specific practice groups or departments for which this training is mandatory or recommended (e.g., Corporate, Litigation, IP, Employment). Null if applicable to all practice groups.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteProgrammes rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Programmes' ;
    rdfs:comment 'List or description of other training programmes that must be completed before participants can enroll in this programme. Null if no prerequisites exist.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeCode rdf:type rdf:Property ;
    rdfs:label 'Programme Code' ;
    rdfs:comment 'Unique business identifier code for the training programme, used for external reference and system integration.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeDescription rdf:type rdf:Property ;
    rdfs:label 'Programme Description' ;
    rdfs:comment 'Detailed description of the training programme content, learning objectives, and scope.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeName rdf:type rdf:Property ;
    rdfs:label 'Programme Name' ;
    rdfs:comment 'Full name of the compliance training programme as displayed to users and in reporting.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeStatus rdf:type rdf:Property ;
    rdfs:label 'Programme Status' ;
    rdfs:comment 'Current lifecycle status of the training programme indicating its availability and operational state.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the external training provider or vendor if the programme is delivered by a third party. Null for internally developed training.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Months' ;
    rdfs:comment 'Number of months between required completions for recurring training programmes. Null for one-time training.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the training programme was or will be retired and no longer available for new completions. Null for active programmes.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended audience for this training programme, including roles, practice groups, or seniority levels (e.g., all fee earners, partners only, support staff, specific practice groups).' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRoleCategory rdf:type rdf:Property ;
    rdfs:label 'Target Role Category' ;
    rdfs:comment 'Categorical classification of the primary role groups required to complete this training. [ENUM-REF-CANDIDATE: all-staff|fee-earners|partners|associates|paralegals|support-staff|practice-specific|management — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Classification of the training programme based on requirement level and purpose.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date from which this version of the training programme became effective and available for completion.' ;
    rdfs:domain ind:TrainingProgramme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Id' ;
    rdfs:comment 'Foreign key linking to ip.ownership. Business justification: Sanctions screening of IP owners and assignees is required for AML/KYC compliance in IP transactions, especially cross-border assignments and licensing. Essential for ensuring IP ownership transfers c' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ownership .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date on which the final disposition decision was made for this screening result.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'Detailed explanation and business justification for the disposition decision, including evidence reviewed and reasoning applied.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRecipient rdf:type rdf:Property ;
    rdfs:label 'Escalation Recipient' ;
    rdfs:comment 'Name and role of the individual or authority to whom the screening result was escalated (e.g., Chief Compliance Officer, MLRO, NCA).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed description of the match found, including the matched name from the sanctions list, list entry reference number, and any additional identifying information.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Name' ;
    rdfs:comment 'Full name of the compliance officer or authorized personnel who reviewed and made the disposition decision.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListScreened rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Screened' ;
    rdfs:comment 'Identifier of the sanctions list(s) screened against: OFAC SDN (Office of Foreign Assets Control Specially Designated Nationals), HM Treasury (UK), EU Consolidated List, UN Sanctions List, or Combined All.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDisposition rdf:type rdf:Property ;
    rdfs:label 'Screening Disposition' ;
    rdfs:comment 'Final disposition of the screening result: cleared (no action required), escalated (referred to compliance officer), blocked (transaction/engagement prevented), pending review, or false positive (match dismissed).' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Subject Country Of Residence' ;
    rdfs:comment 'Three-letter ISO country code representing the country of residence or incorporation of the subject being screened.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Subject Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual subject being screened, used for enhanced matching accuracy. Null for non-individual subjects.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Full name of the individual or entity being screened against sanctions lists.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNationalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subject National Identifier' ;
    rdfs:comment 'National identification number, passport number, or registration number of the subject being screened, used for enhanced matching.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Amended Regulatory Obligation Id' ;
    rdfs:comment 'FK to compliance.regulatory_obligation.regulatory_obligation_id — Regulatory changes impact existing obligations or create new ones. This FK enables impact assessment and obligation register updates when new regulations are enacted.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:changeOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Change Owner Timekeeper Id' ;
    rdfs:comment 'Employee identifier of the individual responsible for leading the implementation of required changes.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:impactedControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Impacted Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Regulatory changes often necessitate updates to control frameworks (e.g., new GDPR guidance requires ISO 27001 control updates). The regulatory_change table has regulatory_framework as a string, but l' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:regulatoryImplementationOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Implementation Owner Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Regulatory changes require a named timekeeper as implementation owner for tracking accountability, workload, and completion. The existing implementation_owner_employee_id(unlinked) should map to timek' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory change, including scope, intent, and key provisions that may impact the firm.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this regulatory change by the issuing body or internal tracking system.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory change: proposed (under consultation), published (finalized but not yet effective), effective (in force), superseded (replaced by newer regulation), or withdrawn.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Short descriptive title or name of the regulatory change, legislative update, or guidance document.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the nature of the regulatory change: new regulation, amendment to existing regulation, repeal, guidance, interpretation, advisory, or consultation. [ENUM-REF-CANDIDATE: new_regulation|amendment|repeal|guidance|interpretation|advisory|consultation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Consultation Response Deadline' ;
    rdfs:comment 'Deadline by which the firm must submit its consultation response to the governing body.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationResponseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consultation Response Required Flag' ;
    rdfs:comment 'Indicates whether the firm intends to submit a formal response to a regulatory consultation or request for comment associated with this change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Date' ;
    rdfs:comment 'Date on which the Data Protection Officer (DPO) completed their review of this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Required Flag' ;
    rdfs:comment 'Indicates whether this regulatory change requires review and approval by the firms Data Protection Officer (DPO) due to data privacy implications.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Date' ;
    rdfs:comment 'Date on which the impact assessment was completed and approved.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Status' ;
    rdfs:comment 'Current status of the internal impact assessment process to evaluate the implications of this regulatory change on the firms operations and compliance posture.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Assessed severity level of the regulatory changes impact on the firms compliance posture, operations, and risk exposure.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedBusinessFunctions rdf:type rdf:Property ;
    rdfs:label 'Impacted Business Functions' ;
    rdfs:comment 'Comma-separated list of internal business functions or departments affected by this regulatory change (e.g., Client Intake, Matter Management, Billing, Knowledge Management, Trust Accounting).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Internal deadline by which the firm must complete all required actions to comply with the regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Review Date' ;
    rdfs:comment 'Date on which internal legal counsel or General Counsel (GC) completed their review of this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Review Required Flag' ;
    rdfs:comment 'Indicates whether this regulatory change requires review by internal legal counsel or General Counsel (GC) for legal interpretation and compliance strategy.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Policy Update Required Flag' ;
    rdfs:comment 'Indicates whether existing firm policies, procedures, or governance documents require updates to reflect this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryObligationCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Created Flag' ;
    rdfs:comment 'Indicates whether this regulatory change has resulted in the creation of a new entry in the regulatory obligation register.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedPolicyReferences rdf:type rdf:Property ;
    rdfs:label 'Related Policy References' ;
    rdfs:comment 'Comma-separated list of internal policy document references or identifiers that are affected by or related to this regulatory change.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredControlUpdates rdf:type rdf:Property ;
    rdfs:label 'Required Control Updates' ;
    rdfs:comment 'Description of the control framework updates, policy changes, or procedural modifications required to achieve compliance with this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemChangesDescription rdf:type rdf:Property ;
    rdfs:label 'System Changes Description' ;
    rdfs:comment 'Description of the system, technology, or data management changes required to achieve compliance with this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemChangesRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'System Changes Required Flag' ;
    rdfs:comment 'Indicates whether changes to operational systems, technology platforms, or data management systems are required to support compliance with this regulatory change.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDeadline rdf:type rdf:Property ;
    rdfs:label 'Training Completion Deadline' ;
    rdfs:comment 'Deadline by which all required training on this regulatory change must be completed by relevant staff.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementingControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Implementing Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Policies are often written to implement specific control framework requirements (e.g., Information Security Policy implements ISO 27001, Data Retention Policy implements GDPR requirements). The po' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:breachReportingProcedure rdf:type rdf:Property ;
    rdfs:label 'Breach Reporting Procedure' ;
    rdfs:comment 'Description of the procedure for reporting breaches or violations of this policy.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path, DMS reference, or URL where the full policy document is stored (e.g., iManage workspace ID, NetDocuments link).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or business unit responsible for the policy (e.g., Compliance, Risk Management, Legal Operations).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the policy, typically following firm naming convention (e.g., AML-001, GDPR-002, SOX-003).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Full name of the compliance policy (e.g., Anti-Money Laundering Policy, Data Protection Policy, Conflicts of Interest Policy).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationsSatisfied rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligations Satisfied' ;
    rdfs:comment 'Comma-separated list or description of specific regulatory obligations that this policy satisfies (e.g., GDPR Article 5, FATF Recommendation 10, SOX Section 404).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Code' ;
    rdfs:comment 'Policy code of the previous version or policy that this policy replaces, establishing version lineage.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'Frequency in months at which training must be completed by applicable staff (e.g., 12, 24).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditResponsibleOfficerEmployeeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Audit Responsible Officer Employee Timekeeper Id' ;
    rdfs:comment 'Employee identifier for the responsible officer accountable for audit remediation.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:engagementOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Engagement Owner Timekeeper Id' ;
    rdfs:comment 'Employee identifier for the lead auditor if the audit is conducted internally or by a known staff member.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryLeadAuditorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Lead Auditor Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Internal compliance audits are conducted by firm timekeepers (often senior associates or compliance specialists). Linking lead auditor to timekeeper enables workload tracking, CPD credit allocation, a' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:auditDocumentationLocation rdf:type rdf:Property ;
    rdfs:label 'Audit Documentation Location' ;
    rdfs:comment 'File path, document management system reference, or storage location for the complete audit engagement documentation and working papers.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'The number of critical severity findings identified that represent immediate and significant compliance or control failures.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftReportDate rdf:type rdf:Property ;
    rdfs:label 'Draft Report Date' ;
    rdfs:comment 'The date on which the draft audit report was issued to management for review and response.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementName rdf:type rdf:Property ;
    rdfs:label 'Engagement Name' ;
    rdfs:comment 'Descriptive name of the audit engagement identifying the subject and scope of the audit.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Reference Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to the audit engagement for tracking and communication purposes.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date on which the audit fieldwork and evidence gathering activities concluded.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date on which the audit fieldwork and evidence gathering activities commenced.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Date' ;
    rdfs:comment 'The date on which the final audit report was issued incorporating management responses and final audit opinion.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsClosedCount rdf:type rdf:Property ;
    rdfs:label 'Findings Closed Count' ;
    rdfs:comment 'The number of audit findings that have been remediated and verified as closed.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsOpenCount rdf:type rdf:Property ;
    rdfs:label 'Findings Open Count' ;
    rdfs:comment 'The number of audit findings that remain open and require remediation action.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsOverdueCount rdf:type rdf:Property ;
    rdfs:label 'Findings Overdue Count' ;
    rdfs:comment 'The number of audit findings that have passed their target remediation date and remain open.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'The scheduled date for the follow-up audit engagement to verify closure of findings.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'The number of high severity findings identified that represent material compliance or control weaknesses.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Findings Count' ;
    rdfs:comment 'The number of low severity findings identified that represent minor compliance or control observations.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Due Date' ;
    rdfs:comment 'The deadline by which management is required to provide formal responses to audit findings and proposed remediation plans.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Date' ;
    rdfs:comment 'The actual date on which management submitted their formal response to the audit findings.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediumFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Findings Count' ;
    rdfs:comment 'The number of medium severity findings identified that represent moderate compliance or control gaps.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditOpinion rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Opinion' ;
    rdfs:comment 'The auditors overall conclusion regarding the effectiveness of controls and compliance with the regulatory framework under review.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'The date on which the regulatory report was submitted to the governing authority.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Name of the senior officer or executive responsible for overseeing the remediation of audit findings and ensuring compliance.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'The total number of audit findings identified during the engagement across all severity levels.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditActionOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Audit Action Owner Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Audit findings require remediation by named timekeepers. Linking action owner to timekeeper enables tracking of open findings by owner, workload balancing, and performance review input for remediation' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:auditorEmployeeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Timekeeper Id' ;
    rdfs:comment 'Employee identifier of the auditor who raised the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:findingOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Finding Owner Timekeeper Id' ;
    rdfs:comment 'Employee identifier of the action owner responsible for remediation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreedAction rdf:type rdf:Property ;
    rdfs:label 'Agreed Action' ;
    rdfs:comment 'The specific action agreed between auditor and management to remediate the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlReference rdf:type rdf:Property ;
    rdfs:label 'Control Reference' ;
    rdfs:comment 'Reference to the specific control or control framework element that is deficient or non-compliant.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Classification of the finding type: control gap (missing or ineffective control), policy breach (violation of internal policy), regulatory non-compliance (failure to meet external regulatory requirement), process deficiency (operational process weakness), documentation gap (missing or inadequate documentation), or system weakness (technology control failure).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including the condition observed, the criteria or standard against which it was assessed, and the context.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Raised Date' ;
    rdfs:comment 'Date on which the audit finding was formally raised and documented.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to this finding for tracking and reporting purposes.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding: open (newly raised, no action started), in progress (remediation underway), pending verification (action completed, awaiting audit verification), closed (verified and resolved), overdue (past target date without closure).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Concise title or summary of the audit finding for quick identification and reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Nature of the finding: observation (noted fact without immediate action), recommendation (suggested improvement), non-conformance (failure to meet requirement), or opportunity for improvement (enhancement suggestion).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Managements formal response to the finding, including acceptance, planned actions, or alternative approach.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Auditors recommended corrective or remedial action to address the finding and mitigate associated risk.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity rating of the finding based on potential impact and urgency: critical (immediate action required, significant regulatory or business risk), high (prompt action needed, material risk), medium (moderate risk, action required within normal cycle), low (minor issue, improvement opportunity).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScopeId rdf:type rdf:Property ;
    rdfs:label 'Audit Scope Id' ;
    rdfs:comment 'Unique identifier for this audit scope record. Primary key.' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the auditor regarding this obligation during this engagement' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionsIdentified rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified' ;
    rdfs:comment 'Number of exceptions or control failures identified during testing of this obligation' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:obligationComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Compliance Status' ;
    rdfs:comment 'The audit conclusion regarding compliance with this specific obligation within this engagement: compliant, non_compliant, partially_compliant, not_tested, in_progress' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Obligation Findings Count' ;
    rdfs:comment 'The number of audit findings identified that relate specifically to this regulatory obligation within this audit engagement' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:obligationRiskRating rdf:type rdf:Property ;
    rdfs:label 'Obligation Risk Rating' ;
    rdfs:comment 'Risk rating assigned to this obligation within the context of this audit engagement based on inherent risk, control effectiveness, and audit findings: critical, high, medium, low' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTestResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Obligation Test Results Summary' ;
    rdfs:comment 'Summary of the testing procedures performed and results obtained for this specific obligation during this audit engagement' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeInclusionDate rdf:type rdf:Property ;
    rdfs:label 'Scope Inclusion Date' ;
    rdfs:comment 'Date when this regulatory obligation was formally included in the audit engagement scope during planning' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testingApproach rdf:type rdf:Property ;
    rdfs:label 'Testing Approach' ;
    rdfs:comment 'Description of the audit testing methodology and procedures applied to assess compliance with this obligation in this engagement' ;
    rdfs:domain ind:AuditScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyAcknowledgementId rdf:type rdf:Property ;
    rdfs:label 'Policy Acknowledgement Id' ;
    rdfs:comment 'Unique identifier for this policy acknowledgement record. Primary key.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgedByContactEmail rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By Contact Email' ;
    rdfs:comment 'Email address of the individual who acknowledged the policy. Used for audit trail and for sending renewal notifications.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedByContactName rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By Contact Name' ;
    rdfs:comment 'Name of the individual at the client organization who provided the acknowledgement. For individual clients, this is the client themselves. For corporate clients, this is the authorized representative.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Document Reference' ;
    rdfs:comment 'Reference to the signed acknowledgement document stored in the document management system. Critical for regulatory audit and dispute resolution.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationMethod rdf:type rdf:Property ;
    rdfs:label 'Attestation Method' ;
    rdfs:comment 'The method by which the client provided acknowledgement. Electronic Signature and Wet Signature provide strongest audit evidence. Implied by Engagement may be used for existing clients under legacy policies.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAcknowledgementDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Acknowledgement Due Date' ;
    rdfs:comment 'Scheduled date when the client must re-acknowledge this policy. Calculated based on the policy review cycle and regulatory requirements. Used to trigger renewal workflows.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredForEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Required For Engagement Flag' ;
    rdfs:comment 'Indicates whether acknowledgement of this policy is mandatory before the firm can accept new matters from this client. AML and conflicts policies are typically mandatory.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Version Acknowledged' ;
    rdfs:comment 'The specific version number of the policy that was acknowledged by the client. Critical for audit trail as policies evolve over time and clients must re-acknowledge new versions.' ;
    rdfs:domain ind:PolicyAcknowledgement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Approved By Employee Id' ;
    rdfs:comment 'Identifier of the individual who approved this audit program for execution.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAuditProgramId rdf:type rdf:Property ;
    rdfs:label 'Parent Audit Program Id' ;
    rdfs:comment 'Self-referencing FK on audit_program (parent_audit_program_id)' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:primaryLeadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lead Auditor Employee Id' ;
    rdfs:comment 'Identifier of the lead auditor assigned to execute this audit program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Owner Employee Id' ;
    rdfs:comment 'Identifier of the individual or role responsible for the overall management and governance of this audit program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetControlFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Target Control Framework Id' ;
    rdfs:comment 'Foreign key linking to compliance.control_framework. Business justification: Audit programs are often designed to test compliance with specific control frameworks (e.g., ISO 27001 Annual Audit Program, SOX Controls Testing Program). The audit_program table has compliance_f' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlFramework .

ind:auditCriteria rdf:type rdf:Property ;
    rdfs:label 'Audit Criteria' ;
    rdfs:comment 'Set of policies, procedures, standards, or requirements used as a reference against which audit evidence is compared.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date when this audit program was last executed or completed.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Date when the next execution of this audit program is scheduled to begin.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier or reference code for the audit program used in reporting and tracking.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the audit program based on its origin and purpose (internal firm audit, external regulatory audit, client-requested audit, or combined).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresExternalAuditor rdf:type rdf:Property ;
    rdfs:label 'Requires External Auditor' ;
    rdfs:comment 'Indicates whether this audit program requires participation or oversight by an external independent auditor.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorEmployeeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Timekeeper Id' ;
    rdfs:comment 'The SAP SuccessFactors employee ID of the timekeepers direct supervisor or supervising attorney. Used for performance management hierarchies, matter supervision compliance, and organisational reporting structures. Self-referencing relationship within the timekeeper population.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:admissionMultiJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Admission Multi Jurisdiction' ;
    rdfs:comment 'Indicates whether the attorney timekeeper holds bar admissions in more than one jurisdiction. Used for matter assignment eligibility across jurisdictions, cross-border transaction staffing, and conflict check scope determination in Intapp Conflicts.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualBillableHoursTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Billable Hours Target' ;
    rdfs:comment 'The annual billable hours target assigned to the timekeeper for performance management and compensation purposes. Used in utilisation rate calculations, performance review benchmarking, and Legal Project Management (LPM) capacity planning.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barStatus rdf:type rdf:Property ;
    rdfs:label 'Bar Status' ;
    rdfs:comment 'Current standing of the attorney timekeepers bar admission in their primary jurisdiction. Active status is required for matter assignment and client representation. Suspended or disbarred status triggers immediate matter reassignment and regulatory notification workflows.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateTier rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Tier' ;
    rdfs:comment 'The standard billing rate tier code assigned to the timekeeper in the billing system (Elite 3E / Aderant Expert). Determines the default hourly rate applied to time entries before client-specific rate overrides or Alternative Fee Arrangements (AFA) are applied. Referenced by the billing.timekeeper_rate product.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biography rdf:type rdf:Property ;
    rdfs:label 'Biography' ;
    rdfs:comment 'The timekeepers professional biography narrative for use in client-facing materials, firm website directory listings, pitch documents, and Request for Proposal (RFP) responses. Maintained in the firms CRM (Microsoft Dynamics 365) and HR system.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdCompliancePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Cpd Compliance Period End' ;
    rdfs:comment 'The end date of the current CPD/CLE compliance reporting period for the timekeepers primary bar jurisdiction. Used to trigger compliance alerts and reporting to state bar associations or the SRA.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpdHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Required' ;
    rdfs:comment 'The annual Continuing Professional Development (CPD) / Continuing Legal Education (CLE) hours required for the timekeeper to maintain their bar admission and professional standing in their jurisdiction. Drives compliance tracking in SAP SuccessFactors Learning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the timekeepers employment arrangement with the firm. Drives Full-Time Equivalent (FTE) calculations, benefit eligibility, billing rate tier assignment, and workforce planning analytics. CLASSIFICATION_OR_TYPE for MASTER_PARTY role.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEquityPartner rdf:type rdf:Property ;
    rdfs:label 'Is Equity Partner' ;
    rdfs:comment 'Indicates whether the timekeeper holds equity partner status in the firm. Equity partners participate in Profit Per Equity Partner (PEP) and Profit Per Partner (PPP) distributions. Drives partnership compensation calculations and governance reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartnershipTrack rdf:type rdf:Property ;
    rdfs:label 'Is Partnership Track' ;
    rdfs:comment 'Indicates whether the timekeeper is currently on the firms partnership track programme. Used for succession planning, performance management targeting, and mentorship programme assignment in SAP SuccessFactors.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawSchool rdf:type rdf:Property ;
    rdfs:label 'Law School' ;
    rdfs:comment 'The name of the law school or university from which the timekeeper obtained their primary legal qualification (JD, LLB, LLM). Used in professional biography publications, client-facing directory listings, and lateral hire credential verification.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawSchoolGraduationYear rdf:type rdf:Property ;
    rdfs:label 'Law School Graduation Year' ;
    rdfs:comment 'The calendar year in which the timekeeper graduated from law school. Used to calculate class year seniority, benchmark compensation against peer cohorts, and support partnership track timeline analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lppDesignation rdf:type rdf:Property ;
    rdfs:label 'Lpp Designation' ;
    rdfs:comment 'Indicates whether the timekeeper holds a Legal Professional Privilege (LPP) designation, meaning their communications and work product may attract privilege protection. Used in eDiscovery (Relativity) privilege review workflows, document tagging, and litigation hold management.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceSpecializations rdf:type rdf:Property ;
    rdfs:label 'Practice Specializations' ;
    rdfs:comment 'Comma-separated list of the timekeepers declared legal practice specializations (e.g., M&A, IP Litigation, Employment, Regulatory Compliance). Used for matter staffing recommendations, client directory listings, and knowledge management tagging in Thomson Reuters Practical Law.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Group Id' ;
    rdfs:comment 'FK to workforce.practice_group.practice_group_id — Every timekeeper is assigned to a practice group. This is the primary organizational hierarchy link for staffing and financial reporting.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proBonoHoursTarget rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Hours Target' ;
    rdfs:comment 'The annual pro bono hours target assigned to the timekeeper, consistent with American Bar Association (ABA) aspirational guidelines of 50 hours per year. Used for pro bono programme compliance tracking, performance review, and firm-level pro bono reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timekeeperType rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Type' ;
    rdfs:comment 'Categorical classification of the timekeepers professional role within the firm. Determines billing eligibility, rate tier, UTBMS classification, and matter staffing rules. Used in LEDES invoice generation and client billing guidelines compliance.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTimekeeperCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Timekeeper Code' ;
    rdfs:comment 'The firm-assigned UTBMS timekeeper code used in LEDES-formatted invoices and electronic billing submissions to clients and insurers. Required for e-billing compliance and client matter billing feeds. Aligns with UTBMS coding standards.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Primary corporate email address for the timekeeper. Used for matter communications, client correspondence, DMS access provisioning, and system notifications. PRIMARY_CONTACT for MASTER_PARTY role.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Direct office telephone number for the timekeeper. Used for client contact, internal directory, and matter team coordination. Stored in E.164-compatible format.' ;
    rdfs:domain ind:Timekeeper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAttorneyTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Attorney Timekeeper Id' ;
    rdfs:comment 'Reference to the core timekeeper master record in Elite 3E, which holds employment identity and billing attributes. This profile extends that record with legal-specific credentials and career attributes not held on the timekeeper record.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:toTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'To Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Every attorney_profile extends exactly one timekeeper record. This is the most fundamental 1:1 extension relationship in the domain — without it, attorney credentials cannot be associated with the fee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:admissionJurisdictionSummary rdf:type rdf:Property ;
    rdfs:label 'Admission Jurisdiction Summary' ;
    rdfs:comment 'Comma-separated summary list of jurisdictions in which the attorney holds active bar admission or practising certificate (e.g., NY, CA, England & Wales). This is a denormalised summary view for quick reference and directory display; full detail is held in the bar_admission product.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attorneyType rdf:type rdf:Property ;
    rdfs:label 'Attorney Type' ;
    rdfs:comment 'Classification of the legal professional by credential type, distinguishing attorneys (US), solicitors and barristers (UK/Commonwealth), paralegals, and legal executives. Drives jurisdiction-specific compliance and billing rate rules.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chambersRanking rdf:type rdf:Property ;
    rdfs:label 'Chambers Ranking' ;
    rdfs:comment 'Current Chambers & Partners directory ranking band for the attorney (e.g., Band 1, Band 2, Up and Coming, Recognised Practitioner). Used in business development, pitch materials, and competitive benchmarking.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Clearance Status' ;
    rdfs:comment 'Current conflict-of-interest clearance status for the attorney as maintained in Intapp Conflicts. Flagged status prevents the attorney from being assigned to new matters until the conflict is resolved or a waiver is obtained per ABA Model Rules.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdAnnualHoursTarget rdf:type rdf:Property ;
    rdfs:label 'Cpd Annual Hours Target' ;
    rdfs:comment 'Annual target number of Continuing Professional Development (CPD) or Continuing Legal Education (CLE) hours the attorney must complete to maintain bar admission and firm compliance. Jurisdiction-specific minimums are tracked in the bar_admission product.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpdComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Cpd Compliance Status' ;
    rdfs:comment 'Current CPD/CLE compliance status of the attorney for the active reporting period. Non-compliant status may trigger bar suspension risk and must be escalated to the firms General Counsel (GC) or Chief Legal Officer (CLO).' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdHoursCompletedYtd rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Completed Ytd' ;
    rdfs:comment 'Cumulative number of CPD/CLE hours completed by the attorney in the current reporting year to date. Compared against the annual target to assess compliance status. Sourced from SAP SuccessFactors Learning Management.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacyCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Certified Flag' ;
    rdfs:comment 'Indicates whether the attorney has completed mandatory data privacy training covering GDPR, CCPA, and the Data Protection Act (DPA). Required for attorneys advising on data protection matters or handling Personally Identifiable Information (PII) in client engagements.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directoryListingFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Listing Flag' ;
    rdfs:comment 'Indicates whether the attorneys profile is approved for publication in external legal directories (e.g., Chambers & Partners, Legal 500) and the firms public-facing website. Controls visibility in client-facing marketing materials.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycAmlCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Certification Date' ;
    rdfs:comment 'Date on which the attorney most recently completed KYC/AML certification training. Used to determine certification currency and trigger renewal reminders per FATF and SRA requirements.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Certified Flag' ;
    rdfs:comment 'Indicates whether the attorney has completed mandatory Know Your Client (KYC) and Anti-Money Laundering (AML) certification training required for client intake and matter opening. Non-certified attorneys may not supervise new client onboarding.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawDegreeType rdf:type rdf:Property ;
    rdfs:label 'Law Degree Type' ;
    rdfs:comment 'Type of primary legal qualification awarded by the law school (e.g., Juris Doctor (JD) in the US, Bachelor of Laws (LLB) in the UK/Commonwealth, Master of Laws (LLM) for postgraduate). Determines eligibility for bar admission in specific jurisdictions. [ENUM-REF-CANDIDATE: JD|LLB|LLM|BCL|SJD|LLD|BL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpmCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Lpm Certified Flag' ;
    rdfs:comment 'Indicates whether the attorney holds a recognised Legal Project Management (LPM) certification, qualifying them to lead matter budgeting, scoping, and project governance under Alternative Fee Arrangements (AFA).' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnershipTrackStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Track Status' ;
    rdfs:comment 'Current status of the attorneys progression toward equity or non-equity partnership. Confidential HR data used in succession planning, compensation modelling, and workforce analytics. Managed in SAP SuccessFactors Performance & Goals.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pppPepParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Ppp Pep Participation Flag' ;
    rdfs:comment 'Indicates whether the attorney participates in the firms Profit Per Partner (PPP) or Profit Per Equity Partner (PEP) compensation pool. Used in financial reporting, partner compensation analytics, and benchmarking against industry PPP/PEP metrics.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAdmissionDate rdf:type rdf:Property ;
    rdfs:label 'Primary Admission Date' ;
    rdfs:comment 'Date on which the attorney was first admitted to the bar or granted a practising certificate in their primary jurisdiction. Used to calculate years of post-qualification experience (PQE) and seniority for compensation benchmarking.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalBiography rdf:type rdf:Property ;
    rdfs:label 'Professional Biography' ;
    rdfs:comment 'Narrative professional biography of the attorney used in client-facing materials, firm website directory listings, pitch documents, and Request for Proposal (RFP) responses. Maintained in SAP SuccessFactors and published via Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalTitle rdf:type rdf:Property ;
    rdfs:label 'Professional Title' ;
    rdfs:comment 'Formal professional title of the attorney within the firm hierarchy, used in client-facing materials, directory listings, and engagement letters. [ENUM-REF-CANDIDATE: Partner|Senior Associate|Associate|Of Counsel|Counsel|Paralegal|Legal Director|Solicitor|Barrister|Senior Partner|Managing Partner — promote to reference product]' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when the attorney profile record was most recently modified in the Silver Layer lakehouse. Used for data freshness monitoring, incremental ETL processing, and audit trail compliance under GDPR and ISO 27001.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yearsPostQualification rdf:type rdf:Property ;
    rdfs:label 'Years Post Qualification' ;
    rdfs:comment 'Number of complete years of post-qualification experience (PQE) since the attorneys primary bar admission date. Used for seniority classification, billing rate banding, matter staffing, and compensation benchmarking. Derived from primary_admission_date but stored for reporting efficiency.' ;
    rdfs:domain ind:AttorneyProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barAdmissionId rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Id' ;
    rdfs:comment 'Unique identifier for the bar admission record. Primary key for the bar admission entity.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admittedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Admitted Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Bar admissions belong to a specific attorney/timekeeper. This FK is critical for conflict checking and matter staffing eligibility validation.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryBarTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Bar Timekeeper Id' ;
    rdfs:comment 'Identifier of the attorney or legal professional who holds this bar admission. Links to the timekeeper master record in the workforce domain.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:proHacViceMatterId rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Matter Id' ;
    rdfs:comment 'For pro hac vice admissions, the identifier of the specific matter or case for which temporary admission was granted. Pro hac vice admissions are case-specific and expire when the matter concludes. Null for permanent bar admissions.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'The date on which the attorney was officially admitted to practice law in this jurisdiction. This is the effective start date of the bar admission.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:admissionStatus rdf:type rdf:Property ;
    rdfs:label 'Admission Status' ;
    rdfs:comment 'The current lifecycle status of the bar admission. Active indicates the attorney is in good standing and authorized to practice; inactive indicates the attorney has voluntarily placed the license on inactive status; suspended indicates temporary disciplinary suspension; disbarred indicates permanent revocation; retired indicates voluntary retirement from practice; resigned indicates voluntary resignation from the bar.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionType rdf:type rdf:Property ;
    rdfs:label 'Admission Type' ;
    rdfs:comment 'The method by which the attorney was admitted to the bar. Examination indicates passing the bar exam; motion indicates admission without examination based on prior practice; reciprocity indicates admission based on another jurisdictions bar membership; pro hac vice indicates temporary admission for a specific case; in-house counsel indicates limited admission for corporate legal department work.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'The annual or periodic membership fee required to maintain this bar admission in good standing. Amount is in the local currency of the jurisdiction.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barAssociationWebsite rdf:type rdf:Property ;
    rdfs:label 'Bar Association Website' ;
    rdfs:comment 'The official website URL of the governing bar association. Used for reference and verification of admission status and requirements.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barBelongsToTimekeeper rdf:type rdf:Property ;
    rdfs:label 'Bar Belongs To Timekeeper' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Every bar admission record must reference the attorney it belongs to. Critical for conflict checking and matter staffing eligibility validation.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Cle Compliance Status' ;
    rdfs:comment 'Indicates whether the attorney is in compliance with the CLE or CPD requirements for this jurisdiction. Compliant indicates all requirements are met; non-compliant indicates requirements are not met; pending verification indicates CLE credits are submitted but not yet verified; exempt indicates the attorney is exempt from CLE requirements.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleHoursCompletedCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Cle Hours Completed Current Period' ;
    rdfs:comment 'The number of CLE or CPD hours the attorney has completed in the current reporting period for this jurisdiction. Used to track compliance with mandatory continuing education requirements.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disciplinaryActionCount rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Count' ;
    rdfs:comment 'The total number of formal disciplinary actions taken against this attorney by the bar association in this jurisdiction over the lifetime of the admission. Used for risk assessment and matter staffing decisions.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disciplinaryStanding rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Standing' ;
    rdfs:comment 'The current disciplinary status of the attorney with the bar association. Good standing indicates no disciplinary issues; under investigation indicates an active disciplinary inquiry; probation indicates the attorney is under disciplinary probation; suspended indicates temporary disciplinary suspension; disbarred indicates permanent revocation of the license to practice.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityForMatterStaffingFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility For Matter Staffing Flag' ;
    rdfs:comment 'Boolean indicator of whether this bar admission qualifies the attorney to be staffed on matters in this jurisdiction. True indicates the attorney is eligible (active status, good standing, no practice restrictions); False indicates the attorney is not eligible due to inactive status, disciplinary issues, or practice restrictions. Critical for conflict checking and resource allocation.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'The current payment status of the annual bar membership fee. Current indicates fees are paid and up to date; overdue indicates fees are past due; waived indicates fees have been waived by the bar association; exempt indicates the attorney is exempt from fees (e.g., retired status, pro bono service).' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBarAssociation rdf:type rdf:Property ;
    rdfs:label 'Governing Bar Association' ;
    rdfs:comment 'The name of the bar association or regulatory authority that governs this bar admission and enforces professional conduct rules (e.g., State Bar of California, New York State Bar Association, Solicitors Regulation Authority, Law Society of England and Wales).' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDisciplinaryActionDate rdf:type rdf:Property ;
    rdfs:label 'Last Disciplinary Action Date' ;
    rdfs:comment 'The date of the most recent formal disciplinary action taken against this attorney by the bar association in this jurisdiction. Null if no disciplinary actions have been taken.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFeePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Fee Payment Date' ;
    rdfs:comment 'The date on which the most recent bar membership fee payment was received and processed by the bar association.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:malpracticeInsuranceComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Malpractice Insurance Compliance Status' ;
    rdfs:comment 'Indicates whether the attorney is in compliance with professional liability insurance requirements for this jurisdiction. Compliant indicates insurance is current; non-compliant indicates insurance is lapsed or insufficient; exempt indicates the attorney is exempt from the requirement; not required indicates the jurisdiction does not mandate insurance.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeInsuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Malpractice Insurance Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this jurisdiction requires attorneys to maintain professional liability (malpractice) insurance as a condition of bar membership. True indicates insurance is required; False indicates it is not required.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Practice Restriction Description' ;
    rdfs:comment 'Detailed description of any practice restrictions or limitations associated with this bar admission. Examples include limited to corporate in-house counsel, limited to federal practice, limited to specific counties, or subject to supervision requirements.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Practice Restriction Flag' ;
    rdfs:comment 'Boolean indicator of whether this bar admission has any practice restrictions or limitations imposed by the bar association (e.g., limited to in-house counsel work, limited to specific practice areas, geographic restrictions). True indicates restrictions exist; False indicates no restrictions.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proHacViceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Expiration Date' ;
    rdfs:comment 'For pro hac vice admissions, the date on which the temporary admission expires. Typically tied to the conclusion of the specific matter. Null for permanent bar admissions.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reciprocitySourceJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Reciprocity Source Jurisdiction' ;
    rdfs:comment 'For admissions granted by reciprocity or motion, the name of the jurisdiction whose bar membership served as the basis for admission without examination. Null for admissions by examination.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'The frequency with which this bar admission must be renewed. Annual indicates yearly renewal; biennial indicates every two years; triennial indicates every three years; not required indicates jurisdictions with no periodic renewal requirement.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date on which the current admission status became effective. Used to track when status changes occurred (e.g., when a suspension began, when an attorney went inactive).' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustAccountCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Trust Account Certification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this jurisdiction requires attorneys to certify compliance with Interest on Lawyers Trust Accounts (IOLTA) or client trust account rules as part of bar membership. True indicates certification is required; False indicates it is not required.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trustAccountComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Trust Account Compliance Status' ;
    rdfs:comment 'Indicates whether the attorney is in compliance with IOLTA or client trust account certification requirements for this jurisdiction. Compliant indicates certification is current; non-compliant indicates certification is missing or deficient; exempt indicates the attorney is exempt; not applicable indicates the attorney does not handle client funds.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsPracticeAtAdmission rdf:type rdf:Property ;
    rdfs:label 'Years Practice At Admission' ;
    rdfs:comment 'The number of years the attorney had been practicing law at the time of admission to this jurisdiction. Used for admissions by motion or reciprocity where prior practice experience is a requirement.' ;
    rdfs:domain ind:BarAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleRequirementId rdf:type rdf:Property ;
    rdfs:label 'Cle Requirement Id' ;
    rdfs:comment 'Unique surrogate identifier for each CLE/CPD requirement record. Primary key for the cle_requirement data product in the workforce domain.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCleTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Cle Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — CLE requirements are tracked per attorney per jurisdiction. The requirement must link to the timekeeper to determine individual compliance status.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:requiredTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Required Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — CLE requirements are tracked per attorney per jurisdiction. Must link to the timekeeper to determine compliance status.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:accreditedProviderRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Accredited Provider Required Flag' ;
    rdfs:comment 'Indicates whether the jurisdiction requires CLE/CPD hours to be earned exclusively from accredited providers. When True, only courses from approved providers count toward the requirement.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biasInclusionHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Bias Inclusion Hours Required' ;
    rdfs:comment 'The minimum number of CLE/CPD hours that must be earned in implicit bias, diversity, equity, and inclusion topics as mandated by certain jurisdictions (e.g., California, New York).' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryoverExpiryMonths rdf:type rdf:Property ;
    rdfs:label 'Carryover Expiry Months' ;
    rdfs:comment 'The number of months after the end of the current reporting period within which carried-over CLE/CPD hours must be applied before they expire. Null if the jurisdiction does not impose a carry-over expiry.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carryoverHoursAllowed rdf:type rdf:Property ;
    rdfs:label 'Carryover Hours Allowed' ;
    rdfs:comment 'The maximum number of excess CLE/CPD hours earned in the current reporting period that may be carried forward and credited toward the next reporting period, as permitted by the jurisdiction.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpdSchemeName rdf:type rdf:Property ;
    rdfs:label 'Cpd Scheme Name' ;
    rdfs:comment 'Name of the CPD/CLE scheme or programme under which this requirement is administered (e.g., SRA CPD Scheme, New York Continuing Legal Education Program). Relevant for multi-jurisdictional firms operating under different CPD frameworks.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Ethics Hours Required' ;
    rdfs:comment 'The minimum number of CLE/CPD hours that must be earned in legal ethics, professional responsibility, or professionalism topics as mandated by the jurisdiction.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Eligible Flag' ;
    rdfs:comment 'Indicates whether the attorney may be eligible for a full or partial exemption from CLE/CPD requirements for this period (e.g., inactive status, judicial appointment, hardship). Triggers a review workflow.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'The category of exemption applied to this CLE/CPD requirement record when exemption_eligible_flag is True. Null or none when no exemption applies.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFilingPenaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Late Filing Penalty Description' ;
    rdfs:comment 'Textual description of the penalty or consequence imposed by the jurisdiction for failure to certify CLE/CPD compliance by the compliance_deadline_date (e.g., Administrative suspension, $100 late fee). Supports risk management and attorney communications.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newAttorneyRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'New Attorney Requirement Flag' ;
    rdfs:comment 'Indicates whether this requirement record reflects a newly-admitted attorney (bridge-the-gap or transition) CLE/CPD requirement, which typically differs in hours and subject matter from the standard requirement.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineHoursCap rdf:type rdf:Property ;
    rdfs:label 'Online Hours Cap' ;
    rdfs:comment 'The maximum number of CLE/CPD hours that may be earned through online, on-demand, or self-study formats within the reporting period, as restricted by the jurisdiction. Null if no cap applies.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proBonoCreditHoursAllowed rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Credit Hours Allowed' ;
    rdfs:comment 'The maximum number of CLE/CPD credit hours that may be satisfied through qualifying pro bono legal service activities in lieu of formal coursework, as permitted by the jurisdiction.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryBodyCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Code' ;
    rdfs:comment 'Code identifying the specific regulatory or licensing body that issued this CLE/CPD mandate (e.g., ABA, SRA, CALBAR, NYSBA). Enables multi-jurisdictional reporting and regulatory body-level analytics.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodLabel rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Label' ;
    rdfs:comment 'Human-readable label for the CLE/CPD compliance reporting cycle (e.g., 2024–2025 Biennial, FY2024 Annual). Used for display in dashboards and compliance reports.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Requirement Source Url' ;
    rdfs:comment 'URL reference to the official regulatory body publication or rule document that defines this CLE/CPD requirement. Provides an audit trail back to the authoritative source.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementVersion rdf:type rdf:Property ;
    rdfs:label 'Requirement Version' ;
    rdfs:comment 'Version identifier for this CLE/CPD requirement definition, reflecting updates issued by the regulatory body (e.g., 2024.1). Enables tracking of rule changes over time and audit of which version governed a given period.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfStudySubjectRestriction rdf:type rdf:Property ;
    rdfs:label 'Self Study Subject Restriction' ;
    rdfs:comment 'Describes any subject-matter restrictions on self-study or on-demand CLE/CPD hours imposed by the jurisdiction (e.g., ethics hours may not be earned via self-study in some jurisdictions). Null if no restriction applies.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceAbuseHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Substance Abuse Hours Required' ;
    rdfs:comment 'The minimum number of CLE/CPD hours that must be earned in attorney wellness, substance abuse, or mental health topics as mandated by certain jurisdictions.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Technology Hours Required' ;
    rdfs:comment 'The minimum number of CLE/CPD hours that must be earned in legal technology topics (e.g., cybersecurity, AI in law, eDiscovery) as mandated by the jurisdiction. Reflects ABA Comment 8 to Rule 1.1 on technological competence.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Total Hours Required' ;
    rdfs:comment 'The total number of CLE/CPD credit hours the attorney must complete within the reporting period as mandated by the jurisdiction. Includes all sub-category requirements.' ;
    rdfs:domain ind:CleRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleCompletionId rdf:type rdf:Property ;
    rdfs:label 'Cle Completion Id' ;
    rdfs:comment 'Unique surrogate identifier for each CLE/CPD completion record in the Silver layer. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Completing Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Each CLE completion record must reference the attorney who completed the course. Required for compliance reporting.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:learningItemId rdf:type rdf:Property ;
    rdfs:label 'Learning Item Id' ;
    rdfs:comment 'Reference to the course or learning item catalogue record in SAP SuccessFactors Learning. Enables linkage to the course master for provider, accreditation body, and curriculum metadata.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningItem .

ind:primaryCleRequirementId rdf:type rdf:Property ;
    rdfs:label 'Primary Cle Requirement Id' ;
    rdfs:comment 'Foreign key linking to workforce.cle_requirement. Business justification: CLE completions should link to the specific requirement record they satisfy. This enables tracking compliance against jurisdiction-specific CPD/CLE requirements. The cle_completion table currently has' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleRequirement .

ind:recordedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Recorded By Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Each CLE completion event is performed by a specific attorney/timekeeper. Essential for compliance tracking.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:satisfiedCleRequirementId rdf:type rdf:Property ;
    rdfs:label 'Satisfied Cle Requirement Id' ;
    rdfs:comment 'FK to workforce.cle_requirement.cle_requirement_id — Completions must be matched against requirements to determine compliance. This is the core CLE compliance join.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleRequirement .

ind:toCleRequirementId rdf:type rdf:Property ;
    rdfs:label 'To Cle Requirement Id' ;
    rdfs:comment 'FK to workforce.cle_requirement.cle_requirement_id — Each completion record satisfies credits toward a specific CLE requirement (jurisdiction + reporting period). This link enables compliance gap analysis.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleRequirement .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Unique accreditation or approval number assigned to this course by the accrediting bar association or regulatory body. Required for bar compliance submissions and audit verification.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Accreditation status of the course or activity as determined by the relevant bar association or regulatory body. Only accredited completions count toward mandatory CLE/CPD requirements. pending indicates the firm has applied for accreditation but approval has not yet been received.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingBody rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body' ;
    rdfs:comment 'Name of the bar association, regulatory body, or professional organisation that accredited this CLE/CPD activity (e.g., New York State CLE Board, State Bar of California, Solicitors Regulation Authority, International Bar Association). A single completion may be accredited by multiple bodies; this field captures the primary accrediting body.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievedScore rdf:type rdf:Property ;
    rdfs:label 'Achieved Score' ;
    rdfs:comment 'The actual score (as a percentage) achieved by the timekeeper on the course assessment. Null if no assessment is required. Used to validate completion eligibility and track learning effectiveness.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Bar Confirmation Number' ;
    rdfs:comment 'Confirmation or acknowledgement number returned by the bar association or regulatory body upon successful receipt of the CLE/CPD completion report. Provides audit evidence that the credit has been officially recorded by the regulator.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate or completion reference number issued by the course provider to the individual timekeeper upon successful completion. Used for audit evidence and bar compliance verification.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Number' ;
    rdfs:comment 'Externally-visible business identifier for this completion record, typically generated by SAP SuccessFactors Learning or the accrediting body. Used for audit trails, bar reporting submissions, and certificate cross-referencing. Satisfies BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred by the firm for this CLE/CPD completion, including registration fees, materials, and any associated expenses. Used for workforce development budget tracking and cost-per-credit analytics. Expressed in the firms base currency.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost amount (e.g., USD, GBP, EUR). Required for multi-currency firms operating across jurisdictions.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Categorical classification of the CLE/CPD course content area as defined by the accrediting body or firm taxonomy. Used for workforce development analytics, skills gap analysis, and compliance sub-category tracking. [ENUM-REF-CANDIDATE: substantive_law|ethics_professionalism|skills|practice_management|technology|diversity_equity_inclusion|wellbeing — promote to reference product if additional categories are required]' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Course Duration Minutes' ;
    rdfs:comment 'Total instructional duration of the CLE/CPD course in minutes as recorded by the provider. Used to validate credit hour claims (typically 60 minutes = 1.0 credit hour) and detect discrepancies between claimed and actual seat time.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseStartDate rdf:type rdf:Property ;
    rdfs:label 'Course Start Date' ;
    rdfs:comment 'The date on which the CLE/CPD course or activity commenced. For multi-day programmes, this is the first day of instruction. Distinct from completion_date; used to calculate course duration and validate credit hour claims.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full title of the CLE/CPD course or activity as provided by the course provider or accrediting body. Used for compliance reporting submissions to state bars, SRA, and IBA, and for knowledge management analytics.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'Total number of Continuing Legal Education (CLE) or Continuing Professional Development (CPD) credit hours earned by the timekeeper for this completion. Expressed in decimal hours (e.g., 1.50 = 90 minutes). Used to calculate compliance against annual or biennial bar requirements.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityEquityInclusionCreditHours rdf:type rdf:Property ;
    rdfs:label 'Diversity Equity Inclusion Credit Hours' ;
    rdfs:comment 'Subset of total credit hours that qualify as diversity, equity, and inclusion (DEI) credits. A growing number of state bars (e.g., California, New York) mandate DEI-focused CLE credits per reporting period. Enables compliance tracking against DEI credit sub-requirements.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicsCreditHours rdf:type rdf:Property ;
    rdfs:label 'Ethics Credit Hours' ;
    rdfs:comment 'Subset of total credit hours that qualify as ethics or professional responsibility credits. Most state bars and the SRA mandate a minimum number of ethics credits per reporting period; this field enables compliance tracking against those sub-requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDiversityEquityInclusionCredit rdf:type rdf:Property ;
    rdfs:label 'Is Diversity Equity Inclusion Credit' ;
    rdfs:comment 'Boolean flag indicating whether any portion of this CLE/CPD activity qualifies as a diversity, equity, and inclusion (DEI) credit. Enables rapid filtering for DEI credit compliance reporting.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEthicsCredit rdf:type rdf:Property ;
    rdfs:label 'Is Ethics Credit' ;
    rdfs:comment 'Boolean flag indicating whether any portion of this CLE/CPD activity qualifies as ethics or professional responsibility credit. Provides a quick filter for ethics compliance dashboards without requiring a numeric threshold check.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirmSponsored rdf:type rdf:Property ;
    rdfs:label 'Is Firm Sponsored' ;
    rdfs:comment 'Boolean flag indicating whether the firm paid for or sponsored this CLE/CPD activity. False indicates the attorney self-funded the course. Used for workforce development budget reporting and reimbursement processing.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProBonoCredit rdf:type rdf:Property ;
    rdfs:label 'Is Pro Bono Credit' ;
    rdfs:comment 'Boolean flag indicating whether this activity qualifies for pro bono CLE credit. Some jurisdictions (e.g., New York) allow attorneys to earn CLE credit for qualifying pro bono legal services. Enables compliance tracking for pro bono credit sub-requirements.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTechnologyCredit rdf:type rdf:Property ;
    rdfs:label 'Is Technology Credit' ;
    rdfs:comment 'Boolean flag indicating whether any portion of this CLE/CPD activity qualifies as a technology competency credit. Enables rapid filtering for technology credit compliance reporting.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the in-person CLE/CPD event was held. Applicable for in-person and blended delivery formats. Used for travel expense reconciliation and geographic analytics on CLE attendance patterns.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the in-person CLE/CPD event was held (e.g., USA, GBR, AUS). Used for international compliance reporting and travel analytics.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passScore rdf:type rdf:Property ;
    rdfs:label 'Pass Score' ;
    rdfs:comment 'The minimum passing score threshold (as a percentage) required by the course provider or accrediting body for this CLE/CPD activity. Applicable for courses with a formal assessment component. Null if no assessment is required.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Accreditation or registration code assigned to the course provider by the relevant bar association or regulatory body (e.g., MCLE provider number issued by a state bar). Required for automated compliance submissions.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToBarDate rdf:type rdf:Property ;
    rdfs:label 'Reported To Bar Date' ;
    rdfs:comment 'The date on which this CLE/CPD completion was formally reported to the relevant bar association or regulatory body. Null if not yet reported. Used to track submission status and ensure timely compliance filings.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Reporting Jurisdiction' ;
    rdfs:comment 'The bar association jurisdiction or regulatory body to which this completion is being reported (e.g., NY, CA, TX, SRA-England-Wales, IBA). An attorney admitted in multiple jurisdictions may have the same completion reported to several bodies; this field identifies the primary reporting jurisdiction for this record.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The compliance reporting period to which this CLE/CPD credit applies, expressed as a calendar year (e.g., 2024) or biennial period (e.g., 2023-2024) depending on the jurisdictions cycle. Credits must be allocated to the correct reporting period for bar compliance submissions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., SAP SuccessFactors Learning completion ID). Enables traceability back to the system of record for reconciliation, re-processing, and audit purposes.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyCreditHours rdf:type rdf:Property ;
    rdfs:label 'Technology Credit Hours' ;
    rdfs:comment 'Subset of total credit hours that qualify as technology competency credits. Several state bars (e.g., Florida, North Carolina) require attorneys to complete technology-focused CLE credits per reporting period. Enables compliance tracking against technology credit sub-requirements.' ;
    rdfs:domain ind:CleCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each billing rate record in the master rate schedule. Primary key for the billing_rate data product.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Billed Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Billing rates are set per timekeeper. This link is critical for rate lookups during time entry and billing.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:billingApprovingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Billing Approving Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the equity or billing partner who approved this rate. Required for rate governance and audit trail per firm billing policy.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:priorRateBillingRateId rdf:type rdf:Property ;
    rdfs:label 'Prior Rate Billing Rate Id' ;
    rdfs:comment 'Reference to the immediately preceding billing rate record that this version supersedes. Enables traversal of the rate version chain for historical billing analysis and dispute resolution.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRate .

ind:rateOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Rate Owner Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Billing rates are defined per timekeeper. This is the core link enabling rate lookups for time entry billing.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:afaArrangementType rdf:type rdf:Property ;
    rdfs:label 'Afa Arrangement Type' ;
    rdfs:comment 'Specifies the type of Alternative Fee Arrangement (AFA) when rate_type is afa_blended. Drives billing logic, WIP recognition, and revenue forecasting for non-hourly engagements.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAgreedDate rdf:type rdf:Property ;
    rdfs:label 'Client Agreed Date' ;
    rdfs:comment 'The date on which the client formally agreed to or acknowledged this billing rate, typically documented in the Letter of Engagement (LOE) or rate agreement letter. Supports billing dispute resolution.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClientApproved rdf:type rdf:Property ;
    rdfs:label 'Is Client Approved' ;
    rdfs:comment 'Indicates whether the client has formally approved or acknowledged this billing rate. True = client has confirmed acceptance; False = rate is pending client acknowledgement. Critical for billing dispute prevention.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProBono rdf:type rdf:Property ;
    rdfs:label 'Is Pro Bono' ;
    rdfs:comment 'Indicates whether this rate record applies to pro bono matters. True = pro bono rate (typically zero or nominal); False = commercial rate. Supports pro bono reporting and ABA pro bono commitment tracking.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesRateCode rdf:type rdf:Property ;
    rdfs:label 'Ledes Rate Code' ;
    rdfs:comment 'The LEDES-compliant rate code assigned to this billing rate for inclusion in LEDES 1998B and LEDES XML electronic billing exports submitted to clients and legal bill review vendors.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterPhaseCode rdf:type rdf:Property ;
    rdfs:label 'Matter Phase Code' ;
    rdfs:comment 'UTBMS or firm-defined phase code indicating the matter phase to which this rate applies (e.g., discovery, trial, closing). Enables phase-specific rate differentiation under phased AFA or fixed-fee arrangements.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Date' ;
    rdfs:comment 'The date on which the approving partner formally approved this billing rate. Required for rate governance, audit trail, and compliance with firm billing policy.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateNotes rdf:type rdf:Property ;
    rdfs:label 'Rate Notes' ;
    rdfs:comment 'Free-text notes providing additional context about this billing rate, such as negotiation history, special conditions, client-specific restrictions, or approval commentary. Sourced from Aderant Expert rate record comments.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperClass rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Class' ;
    rdfs:comment 'Professional classification of the timekeeper to which this rate applies, reflecting seniority and role tier used in rate scheduling and UTBMS task-based billing.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Wip Recognition Method' ;
    rdfs:comment 'Specifies how Work in Progress (WIP) is recognised for this rate type. time_and_rate = standard hourly WIP accrual; fixed_fee_milestone = WIP recognised at milestone completion; contingent = WIP held until contingency event; deferred = WIP deferred per agreement terms.' ;
    rdfs:domain ind:BillingRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGroupPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Group Practice Group Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent practice group in the organizational hierarchy, enabling multi-level group structures (e.g., Disputes as parent of Commercial Litigation and International Arbitration). Null for top-level groups. Supports hierarchical financial roll-up reporting.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:primaryPracticeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Timekeeper Id' ;
    rdfs:comment 'foreign_key_to' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:afaEligible rdf:type rdf:Property ;
    rdfs:label 'Afa Eligible' ;
    rdfs:comment 'Indicates whether matters assigned to this practice group are eligible for Alternative Fee Arrangements (AFA) such as fixed fees, capped fees, contingency, or blended rates. Drives AFA proposal workflows in Elite 3E and client engagement letter templates.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedFteCount rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Count' ;
    rdfs:comment 'Approved Full-Time Equivalent (FTE) count for the practice group, accounting for part-time and flexible working arrangements. Distinct from headcount_budget as it normalizes part-time positions to full-time equivalents. Sourced from SAP SuccessFactors workforce planning module.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associateCount rdf:type rdf:Property ;
    rdfs:label 'Associate Count' ;
    rdfs:comment 'Number of associates (non-partner attorneys) currently assigned to the practice group. Used in leverage ratio calculations (associates per partner), capacity planning, and recruitment pipeline management.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingRateScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Code' ;
    rdfs:comment 'Code referencing the standard billing rate schedule applied to timekeepers in this practice group in Aderant Expert. Determines the default hourly rates for matter billing, AFA (Alternative Fee Arrangement) baseline calculations, and client rate negotiations.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Cle Requirement Hours' ;
    rdfs:comment 'Annual Continuing Legal Education (CLE) / Continuing Professional Development (CPD) hours required for attorneys in this practice group, which may exceed the minimum jurisdictional bar requirement due to practice area specialization (e.g., IP attorneys may require additional patent prosecution training). Tracked in SAP SuccessFactors Learning.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Actual current number of active timekeepers and staff assigned to the practice group as of the last data refresh from SAP SuccessFactors. Used to calculate headcount variance against budget and identify open positions requiring recruitment.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Externally-known alphanumeric short code uniquely identifying the practice group across firm systems (e.g., MA, LIT, IP, EMP, REG). Used as the business key in Elite 3E matter staffing, billing rate tables, and financial reporting. Aligns with UTBMS task code groupings.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Full human-readable name of the practice group or department (e.g., Mergers and Acquisitions, Commercial Litigation, Intellectual Property, Employment Law, Regulatory Compliance). The primary display label used in client-facing materials, internal directories, and reporting dashboards.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Total approved headcount budget (number of positions) for the practice group in the current fiscal year, including attorneys, paralegals, and dedicated support staff. Used in workforce planning, recruitment authorization, and FTE utilization reporting.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionPrimary rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Primary' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code representing the primary legal jurisdiction in which this practice group operates and advises (e.g., USA, GBR, DEU). Drives bar admission requirements for timekeepers, regulatory compliance obligations, and jurisdictional conflict checking in Intapp Conflicts.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterCountActive rdf:type rdf:Property ;
    rdfs:label 'Matter Count Active' ;
    rdfs:comment 'Current number of active matters assigned to this practice group as sourced from Elite 3E matter management. Used in capacity planning, workload balancing, and practice group performance dashboards. This is a point-in-time operational count, not a calculated aggregate.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceReviewCycle rdf:type rdf:Property ;
    rdfs:label 'Performance Review Cycle' ;
    rdfs:comment 'Frequency of formal performance reviews for timekeepers assigned to this practice group as configured in SAP SuccessFactors Performance & Goals. Drives automated review initiation, goal-setting workflows, and compensation adjustment timelines.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Group Status' ;
    rdfs:comment 'Current lifecycle status of the practice group within the firms organizational structure. active indicates the group is operational and accepting matter assignments; inactive indicates temporarily suspended; pending indicates newly created but not yet operational; dissolved indicates permanently closed; merged indicates consolidated into another group.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentOpenPositions rdf:type rdf:Property ;
    rdfs:label 'Recruitment Open Positions' ;
    rdfs:comment 'Number of currently open and approved recruitment positions for the practice group as tracked in SAP SuccessFactors Recruiting. Used in talent acquisition planning, headcount gap analysis, and lateral hire pipeline management.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionScope rdf:type rdf:Property ;
    rdfs:label 'Region Scope' ;
    rdfs:comment 'Geographic or jurisdictional scope of the practice groups operations (e.g., North America, EMEA, Asia Pacific, Global, United States, United Kingdom). Indicates whether the group operates locally, regionally, or globally. Used in resource allocation planning and cross-border matter staffing.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Annual revenue target (in firm base currency) set for the practice group for the current fiscal year. Used in financial performance dashboards, RPE (Revenue Per Equity Partner) calculations, and partner compensation reviews. Sourced from the firms annual budgeting process.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the revenue target amount (e.g., USD, GBP, EUR). Required for multi-currency firms operating across jurisdictions.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2025) to which the revenue target applies. Enables year-over-year comparison of practice group financial performance and target-setting history.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Status' ;
    rdfs:comment 'Current status of the succession planning process for the practice groups managing partner and key leadership roles in SAP SuccessFactors Succession & Development. Supports firm continuity planning and partner transition management.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperClassScope rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Class Scope' ;
    rdfs:comment 'Comma-separated list of timekeeper classification levels authorized to bill under this practice group (e.g., Equity Partner, Income Partner, Senior Associate, Associate, Paralegal, Law Clerk). Drives billing rate table lookups in Aderant Expert and timekeeper assignment validation in Elite 3E.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipWriteOffAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Wip Write Off Authority Limit' ;
    rdfs:comment 'Maximum monetary amount (in firm base currency) that the managing partner of this practice group is authorized to write off from WIP (Work in Progress) without escalation to firm management. Supports financial controls and write-off governance in Elite 3E.' ;
    rdfs:domain ind:PracticeGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matterAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Matter Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each matter assignment record linking a timekeeper to a specific matter. Primary key of this entity.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMatterTeamLeadTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Matter Team Lead Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper designated as the overall matter team lead, which may differ from the responsible attorney or lead partner. Used for LPM reporting and team coordination.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryMatterSupervisingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Matter Supervising Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper who holds supervisory responsibility over this assignment. Supports professional responsibility compliance, associate development, and matter hierarchy reporting. Null for lead partners or independently operating timekeepers.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'The date and time at which this matter assignment record was first created in the system of record (Elite 3E or SAP SuccessFactors). Supports audit trail, data lineage, and compliance reporting.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'The functional role the timekeeper holds on this matter. Drives billing authority, supervision hierarchy, and resource utilization reporting. [ENUM-REF-CANDIDATE: lead_partner|supervising_attorney|associate|paralegal|project_manager|of_counsel|staff — promote to reference product]' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Updated Timestamp' ;
    rdfs:comment 'The date and time at which this matter assignment record was most recently modified in the system of record. Supports change tracking, audit trail, and Silver layer incremental load processing.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingAttorneyFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Attorney Flag' ;
    rdfs:comment 'Indicates whether this timekeeper is designated as the Billing Attorney responsible for reviewing and approving prebills and invoices for this matter in Aderant Expert and Elite 3E.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Authorization Flag' ;
    rdfs:comment 'Indicates whether this timekeeper is authorized to record billable time against this matter. When False, time entries may be recorded as non-billable or blocked at prebill stage in Aderant Expert.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the billing_rate_override for this matter assignment (e.g., USD, GBP, EUR). Supports multi-currency matter billing in international practices.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Clearance Flag' ;
    rdfs:comment 'Indicates whether a conflict of interest check has been completed and cleared for this timekeeper on this matter assignment. Sourced from Intapp Conflicts. Mandatory for professional responsibility compliance.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpdHoursEarned rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Earned' ;
    rdfs:comment 'Number of Continuing Professional Development (CPD) / Continuing Legal Education (CLE) hours earned by the timekeeper through work on this matter assignment, where applicable (e.g., pro bono matters qualifying for CLE credit). Tracked in SAP SuccessFactors.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lpmResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Lpm Responsibility Flag' ;
    rdfs:comment 'Indicates whether this timekeeper holds Legal Project Management (LPM) responsibility for this matter assignment, including budget oversight, milestone tracking, and resource coordination.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterRoleSequence rdf:type rdf:Property ;
    rdfs:label 'Matter Role Sequence' ;
    rdfs:comment 'Numeric ordering of this timekeepers role within the matter team, used to distinguish primary from secondary assignments of the same role type (e.g., first associate vs. second associate). Supports matter team hierarchy display and reporting.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingAttorneyFlag rdf:type rdf:Property ;
    rdfs:label 'Originating Attorney Flag' ;
    rdfs:comment 'Indicates whether this timekeeper is the originating attorney who brought the client or matter to the firm. Used for business development credit allocation, compensation calculations, and PPP/RPE attribution.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proBonoCommittedHours rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Committed Hours' ;
    rdfs:comment 'The number of pro bono hours this timekeeper has committed to deliver on this matter assignment. Populated only when pro_bono_flag is True. Used for tracking individual and firm-level pro bono commitments against ABA Model Rule 6.1 targets.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proBonoDeliveredHours rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Delivered Hours' ;
    rdfs:comment 'Actual pro bono hours delivered by this timekeeper on this matter assignment to date. Populated only when pro_bono_flag is True. Enables variance analysis between committed and delivered pro bono hours for regulatory and firm reporting.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleAttorneyFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Attorney Flag' ;
    rdfs:comment 'Indicates whether this timekeeper is designated as the Responsible Attorney (RA) for the matter, holding ultimate professional and ethical accountability. Relevant for conflict checking, client relationship management, and regulatory compliance.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondmentFlag rdf:type rdf:Property ;
    rdfs:label 'Secondment Flag' ;
    rdfs:comment 'Indicates whether this timekeeper is on secondment (temporarily assigned to a client or another office) for this matter. Affects billing treatment, cost allocation, and SAP SuccessFactors workforce records.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native identifier of this matter assignment record in the originating source system (e.g., Elite 3E internal assignment key). Enables traceability from the Silver layer back to the operational system for reconciliation and audit purposes.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisionLevel rdf:type rdf:Property ;
    rdfs:label 'Supervision Level' ;
    rdfs:comment 'Indicates the degree of supervision under which this timekeeper operates on this matter. Relevant for professional responsibility compliance, associate development tracking, and quality control under ABA Model Rules.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipHoursUnbilled rdf:type rdf:Property ;
    rdfs:label 'Wip Hours Unbilled' ;
    rdfs:comment 'Hours recorded by this timekeeper on this matter that have been entered in Elite 3E but not yet included on a client invoice. Represents the timekeepers contribution to the matters Work in Progress (WIP) balance for revenue recognition and collections management.' ;
    rdfs:domain ind:MatterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each performance review record in the workforce domain. Primary key for the performance_review data product.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or staff member) who is the subject of this performance review. Sourced from SAP SuccessFactors employee master.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:reviewedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Performance reviews are conducted for a specific timekeeper. Critical for compensation decisions and partnership track.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:billableHoursAchieved rdf:type rdf:Property ;
    rdfs:label 'Billable Hours Achieved' ;
    rdfs:comment 'The actual billable hours recorded by the timekeeper during the review period, sourced from Elite 3E or Aderant Expert time entry systems. Compared against billable_hours_target to assess performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessDevelopmentHours rdf:type rdf:Property ;
    rdfs:label 'Business Development Hours' ;
    rdfs:comment 'Total hours invested by the timekeeper in business development activities (pitches, RFP responses, client entertainment, networking) during the review period. Sourced from non-billable time entries in Elite 3E or Aderant Expert.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionRate rdf:type rdf:Property ;
    rdfs:label 'Collection Rate' ;
    rdfs:comment 'The percentage of billed fees actually collected from clients attributable to the timekeepers work during the review period. Distinct from realization_rate; reflects accounts receivable performance and client payment behavior.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationAdjustmentRecommended rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Recommended' ;
    rdfs:comment 'Indicates whether the reviewer has recommended a compensation adjustment (salary increase, bonus, or equity tier change) as an outcome of this performance review. Feeds the compensation decision workflow.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentAreasNarrative rdf:type rdf:Property ;
    rdfs:label 'Development Areas Narrative' ;
    rdfs:comment 'Free-text narrative authored by the reviewer identifying areas for improvement and development goals for the timekeeper in the next review period. Feeds individual development plans in SAP SuccessFactors.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgement rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement' ;
    rdfs:comment 'Indicates whether the timekeeper has formally acknowledged receipt and review of their completed performance evaluation in SAP SuccessFactors. Required for HR compliance and employment law documentation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteStatus rdf:type rdf:Property ;
    rdfs:label 'Fte Status' ;
    rdfs:comment 'The Full-Time Equivalent (FTE) employment status of the timekeeper during the review period. Affects billable hours targets, utilization rate calculations, and compensation benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Numerical rating assessing the timekeepers leadership contributions, mentoring of junior staff, participation in firm committees, and professional development activities during the review period. Typically on a 1.0–5.0 scale.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Amount' ;
    rdfs:comment 'The total value of new business originated by the timekeeper during the review period, expressed in the firms base currency. Origination credit is a key metric for partnership track and compensation decisions, reflecting business development contribution.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The composite numerical performance rating assigned to the timekeeper for the review period, typically on a 1.0–5.0 scale as configured in SAP SuccessFactors. Drives compensation band placement, partnership track eligibility, and bonus pool allocation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRatingLabel rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Label' ;
    rdfs:comment 'Descriptive label corresponding to the overall_rating numeric score, as defined in the firms performance calibration framework. Used in narrative reporting and partnership committee presentations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipTrackEligible rdf:type rdf:Property ;
    rdfs:label 'Partnership Track Eligible' ;
    rdfs:comment 'Indicates whether the timekeeper has been identified as eligible for partnership track consideration based on this review cycles outcomes. Drives succession planning and partnership committee workflows.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceImprovementPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Required' ;
    rdfs:comment 'Indicates whether a formal Performance Improvement Plan (PIP) has been triggered as a result of this review. Drives HR case management workflows and compliance documentation requirements.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proBonoHoursDelivered rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Hours Delivered' ;
    rdfs:comment 'The actual pro bono hours recorded by the timekeeper during the review period. Compared against pro_bono_hours_target to assess compliance with firm pro bono commitments and ABA aspirational standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionRecommended rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended' ;
    rdfs:comment 'Indicates whether the reviewer has recommended the timekeeper for promotion (e.g., associate to senior associate, senior associate to counsel, counsel to partner) as an outcome of this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:realizationRate rdf:type rdf:Property ;
    rdfs:label 'Realization Rate' ;
    rdfs:comment 'The percentage of the timekeepers standard billing rate actually collected after write-downs and write-offs during the review period. A key financial performance metric for attorneys, reflecting billing efficiency and client relationship quality.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleYear rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Year' ;
    rdfs:comment 'The calendar or fiscal year in which this performance review cycle falls (e.g., 2024). Used to group and compare reviews across annual cycles for partnership track and compensation decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfAssessmentNarrative rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Narrative' ;
    rdfs:comment 'Free-text self-assessment narrative authored by the timekeeper themselves as part of the review process. Captures the employees own perspective on their performance, achievements, and development needs.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReviewCode rdf:type rdf:Property ;
    rdfs:label 'Source System Review Code' ;
    rdfs:comment 'The native performance review identifier as assigned by SAP SuccessFactors Performance Management module. Enables traceability back to the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsNarrative rdf:type rdf:Property ;
    rdfs:label 'Strengths Narrative' ;
    rdfs:comment 'Free-text narrative authored by the reviewer describing the timekeepers key strengths, accomplishments, and positive contributions during the review period. Stored as sourced from SAP SuccessFactors performance form.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationRateActual rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Actual' ;
    rdfs:comment 'The actual utilization rate achieved by the timekeeper during the review period, expressed as a percentage. Calculated from time entry data in Elite 3E or Aderant Expert. Used in utilization variance analysis and compensation decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRateTarget rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Target' ;
    rdfs:comment 'The target utilization rate (billable hours as a percentage of total available hours) set for the timekeeper for the review period. Expressed as a percentage (e.g., 85.00 for 85%). Feeds utilization variance analysis.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationRecordId rdf:type rdf:Property ;
    rdfs:label 'Compensation Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each compensation record in the workforce domain. Primary key for the compensation_record data product.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationSubjectTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Compensation Subject Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Compensation records belong to a specific timekeeper. Critical for payroll and PPP/PEP calculations.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:recordOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Record Owner Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Compensation records belong to a specific timekeeper. Critical for payroll and PPP/PEP calculations.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'Annual base salary amount for the timekeeper in the firms operating currency. Excludes bonuses, origination credits, and profit share distributions. Core input for PPP and RPE financial analytics.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsTierCode rdf:type rdf:Property ;
    rdfs:label 'Benefits Tier Code' ;
    rdfs:comment 'Code identifying the benefits package tier assigned to this timekeeper (e.g., BASIC, STANDARD, ENHANCED, EXECUTIVE). Determines eligibility for health insurance, retirement contributions, professional indemnity coverage, and other firm-provided benefits.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusActualAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Actual Amount' ;
    rdfs:comment 'Actual bonus amount paid to the timekeeper for the compensation period following performance evaluation and management approval. May differ from the target based on individual and firm performance outcomes.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Amount' ;
    rdfs:comment 'Target bonus amount established for the timekeeper at the start of the performance period under the applicable bonus plan. Represents the expected payout at 100% performance achievement. Used for compensation modeling and budget forecasting.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalContribution rdf:type rdf:Property ;
    rdfs:label 'Capital Contribution' ;
    rdfs:comment 'Amount of capital contributed by the equity partner to the firm as required under the partnership agreement. Null for non-equity timekeepers. Used in partner financial modeling and balance sheet reporting.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Classification of the compensation structure applied to this timekeeper. Lockstep advances by seniority year; merit-based is performance-driven; equity and non-equity partner tiers reflect partnership status; staff covers non-attorney personnel.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredCompensation rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation' ;
    rdfs:comment 'Amount of compensation deferred to a future period under a firm-sponsored deferred compensation arrangement. Common for equity partners deferring a portion of profit distributions. Supports long-term compensation liability reporting.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawAmount rdf:type rdf:Property ;
    rdfs:label 'Draw Amount' ;
    rdfs:comment 'Monthly or periodic draw amount paid to an equity partner as an advance against their anticipated profit share distribution. Null for non-partner timekeepers. Used in partner cash flow management and year-end reconciliation against actual profit share.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPartnerPoints rdf:type rdf:Property ;
    rdfs:label 'Equity Partner Points' ;
    rdfs:comment 'Numeric points value assigned to the equity partner under the firms points-based profit sharing system. Determines the partners proportional share of distributable profits. Null for non-equity timekeepers. Key input for PPP and PEP calculations.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPartnerTierName rdf:type rdf:Property ;
    rdfs:label 'Equity Partner Tier Name' ;
    rdfs:comment 'Human-readable name of the equity partner tier assigned to this timekeeper (e.g., Tier 1, Senior Partner, Managing Partner). Null for non-equity timekeepers. Drives profit share and capital contribution calculations for PEP and PPP analytics.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRecordRef rdf:type rdf:Property ;
    rdfs:label 'External Record Ref' ;
    rdfs:comment 'Externally-known reference number or identifier for this compensation record as assigned by SAP SuccessFactors or the firms HR system of record. Used for cross-system reconciliation.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteFraction rdf:type rdf:Property ;
    rdfs:label 'Fte Fraction' ;
    rdfs:comment 'Numeric fraction representing the timekeepers working proportion relative to a full-time position (e.g., 1.0 for full-time, 0.5 for half-time). Used to prorate salary, bonus targets, and billable hour targets for part-time timekeepers.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockstepYear rdf:type rdf:Property ;
    rdfs:label 'Lockstep Year' ;
    rdfs:comment 'The seniority year within the firms lockstep compensation progression at which this timekeeper is placed for the compensation period. Null for merit-based or partner compensation structures. Drives automatic salary advancement in lockstep plans.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meritIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Pct' ;
    rdfs:comment 'Percentage salary increase awarded to the timekeeper based on individual performance evaluation for the compensation cycle. Null for lockstep or partner compensation structures. Supports merit budget analysis and pay equity reporting.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationBonus rdf:type rdf:Property ;
    rdfs:label 'Origination Bonus' ;
    rdfs:comment 'Bonus amount awarded to the timekeeper for originating new client business or matters during the compensation period. Reflects the firms business development incentive structure and is a key component of partner compensation analytics including RPE.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payBandCode rdf:type rdf:Property ;
    rdfs:label 'Pay Band Code' ;
    rdfs:comment 'Firm-defined pay band or grade code assigned to this timekeeper under the applicable compensation plan (e.g., A1, A2, SA1, P1 for associates and senior associates). Drives lockstep or merit-based salary range boundaries.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payBandMax rdf:type rdf:Property ;
    rdfs:label 'Pay Band Max' ;
    rdfs:comment 'Maximum salary amount defined for the assigned pay band. Used to validate that the timekeepers base salary does not exceed the approved compensation ceiling and supports pay equity reporting.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payBandMin rdf:type rdf:Property ;
    rdfs:label 'Pay Band Min' ;
    rdfs:comment 'Minimum salary amount defined for the assigned pay band. Used to validate that the timekeepers base salary falls within the approved compensation range and supports equity analysis.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payEquityFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Equity Flag' ;
    rdfs:comment 'Indicates whether this compensation record has been flagged for pay equity review, typically triggered when the timekeepers compensation falls outside the expected range for their grade, gender, or demographic cohort. Supports compliance with pay equity legislation.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitSharePct rdf:type rdf:Property ;
    rdfs:label 'Profit Share Pct' ;
    rdfs:comment 'Percentage of the firms distributable profits allocated to this equity partner for the compensation period. Derived from the partners points relative to total firm points but stored as a discrete record for audit and historical reporting. Null for non-equity timekeepers.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementContributionPct rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Pct' ;
    rdfs:comment 'Firms contribution percentage to the timekeepers retirement or pension plan as a proportion of base salary. Supports total compensation cost modeling and benefits benchmarking.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timekeeperGrade rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Grade' ;
    rdfs:comment 'Seniority or grade classification of the timekeeper within the firms career framework (e.g., Year 1 Associate, Year 5 Associate, Senior Associate, Counsel, Non-Equity Partner, Equity Partner). Drives pay band assignment and lockstep progression.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCashCompensation rdf:type rdf:Property ;
    rdfs:label 'Total Cash Compensation' ;
    rdfs:comment 'Total cash compensation for the timekeeper for the compensation period, comprising base salary plus actual bonus payout plus origination bonus. Stored as a discrete field (not computed at query time) to support point-in-time compensation reporting and regulatory pay equity analysis.' ;
    rdfs:domain ind:CompensationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Unique surrogate identifier for each recruitment requisition record in the workforce data product. Primary key for the silver-layer lakehouse table. Entity role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:originPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Origin Practice Group Id' ;
    rdfs:comment 'FK to workforce.practice_group.practice_group_id — Recruitment requisitions are opened for a specific practice group. Links hiring to organizational structure.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:primaryRecruitmentPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Practice Group Id' ;
    rdfs:comment 'FK to workforce.practice_group' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:primaryRecruitmentTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Timekeeper Id' ;
    rdfs:comment 'Identifier of the attorney, partner, or staff manager who initiated and owns the recruitment requisition. Corresponds to the PARTY_REFERENCE category for TRANSACTION_HEADER role. Links to the workforce employee/timekeeper master record.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:requestingPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Requesting Practice Group Id' ;
    rdfs:comment 'FK to workforce.practice_group.practice_group_id — Recruitment requisitions are opened for specific practice groups. Required for headcount planning alignment.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:successionPlanId rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Id' ;
    rdfs:comment 'Foreign key linking to workforce.succession_plan. Business justification: Recruitment requisitions may be created to fulfill succession plans when a key role needs to be filled. The recruitment_requisition table has succession_plan_flag (BOOLEAN) indicating the requisition ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuccessionPlan .

ind:targetPracticeGroupId rdf:type rdf:Property ;
    rdfs:label 'Target Practice Group Id' ;
    rdfs:comment 'FK to workforce.practice_group.practice_group_id — Each recruitment requisition is opened for a specific practice group. Required for headcount planning and budget tracking by practice area.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'Number of full-time equivalent (FTE) positions approved for hire under this requisition. Typically 1 for individual hires; may be greater for cohort or class-year campus recruiting campaigns. Drives headcount budget reconciliation.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backgroundCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Required Flag' ;
    rdfs:comment 'Indicates whether candidates for this requisition are required to complete a background check (criminal, credit, education verification) as part of the pre-employment screening process. Driven by position type, seniority level, and client-facing responsibilities.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barAdmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Required Flag' ;
    rdfs:comment 'Indicates whether the open position requires the candidate to hold an active bar admission or solicitor qualification. True for attorney and counsel roles; False for paralegal, legal secretary, and business services staff. Drives compliance screening in the candidate pipeline.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barJurisdictionRequired rdf:type rdf:Property ;
    rdfs:label 'Bar Jurisdiction Required' ;
    rdfs:comment 'The specific jurisdiction(s) in which the candidate must hold an active bar admission or solicitor qualification (e.g., New York, California, England and Wales). Null for non-attorney positions. Used for compliance screening and lateral hire eligibility assessment.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeReason rdf:type rdf:Property ;
    rdfs:label 'Close Reason' ;
    rdfs:comment 'The business reason for closing the recruitment requisition. Distinguishes successful fills from cancellations due to headcount freezes, organisational restructuring, or strategic withdrawal. Critical for workforce planning analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary band and compensation figures associated with this requisition (e.g., USD, GBP, EUR). Required for multi-office firms operating across jurisdictions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictsPrescreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Conflicts Prescreening Required Flag' ;
    rdfs:comment 'Indicates whether candidates for this requisition must undergo a conflicts of interest pre-screen via Intapp Conflicts before progressing to interview stages. Mandatory for attorney and counsel positions to satisfy professional responsibility obligations and ethical wall requirements.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentPipelineCount rdf:type rdf:Property ;
    rdfs:label 'Current Pipeline Count' ;
    rdfs:comment 'Total number of active candidates currently in the pipeline for this requisition across all interview stages. Provides a real-time snapshot of pipeline depth for recruiter workload management and hiring manager reporting.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStageCount rdf:type rdf:Property ;
    rdfs:label 'Interview Stage Count' ;
    rdfs:comment 'Total number of defined interview stages configured for this requisitions hiring process in SAP SuccessFactors (e.g., phone screen, first-round, callback, partner interview). Used for process standardisation and time-to-hire analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobDescriptionUrl rdf:type rdf:Property ;
    rdfs:label 'Job Description Url' ;
    rdfs:comment 'URL link to the full job description document stored in the firms document management system (iManage Work or NetDocuments) or careers portal. Provides recruiters and hiring managers with direct access to the approved position specification.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPostingDate rdf:type rdf:Property ;
    rdfs:label 'Job Posting Date' ;
    rdfs:comment 'The date on which the position was first published externally on job boards, the firms careers portal, or law school recruiting platforms. Used to measure sourcing lead time and candidate pipeline velocity.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Check Required Flag' ;
    rdfs:comment 'Indicates whether the candidate must undergo KYC (Know Your Client) and AML (Anti-Money Laundering) screening as part of the pre-employment process. Applicable for positions with access to client trust accounts (IOLTA), financial transactions, or regulated activities under FATF guidelines.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawSchoolTargetTier rdf:type rdf:Property ;
    rdfs:label 'Law School Target Tier' ;
    rdfs:comment 'For law school campus recruiting requisitions, the target law school ranking tier from which the firm is recruiting (e.g., T14 top-14 law schools, Top 25, Top 50, any ABA-accredited school). Not applicable for lateral hire or staff requisitions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'The date on which the selected candidate formally accepted the employment offer. Marks the transition from active recruiting to onboarding. Null if offer has not yet been accepted.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'The date on which the formal employment offer was extended to the selected candidate. Used to calculate offer-to-acceptance cycle time and compliance with candidate communication SLAs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Flag' ;
    rdfs:comment 'Indicates whether a formal offer of employment has been extended to at least one candidate under this requisition. True when an offer letter has been issued; False when no offer has yet been made. Used for pipeline conversion rate reporting.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerOutcome rdf:type rdf:Property ;
    rdfs:label 'Offer Outcome' ;
    rdfs:comment 'The outcome of the most recent employment offer extended under this requisition. Accepted indicates the candidate accepted the offer; declined indicates candidate rejection; rescinded indicates the firm withdrew the offer. Null when no offer has been extended.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Categorical classification of the open position distinguishing attorney roles from paralegal, legal secretary, and business services staff. Determines applicable bar admission requirements and CPD/CLE obligations. [ENUM-REF-CANDIDATE: attorney|paralegal|legal_secretary|staff|partner|of_counsel — promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementOrNewFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Or New Flag' ;
    rdfs:comment 'Indicates whether the requisition is for a replacement of a departing employee, a net-new approved headcount position, or a backfill for a temporarily vacated role. Critical for headcount budget reconciliation and workforce planning analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNotes rdf:type rdf:Property ;
    rdfs:label 'Requisition Notes' ;
    rdfs:comment 'Free-text field for additional context, special requirements, or internal notes related to the recruitment requisition as entered by the recruiter or HR business partner in SAP SuccessFactors. May include client-specific staffing requirements or practice group preferences.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the recruitment requisition as assigned by SAP SuccessFactors Recruiting. Used in communications with hiring managers, HR business partners, and candidates. Corresponds to the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionPriority rdf:type rdf:Property ;
    rdfs:label 'Requisition Priority' ;
    rdfs:comment 'Business priority level assigned to the requisition by the hiring manager or HR business partner. Critical and high-priority requisitions receive accelerated recruiter attention and may trigger executive escalation if unfilled beyond SLA thresholds.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the recruitment requisition. Drives workflow routing, reporting, and headcount budget tracking. Corresponds to the LIFECYCLE_STATUS category for TRANSACTION_HEADER role. [ENUM-REF-CANDIDATE: draft|open|on_hold|filled|cancelled|closed — promote to reference product if additional states are required]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryBandMax rdf:type rdf:Property ;
    rdfs:label 'Salary Band Max' ;
    rdfs:comment 'The maximum base compensation amount for the approved salary band associated with this requisition, expressed in the office locations local currency. Used for compensation benchmarking, budget approval, and pay equity analysis. Classified confidential as it represents sensitive business compensation data.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryBandMin rdf:type rdf:Property ;
    rdfs:label 'Salary Band Min' ;
    rdfs:comment 'The minimum base compensation amount for the approved salary band associated with this requisition, expressed in the office locations local currency. Used for compensation benchmarking and pay equity analysis. Classified confidential as it represents sensitive business compensation data.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Sourcing Agency Name' ;
    rdfs:comment 'Name of the external legal search firm or recruitment agency engaged to source candidates for this requisition (e.g., Major Lindsey & Africa, Lateral Link). Null for internally sourced or campus recruiting requisitions. Used for agency fee tracking and vendor performance management.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'Primary channel through which candidates are being sourced for this requisition. Lateral hire indicates experienced attorney recruitment; law_school_campus indicates on-campus recruiting; ALSP (Alternative Legal Service Provider) indicates contract staffing; referral indicates employee referral programme. Used for cost-per-hire and sourcing effectiveness analytics.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'The desired or planned start date for the successful candidate as specified by the hiring manager at the time of requisition creation. Used for workforce planning, matter staffing projections, and bar admission timeline management.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yearsExperienceMin rdf:type rdf:Property ;
    rdfs:label 'Years Experience Min' ;
    rdfs:comment 'Minimum number of years of post-qualification or relevant legal experience required for the open position. Used to filter candidate pipelines and benchmark against lateral hire market data.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveRecordId rdf:type rdf:Property ;
    rdfs:label 'Leave Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each leave record in the workforce domain. Primary key for the leave_record data product sourced from SAP SuccessFactors Time and Attendance.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveSubjectTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Leave Subject Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Leave records track absences for a specific timekeeper. Critical for resource planning and billable hours target adjustment.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryLeaveTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or staff member) for whom this leave record applies. Links to the workforce.timekeeper master record.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryLeaveCoveringTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Covering Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper assigned as primary cover for the absent timekeepers matters. Populated when coverage_arrangement is internal_cover or shared_cover. Supports matter staffing continuity and conflict checking.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The actual calendar date on which the timekeeper returned to active work. May differ from approved_end_date due to early return, extended leave, or phased return arrangements. Null until the timekeeper has returned.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Approved Duration Days' ;
    rdfs:comment 'Total number of calendar days covered by the approved leave period, calculated from approved_start_date to approved_end_date inclusive. Used for entitlement balance deduction and payroll adjustment.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The formally approved last calendar day of the leave period. Nullable for open-ended leaves such as long-term medical or parental leave where return date is not yet confirmed.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The formally approved first calendar day of the leave period. Used for matter staffing continuity planning, billable hours target proration, and payroll processing.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barComplianceRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Bar Compliance Risk Flag' ;
    rdfs:comment 'Indicates whether this leave event creates a risk of non-compliance with bar admission CPD/CLE requirements (True). Triggers proactive outreach to the timekeeper and bar compliance team.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billableHoursTargetImpact rdf:type rdf:Property ;
    rdfs:label 'Billable Hours Target Impact' ;
    rdfs:comment 'Reduction in the timekeepers annual billable hours target (in hours) attributable to this leave event. Used by Legal Project Management (LPM) and practice group leaders to reforecast capacity and matter staffing.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The calendar date on which an approved or pending leave request was cancelled, either by the employee or HR. Populated only when leave_status is cancelled. Triggers reversal of payroll adjustments and entitlement balance restoration.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageArrangement rdf:type rdf:Property ;
    rdfs:label 'Coverage Arrangement' ;
    rdfs:comment 'Describes the staffing continuity arrangement put in place to cover the absent timekeepers matters and client responsibilities during the leave period.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdImpactHours rdf:type rdf:Property ;
    rdfs:label 'Cpd Impact Hours' ;
    rdfs:comment 'Number of Continuing Professional Development (CPD)/Continuing Legal Education (CLE) hours that may be deferred or waived as a result of this leave event. Used by HR to manage bar compliance and CPD exemption applications.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeNotes rdf:type rdf:Property ;
    rdfs:label 'Employee Notes' ;
    rdfs:comment 'Free-text notes submitted by the timekeeper as part of the leave request, providing context or special instructions. Classified as confidential.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrNotes rdf:type rdf:Property ;
    rdfs:label 'Hr Notes' ;
    rdfs:comment 'Free-text notes entered by HR personnel regarding special circumstances, accommodation arrangements, or case-specific details for this leave record. Classified as confidential due to potential sensitivity of employment-related information.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether the leave is taken intermittently (True) rather than as a continuous block (False). Intermittent leave requires separate scheduling and has different billable hours impact calculations under FMLA.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the leave is fully paid (True) or unpaid/partially unpaid (False). Drives payroll adjustment processing and IOLTA trust account considerations for partner draws.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhasedReturn rdf:type rdf:Property ;
    rdfs:label 'Is Phased Return' ;
    rdfs:comment 'Indicates whether the timekeeper is returning to work on a phased/reduced-hours basis (True) rather than full capacity (False). Affects FTE percentage, billable hours target, and matter staffing planning.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'The timekeepers accrued leave entitlement balance in days immediately after this leave event has been applied. Supports entitlement audit and payroll reconciliation.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'The timekeepers accrued leave entitlement balance in days immediately prior to this leave event being applied. Supports entitlement audit and dispute resolution.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveReasonCode rdf:type rdf:Property ;
    rdfs:label 'Leave Reason Code' ;
    rdfs:comment 'Standardised code from SAP SuccessFactors identifying the specific reason for the leave (e.g., FMLA-SELF, FMLA-FAMILY, PERSONAL-ILLNESS, MATERNITY, PATERNITY, SABBATICAL-RESEARCH). Sensitive business data used for HR reporting and regulatory compliance.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Leave Request Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the leave request as generated by SAP SuccessFactors Time and Attendance. Used for cross-system reference and employee communications.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveStatus rdf:type rdf:Property ;
    rdfs:label 'Leave Status' ;
    rdfs:comment 'Current lifecycle state of the leave record within the approval and execution workflow. Drives resource planning and matter staffing continuity actions.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave event by its nature and entitlement basis. Drives payroll treatment, billable hours target adjustment, and matter staffing continuity planning. [ENUM-REF-CANDIDATE: annual|parental|medical|sabbatical|unpaid|bereavement|jury_duty|military|study|compassionate — promote to reference product]' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterImpactAssessed rdf:type rdf:Property ;
    rdfs:label 'Matter Impact Assessed' ;
    rdfs:comment 'Indicates whether a formal matter staffing impact assessment has been completed for this leave event (True). Ensures compliance with ABA Rule 1.3 (Diligence) and SRA Code of Conduct obligations for client service continuity.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received' ;
    rdfs:comment 'Indicates whether the required medical certification documentation has been received and validated by HR (True). Null or False when medical_certification_required is False.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required' ;
    rdfs:comment 'Indicates whether medical certification documentation is required for this leave type and jurisdiction (True). Drives document collection workflow in SAP SuccessFactors and compliance with FMLA/ADA certification requirements.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Payroll Adjustment Amount' ;
    rdfs:comment 'Monetary value of the payroll deduction or adjustment resulting from this leave event, expressed in the firms base currency. Populated only when payroll_adjustment_flag is True. Sensitive compensation data.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Adjustment Flag' ;
    rdfs:comment 'Indicates whether a payroll adjustment is required for this leave event (True) due to unpaid leave, partial pay, or leave without pay arrangements. Triggers downstream payroll processing in SAP SuccessFactors Payroll.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phasedReturnEndDate rdf:type rdf:Property ;
    rdfs:label 'Phased Return End Date' ;
    rdfs:comment 'The date on which the phased return arrangement concludes and the timekeeper resumes full FTE capacity. Null when is_phased_return is False.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phasedReturnFtePercentage rdf:type rdf:Property ;
    rdfs:label 'Phased Return Fte Percentage' ;
    rdfs:comment 'The reduced Full-Time Equivalent (FTE) percentage applicable during a phased return period, expressed as a decimal percentage (e.g., 50.00 for 50%). Null when is_phased_return is False.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryLeaveCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Leave Category' ;
    rdfs:comment 'The statutory or regulatory framework under which this leave is classified (e.g., FMLA, ADA, UK statutory maternity/paternity, EU Working Time Directive, or firm policy only). Drives compliance reporting obligations. [ENUM-REF-CANDIDATE: fmla|ada|state_statutory|firm_policy|uk_statutory|eu_directive|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDaysAbsent rdf:type rdf:Property ;
    rdfs:label 'Working Days Absent' ;
    rdfs:comment 'Number of business working days (excluding weekends and public holidays) within the approved leave period. Used for billable hours target adjustment and FTE capacity planning.' ;
    rdfs:domain ind:LeaveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySuccessorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Successor Timekeeper Id' ;
    rdfs:comment 'Identifier of the first-ranked designated successor candidate for the key role. References the timekeeper record of the attorney or professional identified as the primary succession candidate.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:subjectTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Subject Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Succession plans identify the incumbent in a key role. Must reference the timekeeper at risk of departure.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiarySuccessionTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Succession Timekeeper Id' ;
    rdfs:comment 'Identifier of the equity partner or senior leader who sponsors and is accountable for this succession plan. Responsible for overseeing development actions and plan reviews.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:barAdmissionGap rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Gap' ;
    rdfs:comment 'Indicates whether the primary successor candidate lacks a required bar admission or jurisdiction-specific licence needed to fully assume the key role. Triggers targeted bar admission development actions.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleGapIdentified rdf:type rdf:Property ;
    rdfs:label 'Cle Gap Identified' ;
    rdfs:comment 'Indicates whether a Continuing Legal Education (CLE) or Continuing Professional Development (CPD) gap has been identified for the primary successor candidate that must be addressed before they are ready to assume the key role.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientTransitionRisk rdf:type rdf:Property ;
    rdfs:label 'Client Transition Risk' ;
    rdfs:comment 'Assessment of the risk to client relationships if the incumbent vacates the role without a prepared successor. Reflects the degree to which key client relationships are concentrated in the incumbent and the potential revenue impact on the firm.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Development Actions Required' ;
    rdfs:comment 'Narrative description of the key development actions, training programs, mentoring assignments, or experience gaps that must be addressed to prepare successor candidates for the role. May reference CPD/CLE requirements or LPM training.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedVacancyDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Vacancy Date' ;
    rdfs:comment 'Projected date on which the incumbent is expected to vacate the role (e.g., planned retirement date, anticipated departure date). Used to set urgency and readiness timelines for successor development.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCandidateConsidered rdf:type rdf:Property ;
    rdfs:label 'External Candidate Considered' ;
    rdfs:comment 'Indicates whether external lateral hire candidates are being considered as part of the succession strategy for this role, in addition to or instead of internal successor development.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incumbentPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Incumbent Performance Rating' ;
    rdfs:comment 'Most recent formal performance rating of the incumbent in the key role. Confidential HR data used to assess whether the role vacancy is performance-driven and to calibrate urgency of succession planning.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyPlan rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Plan' ;
    rdfs:comment 'Indicates whether this plan has been designated as an emergency succession plan, activated in response to an unplanned or sudden vacancy (e.g., unexpected departure, incapacitation). Triggers expedited review and activation workflows.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyClientRevenueAtRisk rdf:type rdf:Property ;
    rdfs:label 'Key Client Revenue At Risk' ;
    rdfs:comment 'Estimated annual revenue (in the firms base currency) associated with key client relationships held by the incumbent that could be at risk upon role vacancy. Confidential financial planning data used to prioritize succession investment.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:knowledgeTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Knowledge Transfer Status' ;
    rdfs:comment 'Current status of knowledge transfer activities from the incumbent to designated successor candidates. Tracks progress of client introductions, matter handovers, and institutional knowledge documentation.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateralHireTargetSeniority rdf:type rdf:Property ;
    rdfs:label 'Lateral Hire Target Seniority' ;
    rdfs:comment 'If an external lateral hire is being considered as part of the succession strategy, the target seniority level for the lateral candidate. Applicable only when external_candidate_considered is true.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpmTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Lpm Training Required' ;
    rdfs:comment 'Indicates whether Legal Project Management (LPM) training has been identified as a required development action for the designated successor(s) to be ready for the key role.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mentoringAssignment rdf:type rdf:Property ;
    rdfs:label 'Mentoring Assignment' ;
    rdfs:comment 'Description of formal mentoring or coaching arrangements established between the incumbent and successor candidates, or between the sponsoring partner and successors, as part of the development plan.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nineBoxRating rdf:type rdf:Property ;
    rdfs:label 'Nine Box Rating' ;
    rdfs:comment 'Nine-box talent grid position assigned to the primary successor candidate, combining performance and potential dimensions (e.g., 1A, 2B, 3C). Confidential HR assessment used to calibrate succession readiness and development investment. [ENUM-REF-CANDIDATE: 1A|1B|1C|2A|2B|2C|3A|3B|3C — promote to reference product]' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'Date from which this succession plan became active and operative. Marks the start of the formal succession planning period for the role.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiry Date' ;
    rdfs:comment 'Date on which this succession plan is scheduled to expire or be superseded. Nullable for open-ended plans. Triggers mandatory review or closure workflow upon reaching this date.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the succession plan, used for cross-system identification and reporting. Sourced from SAP SuccessFactors.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReviewDate rdf:type rdf:Property ;
    rdfs:label 'Plan Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this succession plan by the sponsoring partner and HR leadership. Ensures plans remain current and development actions are progressing.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the succession plan record. Drives workflow routing and reporting visibility. Valid values: draft, active, under_review, on_hold, closed, archived.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySuccessorReadiness rdf:type rdf:Property ;
    rdfs:label 'Primary Successor Readiness' ;
    rdfs:comment 'Individual readiness assessment for the primary successor candidate, indicating how soon they could assume the key role. May differ from the overall plan readiness timeline if multiple candidates are assessed.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readinessTimeline rdf:type rdf:Property ;
    rdfs:label 'Readiness Timeline' ;
    rdfs:comment 'Assessed timeframe within which a designated successor will be ready to assume the key role. Drives development action prioritization and urgency of succession planning activities.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Eligibility Date' ;
    rdfs:comment 'Date on which the incumbent becomes eligible for retirement under the firms partnership agreement or retirement policy. Confidential HR data used to calibrate the succession planning horizon.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'Title of the critical role or position being succession-planned (e.g., Managing Partner, Practice Group Leader, Head of Litigation, Chief Legal Officer). Represents the position, not the individual.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondarySuccessorReadiness rdf:type rdf:Property ;
    rdfs:label 'Secondary Successor Readiness' ;
    rdfs:comment 'Individual readiness assessment for the secondary successor candidate, indicating how soon they could assume the key role if the primary successor is unavailable.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionNotes rdf:type rdf:Property ;
    rdfs:label 'Succession Notes' ;
    rdfs:comment 'Free-text confidential notes recorded by the sponsoring partner or HR leadership regarding the succession plan, including context on risk factors, candidate assessments, client sensitivities, or special circumstances not captured in structured fields.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorCount rdf:type rdf:Property ;
    rdfs:label 'Successor Count' ;
    rdfs:comment 'Total number of identified successor candidates associated with this succession plan. A count of zero indicates a critical gap with no identified pipeline for the role.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentPoolSegment rdf:type rdf:Property ;
    rdfs:label 'Talent Pool Segment' ;
    rdfs:comment 'SAP SuccessFactors talent pool classification assigned to the primary successor candidate. Segments the successor pipeline by potential and performance to prioritize development investment.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsInRole rdf:type rdf:Property ;
    rdfs:label 'Years In Role' ;
    rdfs:comment 'Number of years the incumbent has held the key role being succession-planned. Used to assess institutional knowledge concentration and urgency of knowledge transfer activities.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondmentId rdf:type rdf:Property ;
    rdfs:label 'Secondment Id' ;
    rdfs:comment 'Unique surrogate identifier for the secondment arrangement record in the workforce data product. Primary key for the secondment entity.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySecondmentSupervisingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Secondment Supervising Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the equity or non-equity partner responsible for overseeing the secondment arrangement, managing performance expectations, and maintaining the client relationship during the placement.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:secondedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Seconded Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Secondments place a specific timekeeper with a client or office. Required for tracking who is seconded where.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiarySecondmentApprovedByEmployeeTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Secondment Approved By Employee Timekeeper Id' ;
    rdfs:comment 'Reference to the firm employee (typically a practice group leader, managing partner, or HR director) who formally approved the secondment arrangement in SAP SuccessFactors.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:agreementDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Date' ;
    rdfs:comment 'The date on which the formal secondment agreement between the firm and the host organisation was executed and signed by all parties. Marks the binding commencement of the contractual arrangement.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingRateDuringSecondment rdf:type rdf:Property ;
    rdfs:label 'Billing Rate During Secondment' ;
    rdfs:comment 'The hourly billing rate applied to the secondees time charged to the host organisation or matter during the secondment period. May differ from the timekeepers standard rate in the firms rate schedule. Expressed in the currency defined by billing_currency_code.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationType rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Type' ;
    rdfs:comment 'Defines how the financial cost of the secondment is allocated between the firm and the host organisation. Client-funded: host client bears full cost; Firm-funded: firm absorbs all costs; Split: costs shared under an agreed ratio; Third-party funded: an external body (e.g., government grant) funds the placement.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Split Percentage' ;
    rdfs:comment 'Where cost_allocation_type is split, the percentage of total secondment cost borne by the host organisation. The firm bears the remainder (100 minus this value). Expressed as a percentage between 0.00 and 100.00.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpdHoursCredited rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Credited' ;
    rdfs:comment 'Number of Continuing Professional Development (CPD) or Continuing Legal Education (CLE) hours formally credited to the secondee for the secondment placement, as recognised by the relevant bar association or regulatory body.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProtectionAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Data Protection Agreement Signed' ;
    rdfs:comment 'Indicates whether a data protection agreement or data processing addendum has been executed between the firm and the host organisation governing the handling of personal data accessed by the secondee during the placement.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Early Termination Reason' ;
    rdfs:comment 'Reason code for the early termination of the secondment before the scheduled end date. Populated only when secondment_status is terminated_early. [ENUM-REF-CANDIDATE: recall_by_firm|resignation|host_request|performance|health|redundancy|matter_concluded|other — promote to reference product]' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostBarAdmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Host Bar Admission Required' ;
    rdfs:comment 'Indicates whether the secondee must hold or obtain a bar admission, practising certificate, or equivalent authorisation in the host jurisdiction to perform legal work during the secondment.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hostBarAdmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Host Bar Admission Status' ;
    rdfs:comment 'Current status of the secondees bar admission or practising certificate in the host jurisdiction. Not Required: no local admission needed; Pending: application in progress; Obtained: admission secured; Waived: exemption granted; Expired: admission lapsed.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCity rdf:type rdf:Property ;
    rdfs:label 'Host City' ;
    rdfs:comment 'City where the host organisations primary office or placement location is situated. Used for resource planning, travel and expense management, and cross-border staffing analytics.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostContactEmail rdf:type rdf:Property ;
    rdfs:label 'Host Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the host organisation. Used for secondment coordination, performance review communications, and return-to-role planning.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostContactName rdf:type rdf:Property ;
    rdfs:label 'Host Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the host organisation responsible for managing the secondees day-to-day activities, performance feedback, and administrative matters during the placement.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCountryCode rdf:type rdf:Property ;
    rdfs:label 'Host Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the host organisation is located. Drives international rotation classification, cross-border tax treatment, work permit requirements, and applicable bar admission rules.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostOrganisationName rdf:type rdf:Property ;
    rdfs:label 'Host Organisation Name' ;
    rdfs:comment 'The legal or trading name of the organisation hosting the secondee, which may be a client entity, another law firm office, a government body, or a non-profit. Sensitive as it reveals client relationship details.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostOrganisationType rdf:type rdf:Property ;
    rdfs:label 'Host Organisation Type' ;
    rdfs:comment 'Classification of the host organisation category, used to determine applicable billing arrangements, conflict-check requirements, and regulatory obligations during the secondment.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Lpp Risk Assessment' ;
    rdfs:comment 'Assessment of the risk that Legal Professional Privilege (LPP) over communications and work product may be compromised during the secondment, particularly relevant for in-house placements where LPP protections may differ from private practice.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectives rdf:type rdf:Property ;
    rdfs:label 'Objectives' ;
    rdfs:comment 'Narrative description of the agreed business and professional development objectives for the secondment, including skills to be developed, client relationship goals, and knowledge transfer targets. Used in performance management and CPD planning.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Performance Review Completed' ;
    rdfs:comment 'Indicates whether the formal performance review for the secondment has been completed and submitted in SAP SuccessFactors. Used to track compliance with the firms performance management obligations.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Due Date' ;
    rdfs:comment 'The scheduled date by which a formal mid-secondment or end-of-secondment performance review must be completed by the supervising partner and host contact, feeding into the timekeepers annual performance management cycle.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToRolePlan rdf:type rdf:Property ;
    rdfs:label 'Return To Role Plan' ;
    rdfs:comment 'Documented plan outlining the timekeepers reintegration into their substantive role upon completion of the secondment, including practice group reassignment, matter allocation, and any transitional support arrangements.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondmentStatus rdf:type rdf:Property ;
    rdfs:label 'Secondment Status' ;
    rdfs:comment 'Current lifecycle state of the secondment arrangement. Proposed: under internal review; Approved: authorised but not yet started; Active: timekeeper currently on placement; Extended: original end date extended; Completed: placement concluded as planned; Cancelled: arrangement cancelled before start; Terminated Early: placement ended before scheduled end date. [ENUM-REF-CANDIDATE: proposed|approved|active|extended|completed|cancelled|terminated_early — promote to reference product]' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondmentType rdf:type rdf:Property ;
    rdfs:label 'Secondment Type' ;
    rdfs:comment 'Classification of the secondment arrangement indicating the nature of the placement. Client secondment places the timekeeper at a client organisation; inter-office moves the timekeeper between firm offices; international rotation supports cross-border staffing; pro bono places the timekeeper with a non-profit or legal aid organisation; government secondment places the timekeeper with a regulatory or government body; judicial clerkship places the timekeeper with a court or tribunal. [ENUM-REF-CANDIDATE: client_secondment|inter_office|international_rotation|pro_bono|government_secondment|judicial_clerkship — promote to reference product]' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The date on which the work permit, visa, or immigration authorisation for the secondment expires. Used to trigger renewal workflows and ensure continuous legal right to work compliance.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitReference rdf:type rdf:Property ;
    rdfs:label 'Work Permit Reference' ;
    rdfs:comment 'Government-issued reference number for the work permit, visa, or immigration authorisation obtained for the secondee to work in the host jurisdiction. Classified as restricted PII as it is a government-issued personal identifier.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required' ;
    rdfs:comment 'Indicates whether the secondee requires a work permit, visa, or immigration authorisation to perform the secondment in the host country. Relevant for international rotation and cross-border placements.' ;
    rdfs:domain ind:Secondment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryRecordId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each disciplinary record within the firm. Primary key for the disciplinary_record data product in the workforce domain.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disciplinedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Disciplined Timekeeper Id' ;
    rdfs:comment 'FK to workforce.timekeeper.timekeeper_id — Disciplinary records are about a specific timekeeper. Critical for HR management and regulatory reporting.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryDisciplinaryTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or staff member) who is the subject of this disciplinary record. Links to the workforce.timekeeper product.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryDisciplinaryHrCaseOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Hr Case Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the HR business partner or case manager who owns and administers this disciplinary record within the HR function. Distinct from the investigating officer. Links to the workforce.timekeeper product.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the formal appeal process if an appeal was filed. Upheld indicates original outcome overturned; partially_upheld indicates outcome modified; dismissed indicates original outcome confirmed; pending indicates appeal in progress. Null if no appeal was filed.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'The date on which the appeal was formally resolved and the final outcome confirmed. Null if no appeal was filed or appeal is still pending.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barReferralBody rdf:type rdf:Property ;
    rdfs:label 'Bar Referral Body' ;
    rdfs:comment 'Name of the bar association, regulatory authority, or professional body to which the matter was referred (e.g., State Bar of California, SRA, Law Society of England and Wales). Supports multi-jurisdiction tracking.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barReferralDate rdf:type rdf:Property ;
    rdfs:label 'Bar Referral Date' ;
    rdfs:comment 'The date on which the matter was formally referred to the bar association or regulatory body. Null if is_bar_referral is false or referral has not yet been made.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'Granular sub-classification of the incident within its type, such as billing irregularity, client confidentiality breach, conflict of interest, sexual harassment, substance abuse, or absenteeism. Supports detailed analytics and regulatory reporting. [ENUM-REF-CANDIDATE: billing_irregularity|confidentiality_breach|conflict_of_interest|harassment|substance_abuse|absenteeism|misrepresentation|data_breach — promote to reference product]' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the alleged incident, including facts, circumstances, and any relevant context. This field is subject to Legal Professional Privilege (LPP) and is restricted to HR and firm management access.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'High-level classification of the disciplinary incident. Conduct covers behavioural matters; performance covers work quality/output failures; ethics covers breaches of professional duty; regulatory covers violations of bar or regulatory rules; financial covers billing fraud or misappropriation; harassment covers workplace harassment or discrimination. [ENUM-REF-CANDIDATE: conduct|performance|ethics|regulatory|financial|harassment — promote to reference product]' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'The date on which the internal investigation was formally concluded and findings were documented. Null if investigation is still open.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle state of the disciplinary investigation. Pending indicates not yet commenced; open indicates active investigation; under_review indicates findings being assessed; concluded indicates investigation complete pending outcome; closed indicates fully resolved; appealed indicates outcome under appeal.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAppealFiled rdf:type rdf:Property ;
    rdfs:label 'Is Appeal Filed' ;
    rdfs:comment 'Indicates whether the subject timekeeper has filed a formal appeal against the disciplinary outcome. True triggers appeal tracking workflow and suspends record finalisation.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBarReferral rdf:type rdf:Property ;
    rdfs:label 'Is Bar Referral' ;
    rdfs:comment 'Indicates whether this disciplinary matter has been or is required to be referred to the relevant state bar association, Law Society, or SRA for professional conduct review. True triggers mandatory regulatory notification workflow.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaidSuspension rdf:type rdf:Property ;
    rdfs:label 'Is Paid Suspension' ;
    rdfs:comment 'Indicates whether a suspension was on full pay (true) or unpaid (false). Relevant for payroll processing and employment law compliance during the suspension period. Null if outcome is not suspension.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPiiInvolved rdf:type rdf:Property ;
    rdfs:label 'Is Pii Involved' ;
    rdfs:comment 'Indicates whether the incident involved a breach or mishandling of Personally Identifiable Information (PII) or client data, triggering GDPR, CCPA, or DPA notification obligations.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryNotification rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Notification' ;
    rdfs:comment 'Indicates whether a regulatory notification obligation has been triggered by this disciplinary matter (e.g., GDPR data breach notification to DPA, AML/KYC notification to FATF-aligned authority, or SRA mandatory reporting). Distinct from bar referral.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for this disciplinary record, used in HR correspondence, investigation files, and regulatory notifications. Format: DR-YYYY-NNNNN.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionExpiry rdf:type rdf:Property ;
    rdfs:label 'Record Retention Expiry' ;
    rdfs:comment 'The date after which this disciplinary record may be purged or anonymised in accordance with the firms data retention policy and applicable employment law. Derived from outcome date plus jurisdiction-specific retention period but stored as a business date for operational use.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBodyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notified' ;
    rdfs:comment 'Name of the regulatory authority notified (e.g., Information Commissioners Office, Financial Action Task Force, SRA, relevant DPA). Supports audit trail for multi-regulatory compliance obligations.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedRecordReference rdf:type rdf:Property ;
    rdfs:label 'Related Record Reference' ;
    rdfs:comment 'Reference to a prior or related disciplinary record for the same timekeeper, enabling tracking of repeat conduct patterns and progressive discipline history. Null if this is a standalone first incident.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Description of the specific remediation actions required as part of the disciplinary outcome, such as mandatory ethics CLE hours, supervised practice period, or performance improvement plan milestones.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Indicates whether the disciplinary outcome includes a mandatory remediation action such as additional Continuing Professional Development (CPD/CLE), ethics training, supervision, or a performance improvement plan.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the incident was formally reported to HR or firm management, which may differ from the incident date. Used to track reporting timeliness obligations under SRA and ABA rules.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspension sanction ended and the timekeeper was reinstated to duties. Null if outcome is not suspension or suspension is ongoing.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which a suspension sanction commenced, if the outcome was suspension. Null if outcome is not suspension. Used to track suspension duration and manage matter reassignment.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses formally interviewed or identified during the disciplinary investigation. Supports investigation completeness assessment and audit trail.' ;
    rdfs:domain ind:DisciplinaryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diversityRecordId rdf:type rdf:Property ;
    rdfs:label 'Diversity Record Id' ;
    rdfs:comment 'Unique identifier for the diversity record. Primary key.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDiversityTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Diversity Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney, paralegal, or staff member) to whom this diversity record belongs.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:priorDiversityRecordId rdf:type rdf:Property ;
    rdfs:label 'Prior Diversity Record Id' ;
    rdfs:comment 'Self-referencing FK on diversity_record (prior_diversity_record_id)' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiversityRecord .

ind:accessRestrictedToRole rdf:type rdf:Property ;
    rdfs:label 'Access Restricted To Role' ;
    rdfs:comment 'Role-based access control designation specifying which roles (e.g., HR Director, DEI Officer, Chief People Officer) are authorized to view this diversity record.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymizationFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymization Flag' ;
    rdfs:comment 'Indicates whether this diversity record should be anonymized for aggregate reporting purposes to protect timekeeper identity in small cohorts.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caregiverStatus rdf:type rdf:Property ;
    rdfs:label 'Caregiver Status' ;
    rdfs:comment 'Self-reported caregiver status indicating whether the timekeeper has primary or significant caregiving responsibilities (e.g., for children, elderly parents, or disabled family members).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientDiversitySurveyDate rdf:type rdf:Property ;
    rdfs:label 'Client Diversity Survey Date' ;
    rdfs:comment 'Date on which the timekeepers diversity data was submitted to a client diversity survey or reporting platform.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientDiversitySurveyResponse rdf:type rdf:Property ;
    rdfs:label 'Client Diversity Survey Response' ;
    rdfs:comment 'Status of the timekeepers response to client-driven diversity surveys (e.g., ABA Model Diversity Survey, client-specific RFP diversity questionnaires).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source from which the diversity data was collected (e.g., voluntary self-identification workflow, HR system import, recruitment intake, third-party diversity survey).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityDescription rdf:type rdf:Property ;
    rdfs:label 'Disability Description' ;
    rdfs:comment 'Optional free-text description of the nature of the disability, provided voluntarily by the timekeeper for accommodation and support purposes. Highly sensitive Protected Health Information (PHI).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Self-reported disability status indicating whether the timekeeper has a disability as defined by applicable law (e.g., ADA, Equality Act 2010).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureConsentDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Consent Date' ;
    rdfs:comment 'Date on which the timekeeper provided consent for disclosure of their diversity data.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Disclosure Consent Flag' ;
    rdfs:comment 'Indicates whether the timekeeper has consented to the disclosure of their diversity data to clients, regulatory bodies, or third-party diversity surveys.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity or racial background of the timekeeper as collected for DEI reporting and client diversity survey requirements. [ENUM-REF-CANDIDATE: white|black_african_caribbean|asian|hispanic_latino|native_american|pacific_islander|mixed_multiple|prefer_not_to_say|other — promote to reference product]' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstGenerationProfessional rdf:type rdf:Property ;
    rdfs:label 'First Generation Professional' ;
    rdfs:comment 'Indicates whether the timekeeper is the first in their family to enter a professional occupation, used for social mobility and DEI tracking.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-reported gender identity of the timekeeper as collected for diversity, equity, and inclusion (DEI) reporting. [ENUM-REF-CANDIDATE: male|female|non_binary|transgender|prefer_not_to_say|prefer_to_self_describe|other — promote to reference product]' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mansfieldRuleCategory rdf:type rdf:Property ;
    rdfs:label 'Mansfield Rule Category' ;
    rdfs:comment 'The specific Mansfield Rule diversity category under which the timekeeper qualifies (e.g., women, racial/ethnic minority, LGBTQ+, lawyer with disability).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mansfieldRuleEligible rdf:type rdf:Property ;
    rdfs:label 'Mansfield Rule Eligible' ;
    rdfs:comment 'Indicates whether the timekeeper is eligible to be counted in the Mansfield Rule candidate pool for leadership and governance roles based on their diversity characteristics.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the diversity record indicating whether it is active, inactive, pending review, or archived.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:religionOrBelief rdf:type rdf:Property ;
    rdfs:label 'Religion Or Belief' ;
    rdfs:comment 'Self-reported religion or belief system of the timekeeper, collected for DEI reporting and to support religious accommodation requests. [ENUM-REF-CANDIDATE: christian|muslim|jewish|hindu|buddhist|sikh|no_religion|prefer_not_to_say|other — promote to reference product]' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfIdentificationDate rdf:type rdf:Property ;
    rdfs:label 'Self Identification Date' ;
    rdfs:comment 'Date on which the timekeeper voluntarily self-identified their diversity characteristics through the firms diversity data collection workflow.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sexualOrientation rdf:type rdf:Property ;
    rdfs:label 'Sexual Orientation' ;
    rdfs:comment 'Self-reported sexual orientation of the timekeeper as collected for DEI reporting and Mansfield Rule certification. [ENUM-REF-CANDIDATE: heterosexual|gay|lesbian|bisexual|pansexual|asexual|prefer_not_to_say|prefer_to_self_describe|other — promote to reference product]' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socioeconomicBackground rdf:type rdf:Property ;
    rdfs:label 'Socioeconomic Background' ;
    rdfs:comment 'Self-reported socioeconomic background of the timekeeper, typically captured as parental occupation or educational background, used for social mobility tracking and DEI initiatives. [ENUM-REF-CANDIDATE: professional|intermediate|working_class|unemployed|prefer_not_to_say|other — promote to reference product]' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sraDiversityReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Sra Diversity Reporting Flag' ;
    rdfs:comment 'Indicates whether this diversity record is included in the firms annual SRA diversity data collection submission (applicable to UK-regulated firms).' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Self-reported veteran or military service status, collected for diversity reporting and affirmative action compliance in applicable jurisdictions.' ;
    rdfs:domain ind:DiversityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpTeamAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Rfp Team Assignment Id' ;
    rdfs:comment 'Unique identifier for this RFP team assignment record. Primary key.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bioIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Bio Included Flag' ;
    rdfs:comment 'Indicates whether this timekeepers professional biography was included in the RFP response materials. Used to track which team members were presented to the client.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictClearedDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Cleared Date' ;
    rdfs:comment 'The date on which this timekeeper received conflict clearance for this RFP submission.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionHours rdf:type rdf:Property ;
    rdfs:label 'Contribution Hours' ;
    rdfs:comment 'The number of hours this timekeeper contributed to the RFP response preparation. Used for cost recovery analysis, capacity planning, and pitch team efficiency metrics.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitchTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Pitch Team Members' ;
    rdfs:comment 'Comma-separated list or description of the pitch team members assigned to work on the RFP response, including partners, associates, and business development staff. [Moved from rfp_submission: This attribute currently stores a comma-separated list or description of pitch team members in the rfp_submission product. This is a denormalized representation of the many-to-many relationship. The individual team member assignments should be modeled as separate records in the rfp_team_assignment association, each with its own role, hours, and rate attributes. The pitch_team_members attribute becomes redundant once the association product exists and should be removed to eliminate data duplication and maintain referential integrity.]' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationSectionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Presentation Section Responsibility' ;
    rdfs:comment 'The specific section(s) of the RFP response or pitch presentation for which this timekeeper has primary authorship or delivery responsibility (e.g., Executive Summary, Technical Approach, Pricing Schedule, Team Qualifications).' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateQuoted rdf:type rdf:Property ;
    rdfs:label 'Rate Quoted' ;
    rdfs:comment 'The hourly billing rate quoted for this specific timekeeper in this specific RFP response. May differ from their standard rack rate due to client negotiations, competitive positioning, or blended rate strategies. Critical for pricing analysis and margin calculation.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateQuotedCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Quoted Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the quoted rate. Required for multi-jurisdiction RFPs and cross-border engagements.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamRole rdf:type rdf:Property ;
    rdfs:label 'Team Role' ;
    rdfs:comment 'The specific role this timekeeper plays in the RFP response effort. Drives responsibility assignment, effort allocation, and performance attribution in win/loss analysis.' ;
    rdfs:domain ind:RfpTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userId rdf:type rdf:Property ;
    rdfs:label 'User Id' ;
    rdfs:comment 'Primary key for user' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryManagerUserId rdf:type rdf:Property ;
    rdfs:label 'Primary Manager User Id' ;
    rdfs:comment 'Reference to the users direct manager or supervisor within the organizational hierarchy.' ;
    rdfs:domain ind:User ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:tertiaryCreatedByUserId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Created By User Id' ;
    rdfs:comment 'Self-referencing FK on user (created_by_user_id)' ;
    rdfs:domain ind:User ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:cleCreditsCompletedCurrentYear rdf:type rdf:Property ;
    rdfs:label 'Cle Credits Completed Current Year' ;
    rdfs:comment 'CLE or CPD credit hours completed by the user in the current calendar or reporting year. Used for compliance tracking.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleCreditsRequiredAnnual rdf:type rdf:Property ;
    rdfs:label 'Cle Credits Required Annual' ;
    rdfs:comment 'Annual continuing legal education (CLE) or continuing professional development (CPD) credit hours required for the user to maintain professional standing. Zero for non-attorneys.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'Full-time equivalent percentage representing the users work commitment. 1.00 for full-time, 0.50 for half-time, etc. Used for capacity planning and resource allocation.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the user. Used for urgent communication and mobile access.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBarJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primary Bar Jurisdiction' ;
    rdfs:comment 'Primary jurisdiction or state where the user holds bar admission. Nullable for non-attorneys.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userType rdf:type rdf:Property ;
    rdfs:label 'User Type' ;
    rdfs:comment 'Classification of the user role within the legal organization. Distinguishes between attorneys, paralegals, administrative staff, partners, of counsel, and contract workers.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique login username for system access and authentication.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAddressCity rdf:type rdf:Property ;
    rdfs:label 'Work Address City' ;
    rdfs:comment 'City of the users primary work address.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Address Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the users primary work address (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Work Address Line1' ;
    rdfs:comment 'First line of the users primary work address (street address).' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Work Address Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the users primary work address.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAddressStateProvince rdf:type rdf:Property ;
    rdfs:label 'Work Address State Province' ;
    rdfs:comment 'State or province of the users primary work address.' ;
    rdfs:domain ind:User ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitingPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Recruiting Partner Timekeeper Id' ;
    rdfs:comment 'Foreign key linking to workforce.timekeeper. Business justification: Lateral candidates are managed by a recruiting partner who is responsible for the candidate relationship. The lateral_candidate table currently has recruiting_partner_name (STRING) which should be nor' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:referredByLateralCandidateId rdf:type rdf:Property ;
    rdfs:label 'Referred By Lateral Candidate Id' ;
    rdfs:comment 'Self-referencing FK on lateral_candidate (referred_by_lateral_candidate_id)' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LateralCandidate .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the background verification process for the lateral candidate.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barAdmissionJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Bar Admission Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdictions where the candidate is admitted to practice law (e.g., New York, California, District of Columbia).' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNumber rdf:type rdf:Property ;
    rdfs:label 'Candidate Number' ;
    rdfs:comment 'Business-facing unique identifier for the lateral candidate, typically formatted as LC-XXXXXXXX.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current status of the lateral candidate in the recruitment lifecycle.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateType rdf:type rdf:Property ;
    rdfs:label 'Candidate Type' ;
    rdfs:comment 'Classification of the lateral candidate by role type being recruited for.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCompensationUsd rdf:type rdf:Property ;
    rdfs:label 'Current Compensation Usd' ;
    rdfs:comment 'Current total annual compensation of the candidate in US dollars, including base salary and bonuses.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFirmName rdf:type rdf:Property ;
    rdfs:label 'Current Firm Name' ;
    rdfs:comment 'Name of the law firm or legal organization where the candidate is currently employed.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTitle rdf:type rdf:Property ;
    rdfs:label 'Current Title' ;
    rdfs:comment 'Current job title or position held by the lateral candidate at their present firm.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Anticipated date when the lateral candidate will begin employment with the firm.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstContactDate rdf:type rdf:Property ;
    rdfs:label 'First Contact Date' ;
    rdfs:comment 'Date when the firm first made contact with the lateral candidate.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Date' ;
    rdfs:comment 'Date when the lateral candidate accepted the offer.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portableBookValueUsd rdf:type rdf:Property ;
    rdfs:label 'Portable Book Value Usd' ;
    rdfs:comment 'Estimated annual revenue in US dollars that the candidate is expected to bring from existing client relationships.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBarAdmissionYear rdf:type rdf:Property ;
    rdfs:label 'Primary Bar Admission Year' ;
    rdfs:comment 'Year the candidate was first admitted to practice law in their primary jurisdiction.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedCompensationUsd rdf:type rdf:Property ;
    rdfs:label 'Proposed Compensation Usd' ;
    rdfs:comment 'Proposed total annual compensation offer for the lateral candidate in US dollars.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recruiterName rdf:type rdf:Property ;
    rdfs:label 'Recruiter Name' ;
    rdfs:comment 'Name of the internal or external recruiter managing the lateral candidate relationship.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Name of the person or organization that referred the lateral candidate, if applicable.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPracticeArea rdf:type rdf:Property ;
    rdfs:label 'Secondary Practice Area' ;
    rdfs:comment 'Secondary or complementary legal practice area of the lateral candidate.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingBonusUsd rdf:type rdf:Property ;
    rdfs:label 'Signing Bonus Usd' ;
    rdfs:comment 'One-time signing bonus offered to the lateral candidate in US dollars.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:undergraduateInstitution rdf:type rdf:Property ;
    rdfs:label 'Undergraduate Institution' ;
    rdfs:comment 'Name of the college or university where the candidate completed their undergraduate degree.' ;
    rdfs:domain ind:LateralCandidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteLearningItemId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Learning Item Id' ;
    rdfs:comment 'Self-referencing FK on learning_item (prerequisite_learning_item_id)' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningItem .

ind:learningItemCategory rdf:type rdf:Property ;
    rdfs:label 'Learning Item Category' ;
    rdfs:comment 'The subject matter category or domain of the learning item.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAwardedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded Flag' ;
    rdfs:comment 'Indicates whether successful completion results in a formal certification or credential.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'The name of the certification or credential awarded upon successful completion.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningItemCode rdf:type rdf:Property ;
    rdfs:label 'Learning Item Code' ;
    rdfs:comment 'The unique business identifier or catalog code for the learning item used for external reference and registration.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'The target competency or skill level for participants of this learning item.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this learning item fulfills a regulatory or professional compliance requirement.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:learningItemDescription rdf:type rdf:Property ;
    rdfs:label 'Learning Item Description' ;
    rdfs:comment 'Detailed description of the learning item content, objectives, and outcomes.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacity rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity' ;
    rdfs:comment 'The maximum number of participants that can enroll in a single offering of this learning item.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'The minimum score percentage required to pass the assessment and receive credit.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteRequirements rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Requirements' ;
    rdfs:comment 'Description of any prerequisite knowledge, courses, or qualifications required before enrolling in this learning item.' ;
    rdfs:domain ind:LearningItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the learning provider by organizational relationship.' ;
    rdfs:domain ind:LearningItem ;
