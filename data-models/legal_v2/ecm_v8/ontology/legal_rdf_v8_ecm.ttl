    rdfs:range ind:User .

ind:primarySupersedingExecutionWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseding Execution Workflow Id' ;
    rdfs:comment 'Reference to the newer workflow version that supersedes this one, if applicable.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExecutionWorkflow .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether a complete audit trail of all execution activities must be maintained for compliance.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or department that primarily uses this execution workflow.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyRequired rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Required' ;
    rdfs:comment 'Indicates whether chain of custody documentation is required for evidentiary purposes.' ;
    rdfs:domain ind:ExecutionWorkflow ;
