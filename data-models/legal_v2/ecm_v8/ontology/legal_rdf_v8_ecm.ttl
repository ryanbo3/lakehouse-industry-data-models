ind:isDefaultWorkflow rdf:type rdf:Property ;
    rdfs:label 'Is Default Workflow' ;
    rdfs:comment 'Indicates whether this is the default workflow for its document type and jurisdiction.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Timestamp when this workflow was last used for a document execution.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumSignatories rdf:type rdf:Property ;
    rdfs:label 'Maximum Signatories' ;
    rdfs:comment 'Maximum number of signatories allowed in this execution workflow.' ;
