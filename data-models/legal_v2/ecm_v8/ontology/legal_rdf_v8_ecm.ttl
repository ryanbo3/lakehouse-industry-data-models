ind:originatingAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Originating Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney who originated or initiated the workspace, typically the relationship partner or business developer.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:ownerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Owner Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney who has primary responsibility and oversight for this workspace and its contents.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:parentWorkspaceId rdf:type rdf:Property ;
    rdfs:label 'Parent Workspace Id' ;
    rdfs:comment 'Self-referencing FK on workspace (parent_workspace_id)' ;
