    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSessionStatus rdf:type rdf:Property ;
    rdfs:label 'Review Session Status' ;
    rdfs:comment 'Current lifecycle status of the review session indicating its operational state.' ;
