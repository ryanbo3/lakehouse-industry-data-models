# RDFS Schema for Business: Legal

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/legal#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Legal ---
ind:Legal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Legal' ;
    rdfs:comment 'Legal is a professional services industry providing advisory and representation services across corporate transactions, dispute resolution, intellectual property, employment law, and regulatory compliance for organizations and governments.' .

# --- Domain Classes ---
ind:Client rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Client' ;
    rdfs:comment 'Single source of truth for all client entities served by the firm including corporate clients, government agencies, individual clients, and prospective clients. Manages client profiles, organizational hierarchies, contact information, client segments, relationship history, KYC documentation, and client classification for conflict checking and engagement purposes. Supports both B2B and B2C client types across all practice areas.' .

ind:Matter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Matter' ;
    rdfs:comment 'Core operational domain governing the lifecycle of every legal matter and case from inception to closure. Serves as the central hub linking clients, timekeepers, documents, and billing to a single matter record. Supports matter management, case administration, litigation, corporate transaction advisory, and LPM workflows across all practice groups.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Document' ;
    rdfs:comment 'Manages the full lifecycle of all legal documents including drafting, versioning, review, execution, and records retention. Encompasses DMS metadata from iManage Work and NetDocuments, eDiscovery ESI collections via Relativity, TAR/CAL review workflows, OCR/NLP processing outputs, privilege designations, and LPP classification. Authoritative source for document provenance and chain of custody.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Single source of truth for all revenue cycle operations including timekeeping, WIP management, prebilling, invoice generation, payment processing, accounts receivable, collections, and write-offs. Supports multiple fee arrangements including hourly, contingency, flat fee, AFA, and blended rates. Integrates LEDES and UTBMS standards for electronic billing and task-based management. Covers PPP, PEP, RPE, and ARPU financial KPIs.' .

ind:Conflict rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Conflict' ;
    rdfs:comment 'Manages new business intake, conflict-of-interest screening, ethical wall configuration, and clearance workflows required before any matter may be opened. Integrates Intapp Conflicts as the system of record. Enforces ABA Rule 1.7/1.9/1.10 conflict rules, lateral hire screening, and relationship mapping to protect LPP and firm ethics obligations.' .

ind:Ip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Ip' ;
    rdfs:comment 'Manages the intellectual property portfolio lifecycle including patent prosecution (PCT, PPH), trademark registration, copyright registration, trade secrets, licensing, FRAND obligations, and IP docketing deadlines. Serves as SSOT for all IP assets, annuity payments, portfolio valuation, and IP ownership records across all jurisdictions.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Governs the full Contract Lifecycle Management (CLM) pipeline for both client-facing engagement letters (LOE, POA, SPA, NDA) and firm vendor/supplier agreements. Owns contract templates, obligation tracking, milestone alerts, renewal management, and executed agreement metadata. Distinct from the matter domain — contract owns the agreement artifact; matter owns the work performed under it.' .

ind:Trust rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Trust' ;
    rdfs:comment 'Dedicated domain for client trust account management in strict compliance with IOLTA rules and jurisdiction-specific trust accounting regulations. Owns trust ledger entries, three-way reconciliations, client fund segregation records, disbursement authorizations, and regulatory trust account reporting. Operationally distinct from the billing domain — trust owns fiduciary client funds; billing owns firm revenue.' .

ind:Knowledge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Knowledge' ;
    rdfs:comment 'Curates and governs the firms institutional knowledge assets including precedent documents, practice notes, legal research memoranda, standard clause libraries, form libraries, checklists, and expertise directories. Integrates Thomson Reuters Practical Law and LexisNexis as primary knowledge platforms. Supports knowledge capture, taxonomy management, and NLP-driven retrieval.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Owns regulatory compliance obligations, control frameworks, and reporting requirements applicable to the firm and its clients. Covers AML/KYC program management, GDPR/CCPA/DPA data privacy controls, SOX compliance tracking, SRA regulatory returns, DPO activities, FATF obligations, and professional indemnity insurance. Distinct from conflict domain — compliance owns firm-level regulatory posture; conflict owns matter-level ethics screening.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'Manages all timekeeper, attorney, paralegal, and staff human capital data including attorney bar admissions, CPD/CLE tracking, performance management, compensation structures (FTE, equity partner tiers, PPP, PEP, RPE), recruitment, succession planning, and resource allocation across matters. SAP SuccessFactors is the system of record.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Service' ;
    rdfs:comment 'Catalog of legal service offerings such as M&A advisory, litigation, IP counsel, regulatory compliance counseling, employment law, and advisory packages. Manages service definitions, practice area taxonomy, pricing models, SLA terms, and service-to-matter mappings enabling business development and RFP responses.' .

ind:Intake rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Intake' ;
    rdfs:comment 'Manages the end-to-end new business intake and client onboarding pipeline from RFP receipt through LOE execution. Owns prospect qualification, pitch and proposal tracking, engagement scope definition, fee arrangement negotiation (AFA), and handoff to the matter domain upon matter opening. Bridges the CRM pipeline in Microsoft Dynamics 365 with operational matter creation in Elite 3E.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Owns enterprise and matter-level risk identification, assessment, and mitigation records for the firm. Covers professional indemnity exposure, data breach incident management (PII/GDPR), cybersecurity risk (ISO 27001), sanctions screening, and reputational risk flags. Provides the risk register that feeds compliance, conflict, and workforce domains without duplicating their operational data.' .

ind:Court rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Legal ;
    rdfs:label 'Court' ;
    rdfs:comment 'Manages court and tribunal information including court jurisdictions, judges, court rules, filing requirements, hearing schedules, docket management, and electronic case filing (ECF) integration. Supports litigation practice with court calendar management, appearance tracking, ADR proceedings, arbitration (ICC, LCIA), and PACER integration for federal court access.' .

# --- Data Product Classes (Tables) ---
ind:ExpertiseDirectory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Expertise Directory' ;
    rdfs:comment 'Directory of attorney and professional staff expertise profiles enabling knowledge routing, matter staffing recommendations, and expert identification. Each record captures timekeeper reference, practice area specializations, jurisdiction admissions, industry sector expertise, language capabilities, CPD/CLE completion records, publication history, and NLP-derived expertise tags extracted from authored knowledge assets. Complements the workforce domain attorney master data by adding knowledge-specific expertise dimensions used for intelligent work allocation.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master registry of all regulatory obligations applicable to the firm across all jurisdictions of operation. Each obligation captures the governing body, jurisdiction, regulatory framework, obligation type (periodic filing, ongoing conduct, event-triggered), effective date, review cycle, current compliance status, and responsible officer. Serves as the authoritative catalog against which controls are designed, policies are written, training is mandated, and returns are filed. The single source of truth for answering what must we comply with?' .

ind:ControlFramework rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Control Framework' ;
    rdfs:comment 'Master catalog of compliance control frameworks adopted by the firm (e.g., ISO 27001, FATF 40 Recommendations, SRA Code of Conduct, GDPR Article 32 measures, SOX COSO). Each record captures framework name, version, issuing body, adoption date, scope of applicability, and mapping to internal control domains. Provides the structural backbone against which individual controls are designed, tested, and audited.' .

ind:ComplianceControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Control' ;
    rdfs:comment 'Individual internal controls and their testing evidence, designed to satisfy regulatory obligations within a given framework. Control attributes capture identifier, objective, type (preventive, detective, corrective), owner, frequency, testing methodology, and UTBMS alignment. Testing attributes capture test date, tester, methodology (walkthrough, sample testing, re-performance), sample size, exceptions, test conclusion (effective/ineffective), and remediation flags. Serves as the SSOT for the firms control inventory and assurance evidence, supporting SOX, ISO 27001, and SRA compliance programmes.' .

ind:AmlKycProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Kyc Program' ;
    rdfs:comment 'Master record for the firms AML/KYC programme including enterprise-wide and matter-type-level risk assessments, as required by FATF obligations and jurisdiction-specific AML legislation. Programme attributes capture MLRO designation, programme scope, risk appetite, regulatory approval status, and applicable jurisdictions. Risk assessment attributes capture assessment date, assessor, risk categories (client, geographic, product/service, delivery channel), inherent and residual risk ratings, methodology, and findings. Provides the complete firm-level AML governance artifact distinct from individual client KYC checks owned by conflict/intake.' .

ind:AmlRiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Risk Assessment' ;
    rdfs:comment 'Firm-level and matter-type-level AML risk assessments conducted under FATF and jurisdiction-specific AML regulations. Captures assessment date, assessor, risk category (client, geographic, product/service, delivery channel), inherent risk rating, residual risk rating after controls, assessment methodology, findings narrative, and next scheduled review. Supports the firms enterprise-wide AML risk posture distinct from individual client due diligence.' .

ind:SarFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sar Filing' ;
    rdfs:comment 'Suspicious Activity Report (SAR) filings submitted to the relevant financial intelligence unit (e.g., NCA in the UK, FinCEN in the US) by the firms MLRO. Captures SAR reference number, filing date, subject details (anonymised), transaction or matter reference, suspicion grounds, consent request status, defence against money laundering (DAML) consent outcome, and filing jurisdiction. Critical for FATF and AML regulatory compliance audit trails.' .

ind:DataPrivacyRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Privacy Register' ;
    rdfs:comment 'Unified data privacy compliance register combining the Record of Processing Activities (RoPA) under GDPR Article 30 with Data Protection Impact Assessments (DPIAs) under Article 35. RoPA entries document processing activities, legal bases, data categories, subjects, retention periods, processors, and transfer mechanisms. DPIA entries document assessment triggers, necessity analysis, risk identification, mitigation measures, DPO consultation outcomes, and supervisory authority consultation requirements. Managed by the DPO function as the authoritative privacy compliance artifact.' .

ind:Dpia rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Dpia' ;
    rdfs:comment 'Data Protection Impact Assessment (DPIA) records conducted for high-risk processing activities as required under GDPR Article 35. Captures assessment trigger, processing description, necessity and proportionality assessment, risk identification, risk mitigation measures, DPO consultation outcome, supervisory authority consultation requirement flag, approval status, and review schedule. Owned by the DPO function within the compliance domain.' .

ind:DataSubjectRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Subject Request' ;
    rdfs:comment 'Tracks individual data subject rights requests received and processed by the firm under GDPR, CCPA, and DPA, including Subject Access Requests (SARs), right to erasure, right to rectification, data portability, and objection requests. Captures request type, receipt date, identity verification status, response due date (statutory deadline), response date, outcome, exemptions applied (e.g., LPP), and escalation history. Managed by the DPO function.' .

ind:PrivacyBreach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Privacy Breach' ;
    rdfs:comment 'Records of personal data breaches as defined under GDPR Article 4(12), including accidental or unlawful destruction, loss, alteration, or unauthorised disclosure of PII. Captures incident date, discovery date, breach type, affected data categories, number of data subjects impacted, risk assessment to data subjects, ICO/supervisory authority notification requirement flag, notification date, remediation actions, and post-incident review outcome. Owned by the DPO/compliance function.' .

ind:RegulatoryReturn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Return' ;
    rdfs:comment 'Regulatory returns, periodic filings, and breach notifications submitted to governing bodies such as the SRA, Legal Services Board, ABA, state bar associations, and financial regulators. Covers routine returns (SRA Annual Report, COFA certificate, accountants report) and event-triggered filings (regulatory breach notifications, remediation plans). Captures return/filing type, reporting period, submission details, regulatory body, preparer, reviewer, approval status, breach severity and root cause where applicable, and any regulatory findings or queries raised. Serves as the SSOT for all firm-level regulatory submissions and compliance incident reporting.' .

ind:ComplianceControlTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Control Test' ;
    rdfs:comment 'Records of individual control testing activities performed against compliance controls, including design effectiveness testing and operating effectiveness testing. Captures test date, tester, test methodology (walkthrough, sample testing, re-performance), sample size, exceptions identified, exception rate, overall test conclusion (effective/ineffective), remediation required flag, and linkage to the parent compliance control. Supports SOX, ISO 27001, and SRA compliance assurance programmes.' .

ind:RegulatoryBreach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Breach' ;
    rdfs:comment 'Records of identified compliance breaches or regulatory violations at the firm level, distinct from data breaches (which are privacy-specific). Captures breach type (AML, SRA conduct, SOX, GDPR, professional indemnity), discovery date, root cause, severity rating, regulatory notification obligation flag, notification date, remediation plan, remediation owner, target resolution date, and actual resolution date. Feeds into the firms regulatory risk posture and professional indemnity insurance disclosures.' .

ind:IndemnityPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Indemnity Policy' ;
    rdfs:comment 'Professional indemnity insurance records covering both policy master data and claims lifecycle, as required by SRA, Law Society, and other bar regulators. Policy attributes include insurer, policy number, coverage period, limits, excess, retroactive date, qualifying insurer status, and premium. Claims attributes include notification date, claimant details, matter reference, alleged negligence, exposure estimates, insurer acknowledgement, reserve and settlement amounts, and closure status. Provides the unified PI compliance artifact for regulatory reporting and premium renewal actuarial analysis.' .

ind:IndemnityClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Indemnity Claim' ;
    rdfs:comment 'Professional indemnity insurance claims made against or notified under the firms indemnity policy. Captures claim reference, notification date, claimant details, matter reference, alleged negligence description, estimated exposure, insurer acknowledgement date, coverage confirmation status, reserve amount, settlement amount, and claim closure date. Supports SRA compliance obligations and actuarial reporting for premium renewal.' .

ind:TrainingProgramme rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Training Programme' ;
    rdfs:comment 'Compliance training programme records covering mandatory regulatory training requirements such as AML awareness, GDPR/data privacy, anti-bribery and corruption (ABC), sanctions screening, and CPD/CLE compliance obligations. Captures training programme name, regulatory requirement it satisfies, delivery method, frequency, target audience (by role/practice group), pass mark, and version. Distinct from individual completion records tracked in workforce domain — this entity owns the programme definition.' .

ind:SanctionsCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sanctions Check' ;
    rdfs:comment 'Records of sanctions list screening checks performed against clients, counterparties, beneficial owners, and related parties against OFAC SDN, HM Treasury, EU Consolidated, and UN sanctions lists. Captures screening date, subject name, subject type, list screened, match type (exact, fuzzy, alias), match score, disposition (cleared, escalated, blocked), reviewing officer, and disposition rationale. Supports FATF obligations and AML programme requirements. Firm-level screening infrastructure distinct from matter-level conflict checks.' .

ind:RegulatoryChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Change' ;
    rdfs:comment 'Tracks incoming regulatory changes, legislative updates, and new guidance from governing bodies (ABA, SRA, IBA, FATF, ICO, SEC, FCA) that may impact the firms compliance posture. Captures change source, publication date, effective date, impacted regulatory frameworks, impacted practice areas, impact assessment status, required control updates, implementation owner, and implementation deadline. Feeds the regulatory obligation register when new obligations are confirmed.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Master register of the firms internal compliance policies and procedures, including AML policy, data protection policy, anti-bribery policy, sanctions policy, conflicts of interest policy, and information security policy. Captures policy name, policy owner, version, effective date, review cycle, approval authority, regulatory obligations satisfied, and current status (draft, approved, superseded). Provides the policy governance layer above individual controls.' .

ind:AuditEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Engagement' ;
    rdfs:comment 'Records of internal and external compliance audit engagements and their findings, conducted against the firms regulatory obligations and control frameworks. Covers SRA inspections, ISO 27001 surveillance audits, external AML audits, and internal compliance reviews. Each engagement captures audit type, auditor (internal/external), scope, audit period, fieldwork dates, report dates, management responses, overall opinion, and individual findings with severity ratings, root causes, recommended actions, remediation owners, target dates, and closure verification. Serves as the complete audit lifecycle record from planning through finding remediation.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual findings raised during compliance audit engagements, including observations, recommendations, and agreed management actions. Captures finding reference, parent audit engagement, finding category (control gap, policy breach, regulatory non-compliance), severity (critical, high, medium, low), root cause, recommended action, management response, action owner, target remediation date, actual closure date, and verification status. Supports ongoing compliance assurance and regulatory reporting.' .

ind:AuditScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'This association product represents the scoping relationship between audit engagements and regulatory obligations. It captures which specific regulatory obligations are included in the scope of each audit engagement, along with the compliance assessment results, findings, and test outcomes specific to that obligation within that audit. Each record links one audit engagement to one regulatory obligation with attributes that exist only in the context of this specific audit-obligation pairing.. Existence Justification: Audit engagements are explicitly scoped to cover multiple regulatory obligations, and each regulatory obligation is audited repeatedly across multiple audit engagements over time. Audit teams actively manage the scoping process during audit planning, defining which obligations are in-scope for each engagement. The relationship carries significant operational data including compliance assessment results, findings counts, test results, and risk ratings that are specific to each obligation-engagement pairing.' .

ind:PolicyAcknowledgement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy Acknowledgement' ;
    rdfs:comment 'This association product represents the formal acknowledgement event between client_profile and policy. It captures the regulatory requirement for clients to acknowledge and accept specific compliance policies as part of the client onboarding and ongoing compliance management process. Each record links one client to one policy version with the date acknowledged, acceptance status, attestation method, and next renewal date. This is a critical audit trail for regulatory compliance and risk management.. Existence Justification: Legal services firms are required by regulators to obtain and track client acknowledgement of multiple compliance policies (AML, conflicts of interest, data protection, engagement terms, etc.). Each client must acknowledge multiple policies, and each policy must be acknowledged by multiple clients. The business actively manages this relationship through onboarding workflows, renewal cycles, and audit trail maintenance for regulatory examinations.' .

ind:AuditProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Program' ;
    rdfs:comment 'Master reference table for audit_program. Referenced by audit_program_id.' .

ind:Timekeeper rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Timekeeper' ;
    rdfs:comment 'Master record for every fee-earner and staff member who records time or performs billable/non-billable work at the firm. Captures attorney, paralegal, and support staff identity, employment classification (FTE, part-time, contract), bar admission status, practice group, office location, UTBMS timekeeper code, standard billing rate tier, seniority level (associate, senior associate, counsel, partner, equity partner), SAP SuccessFactors employee ID, and extended professional profile attributes including law school, graduation year, practice specializations, languages spoken, partnership track status, PPP/PEP participation flag, pro bono hours target, LPP designation, and professional biography for client-facing materials and directory listings. This is the SSOT for timekeeper identity and professional credentials referenced by billing, matter, conflict, and intake domains.' .

ind:AttorneyProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Attorney Profile' ;
    rdfs:comment 'Extended professional profile for attorneys and solicitors, supplementing the core timekeeper master record with legal-specific credentials and career attributes NOT held on the timekeeper record. Stores law school, graduation year, jurisdictions of admission (summary view — detail in bar_admission), practice specializations, languages spoken, pro bono hours target, LPP designation, partnership track status, PPP/PEP participation flag, and professional biography used in client-facing materials and directory listings. Distinguished from timekeeper by holding career/credential attributes rather than employment/billing identity. Sourced from SAP SuccessFactors and supplemented by bar admission records.' .

ind:BarAdmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Bar Admission' ;
    rdfs:comment 'Tracks each attorneys active and historical bar admissions across all jurisdictions (state bars, federal courts, international bars). Records jurisdiction name, admission date, bar number, admission type (active, inactive, pro hac vice), renewal due date, annual fee status, disciplinary standing, and the governing bar association. Critical for conflict checking, matter staffing eligibility, and regulatory compliance with SRA, ABA, and state bar requirements.' .

ind:CleRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Cle Requirement' ;
    rdfs:comment 'Defines the CPD/CLE compliance requirements applicable to each attorney by jurisdiction and reporting period. Stores jurisdiction, reporting cycle start and end dates, total hours required, ethics hours required, technology CLE hours required, pro bono hours credit allowed, carry-over rules, and compliance deadline. Enables the firm to track each attorneys obligations across multiple jurisdictions simultaneously. Sourced from state bar and SRA regulatory mandates.' .

ind:CleCompletion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Cle Completion' ;
    rdfs:comment 'Transactional record of each CPD/CLE course or activity completed by an attorney. Captures course title, provider, delivery format (in-person, webinar, self-study), completion date, credit hours earned, ethics credit flag, technology credit flag, accreditation status, certificate number, and the reporting period to which the credit applies. Supports compliance reporting to state bars, SRA, and IBA. Sourced from SAP SuccessFactors Learning module.' .

ind:BillingRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'Master rate schedule defining the standard, negotiated, and matter-specific billing rates for each timekeeper by effective date range. Stores rate type (standard, client-negotiated, AFA blended, matter-specific), currency, hourly rate amount, LEDES rate code, rate approval status, and the approving partner. Supports LEDES billing exports and AFA arrangements. This is the SSOT for timekeeper rate data consumed by the billing domain. Sourced from Aderant Expert Rate Management module.' .

ind:PracticeGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Practice Group' ;
    rdfs:comment 'Organizational unit representing a legal practice group or department within the firm (e.g., M&A, Litigation, IP, Employment, Regulatory). Stores practice group name, group code, managing partner, practice area classification (aligned to UTBMS task codes), office or region scope, revenue target, headcount budget, approved FTE count, and active status. Serves as the primary organizational hierarchy for matter staffing, financial reporting by practice, resource allocation, and recruitment planning. Sourced from SAP SuccessFactors organizational structure.' .

ind:MatterAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Matter Assignment' ;
    rdfs:comment 'Association record linking timekeepers to specific matters with defined roles, responsibilities, and time periods. Captures assignment role (lead partner, supervising attorney, associate, paralegal, project manager), assignment start and end dates, budgeted hours, actual hours to date, billing authorization flag, LPM responsibility flag, pro bono matter flag, pro bono hours commitment and delivery tracking, and assignment status. Enables resource utilization tracking, matter staffing analysis, RPE/PPP calculations, and pro bono hours reporting against firm and individual targets. This is the workforce domains authoritative record of who works on what.' .

ind:PerformanceReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Performance Review' ;
    rdfs:comment 'Annual and mid-year performance evaluation records for all timekeepers and staff. Stores review cycle year, review type (annual, mid-year, probationary, promotion), overall rating, billable hours target and achieved, utilization rate target and actual, origination credit, client feedback score, pro bono hours target and delivered, business development hours, leadership and development rating, reviewer identity, review completion date, and narrative comments. Sourced from SAP SuccessFactors Performance Management module. Feeds partnership track, compensation decisions, and utilization variance analysis.' .

ind:CompensationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Compensation Record' ;
    rdfs:comment 'Confidential compensation record for each timekeeper capturing base salary, lockstep or merit-based pay band, equity partner tier designation (tier name, points value, profit share percentage, capital contribution), bonus target and actual payout, origination bonus, benefits package tier, effective date, and compensation approval status. Supports PPP, PEP, and RPE financial analytics including partner compensation modeling across equity tiers. Sourced from SAP SuccessFactors Compensation module. Access is restricted to HR and firm management.' .

ind:RecruitmentRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Recruitment Requisition' ;
    rdfs:comment 'Tracks open and closed attorney and staff recruitment requisitions from job posting through offer acceptance, including the embedded candidate pipeline for each requisition. Stores position title, seniority level, practice group, office location, requisition open date, target start date, approved headcount budget, sourcing channel (lateral hire, law school campus, ALSP, referral), recruiter assigned, interview stages, offer extended flag, offer outcome, and requisition close reason. Candidate pipeline attributes per requisition include candidate name, current employer, law school, years of experience, bar admissions held, application stage, background check status, and conflicts pre-screen status. Sourced from SAP SuccessFactors Recruiting module.' .

ind:LeaveRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Leave Record' ;
    rdfs:comment 'Tracks all approved and pending leave events for timekeepers including parental leave, sabbatical, medical leave, vacation, and unpaid leave. Stores leave type, request date, approved start date, approved end date, actual return date, leave reason code, coverage arrangement, impact on billable hours target, payroll adjustment flag, and approving manager. Sourced from SAP SuccessFactors Time and Attendance. Critical for resource planning and matter staffing continuity.' .

ind:SuccessionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Succession Plan' ;
    rdfs:comment 'Succession planning records identifying key roles at risk and designated successors for critical partner and leadership positions. Stores the incumbent timekeeper, role title, risk level (flight risk, retirement horizon), readiness timeline, designated successor candidates, development actions required, plan review date, and sponsoring partner. Sourced from SAP SuccessFactors Succession and Development module. Supports firm continuity and client relationship transition planning.' .

ind:Secondment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Secondment' ;
    rdfs:comment 'Records attorney and staff secondment arrangements where a timekeeper is temporarily placed with a client organization, another firm office, or an international rotation. Stores secondment type (client secondment, inter-office, international rotation), host organization, host contact, secondment start and end dates, cost allocation arrangement (client-funded, firm-funded, split), billing rate during secondment, supervising partner, secondment objectives, and return-to-role plan. Supports client relationship management, cross-border staffing, and resource planning continuity.' .

ind:DisciplinaryRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Disciplinary Record' ;
    rdfs:comment 'Confidential record of internal disciplinary actions and professional conduct matters involving firm timekeepers. Stores incident date, incident type (conduct, performance, ethics, regulatory), description, investigation status, outcome (warning, suspension, termination, no action), bar referral flag, regulatory notification flag, and resolution date. Distinct from bar admission disciplinary standing which is externally held. Access is restricted to HR and firm management. Supports SRA and ABA professional conduct obligations.' .

ind:DiversityRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Diversity Record' ;
    rdfs:comment 'Tracks self-reported and firm-collected diversity, equity, and inclusion (DEI) data for each timekeeper as required by SRA diversity data collection, Mansfield Rule certification, client-driven diversity reporting (e.g., ABA Model Diversity Survey), and internal firm DEI initiatives. Stores demographic category (gender, ethnicity, disability status, sexual orientation, socioeconomic background, caregiver status), self-identification date, reporting period, disclosure consent flag, Mansfield Rule candidate pool eligibility, client diversity survey response data, and anonymization flag for aggregate reporting. Access restricted to HR and DEI leadership. Sourced from SAP SuccessFactors with voluntary self-identification workflows.' .

ind:RfpTeamAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Rfp Team Assignment' ;
    rdfs:comment 'This association product represents the assignment of individual timekeepers (attorneys, paralegals, and staff) to RFP pitch teams. It captures the specific role each timekeeper plays in the RFP response effort, their time contribution, section ownership, and the billing rate quoted for their participation. Each record links one timekeeper to one RFP submission with attributes that exist only in the context of this specific pitch team assignment, enabling cost recovery analysis, win/loss performance tracking, and pitch team composition optimization.. Existence Justification: In legal services, RFP responses require multi-attorney pitch teams where each timekeeper contributes specific expertise, hours, and section ownership. A single timekeeper participates in multiple concurrent RFP opportunities throughout the year, and each RFP submission requires multiple timekeepers with distinct roles (lead partner, subject matter expert, pricing analyst, etc.). The firm actively manages these assignments for cost recovery, capacity planning, and win/loss analysis by team composition.' .

ind:User rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'User' ;
    rdfs:comment 'Master reference table for user. Referenced by modified_by_user_id.' .

ind:LateralCandidate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Lateral Candidate' ;
    rdfs:comment 'Master reference table for lateral_candidate. Referenced by candidate_id.' .

ind:LearningItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Learning Item' ;
    rdfs:comment 'Master reference table for learning_item. Referenced by learning_item_id.' .

ind:CompensationPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Compensation Plan' ;
    rdfs:comment 'Master reference table for compensation_plan. Referenced by compensation_plan_id.' .

ind:CalibrationSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Calibration Session' ;
    rdfs:comment 'Master reference table for calibration_session. Referenced by calibration_session_id.' .

ind:Employee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Employee' ;
    rdfs:comment 'Master reference table for employee. Referenced by employee_id.' .

ind:Department rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Department' ;
    rdfs:comment 'Master reference table for department. Referenced by department_id.' .

ind:ReviewCycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Master reference table for review_cycle. Referenced by review_cycle_id.' .

ind:RatingScale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Rating Scale' ;
    rdfs:comment 'Master reference table for rating_scale. Referenced by rating_scale_id.' .

ind:PracticeArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Practice Area' ;
    rdfs:comment 'Master taxonomy of legal practice areas and sub-specializations offered by the firm (e.g., M&A, Litigation, IP, Employment Law, Regulatory Compliance, Real Estate). Supports hierarchical parent-child classification enabling roll-up reporting. Each practice area carries a unique code, description, active/inactive status, and regulatory body alignment. Used to categorize matters, timekeepers, service offerings, and rate cards across all firm systems.' .

ind:LegalService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Legal Service' ;
    rdfs:comment 'Core catalog of legal service offerings available from the firm, including M&A advisory, litigation representation, IP counsel, regulatory compliance counseling, employment law advisory, and structured advisory packages. Each record defines a distinct service offering with its scope, practice area alignment, delivery model, and eligibility criteria. This is the SSOT for what the firm offers commercially and operationally, used in RFP responses, engagement letters (LOE), and business development pipelines in Microsoft Dynamics 365.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Defines the tiered packaging levels for legal services (e.g., Standard, Premium, Enterprise, Bespoke). Each tier specifies the scope of coverage, included deliverables, response commitments, and eligibility for alternative fee arrangements (AFA). Used to structure RFP responses and engagement letter (LOE) terms. Enables differentiated pricing and SLA assignment across client segments.' .

ind:PricingModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Defines the fee structures and alternative fee arrangements (AFA) applicable to legal service offerings, including hourly billing, fixed fee, capped fee, blended rate, retainer, contingency, and success fee models. Each record captures the model type, calculation basis, currency, applicable jurisdictions, and LEDES/UTBMS billing code alignment. Serves as the authoritative pricing configuration referenced by billing and matter domains.' .

ind:RateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Rate Card' ;
    rdfs:comment 'Stores the standard and negotiated timekeeper billing rates for legal services by practice area, seniority level (partner, associate, paralegal), jurisdiction, and client segment. Captures effective date ranges, currency, rate type (standard, preferred, blended), and UTBMS task code alignment. Feeds directly into Elite 3E and Aderant Expert rate management modules for WIP calculation and prebilling. Distinct from pricing_model which defines the fee structure type.' .

ind:SlaTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Template' ;
    rdfs:comment 'Defines the service level agreement (SLA) templates governing response times, turnaround commitments, escalation thresholds, and quality standards for each legal service offering. Captures SLA type (matter response, document turnaround, court filing deadline, regulatory submission), target metrics, breach thresholds, and remediation terms. Used in LOE drafting, RFP responses, and matter management SLA monitoring. Distinct from individual matter-level SLA instances.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Package' ;
    rdfs:comment 'Defines bundled legal service packages combining multiple legal_service offerings into structured advisory packages (e.g., Corporate Governance Bundle, M&A Full-Service Package, IP Portfolio Management Suite). Modeled as header+line: header captures package name, target client segment, minimum engagement term, pricing basis, cross-sell eligibility, and active/inactive status; line-level rows specify each constituent legal_service, its quantity or scope allocation within the package, sequencing order, optionality (mandatory vs. elective component), and any component-level pricing override. This is the SSOT for all package composition data. Enables cross-selling, structured RFP responses, and downstream matter-to-service mapping.' .

ind:JurisdictionCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Jurisdiction Coverage' ;
    rdfs:comment 'Defines the jurisdictional scope in which each legal service offering is available and licensed for delivery. Captures country, state/province, regulatory body (ABA, SRA, IBA, state bar), admission requirements, local counsel requirements, and any jurisdictional restrictions or caveats. Critical for conflict checking, RFP eligibility, and regulatory compliance counseling scope definition. Enables multi-jurisdictional matter staffing decisions.' .

ind:OfferingVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Offering Version' ;
    rdfs:comment 'Tracks the versioned lifecycle of legal service definitions, capturing changes to scope, pricing model, SLA terms, and practice area classification over time. Each version record preserves the full service definition snapshot at a point in time with effective start/end dates, change reason, and approval status. Enables historical audit of what was offered at the time of any given engagement letter or matter opening. Supports regulatory compliance and professional indemnity review.' .

ind:MatterServiceMapping rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Matter Service Mapping' ;
    rdfs:comment 'Operational association linking active legal matters to the specific legal_service offerings and service_packages under which work is delivered. Each record captures the agreed service scope at matter opening, applied pricing_model, active sla_template, service_tier, effective dates, and approval status. Serves as the runtime bridge between the service catalog and matter execution, enabling service-level WIP attribution, SLA monitoring, billing code alignment per LEDES/UTBMS, and performance analytics by service type. Parent record for service_scope_amendment records that track post-opening changes.' .

ind:DeliveryModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Reference catalog of operational delivery models through which legal services are provided to clients. Covers traditional partner-led attorney teams, client secondments, ALSP (Alternative Legal Service Provider) co-delivery, managed legal services (MLS), legal process outsourcing (LPO), and hybrid models. Each record defines the staffing model type, resource composition, technology enablement approach, primary delivery geography, cost structure basis, and applicable service types. Referenced by legal_service definitions for default delivery configuration and used in capacity planning, RFP staffing proposals, and client reporting on delivery efficiency.' .

ind:ScopeAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Scope Amendment' ;
    rdfs:comment 'Records formal amendments to the agreed scope of a legal service engagement after matter opening, including scope expansions, reductions, fee renegotiations, SLA modifications, and AFA restructuring. Each amendment captures the original scope reference, the nature of the change, the effective date, approval chain, and impact on the pricing model and WIP. Supports LOE amendment tracking and professional indemnity exposure management.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Defines configurable business rules governing which clients or matters qualify for specific legal service offerings during new business intake. Rule types include client-type restrictions (corporate, government, individual), minimum matter value thresholds, jurisdictional licensing constraints, industry sector exclusions, and prerequisite clearance requirements. Each rule specifies evaluation logic, enforcement level (hard block preventing engagement vs. advisory warning requiring partner override), and the legal_service scope to which it applies. Consumed by the intake workflow engine during RFP qualification and matter opening. Note: this product defines the eligibility gating rules only — actual conflict-of-interest screening execution is owned by the conflict domain, and KYC/AML program management is owned by the compliance domain. This product references their clearance outcomes as prerequisite inputs.' .

ind:LpmTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Lpm Template' ;
    rdfs:comment 'Stores Legal Project Management (LPM) plan templates associated with specific legal service offerings, defining standard phases, milestones, task sequences, resource role requirements, budget allocation by phase, and risk checkpoints. Each template provides a reusable project structure for matter teams to instantiate when opening a new matter under a given service type. Supports consistent delivery, budget control, and client reporting across matters of the same service type.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Line' ;
    rdfs:comment 'Defines the firms operational business lines that group legal service offerings for P&L reporting, partner compensation allocation, strategic planning, and client-facing branding. Each service line (e.g., Corporate Advisory, Disputes & Investigations, Regulatory & Government Affairs, Transactional) aggregates multiple practice areas and legal services into a commercially-managed unit with its own revenue targets, leadership structure, and market positioning. Distinct from practice_area (which is a professional taxonomy) — service_line is the business management layer used in firm financials, lateral hiring decisions, and strategic growth planning.' .

ind:DeliveryConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Delivery Configuration' ;
    rdfs:comment 'This association product represents the operational configuration between legal services and delivery models. It captures which services can be delivered through which models, tracking effectiveness, cost allocation, and SLA overrides for each combination. Each record links one legal_service to one delivery_model with attributes that exist only in the context of this specific service-model pairing, used in capacity planning, RFP staffing proposals, and client delivery optimization.. Existence Justification: In legal services operations, firms actively manage which services can be delivered through which delivery models, creating a genuine many-to-many operational relationship. A single legal service (e.g., M&A advisory) can be delivered through multiple models (traditional partner-led, ALSP co-delivery, managed legal services) depending on client requirements, matter complexity, and cost constraints. Conversely, a single delivery model (e.g., client secondment) can be used to deliver multiple different legal services (litigation, IP counsel, regulatory compliance). The firm tracks the effectiveness, cost allocation, and SLA commitments for each specific service-model pairing.' .

ind:PracticeAreaDeliveryConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Practice Area Delivery Configuration' ;
    rdfs:comment 'This association product represents the operational configuration between practice areas and delivery models in legal service delivery. It captures which practice areas can be delivered through which delivery models, along with capacity allocation, performance targets, and effectiveness tracking. Each record links one practice area to one delivery model with attributes that define the operational parameters, resource allocation, and quality metrics for that specific combination. This is actively managed by legal operations teams for capacity planning, RFP response preparation, and delivery optimization.. Existence Justification: In legal operations, practice areas can be delivered through multiple delivery models (e.g., M&A can be delivered via traditional partner-led teams, ALSP co-delivery, or managed legal services), and each delivery model supports multiple practice areas (e.g., ALSP co-delivery can handle IP, employment law, and regulatory compliance). Legal operations teams actively manage this matrix to allocate capacity, respond to RFPs with appropriate staffing models, track delivery effectiveness, and optimize resource deployment across the practice-delivery configuration space.' .

ind:Prospect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Prospect' ;
    rdfs:comment 'Master record for prospective clients entering the new business intake pipeline. Captures the pre-engagement identity of an organization or individual before formal client status is established in the client domain. Tracks prospect source (RFP, referral, BD outreach, directory, conference, panel, alumni network), prospect type (corporate, government, individual), referral attribution (referral source type, referring party, relationship owner, referral date), KYC/AML pre-screening status, originating attorney, and pipeline stage. Bridges Microsoft Dynamics 365 CRM lead/account records with the intake workflow. Supports BD attribution reporting and referral network analytics. Distinct from the client domains client entity — prospect represents the pre-onboarding state prior to conflict clearance and LOE execution.' .

ind:RfpSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Rfp Submission' ;
    rdfs:comment 'Transactional record capturing each Request for Proposal received from a prospective or existing client. Tracks RFP receipt date, issuing organization, RFP reference number, practice area scope, response deadline, assigned pitch team, submission status (received, under review, declined, responded), and the resulting pitch or proposal linkage. Sourced from Microsoft Dynamics 365 opportunity pipeline. Serves as the intake trigger event that initiates the prospect qualification and conflict check workflow.' .

ind:Pitch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Pitch' ;
    rdfs:comment 'Master record representing a formal pitch or credentials presentation made to a prospective or existing client in response to an RFP or BD opportunity. Tracks pitch type (beauty parade, credentials deck, oral presentation), pitch date, presenting attorneys, practice areas covered, competitive context, pitch outcome (won, lost, pending, withdrawn), and win/loss reason codes. Linked to the originating RFP submission and the resulting engagement opportunity. Sourced from Microsoft Dynamics 365 opportunity and activity records.' .

ind:EngagementOpportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Engagement Opportunity' ;
    rdfs:comment 'Core CRM pipeline entity representing a qualified business development opportunity for a specific legal matter or ongoing client relationship. Tracks opportunity stage (qualification, proposal, negotiation, closed-won, closed-lost), estimated matter value, practice group, responsible partner, probability of conversion, expected matter open date, and AFA type under consideration. Maps directly to Microsoft Dynamics 365 Opportunity records and serves as the commercial anchor linking prospect, pitch, and eventual matter opening in Elite 3E.' .

ind:Request rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Request' ;
    rdfs:comment 'Central workflow orchestration record for the new business intake lifecycle. Represents the formal request submitted by an attorney or BD professional to initiate conflict checking, KYC/AML screening, engagement approval, and ultimately matter opening in Elite 3E. Captures requesting timekeeper, proposed client name, adverse parties, matter description, practice area, office, supervising partner, urgency flag, submission timestamp, and matter opening details (proposed matter number, billing arrangement, approval status). Progresses through stages from submission through conflict clearance, LOE execution, and matter number reservation. Acts as the operational trigger in Intapp Conflicts and the handoff record to the matter domain. Encompasses the full intake-to-open lifecycle including onboarding task tracking and matter opening request details.' .

ind:ConflictSearch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Conflict Search' ;
    rdfs:comment 'Transactional record of each conflict-of-interest search executed against the firms relationship and matter database during the intake workflow. Tracks search parameters (party names, roles, matter type), execution timestamp, search engine version, number of hits returned, searcher identity, and overall search status (pending, complete, escalated). Each intake request may generate multiple conflict searches for different parties. Sourced from Intapp Conflicts search execution logs. Boundary: this entity captures the search execution act and raw results within the intake workflow; formal clearance decisions, waiver approvals, and ethical wall configurations are owned by the conflict domain.' .

ind:ConflictHit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Conflict Hit' ;
    rdfs:comment 'Individual conflict search result record representing a potential conflict match identified during intake conflict screening. Captures matched party name, matched matter or client reference, relationship type, hit severity (potential, actual, waivable), assigned reviewer, review status, and disposition notes. Multiple hits may be generated per conflict search. Sourced from Intapp Conflicts hit results. Boundary: this entity owns the raw hit record and initial triage within the intake workflow; formal clearance decisions, conflict waivers, and ethical wall enforcement are owned by the conflict domain.' .

ind:IntakeParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Intake Party' ;
    rdfs:comment 'Master record of each party (client, adverse party, related entity, guarantor, subsidiary) associated with a new business intake request. Captures party name, party role (client, adverse, related, guarantor, co-counsel), entity type (corporation, individual, government), jurisdiction of incorporation, parent entity reference, and KYC/AML screening status. Supports multi-party conflict searches and adverse party tracking. Distinct from the client domains client entity — intake_party represents unverified parties at the pre-clearance stage before formal client onboarding.' .

ind:KycScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Kyc Screening' ;
    rdfs:comment 'Transactional record capturing the Know Your Client (KYC) and Anti-Money Laundering (AML) due diligence screening performed on a prospective client or intake party during the onboarding process. Tracks screening type (KYC, AML, sanctions, PEP check), screening provider, screening date, risk rating assigned (low, medium, high), screening outcome (cleared, escalated, rejected), escalation reason, and approving compliance officer. Supports FATF, AML, and SRA regulatory obligations. Each intake party requiring due diligence generates one or more KYC screening records.' .

ind:IntakeEngagementScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Intake Engagement Scope' ;
    rdfs:comment 'Master record defining the agreed scope of legal services for a proposed engagement, negotiated during the intake process prior to LOE execution. Captures practice area, matter type, service description, geographic scope, included and excluded services, staffing plan (partner, associate, paralegal), estimated hours by role, and scope version number. Serves as the commercial specification that feeds the LOE drafting process and AFA negotiation. Linked to the engagement opportunity and the resulting letter of engagement. Owned by the intake domain as the pre-matter scope definition.' .

ind:IntakeFeeArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Intake Fee Arrangement' ;
    rdfs:comment 'Master record capturing the negotiated fee arrangement (AFA) agreed with a prospective client during the intake and engagement scoping process. Tracks AFA type (hourly, fixed fee, capped fee, contingency, blended rate, retainer, success fee), agreed fee amount or rate schedule reference, billing frequency, currency, discount applied, approval status, approving partner, and effective date. Linked to the engagement scope and letter of engagement. Sourced from Elite 3E rate and billing configuration. Distinct from the billing domains rate schedule — this entity captures the negotiated commercial agreement, not the rate table.' .

ind:LetterOfEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Letter Of Engagement' ;
    rdfs:comment 'Master record representing the Letter of Engagement (LOE) issued to a prospective client formalizing the attorney-client relationship, scope of services, fee arrangement, and terms of engagement. Tracks LOE version, issue date, acceptance date, signatory details, governing law, jurisdiction, LPP acknowledgment, data protection consent (GDPR/DPA), conflict waiver references, and execution status (draft, issued, accepted, declined, superseded). The LOE execution event triggers the handoff from the intake domain to the matter domain for matter opening in Elite 3E. Owned by the intake domain as the pre-matter commercial instrument.' .

ind:MatterOpeningRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Matter Opening Request' ;
    rdfs:comment 'Transactional record representing the formal request to open a new matter in Elite 3E following successful conflict clearance and LOE execution. Captures requested matter name, client reference, practice group, responsible partner, billing attorney, originating attorney, office, matter type, proposed matter number, billing arrangement reference, and submission status (pending, approved, rejected, opened). Serves as the handoff record between the intake domain and the matter domain. Triggers matter creation in Elite 3E and closes the intake workflow lifecycle.' .

ind:OriginationCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Origination Credit' ;
    rdfs:comment 'Master record capturing the business origination and relationship credit allocation for a new engagement at the point of intake. Records which attorneys (originating, responsible, billing, cross-selling) receive credit for bringing in the client or matter, including credit type, percentage split, credited timekeeper, practice group, office, and approval status. Established during intake as the commercial attribution record and feeds partner compensation calculations (PPP/PEP) in Elite 3E. Distinct from billing-domain revenue allocation — this captures the agreed credit split at engagement inception before any billing activity occurs.' .

ind:ClientOnboardingTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Client Onboarding Task' ;
    rdfs:comment 'Transactional record representing an individual task or action item within the client onboarding checklist for a new engagement. Tracks task type (KYC document collection, conflict waiver execution, engagement letter signature, matter number assignment, billing setup, ethical wall configuration, DMS folder creation), assigned owner, due date, completion date, status (pending, in progress, complete, waived), blocking dependencies, and SLA threshold. Supports structured onboarding workflow management, task dependency resolution, and SLA compliance tracking from intake through matter handoff in Elite 3E.' .

ind:ReferralSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Master reference record identifying the source through which a prospect or new business opportunity was referred to the firm. Captures referral source type (existing client, attorney referral, alumni, intermediary, directory listing, conference, website, panel appointment), referral source name, relationship owner, referral date, and associated engagement opportunity. Supports BD attribution reporting, referral network management, and client relationship analytics. Owned by the intake domain as the commercial origination attribution record.' .

ind:PanelAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Panel Appointment' ;
    rdfs:comment 'Master record representing a formal legal panel or preferred supplier appointment under which the firm is pre-authorized to receive instructions from a client organization. Captures panel name, appointing client, panel category (general counsel, litigation, M&A, regulatory, employment), appointment and expiry dates, geographic scope, agreed rate card reference, volume commitment, review cycle, and panel status (active, under review, expired, terminated). Panel appointments are a primary driver of intake volume for large corporate and government clients — new matters arriving under panel terms bypass certain BD stages and flow directly into the intake request workflow.' .

ind:RiskAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Risk Action' ;
    rdfs:comment 'This association product represents the assignment of risk mitigation actions to specific intake requests in the new business intake lifecycle. It captures the operational linkage between intake requests that trigger risk concerns (conflicts, sanctions, reputational issues) and the specific mitigation actions assigned to address those concerns. Each record links one intake request to one risk mitigation action with attributes that track the assignment context, timing, priority, effort, and completion status specific to that intake-action pairing.. Existence Justification: In legal firm intake operations, a single intake request can trigger multiple distinct risk mitigation actions (conflict waiver, enhanced KYC, sanctions clearance, ethical wall implementation, reputational review) based on the specific risk profile of the proposed matter. Conversely, a single mitigation action template (e.g., implementing an ethical wall protocol) can be assigned to address risks identified across multiple concurrent intake requests involving related parties or overlapping conflicts. The business actively manages these assignments as operational records with timing, priority, and completion tracking specific to each intake-action pairing.' .

ind:OpportunityRiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intake ;
    rdfs:label 'Opportunity Risk Assessment' ;
    rdfs:comment 'This association product represents the formal risk evaluation performed for a specific engagement opportunity during the business development lifecycle. It captures the point-in-time risk assessment conducted as part of client acceptance, conflict clearance, and engagement approval processes. Each record links one engagement opportunity to one risk assessment with attributes that exist only in the context of this evaluation relationship.. Existence Justification: In legal services business development, engagement opportunities undergo multiple formal risk assessments at different stages of the pipeline (initial screening at qualification, detailed due diligence during proposal, pre-engagement final review before LOE execution). A single comprehensive risk assessment can also evaluate multiple related opportunities simultaneously (e.g., panel appointment covering multiple anticipated matters, multi-jurisdiction engagement with separate opportunity records). The business actively manages these assessment relationships with stage-specific scores, approval workflows, and reviewer assignments.' .

ind:Register rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Register' ;
    rdfs:comment 'Enterprise-wide and matter-level risk register serving as the authoritative single source of truth for all identified risks across professional indemnity, data breach, cybersecurity, sanctions, reputational, and operational categories. Each record represents a discrete risk item with classification, inherent and residual risk ratings (likelihood × impact matrix), current mitigation status, risk owner, escalation history, exception status (approved deviations from policy with approval metadata), and review cycle scheduling. Supports Risk Committee reporting, SRA regulatory submissions, ISO 31000 alignment, and feeds compliance, conflict, and workforce domains.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Category' ;
    rdfs:comment 'Reference taxonomy of risk categories applicable to a legal services firm, including professional indemnity, data privacy (PII/GDPR), cybersecurity (ISO 27001), sanctions and AML, reputational, operational, and regulatory risk types. Provides standardized classification codes used across the risk register and incident management processes.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Formal risk assessment record capturing the structured evaluation of a specific risk item at a point in time. Records inherent risk score, control effectiveness rating, residual risk score, likelihood rating, impact rating, risk appetite threshold comparison, assessor identity, assessment methodology (qualitative/quantitative), and next review date. Supports periodic risk review cycles mandated by ISO 27001 and SRA requirements.' .

ind:RiskControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Control' ;
    rdfs:comment 'Catalog of risk controls and mitigating measures implemented to address identified risks, including complete control testing and audit history. Each record captures control type (preventive, detective, corrective), control owner, implementation status, operational effectiveness rating, and linkage to mitigated risk items. Embeds the full testing lifecycle: each test instance records test date, tester identity, test methodology, evidence reference, pass/fail outcome, deficiencies identified, remediation required flag, and remediation due date. Provides the consolidated control-and-test audit trail required for ISO 27001 certification and SRA compliance reviews. Aligned to ISO 27001 Annex A control framework.' .

ind:IndemnityExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Indemnity Exposure' ;
    rdfs:comment 'Professional indemnity (PI) exposure record tracking the firms estimated liability exposure on a per-matter or per-claim basis. Captures exposure type (negligence, breach of duty, conflict of interest), estimated claim value, reserve amount, insurer notified flag, notification date, policy year, excess amount, and current exposure status. Feeds the firms PI insurance renewal process and risk appetite monitoring.' .

ind:PiClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Pi Claim' ;
    rdfs:comment 'Professional indemnity (PI) claim record capturing formal claims made against the firm by clients or third parties. Records claimant details, claim date, matter reference, alleged breach description, claim amount, insurer reference, coverage confirmation, legal representation assigned, settlement amount, claim outcome, and closure date. Managed in coordination with the firms PI insurer and external coverage counsel.' .

ind:DataBreachIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Data Breach Incident' ;
    rdfs:comment 'Data breach and privacy incident record tracking all actual or suspected breaches of PII, confidential client data, or LPP-protected information. Captures incident discovery date, breach type (unauthorized access, accidental disclosure, ransomware, insider threat), data subjects affected count, data categories involved (PII, special category, LPP), regulatory notification obligations triggered (GDPR 72-hour, DPA, CCPA), ICO/DPA notification status, and remediation actions taken. Supports GDPR Article 33/34 breach notification obligations.' .

ind:CyberRiskEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Cyber Risk Event' ;
    rdfs:comment 'Unified operational and cybersecurity risk event record serving as the single source of truth for all realized risk losses, near-miss events, and security incidents across the firm. Covers the full spectrum of operational risk events including process failures, system outages, human error, external events, as well as cybersecurity-specific events such as phishing, ransomware, DDoS, insider threats, and vulnerability exploits. Each record captures event date, event type and category, severity classification (aligned to ISO 27001 impact levels), affected systems or practice groups, detection source, containment actions, root cause analysis, financial impact (actual loss or near-miss estimated loss), matter reference if applicable, lessons-learned documentation, and linkage to ISO 27001 controls. Distinct from data_breach_incident which tracks privacy-specific regulatory notification obligations under GDPR Article 33/34.' .

ind:SanctionsScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Sanctions Screening' ;
    rdfs:comment 'Record of each sanctions and AML screening check performed against a client, counterparty, beneficial owner, or matter participant. Captures screening date, screened entity name and type, screening list(s) checked (OFAC, UN, EU, HMT), match type (exact, fuzzy, alias), match score, false positive determination, escalation flag, compliance officer review outcome, and clearance or rejection decision. Supports FATF AML obligations and SRA AML regulations. Distinct from conflict check domain which handles conflict-of-interest screening.' .

ind:ReputationalRisk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Reputational Risk' ;
    rdfs:comment 'Reputational risk flag record identifying clients, matters, counterparties, or industries that present elevated reputational risk to the firm. Captures flag type (adverse media, politically exposed person, high-risk jurisdiction, controversial industry, ESG concern), flag source, severity level, flag raised date, review status, approving partner identity, and disposition (accepted with conditions, declined, monitored). Feeds new business intake and matter acceptance decisions. Supports the firms ethical obligations under SRA Principles and Code of Conduct regarding client selection.' .

ind:MatterRiskProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Matter Risk Profile' ;
    rdfs:comment 'Matter-level risk profile aggregating all risk dimensions for a specific legal matter including complexity rating, jurisdictional risk, client credit risk, legal professional privilege (LPP) sensitivity, eDiscovery/ESI volume exposure, regulatory scrutiny level, and overall matter risk tier (green/amber/red). Created at matter intake and updated at key lifecycle milestones (mid-matter review, pre-trial, closure). Provides the consolidated risk view consumed by matter management, billing, and partner review processes.' .

ind:Appetite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Appetite' ;
    rdfs:comment 'Reference record defining the firms risk appetite thresholds by risk category and organizational level (firm-wide, practice group, office). Captures maximum tolerable risk score, escalation trigger score, risk tolerance band (low/medium/high/critical), review frequency, approving governance body (Risk Committee, Managing Partner, Board), and effective date range. Used to evaluate whether assessed risks fall within or outside the firms stated risk appetite.' .

ind:MitigationAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Transactional record of each risk mitigation or remediation action assigned to address an identified risk or control deficiency. Captures action description, action owner, assigned date, due date, priority, completion status, completion date, evidence of completion, and residual risk re-assessment trigger. Provides the action tracking layer that drives risk reduction workflows and management reporting.' .

ind:CreditNote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Note' ;
    rdfs:comment 'Transactional record of credit notes issued to clients to reverse or reduce previously invoiced amounts. Captures credit note number, originating invoice reference, credit reason (overbilling, dispute resolution, goodwill adjustment, fee cap correction), credit amount, tax adjustment, issuance date, and application status (applied to outstanding AR, refunded, held on account). Supports realization rate analysis and AR reconciliation.' .

ind:BillingOffice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Office' ;
    rdfs:comment 'Master reference table for billing_office. Referenced by billing_office_id.' .

ind:RateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rate Schedule' ;
    rdfs:comment 'Master reference table for rate_schedule. Referenced by rate_schedule_id.' .

ind:Check rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Check' ;
    rdfs:comment 'Core transactional record of each conflict-of-interest screening request initiated during new business intake or lateral hire onboarding. Captures the check type (ABA Rule 1.7 current client, Rule 1.9 former client, Rule 1.10 imputed disqualification, lateral hire), the triggering event, requestor, assigned reviewer(s) and their roles, clearance status, and disposition. Reviewer assignments (primary reviewer, ethics partner, supervising partner) with their individual disposition recommendations are tracked directly on this record. This is the primary operational entity of the conflict domain and the system-of-record entry sourced from Intapp Conflicts.' .

ind:ConflictParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Conflict Party' ;
    rdfs:comment 'Master registry of all parties — clients, adverse parties, related entities, individuals, and corporate affiliates — indexed in the conflict search universe. Each party record captures name variants, role classification (client, adverse, related entity, guarantor, beneficial owner), entity type (individual, corporation, government, trust, partnership), jurisdiction of incorporation or domicile, KYC/AML flags, and active/inactive status. Serves as the searchable party index used by every conflict check. Distinct from the client domains client record: this product owns the conflict-specific party classification and search indexing; a party here may or may not be a firm client. For multi-jurisdictional firms, party records are subject to data residency requirements — GDPR-regulated party data (EU/UK natural persons) must be stored and processed within compliant regions, with appropriate cross-border transfer mechanisms documented.' .

ind:SearchExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Search Execution' ;
    rdfs:comment 'Transactional record of each individual name or entity search executed within a conflict check. Captures the search string, phonetic and fuzzy-match variants applied, search algorithm version, number of hits returned, and the timestamp of execution. One conflict_check may spawn multiple search_execution records (one per party searched). Sourced from Intapp Conflicts search audit log. Note: the logical primary key is conflict_search_id; the physical PK conflict_conflict_search_id reflects the platform naming convention (domain prefix + product-derived name).' .

ind:SearchHit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Search Hit' ;
    rdfs:comment 'Each potential conflict match surfaced by a conflict search against the party index and matter history. Records the matched party, the matter or engagement where the relationship was found, the relationship type (current client, former client, adverse party, related entity), the match confidence score, and the reviewing attorneys initial assessment (potential conflict, no conflict, waivable). Central to the conflict clearance workflow. Note: the logical primary key is conflict_hit_id; the physical PK conflict_conflict_hit_id reflects the platform naming convention.' .

ind:Clearance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Clearance' ;
    rdfs:comment 'Formal clearance decision record issued at the conclusion of a conflict check workflow. Captures the clearance outcome (cleared, cleared with conditions, declined — conflict identified, deferred pending waiver), the authorizing partner or general counsel, the ABA rule basis for any identified conflict, and the date clearance was granted or denied. When conditions are imposed (e.g., mandatory ethical wall erection, restricted matter scope, required client notification, periodic review), each condition is recorded with its type, responsible party, due date, and fulfillment status directly on this record. This record gates matter opening in Elite 3E.' .

ind:Waiver rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Waiver' ;
    rdfs:comment 'Records informed consent waivers obtained from clients to permit representation despite an identified conflict of interest under ABA Rule 1.7(b). Captures the waiving client, the conflicted matter, the nature of the conflict disclosed, the form of consent (written, verbal with written confirmation), the consenting signatory, waiver execution date, and any scope limitations. Linked to the clearance record and stored in iManage Work.' .

ind:EthicalWall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Ethical Wall' ;
    rdfs:comment 'Master record of each ethical screen (information barrier) erected to isolate timekeepers from matters where a conflict or LPP risk exists. Captures the screen name, triggering reason (lateral hire, former client, adverse party, regulatory requirement), effective date, expiration date, screen status (active, expired, dissolved), and the supervising partner responsible for screen integrity. Linked to the clearance or lateral screening record that triggered its creation. Sourced from Intapp Conflicts ethical wall module and enforced in iManage Work and Elite 3E access controls.' .

ind:WallMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Wall Membership' ;
    rdfs:comment 'Association entity recording which timekeepers (attorneys, paralegals, staff) are included within or excluded from a specific ethical wall. Captures the timekeeper reference, inclusion/exclusion designation, the date added or removed, the reason for the membership change, and the authorizing partner. Enables enforcement of access restrictions in iManage Work and Elite 3E.' .

ind:LateralScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Lateral Screening' ;
    rdfs:comment 'Conflict screening record specific to lateral attorney and staff hires. Captures the candidates prior firm, practice group, matters handled at prior firm (as disclosed), parties represented or adverse, the screening questionnaire responses, identified conflicts, and the hiring partners clearance decision. Enforces ABA Rule 1.10(a)(2) lateral hire imputed disqualification analysis. Integrates with SAP SuccessFactors recruitment workflow.' .

ind:RelationshipMap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Relationship Map' ;
    rdfs:comment 'Master record capturing known relationships between parties in the conflict universe — corporate family trees (parent/subsidiary), affiliate chains, beneficial ownership structures, joint venture partnerships, and adverse party pairings. Each record defines the two related parties, relationship type, directionality (parent-to-child, peer-to-peer), effective date range, and the source of the relationship data (client disclosure, public registry, KYC/AML review, Companies House filing). Used to expand conflict search scope beyond direct name matches to identify indirect conflicts through corporate affiliations.' .

ind:Rule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Rule' ;
    rdfs:comment 'Reference catalog of conflict-of-interest rules and ethical obligations configured in the firms conflict system. Each record defines the rule identifier (e.g., ABA 1.7, ABA 1.9, ABA 1.10, SRA Rule 6.1), the governing body, the rule description, the jurisdiction(s) of applicability, the conflict category it governs, and whether the conflict is waivable. Drives automated conflict classification logic in Intapp Conflicts.' .

ind:PartyAlias rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Party Alias' ;
    rdfs:comment 'Registry of known name aliases, former names, trade names, DBA designations, and transliterated variants for parties in the conflict search universe. Each alias record links to the canonical conflict_party record and captures the alias type, the source of the alias (client disclosure, public registry, prior matter), and the effective date range. Enables comprehensive fuzzy and phonetic matching during conflict searches.' .

ind:ConflictException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Conflict Exception' ;
    rdfs:comment 'Records formally approved exceptions to standard conflict clearance requirements — including pre-approved engagement categories (e.g., pro bono matters for approved nonprofits), standing institutional client waivers, regulatory safe harbors, and de minimis thresholds. Captures the exception type, approving authority (managing partner, ethics committee, general counsel), scope definition (client categories, matter types, practice groups covered), approval date, expiration or mandatory review date, and usage count. Distinct from per-matter waivers: exceptions apply prospectively to categories of work rather than retroactively to a specific identified conflict.' .

ind:AuditLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Audit Log' ;
    rdfs:comment 'Business-level audit trail capturing every material state change in the conflict check lifecycle — check creation, search execution, hit review disposition, reviewer assignment and response, clearance decision, waiver execution, ethical wall creation/modification/dissolution, and exception approval or revocation. Each log entry records the actor (timekeeper or system), action type, affected entity and ID, prior state, new state, timestamp, and IP address. Supports SRA accountability, ABA ethics audit, GDPR data subject access requests (Article 15/17), and professional indemnity insurance audit requirements. Partitioned by conflict_check_id for efficient per-matter audit retrieval. Data residency: audit records containing EU/UK personal data are subject to GDPR storage requirements and must be retained in compliant jurisdictions with documented legal basis for processing. Retention periods follow jurisdiction-specific professional conduct rules (typically 6-10 years post-matter closure). This is a business compliance record, not a technical system log.' .

ind:MatterPartyRole rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Matter Party Role' ;
    rdfs:comment 'Conflict-domain view of each partys role on a specific matter — client, co-client, adverse party, third-party witness, guarantor, related entity, or regulatory counterparty. Captures the role effective date, role end date, and the source of the role assignment (matter opening form, court filing, client disclosure). This entity populates and maintains the conflict search index by recording party-matter relationships as they are disclosed or discovered. The matter domain owns the canonical matter record; this product owns the conflict-specific role classification and temporal tracking needed for conflict screening.' .

ind:PartyJudgeAppearance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Party Judge Appearance' ;
    rdfs:comment 'This association product represents the appearance history between conflict parties and judges. It captures the operational record of which parties have appeared before which judges across matters, supporting conflict screening, recusal analysis, and litigation strategy intelligence. Each record links one conflict party to one judge with relationship metrics that exist only in the context of their appearance history.. Existence Justification: In legal practice, conflict parties (clients, adverse parties, related entities) appear before multiple judges across different matters over time, and judges preside over cases involving multiple parties. Law firms must track this appearance history to support conflict screening (ensuring no conflicts when taking on new matters), lateral hire screening (assessing whether a new attorney brings conflicts based on their prior party-judge relationships), and litigation strategy (understanding judicial familiarity and past outcomes with specific parties).' .

ind:PartyPracticeConflict rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Party Practice Conflict' ;
    rdfs:comment 'This association product represents the practice-area-specific conflict relationship between a conflict party and a practice area. Legal firms must track conflict status at the granular level of each party-practice area combination because a single party may simultaneously be a client in one practice area (e.g., IP) while being adverse in another (e.g., litigation). Each record captures the conflict severity, relationship type (client/adverse/neutral), and temporal tracking of conflict checks specific to that party-practice area pairing.. Existence Justification: In legal practice, conflict checking must be performed at the granular level of each party-practice area combination because a single party can simultaneously hold different conflict statuses across practice areas. For example, a corporation may be a current client for IP matters while being adverse to another client in litigation, or a related entity in M&A while neutral in employment law. Law firms operationally manage these practice-area-specific conflict relationships as distinct records, each with its own severity assessment, relationship type, conflict check history, and waiver status.' .

ind:WallEnforcement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Wall Enforcement' ;
    rdfs:comment 'This association product represents the enforcement relationship between an ethical wall (information barrier) and a specific agreement. It captures the applicability of an ethical screen to a contract artifact, tracking when and why the wall applies to the agreement, enforcement status, and any breach incidents. Each record links one ethical wall to one agreement with attributes that exist only in the context of this enforcement relationship.. Existence Justification: In legal practice, one ethical wall can apply to multiple agreements when the conflict or screening trigger affects multiple contracts (e.g., a lateral hires former client has multiple active agreements with the firm). Conversely, one agreement can be subject to multiple ethical walls when different conflicts arise from different sources (e.g., multiple lateral hires with conflicts, or multiple adverse parties). The firm actively manages these enforcement relationships, tracking when each wall applies to each agreement, with specific applicability reasons, dates, and breach monitoring per wall-agreement pair.' .

ind:AuditSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Conflict ;
    rdfs:label 'Audit Session' ;
    rdfs:comment 'Master reference table for audit_session. Referenced by session_id.' .

ind:IpAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ip Asset' ;
    rdfs:comment 'Master record for every intellectual property asset managed by the firm on behalf of clients, including patents, trademarks, copyrights, trade secrets, and design rights. Serves as the SSOT for IP asset identity, type, status, jurisdiction, ownership, filing dates, registration numbers, and portfolio classification. Anchors all downstream IP lifecycle, docketing, annuity, and licensing records.' .

ind:Patent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Patent' ;
    rdfs:comment 'Detailed master record for patent assets including utility, design, and plant patents. Captures patent-specific attributes such as PCT application number, PPH eligibility, claims count, independent claims, priority date, publication number, grant date, expiry date, patent family identifier, IPC/CPC classification codes, prosecution status, and assignee chain. Extends ip_asset for patent-specific prosecution and portfolio management.' .

ind:Trademark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Trademark' ;
    rdfs:comment 'Master record for trademark assets including word marks, device marks, trade dress, and certification marks. Captures Nice Classification codes, goods and services descriptions, application serial number, registration number, registration date, renewal due date, use-in-commerce date, specimen of use, opposition period status, Madrid Protocol designations, and multi-class filing indicators. Extends ip_asset for trademark-specific prosecution and maintenance.' .

ind:ProsecutionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Prosecution Event' ;
    rdfs:comment 'Transactional record of every official prosecution action, office communication, or applicant response in the lifecycle of a patent or trademark application. Captures event type (office action received, response filed, notice of allowance, final rejection, restriction requirement, appeal filed, grant issued, request for continued examination), event date, official deadline, response deadline, examiner name and art unit, attorney of record, response summary, and outcome. Supports docketing trigger automation, deadline management, and prosecution history estoppel analysis.' .

ind:DocketDeadline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Docket Deadline' ;
    rdfs:comment 'Operational record of every docketed deadline associated with an IP asset or prosecution event. Covers statutory deadlines, office action response due dates, annuity/renewal payment dates, PCT national phase entry deadlines (30/31 month), opposition filing windows, priority year expiry, and divisional filing deadlines. Captures deadline type, rule-based calculated due date, extended due date (with extension fee flag), responsible attorney, docketing clerk, reminder cascade schedule, completion status, completion date, and missed-deadline escalation flag. Mission-critical for IP docketing compliance — a missed deadline can result in irrecoverable loss of rights and malpractice liability.' .

ind:IpPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ip Payment' ;
    rdfs:comment 'Unified transactional record of every financial payment made or received in connection with IP assets and license agreements. Covers annuity fees, maintenance fees, renewal fees, official surcharges, royalty payments (inbound and outbound), milestone payments, and FRAND commitment payments. Captures payment type (annuity, maintenance_fee, renewal_fee, royalty_inbound, royalty_outbound, surcharge, milestone), associated IP asset or license agreement, due date, payment date, payment amount, currency, IP office receipt number or remittance reference, payment agent, payment method, royalty base and rate (for royalty types), royalty period, withholding tax, late payment surcharge flag, audit adjustment flag, reconciliation status, and payment status. Supports portfolio cost management, annuity forecasting, lapse risk monitoring, royalty accounting, audit rights enforcement, revenue recognition, and unified payment reconciliation.' .

ind:LicenseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'License Agreement' ;
    rdfs:comment 'Master record for ALL IP-specific agreements governing the use, transfer, ownership, co-development, or protection of IP assets. Covers license agreements (exclusive, non-exclusive, sole, cross-license, compulsory, FRAND-encumbered), invention assignment agreements, co-ownership agreements, joint development agreements, technology transfer agreements, IP indemnification agreements, confidentiality agreements with IP-specific terms, and settlement agreements with IP covenants. Captures agreement type discriminator, parties (licensor/licensee, assignor/assignee, co-owners, joint developers), licensed/assigned IP assets, territory, field of use, royalty structure (fixed, running, milestone, lump-sum), effective date, expiry date, renewal terms, sublicensing rights, FRAND obligation flag, key obligations, governing law, execution status, termination provisions, and amendment history. SSOT for all IP agreement relationships — the ONLY product in this domain for recording any IP-related agreement. Distinct from the contract domains general CLM pipeline which handles engagement letters and vendor contracts.' .

ind:RoyaltyPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Royalty Payment' ;
    rdfs:comment 'Transactional record of royalty payments made or received under an IP license agreement. Captures payment period, royalty base (net sales, units, revenue), royalty rate, calculated royalty amount, currency, payment date, payment direction (inbound/outbound), withholding tax amount, audit adjustment flag, and reconciliation status. Supports royalty accounting, audit rights enforcement, and revenue recognition for IP licensing income.' .

ind:Ownership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'Master record establishing the chain of title and ownership interests in each IP asset across all jurisdictions. Captures owner entity name, owner type (individual inventor, corporate assignee, joint owner, government), ownership percentage, assignment date, recordal date, IP office recordal number, consideration paid, and ownership status. Supports ownership verification, assignment recordal tracking, and portfolio due diligence for M&A transactions.' .

ind:Inventor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Inventor' ;
    rdfs:comment 'Master record for individual inventors named on patent applications and grants, maintaining independent lifecycle for inventorship determination, derivation proceedings, and assignment chain management. Captures inventor full name, nationality, residence address, employer at time of invention, invention disclosure date, assignment executed flag, oath or declaration status, inventor contribution description, joint inventor flag, and employment agreement reference. Supports inventorship disputes, correction of inventorship filings, assignment chain integrity verification, and derivation proceeding risk management. Linked to patents via many-to-many relationship reflecting that inventors may appear on multiple patent applications.' .

ind:PatentFamily rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Patent Family' ;
    rdfs:comment 'Master record grouping related patent applications and grants that share a common priority claim into a patent family. Captures family identifier, priority application reference (earliest filing), priority date, family type (simple/Paris Convention, extended/INPADOC, complete), member jurisdiction count, technology area (IPC/CPC based), strategic importance rating, family status, and continuation/divisional chain indicators. Enables portfolio-level analysis, freedom-to-operate assessments, patent landscape mapping, and coordinated multi-jurisdictional prosecution strategy.' .

ind:Valuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Valuation' ;
    rdfs:comment 'Transactional record of formal IP asset valuations conducted for purposes including M&A due diligence, licensing negotiations, balance sheet reporting, litigation damages, and portfolio strategy. Captures valuation date, valuation methodology (income approach, market approach, cost approach, relief-from-royalty), appraiser name, appraiser firm, valuation amount, currency, discount rate applied, useful life estimate, valuation purpose, and approval status.' .

ind:OppositionProceeding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Opposition Proceeding' ;
    rdfs:comment 'Transactional record of inter partes proceedings challenging the validity or registrability of an IP asset. Covers patent oppositions (EPO), inter partes reviews (IPR), post-grant reviews (PGR), covered business method reviews, trademark oppositions (TTAB, EUIPO), cancellation proceedings, and invalidation actions. Captures proceeding type, tribunal or board (PTAB, TTAB, EPO Opposition Division), petitioner/opponent, patent owner/respondent, institution date, grounds of challenge (anticipation, obviousness, non-use, descriptiveness), claims at issue, claim amendments proposed, hearing dates, oral proceedings date, decision date, outcome (maintained, revoked, amended, cancelled), and appeal status. Supports portfolio risk assessment and defensive prosecution strategy.' .

ind:TradeSecret rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Trade Secret' ;
    rdfs:comment 'Master record for trade secret assets including proprietary formulas, manufacturing processes, algorithms, customer lists, pricing methodologies, and confidential business information protected under DTSA and state UTSA equivalents. Captures trade secret identifier, description, classification level (confidential, highly confidential, restricted), date of creation, owner entity, designated custodian, protective measures inventory (NDA coverage, access control lists, physical security, encryption, need-to-know protocols), last audit date, misappropriation risk level, and jurisdiction of protection. Supports trade secret portfolio management, reasonable measures documentation for litigation, and DTSA compliance.' .

ind:IpAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Ip Agreement' ;
    rdfs:comment 'Master record for IP-specific agreements that are distinct from general CLM contracts, including invention assignment agreements, confidentiality agreements covering IP, co-ownership agreements, joint development agreements, technology transfer agreements, and IP indemnification agreements. Captures agreement type, parties, effective date, expiry date, IP assets covered, key obligations, governing law, and execution status. Complements the contract domain without duplicating general CLM records.' .

ind:Copyright rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Copyright' ;
    rdfs:comment 'Master record for copyright assets including both registered and unregistered works managed by the firm on behalf of clients. Covers literary, musical, dramatic, artistic, audiovisual, and software works. Captures work title, work type, author(s), copyright claimant, year of creation, year of first publication, registration status (registered, unregistered, pending), registration number, registration date, jurisdiction, deposit copy status, registration certificate reference, and copyright duration. Extends ip_asset for copyright-specific portfolio management, enforcement readiness, and licensing support.' .

ind:EnforcementAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Transactional record of IP enforcement activities initiated to protect client IP rights, including cease-and-desist letters, customs recordal actions, domain name dispute filings (UDRP), takedown notices (DMCA), and infringement litigation referrals. Captures enforcement type, target party, infringing activity description, enforcement date, jurisdiction, outcome, settlement terms, and referral to litigation flag. Distinct from court domain litigation records which cover filed proceedings.' .

ind:AssetPrecedentUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Asset Precedent Usage' ;
    rdfs:comment 'This association product represents the usage event between an IP asset and a precedent document. It captures when and how a specific precedent template was applied during the lifecycle of an IP asset, including which sections were used, how they were adapted, and effectiveness ratings for knowledge management feedback loops. Each record links one IP asset to one precedent with attributes that exist only in the context of this specific usage instance.. Existence Justification: In legal practice, a single IP asset (patent, trademark, copyright) progresses through multiple lifecycle stages (filing, prosecution, assignment, licensing, maintenance) and may reference different precedent templates at each stage—a patent might use a filing template, then a prosecution response template, then an assignment agreement template. Conversely, a single precedent template (e.g., a standard office action response template) is reused across hundreds or thousands of IP assets. The relationship is operationally managed by knowledge management teams who track which precedents are used, how they are adapted, and their effectiveness to continuously improve the precedent library.' .

ind:AssetContactAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Asset Contact Assignment' ;
    rdfs:comment 'This association product represents the role-based assignment between contacts and IP assets. It captures the operational relationship where contacts serve specific functions (inventor liaison, business owner, licensing manager, billing contact) for IP assets under management. Each record links one contact to one IP asset with role, notification preferences, authority level, and temporal validity that exist only in the context of this assignment.. Existence Justification: In legal IP practice management, a single IP asset requires multiple contacts serving different operational roles (inventor liaison for technical queries, business owner for strategic decisions, licensing manager for commercialization, billing contact for invoicing). Conversely, a single contact—especially in-house counsel or portfolio managers—is routinely assigned responsibility for multiple IP assets across a clients portfolio. This is an operational assignment that IP practice managers actively create, update, and terminate based on client organizational changes, matter staffing, and portfolio restructuring.' .

ind:PatentProsecutionAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Patent Prosecution Assignment' ;
    rdfs:comment 'This association product represents the assignment of timekeepers to patent prosecution matters. It captures the role-based participation of attorneys, patent agents, paralegals, and support staff in patent prosecution work. Each record links one patent to one timekeeper with attributes that exist only in the context of this working relationship, including prosecution role, time allocation, responsibility designation, and engagement period.. Existence Justification: Patent prosecution is a team-based legal process where multiple timekeepers (lead attorneys, associate attorneys, patent agents, paralegals, technical specialists) collaborate on a single patent application over its multi-year lifecycle, and each timekeeper typically works on dozens to hundreds of patents simultaneously. Law firms actively manage these assignments for staffing optimization, workload balancing, billing allocation, and expertise matching. The relationship itself carries operational data including prosecution role, hours worked, responsibility designation, and engagement period that cannot be attributed to either the patent or the timekeeper alone.' .

ind:RoyaltyReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ip ;
    rdfs:label 'Royalty Report' ;
    rdfs:comment 'Master reference table for royalty_report. Referenced by royalty_report_id.' .

ind:ContractAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Agreement' ;
    rdfs:comment 'Master record for every executed or in-progress contract artifact owned by the firm, covering client-facing instruments (LOE, NDA, SPA, POA) and firm vendor/supplier agreements. SSOT for agreement identity, counterparty references, effective/expiry dates, governing law, jurisdiction, contract value, currency, confidentiality classification, LPP flag, execution status, and CLM stage.' .

ind:AgreementType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Reference classification of contract instrument types recognized by the firm, including LOE (Letter of Engagement), NDA (Non-Disclosure Agreement), SPA (Share Purchase Agreement), POA (Power of Attorney), MSA (Master Services Agreement), SOW (Statement of Work), vendor agreement, retainer agreement, and ADR arbitration agreement. Carries UTBMS-aligned codes, default renewal terms, standard notice periods, and governing regulatory framework flags (GDPR, SOX, FRAND).' .

ind:Template rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Template' ;
    rdfs:comment 'Approved master template library for each agreement type maintained in the firms document management system. Tracks template version, practice group owner, jurisdiction applicability, language locale, last review date, approval status, precedent reference, and mandatory-use lock flag. Serves as the catalog of approved starting points for contract drafting.' .

ind:ContractParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Party' ;
    rdfs:comment 'Records every counterparty, signatory, or named party to a specific agreement, including the firm itself, clients, opposing counsel entities, vendors, guarantors, and government bodies. Captures party role (offeror, offeree, guarantor, witness, notary), legal entity name, jurisdiction of incorporation, KYC/AML clearance status, authorized signatory name, and execution capacity. Supports multi-party M&A and syndicated transaction structures.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Granular obligation register extracted from executed agreements, capturing each discrete contractual duty, covenant, representation, warranty, or condition precedent as a header record with associated lifecycle event lines. Header stores obligation text, category (payment, delivery, reporting, confidentiality, regulatory, IP assignment), responsible party, due date, recurrence schedule, priority, and fulfillment status. Line-level event records capture the full audit trail: creation, fulfillment, partial completion, breach notice, cure, waiver, and escalation events with actor, timestamp, event type, supporting document reference, and resulting status change. SSOT for all obligation data including lifecycle events. Core to CLM obligation tracking, dispute resolution evidence, and regulatory compliance reporting.' .

ind:ObligationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Obligation Event' ;
    rdfs:comment 'Transactional record of each obligation lifecycle event — creation, fulfillment, partial completion, breach notice, cure, waiver, or escalation. Captures event timestamp, actor (attorney, client, counterparty), event type, supporting document reference, and resulting obligation status change. Provides the full audit trail required for dispute resolution and regulatory compliance reporting.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Scheduled key dates and milestone events tied to an agreement, including execution date, effective date, condition precedent satisfaction deadline, notice periods, option exercise windows, renewal decision dates, expiry date, and termination for convenience windows. Tracks milestone status, alert lead-time configuration, responsible attorney, and whether the milestone triggered an automated notification. Critical for renewal management and M&A transaction timetables.' .

ind:Renewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Renewal' ;
    rdfs:comment 'Manages the renewal lifecycle for agreements subject to auto-renewal, optional renewal, or renegotiation. Captures renewal type (auto-renew, opt-in, renegotiate), renewal term length, notice-to-cancel deadline, renewal decision (renew, terminate, renegotiate), decision date, responsible partner, AFA or fee adjustment for the renewal term, and the resulting successor agreement reference. Supports proactive renewal pipeline management.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records every formal amendment, addendum, side letter, or variation to an executed agreement. Stores amendment number, amendment type, description of changes, effective date of amendment, parties consenting, execution status, and reference to the redlined document version in the DMS. Maintains the chain of agreement versions for legal enforceability and audit purposes.' .

ind:NegotiationRound rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Negotiation Round' ;
    rdfs:comment 'Tracks each discrete negotiation cycle for a contract under drafting or renegotiation. Records round number, dates sent/returned, negotiating attorney, counterparty negotiator, redline version reference, open/agreed issues count, and round outcome (agreed, escalated, impasse). Enables LPM tracking of negotiation velocity and cycle time for AFA scoping and client reporting.' .

ind:ExecutionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Execution Record' ;
    rdfs:comment 'Captures the formal execution event for an agreement, recording execution method (wet ink, electronic signature, notarized, deed), execution date per party, signatory name and title, witness details, notary details where applicable, jurisdiction of execution, and the executed document reference in the DMS. Provides the legally authoritative record of when and how an agreement became binding.' .

ind:Termination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Termination' ;
    rdfs:comment 'Records the termination or expiry of an agreement, capturing termination type (expiry, termination for convenience, termination for cause, mutual rescission, frustration), effective termination date, notice date, terminating party, grounds for termination, dispute flag, post-termination obligations surviving, and settlement or wind-down terms. Feeds compliance reporting and professional indemnity risk registers.' .

ind:ClauseLibrary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Clause Library' ;
    rdfs:comment 'Curated repository of approved standard and fallback clauses maintained by knowledge management and CLM teams. Each clause stores type (indemnity, limitation of liability, governing law, force majeure, IP assignment, confidentiality, FRAND, arbitration), approved text, fallback text, jurisdiction applicability, practice group owner, approval date, and usage tier (mandatory, preferred, fallback). Integrates with external standard clause guidance sources.' .

ind:ClauseDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Clause Deviation' ;
    rdfs:comment 'Tracks every instance where a negotiated agreement departs from the firms approved standard or fallback clause position. Records the agreement, clause type, approved position, negotiated position, deviation rationale, approving partner, approval date, risk rating, and whether the deviation sets a precedent requiring playbook update. Supports risk management, professional indemnity exposure tracking, and continuous improvement of the clause library.' .

ind:AfaArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Afa Arrangement' ;
    rdfs:comment 'Records the Alternative Fee Arrangement (AFA) terms agreed in client-facing engagement letters and retainer agreements, including AFA type (fixed fee, capped fee, blended rate, success fee, contingency, subscription retainer), agreed fee amount or rate, scope of services covered, billing frequency, budget cap, overage handling, and currency. Distinct from billing domain invoices — this is the contractual fee commitment that governs how billing is calculated.' .

ind:AgreementTypeClausePolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement Type Clause Policy' ;
    rdfs:comment 'This association product represents the clause playbook policy between agreement types and clause library entries. It captures the knowledge management rules that define which clauses are mandatory, recommended, or optional for each agreement type. Each record links one agreement type to one clause with policy attributes that govern clause selection and usage during contract drafting and negotiation.. Existence Justification: This is a genuine operational M:N relationship representing the Agreement Type Clause Playbook, a core knowledge management concept in legal contract lifecycle management. Law firms actively maintain policy rules that define which clauses are mandatory, recommended, or optional for each agreement type. Knowledge management teams update these playbooks when regulations change (e.g., requiring specific clauses in all NDAs) or when court rulings affect clause risk profiles. This is distinct from template composition—it is the policy layer that governs clause selection during contract drafting.' .

ind:TemplateClause rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Template Clause' ;
    rdfs:comment 'This association product represents the composition relationship between contract templates and clause library entries. It captures which approved clauses are included in which contract templates, along with sequencing, optionality, and jurisdiction-specific overrides. Each record links one contract template to one clause with attributes that govern how that clause is used within that specific template context.. Existence Justification: Law firms actively manage template composition as a core knowledge management process. Knowledge management teams curate which approved clauses belong in which contract templates, attorneys review and approve clause selections for specific template types, and compliance teams audit template composition for regulatory adherence. This is not a derived correlation but an operational business process where the firm maintains explicit clause-to-template assignments with sequencing, optionality rules, and jurisdiction-specific overrides.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for each client trust account maintained by the firm in compliance with IOLTA rules and jurisdiction-specific trust accounting regulations. Captures account type (IOLTA pooled, individual client trust, escrow, retainer), account status, designated financial institution, account number, jurisdiction, opening and closing dates, responsible attorney, and regulatory classification. Serves as the SSOT for all fiduciary client fund accounts — operationally distinct from billing accounts which track firm revenue.' .

ind:LedgerEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Ledger Entry' ;
    rdfs:comment 'Granular double-entry ledger record for every debit and credit movement within a client trust account. The single source of truth (SSOT) for all trust fund transactions — no other product in this domain records financial movements. Covers all transaction types including: receipts (advance retainers, settlement proceeds, escrow deposits, court-ordered funds) with source-of-funds, payment method, client authorization reference, and AML screening attributes; disbursements (third-party payments, fee transfers to operating, settlement distributions, filing fees, expert witness payments) with payee, disbursement category (UTBMS cost code), signatory attorney, and authorization status; transfers between accounts; interest credits; and bank charge reversals. Captures transaction date, value date, transaction type, direction (debit/credit), amount, running balance, matter reference, counterparty identity, payment method (wire, cheque, ACH, SWIFT), authorization reference, and LEDES coding where applicable. Receipt entries include source-of-funds classification and AML screening outcome. Disbursement entries link to disbursement_authorization for approval workflow. The atomic unit of trust accounting — every three-way reconciliation, client balance, and regulatory report is built from these entries.' .

ind:ClientTrustBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Client Trust Balance' ;
    rdfs:comment 'Authoritative per-client, per-matter trust balance record representing the current and historical segregated fund position for each client within a pooled or individual trust account. Tracks available balance, held balance (pending disbursements), matter-level sub-ledger balance, last reconciled balance, and balance as-of date. Enforces client fund segregation requirements mandated by bar association rules and IOLTA regulations.' .

ind:Receipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Receipt' ;
    rdfs:comment 'Records the receipt of client funds into a trust account including advance retainers, settlement proceeds, escrow deposits, and court-ordered fund receipts. Captures receipt date, source of funds, payment method (wire, cheque, ACH, SWIFT), amount, matter association, client authorization reference, and anti-money laundering (AML) screening status. Triggers the creation of a corresponding trust_ledger_entry credit record.' .

ind:TrustDisbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Trust Disbursement' ;
    rdfs:comment 'Records every authorized payment or transfer of client funds out of a trust account including payments to third parties, transfers to firm operating accounts upon fee earning, settlement distributions, court filing fee payments, and expert witness payments. Captures disbursement date, payee, payment method, amount, matter reference, disbursement category (UTBMS cost code), authorization status, and signatory attorney. Core operational record for trust fund outflows.' .

ind:DisbursementAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Disbursement Authorization' ;
    rdfs:comment 'Workflow and approval record governing the authorization of each disbursement from a client trust account. Captures the requesting timekeeper, authorization chain (supervising partner, managing partner where required), authorization date and time, approval status, rejection reason, dual-signatory requirements for amounts above threshold, and digital signature references. Enforces the firms internal controls and bar association disbursement authorization rules.' .

ind:ThreeWayReconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Three Way Reconciliation' ;
    rdfs:comment 'Periodic three-way reconciliation record that validates agreement between the firms trust ledger balance, the client sub-ledger total, and the bank statement balance for each trust account. Header captures reconciliation period (monthly mandatory), bank statement balance, book balance, client ledger total, identified variances, variance resolution notes, reconciliation status (in-progress, completed, exception), preparer, reviewer, and sign-off date. Reconciling items (modeled as detail records within this product) capture: item type (outstanding cheque, deposit in transit, bank error, ledger error, timing difference), amount, originating transaction reference, expected clearance date, resolution status, and resolution date. Mandatory under ABA Model Rules and SRA Accounts Rules. Provides the complete audit trail required to clear reconciliation exceptions and satisfy regulatory examination.' .

ind:ReconciliationItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Reconciliation Item' ;
    rdfs:comment 'Individual reconciling item identified during a three-way reconciliation that explains a variance between the trust ledger, client sub-ledger, or bank statement. Captures item type (outstanding cheque, deposit in transit, bank error, ledger error, timing difference), amount, originating transaction reference, expected clearance date, resolution status, and resolution date. Provides the audit trail required to clear reconciliation exceptions and satisfy regulatory examination.' .

ind:BankStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Bank Statement' ;
    rdfs:comment 'Imported or manually entered bank statement record for each trust account covering a defined statement period, including header-level summary and all constituent line items. Header captures financial institution name, account number, statement period start and end dates, opening balance, closing balance, total credits, total debits, statement source (electronic feed, PDF import, manual entry), and import timestamp. Line items (modeled as detail records within this product) capture transaction date, posting date, description, debit amount, credit amount, running bank balance, transaction reference number, and matching status to a trust_ledger_entry. Enables automated matching during reconciliation and identification of unmatched bank transactions requiring investigation. Serves as the external reference leg of the three-way reconciliation.' .

ind:BankStatementLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Bank Statement Line' ;
    rdfs:comment 'Individual line item from an imported bank statement for a trust account. Captures transaction date, posting date, description, debit amount, credit amount, running bank balance, transaction reference number, and matching status to a trust_ledger_entry. Enables automated matching during reconciliation and identification of unmatched bank transactions that require investigation.' .

ind:IoltaInterestRemittance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Iolta Interest Remittance' ;
    rdfs:comment 'Records the periodic remittance of interest earned on pooled IOLTA trust accounts to the designated state IOLTA program or legal aid foundation. Captures remittance period, gross interest earned, bank service charges deducted, net remittance amount, recipient organization, remittance date, payment method, confirmation reference, and IRS Form 1099 reporting flag. Mandatory compliance record under IOLTA program rules in all US jurisdictions.' .

ind:Transfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Transfer' ;
    rdfs:comment 'Records the movement of client funds between trust accounts or between a trust account and the firms operating account upon fee earning. Captures transfer type (inter-trust, trust-to-operating, operating-to-trust top-up), source account, destination account, transfer amount, matter reference, transfer date, authorization reference, and the earned fee invoice linkage when transferring earned fees to operating. Ensures complete audit trail for all inter-account fund movements.' .

ind:RetainerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Retainer Agreement' ;
    rdfs:comment 'Master record for each client retainer arrangement governing the deposit and replenishment of advance funds held in trust. Captures retainer type (evergreen, fixed, security deposit), agreed retainer amount, replenishment threshold, replenishment amount, matter scope, effective date, expiry date, client authorization reference, and current retainer status. Distinct from the billing domains engagement letter — this record governs the fiduciary fund-holding obligation.' .

ind:RetainerReplenishment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Retainer Replenishment' ;
    rdfs:comment 'Transactional record of each request or event triggering a client retainer top-up when the trust balance falls below the agreed replenishment threshold. Captures trigger date, current balance at trigger, required replenishment amount, replenishment request sent date, client response date, receipt date, and status (requested, received, overdue, waived). Supports proactive retainer management and WIP exposure monitoring.' .

ind:EscrowArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Escrow Arrangement' ;
    rdfs:comment 'Master record for escrow accounts established in connection with corporate transactions (M&A, SPA, real estate closings) where the firm acts as escrow agent holding funds pending satisfaction of conditions. Captures escrow purpose, transaction reference, escrow amount, release conditions, release schedule, escrow period start and end dates, counterparty identities, governing escrow agreement reference, and current escrow status. Release events (modeled as detail records within this product) capture: release date, release amount, beneficiary identity, release condition satisfied (description and evidence reference), authorizing parties, payment method, and residual escrow balance post-release. Operationally distinct from general retainer trust accounts. Provides the complete transactional audit trail for escrow fund deposits and distributions.' .

ind:EscrowRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Escrow Release' ;
    rdfs:comment 'Records each release of escrowed funds to a designated beneficiary upon satisfaction of escrow release conditions. Captures release date, release amount, beneficiary identity, release condition satisfied (description and evidence reference), authorizing parties, payment method, and residual escrow balance post-release. Provides the transactional audit trail for escrow fund distributions in M&A and transactional matters.' .

ind:RegulatoryReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Regulatory Report' ;
    rdfs:comment 'Periodic regulatory trust account report submitted to bar associations, the SRA, state law societies, or other oversight bodies as required by jurisdiction-specific trust accounting rules. Captures reporting period, jurisdiction, report type (annual trust account certificate, SRA Accounts Rules compliance report, state bar trust account registration), submission date, submitted by, report status (draft, submitted, acknowledged, queried), and regulatory body acknowledgment reference.' .

ind:AccountAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Account Audit' ;
    rdfs:comment 'Record of internal or external audits conducted on trust accounts including bar association spot examinations, annual external accountant reviews (required in many jurisdictions), and internal compliance audits. Captures audit type, audit period, auditor identity (internal compliance officer or external CPA firm), audit scope, findings summary, deficiency count, remediation required flag, remediation deadline, and audit closure date. Supports regulatory examination readiness.' .

ind:TrustException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Trust Exception' ;
    rdfs:comment 'Operational record of any exception, anomaly, or potential violation identified in trust account management including negative client balances, unidentified receipts, stale disbursements, missing authorizations, reconciliation failures, and AML red flags. Captures exception type, detection date, detection method (automated rule, manual review, reconciliation), severity, assigned investigator, investigation status, resolution action, and resolution date. Critical for regulatory compliance and professional indemnity risk management.' .

ind:UnclaimedFundsRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Unclaimed Funds Record' ;
    rdfs:comment 'Tracks client trust funds that have remained unclaimed or dormant beyond the jurisdiction-mandated dormancy period and are subject to escheatment (abandoned property reporting) to state or government authorities. Captures client identity, matter reference, dormancy start date, dormancy period elapsed, amount subject to escheatment, jurisdiction escheatment rules reference, outreach attempts to locate client, escheatment filing date, and remittance confirmation. Mandatory under state unclaimed property laws.' .

ind:TrustControlTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Trust Control Test' ;
    rdfs:comment 'This association product represents the testing event between trust_account and compliance_control. It captures the execution of a specific compliance control test against a specific trust account, recording test methodology, results, exceptions, and review evidence. Each record links one trust_account to one compliance_control with attributes that exist only in the context of this testing relationship.. Existence Justification: In legal practice, compliance controls are tested across multiple trust accounts as part of regulatory assurance programs (SOX, SRA, IOLTA compliance). Each control (e.g., three-way reconciliation, dual authorization, segregation of duties) is executed and tested against multiple trust accounts, and each trust account is subject to multiple controls. The business actively manages control testing as a distinct operational activity, recording test-specific evidence, results, exceptions, and remediation for each control-account combination.' .

ind:ReconciliationPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trust ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'Master reference table for reconciliation_period. Referenced by reconciliation_period_id.' .

ind:KnowledgeAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Knowledge Asset' ;
    rdfs:comment 'Unified master catalog and registry of all knowledge assets managed within the knowledge domain, serving as the single entry point for cross-asset search, governance, analytics, and contribution tracking regardless of asset type. Each type-specific product (precedent, practice_note, clause, form_template, checklist, research_memo) holds a foreign key to this catalog. Captures asset type, source system (iManage, NetDocuments, Practical Law, LexisNexis), access classification (restricted/confidential/internal/public), LPP flag, retention schedule, lifecycle status, and full contribution workflow (contributor timekeeper reference, asset type submitted, submission date, reviewer assignment, review status, approval/rejection outcome, CPD/CLE credit eligibility, contribution history). Enables NLP-driven retrieval, knowledge contribution governance, and portfolio-level analytics.' .

ind:AssetUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Asset Usage' ;
    rdfs:comment 'Transactional record capturing every instance a knowledge asset is accessed, downloaded, adapted, cited, or linked within a matter or document. Tracks timekeeper, matter reference, asset reference, usage type (view, download, adapt, cite, apply), timestamp, source system, relevance rating, and linking context. Enables usage analytics for knowledge asset curation prioritization, matter-level knowledge reuse tracking, post-matter knowledge harvesting, and ROI measurement of knowledge investments.' .

ind:PrecedentUpdate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Precedent Update' ;
    rdfs:comment 'Tracks the lifecycle of precedent review and update events, capturing when a precedent was flagged for review, who reviewed it, what changes were made, the triggering event (legislative change, case law development, regulatory update), approval workflow status, and effective date of the updated version. Supports the firms precedent governance and currency management obligations.' .

ind:Contribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Contribution' ;
    rdfs:comment 'Records individual attorney and staff contributions to the firms knowledge base including submission of new precedents, practice notes, research memos, and clause variants for peer review and approval. Captures contributor timekeeper reference, asset type submitted, submission date, review status, reviewer assignment, approval or rejection outcome, and CPD/CLE credit eligibility. Supports Knowledge Management and Precedent Tracking and attorney development programs.' .

ind:ResearchRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Research Request' ;
    rdfs:comment 'Formal legal research requests submitted by attorneys or clients to the research services team or library. Captures requesting attorney, matter reference, research question, jurisdiction, urgency level, assigned researcher, LexisNexis or Practical Law platform used, delivery deadline, completion status, and resulting research memo reference. Supports Legal Research and Analysis and Matter Management processes.' .

ind:ExternalSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'External Source' ;
    rdfs:comment 'Master registry of external knowledge platforms, databases, and subscription services integrated into the firms knowledge ecosystem. Captures source name (LexisNexis, Thomson Reuters Practical Law, Westlaw, PACER, ICC, LCIA), source type, subscription tier, coverage jurisdictions, content categories, API integration status, contract renewal date, and cost centre allocation. Supports knowledge sourcing governance and vendor management.' .

ind:LegalUpdate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Legal Update' ;
    rdfs:comment 'Tracks legislative, regulatory, and case law developments that trigger review or amendment of the firms knowledge assets. Captures update type (statute amendment, new regulation, landmark judgment, regulatory guidance), jurisdiction, effective date, impacted practice areas, source citation (LexisNexis, Practical Law, official gazette), assigned knowledge manager, review status, and linked precedents or practice notes requiring update. Supports proactive knowledge currency management.' .

ind:ImpactAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'This association product represents the impact assessment workflow between legal_update and practice_note. It captures the knowledge management process of evaluating and tracking how legislative, regulatory, and case law developments affect specific practice notes. Each record links one legal_update to one practice_note with workflow attributes that exist only in the context of this impact relationship, including review priority, status tracking, and action documentation.. Existence Justification: In legal knowledge management operations, a single legal update (statute amendment, new regulation, landmark judgment) routinely impacts multiple practice notes across different practice areas and jurisdictions, and conversely, a single practice note may require review and amendment in response to multiple legal developments over time. The firm actively manages this many-to-many relationship through a formal impact assessment workflow where knowledge managers evaluate each legal_update-practice_note pair, assign review priorities, track review status, document specific actions taken, and record which content sections were modified.' .

ind:PrecedentImpactAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Precedent Impact Assessment' ;
    rdfs:comment 'This association product represents the impact assessment and review workflow triggered when a legal update (legislative change, regulatory amendment, or case law development) affects one or more precedent documents. It captures the knowledge management teams evaluation of each precedent-update pair, including impact severity, review priority, workflow status, actions taken, and completion tracking. Each record links one precedent to one legal update with attributes that exist only in the context of this specific impact relationship.. Existence Justification: In legal knowledge management operations, a single legal update (legislative change, new regulation, or case law development) routinely impacts multiple precedent documents across different practice areas, and conversely, a single precedent document is impacted by multiple legal updates over its lifecycle. The knowledge management team actively manages each precedent-update pair through a formal impact assessment workflow with distinct status tracking, priority assignment, and remediation actions.' .

ind:ControlMapping rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Control Mapping' ;
    rdfs:comment 'This association product represents the control relationship between knowledge assets and risk categories in the firms integrated risk management and knowledge governance framework. It captures which knowledge assets (precedents, templates, checklists, practice notes) serve as controls or mitigations for specific risk categories (professional indemnity, data privacy, conflicts, AML). Each record links one knowledge asset to one risk category with attributes that document control effectiveness, deployment patterns, and compliance mapping required for ISO 27001, professional indemnity audits, and regulatory risk reporting.. Existence Justification: In legal risk management, a single knowledge asset (e.g., conflicts of interest checklist) serves as a control for multiple risk categories (conflict of interest risk, reputational risk, regulatory breach risk), and conversely, a single risk category (e.g., data breach risk) is mitigated by multiple knowledge assets (data processing agreement template, data retention checklist, breach response playbook, encryption policy). Risk managers actively maintain a control matrix mapping which assets control which risks, with effectiveness ratings, deployment patterns, and compliance references required for ISO 27001 certification and professional indemnity audits.' .

ind:PrecedentRiskMitigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Precedent Risk Mitigation' ;
    rdfs:comment 'This association product represents the risk mitigation relationship between precedent documents and risk categories. It captures which precedent documents (templates, clauses, agreements) are designed to mitigate which specific risk categories, along with the effectiveness of that mitigation, clause coverage metrics, and usage tracking. Each record links one precedent to one risk category with attributes that exist only in the context of this mitigation relationship. This mapping is actively used in matter risk profiling workflows, precedent approval processes, and knowledge management governance to ensure precedents adequately address firm risk exposure.. Existence Justification: In legal services firms, precedent documents (templates, agreements, clauses) are explicitly designed to mitigate multiple risk categories (e.g., a SaaS agreement addresses IP infringement, data breach, and payment default risks), and each risk category is addressed by multiple precedents (e.g., data breach risk is mitigated by DPAs, SaaS agreements, and vendor contracts). Knowledge management teams actively maintain precedent-risk mappings with effectiveness ratings, clause coverage metrics, and usage tracking to support matter risk profiling and precedent approval workflows. This is an operational relationship managed as part of knowledge governance, not an analytical correlation.' .

ind:Precedent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Precedent' ;
    rdfs:comment 'Master repository of approved precedent documents curated by the firms knowledge management team. Captures the canonical version of standard legal documents (e.g., SPA, NDA, LOE templates) sourced from iManage Work and Thomson Reuters Practical Law, including practice area classification, jurisdiction applicability, approval status, LPP flags, version lineage, and full update/review history (triggering events, reviewer, changes made, approval workflow status, effective dates of updated versions). Each precedent holds a foreign key to knowledge_asset for unified cross-asset catalog governance. Serves as the SSOT for reusable document templates, their currency governance, and their complete amendment lifecycle across all practice groups.' .

ind:PracticeNote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Practice Note' ;
    rdfs:comment 'Authoritative internal and externally sourced practice notes providing legal guidance on specific topics, statutes, regulations, and procedural requirements. Integrates content from Thomson Reuters Practical Law and LexisNexis. Tracks authorship, practice area, jurisdiction, currency date, review cycle, and NLP-extracted topic tags. Each practice note links to a knowledge_asset catalog entry for unified cross-asset governance. Supports Legal Research and Analysis and Regulatory Compliance Counseling processes.' .

ind:Clause rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Clause' ;
    rdfs:comment 'Structured repository of standard and negotiated contract clauses maintained by the firms knowledge management and CLM teams. Each clause record captures clause type (e.g., indemnity, limitation of liability, governing law), jurisdiction, practice area, approved variants, fallback positions, and NLP-extracted semantic tags. Each clause links to a knowledge_asset catalog entry for unified cross-asset governance. Supports Document Drafting and Review and Contract Lifecycle Management processes.' .

ind:FormTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Form Template' ;
    rdfs:comment 'Library of standardized legal forms, court filing templates, regulatory submission forms, and transactional forms used across practice groups. Each record represents a specific form capturing form type, applicable jurisdiction, court or tribunal, regulatory body, version, effective date, expiry date, filing instructions, and associated procedural requirements. Sourced from ECF/PACER integrations and internal DMS (iManage Work / NetDocuments). Each form links to a knowledge_asset catalog entry for unified cross-asset governance. Supports litigation filing, regulatory submissions, and transactional document assembly.' .

ind:Checklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Checklist' ;
    rdfs:comment 'Structured task and due-diligence checklists used across practice areas including M&A due diligence, regulatory compliance, IP prosecution, and litigation readiness. Each checklist record captures the checklist type, practice area, jurisdiction, associated matter type, step sequence, mandatory vs. optional flags, and Thomson Reuters Practical Law source reference. Each checklist links to a knowledge_asset catalog entry for unified cross-asset governance. Supports Matter Management and Case Administration.' .

ind:ResearchMemo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Research Memo' ;
    rdfs:comment 'Legal research memoranda produced by attorneys and paralegals capturing analysis of case law, statutes, regulations, and secondary sources. Tracks author, supervising attorney, matter association, research question, jurisdiction, LexisNexis and Westlaw source citations, LPP classification, confidentiality level, and NLP-extracted key legal concepts. Each memo links to a knowledge_asset catalog entry for unified cross-asset governance. Supports Legal Research and Analysis and Knowledge Management and Precedent Tracking processes.' .

ind:Taxonomy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Knowledge ;
    rdfs:label 'Taxonomy' ;
    rdfs:comment 'Hierarchical taxonomy governing the classification of all knowledge assets within the firm. Defines practice area nodes, sub-practice nodes, jurisdiction nodes, matter type nodes, and topic tags used for NLP-driven retrieval and knowledge graph navigation. Managed by the Knowledge Management team and applied consistently across precedents, practice notes, clause libraries, and research memos.' .

ind:Organisation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Organisation' ;
    rdfs:comment 'Master record for all corporate, government, and institutional client entities served by the firm. Captures the legal entity name, registration number, jurisdiction of incorporation, entity type (corporation, partnership, government agency, NGO), industry sector, SIC/NAICS code, parent organisation reference, ultimate beneficial owner flags, public/private status, listed exchange, regulatory identifiers (LEI, DUNS), AML risk tier, KYC status, and relationship inception date. Serves as the B2B anchor entity for all matter, billing, and conflict-check relationships. Sourced primarily from Elite 3E client/matter management and Intapp Conflicts.' .

ind:Individual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Individual' ;
    rdfs:comment 'Master record for natural-person clients including individual (B2C) clients, sole traders, high-net-worth individuals, and personal-capacity contacts who engage the firm directly. Stores salutation, full legal name, preferred name, date of birth, nationality, country of domicile, tax identification number, PII classification flags, LPP status, politically exposed person (PEP) flag, sanctions screening status, preferred language, and communication preferences. Distinct from the organisation entity; supports B2C practice areas such as employment law, estate planning, and personal injury. Sourced from Elite 3E and Microsoft Dynamics 365 CRM.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Unified client identity record serving as the firms Single Source of Truth for client master data across all practice areas and systems. Stores the canonical client_number (firm-assigned), client type (corporate, government, individual, prospective), client status (active, inactive, prospect, former, suspended), references to organisation or individual entity, originating partner, responsible relationship partner, primary practice area, client tier (platinum, gold, silver), AFA eligibility flag, preferred billing currency, billing address reference, client segment assignment, and date of first engagement. Acts as the central hub entity linking to KYC records, engagement scope, relationship teams, corporate hierarchies, and all matter/billing/conflict relationships. Every system interaction with a client resolves through this record. Sourced from Elite 3E client master.' .

ind:ClientContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Contact' ;
    rdfs:comment 'Individual persons who serve as points of contact, authorised representatives, or signatories for organisation and individual client relationships. Captures contact full name, job title, department, direct phone, mobile, email, preferred communication channel, contact role (primary, billing, legal, signatory, authorised representative, in-house counsel), active flag, LinkedIn/professional profile URL, and PEP/sanctions screening status. A single organisation may have multiple contacts across different roles; a contact may be associated with multiple organisations (e.g., in-house counsel moving between clients). Critical for conflict checking (contacts as parties), engagement letter execution (signatories), and day-to-day matter communication. Sourced from Microsoft Dynamics 365 CRM and Elite 3E.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Address' ;
    rdfs:comment 'Multi-purpose address registry for all client-domain entities (organisations, individuals, client profiles). Captures address type (registered office, principal place of business, billing, correspondence, service of process), address lines 1-3, city, state/province, postal code, country ISO code, geocode coordinates, postal validation status, effective date, and expiry date. Supports temporal address tracking for regulatory purposes (service of process requires historical accuracy) and multi-address clients. Critical for billing address resolution, court filing service addresses, and regulatory jurisdiction determination. Sourced from Elite 3E and Microsoft Dynamics 365.' .

ind:CorporateHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Corporate Hierarchy' ;
    rdfs:comment 'Models the parent-subsidiary and affiliated-entity relationships within a corporate client group. Captures parent organisation, child organisation, relationship type (wholly owned subsidiary, majority-owned, minority stake, affiliate, joint venture, branch), ownership percentage, effective date, expiry date, jurisdiction of the relationship, and consolidation flag. Critical for conflict-of-interest checking (Intapp Conflicts), matter origination, and group-level billing arrangements. Enables traversal of the full corporate family tree for AML/KYC and engagement scope purposes.' .

ind:KycRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Kyc Record' ;
    rdfs:comment 'Complete KYC/AML due diligence dossier for each client, structured as a header (review assessment) with child document lines. Header captures: KYC review date, reviewer identity, KYC tier (standard, enhanced, simplified), AML risk rating (low, medium, high, prohibited), source of funds verification status, beneficial ownership verification status, sanctions screening result, PEP screening result, next review due date, and KYC expiry date. Child document lines track each supporting document (certificates of incorporation, passports, utility bills, beneficial ownership registers, sanctions clearance certificates) with document type, issuing authority, reference number, issue/expiry dates, verification method (original, certified copy, electronic), verifying officer, DMS storage reference (iManage document_id), and document status (pending, verified, expired, rejected). This product is the SINGLE authoritative owner of all KYC document metadata within the client domain. Each client profile has one active KYC dossier; historical records retained for regulatory audit. Supports FATF, AML, SRA, and GDPR compliance obligations. Sourced from Intapp Conflicts and firm compliance workflows.' .

ind:KycDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Kyc Document' ;
    rdfs:comment 'Tracks individual KYC/AML supporting documents submitted by or on behalf of a client, such as certificates of incorporation, passports, utility bills, beneficial ownership registers, and sanctions clearance certificates. Captures document type, issuing authority, document reference number, issue date, expiry date, verification method (original, certified copy, electronic), verification date, verifying officer, document storage reference (iManage DMS link), and document status (pending, verified, expired, rejected). Supports regulatory audit trails for SRA, FATF, and GDPR compliance.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Reference master defining the firms client segmentation taxonomy used for relationship management, pricing strategy, rate card selection, and business development targeting. Each segment record captures segment code, segment name (e.g., Global 500, Mid-Market Corporate, Government & Public Sector, High Net Worth Individual, Start-up & Emerging Growth), segment description, applicable practice areas, minimum revenue threshold, preferred AFA types, assigned BD team, segment review cycle, and segment-level discount authority. Segments drive rate card selection in Elite 3E, pipeline segmentation in Microsoft Dynamics 365 CRM, and partner compensation allocation. Maintained by the firms pricing and BD leadership; changes require partnership approval. Typically 8-15 active segments at any time.' .

ind:RelationshipTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Relationship Team' ;
    rdfs:comment 'Defines the firm-side relationship team assigned to a client, capturing the client relationship partner (CRP), originating partner, supervising partner, relationship manager, business development manager, and supporting fee earners. Stores role type, assignment start date, assignment end date, primary contact flag, and notification preferences. Supports RPE/PPP reporting, client satisfaction tracking, and BD pipeline management in Microsoft Dynamics 365. Enables accountability and escalation routing for client service delivery.' .

ind:ClientEngagementScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Engagement Scope' ;
    rdfs:comment 'Defines the agreed scope of legal services the firm is authorised to provide to a client, as established at the client level (above individual matters). Captures authorised practice areas, geographic jurisdictions covered, excluded services, panel appointment reference, panel start date, panel expiry date, preferred counsel designation, rate card reference, AFA framework type, and scope approval date. Distinct from matter-level engagement letters (owned by the contract domain); this is the client-level standing authority. Sourced from Elite 3E and contract/CLM systems.' .

ind:ClientStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Status History' ;
    rdfs:comment 'Audit trail of all status transitions for a client profile over its lifecycle, capturing previous status, new status, change reason code, change date, changed by (user), approving partner, and any supporting notes. Tracks transitions such as prospect-to-active, active-to-suspended (e.g., due to KYC failure or sanctions hit), and active-to-former. Supports regulatory audit requirements (SRA, GDPR), conflict-check history, and client lifecycle analytics. Ensures full traceability of client standing changes.' .

ind:BeneficialOwner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Beneficial Owner' ;
    rdfs:comment 'Records the ultimate beneficial owners (UBOs) of corporate client entities as required by AML/KYC regulations (FATF, EU 4th/5th AML Directives, FinCEN). Captures UBO full name, date of birth, nationality, country of residence, ownership percentage, nature of control (direct shareholding, indirect, voting rights, other significant influence), PEP status, sanctions status, verification date, and verification method. Linked to the organisation master and KYC record. Supports SRA and FATF beneficial ownership disclosure obligations.' .

ind:OutsideCounselGuideline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Outside Counsel Guideline' ;
    rdfs:comment 'Consolidated record of all client service delivery requirements, encompassing both formal outside counsel guidelines (OCGs) and operational service preferences. For OCGs: captures guideline version, effective date, expiry date, billing rate caps, staffing restrictions, budget approval thresholds, e-billing platform mandate, UTBMS task code requirements, diversity reporting obligations, travel and expense policy, and acceptance status. For operational preferences: captures preferred billing format (LEDES, PDF, e-billing portal), invoice delivery method, reporting frequency, matter update preferences, preferred communication channel, language preference, data residency requirements, and sustainability reporting flags. Represents the complete how to serve this client specification that governs matter staffing, billing, and reporting. Sourced from Elite 3E billing preferences, Microsoft Dynamics 365 CRM, and client-issued OCG documents.' .

ind:CreditStanding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Credit Standing' ;
    rdfs:comment 'Tracks the credit and financial standing of a client for billing risk management purposes. Captures credit limit, current WIP exposure, outstanding AR balance, credit rating (internal tier: A, B, C, D), payment terms (net 30, net 60, retainer-based), retainer balance, last payment date, average days to pay, credit hold flag, credit hold reason, credit review date, and credit approving partner. Sourced from Elite 3E AR and billing modules and Aderant Expert collections. Supports prebilling decisions, retainer top-up triggers, and collections escalation.' .

ind:ServiceEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Service Engagement' ;
    rdfs:comment 'This association product represents the contractual engagement between a client and a specific legal service offering. It captures the terms, pricing, scope, and lifecycle of each service engagement. Each record links one client to one legal service with attributes that exist only in the context of this specific engagement relationship, including negotiated rates, service-level agreements, approval workflows, and engagement-specific scope definitions.. Existence Justification: In legal services, clients engage multiple legal services simultaneously (a corporate client may have active M&A, litigation, IP, and employment law engagements), and each legal service offering is delivered to multiple clients concurrently. The relationship between client and service is not a simple reference but a managed engagement with specific terms, negotiated rates, service-level agreements, scope definitions, and lifecycle tracking from proposal through delivery to completion.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'This association product represents the subscription contract between client_profile and service_package. It captures the commercial terms, pricing, and lifecycle status of each clients subscription to a specific service package. Each record links one client to one service package with subscription-specific attributes including pricing overrides, discount terms, renewal status, and usage tracking that exist only in the context of this subscription relationship. This is the SSOT for all active and historical client-package subscription relationships enabling recurring revenue management, renewal forecasting, and cross-sell analytics.. Existence Justification: In legal services, clients routinely subscribe to multiple service packages simultaneously (e.g., a corporate client may have an ongoing compliance retainer, an IP portfolio management package, and a regulatory advisory package). Conversely, each service package is sold to multiple clients with client-specific pricing, discount terms, renewal cycles, and usage patterns. The subscription relationship is actively managed by relationship partners who negotiate pricing, track renewals, monitor usage, and identify cross-sell opportunities.' .

ind:DocumentAccess rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Document Access' ;
    rdfs:comment 'This association product represents the access grant between contact and legal_document. It captures the sharing, permission, and access control relationship when legal documents are shared with client contacts through client portals or matter management systems. Each record links one contact to one legal_document with attributes that exist only in the context of this access relationship, including who shared it, when access was granted, permission levels, and expiration dates.. Existence Justification: In legal practice, document sharing and access control is a core operational process managed through client portals and document management systems. A single legal document (contract, brief, disclosure) is routinely shared with multiple client contacts (in-house counsel, compliance officers, business stakeholders, signatories) with different permission levels and access windows. Conversely, each contact accesses many documents across multiple matters over time. The firm actively manages these access grants—creating them when documents are shared, tracking who accessed what and when, setting expiration dates for sensitive documents, and revoking access when matters close or contacts leave client organizations.' .

ind:KycDocumentVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Kyc Document Verification' ;
    rdfs:comment 'This association product represents the verification relationship between KYC reviews and supporting legal documents. It captures which documents satisfy which KYC requirements, the verification status of each document within the context of a specific KYC review, verification dates, expiry tracking, and the reviewer responsible. Each record links one KYC dossier to one supporting document with attributes that exist only in the context of this compliance verification relationship.. Existence Justification: In legal practice, a single KYC review dossier requires multiple supporting documents (passport, utility bill, incorporation certificate, beneficial ownership register, financial statements), and a single document (such as audited financials or a corporate registry extract) can legitimately support multiple KYC reviews across related entities (parent/subsidiary relationships) or periodic renewals for the same client. Compliance teams actively manage which documents satisfy which KYC requirements, track verification status per document-per-review, and monitor expiry dates for periodic re-verification.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master reference table for vendor. Referenced by vendor_id.' .

ind:Tribunal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Tribunal' ;
    rdfs:comment 'Master record for every court, tribunal, arbitral body, and ADR forum the firm interacts with. Captures the official name, jurisdiction level (federal, state, appellate, international), court type (district, circuit, chancery, arbitration panel, ICC, LCIA), geographic jurisdiction, ECF/PACER enrollment status, filing system credentials reference, and operational status. Serves as the authoritative SSOT for court identity across the litigation and dispute resolution practice.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference catalog of legal jurisdictions — federal circuits, state/provincial courts, international arbitral seats, and regulatory jurisdictions. Stores jurisdiction code, governing law system (common law, civil law, mixed), geographic region, applicable rules of civil procedure, statute of limitations defaults, and treaty memberships (e.g., New York Convention for arbitration enforcement). Used to classify matters, filings, and judgments by controlling law.' .

ind:Judge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Judge' ;
    rdfs:comment 'Master record for judicial officers, arbitrators, and mediators before whom the firm appears. Captures full name, title, court assignment, chamber details, appointment date, judicial philosophy notes, recusal history flags, ADR certification type, and preferred filing/communication protocols. Supports conflict screening, appearance preparation, and relationship intelligence for litigation strategy.' .

ind:Docket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Docket' ;
    rdfs:comment 'Official docket record linking a matter to a specific court or tribunal. Stores the court-assigned docket number, case caption, filing date, case type (civil, criminal, appellate, arbitration), assigned judge reference, case status (active, stayed, closed, appealed), PACER case ID for federal matters, ECF registration status, and next scheduled event date. Acts as the operational hub for all court-side activity on a matter.' .

ind:Hearing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Hearing' ;
    rdfs:comment 'Transactional record of each scheduled or completed court hearing, conference, or oral argument. Captures hearing type (status conference, motion hearing, trial, deposition, arbitration session), scheduled date and time, courtroom or virtual platform, presiding judge, duration, outcome summary, continuance flag, and appearance requirements. Feeds the firm-wide court calendar and attorney appearance tracking workflows.' .

ind:Appearance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Appearance' ;
    rdfs:comment 'Records each attorney appearance at a court proceeding, arbitration session, or ADR hearing. Stores timekeeper reference, docket reference, hearing reference, appearance type (lead counsel, co-counsel, local counsel, observer), pro hac vice status, bar admission jurisdiction, appearance date, outcome notes, and time spent. Supports billing verification, court-mandated appearance reporting, and attorney utilization analytics.' .

ind:Filing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Filing' ;
    rdfs:comment 'Transactional record of every document filed with a court, tribunal, or arbitral body. Captures filing type (complaint, motion, brief, answer, notice, order, judgment), filing date/time, ECF confirmation number, PACER transaction ID, filed-by attorney, filing fee amount, service method, acceptance status (accepted, rejected, pending), and deadline compliance flag. Links to document management for source document reference and supports cost recovery allocation for client billing.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Order' ;
    rdfs:comment 'Records judicial orders, rulings, and decisions issued in connection with a docket. Captures order type (procedural, substantive, consent, default, summary judgment, injunction), issue date, issuing judge, order text summary, compliance deadline, appeal deadline, enforcement status, and whether the order is published or unpublished. Distinct from filed documents — this is the authoritative record of what the court has directed.' .

ind:CourtRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Court Rule' ;
    rdfs:comment 'Reference catalog of procedural rules, local rules, standing orders, and practice directions applicable to each court or tribunal. Stores rule code, rule title, effective date, expiry date, court reference, rule category (filing, service, discovery, evidence, scheduling), page/word limits, mandatory form references, and electronic filing requirements. Enables automated deadline calculation and filing compliance checks.' .

ind:Judgment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Judgment' ;
    rdfs:comment 'Records final judgments, decrees, and court-entered settlements in litigated matters. Stores judgment type (default, consent, summary, trial verdict, appellate), entry date, court reference, docket reference, judgment amount, currency, prevailing party, interest rate, cost award, appeal deadline, satisfaction date, and enforcement status. Distinct from court_order — judgments are final dispositions that close or substantially resolve a docket.' .

ind:Appeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Appeal' ;
    rdfs:comment 'Tracks appellate proceedings initiated from a lower court judgment or order. Records appeal type (interlocutory, final judgment, certiorari petition), appellate court reference, lower court docket reference, notice of appeal filing date, appellant and appellee parties, briefing schedule deadlines, oral argument date, appellate decision date, outcome (affirmed, reversed, remanded, dismissed), and further appeal options. Supports multi-level litigation lifecycle management.' .

ind:Matter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter' ;
    rdfs:comment 'Core master record for every legal matter and case managed by the firm. Represents the central hub of the matter domain, capturing the full lifecycle from inception to closure. Stores matter number, matter name, practice group, matter type (litigation, transactional, advisory, IP, regulatory), open date, close date, status (active, suspended, closed, archived), responsible attorney, supervising partner, originating attorney, billing attorney, office, jurisdiction, governing law, matter description, LPM classification, budget amount, estimated hours, risk rating, confidentiality flag, LPP flag, and LEDES matter category. Sourced primarily from Elite 3E Client/Matter Management module.' .

ind:Phase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Defines the structured phases within a matter lifecycle used for LPM (Legal Project Management) and UTBMS-aligned task budgeting. Each phase record captures phase code, phase name (e.g., Pleadings, Discovery, Trial, Closing), sequence order, estimated hours, budgeted fees, actual hours to date, phase status, start date, target end date, and actual end date. Enables phase-level budget vs. actual tracking and milestone management across litigation and transactional matters.' .

ind:Task rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Task' ;
    rdfs:comment 'Granular task records within a matter phase, aligned to UTBMS task codes for structured billing and LPM tracking. Captures task code, task name, task description, assigned timekeeper, estimated hours, actual hours, task status (open, in-progress, complete, deferred), due date, completion date, priority level, and billable flag. Supports matter budgeting, workload distribution, and LEDES-compliant billing narratives. Sourced from Elite 3E task management and LPM workflow modules.' .

ind:MatterStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Status History' ;
    rdfs:comment 'Immutable audit log of all matter status transitions throughout the matter lifecycle. Records each status change event including prior status, new status, effective date and timestamp, reason for change, changed by user, and any associated notes. Supports compliance reporting, matter lifecycle analytics, and regulatory audit requirements. Captures transitions such as active→suspended, active→closed, closed→reopened.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Team' ;
    rdfs:comment 'Association entity capturing the assignment of timekeepers and staff to a matter, representing the matter team roster. Records timekeeper role on the matter (responsible attorney, supervising partner, associate, paralegal, billing attorney, originating attorney, co-counsel), assignment start date, assignment end date, billing rate override, hours cap, and active flag. Enables matter-level staffing management, rate governance, and workload reporting. Sourced from Elite 3E and Aderant Expert timekeeper-matter assignment modules.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Formal matter budget, fee arrangement, and rate governance record serving as the single source of truth for all financial planning, approved fee budgets, cost budgets, and matter-level billing rate agreements. Supports AFA (Alternative Fee Arrangement) and hourly billing models. Stores budget type (total fees, phase fees, disbursements, total matter), budget amount, currency, approved date, approved by, budget version, budget status (draft, approved, revised, closed), AFA type (fixed fee, capped fee, blended rate, contingency, success fee), variance threshold percentage. Includes comprehensive rate schedule management: timekeeper role, individual timekeeper reference, rate type (standard, agreed, AFA blended, pro bono), hourly rate amount, rate currency, effective date, expiry date, rate approval status, client-agreed flag, rate source (engagement letter, rate schedule, court order), and rate version history. Enables WIP monitoring, budget vs. actual reporting, rate card management, client budget compliance, LEDES-compliant billing, rate benchmarking analytics, and accurate WIP valuation. This product is the single home for all matter-level rate governance — there is no separate rate entity. Sourced from Elite 3E and Aderant Expert rate and budget management modules.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Event' ;
    rdfs:comment 'Unified calendar, docket, deadline, and milestone record serving as the single source of truth for ALL time-sensitive events and deadlines associated with a matter. Encompasses court hearings, filing deadlines, statute of limitations dates, court-ordered deadlines, regulatory filing deadlines, contractual notice periods, client meetings, deposition dates, arbitration sessions, transaction closing dates, and internal review milestones. Captures event type (hearing, deadline, meeting, milestone, limitation period, closing, regulatory filing), event subtype for deadline-specific classification (court-ordered, statutory, contractual, regulatory, internal), deadline criticality level (critical/malpractice-risk, high, medium, low), event title, event date and time, location, presiding judge or arbitrator, attendees, court or tribunal reference, docket number, governing rule or statute reference, jurisdiction, responsible timekeeper, escalation flag, reminder lead time, completion status, completion date, and outcome notes. Integrates with court domain docket data and supports litigation calendar management, deadline compliance, malpractice prevention, ECF deadline tracking, transactional closing timeline management, and regulatory filing deadline monitoring. This product subsumes all deadline and limitation period tracking — there is no separate deadline entity.' .

ind:MatterDisbursement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Disbursement' ;
    rdfs:comment 'Records of out-of-pocket costs and disbursements incurred on behalf of a client matter, distinct from fee-based time entries. Captures disbursement type (court filing fees, expert witness fees, travel, courier, process server, transcript costs, eDiscovery processing, search fees, registration fees), vendor name, invoice reference, amount, currency, tax amount, billable flag, write-off flag, reimbursable flag, approval status, incurred date, paid date, and UTBMS expense code. Feeds into WIP and prebilling workflows in Elite 3E and Aderant Expert. Supports cost recovery tracking and client reimbursement management.' .

ind:Counsel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Counsel' ;
    rdfs:comment 'Registry of opposing counsel, co-counsel, local counsel, and third-party legal representatives associated with a matter. Captures counsel role (opposing, co-counsel, local counsel, amicus, intervenor), counsel name, law firm name, bar number, jurisdiction, contact details, representation start date, representation end date, and conflict check reference. Supports conflict-of-interest screening, service of process management, and litigation party tracking. Distinct from the firms own timekeeper assignments captured in matter_team.' .

ind:MatterParty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Party' ;
    rdfs:comment 'All parties to a legal matter beyond the primary client, including adverse parties, co-parties, third parties, intervenors, guarantors, counterparties in transactions, joint venture partners, regulatory bodies, government agencies, and beneficial owners. Captures party name, party type (plaintiff, defendant, counterparty, guarantor, regulator, witness, expert, joint venture partner, licensor, licensee), entity type (individual, corporation, partnership, trust, government), jurisdiction of incorporation or domicile, representation status, party role effective date, party status (active, settled, dismissed, withdrawn), and KYC/AML screening reference. Critical for conflict checking, litigation management, corporate transaction advisory, and regulatory filing party disclosures.' .

ind:Rate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Timekeeper billing rates applicable to a specific matter, capturing matter-level rate agreements that may differ from standard rate schedules. Stores timekeeper role or individual timekeeper reference, rate type (standard, agreed, AFA blended, pro bono), hourly rate amount, currency, effective date, expiry date, rate approval status, client-agreed flag, and rate source (engagement letter, rate schedule, court order). Enables accurate WIP valuation and LEDES-compliant billing. Sourced from Aderant Expert rate management module.' .

ind:MatterRisk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Risk' ;
    rdfs:comment 'Matter-level operational risk register capturing identified risks specific to the conduct and outcome of an individual matter, distinct from enterprise-level risk records owned by the risk domain. Records risk category (professional indemnity exposure, adverse litigation outcome, regulatory sanction, client credit/collection, data breach, LPP waiver, conflict escalation, scope creep), risk description, likelihood rating, impact rating, inherent risk score, residual risk score, mitigation action, risk owner (timekeeper), identified date, next review date, and risk status (open, mitigated, accepted, escalated, closed). Supports the firms professional indemnity insurance reporting, matter-level risk dashboards, and partner risk review meetings. The enterprise risk domain owns firm-wide risk aggregation and risk appetite frameworks.' .

ind:Hold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Hold' ;
    rdfs:comment 'Litigation hold, legal preservation notice, and investigation hold records issued in connection with a matter, capturing ESI (Electronically Stored Information) preservation obligations, eDiscovery scope metadata, and custodian acknowledgement tracking. Records hold type (litigation hold, regulatory hold, internal investigation hold, pre-litigation preservation), hold issuance date, hold custodians (individuals and departments), data categories and sources in scope, collection scope description, data volume estimates, issuing attorney, hold status (active, released, modified, expired), release date and reason, custodian acknowledgement status and date, reminder cadence, eDiscovery vendor reference, and Relativity workspace identifier. Supports eDiscovery readiness, proportionality assessment, ESI protocol compliance, GDPR/DPA data subject request management, and spoliation risk mitigation.' .

ind:CourtFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Court Filing' ;
    rdfs:comment 'Records of court and tribunal filings made in connection with a litigated matter, capturing ECF (Electronic Case Filing) and PACER submission metadata. Stores filing type (complaint, answer, motion, brief, order, judgment, notice of appeal), filing date, filed by, court reference, docket number, filing status (submitted, accepted, rejected, pending), rejection reason, service date, and document reference to iManage Work. Bridges the matter domain with the court domain for litigation workflow management.' .

ind:Outcome rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Records the resolution, disposition, or completion of a matter including case outcomes for litigation (judgment, settlement, dismissal, verdict, consent order), transaction completions (signing, closing, abandonment), advisory deliverables (opinion delivered, memo issued), and regulatory outcomes (approval, denial, conditional approval). Captures outcome type, outcome date, outcome description, financial terms (settlement amount, damages awarded, transaction value), prevailing party, outcome status (preliminary, final, appealed), appeal deadline, satisfaction/compliance date, and lessons learned reference. Supports matter closure workflows, financial reporting of contingent outcomes, win/loss analytics, and practice group performance measurement.' .

ind:Assignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'This association product represents the Assignment between matter and timekeeper. It captures the staffing relationship where timekeepers are assigned to legal matters in specific roles (responsible attorney, supervising partner, billing attorney, associate, paralegal, etc.) with role-specific billing rates, time allocation budgets, and assignment lifecycle tracking. Each record links one matter to one timekeeper with attributes that exist only in the context of this specific assignment, enabling matter staffing management, resource allocation, billing rate overrides, and workload tracking across the firm.. Existence Justification: In legal practice, matters routinely require multiple timekeepers working in different roles (responsible attorney, supervising partner, associates, paralegals, legal assistants), and timekeepers work on multiple matters concurrently. The matter product already contains four separate FK attributes pointing to timekeeper for specific roles (attorney_profile_id, supervising_partner_attorney_profile_id, originating_attorney_attorney_profile_id, billing_attorney_attorney_profile_id), which is a classic anti-pattern indicating that a proper M:N association is needed. The detection reasoning explicitly states this is already modeled via matter_team and matter_assignment junction tables, confirming the business recognizes this as an operational M:N relationship.' .

ind:MatterContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Contact' ;
    rdfs:comment 'This association product represents the Role-based assignment between contact and matter. It captures the participation of client contacts in legal matters across multiple functional roles (billing, technical, signatory, decision-maker). Each record links one contact to one matter with attributes that exist only in the context of this relationship, including role on matter, notification preferences, authorization levels, and assignment lifecycle dates.. Existence Justification: In legal practice operations, a single client contact participates in multiple matters simultaneously (e.g., a General Counsel oversees 20+ active matters across different practice areas), and each matter involves multiple client contacts serving different functional roles (billing contact, technical SME, signatory, decision-maker, witness). Law firms actively manage these matter-contact assignments as a distinct operational concept with role-specific attributes, authorization levels, notification preferences, and lifecycle tracking (assignment start/end dates).' .

ind:HoldCustodian rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Hold Custodian' ;
    rdfs:comment 'This association product represents the assignment of a litigation hold or preservation notice to a specific party who serves as a custodian of potentially relevant ESI (Electronically Stored Information). Each record links one matter_hold to one matter_party (in custodian role) with attributes that track the custodians acknowledgement status, data preservation obligations, collection progress, and compliance with the hold notice. This is a core eDiscovery workflow entity that supports spoliation risk mitigation, proportionality assessment, and regulatory compliance tracking.. Existence Justification: In legal eDiscovery practice, litigation holds are issued to multiple custodians (parties who control potentially relevant ESI), and each custodian may be subject to multiple holds across different matters. Law firms actively manage hold-custodian assignments as distinct operational records, tracking each custodians acknowledgement, data sources, collection status, and compliance obligations. This is not a reference lookup—it is a managed workflow with specialized hold management systems (like Zapproved, Exterro, or Relativity Legal Hold) that track the many-to-many relationship between holds and custodians.' .

ind:JurisdictionPracticeCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Jurisdiction Practice Coverage' ;
    rdfs:comment 'This association product represents the operational coverage matrix between jurisdictions and practice areas. It captures the firms ability to practice in each jurisdiction-practice area combination, including admission requirements, local counsel needs, and practice restrictions. Each record links one jurisdiction to one practice area with regulatory and operational attributes that exist only in the context of this specific combination.. Existence Justification: Law firms operate across multiple jurisdictions and offer multiple practice areas, creating a true many-to-many operational matrix. A single jurisdiction (e.g., New York State Court) supports many practice areas (M&A, Litigation, IP, Employment), and a single practice area (e.g., Securities Litigation) is practiced across many jurisdictions (federal circuits, state courts, international tribunals). The firm actively manages this coverage matrix to determine matter acceptance, staffing requirements, and local counsel needs.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'This association product represents the Risk Assessment between matter and risk_category. It captures the firms evaluation of each risk categorys applicability and exposure level for each legal matter. Each record links one matter to one risk_category with assessment scores, dates, and review status that exist only in the context of this specific matter-risk combination.. Existence Justification: Legal firms operationally assess each matter against multiple risk categories (cybersecurity, AML, professional indemnity, reputational, data privacy, etc.) as part of their risk management and professional indemnity insurance compliance processes. Each matter-risk combination requires its own assessment with matter-specific inherent and residual risk scores, assessment dates, review cycles, mitigation plans, and risk owners. Risk managers and partners actively create, update, and review these assessments throughout the matter lifecycle.' .

ind:Assertion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Assertion' ;
    rdfs:comment 'This association product represents the assertion of a specific intellectual property asset (patent, trademark, or other IP) within a specific court docket. It captures the operational reality of IP litigation where multiple patents may be asserted in a single case, and a single patent may be asserted across multiple cases. Each record links one docket to one IP asset with attributes that exist only in the context of this specific assertion, including which claims are asserted, invalidity defenses raised, damages theories, and settlement allocations.. Existence Justification: Patent litigation routinely involves multiple patents asserted in a single case (one docket references many IP assets) and individual patents asserted across multiple cases (one IP asset is referenced in many dockets). The business actively manages assertion-specific data including which claims are asserted, invalidity defenses per patent-case pair, damages allocation per patent, and settlement apportionment. This is a core operational relationship in IP litigation practice.' .

ind:LateralConflict rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Lateral Conflict' ;
    rdfs:comment 'This association product represents the conflict relationship between current firm matters and lateral hire candidate prior matters. It captures the specific conflict analysis performed during lateral attorney screening, documenting which prior matters from the candidates former firm create conflicts with which current firm matters. Each record links one current matter to one lateral screening with attributes that describe the nature, severity, and mitigation requirements of the specific conflict relationship.. Existence Justification: In legal lateral hire screening, a single lateral candidate may have worked on multiple prior matters at their former firm, each of which may conflict with multiple current firm matters. Conflicts counsel maintain a matter-to-matter conflict matrix where each prior matter is analyzed against each potentially conflicting current matter. The business actively manages this many-to-many relationship, tracking the specific nature of each conflict (adverse party, co-counsel, confidential information overlap), severity level, required mitigation measures, and client consent status for each matter pair.' .

ind:MatterControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Matter ;
    rdfs:label 'Matter Control' ;
    rdfs:comment 'This association product represents the implementation and testing of specific risk controls within the context of individual legal matters. It captures the matter-specific application of enterprise risk controls, including control effectiveness ratings, test results, evidence references, and responsible timekeepers for each matter-control pairing. Each record links one matter to one risk control with attributes that exist only in the context of this relationship, enabling matter-level control dashboards and ISO 27001/SRA compliance tracking at the engagement level.. Existence Justification: In legal practice, matters require implementation of multiple risk controls (conflict checks, data protection protocols, billing compliance, privilege management, confidentiality safeguards), and each enterprise risk control is applied across many matters with matter-specific testing, effectiveness ratings, and evidence collection. Law firms actively manage matter-level control dashboards for ISO 27001 certification and SRA compliance reviews, tracking which controls are implemented per engagement, test results, responsible timekeepers, and remediation status. This is an operational many-to-many relationship where the business manages matter-control pairings as distinct compliance records.' .

ind:LegalDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Legal Document' ;
    rdfs:comment 'Master record for every legal document managed within the firms DMS (iManage Work, NetDocuments). Captures document identity, classification, matter association, author, version lineage, LPP/privilege status, retention schedule, and chain-of-custody provenance. Serves as the authoritative SSOT for all document metadata across the document lifecycle from drafting through archival.' .

ind:DocVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Version' ;
    rdfs:comment 'Tracks every version of a legal document stored in the DMS including full content metadata. Records version number, author, timestamp, change summary, check-in/check-out state, file format, file size, whether the version is the current authoritative copy, and any OCR/NLP processing outputs (extracted text, confidence score, extraction engine, language detected). Supports full version lineage, rollback capability, full-text search enablement, and TAR model training — all required for LPP compliance and eDiscovery chain-of-custody.' .

ind:DocType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Type' ;
    rdfs:comment 'Reference classification of legal document types used across the firm (e.g., NDA, SPA, POA, LOE, pleading, brief, affidavit, court order, patent application, trademark filing, board resolution, engagement letter). Includes UTBMS task code alignment, retention category, and default privilege classification. Governs document naming conventions and DMS folder taxonomy.' .

ind:DocFolder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Folder' ;
    rdfs:comment 'Represents the DMS folder and workspace hierarchy within iManage Work and NetDocuments. Captures workspace name, matter or client association, folder path, parent folder reference for hierarchy traversal, access control group, security classification, and governance policy. Provides the organizational container structure for document storage and retrieval aligned to matter workspaces. Supports workspace provisioning automation and access inheritance rules.' .

ind:DocReviewAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Review Assignment' ;
    rdfs:comment 'Complete record of document review work product within eDiscovery and collaborative review workflows. Captures reviewer identity, review batch, assignment and completion dates, review decisions (responsive/non-responsive/privilege), TAR/CAL model round, and all associated annotations including issue tags, redactions, coding decisions, highlights, comments, redlines, and annotation metadata (type, timestamp, review round, CAL feedback flag). Supports review throughput management, quality control, second-level review, continuous active learning feedback, privilege log compilation, ad-hoc collaborative annotation outside formal review batches, and annotation-level audit trail. Central operational entity for managing the entire review, annotation, and coding lifecycle from assignment through final production coding.' .

ind:PrivilegeLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Privilege Log' ;
    rdfs:comment 'Authoritative record of privilege designations applied to documents, capturing LPP (Legal Professional Privilege), attorney-client privilege, work-product doctrine, and common-interest privilege claims. Records the basis for privilege assertion, asserting attorney, date of designation, redaction status, and challenge history. Required for eDiscovery productions and court submissions.' .

ind:EsiCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Esi Collection' ;
    rdfs:comment 'Master record for each ESI (Electronically Stored Information) collection event executed via Relativity or other collection tools. Captures custodian identity, collection date range, data sources (email, file share, cloud), collection method, chain-of-custody hash values, volume statistics, and matter linkage. Serves as the authoritative provenance record for all eDiscovery collections.' .

ind:EsiCustodian rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Esi Custodian' ;
    rdfs:comment 'Identifies individuals or entities whose ESI is subject to legal hold and collection in litigation or investigation matters. Records custodian name, role, organization, data sources held (email systems, file shares, cloud storage, mobile devices), legal hold acknowledgement status, collection status, and interview notes. This is the document-domain view of a person-as-custodian — the authoritative record of their preservation obligations, data map, and collection history. Supports custodian interview workflows and defensible collection planning under FRCP Rule 26, Practice Direction 31B, and GDPR obligations.' .

ind:LegalHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Legal Hold' ;
    rdfs:comment 'Records the issuance, scope, and lifecycle of legal hold notices sent to custodians to preserve ESI and physical documents in anticipation of litigation or regulatory investigation. Captures hold trigger event, issuing attorney, custodian acknowledgement status, scope of preservation, suspension of routine destruction, and release date. Critical for defensible litigation readiness and spoliation risk management.' .

ind:DocProduction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Production' ;
    rdfs:comment 'Records each eDiscovery production set delivered to opposing counsel or a regulatory body via Relativity. Captures production volume, Bates number range, production format (TIFF, native, PDF), redaction applied, privilege log reference, delivery method, and receiving party. Provides the authoritative audit trail for all productions in litigation and regulatory matters.' .

ind:DocAnnotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Annotation' ;
    rdfs:comment 'Captures reviewer annotations, issue tags, redlines, and coding decisions applied to documents during review workflows in Relativity or iManage. Records annotation type (issue tag, redaction, comment, highlight), annotating reviewer, timestamp, review round, and TAR/CAL model feedback flag. Supports quality control, second-level review, and continuous active learning workflows.' .

ind:RetentionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Retention Schedule' ;
    rdfs:comment 'Reference table defining the firms document retention, destruction, and disposal policies by document type, matter type, jurisdiction, and regulatory framework (GDPR, DPA, SOX, SRA). Specifies minimum and maximum retention periods, destruction method (shredding, secure deletion, degaussing), destruction authorization requirements, legal basis for retention, responsible records manager, and certificate of destruction tracking. Governs automated retention enforcement in iManage Records Management and NetDocuments Governance, including end-of-life destruction event recording.' .

ind:DocAccessEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Access Event' ;
    rdfs:comment 'Business-level audit log capturing document access, download, print, share, and email-out events from iManage Work and NetDocuments. Records the accessing user, access type, timestamp, client/matter context, and whether the access was within or outside an ethical wall. Supports LPP breach detection, PII access monitoring, and SRA/GDPR data subject access request responses.' .

ind:DocExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Execution' ;
    rdfs:comment 'Records the formal execution of legal documents including signing parties, execution method (wet ink, DocuSign, Adobe Sign), execution date, counterpart details, governing law, and notarization or witnessing requirements. Tracks execution status through the signing workflow and stores the executed document reference. Authoritative record for contract execution events across M&A, CLM, and engagement letter workflows.' .

ind:DocTemplate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Template' ;
    rdfs:comment 'Catalog of approved document templates and precedent forms maintained in Thomson Reuters Practical Law and the firms knowledge management system. Records template name, practice area, jurisdiction, version, approval status, approving partner, last review date, and associated clause library references. Serves as the authoritative source for standardized drafting starting points across all practice groups.' .

ind:DocRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Doc Relationship' ;
    rdfs:comment 'Models typed relationships between legal documents including parent-child (email thread to attachment), document family groupings for eDiscovery, exhibit references for court filings, supersedes/amends chains for contract versions, and related-document links for matter workspaces. Captures relationship type, source document, target document, relationship direction, effective date, and matter context. Essential for eDiscovery family deduplication, exhibit list generation, court bundle assembly, and amendment chain tracing.' .

ind:CustodianHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Custodian Hold' ;
    rdfs:comment 'This association product represents the assignment of legal hold notices to ESI custodians in litigation and investigation matters. It captures the issuance, acknowledgement, compliance monitoring, and release lifecycle for each custodian-hold pairing. Each record links one custodian to one legal hold with attributes that track the custodians specific preservation obligations, acknowledgement status, interview details, and collection activities under that hold. This is a core eDiscovery workflow entity managed actively throughout the litigation lifecycle.. Existence Justification: In legal eDiscovery practice, legal holds are issued to multiple custodians, and custodians are frequently subject to multiple concurrent legal holds across different matters. Law firms and legal departments actively manage custodian-hold assignments as a distinct workflow: issuing notices, tracking acknowledgements, conducting custodian interviews, monitoring collection progress, and releasing custodians when holds are lifted. This is not a reference relationship—it is an operational business process with its own lifecycle, compliance requirements, and risk management implications governed by FRCP Rule 26 and spoliation case law.' .

ind:ProductionSource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Production Source' ;
    rdfs:comment 'This association product represents the sourcing relationship between eDiscovery production sets and the ESI collections from which they are derived. In eDiscovery workflows, a single production may draw documents from multiple collection events (e.g., combining custodian collections), and a single collection may contribute documents to multiple productions over time (initial production, supplemental production, different matters). Each record captures the subset of documents from a specific collection included in a specific production, along with the Bates numbering applied to that subset and any collection-specific filters or date ranges used during production assembly.. Existence Justification: In eDiscovery operations, production sets routinely draw documents from multiple ESI collection events (e.g., combining collections from different custodians, time periods, or data sources into a single production), and a single collection event commonly contributes documents to multiple productions over the lifecycle of a matter (initial production, supplemental productions, productions for different matters sharing custodians). Legal teams actively manage this many-to-many relationship in platforms like Relativity during production assembly, applying collection-specific Bates ranges, filters, and document counts that exist only in the context of each production-collection pairing.' .

ind:TemplateClauseUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Template Clause Usage' ;
    rdfs:comment 'This association product represents the operational relationship between document templates and clause library entries in the firms knowledge management system. It captures which clauses are incorporated into which templates, including the clauses position within the template, the specific variant selected, customization notes, and whether the clause is mandatory or optional. Each record represents a deliberate design decision by knowledge management professionals about template composition and is actively managed as templates evolve.. Existence Justification: In legal knowledge management systems, document templates are assembled from multiple reusable clause library entries, and each clause is designed to be reused across multiple templates. Knowledge management teams actively manage these template-clause mappings, making deliberate decisions about which clause variant to use, where to position it, whether its mandatory, and any template-specific customizations. This is a core operational process in contract automation and template governance.' .

ind:ReviewSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Review Set' ;
    rdfs:comment 'Master reference table for review_set. Referenced by review_set_id.' .

ind:ReviewSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Review Session' ;
    rdfs:comment 'Master reference table for review_session. Referenced by session_id.' .

ind:ExecutionWorkflow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Execution Workflow' ;
    rdfs:comment 'Master reference table for execution_workflow. Referenced by execution_workflow_id.' .

ind:Workspace rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Workspace' ;
    rdfs:comment 'Master reference table for workspace. Referenced by workspace_id.' .

ind:ProductionSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Production Set' ;
    rdfs:comment 'Master reference table for production_set. Referenced by production_set_id.' .

ind:FamilyGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Family Group' ;
    rdfs:comment 'Master reference table for family_group. Referenced by family_group_id.' .

ind:ReviewBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Review Batch' ;
    rdfs:comment 'Master reference table for review_batch. Referenced by review_batch_id.' .

ind:ProductionBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Production Batch' ;
    rdfs:comment 'Master reference table for production_batch. Referenced by production_batch_id.' .

ind:TarModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Tar Model' ;
    rdfs:comment 'Master reference table for tar_model. Referenced by tar_model_id.' .

ind:ReviewProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Review Project' ;
    rdfs:comment 'Master reference table for review_project. Referenced by project_id.' .

ind:ProductionSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Production Specification' ;
    rdfs:comment 'Master reference table for production_specification. Referenced by production_specification_id.' .

ind:ProcessingBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Processing Batch' ;
    rdfs:comment 'Master reference table for processing_batch. Referenced by processing_batch_id.' .

ind:ReviewProtocol rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Review Protocol' ;
    rdfs:comment 'Master reference table for review_protocol. Referenced by review_protocol_id.' .

ind:TimekeeperRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Timekeeper Rate' ;
    rdfs:comment 'Master rate card defining billable rates for each timekeeper by client, matter, practice group, and effective date period. Supports standard hourly rates, blended rates, client-negotiated rates, and alternative fee arrangement rate structures. Tracks rate currency, jurisdiction-specific rate tiers, rate approval status, and rate history for audit purposes. Governs the monetary value applied to time entries during WIP calculation.' .

ind:TimeEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Time Entry' ;
    rdfs:comment 'Granular transactional record of billable and non-billable time recorded by timekeepers against a matter. Captures UTBMS task and activity codes, narrative descriptions, hours worked, billable hours, billing rate at time of entry, WIP value, and timekeeper identity. Supports LEDES export format for electronic billing. Tracks entry status through draft, submitted, approved, billed, and written-off lifecycle stages. Primary source record for WIP accumulation and invoice generation.' .

ind:WipLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Wip Ledger' ;
    rdfs:comment 'Accumulated Work in Progress ledger representing unbilled time and disbursements for each matter. Tracks WIP balance by timekeeper, matter, billing period, and fee arrangement type. Provides the authoritative WIP snapshot used in prebilling and financial reporting. Captures WIP aging buckets, write-up/write-down adjustments, and transfer history. Critical for PPP (Profit Per Partner), PEP (Profit Per Equity Partner), and RPE (Revenue Per Employee) financial KPI calculations.' .

ind:Prebill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Prebill' ;
    rdfs:comment 'Pre-invoice draft generated from WIP for attorney review and approval before final invoice issuance. Captures prebill number, matter reference, billing attorney, billing period, total WIP value, proposed adjustments, write-up/write-down amounts, and prebill status (draft, under review, approved, rejected). Supports the prebilling workflow including partner review, narrative editing, and billing guideline compliance checks. Central to the legal billing quality control process.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Authoritative billing document issued to a client for legal services rendered on one or more matters. Captures invoice number, invoice date, billing period, total fees, total disbursements, tax amounts, discounts, net amount due, currency, and invoice status lifecycle (draft, issued, disputed, paid, partially paid, written off, credited). Supports LEDES 1998B and LEDES XML electronic billing formats for corporate clients and insurance carriers. Encompasses credit notes (negative invoices with credit reason, originating invoice reference, and application status) and LEDES e-billing portal submission tracking (submission date, format version, target portal, submission status, rejection reasons, and resubmission history). Provides complete invoice-to-payment lifecycle visibility including dispute resolution and collections integration.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual line item on a legal invoice representing a single time entry, disbursement, or flat fee component. Captures UTBMS task code, activity code, timekeeper, narrative, quantity, rate, amount, tax code, and line-level write-up/write-down adjustments. Provides the granular detail required for LEDES electronic billing submissions and client billing guideline compliance. Each line traces back to an originating time entry or disbursement record.' .

ind:PaymentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Allocation' ;
    rdfs:comment 'Association record linking a payment to one or more invoice lines, capturing how received funds are distributed across outstanding invoices and line items. Tracks allocated amount, allocation date, allocation type (full, partial, retainer drawdown, trust transfer), and any unapplied balance. Ensures accurate AR aging and supports complex multi-matter payment scenarios common in large corporate client relationships.' .

ind:ArBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Ar Balance' ;
    rdfs:comment 'Accounts receivable balance record representing the outstanding amount owed by a client at the matter and invoice level. Tracks current balance, aged buckets (0-30, 31-60, 61-90, 90+ days), last payment date, last statement date, credit terms, and collection status. Serves as the authoritative AR aging ledger for collections management, partner financial reviews, and PPP/PEP reporting.' .

ind:WriteOff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Write Off' ;
    rdfs:comment 'Transactional record of WIP or AR amounts formally written off or written down following partner approval. Captures write-off type (WIP write-off, bad debt write-off, courtesy discount, billing guideline reduction), original amount, write-off amount, write-off reason code, approving partner, approval date, and GL impact. Critical for realization rate calculations, profitability analysis, and financial period close.' .

ind:Retainer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Retainer' ;
    rdfs:comment 'Master record of client retainer arrangements including general retainers, matter-specific retainers, and evergreen retainers. Tracks retainer amount, replenishment threshold, current balance, drawdown history, retainer type, and associated trust account reference. Distinct from IOLTA trust accounts (owned by the trust domain) — this entity governs the commercial retainer agreement terms and drawdown authorization rules within the billing cycle.' .

ind:CollectionAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Collection Action' ;
    rdfs:comment 'Transactional record of collections activities undertaken to recover outstanding AR balances. Captures action type (statement issued, demand letter sent, payment plan agreed, escalated to collections counsel, written off), action date, responsible collections coordinator, follow-up date, client response, and outcome. Supports the end-to-end collections workflow from first reminder through final resolution.' .

ind:Guideline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Guideline' ;
    rdfs:comment 'Master record of client-specific billing guidelines and outside counsel guidelines (OCG) that govern invoice compliance requirements. Captures guideline source (client-issued OCG, engagement letter, standing instruction), rule type (rate cap, timekeeper approval, task code restriction, narrative requirement, block billing prohibition, expense limit), effective date, and enforcement action. Used during prebilling review and LEDES submission validation to flag non-compliant entries before invoice issuance.' .

ind:InvoiceDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Dispute' ;
    rdfs:comment 'Transactional record of client-raised disputes or reductions against a submitted invoice. Captures dispute date, disputed amount, dispute reason (billing guideline violation, rate discrepancy, duplicate entry, unauthorized timekeeper, narrative deficiency), resolution status, agreed reduction amount, and resolution date. Supports dispute resolution workflow and feeds realization rate and write-off analytics.' .

ind:LedesSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Ledes Submission' ;
    rdfs:comment 'Transactional record of LEDES-format electronic billing file submissions to client e-billing portals. Captures submission date, LEDES format version (1998B, XML 2.0), target portal identifier, invoice references included, submission status (pending, accepted, rejected, partially accepted), rejection reason codes, and resubmission history. Enables tracking of e-billing compliance and portal-specific submission outcomes.' .

ind:ThirdPartyRisk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Third Party Risk' ;
    rdfs:comment 'Third-party and vendor risk record assessing the risk profile of external service providers, ALSPs, technology vendors, and outsourced functions that handle firm or client data. Captures vendor name, service category, data access level (PII, LPP, confidential), due diligence status, ISO 27001 certification status, contractual security obligations, last assessment date, risk tier (critical/high/medium/low), and ongoing monitoring status. Supports SRA outsourcing requirements and GDPR processor obligations.' .

ind:Escalation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Escalation' ;
    rdfs:comment 'Governance escalation and decision record capturing formal risk escalation events from operational teams to Risk Committee, Managing Partner, or Board. Each record documents the escalated risk or event reference, escalation trigger (threshold breach, novel risk type, regulatory inquiry), escalation date, escalating party, receiving governance body, decision outcome (accept, mitigate, transfer, avoid, defer), conditions imposed, decision rationale, decision date, and follow-up action references. Provides the governance audit trail required by SRA, ISO 31000, and internal risk governance frameworks to demonstrate that material risks received appropriate senior oversight.' .

ind:ServiceOfProcess rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Court ;
    rdfs:label 'Service Of Process' ;
    rdfs:comment 'Tracks formal service of legal process on parties including complaints, summonses, subpoenas (ad testificandum and duces tecum), arbitration notices, and other compulsory instruments. Records service method (personal, substituted, publication, electronic, Hague Convention), service date, process server identity, party served, document type and reference, proof of service filing date, service validity status, objection status, compliance deadline, and ESI/eDiscovery implications flag. Supports litigation workflow, ensures compliance with jurisdictional service requirements, and links to document management for collection when subpoenas duces tecum are involved.' .

ind:AdrProceeding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Court ;
    rdfs:label 'Adr Proceeding' ;
    rdfs:comment 'Master record for Alternative Dispute Resolution proceedings including mediation, arbitration (ICC, LCIA, AAA, JAMS), and expert determination. Captures ADR type, administering institution, seat of arbitration, governing rules version, number of arbitrators, arbitrator appointment dates, claimant and respondent references, claim amount, currency, commencement date, award date, and enforcement status. Distinct from court dockets — ADR proceedings follow separate procedural rules and timelines.' .

ind:ArbitralAward rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Court ;
    rdfs:label 'Arbitral Award' ;
    rdfs:comment 'Records final and interim awards issued in arbitration and ADR proceedings. Stores award type (final, partial, interim, consent), issue date, arbitral tribunal composition, awarded amount, currency, interest provisions, cost allocation, enforcement jurisdiction, New York Convention applicability flag, challenge status, and enforcement order reference. Supports post-award enforcement strategy and matter closure.' .

# --- Attribute Properties ---
ind:adrProceedingId rdf:type rdf:Property ;
    rdfs:label 'Adr Proceeding Id' ;
    rdfs:comment 'Unique identifier for the ADR proceeding. Primary key for the ADR proceeding record.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: ADR proceedings frequently involve trust or escrow arrangements for settlement funds, arbitration deposits, or mediation settlement amounts. Attorneys must track which trust account holds ADR-related ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:indemnityClaimId rdf:type rdf:Property ;
    rdfs:label 'Indemnity Claim Id' ;
    rdfs:comment 'Foreign key linking to compliance.indemnity_claim. Business justification: Mediation/arbitration of indemnity claims is standard practice for settlement; essential for claims management, insurer coordination, and regulatory compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndemnityClaim .

ind:matterId rdf:type rdf:Property ;
    rdfs:label 'Matter Id' ;
    rdfs:comment 'Reference to the parent matter under which this ADR proceeding is conducted. Links the ADR proceeding to the broader legal matter for tracking and billing purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:practiceNoteId rdf:type rdf:Property ;
    rdfs:label 'Practice Note Id' ;
    rdfs:comment 'Foreign key linking to knowledge.practice_note. Business justification: ADR forums have specific practice notes (arbitration procedures, mediation protocols, institutional rules, discovery in arbitration). Linking proceeding to practice notes ensures procedural compliance' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeNote .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Foreign key linking to client.client_profile. Business justification: ADR proceedings are client matters. Direct link supports alternative dispute resolution tracking, client preference analysis for settlement vs. litigation, cost-benefit reporting, and ADR outcome metr' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:regulatoryBreachId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Breach Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_breach. Business justification: ADR/arbitration of regulatory disputes is common in commercial regulatory matters; essential for breach resolution tracking and regulatory reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBreach .

ind:administeringInstitution rdf:type rdf:Property ;
    rdfs:label 'Administering Institution' ;
    rdfs:comment 'The arbitration or ADR institution administering the proceeding (e.g., ICC, LCIA, AAA, JAMS, SIAC, HKIAC). For ad hoc proceedings, this field may be null or indicate Ad Hoc.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adrAdministeringBody rdf:type rdf:Property ;
    rdfs:label 'Adr Administering Body' ;
    rdfs:comment 'FK to court.tribunal.tribunal_id — ADR proceedings are administered by an institution (ICC, LCIA, AAA) which is stored as a tribunal record. Required for institutional rule application.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adrToAdministeringBody rdf:type rdf:Property ;
    rdfs:label 'Adr To Administering Body' ;
    rdfs:comment 'FK to court.tribunal.tribunal_id — ADR proceedings are administered by a specific body (ICC, LCIA, AAA). The tribunal product covers arbitral bodies. Links ADR to its forum.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adrToSeatJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Adr To Seat Jurisdiction' ;
    rdfs:comment 'FK to court.court_jurisdiction.court_jurisdiction_id — ADR proceedings have a seat of arbitration which determines the governing jurisdiction for procedural matters and enforcement.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adrType rdf:type rdf:Property ;
    rdfs:label 'Adr Type' ;
    rdfs:comment 'The type of ADR mechanism being used to resolve the dispute. Arbitration is binding; mediation is facilitative; expert determination involves a neutral expert; adjudication is common in construction disputes; conciliation is similar to mediation; dispute boards provide ongoing dispute resolution during long-term projects.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardAmount rdf:type rdf:Property ;
    rdfs:label 'Award Amount' ;
    rdfs:comment 'The monetary amount awarded by the tribunal in favor of the prevailing party. May be positive (in favor of claimant) or negative (in favor of respondent if counterclaim succeeds). Excludes costs and interest unless specified. Confidential financial information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardCurrency rdf:type rdf:Property ;
    rdfs:label 'Award Currency' ;
    rdfs:comment 'The currency in which the award amount is denominated, using ISO 4217 three-letter currency code. Null if no award has been issued.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date on which the final award was issued by the arbitral tribunal. For mediation, the date of the settlement agreement. Null if no award or settlement has been reached.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'External case or proceeding reference number assigned by the administering institution or by the parties. This is the business identifier used in correspondence and filings.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Amount' ;
    rdfs:comment 'The monetary value of the claim as stated by the claimant in the notice of arbitration or statement of claim. Excludes interest, costs, and fees unless explicitly included in the claim. Confidential financial information.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimCurrency rdf:type rdf:Property ;
    rdfs:label 'Claim Currency' ;
    rdfs:comment 'The currency in which the claim amount is denominated, using ISO 4217 three-letter currency code (e.g., USD, GBP, EUR, CHF).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantPartyName rdf:type rdf:Property ;
    rdfs:label 'Claimant Party Name' ;
    rdfs:comment 'The name of the claimant party (or parties) initiating the ADR proceeding. May be a single entity or multiple co-claimants. Confidential business information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'The date on which the ADR proceeding was formally commenced, typically the date the notice of arbitration or request for mediation was filed with the administering institution or served on the respondent.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The level of confidentiality applicable to the ADR proceeding. Public: no confidentiality restrictions. Confidential: standard confidentiality per institutional rules. Highly confidential: enhanced confidentiality by agreement. Sealed: court-ordered sealing or equivalent. Most arbitrations are confidential by default.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costsAwardedToClaimant rdf:type rdf:Property ;
    rdfs:label 'Costs Awarded To Claimant' ;
    rdfs:comment 'The amount of legal costs and expenses awarded to the claimant by the tribunal. Null if no costs award has been made or if costs were awarded to respondent. Confidential financial information.' ;
    rdfs:domain ind:Court ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costsAwardedToRespondent rdf:type rdf:Property ;
    rdfs:label 'Costs Awarded To Respondent' ;
    rdfs:comment 'The amount of legal costs and expenses awarded to the respondent by the tribunal. Null if no costs award has been made or if costs were awarded to claimant. Confidential financial information.' ;
    rdfs:domain ind:Court ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterclaimAmount rdf:type rdf:Property ;
    rdfs:label 'Counterclaim Amount' ;
    rdfs:comment 'The monetary value of any counterclaim filed by the respondent. Null if no counterclaim has been filed. Confidential financial information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterclaimCurrency rdf:type rdf:Property ;
    rdfs:label 'Counterclaim Currency' ;
    rdfs:comment 'The currency in which the counterclaim amount is denominated, using ISO 4217 three-letter currency code. Null if no counterclaim exists.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeSubjectMatter rdf:type rdf:Property ;
    rdfs:label 'Dispute Subject Matter' ;
    rdfs:comment 'A brief description of the subject matter of the dispute (e.g., breach of contract, intellectual property infringement, construction delay, shareholder dispute, M&A dispute). Confidential business information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyArbitratorAppointedFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Arbitrator Appointed Flag' ;
    rdfs:comment 'Indicates whether an emergency arbitrator was appointed under the institutional rules to grant urgent interim relief before the tribunal is constituted. True if emergency arbitrator appointed; False otherwise.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Jurisdiction' ;
    rdfs:comment 'The country or jurisdiction in which enforcement of the award is being sought or has been obtained. May be multiple jurisdictions if enforcement is pursued in multiple countries. Null if no enforcement action has been initiated.' ;
    rdfs:domain ind:Court ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'The status of enforcement of the arbitral award. Not applicable: no award issued or settlement reached voluntarily. Pending: award issued, enforcement not yet initiated. In progress: enforcement proceedings underway. Enforced: award successfully enforced. Challenged: enforcement challenged by losing party. Set aside: award set aside by competent court. Refused: enforcement refused by court. [ENUM-REF-CANDIDATE: not_applicable|pending|in_progress|enforced|challenged|set_aside|refused — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstHearingDate rdf:type rdf:Property ;
    rdfs:label 'First Hearing Date' ;
    rdfs:comment 'The date of the first substantive hearing or procedural conference in the ADR proceeding. Null if no hearing has been scheduled or held.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'The substantive law governing the merits of the dispute (e.g., English law, New York law, Swiss law). Distinct from the procedural law, which is determined by the seat of arbitration.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRules rdf:type rdf:Property ;
    rdfs:label 'Governing Rules' ;
    rdfs:comment 'The procedural rules governing the ADR proceeding (e.g., ICC Arbitration Rules 2021, LCIA Arbitration Rules 2020, UNCITRAL Arbitration Rules 2013, AAA Commercial Arbitration Rules). Includes version year where applicable.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMeasuresGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Interim Measures Granted Flag' ;
    rdfs:comment 'Indicates whether the tribunal or emergency arbitrator granted interim measures (provisional relief) during the proceeding, such as injunctions, asset freezes, or orders for security for costs. True if interim measures granted; False otherwise.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Lead Counsel Firm' ;
    rdfs:comment 'The name of the law firm representing the client (claimant or respondent) as lead counsel in the ADR proceeding. Confidential business information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfArbitrators rdf:type rdf:Property ;
    rdfs:label 'Number Of Arbitrators' ;
    rdfs:comment 'The number of arbitrators constituting the tribunal. Typically 1 (sole arbitrator) or 3 (panel). Occasionally 5 or more for complex multi-party disputes. Null for non-arbitration ADR types.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opposingCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Opposing Counsel Firm' ;
    rdfs:comment 'The name of the law firm representing the opposing party in the ADR proceeding. Confidential business information.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfHearing rdf:type rdf:Property ;
    rdfs:label 'Place Of Hearing' ;
    rdfs:comment 'The physical or virtual location where hearings are conducted. May differ from the seat of arbitration. Can include multiple locations or indicate Virtual for remote hearings.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proceedingStatus rdf:type rdf:Property ;
    rdfs:label 'Proceeding Status' ;
    rdfs:comment 'Current lifecycle status of the ADR proceeding. Initiated: proceeding has been commenced. Constituted: tribunal or mediator appointed. Ongoing: active proceedings. Suspended: temporarily paused. Settled: parties reached agreement. Award issued: final decision rendered. Terminated: proceeding ended without award. Enforcement pending: award issued, enforcement in progress. Enforced: award successfully enforced. [ENUM-REF-CANDIDATE: initiated|constituted|ongoing|suspended|settled|award_issued|terminated|enforcement_pending|enforced — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this ADR proceeding record was first created in the system. Audit trail field for data governance and lineage tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this ADR proceeding record was last updated in the system. Audit trail field for data governance and lineage tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:respondentPartyName rdf:type rdf:Property ;
    rdfs:label 'Respondent Party Name' ;
    rdfs:comment 'The name of the respondent party (or parties) against whom the ADR proceeding is brought. May be a single entity or multiple co-respondents. Confidential business information.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatOfArbitration rdf:type rdf:Property ;
    rdfs:label 'Seat Of Arbitration' ;
    rdfs:comment 'The legal seat (juridical seat) of the arbitration, which determines the procedural law and supervisory court jurisdiction. Typically a city and country (e.g., London, United Kingdom; New York, USA; Singapore). Critical for enforcement under the New York Convention.' ;
    rdfs:domain ind:Court ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the parties executed a settlement agreement, if applicable. Null if no settlement was reached.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReachedFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Reached Flag' ;
    rdfs:comment 'Indicates whether the parties reached a settlement during the ADR proceeding, resulting in termination of the proceeding by consent. True if settlement reached; False otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which the ADR proceeding was formally terminated, whether by award, settlement, withdrawal, or other means. Null if the proceeding is still ongoing.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason for termination of the ADR proceeding. Award issued: tribunal rendered final award. Settlement: parties reached agreement. Withdrawal: claimant withdrew claim. Lack of prosecution: proceeding terminated due to inactivity. Jurisdictional objection sustained: tribunal declined jurisdiction. Other: other reasons.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tribunalConstitutionDate rdf:type rdf:Property ;
    rdfs:label 'Tribunal Constitution Date' ;
    rdfs:comment 'The date on which the arbitral tribunal was fully constituted (all arbitrators appointed and confirmed). For mediation, the date the mediator was appointed. Null if not yet constituted.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underlyingContractType rdf:type rdf:Property ;
    rdfs:label 'Underlying Contract Type' ;
    rdfs:comment 'The type of contract or agreement that is the subject of the dispute (e.g., Share Purchase Agreement (SPA), Joint Venture Agreement, Construction Contract, License Agreement, Distribution Agreement, Employment Agreement). Null if dispute does not arise from a contract.' ;
    rdfs:domain ind:AdrProceeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitralAwardId rdf:type rdf:Property ;
    rdfs:label 'Arbitral Award Id' ;
    rdfs:comment 'Unique identifier for the arbitral award record. Primary key.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indemnityExposureId rdf:type rdf:Property ;
    rdfs:label 'Indemnity Exposure Id' ;
    rdfs:comment 'Foreign key linking to risk.indemnity_exposure. Business justification: Adverse arbitral awards can trigger professional indemnity claims, particularly in international arbitration. Essential for reserve setting and insurer notification in arbitration practice.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndemnityExposure .

ind:legalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Legal Document Id' ;
    rdfs:comment 'Foreign key linking to document.legal_document. Business justification: Arbitral awards are legal documents requiring secure storage, confidentiality controls, and retention management; link connects award records to document files for enforcement proceedings and New York' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:precedentId rdf:type rdf:Property ;
    rdfs:label 'Precedent Id' ;
    rdfs:comment 'Foreign key linking to knowledge.precedent. Business justification: Significant arbitration awards, especially published ones, serve as precedents for future ADR proceedings. Captures institutional knowledge from alternative dispute resolution, enables arbitration str' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Precedent .

ind:primaryAdrProceedingId rdf:type rdf:Property ;
    rdfs:label 'Primary Adr Proceeding Id' ;
    rdfs:comment 'FK to court.adr_proceeding.adr_proceeding_id — Arbitral awards are issued in connection with a specific ADR proceeding. This is the parent-child relationship between the proceeding and its outcome.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdrProceeding .

ind:adrMechanism rdf:type rdf:Property ;
    rdfs:label 'Adr Mechanism' ;
    rdfs:comment 'The specific ADR mechanism under which this award was issued.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitralInstitution rdf:type rdf:Property ;
    rdfs:label 'Arbitral Institution' ;
    rdfs:comment 'The name of the arbitral institution administering the arbitration (e.g., ICC, LCIA, AAA, SIAC) or indication of ad hoc arbitration.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Award Reference Number' ;
    rdfs:comment 'The official reference or case number assigned to this arbitral award by the arbitral institution or tribunal.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Current lifecycle status of the arbitral award reflecting enforcement and challenge proceedings. [ENUM-REF-CANDIDATE: issued|challenged|upheld|set_aside|enforced|partially_enforced|recognition_pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardSummary rdf:type rdf:Property ;
    rdfs:label 'Award Summary' ;
    rdfs:comment 'A concise summary of the key findings, rulings, and relief granted in the arbitral award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Classification of the arbitral award indicating its nature and finality within the arbitration proceeding.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'The principal monetary amount awarded to the prevailing party, excluding interest and costs.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:challengeFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Challenge Filed Flag' ;
    rdfs:comment 'Indicates whether a challenge or application to set aside the award has been filed by any party.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:challengeFilingDate rdf:type rdf:Property ;
    rdfs:label 'Challenge Filing Date' ;
    rdfs:comment 'The date on which a challenge or set-aside application was filed against the award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:challengeGrounds rdf:type rdf:Property ;
    rdfs:label 'Challenge Grounds' ;
    rdfs:comment 'Description of the legal grounds cited for challenging or setting aside the arbitral award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeOutcome rdf:type rdf:Property ;
    rdfs:label 'Challenge Outcome' ;
    rdfs:comment 'The outcome or current status of the challenge proceedings against the award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether the arbitral award is subject to confidentiality obligations restricting disclosure.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAllocationBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Basis' ;
    rdfs:comment 'Description of the basis or rationale used by the tribunal for allocating costs between parties (e.g., costs follow the event, proportional allocation).' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this arbitral award record was first created in the system.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the awarded amount.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to the full arbitral award document stored in the document management system (DMS).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementOrderDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Order Date' ;
    rdfs:comment 'The date on which the enforcement or recognition order was issued by the competent court.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementOrderReference rdf:type rdf:Property ;
    rdfs:label 'Enforcement Order Reference' ;
    rdfs:comment 'Reference number or citation of the court order granting enforcement or recognition of the arbitral award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'The method specified for calculating interest on the awarded amount.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Provision Flag' ;
    rdfs:comment 'Indicates whether the award includes provisions for interest on the awarded amount.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate percentage awarded, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestStartDate rdf:type rdf:Property ;
    rdfs:label 'Interest Start Date' ;
    rdfs:comment 'The date from which interest begins to accrue on the awarded amount.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the arbitral tribunal issued and signed the award.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this arbitral award record was last updated or modified.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matterClosureTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Closure Trigger Flag' ;
    rdfs:comment 'Indicates whether the issuance of this award triggers closure of the associated legal matter.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newYorkConventionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'New York Convention Applicable Flag' ;
    rdfs:comment 'Indicates whether the award is subject to the New York Convention on the Recognition and Enforcement of Foreign Arbitral Awards, facilitating international enforcement.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for internal notes, observations, or strategic considerations related to the arbitral award and its enforcement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the parties were formally notified of the arbitral award.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:presidingArbitratorName rdf:type rdf:Property ;
    rdfs:label 'Presiding Arbitrator Name' ;
    rdfs:comment 'Full name of the presiding arbitrator or sole arbitrator who issued the award.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Publication Permitted Flag' ;
    rdfs:comment 'Indicates whether the award may be published in redacted or anonymized form for legal research or precedent purposes.' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tribunalComposition rdf:type rdf:Property ;
    rdfs:label 'Tribunal Composition' ;
    rdfs:comment 'Description of the arbitral tribunal composition including number of arbitrators and their appointment method (e.g., sole arbitrator, three-member panel).' ;
    rdfs:domain ind:ArbitralAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationId rdf:type rdf:Property ;
    rdfs:label 'Escalation Id' ;
    rdfs:comment 'Unique identifier for the risk escalation record. Primary key.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Escalation .

ind:attorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Attorney Profile Id' ;
    rdfs:comment 'Reference to the senior individual who made or approved the final decision.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_category. Business justification: Escalations are categorized by risk type. risk_escalation has risk_category (STRING) which should normalize to risk_category reference table for taxonomy consistency.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:escalationLastUpdatedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Escalation Last Updated By Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last updated the escalation record.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:escalationOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Escalation Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the individual or role who initiated the escalation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:priorEscalationId rdf:type rdf:Property ;
    rdfs:label 'Prior Escalation Id' ;
    rdfs:comment 'Self-referencing FK on escalation (prior_escalation_id)' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Escalation .

ind:registerId rdf:type rdf:Property ;
    rdfs:label 'Register Id' ;
    rdfs:comment 'Reference to the underlying risk register entry that triggered this escalation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Register .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date when the Board of Partners was formally notified of the escalation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Board Notification Required Flag' ;
    rdfs:comment 'Indicates whether the escalation requires formal notification to the Board of Partners.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the escalation was formally closed after decision implementation or risk resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Any specific conditions, restrictions, or requirements imposed by the governance body as part of the decision.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the governance body made the formal decision on the escalated risk.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Name of the senior individual who made or approved the final decision.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'The risk treatment decision made by the governance body following review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Detailed explanation of the reasoning behind the governance decision, including factors considered and risk-benefit analysis.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatingPartyName rdf:type rdf:Property ;
    rdfs:label 'Escalating Party Name' ;
    rdfs:comment 'Name of the individual or role who escalated the risk.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Escalating Party Role' ;
    rdfs:comment 'Job title or functional role of the person who escalated the risk.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the risk was formally escalated to the governance body.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Current lifecycle status of the escalation event.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Precise timestamp when the escalation was initiated.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated financial exposure or potential loss associated with the escalated risk.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpActionReference rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Reference' ;
    rdfs:comment 'Reference number or identifier linking to follow-up mitigation actions or monitoring activities.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required Flag' ;
    rdfs:comment 'Indicates whether follow-up actions or monitoring are required as a result of the decision.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Notification Date' ;
    rdfs:comment 'Date when the professional indemnity insurer was notified of the escalated risk.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Notification Required Flag' ;
    rdfs:comment 'Indicates whether the escalated risk requires notification to the firms professional indemnity insurer.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when the escalation record was last modified.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lppAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Applies Flag' ;
    rdfs:comment 'Indicates whether Legal Professional Privilege applies to the escalation documentation and decision records.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Involved Flag' ;
    rdfs:comment 'Indicates whether the escalated risk involves Personally Identifiable Information.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the escalation based on urgency and potential impact.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingGovernanceBody rdf:type rdf:Property ;
    rdfs:label 'Receiving Governance Body' ;
    rdfs:comment 'The senior governance body or authority to which the risk was escalated. [ENUM-REF-CANDIDATE: risk_committee|board_of_partners|managing_partner|executive_committee|compliance_committee|audit_committee|practice_group_head|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this escalation event, used for tracking and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority to which the risk must be reported, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Applicable regulatory framework or compliance standard relevant to the escalated risk.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the regulatory body was notified of the escalated risk.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the escalated risk requires notification to external regulatory bodies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Date by which the escalated risk must be reviewed again or follow-up actions completed.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Level' ;
    rdfs:comment 'Assessed severity level of the risk at the time of escalation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trigger rdf:type rdf:Property ;
    rdfs:label 'Trigger' ;
    rdfs:comment 'The event or condition that triggered the escalation to senior governance. [ENUM-REF-CANDIDATE: threshold_breach|novel_risk_type|regulatory_inquiry|client_complaint|material_loss|reputational_threat|policy_exception|control_failure|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Description' ;
    rdfs:comment 'Detailed narrative explaining the specific circumstances that triggered the escalation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOfProcessId rdf:type rdf:Property ;
    rdfs:label 'Service Of Process Id' ;
    rdfs:comment 'Unique identifier for the service of process record. Primary key.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formTemplateId rdf:type rdf:Property ;
    rdfs:label 'Form Template Id' ;
    rdfs:comment 'Foreign key linking to knowledge.form_template. Business justification: Service of process requires specific forms (summons, proof of service affidavits, declaration of service). Linking service events to the forms used tracks compliance with service requirements and enab' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormTemplate .

ind:primaryProofOfServiceLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Proof Of Service Legal Document Id' ;
    rdfs:comment 'Reference to the document management system record for the filed proof of service (affidavit, certificate, or return of service).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:privacyBreachId rdf:type rdf:Property ;
    rdfs:label 'Privacy Breach Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_breach. Business justification: Service of process in privacy litigation triggers DPO notification and supervisory authority reporting; essential for GDPR compliance and breach incident tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyBreach .

ind:attemptedServiceCount rdf:type rdf:Property ;
    rdfs:label 'Attempted Service Count' ;
    rdfs:comment 'Number of attempts made to effect service on the party before successful service or abandonment.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centralAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Central Authority Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the Central Authority when service is effected under the Hague Service Convention.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline Date' ;
    rdfs:comment 'Date by which the served party must comply with the served document (e.g., response deadline for complaint, production deadline for subpoena duces tecum, appearance date for subpoena ad testificandum).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Identifier of the user or system account that created this service of process record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Type of legal document being served. Distinguishes between complaints, summonses, subpoenas (ad testificandum for testimony, duces tecum for documents), arbitration notices, and other compulsory instruments. [ENUM-REF-CANDIDATE: complaint|summons|subpoena_ad_testificandum|subpoena_duces_tecum|arbitration_notice|motion|order|notice|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfFilingReference rdf:type rdf:Property ;
    rdfs:label 'Ecf Filing Reference' ;
    rdfs:comment 'Reference number or transaction ID from the Electronic Case Filing (ECF) system if proof of service was filed electronically.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esiEdiscoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Esi Ediscovery Flag' ;
    rdfs:comment 'Indicates whether this service of process involves electronically stored information (ESI) or triggers eDiscovery obligations (True/False), particularly relevant for subpoenas duces tecum requesting electronic documents.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hagueConventionFlag rdf:type rdf:Property ;
    rdfs:label 'Hague Convention Flag' ;
    rdfs:comment 'Indicates whether service was effected under the Hague Service Convention for international service of process (True/False).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code identifying the legal jurisdiction governing this service of process (federal, state, county, or international jurisdiction).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Identifier of the user or system account that last modified this service of process record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this service of process record was last modified or updated.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:objectionDate rdf:type rdf:Property ;
    rdfs:label 'Objection Date' ;
    rdfs:comment 'Date on which an objection or motion to quash service was filed by the served party.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectionFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Objection Filed Flag' ;
    rdfs:comment 'Indicates whether the party served has filed an objection or motion to quash service (True/False).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectionReason rdf:type rdf:Property ;
    rdfs:label 'Objection Reason' ;
    rdfs:comment 'Textual description of the grounds for objection to service (e.g., insufficient process, insufficient service of process, lack of personal jurisdiction).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacerCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Pacer Case Number' ;
    rdfs:comment 'PACER case number for federal court cases, linking this service of process to the federal court docket.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyServedName rdf:type rdf:Property ;
    rdfs:label 'Party Served Name' ;
    rdfs:comment 'Full legal name of the individual or entity upon whom service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyServedRole rdf:type rdf:Property ;
    rdfs:label 'Party Served Role' ;
    rdfs:comment 'Role of the party being served in the legal proceeding (defendant, plaintiff, witness, third-party, agent, registered agent). [ENUM-REF-CANDIDATE: defendant|plaintiff|witness|third_party|agent|registered_agent|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processServerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Process Server License Number' ;
    rdfs:comment 'License or registration number of the process server, if applicable under jurisdictional requirements.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processServerName rdf:type rdf:Property ;
    rdfs:label 'Process Server Name' ;
    rdfs:comment 'Full name of the individual or entity who effected service (process server, sheriff, marshal, attorney, or other authorized person).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfServiceFiledDate rdf:type rdf:Property ;
    rdfs:label 'Proof Of Service Filed Date' ;
    rdfs:comment 'Date on which the proof of service (affidavit or certificate of service) was filed with the court or tribunal.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the served party must file a responsive pleading or answer, calculated from the service date per applicable rules.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line1' ;
    rdfs:comment 'Primary street address line where service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line2' ;
    rdfs:comment 'Secondary address line (suite, apartment, floor) where service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCity rdf:type rdf:Property ;
    rdfs:label 'Service City' ;
    rdfs:comment 'City where service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Service Cost Amount' ;
    rdfs:comment 'Total cost incurred for effecting service of process, including process server fees, mailing costs, publication costs, or international service fees.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Service Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the service cost amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Service Country Code' ;
    rdfs:comment 'Three-letter ISO country code where service was effected (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date on which service of process was completed and the document was delivered to or left with the party served.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDocket rdf:type rdf:Property ;
    rdfs:label 'Service Docket' ;
    rdfs:comment 'FK to court.docket.docket_id — Service of process is performed in connection with a docket. Required for proof of service filing and compliance tracking.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceMethod rdf:type rdf:Property ;
    rdfs:label 'Service Method' ;
    rdfs:comment 'Method by which service was effected: personal service, substituted service, service by publication, electronic service, Hague Convention service for international parties, certified or registered mail, or other jurisdictionally-approved method. [ENUM-REF-CANDIDATE: personal|substituted|publication|electronic|hague_convention|certified_mail|registered_mail|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Free-text notes documenting circumstances of service, challenges encountered, special instructions followed, or other relevant details provided by the process server or attorney.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePostalCode rdf:type rdf:Property ;
    rdfs:label 'Service Postal Code' ;
    rdfs:comment 'Postal or ZIP code where service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Service Reference Number' ;
    rdfs:comment 'Business identifier or tracking number assigned to this service of process event for external reference and tracking.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Service State Province' ;
    rdfs:comment 'State or province where service was effected.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of the service of process attempt: pending (not yet attempted), completed (successfully served), failed (attempt unsuccessful), returned unserved (unable to locate or serve party), or quashed (invalidated by court).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTime rdf:type rdf:Property ;
    rdfs:label 'Service Time' ;
    rdfs:comment 'Precise timestamp when service was completed, including time of day, for jurisdictions requiring exact time documentation.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceToDocket rdf:type rdf:Property ;
    rdfs:label 'Service To Docket' ;
    rdfs:comment 'FK to court.docket.docket_id — Service of process occurs in connection with a litigated matter/docket. Required to track which case the service relates to.' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceValidityStatus rdf:type rdf:Property ;
    rdfs:label 'Service Validity Status' ;
    rdfs:comment 'Current validity status of the service of process: valid (accepted by court), invalid (rejected or defective), pending validation, quashed (set aside by court order), or objected (party has filed objection).' ;
    rdfs:domain ind:ServiceOfProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionId rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action Id' ;
    rdfs:comment 'Unique identifier for the risk mitigation action record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MitigationAction .

ind:practiceGroupId rdf:type rdf:Property ;
    rdfs:label 'Practice Group Id' ;
    rdfs:comment 'Reference to the practice group responsible for or affected by this mitigation action (e.g., Corporate, Litigation, IP).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeGroup .

ind:primaryAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member responsible for executing and completing the mitigation action.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:reviewerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member responsible for reviewing and verifying completion of the mitigation action.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:riskControlId rdf:type rdf:Property ;
    rdfs:label 'Risk Control Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_control. Business justification: Mitigation actions implement, test, or remediate specific controls. Business semantics: this action addresses this control. Creates valid chain: risk_mitigation_action → risk_control → risk_register' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskControl .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the mitigation or remediation action to be taken, including specific steps, controls, or interventions required.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerName rdf:type rdf:Property ;
    rdfs:label 'Action Owner Name' ;
    rdfs:comment 'Full name of the individual assigned as the action owner, denormalized for reporting convenience.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority level assigned to the mitigation action based on risk severity and urgency: critical (immediate), high (urgent), medium (standard), or low (routine).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Business-facing unique reference code for the mitigation action, used in reporting and tracking (e.g., RMA-00012345).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the mitigation action: assigned (not started), in_progress (underway), pending_review (awaiting approval), completed (finished), overdue (past due date), or cancelled (no longer required).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short descriptive title of the mitigation action for quick identification and reporting.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the mitigation action by control type: preventive (avoid risk), detective (identify occurrence), corrective (fix issue), compensating (alternative control), directive (policy/procedure), or recovery (restore after event).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the mitigation action, captured for budget tracking and ROI analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of hours spent completing the mitigation action, captured for performance tracking and future estimation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the mitigation action was formally assigned to the action owner.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the mitigation action was completed and closed. Null if action is not yet completed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionEvidence rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence' ;
    rdfs:comment 'Description or reference to evidence demonstrating completion of the mitigation action (e.g., document reference, system log, attestation, audit report).' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Detailed completion state: not_started (no work done), partial (in progress), complete (finished but not verified), verified (reviewed and approved), or rejected (completion not accepted).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Post-implementation assessment of how effective the mitigation action was in reducing the risk: effective (fully mitigated), partially_effective (some reduction), ineffective (no impact), or not_tested (not yet evaluated).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target completion date for the mitigation action, used for tracking and escalation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the mitigation action was escalated (e.g., overdue, insufficient resources, control ineffective, regulatory deadline).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Flag indicating whether this mitigation action requires escalation to senior management or the risk committee due to delays, resource constraints, or effectiveness concerns.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the mitigation action, including internal labor, external counsel, technology, or other resources.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of hours required to complete the mitigation action, used for resource planning and capacity management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lppApplies rdf:type rdf:Property ;
    rdfs:label 'Lpp Applies' ;
    rdfs:comment 'Flag indicating whether Legal Professional Privilege applies to this mitigation action and its associated documentation, restricting disclosure.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiInvolved rdf:type rdf:Property ;
    rdfs:label 'Pii Involved' ;
    rdfs:comment 'Flag indicating whether this mitigation action involves processing or handling of Personally Identifiable Information (PII), triggering additional data protection controls.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Flag indicating whether completion or failure of this mitigation action must be reported to a regulatory body or governing authority.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRiskReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Reassessment Date' ;
    rdfs:comment 'Date when the residual risk was reassessed following completion of this mitigation action. Null if reassessment not yet performed.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskReassessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Reassessment Required' ;
    rdfs:comment 'Flag indicating whether completion of this action triggers a formal reassessment of the residual risk rating in the risk register.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Comments or notes provided by the reviewer regarding the quality, completeness, or effectiveness of the mitigation action.' ;
    rdfs:domain ind:MitigationAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the completed mitigation action was formally reviewed and verified by the reviewer.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartyRiskId rdf:type rdf:Property ;
    rdfs:label 'Third Party Risk Id' ;
    rdfs:comment 'Unique identifier for the third-party risk assessment record. Primary key for the third_party_risk product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyRisk .

ind:primaryContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Agreement Id' ;
    rdfs:comment 'Unique identifier for the master service agreement or contract governing the vendor relationship.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAgreement .

ind:trustAccountId rdf:type rdf:Property ;
    rdfs:label 'Trust Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: Third-party payment processors and banks handling trust funds require vendor risk assessment. Trust banking relationships link to third-party risk records for due diligence, SOC2 verification, and DPA' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Unique identifier for the external vendor or service provider being assessed. Links to the vendor master record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:assessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency' ;
    rdfs:comment 'Frequency at which the vendor risk assessment is conducted, based on the risk tier and criticality of services provided.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientDataFlag rdf:type rdf:Property ;
    rdfs:label 'Client Data Flag' ;
    rdfs:comment 'Indicates whether the vendor has access to client data, including matter files, client communications, or client-specific information.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractualSecurityObligations rdf:type rdf:Property ;
    rdfs:label 'Contractual Security Obligations' ;
    rdfs:comment 'Summary of security and data protection obligations imposed on the vendor through contractual terms, including encryption, access controls, incident notification, and audit rights.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Incident Count' ;
    rdfs:comment 'Number of cybersecurity incidents or data breaches reported by or involving the vendor during the current assessment period.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Data Access Level' ;
    rdfs:comment 'Level of access the vendor has to firm or client data. Indicates whether vendor handles Personally Identifiable Information (PII), Legal Professional Privilege (LPP) protected data, or confidential information.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Execution Date' ;
    rdfs:comment 'Date when the Data Processing Agreement (DPA) was signed and became effective.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpaSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Dpa Signed Flag' ;
    rdfs:comment 'Indicates whether a Data Processing Agreement (DPA) has been executed with the vendor as required under GDPR Article 28 for data processors.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'Date when the initial due diligence assessment was completed for the vendor.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Status' ;
    rdfs:comment 'Current status of the vendor due diligence process, including Know Your Client (KYC) and Anti-Money Laundering (AML) checks required for third-party onboarding.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the vendor has demonstrated compliance with General Data Protection Regulation (GDPR) requirements for data processing and protection.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Quantitative risk score representing the inherent risk posed by the vendor before considering mitigating controls. Calculated based on data access, service criticality, and vendor profile.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Certificate Number' ;
    rdfs:comment 'Certificate number for the vendors ISO 27001 certification, if applicable.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds ISO 27001 certification for Information Security Management Systems (ISMS), demonstrating compliance with international security standards.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso27001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Expiry Date' ;
    rdfs:comment 'Expiration date of the vendors ISO 27001 certification, requiring renewal or re-assessment.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent risk assessment conducted for this vendor.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lppAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Access Flag' ;
    rdfs:comment 'Indicates whether the vendor has access to data protected by Legal Professional Privilege (LPP), requiring heightened confidentiality and security controls.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Status of ongoing monitoring activities for the vendor, including continuous security assessments, performance reviews, and compliance checks.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic risk assessment or review of the vendor relationship.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the vendor was formally onboarded and approved to provide services to the firm.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piiAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Access Flag' ;
    rdfs:comment 'Indicates whether the vendor has access to Personally Identifiable Information (PII) as defined under GDPR and data protection regulations.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reputationalRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Flag' ;
    rdfs:comment 'Indicates whether the vendor poses a reputational risk to the firm based on adverse media, regulatory actions, or ethical concerns.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reputationalRiskNotes rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Notes' ;
    rdfs:comment 'Detailed notes describing any reputational risk factors identified during vendor assessment, including adverse media findings or regulatory enforcement actions.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Quantitative risk score representing the residual risk after considering contractual controls, certifications, and monitoring activities.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current status of the vendor risk profile, indicating whether the risk is within acceptable thresholds or requires remediation actions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Overall risk classification assigned to the vendor based on data access level, service criticality, and security posture. Critical tier vendors require enhanced monitoring and controls.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date when the most recent sanctions screening was performed for the vendor.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of sanctions screening checks against international sanctions lists (OFAC, UN, EU) to ensure the vendor is not subject to trade restrictions or financial sanctions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Category of service provided by the third party. Includes Alternative Legal Service Provider (ALSP), technology vendors, document management systems, eDiscovery platforms, and other outsourced functions. [ENUM-REF-CANDIDATE: ALSP|technology_vendor|document_management|ediscovery|legal_research|cloud_services|managed_services|consulting|outsourced_legal_services — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the services provided by the third party, including scope of work and deliverables.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soc2CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Soc2 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor has completed a Service Organization Control (SOC) 2 audit, demonstrating controls for security, availability, processing integrity, confidentiality, and privacy.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toRegister rdf:type rdf:Property ;
    rdfs:label 'To Register' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Third-party risks should be registered in the enterprise risk register for consolidated reporting and governance oversight.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toRiskRegister rdf:type rdf:Property ;
    rdfs:label 'To Risk Register' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Third-party risks should be registered in the enterprise risk register. This ensures vendor risks are visible in the consolidated risk view.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Code' ;
    rdfs:comment 'Internal reference code or identifier assigned to the vendor for tracking and reporting purposes.' ;
    rdfs:domain ind:ThirdPartyRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor relationship, indicating whether services are actively being provided or the relationship has been suspended or terminated.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyberRiskEventId rdf:type rdf:Property ;
    rdfs:label 'Cyber Risk Event Id' ;
    rdfs:comment 'Unique identifier for the cyber risk event record. Primary key for the cyber risk event entity.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedTrustAccountId rdf:type rdf:Property ;
    rdfs:label 'Affected Trust Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: Cyber events (ransomware, unauthorized access, phishing) target trust accounts for fraud. Incident response requires isolating affected trust accounts for containment, forensic preservation, and clien' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:cyberAssignedToUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Cyber Assigned To User Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper or staff member currently responsible for managing and resolving the cyber risk event.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:cyberEscalatedToUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Cyber Escalated To User Timekeeper Id' ;
    rdfs:comment 'Reference to the senior timekeeper or executive to whom the cyber risk event was escalated for decision-making or oversight.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:eventOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Event Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper or staff member who first reported or identified the cyber risk event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:actualLossAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Loss Amount' ;
    rdfs:comment 'The realized financial loss incurred as a direct result of the cyber risk event, including recovery costs, legal fees, regulatory fines, and business interruption costs.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedClientCount rdf:type rdf:Property ;
    rdfs:label 'Affected Client Count' ;
    rdfs:comment 'The number of clients whose data or services were affected by the cyber risk event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Affected Practice Group' ;
    rdfs:comment 'Name of the practice group or business unit affected by the cyber risk event, if the impact was localized to a specific area of the firm.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Affected Record Count' ;
    rdfs:comment 'The total number of data records (documents, files, database rows) compromised or affected by the cyber risk event.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'Name or identifier of the primary IT system, application, or infrastructure component impacted by the cyber risk event (e.g., Elite 3E, iManage Work, email server, network infrastructure).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedUserCount rdf:type rdf:Property ;
    rdfs:label 'Affected User Count' ;
    rdfs:comment 'The number of internal users (timekeepers, staff) whose accounts or data were affected by the cyber risk event.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Description of the immediate containment measures taken to limit the spread or impact of the cyber risk event (e.g., system isolation, account lockdown, network segmentation).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataBreachIncidentId rdf:type rdf:Property ;
    rdfs:label 'Data Breach Incident Id' ;
    rdfs:comment 'foreign_key_to' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataBreachIncident .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'The date when the cyber risk event was first detected or identified by the firm, which may differ from the event occurrence date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'The mechanism or channel through which the cyber risk event was first identified (e.g., automated monitoring, user report, internal audit, external notification). [ENUM-REF-CANDIDATE: automated_monitoring|user_report|internal_audit|external_notification|penetration_test|vulnerability_scan|siem_alert|third_party_notification|regulatory_inquiry — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'The total duration in hours that systems or services were unavailable as a result of the cyber risk event.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'The estimated potential financial loss for near-miss events or events where actual loss has not yet been fully quantified.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date when the cyber risk event occurred or was first realized by the firm.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventRealizesRisk rdf:type rdf:Property ;
    rdfs:label 'Event Realizes Risk' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Risk events represent the realization of identified risks. Linking events back to the register enables loss tracking against risk items.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the cyber risk event, used for tracking and reporting purposes across the firm.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the cyber risk event indicating the stage of incident response and resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when the cyber risk event occurred or was first detected, supporting forensic analysis and timeline reconstruction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Primary classification of the cyber risk event indicating the nature of the incident (e.g., phishing attack, ransomware, DDoS, insider threat, system outage, process failure). [ENUM-REF-CANDIDATE: phishing|ransomware|ddos|insider_threat|malware|vulnerability_exploit|unauthorized_access|data_exfiltration|system_outage|process_failure|human_error|external_fraud|third_party_failure|physical_security_breach — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartyInvolved rdf:type rdf:Property ;
    rdfs:label 'External Party Involved' ;
    rdfs:comment 'Name of any external third party involved in the cyber risk event (e.g., vendor, service provider, attacker organization if known).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed' ;
    rdfs:comment 'Flag indicating whether a professional indemnity or cyber insurance claim was filed for this cyber risk event.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number for the insurance claim filed in relation to this cyber risk event, if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNearMiss rdf:type rdf:Property ;
    rdfs:label 'Is Near Miss' ;
    rdfs:comment 'Flag indicating whether the event was a near-miss incident (detected and prevented before causing actual loss or impact).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportableBreach rdf:type rdf:Property ;
    rdfs:label 'Is Reportable Breach' ;
    rdfs:comment 'Flag indicating whether the cyber risk event constitutes a reportable data breach under GDPR Article 33/34 or other regulatory notification requirements.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoControlReference rdf:type rdf:Property ;
    rdfs:label 'Iso Control Reference' ;
    rdfs:comment 'Reference to the specific ISO 27001 Annex A control(s) that were breached or tested by this cyber risk event (e.g., A.12.6.1, A.16.1.2).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Documentation of key insights, process improvements, and preventive measures identified through post-incident review to reduce future risk exposure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Loss Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the actual or estimated loss amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryCostAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Cost Amount' ;
    rdfs:comment 'The total cost incurred to recover from the cyber risk event, including forensic investigation, system restoration, and external consultant fees.' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Flag indicating whether the cyber risk event requires notification to regulatory authorities (e.g., ICO, SRA, state bar associations).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective actions taken to resolve the cyber risk event and restore normal operations (e.g., patch deployment, password reset, system rebuild).' ;
    rdfs:domain ind:CyberRiskEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date when the cyber risk event was fully resolved and normal operations were restored.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed analysis of the underlying cause(s) of the cyber risk event, identifying systemic weaknesses or control failures that enabled the incident.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Impact severity classification of the event aligned to ISO 27001 impact assessment levels (critical, high, medium, low, informational).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Id' ;
    rdfs:comment 'Primary key for sanctions_screening' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreening .

ind:contractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Contract Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Sanctions screening performed at client onboarding and contract execution. Linking screening results to specific agreements enables AML/KYC compliance, contract approval workflow, conflict checking, a' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAgreement .

ind:reputationalRiskId rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Id' ;
    rdfs:comment 'Foreign key linking to risk.reputational_risk. Business justification: Sanctions screening hits can trigger reputational risk flags. Business semantics: this screening result generated this reputational risk flag. Valid causal relationship.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReputationalRisk .

ind:screenedReceiptId rdf:type rdf:Property ;
    rdfs:label 'Screened Receipt Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_receipt. Business justification: AML sanctions screening occurs at trust receipt intake before deposit. All receipts require payor screening against OFAC/sanctions lists per AML regulations; screening result determines whether receip' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receipt .

ind:screenedTrustDisbursementId rdf:type rdf:Property ;
    rdfs:label 'Screened Trust Disbursement Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_disbursement. Business justification: All trust disbursements require payee sanctions screening before execution per AML policy. Screening result blocks disbursement if match found; clearance decision and screening reference must be docum' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrustDisbursement .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Indicates whether adverse media or negative news was identified for the screened entity during the screening process (True = adverse media found, False = no adverse media).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'Overall AML risk rating assigned to the screened entity based on the screening results and compliance review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceConditions rdf:type rdf:Property ;
    rdfs:label 'Clearance Conditions' ;
    rdfs:comment 'Specific conditions or restrictions imposed if the clearance decision was conditional approval.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date when the final clearance decision was made.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceDecision rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision' ;
    rdfs:comment 'Final clearance decision for the screened entity: approved (cleared to proceed), declined (engagement rejected), or conditional approval (proceed with restrictions).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enhancedDueDiligenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Enhanced Due Diligence Required Flag' ;
    rdfs:comment 'Indicates whether enhanced due diligence procedures are required for this entity based on the screening results (True = EDD required, False = standard due diligence sufficient).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this screening result was escalated to senior compliance or risk management for further review (True = escalated, False = not escalated).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the match was determined to be a false positive after review (True = false positive, False = genuine match).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:falsePositiveReason rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason' ;
    rdfs:comment 'Explanation of why the match was classified as a false positive, including distinguishing factors identified during review.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchCount rdf:type rdf:Property ;
    rdfs:label 'Match Count' ;
    rdfs:comment 'Number of potential matches identified during the screening process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the strength of the match between the screened entity and the sanctions list entry.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Type of match found during screening: exact name match, fuzzy match, alias match, phonetic match, or no match.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListEntryName rdf:type rdf:Property ;
    rdfs:label 'Matched List Entry Name' ;
    rdfs:comment 'Name of the entity on the sanctions list that matched the screened entity.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListEntryReference rdf:type rdf:Property ;
    rdfs:label 'Matched List Entry Reference' ;
    rdfs:comment 'Unique reference or identifier of the matched entry on the sanctions list (e.g., OFAC SDN number, UN reference number).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepCategory rdf:type rdf:Property ;
    rdfs:label 'Pep Category' ;
    rdfs:comment 'Classification of the PEP status: domestic PEP, foreign PEP, international organization PEP, family member of PEP, or close associate of PEP.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Indicates whether the screened entity is identified as a Politically Exposed Person (True = PEP, False = not PEP).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Rescreening Due Date' ;
    rdfs:comment 'Date when the entity is due for periodic rescreening to maintain ongoing AML compliance.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Detailed notes and rationale documented by the compliance officer during their review of the screening result.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Final outcome of the compliance officer review: cleared (no risk), rejected (engagement declined), pending review, requires enhanced due diligence, or approved with conditions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityCountryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Country Of Residence' ;
    rdfs:comment 'Three-letter ISO country code representing the country of residence or incorporation of the screened entity.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual being screened, used to improve match accuracy and reduce false positives.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenedEntityName rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Name' ;
    rdfs:comment 'Full name of the individual or organization being screened against sanctions lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityNationalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Screened Entity National Identifier' ;
    rdfs:comment 'National identification number or registration number of the screened entity used for enhanced screening accuracy.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Classification of the entity being screened (individual, organization, beneficial owner, counterparty, matter participant, or trust).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the sanctions screening check was performed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningListChecked rdf:type rdf:Property ;
    rdfs:label 'Screening List Checked' ;
    rdfs:comment 'Comma-separated list of sanctions and watchlists checked during this screening (OFAC, UN, EU, HMT, PEP, etc.). [ENUM-REF-CANDIDATE: OFAC|UN|EU|HMT|PEP|INTERPOL|DFAT|SECO — promote to reference product]' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Unique business reference number assigned to this screening check for tracking and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current status of the screening process: completed, in progress, pending review, or failed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemName rdf:type rdf:Property ;
    rdfs:label 'Screening System Name' ;
    rdfs:comment 'Name of the automated screening system or service used to perform the sanctions check (e.g., Dow Jones, LexisNexis, Refinitiv World-Check).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Screening System Version' ;
    rdfs:comment 'Version number of the screening system or database used at the time of the check.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the sanctions screening check was initiated.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger Event' ;
    rdfs:comment 'Business event that triggered this sanctions screening: new client intake, matter opening, periodic review, regulatory update, or risk event.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this screening result record was last modified.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoredAccountId rdf:type rdf:Property ;
    rdfs:label 'Monitored Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: High-risk clients flagged for reputational concerns require enhanced trust account monitoring. Enhanced due diligence applies to trust accounts of flagged clients with increased reconciliation frequen' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Explanation for why the reputational risk flag was closed, such as risk no longer applicable, engagement declined, matter completed, or false positive determination.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the counterparty or third party that is the subject of the reputational risk flag.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final decision or action taken regarding the reputational risk flag: accepted with conditions (engagement proceeds with enhanced monitoring), declined (engagement rejected), monitored (ongoing surveillance), escalated to board for decision, or no action required (risk deemed immaterial).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Engaged Flag' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged to advise on the reputational risk flag and appropriate firm response.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flagRaisedBy rdf:type rdf:Property ;
    rdfs:label 'Flag Raised By' ;
    rdfs:comment 'Name or identifier of the individual or system that raised the reputational risk flag.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Flag Raised Date' ;
    rdfs:comment 'Date on which the reputational risk flag was first raised and recorded in the system.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flagReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Flag Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the reputational risk flag, used for tracking and communication.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagSource rdf:type rdf:Property ;
    rdfs:label 'Flag Source' ;
    rdfs:comment 'Origin of the reputational risk flag: internal research, third-party screening service, media monitoring tool, regulatory alert, client disclosure, conflict check system output, or manual review by risk team. [ENUM-REF-CANDIDATE: internal_research|third_party_screening|media_monitoring|regulatory_alert|client_disclosure|conflict_check_system|manual_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagSourceDetail rdf:type rdf:Property ;
    rdfs:label 'Flag Source Detail' ;
    rdfs:comment 'Additional detail about the source of the flag, such as the name of the screening vendor, media outlet, or regulatory body that issued the alert.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of the potential impact to the firm if the reputational risk materializes, including potential regulatory scrutiny, client loss, or media attention.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Industry sector or business activity associated with the reputational risk, such as arms trade, extractive industries, gambling, or tobacco.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Notification Flag' ;
    rdfs:comment 'Indicates whether the firms professional indemnity insurance carrier was notified about the reputational risk flag due to potential exposure.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction associated with the reputational risk flag, particularly relevant for high-risk jurisdiction flags.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Name or identifier of the user who last modified the reputational risk flag record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Media Exposure Flag' ;
    rdfs:comment 'Indicates whether the reputational risk flag has resulted in or has potential for adverse media coverage of the firm.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationActions rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions' ;
    rdfs:comment 'Specific actions taken or planned to mitigate the reputational risk, such as enhanced client due diligence, engagement letter modifications, or public relations strategy.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which the reputational risk flag is monitored if the disposition is to monitor: continuous, monthly, quarterly, semi-annual, annual, or as needed based on trigger events.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the reputational risk flag, applicable when ongoing monitoring is required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether the reputational risk flag triggers a mandatory notification to a regulatory body such as the Solicitors Regulation Authority (SRA) or Law Society.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory body for the notification or investigation related to this reputational risk flag.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the reputational risk flag review process: pending review, under review by risk committee, reviewed and decided, escalated to senior management, or closed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the individual or committee that conducted the formal review of the reputational risk flag.' ;
    rdfs:domain ind:ReputationalRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the reputational risk concern, including specific allegations, media reports, or regulatory findings.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterRiskProfileId rdf:type rdf:Property ;
    rdfs:label 'Matter Risk Profile Id' ;
    rdfs:comment 'Unique identifier for the matter risk profile record. Primary key for this entity. Role: MASTER_RESOURCE (risk profile as a managed resource).' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appetiteId rdf:type rdf:Property ;
    rdfs:label 'Appetite Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_appetite. Business justification: Matter risk profiles are evaluated against firm risk appetite thresholds. Valid business relationship for matter acceptance and risk governance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:primaryAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Id' ;
    rdfs:comment 'Foreign key linking to trust.trust_account. Business justification: High-risk matters require segregated trust accounting with enhanced controls. Matter risk tier determines trust account monitoring frequency, reconciliation requirements, and authorization thresholds ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:amlRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Flag' ;
    rdfs:comment 'Indicates whether the matter presents elevated anti-money laundering risk requiring enhanced due diligence, source of funds verification, and suspicious activity monitoring.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientCreditRiskRating rdf:type rdf:Property ;
    rdfs:label 'Client Credit Risk Rating' ;
    rdfs:comment 'Credit risk assessment of the client using standard rating scale, indicating likelihood of payment default and informing billing arrangements and retainer requirements. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientPaymentHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Client Payment History Flag' ;
    rdfs:comment 'Historical payment performance indicator for this client based on past matters, informing credit risk and billing strategy.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Risk Level' ;
    rdfs:comment 'Assessment of potential conflicts of interest based on client relationships, adverse parties, and matter subject matter, informing ethical wall requirements and engagement decisions.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether the matter involves multiple jurisdictions, triggering additional conflict-of-laws analysis and regulatory compliance requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cybersecurityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Risk Level' ;
    rdfs:comment 'Assessment of cybersecurity and data breach risk for this matter based on data sensitivity, technology platforms used, third-party access, and threat landscape, informing ISO 27001 controls.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediscoveryVolumeExposure rdf:type rdf:Property ;
    rdfs:label 'Ediscovery Volume Exposure' ;
    rdfs:comment 'Assessment of the volume and complexity of Electronically Stored Information (ESI) that may be subject to discovery, impacting matter cost, timeline, and technology-assisted review (TAR) requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this matter risk profile requires escalation to senior management, risk committee, or board level due to risk tier or specific risk factors.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esiVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Esi Volume Gb' ;
    rdfs:comment 'Estimated volume of ESI in gigabytes that may be subject to collection, review, and production in this matter, driving eDiscovery cost and resource planning.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMatterValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Matter Value' ;
    rdfs:comment 'Estimated total value at stake in the matter (transaction value, claim amount, or potential liability), used to assess proportionality of risk and insurance coverage adequacy. Expressed in firm base currency.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionalRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdictional Risk Level' ;
    rdfs:comment 'Risk rating based on the legal jurisdictions involved, considering political stability, judicial predictability, enforcement mechanisms, and regulatory environment.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent risk profile review, typically conducted at matter milestones (mid-matter review, pre-trial, significant developments).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lppSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Lpp Sensitivity Level' ;
    rdfs:comment 'Assessment of the sensitivity of privileged communications and work product in this matter, driving information security controls and ethical wall requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterComplexityRating rdf:type rdf:Property ;
    rdfs:label 'Matter Complexity Rating' ;
    rdfs:comment 'Assessment of the legal and factual complexity of the matter considering number of parties, jurisdictions, legal issues, document volume, and expert requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterProfileReferencesRisks rdf:type rdf:Property ;
    rdfs:label 'Matter Profile References Risks' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Matter risk profiles aggregate risk dimensions that may reference specific risk register items for that matter.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Matter Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated matter value (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaExposureLikelihood rdf:type rdf:Property ;
    rdfs:label 'Media Exposure Likelihood' ;
    rdfs:comment 'Probability that the matter will attract media attention or public scrutiny, informing communications strategy and reputational risk management.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRiskTier rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Tier' ;
    rdfs:comment 'Consolidated risk rating for the matter using traffic-light classification: green (low risk), amber (medium risk), red (high risk). Drives partner review frequency and approval thresholds.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiDataVolumeCategory rdf:type rdf:Property ;
    rdfs:label 'Pii Data Volume Category' ;
    rdfs:comment 'Classification of the volume of PII involved in the matter, informing GDPR compliance requirements, data breach risk exposure, and data protection impact assessment needs.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the primary legal jurisdiction governing this matter (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalIndemnityExposure rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Exposure' ;
    rdfs:comment 'Assessment of potential professional liability and malpractice risk exposure for this matter, informing insurance notification requirements and risk mitigation protocols.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Profile Created Date' ;
    rdfs:comment 'Date when this risk profile was initially created, typically at matter intake or new business approval stage.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Precise timestamp when this risk profile record was first created in the system, supporting audit trail and lifecycle tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Reference Number' ;
    rdfs:comment 'Human-readable unique reference code for this matter risk profile, typically formatted as MRP-YYYYNNNN for external communication and audit trails.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the risk profile indicating whether it is in draft, actively monitored, under review by risk committee, escalated to senior management, closed upon matter completion, or archived.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScrutinyLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scrutiny Level' ;
    rdfs:comment 'Assessment of the level of regulatory oversight and reporting requirements applicable to this matter, considering industry sector, transaction type, and jurisdictional requirements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationalRiskRating rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Rating' ;
    rdfs:comment 'Assessment of potential reputational harm to the firm from association with this matter, considering client profile, matter type, public visibility, and ethical considerations.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Summary of key risk mitigation strategies and controls implemented for this matter, including enhanced supervision, ethical walls, insurance notifications, and client communications.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required Flag' ;
    rdfs:comment 'Indicates whether parties, jurisdictions, or transaction elements require screening against international sanctions lists (OFAC, UN, EU) to ensure compliance with economic sanctions regimes.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCategoryDataFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Flag' ;
    rdfs:comment 'Indicates whether the matter involves GDPR Article 9 special category data (racial/ethnic origin, political opinions, religious beliefs, health data, biometric data, genetic data, sex life/orientation), requiring heightened data protection controls.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Risk Flag' ;
    rdfs:comment 'Indicates whether the matter involves third-party service providers (expert witnesses, eDiscovery vendors, co-counsel, ALSPs) requiring vendor due diligence and data sharing agreements.' ;
    rdfs:domain ind:MatterRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appetiteLastUpdatedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Appetite Last Updated By Timekeeper Id' ;
    rdfs:comment 'Foreign key reference to the user or system that last updated this risk appetite threshold record.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:appetiteOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Appetite Owner Timekeeper Id' ;
    rdfs:comment 'Foreign key reference to the user or system that created this risk appetite threshold record.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryAppetiteAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Appetite Attorney Profile Id' ;
    rdfs:comment 'Foreign key reference to the individual (partner or executive) who formally approved this risk appetite threshold.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:supersededByAppetiteId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Appetite Id' ;
    rdfs:comment 'Foreign key reference to the risk appetite threshold record that supersedes this one (nullable for current active thresholds).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appetite .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which this risk appetite threshold was formally approved by the governance body.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvingGovernanceBody rdf:type rdf:Property ;
    rdfs:label 'Approving Governance Body' ;
    rdfs:comment 'The governance body or role responsible for approving and maintaining this risk appetite threshold (e.g., Risk Committee, Managing Partner, Board, Executive Committee).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automaticEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether risks exceeding the escalation trigger score are automatically escalated to the governance body (true) or require manual review (false).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether client notification is required when a risk exceeds this appetite threshold (relevant for data breach, conflict, or professional indemnity risks).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this risk appetite threshold becomes active and applicable to risk assessments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this risk appetite threshold expires or is superseded. Nullable for currently active thresholds.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationTriggerScore rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Score' ;
    rdfs:comment 'Risk score threshold at which escalation to senior management or governance body is automatically triggered. Typically lower than maximum tolerable score.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialExposureLimit rdf:type rdf:Property ;
    rdfs:label 'Financial Exposure Limit' ;
    rdfs:comment 'Maximum financial exposure (in firm base currency) the firm is willing to accept for risks in this category before mandatory action is required.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether professional indemnity or other insurance coverage is required for risks in this category exceeding the threshold.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryMitigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Mitigation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether risks exceeding this threshold require mandatory mitigation actions (true) or are subject to discretionary treatment (false).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTolerableRiskScore rdf:type rdf:Property ;
    rdfs:label 'Maximum Tolerable Risk Score' ;
    rdfs:comment 'The highest risk score the firm is willing to accept before mandatory mitigation or escalation is required. Represents the upper boundary of risk tolerance.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAcceptableRiskScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Risk Score' ;
    rdfs:comment 'The lower boundary of the risk tolerance band. Risks scoring below this threshold are considered within normal operational tolerance.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizationalLevel rdf:type rdf:Property ;
    rdfs:label 'Organizational Level' ;
    rdfs:comment 'Level of the organization to which this risk appetite threshold applies (firm-wide, practice group, office, or matter-specific).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulator Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether regulatory notification (e.g., to ICO, SRA, State Bar) is required when a risk exceeds this appetite threshold.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which this risk appetite threshold must be reviewed and reaffirmed (monthly, quarterly, semi-annually, annually, or ad-hoc).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreScale rdf:type rdf:Property ;
    rdfs:label 'Risk Score Scale' ;
    rdfs:comment 'The scoring scale used for risk assessment (e.g., 1-5, 1-10, 1-25, 1-100). Provides context for interpreting threshold scores.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Detailed subcategory or classification within the primary risk category (e.g., GDPR breach, ISO 27001 incident, AML screening failure).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceBand rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Band' ;
    rdfs:comment 'Categorical classification of the risk tolerance level (low, medium, high, critical) corresponding to the threshold score range.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdRationale rdf:type rdf:Property ;
    rdfs:label 'Threshold Rationale' ;
    rdfs:comment 'Business justification and rationale for setting this specific risk appetite threshold, including strategic considerations and risk-return trade-offs.' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Threshold Reference Code' ;
    rdfs:comment 'Business-readable unique reference code for the risk appetite threshold (e.g., RAT-FIRM-001, RAT-LITG-002).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdStatus rdf:type rdf:Property ;
    rdfs:label 'Threshold Status' ;
    rdfs:comment 'Current lifecycle status of the risk appetite threshold (draft, active, under review, superseded, expired).' ;
    rdfs:domain ind:Appetite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this risk appetite threshold record, incremented with each revision or update.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClaimId rdf:type rdf:Property ;
    rdfs:label 'Pi Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for the professional indemnity claim record. Primary key for the pi_claim data product in the risk domain.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PiClaim .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: PI claims frequently originate from billing issues (overbilling allegations, rate disputes, guideline violations). Firms track which invoice(s) triggered the claim for defense preparation, settlement ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:responsibleTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Responsible Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney or fee earner) identified as the responsible professional on the matter at the time the alleged breach occurred. Used for workforce risk analytics and PI exposure reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:adrMethod rdf:type rdf:Property ;
    rdfs:label 'Adr Method' ;
    rdfs:comment 'The Alternative Dispute Resolution (ADR) method employed or proposed for resolving the PI claim outside of formal litigation. Null or none if the claim is proceeding through court litigation or has been resolved without ADR.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegedBreachDate rdf:type rdf:Property ;
    rdfs:label 'Alleged Breach Date' ;
    rdfs:comment 'The date on which the alleged act, error, or omission giving rise to the claim is said to have occurred. Relevant for determining the applicable policy period on a claims-made or occurrence basis and for limitation period analysis.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allegedBreachDescription rdf:type rdf:Property ;
    rdfs:label 'Alleged Breach Description' ;
    rdfs:comment 'Narrative description of the alleged act, error, or omission forming the basis of the professional indemnity claim. Includes the nature of the professional failing alleged (e.g., negligent advice, missed deadline, conflict of interest, breach of confidentiality). Protected by Legal Professional Privilege (LPP) considerations.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'The date on which the formal claim was made against the firm by the claimant or their legal representative. This is the principal business event date for the claim and determines the applicable policy year for PI insurance purposes.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimOutcome rdf:type rdf:Property ;
    rdfs:label 'Claim Outcome' ;
    rdfs:comment 'The final resolution outcome of the professional indemnity claim. Populated upon closure of the claim. Used for risk analytics, insurer reporting, and lessons-learned reviews. [ENUM-REF-CANDIDATE: settled|dismissed|judgment_for_claimant|judgment_for_firm|withdrawn|mediated|arbitrated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the claim at inception, used in all correspondence with the PI insurer, coverage counsel, and claimant. Follows the firms PI claim numbering convention (e.g., PI-2024-000123).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the professional indemnity claim. Tracks progression from initial notification through investigation, insurer notification, litigation or negotiation, and final resolution. [ENUM-REF-CANDIDATE: open|under_investigation|notified_to_insurer|in_litigation|settled|closed|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Claimant Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction in which the claimant is domiciled or in which the claim is being pursued. Relevant for determining applicable law, limitation periods, and cross-border PI coverage.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the party making the professional indemnity claim against the firm. May be the firms own client, a third party, or a counterparty to a transaction on which the firm advised. Classified confidential due to sensitivity of claim proceedings.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the claimants relationship to the firm. Distinguishes between the firms own clients, third parties who relied on the firms work product, counterparties to transactions, and regulatory bodies bringing disciplinary claims.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageConfirmed rdf:type rdf:Property ;
    rdfs:label 'Coverage Confirmed' ;
    rdfs:comment 'Indicates whether the PI insurer has confirmed that the claim falls within the scope of the firms professional indemnity policy coverage. True when coverage is confirmed; False when coverage is denied or under reservation of rights.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageDenialReason rdf:type rdf:Property ;
    rdfs:label 'Coverage Denial Reason' ;
    rdfs:comment 'Narrative explanation provided by the insurer for any denial of coverage or reservation of rights. Populated only when coverage_confirmed is False. Used for coverage dispute management and legal review.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataBreachReference rdf:type rdf:Property ;
    rdfs:label 'Data Breach Reference' ;
    rdfs:comment 'Cross-reference to the data breach incident record in the risk domain if the PI claim arises from or is associated with a data breach event. Enables linkage between the PI claims register and the data breach incident management register.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The self-insured retention or deductible amount applicable to this claim under the firms PI policy. Represents the portion of the claim cost borne directly by the firm before insurer indemnity applies.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defenceCostsIncurred rdf:type rdf:Property ;
    rdfs:label 'Defence Costs Incurred' ;
    rdfs:comment 'Cumulative legal and professional costs incurred by the firm in defending the PI claim, including external coverage counsel fees, expert witness fees, and court costs. Tracked separately from the settlement amount for insurer reimbursement and cost management purposes.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicalWallRequired rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Required' ;
    rdfs:comment 'Indicates whether an ethical wall (information barrier) has been established in Intapp Conflicts to prevent the timekeepers involved in the underlying matter from accessing PI claim information, protecting privilege and avoiding further conflict exposure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurerClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Claim Reference' ;
    rdfs:comment 'The reference number assigned to the claim by the PI insurer for tracking within the insurers own claims management system. Used in all insurer correspondence and for reconciliation between the firms records and the insurers records.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'The name of the professional indemnity insurer or lead underwriter handling the claim. Required for insurer correspondence, coverage confirmation, and claims management coordination.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Limitation Expiry Date' ;
    rdfs:comment 'The date on which the applicable limitation period for the claimants cause of action expires. Critical for assessing whether the claim is time-barred and for managing the firms procedural response deadlines.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piiDataInvolved rdf:type rdf:Property ;
    rdfs:label 'Pii Data Involved' ;
    rdfs:comment 'Indicates whether the alleged breach involves the unauthorised disclosure, loss, or mishandling of Personally Identifiable Information (PII). When True, the claim may also trigger data breach notification obligations under GDPR, CCPA, or DPA 2018.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The policy number of the professional indemnity insurance policy under which the claim is being notified and managed. Identifies the specific policy year and coverage layer applicable to the claim.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyYear rdf:type rdf:Property ;
    rdfs:label 'Policy Year' ;
    rdfs:comment 'The four-digit calendar year of the PI insurance policy period under which the claim is notified (e.g., 2024). Determines the applicable coverage limits, deductibles, and insurer for claims-made policies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceArea rdf:type rdf:Property ;
    rdfs:label 'Practice Area' ;
    rdfs:comment 'The legal practice area associated with the matter from which the claim arises. Used for risk analytics to identify practice areas with elevated PI exposure and to inform risk management and training priorities. [ENUM-REF-CANDIDATE: corporate|litigation|intellectual_property|employment|real_estate|regulatory|tax|banking_finance|private_client|other — promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'The date on which the firm submitted the required regulatory report to the relevant governing body (e.g., SRA, state bar). Null if no regulatory report is required or if the report has not yet been filed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required' ;
    rdfs:comment 'Indicates whether the PI claim triggers a mandatory regulatory reporting obligation, such as notification to the SRA, state bar association, or other governing body. True when reporting is required under applicable professional conduct rules.' ;
    rdfs:domain ind:PiClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'The financial reserve established by the firm and/or its PI insurer to cover the estimated ultimate cost of the claim, including potential settlement, defence costs, and associated expenses. Used for financial provisioning and insurer reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The agreed monetary amount paid to the claimant to resolve the professional indemnity claim, as recorded upon settlement. Null if the claim has not been settled. Distinct from the original claim amount and the reserve.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCyberRiskEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Cyber Risk Event Id' ;
    rdfs:comment 'FK to risk.cyber_risk_event.cyber_risk_event_id — A data breach is a specific type of risk event with additional privacy-specific regulatory attributes. The parent event should be linkable for consolidated event reporting.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CyberRiskEvent .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Assessed severity level of the data breach based on volume of data, sensitivity, and potential harm to data subjects.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSource rdf:type rdf:Property ;
    rdfs:label 'Breach Source' ;
    rdfs:comment 'Origin of the breach: internal actor, external threat actor, third-party vendor, or unknown.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentDate rdf:type rdf:Property ;
    rdfs:label 'Containment Date' ;
    rdfs:comment 'Date when the breach was successfully contained and further unauthorized access or data loss was prevented.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesInvolved rdf:type rdf:Property ;
    rdfs:label 'Data Categories Involved' ;
    rdfs:comment 'Comma-separated list of data categories compromised in the breach (e.g., PII, special category data under GDPR Article 9, LPP-protected information, financial data, health data).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Date' ;
    rdfs:comment 'Date when affected data subjects were notified of the breach, if notification was required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Method' ;
    rdfs:comment 'Method used to notify affected data subjects of the breach (email, postal mail, phone call, public notice).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notification Required Flag' ;
    rdfs:comment 'Indicates whether direct notification to affected data subjects is required under GDPR Article 34 or other applicable privacy laws.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Affected Count' ;
    rdfs:comment 'Estimated or confirmed number of individual data subjects (clients, employees, third parties) whose personal data was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discoveredBy rdf:type rdf:Property ;
    rdfs:label 'Discovered By' ;
    rdfs:comment 'Name or role of the individual, team, or automated system that discovered the breach (e.g., IT Security Team, employee report, automated monitoring).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the data breach or privacy incident was first discovered or reported to the firm.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise timestamp when the data breach incident was first discovered, critical for GDPR 72-hour notification clock.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dpoNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Notified Date' ;
    rdfs:comment 'Date when the firms Data Protection Officer was notified of the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forensicInvestigationFlag rdf:type rdf:Property ;
    rdfs:label 'Forensic Investigation Flag' ;
    rdfs:comment 'Indicates whether a formal forensic investigation was conducted by internal or external cybersecurity experts.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdpr72HourDeadline rdf:type rdf:Property ;
    rdfs:label 'Gdpr 72 Hour Deadline' ;
    rdfs:comment 'Calculated timestamp representing the 72-hour deadline from discovery for notifying the supervisory authority under GDPR Article 33.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:icoNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ico Notification Date' ;
    rdfs:comment 'Date when the breach was formally notified to the UK Information Commissioners Office (ICO) or equivalent supervisory authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icoNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ico Notification Status' ;
    rdfs:comment 'Current status of the regulatory notification to the ICO or equivalent data protection authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icoReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ico Reference Number' ;
    rdfs:comment 'Reference number assigned by the ICO or supervisory authority upon receipt of the breach notification.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Estimated or confirmed date when the actual breach or unauthorized access occurred, which may differ from discovery date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentOwner rdf:type rdf:Property ;
    rdfs:label 'Incident Owner' ;
    rdfs:comment 'Name or identifier of the individual responsible for managing the breach incident response and remediation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the data breach incident for tracking and regulatory reporting purposes. Format: DBI-YYYY-NNNNNN.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the data breach incident in the investigation and remediation workflow.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a professional indemnity or cyber insurance claim has been filed for this breach incident.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified of the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReference rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Reference' ;
    rdfs:comment 'Reference number or case identifier assigned by law enforcement if the breach was reported to police or other authorities.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppProtectedDataFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Protected Data Flag' ;
    rdfs:comment 'Indicates whether data protected by Legal Professional Privilege (attorney-client privileged communications) was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory notification to a supervisory authority (ICO, DPA, state attorney general) is required under applicable data protection laws.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiCompromisedFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Compromised Flag' ;
    rdfs:comment 'Indicates whether Personally Identifiable Information was compromised in the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions Taken' ;
    rdfs:comment 'Detailed description of remediation actions taken to address the breach, prevent recurrence, and mitigate harm to data subjects (e.g., password resets, system patches, access revocation, enhanced monitoring).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceControlId rdf:type rdf:Property ;
    rdfs:label 'Compliance Control Id' ;
    rdfs:comment 'Foreign key to compliance.compliance_control.compliance_control_id' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceControl .

ind:riskQuaternaryApprovedByAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Risk Quaternary Approved By Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or senior risk officer who formally approved this control for inclusion in the risk register and Statement of Applicability. Supports governance and segregation of duties requirements.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:tertiaryRemediationOwnerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Remediation Owner Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member accountable for completing the remediation action. Null if no remediation is required. Supports escalation workflows and accountability tracking.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:automationFlag rdf:type rdf:Property ;
    rdfs:label 'Automation Flag' ;
    rdfs:comment 'Indicates whether the control is automated (True) or manual (False). Automated controls are executed by systems (e.g., Intapp Conflicts automated screening, iManage access controls); manual controls rely on human action. Informs risk appetite assessments and operational resilience planning.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and mechanism of the control, including how it addresses the identified risk. Supports ISO 27001 Statement of Applicability (SoA) documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short, human-readable title of the risk control (e.g., Privileged Access Review, PII Data Encryption at Rest, Conflict Check Gate). Used in dashboards, audit reports, and SRA compliance reviews.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control by its functional purpose in the risk management lifecycle. Preventive controls stop risk events; detective controls identify them; corrective controls remediate them; deterrent controls discourage threats; compensating controls substitute for primary controls; directive controls mandate behaviour.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Narrative description of any control deficiency, gap, or weakness identified during the most recent test. Null if no deficiency was found. Feeds the remediation workflow and is referenced in ISO 27001 nonconformity reports and SRA compliance submissions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Design Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the control is suitably designed to address the risk it targets, independent of whether it is operating correctly. Adequate: design is fit for purpose. Inadequate: design has structural gaps. Not Assessed: design review not yet completed.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domain rdf:type rdf:Property ;
    rdfs:label 'Domain' ;
    rdfs:comment 'Business risk domain that this control primarily addresses (e.g., Professional Indemnity, Data Privacy / GDPR, Cybersecurity, Sanctions Screening, Reputational Risk, Anti-Money Laundering (AML), Conflict of Interest). [ENUM-REF-CANDIDATE: professional_indemnity|data_privacy|cybersecurity|sanctions_screening|reputational|aml|conflict_of_interest|regulatory_compliance — promote to reference product]' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Document Management System (DMS) reference or iManage Work document identifier for the evidence artefact supporting the most recent control test (e.g., screenshots, logs, policy documents, access reports). Required for ISO 27001 audit evidence packages.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Relevant Flag' ;
    rdfs:comment 'Indicates whether this control is relevant to the firms General Data Protection Regulation (GDPR) compliance obligations, including Personally Identifiable Information (PII) protection and data breach prevention (True) or not (False). Supports Data Protection Officer (DPO) reporting.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The date on which the control was fully implemented and became operational. Used to calculate control age, schedule periodic reviews, and demonstrate timely remediation to SRA and ISO 27001 auditors.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current lifecycle state of the controls implementation. Planned: approved but not yet started. In Progress: actively being deployed. Implemented: fully operational. Deferred: postponed with documented rationale. Not Applicable: formally excluded from scope with SoA justification.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'The assessed level of risk exposure before any controls are applied. Provides the baseline against which control effectiveness is measured. Required for ISO 27001 risk treatment plan documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAnnexAReference rdf:type rdf:Property ;
    rdfs:label 'Iso Annex A Reference' ;
    rdfs:comment 'The specific ISO 27001:2022 Annex A control identifier to which this control maps (e.g., A.5.1, A.8.24). Enables traceability between the firms control catalogue and the ISO certification framework. Required for Statement of Applicability (SoA) reporting.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoSoaIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso Soa Included Flag' ;
    rdfs:comment 'Indicates whether this control is included in the firms ISO 27001 Statement of Applicability (SoA) (True) or formally excluded with documented justification (False). Mandatory field for ISO 27001 certification maintenance.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date on which the most recently completed control test instance was executed. Used to determine whether the control is within its required testing cadence and to flag overdue tests for the compliance team.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTestOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Test Outcome' ;
    rdfs:comment 'Result of the most recently completed control test instance. Pass: control operated as designed. Fail: control did not operate as designed. Partial Pass: control operated with minor deficiencies. Not Applicable: test was not applicable in the period.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Scope Flag' ;
    rdfs:comment 'Indicates whether this control is specifically designed to protect Legal Professional Privilege (LPP) material from unauthorised disclosure (True) or not (False). Critical for controls governing iManage Work access, Relativity matter workspaces, and client communication channels.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigatesRisk rdf:type rdf:Property ;
    rdfs:label 'Mitigates Risk' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — Controls are implemented to mitigate specific risks. This many-to-many relationship (via junction or FK array) is essential for control-to-risk traceability required by ISO 27001.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Operational Effectiveness Rating' ;
    rdfs:comment 'Assessment of how well the control is operating in practice to mitigate the associated risk. Derived from the most recent completed test cycle. Effective: control operates as designed. Partially Effective: control operates but with gaps. Ineffective: control fails to mitigate risk. Not Tested: no test has been completed.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Scope Flag' ;
    rdfs:comment 'Indicates whether this control specifically addresses the protection of Personally Identifiable Information (PII) held by the firm (True) or not (False). Used to scope GDPR Article 32 technical and organisational measures documentation.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this control, aligned to the ISO 27001 Annex A control numbering scheme or the firms internal control catalogue (e.g., ISO-A.8.1-001). Used for cross-referencing in audit reports and SRA compliance submissions.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date on which the remediation action was confirmed as completed and verified. Null if remediation is not yet complete. Used to close the deficiency lifecycle and update the ISO 27001 nonconformity register.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the identified control deficiency must be remediated. Null if no remediation is required. Used to track overdue remediations and escalate to the Risk Committee and SRA as required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether a remediation action is required as a result of the most recent control test (True) or not (False). Triggers the remediation workflow and escalation process for overdue items.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation action for any identified control deficiency. Not Required: no deficiency found. Open: remediation identified but not started. In Progress: remediation underway. Completed: deficiency resolved and verified. Overdue: remediation due date has passed without completion.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'The assessed level of risk remaining after this control and any other mitigating measures are applied. Represents the firms net exposure. Used in risk appetite reporting to the firms Risk Committee and in SRA regulatory submissions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soaExclusionJustification rdf:type rdf:Property ;
    rdfs:label 'Soa Exclusion Justification' ;
    rdfs:comment 'Documented rationale for excluding this control from the ISO 27001 Statement of Applicability (SoA). Null if the control is included. Required by ISO 27001:2022 Clause 6.1.3(d) for all excluded Annex A controls.' ;
    rdfs:domain ind:RiskControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the operational system of record in which this control is primarily configured or enforced (e.g., Intapp Conflicts, iManage Work, Relativity, SAP SuccessFactors). Supports lineage tracing and system-level risk assessments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sraReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sra Reportable Flag' ;
    rdfs:comment 'Indicates whether a control failure or deficiency associated with this control is reportable to the Solicitors Regulation Authority (SRA) under mandatory reporting obligations (True) or not (False). Supports regulatory breach management workflows.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethodology rdf:type rdf:Property ;
    rdfs:label 'Test Methodology' ;
    rdfs:comment 'The approach used to test the control in the most recent test instance. Inquiry: interviews with control operators. Observation: direct observation of control execution. Inspection: review of evidence documents. Re-performance: independent re-execution of the control. Walkthrough: end-to-end process trace. Automated Scan: system-generated test.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkId rdf:type rdf:Property ;
    rdfs:label 'Check Id' ;
    rdfs:comment 'Reference to the conflict check record that identified or is associated with the conflict-of-interest dimension of this exposure. Links to the conflict domain to provide the full conflict screening context without duplicating conflict data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Check .

ind:estimatedClaimValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Claim Value' ;
    rdfs:comment 'The firms current best estimate of the total monetary value of the potential claim arising from this exposure, expressed in the firms base currency. Used for reserve-setting, PI insurance renewal, and risk appetite monitoring. Reviewed and updated as new information becomes available.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Amount' ;
    rdfs:comment 'The amount of the policy excess (deductible) applicable to this exposure under the firms professional indemnity insurance policy. Represents the portion of any claim the firm must bear before insurer coverage is triggered. Critical for net exposure calculation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLinkedToRisk rdf:type rdf:Property ;
    rdfs:label 'Exposure Linked To Risk' ;
    rdfs:comment 'FK to risk.risk_register.risk_register_id — PI exposures should reference the risk register item they relate to for consolidated risk reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureNarrative rdf:type rdf:Property ;
    rdfs:label 'Exposure Narrative' ;
    rdfs:comment 'Free-text description of the circumstances giving rise to this professional indemnity exposure, including the nature of the alleged failing, the clients complaint, and any relevant background. Confidential and subject to Legal Professional Privilege (LPP) where applicable.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureReference rdf:type rdf:Property ;
    rdfs:label 'Exposure Reference' ;
    rdfs:comment 'Externally-known business reference number assigned to this PI exposure record, used in correspondence with insurers, brokers, and internal risk committees. Format: PI-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of the indemnity exposure record, from initial identification through insurer notification, active reservation, litigation, and final closure. Drives workflow routing and risk appetite monitoring.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm engaged to advise on or defend the claim arising from this exposure. Populated when external_counsel_engaged_flag is True. Used for conflict screening and cost tracking.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date on which the firm first became aware of the potential professional indemnity exposure. Critical for determining the policy year applicable and meeting insurer notification deadlines.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurer Notification Date' ;
    rdfs:comment 'The date on which the firm formally notified its professional indemnity insurer of this exposure. Null if insurer_notified_flag is False. Used to verify compliance with policy notification obligations and to anchor the claims-made trigger.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurer Notified Flag' ;
    rdfs:comment 'Indicates whether the firms professional indemnity insurer has been formally notified of this exposure. A value of True confirms notification has been made; False indicates notification is pending or not yet required.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalInvestigationStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Investigation Status' ;
    rdfs:comment 'Current status of the firms internal investigation into the circumstances giving rise to this exposure. Tracks whether a root cause analysis has been initiated, is ongoing, or has been completed and findings documented.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'The date on which the firms internal investigation into this exposure was formally concluded and findings documented. Null if internal_investigation_status is not completed. Used for risk governance reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterCloseDate rdf:type rdf:Property ;
    rdfs:label 'Matter Close Date' ;
    rdfs:comment 'The date on which the underlying legal matter from which this exposure arises was formally closed in the practice management system. Used to calculate the elapsed time between matter closure and exposure identification, informing limitation period analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piRenewalSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Pi Renewal Submission Flag' ;
    rdfs:comment 'Indicates whether this exposure record has been included in the firms most recent professional indemnity insurance renewal submission to the insurer or broker. True confirms inclusion; False indicates it is pending inclusion or not yet due.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Referral Flag' ;
    rdfs:comment 'Indicates whether this exposure has been or is required to be referred to a regulatory body (e.g., SRA, State Bar Association, Legal Services Board). True if a regulatory referral has been made or is pending. Drives compliance domain notifications.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveLastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reserve Last Reviewed Date' ;
    rdfs:comment 'The date on which the financial reserve for this exposure was most recently reviewed and confirmed or updated by the risk committee or responsible partner. Ensures reserves remain current and supports PI insurance renewal accuracy.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSeverity rdf:type rdf:Property ;
    rdfs:label 'Risk Severity' ;
    rdfs:comment 'The firms internal risk severity rating for this exposure, reflecting the combination of estimated financial impact and likelihood of a formal claim being made. Drives escalation protocols, partner notification requirements, and risk committee reporting.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorisation of the root cause of the professional failing giving rise to this exposure, as determined during the firms internal investigation. Used for risk management trend analysis and process improvement initiatives.' ;
    rdfs:domain ind:IndemnityExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegisterAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Register Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member who is accountable for managing and monitoring this risk item. The risk owner is responsible for implementing mitigations and reporting status to the Risk Committee.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:registerRiskOwnerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Register Risk Owner Attorney Profile Id' ;
    rdfs:comment 'FK to workforce.attorney_profile' ;
    rdfs:domain ind:Register ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'The date on which the risk was formally closed, either because it was fully mitigated, accepted, or the risk event is no longer applicable. Null for open risks.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation tier for this risk item, indicating the highest governance level to which the risk has been formally escalated. None indicates no escalation beyond the risk owner.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialExposure rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Exposure' ;
    rdfs:comment 'Estimated monetary value of the firms financial exposure if this risk materialises, expressed in the firms base currency. Includes potential professional indemnity claims, regulatory fines, and remediation costs. Classified confidential.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Exception Approved By' ;
    rdfs:comment 'Name and role of the senior authority (e.g., Managing Partner, General Counsel, Risk Committee Chair) who formally approved the policy exception for this risk. Populated only when is_exception_approved is True.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exception Expiry Date' ;
    rdfs:comment 'The date on which the approved policy exception expires and must be re-evaluated or revoked. Null if no exception is in force. Drives exception renewal alerts.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inherentImpact rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact' ;
    rdfs:comment 'Impact rating of the risk materialising before any controls are applied, scored on a 1–5 scale (1=Negligible, 2=Minor, 3=Moderate, 4=Major, 5=Catastrophic). Combined with inherent_likelihood to produce the inherent risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentLikelihood rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood' ;
    rdfs:comment 'Likelihood rating of the risk occurring before any controls are applied, scored on a 1–5 scale (1=Rare, 2=Unlikely, 3=Possible, 4=Likely, 5=Almost Certain) per the firms risk appetite matrix. Used to compute the inherent risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceClaimRef rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Ref' ;
    rdfs:comment 'Reference number of the professional indemnity insurance claim raised with the firms insurer in relation to this risk event. Populated when a claim has been formally notified to the insurer. Classified confidential.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExceptionApproved rdf:type rdf:Property ;
    rdfs:label 'Is Exception Approved' ;
    rdfs:comment 'Indicates whether a formal policy exception has been approved for this risk, permitting a deviation from the firms standard risk management policy. True when an approved exception is in force.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this risk record was most recently formally reviewed and assessed by the risk owner or Risk Committee. Used to calculate review cycle compliance and risk register staleness.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationDescription rdf:type rdf:Property ;
    rdfs:label 'Mitigation Description' ;
    rdfs:comment 'Narrative description of the specific controls, actions, and measures implemented or planned to mitigate this risk. Includes procedural, technical, and contractual controls. Classified confidential as it may reveal security posture.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current implementation status of the risk mitigation actions. Tracks whether controls have been designed, are being implemented, are fully operational, are overdue, or have been formally deferred.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualImpact rdf:type rdf:Property ;
    rdfs:label 'Residual Impact' ;
    rdfs:comment 'Impact rating of the risk materialising after all current controls and mitigations have been applied, scored on a 1–5 scale. Combined with residual_likelihood to produce the residual risk rating.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Likelihood rating of the risk occurring after all current controls and mitigations have been applied, scored on a 1–5 scale. Reflects the effectiveness of implemented controls.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskDomain rdf:type rdf:Property ;
    rdfs:label 'Risk Domain' ;
    rdfs:comment 'Indicates whether the risk is enterprise-wide or scoped to a specific domain such as a matter, client relationship, workforce, technology infrastructure, or third-party supplier.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRefCode rdf:type rdf:Property ;
    rdfs:label 'Risk Ref Code' ;
    rdfs:comment 'Human-readable, externally referenceable unique code assigned to each risk item (e.g., RSK-2024-00123). Used in Risk Committee reports, SRA submissions, and cross-domain communications.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, descriptive title summarising the nature of the risk (e.g., Unauthorised disclosure of client PII via email). Used as the primary label in risk dashboards and committee reports.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatment rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment' ;
    rdfs:comment 'The chosen treatment approach for this risk: mitigate (apply controls to reduce likelihood/impact), accept (formally acknowledge within appetite), transfer (insurance or contractual transfer), avoid (cease the activity), escalate (refer to senior governance body).' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'The planned date by which the risk is expected to be fully mitigated or closed. Used for tracking mitigation progress and reporting overdue items to the Risk Committee.' ;
    rdfs:domain ind:Register ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent risk category, enabling a hierarchical taxonomy (e.g., Data Privacy – PII/GDPR as a child of Regulatory Risk). Null for top-level categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:amlRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category is associated with Anti-Money Laundering (AML) or sanctions screening obligations. When true, matters and clients under this category require enhanced Know Your Client (KYC) due diligence and Suspicious Activity Report (SAR) monitoring.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code indicating the primary jurisdiction in which this risk category applies. Use GLB for globally applicable categories. Supports multi-jurisdictional risk management across the firms international offices.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Firm-assigned alphanumeric code uniquely identifying the risk category within the enterprise risk taxonomy (e.g., PI-001 for Professional Indemnity, DP-001 for Data Privacy). Used as the stable business key across risk register, incident management, and compliance reporting systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed narrative description of the risk category, including the nature of the risk, typical triggers, and the business functions or matters most exposed. Supports risk awareness training and knowledge management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the risk category as used in firm-wide risk registers, compliance dashboards, and management reporting (e.g., Professional Indemnity, Data Privacy – PII/GDPR, Cybersecurity – ISO 27001, Sanctions and AML, Reputational Risk, Operational Risk, Regulatory Compliance Risk).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of this risk category within the firms taxonomy. Active categories are available for use in risk register entries; deprecated categories are retained for historical reporting only; under_review categories are pending approval for modification.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Control Framework Reference' ;
    rdfs:comment 'Reference to the specific control framework, standard, or policy document that governs the mitigating controls applicable to this risk category (e.g., ISO 27001 Annex A, GDPR Article 32 Technical Measures, SRA AML Policy, FATF Recommendation 10). Enables traceability from risk category to control library.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category falls within the scope of the firms ISO 27001 Information Security Management System (ISMS). When true, associated risks are subject to ISO 27001 Annex A control requirements and must be included in the Statement of Applicability.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External standard or regulatory reference code that maps this risk category to an industry-standard taxonomy (e.g., ISO 31000 risk category code, COSO ERM category, SRA Risk Outlook category code). Supports benchmarking and regulatory reporting alignment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the primary regulatory or professional body whose rules or standards give rise to this risk category (e.g., Solicitors Regulation Authority, American Bar Association, Financial Action Task Force, Information Commissioners Office). Supports jurisdiction-specific risk reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this category within the risk taxonomy hierarchy. Level 1 represents top-level domains; higher values represent increasingly granular sub-categories. Supports hierarchical roll-up in risk dashboards and regulatory reports.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Delimited string representing the full ancestry path of the risk category within the taxonomy (e.g., Regulatory Risk > Data Privacy > PII/GDPR). Facilitates breadcrumb navigation and hierarchical filtering in risk reporting tools.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed By' ;
    rdfs:comment 'Name or identifier of the risk owner, partner, or committee member who last formally reviewed and approved this risk category. Supports accountability and audit trail requirements under the firms risk governance framework.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lppRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category involves matters that may engage Legal Professional Privilege (LPP), requiring special handling protocols to preserve privilege and avoid inadvertent waiver. Relevant for litigation, regulatory investigation, and eDiscovery risk categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Matter Type Applicability' ;
    rdfs:comment 'Comma-separated list or description of the matter types or practice areas to which this risk category is most applicable (e.g., Litigation, Arbitration, M&A, Corporate Transactions, IP Portfolio Management, All Matters). Guides risk assessment scoping during matter intake.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline Days' ;
    rdfs:comment 'Maximum number of calendar days within which a risk incident under this category must be reported to the relevant regulatory authority (e.g., 72 hours / 3 days for GDPR personal data breaches under Article 33). Null if no mandatory external notification applies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Job title or role designation of the individual or function responsible for owning and managing risks under this category at the firm level (e.g., Chief Risk Officer, Data Protection Officer, General Counsel, Head of Compliance). Distinct from matter-level risk owners.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Relevance Flag' ;
    rdfs:comment 'Indicates whether this risk category is directly associated with the handling, processing, or breach of Personally Identifiable Information (PII). When true, risk register entries under this category are subject to GDPR Article 33/34 breach notification obligations and DPA compliance controls.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalIndemnityFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Flag' ;
    rdfs:comment 'Indicates whether this risk category is relevant to the firms professional indemnity insurance exposure. When true, incidents under this category must be reported to the firms PI insurer and tracked in the claims management process.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAppetiteLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Level' ;
    rdfs:comment 'Qualitative risk appetite classification for this category as declared in the firms risk appetite framework. Zero tolerance applies to categories such as sanctions breaches and money laundering; low to professional indemnity and data privacy; moderate to operational risk.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteThreshold rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Threshold' ;
    rdfs:comment 'Maximum acceptable residual risk score for this category as defined in the firms risk appetite statement. Residual scores exceeding this threshold trigger escalation to the Risk Committee or Managing Partner. Aligns with SRA and ABA professional conduct obligations.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskImpactRating rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Rating' ;
    rdfs:comment 'Standard impact rating assigned to this risk category, reflecting the potential severity of harm to the firm, its clients, or third parties if the risk materialises. Covers financial, reputational, regulatory, and operational impact dimensions.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Risk Likelihood Rating' ;
    rdfs:comment 'Standard likelihood rating assigned to this risk category within the firms risk appetite framework, indicating the probability of occurrence. Used as the default likelihood baseline when creating new risk register entries under this category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Classification of the risk category by its nature within the risk management lifecycle: inherent (pre-control), residual (post-control), emerging (newly identified), or systemic (firm-wide structural exposure). Drives how risk assessments are scoped and reported.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Integer value controlling the display sequence of this risk category in risk registers, dashboards, and dropdown selection lists. Lower values appear first. Enables consistent presentation across risk management tools and reports.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utbmsTaskCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code' ;
    rdfs:comment 'UTBMS task code associated with the legal work type most commonly linked to this risk category (e.g., L430 for Written Discovery in litigation risk, C300 for Due Diligence in transactional risk). Enables cross-referencing between risk categories and billing/matter management data in Elite 3E.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each formal risk assessment record within the enterprise risk register. Primary key for the risk_assessment data product.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:assessmentTreatmentOwnerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Assessment Treatment Owner Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member accountable for implementing the risk treatment actions. Distinct from the assessor; supports accountability and escalation workflows.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryAssessmentAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Assessment Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or workforce member who conducted and is responsible for this risk assessment. Supports accountability tracking and assessor workload reporting.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The calendar date on which the formal risk assessment was conducted. Represents the principal business event date for this assessment cycle, distinct from record creation timestamp.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the risk assessment record. Draft indicates work in progress; in_review indicates pending senior sign-off; approved indicates formally accepted; superseded indicates replaced by a newer assessment; closed indicates the risk has been retired.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentImpactRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact Rating' ;
    rdfs:comment 'Qualitative rating of the severity of consequence if the risk event occurs before any controls are applied. Considers financial, reputational, regulatory, and operational dimensions of impact.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Rating' ;
    rdfs:comment 'Qualitative rating of the probability that the risk event will occur before any controls are applied. Represents the raw, unmitigated likelihood on a five-point scale aligned with the firms risk appetite framework.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDpiaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Dpia Required' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment (DPIA) is required for this risk item under GDPR Article 35. True when the risk involves high-risk processing of personal data, triggering mandatory DPIA before processing commences.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLppSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Lpp Sensitive' ;
    rdfs:comment 'Indicates whether this risk assessment record or its associated matter is subject to Legal Professional Privilege (LPP). When True, access is restricted to authorised legal personnel and the record is excluded from certain regulatory disclosures.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Methodology used to evaluate the risk. Qualitative uses descriptive scales; quantitative uses numerical probability and financial impact modelling; semi_quantitative combines both approaches. Determines how inherent and residual scores are interpreted.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known business identifier for the risk assessment, formatted as RA-{YYYY}-{NNNNNN}. Used in correspondence, audit trails, and regulatory submissions to uniquely reference a specific assessment cycle.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualImpactRating rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Rating' ;
    rdfs:comment 'Qualitative rating of the severity of consequence after existing controls have been applied. Used alongside residual likelihood to compute the residual risk score.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Qualitative rating of the probability that the risk event will occur after existing controls have been applied. Reflects the post-control likelihood used to determine whether residual risk is within appetite.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The mandated frequency at which this risk assessment must be reviewed and refreshed. Drives scheduling of next_review_date and supports compliance with ISO 27001 periodic review requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatmentOption rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment Option' ;
    rdfs:comment 'The selected risk treatment strategy for this assessment. Accept means the firm tolerates the residual risk; mitigate means additional controls will be implemented; transfer means risk is shifted (e.g., via professional indemnity insurance); avoid means the risk-generating activity is discontinued.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Flag' ;
    rdfs:comment 'Indicates whether this risk assessment was triggered by or relates to a sanctions screening alert (e.g., OFAC, UN, EU sanctions lists). True requires escalation to the firms Anti-Money Laundering (AML) compliance officer.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Narrative description of the specific actions, controls, or measures to be implemented under the selected risk treatment option. Classified confidential as it may contain sensitive operational or legal strategy information.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Due Date' ;
    rdfs:comment 'Target date by which the agreed risk treatment actions must be completed. Used for tracking remediation progress and escalation when treatment is overdue.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withinAppetite rdf:type rdf:Property ;
    rdfs:label 'Within Appetite' ;
    rdfs:comment 'Indicates whether the residual risk score falls within the firms defined risk appetite threshold. True means the risk is acceptable; False triggers mandatory escalation and treatment action. Derived from comparing residual_risk_score against risk_appetite_threshold but stored for reporting efficiency.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Panel Appointment Id' ;
    rdfs:comment 'Unique identifier for the panel appointment record. Primary key.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PanelAppointment .

ind:appointmentOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Appointment Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this panel appointment record.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:compliancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Panel appointments must comply with firm policies on panel management, conflicts, and client acceptance criteria. Real process: policy-governed panel appointment approval and governance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:engagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Engagement Opportunity Id' ;
    rdfs:comment 'Foreign key linking to intake.engagement_opportunity. Business justification: Panel appointments may originate from engagement opportunities in the CRM pipeline. This links the panel appointment to the CRM opportunity, enabling tracking of which opportunities resulted in panel ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:guidelineId rdf:type rdf:Property ;
    rdfs:label 'Guideline Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_guideline. Business justification: Panel appointments establish ongoing billing guidelines that apply to all matters under the panel relationship. Linking panel appointments to billing guidelines enables automated guideline inheritance' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:letterOfEngagementId rdf:type rdf:Property ;
    rdfs:label 'Letter Of Engagement Id' ;
    rdfs:comment 'Foreign key linking to intake.letter_of_engagement. Business justification: Panel appointments may be formalized through Letters of Engagement. This links the panel appointment to the LOE, enabling tracking of which panel appointments were formalized through LOEs. This is an ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfEngagement .

ind:panelModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Panel Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this panel appointment record.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:pricingModelId rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Id' ;
    rdfs:comment 'Foreign key linking to service.pricing_model. Business justification: Panel appointments reference agreed pricing models for panel work to ensure consistent billing across panel matters, volume discount application, and compliance with panel terms. Essential for panel m' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingModel .

ind:primaryPanelAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Panel Attorney Profile Id' ;
    rdfs:comment 'Reference to the partner who is the primary relationship owner and accountable for performance under this panel appointment.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryProspectId rdf:type rdf:Property ;
    rdfs:label 'Primary Prospect Id' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Panel appointments are held with specific client organizations (prospects or existing clients). Links panel-driven intake volume to the client pipeline.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:rfpSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rfp Submission Id' ;
    rdfs:comment 'Foreign key linking to intake.rfp_submission. Business justification: Panel appointments often result from RFP wins. This links the panel appointment to the RFP submission. The existing rfp_reference (STRING) should be replaced with a proper FK to enable relational inte' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpSubmission .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'The date on which the panel appointment became effective and the firm was formally authorized to receive instructions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentNotes rdf:type rdf:Property ;
    rdfs:label 'Appointment Notes' ;
    rdfs:comment 'Free-text field for internal notes, special conditions, or additional context regarding this panel appointment that is relevant for matter intake and relationship management.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Required Flag' ;
    rdfs:comment 'Indicates whether a full conflict check in Intapp Conflicts is required for each new matter under this panel, or whether the panel appointment itself constitutes pre-clearance for routine instructions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage discount from standard rates that has been agreed for matters under this panel appointment (e.g., 10.00 for 10% discount). Null if no discount applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicsAccountGuid rdf:type rdf:Property ;
    rdfs:label 'Dynamics Account Guid' ;
    rdfs:comment 'The unique GUID of the corresponding account record in Microsoft Dynamics 365 CRM, enabling integration between the CRM pipeline and panel appointment tracking.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteClientNumber rdf:type rdf:Property ;
    rdfs:label 'Elite Client Number' ;
    rdfs:comment 'The client number in Elite 3E practice management system for the appointing client, enabling linkage between panel appointments and matter creation.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'A description of any specific matter types, jurisdictions, or circumstances that are explicitly excluded from the scope of this panel appointment.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the panel appointment is scheduled to expire or terminate, unless renewed. Null for open-ended appointments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic territories or jurisdictions covered by this panel appointment (e.g., Global, EMEA, United Kingdom, North America). May be comma-separated list of ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'The date on which KYC and AML due diligence was completed and approved for the appointing client in relation to this panel appointment.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'The date on which the current KYC clearance expires and must be refreshed to continue accepting instructions under this panel.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'The current status of Know Your Client due diligence and Anti-Money Laundering (AML) compliance checks for the appointing client organization in relation to this panel appointment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submitted Date' ;
    rdfs:comment 'The date on which the most recent performance or management information report was submitted to the appointing client for this panel.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterTypeScope rdf:type rdf:Property ;
    rdfs:label 'Matter Type Scope' ;
    rdfs:comment 'A description or comma-separated list of the specific matter types or transaction categories that are within scope for this panel appointment (e.g., Commercial Litigation, Employment Tribunal, Share Purchase Agreements).' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The date on which the next scheduled performance or management information report is due to be submitted to the appointing client.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:panelCategory rdf:type rdf:Property ;
    rdfs:label 'Panel Category' ;
    rdfs:comment 'The primary practice area or legal service category for which the firm has been appointed to the panel. [ENUM-REF-CANDIDATE: general counsel|litigation|mergers and acquisitions|regulatory|employment|intellectual property|real estate|tax|corporate|compliance|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'The official name or title of the legal panel or preferred supplier list (e.g., Global Litigation Panel 2024, EMEA Employment Law Panel).' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Panel Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the appointing client to identify this panel appointment (e.g., clients procurement system reference).' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the panel appointment indicating whether the firm is authorized to receive instructions under this panel.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelTier rdf:type rdf:Property ;
    rdfs:label 'Panel Tier' ;
    rdfs:comment 'The tier or ranking level assigned by the appointing client within their panel structure, indicating priority or preferred status for instruction allocation.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroup rdf:type rdf:Property ;
    rdfs:label 'Practice Group' ;
    rdfs:comment 'The internal practice group or department within the firm that is responsible for delivering services under this panel appointment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier or version number of the agreed rate card or fee schedule that applies to matters instructed under this panel appointment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The frequency at which the firm is required to provide management information, performance reports, or spend analysis to the appointing client under this panel appointment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'The frequency in months at which the panel appointment is subject to performance review by the appointing client (e.g., 12 for annual review, 24 for biennial).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'The number of days advance notice required by either party to terminate this panel appointment, as specified in the panel terms.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Amount' ;
    rdfs:comment 'The minimum annual or total fee volume (in the panel currency) that the appointing client has committed or projected for this panel appointment. Null if no commitment exists.' ;
    rdfs:domain ind:PanelAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskActionId rdf:type rdf:Property ;
    rdfs:label 'Risk Action Id' ;
    rdfs:comment 'Unique identifier for this intake-action assignment record. Primary key.' ;
    rdfs:domain ind:RiskAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Created By Attorney Profile Id' ;
    rdfs:comment 'Reference to the timekeeper or system user who created this intake-action assignment, typically the conflicts analyst or intake coordinator.' ;
    rdfs:domain ind:RiskAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Foreign key linking to the intake request that triggered or requires this risk mitigation action' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Context-specific notes explaining why this mitigation action was assigned to this intake request, including specific risk factors identified during intake screening.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for this opportunity risk assessment relationship record. Primary key.' ;
    rdfs:domain ind:OpportunityRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Assessment Id' ;
    rdfs:comment 'Foreign key linking to the formal risk assessment record conducted for this opportunity' ;
    rdfs:domain ind:OpportunityRiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key to the risk assessment record' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:assessmentStage rdf:type rdf:Property ;
    rdfs:label 'Assessment Stage' ;
    rdfs:comment 'The stage in the opportunity lifecycle at which this risk assessment was conducted. Supports tracking multiple assessments over the opportunity progression.' ;
    rdfs:domain ind:OpportunityRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationCreditId rdf:type rdf:Property ;
    rdfs:label 'Origination Credit Id' ;
    rdfs:comment 'Unique identifier for the origination credit record. Primary key for this entity.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Credit Owner Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who created this origination credit record. Typically a practice administrator or business development coordinator.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:creditedEngagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Credited Engagement Opportunity Id' ;
    rdfs:comment 'FK to intake.engagement_opportunity.engagement_opportunity_id — Origination credits are allocated per engagement opportunity. Required for partner compensation attribution.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:intakeFeeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Intake Fee Arrangement Id' ;
    rdfs:comment 'Foreign key linking to billing.fee_arrangement. Business justification: Origination credits track business development value tied to specific fee arrangements. Linking credits to billing fee arrangements enables accurate origination compensation calculations based on actu' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeFeeArrangement .

ind:originationEngagementOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Origination Engagement Opportunity Id' ;
    rdfs:comment 'Reference to the engagement scope record established during intake. Links to the Letter of Engagement (LOE) and scope definition.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementOpportunity .

ind:originationModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Origination Modified By User Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who last modified this origination credit record. Audit trail for accountability.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:pitchId rdf:type rdf:Property ;
    rdfs:label 'Pitch Id' ;
    rdfs:comment 'Foreign key linking to intake.pitch. Business justification: Origination credits may be allocated based on pitch participation. This links the credit to the pitch, enabling tracking of which pitches generated origination credits. The existing pitch_date can be ' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pitch .

ind:primaryCreditedTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Credited Timekeeper Id' ;
    rdfs:comment 'Reference to the timekeeper (attorney or professional) receiving this origination credit. Links to the timekeeper master in Elite 3E or Aderant Expert.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date on which the origination credit was initially allocated. Typically coincides with engagement acceptance or Letter of Engagement (LOE) execution date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current approval status of the origination credit allocation. Draft indicates initial entry; pending approval indicates submission for partner review; approved indicates final acceptance; rejected indicates non-acceptance requiring revision; revised indicates updated allocation; locked indicates finalized allocation that cannot be changed without special authorization.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDevelopmentNotes rdf:type rdf:Property ;
    rdfs:label 'Business Development Notes' ;
    rdfs:comment 'Free-text notes capturing the business development context, relationship history, competitive positioning, and strategic importance of this origination. Used for internal knowledge management and future business development planning.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationYear rdf:type rdf:Property ;
    rdfs:label 'Compensation Year' ;
    rdfs:comment 'Fiscal or calendar year in which this origination credit is recognized for partner compensation purposes. Typically the year of engagement acceptance or Letter of Engagement (LOE) execution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of origination credit allocated to this timekeeper. May be calculated as a percentage of expected engagement value or Alternative Fee Arrangement (AFA) amount. Denominated in the firms base currency.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditIntake rdf:type rdf:Property ;
    rdfs:label 'Credit Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Origination credits are allocated at the point of intake. Required for partner compensation attribution.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditPercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Percentage' ;
    rdfs:comment 'Percentage of origination credit allocated to this timekeeper for this engagement. Multiple timekeepers may share credit with percentages summing to 100% across all credit records for the same engagement. Used in partner compensation calculations including Profit Per Equity Partner (PEP) and Revenue Per Equity Partner (RPE).' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Type of origination credit being allocated. Originating credit recognizes the attorney who brought in the client or matter; responsible credit recognizes the attorney managing the relationship; billing credit recognizes the primary billing attorney; cross-selling credit recognizes attorneys who expanded services to existing clients; referral credit recognizes internal or external referrals; relationship credit recognizes ongoing client stewardship.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditedOffice rdf:type rdf:Property ;
    rdfs:label 'Credited Office' ;
    rdfs:comment 'Office location of the credited timekeeper at the time of origination. Used for office-level revenue attribution and geographic performance analysis.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditedPracticeGroup rdf:type rdf:Property ;
    rdfs:label 'Credited Practice Group' ;
    rdfs:comment 'Practice group of the credited timekeeper at the time of origination. Used for practice-level revenue attribution and Profit Per Partner (PPP) calculations.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Expected Engagement Value' ;
    rdfs:comment 'Estimated total revenue expected from this engagement at the time of origination. Used as the basis for calculating origination credit amounts. May be based on Alternative Fee Arrangement (AFA) fixed fees, estimated hours, or historical matter value.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Type' ;
    rdfs:comment 'Type of Alternative Fee Arrangement (AFA) or billing structure agreed for this engagement. Hourly indicates standard time-based billing; fixed fee indicates a predetermined total; contingency indicates payment contingent on outcome; blended indicates mixed hourly rates; capped indicates hourly with a maximum; retainer indicates ongoing monthly fee; success fee indicates bonus upon achievement; hybrid indicates combination of multiple structures. [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|blended|capped|retainer|success_fee|hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeRequest rdf:type rdf:Property ;
    rdfs:label 'Intake Request' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Origination credits are allocated at the point of intake for a specific new matter. Links compensation attribution to the intake event.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Boolean flag indicating whether this engagement involves cross-border legal work spanning multiple jurisdictions. Cross-border matters may warrant additional origination credit due to complexity and coordination requirements.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicClient rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Client' ;
    rdfs:comment 'Boolean flag indicating whether this engagement is with a client designated as strategically important to the firm. Strategic clients may receive enhanced origination credit recognition or special compensation treatment.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'Date on which this origination credit record was locked for final compensation calculations. Once locked, changes require special authorization from the compensation committee. Null if not yet locked.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterType rdf:type rdf:Property ;
    rdfs:label 'Matter Type' ;
    rdfs:comment 'High-level classification of the matter type for this engagement. Examples include corporate transaction, litigation, intellectual property prosecution, regulatory compliance, employment advisory, real estate, tax planning, etc. Used for practice area revenue attribution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationSource rdf:type rdf:Property ;
    rdfs:label 'Origination Source' ;
    rdfs:comment 'Source or channel through which this engagement was originated. New client indicates first engagement with a new client; existing client new matter indicates additional work for current client; cross-sell indicates expansion of services; referral external indicates referral from outside the firm; referral internal indicates referral from another practice group; Request for Proposal (RFP) response indicates competitive bid; direct approach indicates proactive business development; marketing event indicates conference or seminar lead; alumni network indicates former firm member referral. [ENUM-REF-CANDIDATE: new_client|existing_client_new_matter|cross_sell|referral_external|referral_internal|rfp_response|direct_approach|marketing_event|alumni_network — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number tracking changes to this origination credit allocation. Incremented each time the allocation is revised and resubmitted for approval. Initial allocation is revision 1.' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Free-text explanation for why this origination credit allocation was revised. Null if this is the initial allocation (revision 1).' ;
    rdfs:domain ind:OriginationCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOnboardingTaskId rdf:type rdf:Property ;
    rdfs:label 'Client Onboarding Task Id' ;
    rdfs:comment 'Unique identifier for the client onboarding task. Primary key for this entity.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingDependencyTaskId rdf:type rdf:Property ;
    rdfs:label 'Blocking Dependency Task Id' ;
    rdfs:comment 'Reference to another onboarding task that must be completed before this task can begin. Supports task sequencing and dependency resolution.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:checklistId rdf:type rdf:Property ;
    rdfs:label 'Checklist Id' ;
    rdfs:comment 'Foreign key linking to knowledge.checklist. Business justification: Onboarding task lists are generated from or validated against knowledge management checklists for client intake, KYC procedures, conflict clearance, and matter opening. Quality assurance process ensur' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:clientCompletedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Client Completed By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who completed the task. May differ from assigned user if task was reassigned or escalated.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clientCreatedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Client Created By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created the task record. Typically the intake coordinator or system automation.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clientEscalatedToUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Client Escalated To User Timekeeper Id' ;
    rdfs:comment 'Reference to the user to whom the task has been escalated due to SLA breach risk or blocking issues.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clientModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Client Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified the task record. Supports audit trail and accountability.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:clientWaivedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Client Waived By User Timekeeper Id' ;
    rdfs:comment 'Reference to the authorized user who approved the task waiver. Typically a partner, general counsel, or compliance officer.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:taskOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Task Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user or staff member responsible for completing this onboarding task. Links to workforce/user management system.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:assignedToRole rdf:type rdf:Property ;
    rdfs:label 'Assigned To Role' ;
    rdfs:comment 'Functional role or job title of the person assigned to complete the task (e.g., Conflicts Analyst, Billing Coordinator, Practice Support Manager).' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Explanation of why the task is blocked. Captures impediments such as missing client information, pending approvals, or external dependencies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Actual date when the task was marked as complete. Null if task is still pending or in progress. Used for SLA performance measurement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes entered by the task owner upon completion, documenting outcomes, issues encountered, or follow-up actions required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether the task is mandatory for engagement approval and matter opening, or optional/conditional based on engagement characteristics.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current SLA compliance status for the task. Indicates whether the task is on track, at risk of breach, or has exceeded the threshold.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Hours' ;
    rdfs:comment 'Number of hours allocated for task completion per service level agreement. Used to calculate SLA breach risk and actual performance.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'System Reference Code' ;
    rdfs:comment 'External system identifier linking this task to records in Elite 3E, Intapp Conflicts, or Microsoft Dynamics 365 for cross-system traceability.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the onboarding task requirements, instructions, and any specific notes or context needed for completion.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskIntake rdf:type rdf:Property ;
    rdfs:label 'Task Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Onboarding tasks are generated as part of the intake request workflow. Required for checklist management and SLA tracking.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Human-readable name or title of the onboarding task, providing clear description of the action item for workflow participants.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Business-facing unique identifier for the onboarding task, typically auto-generated in the format OBT-YYYYMMDD-NNNN for tracking and reference purposes.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to the onboarding task, indicating urgency and sequencing within the overall onboarding checklist.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the onboarding task. Tracks progression through the workflow from assignment through completion or waiver.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the onboarding task type. Defines the nature of the action required to complete client onboarding and transition to active matter management. [ENUM-REF-CANDIDATE: kyc_document_collection|conflict_waiver_execution|engagement_letter_signature|matter_number_assignment|billing_setup|ethical_wall_configuration|dms_folder_creation|aml_screening|client_credit_check|retainer_collection — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedDate rdf:type rdf:Property ;
    rdfs:label 'Waived Date' ;
    rdfs:comment 'Date when the task waiver was approved. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:ClientOnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification for waiving a mandatory task. Required when task status is set to waived. Subject to compliance review.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceId rdf:type rdf:Property ;
    rdfs:label 'Referral Source Id' ;
    rdfs:comment 'Unique identifier for the referral source record. Primary key.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingPartnerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Originating Partner Attorney Profile Id' ;
    rdfs:comment 'Identifier of the partner who originally established the referral source relationship. Used for origination credit and relationship attribution. Links to workforce/attorney master data.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryReferralAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Referral Attorney Profile Id' ;
    rdfs:comment 'Identifier of the partner or business development professional responsible for managing the relationship with this referral source. Links to workforce/attorney master data.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Foreign key linking to intake.prospect. Business justification: Referral sources may be linked to specific prospects they referred. This links the referral source to the prospect for tracking referral effectiveness. This is an optional FK (nullable) as referral so' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:referralModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Referral Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this referral source record. Links to user/workforce master data for audit purposes.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:referralOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Referral Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this referral source record. Links to user/workforce master data for audit purposes.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:acknowledgmentProtocol rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Protocol' ;
    rdfs:comment 'Description of the standard acknowledgment or thank-you protocol for referrals from this source (e.g., partner phone call, gift, event invitation). Used to maintain relationship quality.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for the referral source contact. Used for relationship management and acknowledgment communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the referral source organization or the individual referrer.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for the referral source contact.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicsContactGuid rdf:type rdf:Property ;
    rdfs:label 'Dynamics Contact Guid' ;
    rdfs:comment 'Globally unique identifier linking this referral source to the corresponding contact record in Microsoft Dynamics 365 CRM. Used for system integration and data synchronization.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReferralDate rdf:type rdf:Property ;
    rdfs:label 'First Referral Date' ;
    rdfs:comment 'Date when the first engagement opportunity was referred by this source. Marks the beginning of the referral relationship.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industrySectorFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Focus' ;
    rdfs:comment 'Primary industry sector or vertical associated with referrals from this source (e.g., Technology, Financial Services, Healthcare). Used for market segmentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this referral source record is currently active and available for use in business processes. True if active; False if logically deleted or archived.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReferralDate rdf:type rdf:Property ;
    rdfs:label 'Last Referral Date' ;
    rdfs:comment 'Date of the most recent engagement opportunity referred by this source. Used to identify active vs dormant referral relationships.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Name of the organization or firm associated with the referral source, if applicable (e.g., referring law firm, consulting firm, client company).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaFocus rdf:type rdf:Property ;
    rdfs:label 'Practice Area Focus' ;
    rdfs:comment 'Primary practice area or legal specialty associated with referrals from this source (e.g., M&A, IP, Litigation). Used for targeting and relationship strategy.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Date' ;
    rdfs:comment 'Date when the referral agreement was executed. Null if no formal agreement exists.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralAgreementExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Executed Flag' ;
    rdfs:comment 'Indicates whether a formal referral agreement or memorandum of understanding has been executed with this source. True if agreement is in place; False otherwise.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralAgreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Referral Agreement Expiry Date' ;
    rdfs:comment 'Date when the referral agreement expires or requires renewal. Null for evergreen agreements or when no formal agreement exists.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Arrangement' ;
    rdfs:comment 'Type of fee arrangement or compensation structure associated with referrals from this source. Values: none (no fee), percentage (percentage of fees), flat_fee (fixed amount per referral), reciprocal (mutual referral agreement).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Percentage' ;
    rdfs:comment 'Percentage of fees paid to the referral source when referral_fee_arrangement is percentage-based. Expressed as a decimal (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'High-level categorization of the referral source for segmentation and reporting. Values: individual (person-based referral), organization (company or institution referral), digital_channel (website, online directory, social media), event (conference, seminar, networking event), publication (legal publication, directory listing).' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'The full name or title of the referral source entity (individual, organization, or channel).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Number' ;
    rdfs:comment 'Business identifier for the referral source, typically assigned by the business development or intake system. Format: RS-NNNNNN.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceQualityRating rdf:type rdf:Property ;
    rdfs:label 'Source Quality Rating' ;
    rdfs:comment 'Qualitative assessment of the referral source based on conversion rate, matter value, and client quality. Used for relationship prioritization and BD resource allocation.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStatus rdf:type rdf:Property ;
    rdfs:label 'Source Status' ;
    rdfs:comment 'Current lifecycle status of the referral source. Active sources are currently generating referrals; inactive sources are no longer producing leads; suspended sources are temporarily paused; archived sources are historical records.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTier rdf:type rdf:Property ;
    rdfs:label 'Source Tier' ;
    rdfs:comment 'Strategic tier classification of the referral source for relationship management prioritization. Tier 1 sources are highest value and receive most attention.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the referral source indicating the channel or relationship through which the opportunity was referred. Values: existing_client (referral from current client), attorney_referral (referral from external attorney or law firm), alumni (referral from firm alumni), intermediary (referral from broker, consultant, or other intermediary), directory_listing (lead from legal directory such as Chambers, Legal 500), conference (lead from industry conference or event).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulReferralsCount rdf:type rdf:Property ;
    rdfs:label 'Successful Referrals Count' ;
    rdfs:comment 'Count of referred opportunities that resulted in executed Letter of Engagement (LOE) and opened matters. Measures referral source conversion quality.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReferralsCount rdf:type rdf:Property ;
    rdfs:label 'Total Referrals Count' ;
    rdfs:comment 'Cumulative count of engagement opportunities referred by this source since inception. Used for referral source performance tracking.' ;
    rdfs:domain ind:ReferralSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyRegisterId rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Register Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_privacy_register. Business justification: LOEs involving personal data processing must link to ROPA entries for GDPR Article 30 compliance and lawful basis documentation. Real process: privacy impact assessment at engagement inception.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataPrivacyRegister .

ind:letterLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Letter Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user or system account that last modified this Letter of Engagement record. Audit trail for accountability.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:loeOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Loe Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user or system account that created this Letter of Engagement record. Audit trail for accountability.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:outsideCounselGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Guideline Id' ;
    rdfs:comment 'Reference to the clients Outside Counsel Guidelines that govern billing practices, staffing, and service delivery standards for this engagement. Nullable if client has no formal OCG.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutsideCounselGuideline .

ind:primaryLetterAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Letter Attorney Profile Id' ;
    rdfs:comment 'Reference to the equity partner or senior attorney responsible for this engagement. Primary relationship owner and signatory on the LOE.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:supersededByLoeLetterOfEngagementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Loe Letter Of Engagement Id' ;
    rdfs:comment 'Reference to the newer Letter of Engagement that supersedes this one. Nullable if this LOE is current or was not superseded. Used to track LOE version history.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfEngagement .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the client formally accepted and signed the Letter of Engagement. Nullable until acceptance occurs. Triggers handoff to matter domain for matter opening in Elite 3E.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline Date' ;
    rdfs:comment 'Date by which the client must accept and sign the Letter of Engagement. After this date, the LOE may expire or require reissuance.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which invoices will be issued to the client under this engagement. Defines the billing cycle for Work in Progress (WIP) conversion.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Email' ;
    rdfs:comment 'Email address of the client signatory for LOE delivery and correspondence.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Name' ;
    rdfs:comment 'Full name of the individual authorized to sign the Letter of Engagement on behalf of the client organization or as the individual client.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or role of the client signatory (e.g., General Counsel, Chief Legal Officer, CEO, individual capacity).' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictWaiverReference rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Reference' ;
    rdfs:comment 'Reference to any conflict of interest waiver or ethical wall arrangement documented in the conflict checking system (Intapp Conflicts). Nullable if no conflicts identified.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Protection Jurisdiction' ;
    rdfs:comment 'Primary data protection regulatory framework applicable to this engagement. GDPR = EU General Data Protection Regulation; CCPA = California Consumer Privacy Act; DPA UK = UK Data Protection Act; Other = jurisdiction-specific; Not Applicable = no specific data protection requirements.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed method for resolving disputes arising from the engagement. Litigation = court proceedings; Arbitration = binding arbitration; Mediation = facilitated negotiation; ADR = other alternative dispute resolution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which the engagement terms expire or the matter is expected to conclude. Nullable for open-ended engagements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fee Amount' ;
    rdfs:comment 'Estimated total professional fees for the engagement. For fixed-fee arrangements, this is the agreed amount. For hourly arrangements, this is the estimated range or budget.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firmSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Firm Signatory Name' ;
    rdfs:comment 'Full name of the law firm partner or authorized representative signing the Letter of Engagement on behalf of the firm.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Firm Signatory Title' ;
    rdfs:comment 'Title or role of the firm signatory (e.g., Managing Partner, Equity Partner, Practice Group Leader).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the client has provided consent for data processing under GDPR or equivalent data protection regulations. True = consent given; False = consent not given. Required for EU/UK clients.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the Letter of Engagement (e.g., State of New York, England and Wales).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycAmlCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Completed Flag' ;
    rdfs:comment 'Indicates whether Know Your Client and Anti-Money Laundering due diligence has been completed and cleared for this engagement. True = completed and cleared; False = pending or not completed. Required before LOE can be issued.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loeFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Loe Fee Arrangement' ;
    rdfs:comment 'FK to intake.fee_arrangement.fee_arrangement_id — The LOE incorporates the agreed fee arrangement. Essential for ensuring commercial terms are properly documented.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeIntake rdf:type rdf:Property ;
    rdfs:label 'Loe Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — The LOE formalizes the engagement initiated by an intake request. Required for lifecycle completion tracking.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeIntakeRequest rdf:type rdf:Property ;
    rdfs:label 'Loe Intake Request' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — The LOE formalizes the engagement initiated by the intake request. This link closes the intake lifecycle loop.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeIntakeRequestFk rdf:type rdf:Property ;
    rdfs:label 'Loe Intake Request Fk' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — LOE is the output artifact of a successful intake request. Links the formal agreement back to the originating workflow.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeNumber rdf:type rdf:Property ;
    rdfs:label 'Loe Number' ;
    rdfs:comment 'Business-facing unique identifier for the Letter of Engagement, typically formatted as LOE-YYYYNNNNNN. Used for external reference and client communication.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeStatus rdf:type rdf:Property ;
    rdfs:label 'Loe Status' ;
    rdfs:comment 'Current lifecycle status of the Letter of Engagement. Draft = under preparation; Issued = sent to client; Accepted = client signed; Declined = client rejected; Superseded = replaced by newer version; Withdrawn = firm retracted; Expired = acceptance deadline passed. [ENUM-REF-CANDIDATE: draft|issued|accepted|declined|superseded|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeType rdf:type rdf:Property ;
    rdfs:label 'Loe Type' ;
    rdfs:comment 'Classification of the Letter of Engagement purpose. New Matter = initial engagement; Additional Scope = expansion of existing matter; Amendment = modification of terms; Renewal = extension of existing engagement.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeVersion rdf:type rdf:Property ;
    rdfs:label 'Loe Version' ;
    rdfs:comment 'Version number of this Letter of Engagement. Increments when the LOE is revised or reissued. Version 1 is the initial issuance.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lppAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lpp Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the client has acknowledged and agreed to the terms regarding Legal Professional Privilege and attorney-client confidentiality. True = acknowledged; False = not acknowledged.' ;
    rdfs:domain ind:LetterOfEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due. Standard terms are 30, 60, or 90 days.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retainerAmount rdf:type rdf:Property ;
    rdfs:label 'Retainer Amount' ;
    rdfs:comment 'Initial retainer or advance payment required from the client. Nullable if no retainer is required. May be held in Interest on Lawyers Trust Accounts (IOLTA).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the legal services to be provided under this engagement. Defines the boundaries of the attorney-client relationship and the work to be performed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpeningRequestId rdf:type rdf:Property ;
    rdfs:label 'Matter Opening Request Id' ;
    rdfs:comment 'Unique identifier for the matter opening request. Primary key for this transactional record representing the formal request to open a new matter in Elite 3E following successful conflict clearance and Letter of Engagement (LOE) execution.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAttorneyAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Billing Attorney Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney responsible for billing and collections on this matter. May be the same as responsible partner or a designated billing partner.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:eliteMatterId rdf:type rdf:Property ;
    rdfs:label 'Elite Matter Id' ;
    rdfs:comment 'The system-generated matter identifier assigned by Elite 3E upon matter creation. Nullable until matter is opened. Used for cross-system reconciliation.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:matterLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Matter Last Modified By User Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who last modified the matter opening request record. Audit trail for change tracking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:originatingAttorneyAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Originating Attorney Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney who originated the client relationship or brought in the matter. Used for origination credit and compensation calculations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryMatterAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Matter Attorney Profile Id' ;
    rdfs:comment 'Reference to the equity or non-equity partner who has overall responsibility for the matter. This partner oversees matter strategy, client relationship, and profitability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Matter opening must verify regulatory obligations applicable to matter type, jurisdiction, and practice area for compliance risk management. Real process: matter-level regulatory compliance check.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:requestorTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Requestor Timekeeper Id' ;
    rdfs:comment 'User identifier of the person who created the matter opening request record. Typically a business development coordinator, intake specialist, or attorney.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tertiaryMatterApprovedByAttorneyAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Matter Approved By Attorney Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney or partner who approved the matter opening request. Nullable if not yet approved.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the matter opening request was approved by the responsible partner or practice group leader. Nullable if not yet approved.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code representing the department or cost center to which the matter will be allocated for financial reporting and profitability analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Disbursement Amount' ;
    rdfs:comment 'Estimated total disbursements (out-of-pocket expenses) for the matter, as projected at the time of opening request. Includes court fees, filing fees, expert witness costs, travel, etc.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Months' ;
    rdfs:comment 'Estimated duration of the matter in months, as projected at the time of opening request. Used for resource planning and Legal Project Management (LPM).' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Firm Office Code' ;
    rdfs:comment 'Three-letter code representing the primary office location responsible for the matter (e.g., NYC, LON, SFO, HKG). Used for revenue allocation and conflict of interest management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledesBillingRequired rdf:type rdf:Property ;
    rdfs:label 'Ledes Billing Required' ;
    rdfs:comment 'Boolean flag indicating whether invoices for this matter must be submitted in Legal Electronic Data Exchange Standard (LEDES) format for electronic billing. True if LEDES submission is required by the client.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterDescription rdf:type rdf:Property ;
    rdfs:label 'Matter Description' ;
    rdfs:comment 'Detailed description of the matter scope, legal issues, and engagement objectives. Provides context for matter administration and knowledge management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterName rdf:type rdf:Property ;
    rdfs:label 'Matter Name' ;
    rdfs:comment 'Descriptive name for the matter. Typically includes client name, transaction type, and brief description (e.g., Acme Corp - Series B Financing or Smith v. Jones - Employment Dispute).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Matter Opened Timestamp' ;
    rdfs:comment 'Date and time when the matter was successfully created in Elite 3E following approval. Marks the completion of the intake workflow and handoff to the matter domain.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matterTypeCode rdf:type rdf:Property ;
    rdfs:label 'Matter Type Code' ;
    rdfs:comment 'Standardized code classifying the type of legal matter (e.g., M&A transaction, patent prosecution, commercial litigation, regulatory compliance advisory). Aligns with Uniform Task-Based Management System (UTBMS) phase codes where applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroupCode rdf:type rdf:Property ;
    rdfs:label 'Practice Group Code' ;
    rdfs:comment 'Code representing the primary practice group responsible for the matter. Values: CORP (Corporate), LIT (Litigation), IP (Intellectual Property), EMP (Employment), REG (Regulatory), RE (Real Estate), TAX (Tax), BANK (Banking & Finance), MA (Mergers & Acquisitions), ESG (Environmental Social Governance). [ENUM-REF-CANDIDATE: CORP|LIT|IP|EMP|REG|RE|TAX|BANK|MA|ESG — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Proposed Matter Number' ;
    rdfs:comment 'The proposed matter number to be assigned in Elite 3E upon approval. Follows firm matter numbering convention. May be system-generated or manually specified based on client requirements.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the approver for rejecting the matter opening request. Nullable if not rejected.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Date and time when the matter opening request was rejected. Nullable if not rejected.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the matter opening request. Values: draft (being prepared), submitted (awaiting review), pending_approval (under partner review), approved (authorized to open), rejected (denied), opened (matter created in Elite 3E), cancelled (request withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|opened|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresOutsideCounselGuidelines rdf:type rdf:Property ;
    rdfs:label 'Requires Outside Counsel Guidelines' ;
    rdfs:comment 'Boolean flag indicating whether the client has imposed Outside Counsel Guidelines (OCG) that must be followed for billing, staffing, and matter administration. True if OCG compliance is mandatory.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTrustAccount rdf:type rdf:Property ;
    rdfs:label 'Requires Trust Account' ;
    rdfs:comment 'Boolean flag indicating whether this matter requires a client trust account (IOLTA - Interest on Lawyers Trust Accounts) for holding client funds. True if trust accounting is required per engagement terms or jurisdictional rules.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the matter opening request was formally submitted for approval. Marks the start of the approval workflow.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utbmsCodingRequired rdf:type rdf:Property ;
    rdfs:label 'Utbms Coding Required' ;
    rdfs:comment 'Boolean flag indicating whether time entries and invoices for this matter must include Uniform Task-Based Management System (UTBMS) task and activity codes. True if UTBMS coding is required by the client.' ;
    rdfs:domain ind:MatterOpeningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intakeEngagementScopeId rdf:type rdf:Property ;
    rdfs:label 'Intake Engagement Scope Id' ;
    rdfs:comment 'Unique identifier for the engagement scope record. Primary key for the intake engagement scope entity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeEngagementScope .

ind:intakeLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Intake Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier for the user who last modified the engagement scope record. Tracks negotiation and revision activity.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryIntakeAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Intake Attorney Profile Id' ;
    rdfs:comment 'Identifier for the partner who will lead the engagement and serve as primary client relationship owner. Links to timekeeper or workforce records.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:scopeOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Scope Owner Timekeeper Id' ;
    rdfs:comment 'Identifier for the user who created the initial engagement scope record. Typically a business development professional or intake coordinator.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the engagement scope was formally approved by the lead partner or practice group head. Triggers LOE drafting process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Client Responsibilities' ;
    rdfs:comment 'Explicit list of responsibilities, actions, or deliverables expected from the client to enable successful engagement execution (e.g., document provision, decision-making, access to personnel).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckReference rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Reference' ;
    rdfs:comment 'Reference number or identifier for the conflict check record in Intapp Conflicts system associated with this engagement scope.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Status' ;
    rdfs:comment 'Status of the conflict check process for this engagement scope. Must be cleared before LOE execution. Values: pending (check in progress), cleared (no conflicts), conditional (cleared with ethical walls), declined (conflict identified).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Months' ;
    rdfs:comment 'Estimated duration of the engagement in months. Used for resource planning and AFA structuring. Null for open-ended or event-driven engagements.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAssociateHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Associate Hours' ;
    rdfs:comment 'Estimated total hours to be worked by associate-level timekeepers on this engagement. Used for resource planning and AFA pricing.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Anticipated completion or end date for the engagement. Null for ongoing or open-ended matters. Used for pipeline forecasting and resource planning.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedParalegalHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Paralegal Hours' ;
    rdfs:comment 'Estimated total hours to be worked by paralegal staff on this engagement. Used for resource planning and AFA pricing.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPartnerHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Partner Hours' ;
    rdfs:comment 'Estimated total hours to be worked by partner-level timekeepers on this engagement. Used for resource planning and AFA pricing.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Start Date' ;
    rdfs:comment 'Anticipated start date for the engagement if the scope is approved and LOE is executed. Used for resource allocation and capacity planning.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedTotalHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Hours' ;
    rdfs:comment 'Total estimated hours across all timekeeper roles for the engagement. Sum of partner, associate, paralegal, and other staff hours. Used for capacity planning and fee estimation.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedServices rdf:type rdf:Property ;
    rdfs:label 'Excluded Services' ;
    rdfs:comment 'Explicit list of services, tasks, and activities that are outside the agreed engagement scope. Critical for scope management and preventing scope creep.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedServices rdf:type rdf:Property ;
    rdfs:label 'Included Services' ;
    rdfs:comment 'Explicit list of services, tasks, and deliverables that are included within the agreed engagement scope. Used to define boundaries and manage client expectations.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Critical assumptions underlying the scope definition and fee estimate (e.g., client cooperation, document availability, no material changes in law, third-party responsiveness).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyDeliverables rdf:type rdf:Property ;
    rdfs:label 'Key Deliverables' ;
    rdfs:comment 'List of major deliverables, milestones, or work products to be produced during the engagement (e.g., draft agreements, legal opinions, filings, closing documents).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaCode rdf:type rdf:Property ;
    rdfs:label 'Practice Area Code' ;
    rdfs:comment 'Primary practice area for the engagement scope. Values: CORP (Corporate), LIT (Litigation), IP (Intellectual Property), EMP (Employment), REG (Regulatory), TAX (Tax), RE (Real Estate), MA (Mergers and Acquisitions), COMP (Compliance), OTHER. [ENUM-REF-CANDIDATE: CORP|LIT|IP|EMP|REG|TAX|RE|MA|COMP|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFactors rdf:type rdf:Property ;
    rdfs:label 'Risk Factors' ;
    rdfs:comment 'Identified risks, uncertainties, or scope variables that could impact the engagement (e.g., regulatory changes, opposing party behavior, complexity escalation).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeProtocol rdf:type rdf:Property ;
    rdfs:label 'Scope Change Protocol' ;
    rdfs:comment 'Agreed process for handling scope changes, additional services, or out-of-scope requests during the engagement. Defines approval and pricing mechanisms.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scope Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the engagement scope document. Format: practice area code, year-month-sequence, scope version (e.g., CORP-202401-SC01). Used in client communications and LOE drafting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the engagement scope definition. Tracks progression from initial draft through client negotiation to final approval or withdrawal. [ENUM-REF-CANDIDATE: draft|under_review|client_review|negotiation|approved|superseded|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Scope Version Number' ;
    rdfs:comment 'Version number of the engagement scope definition. Increments with each negotiation iteration or material change to scope terms. Version 1 is the initial draft; subsequent versions track negotiation evolution.' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffingPlan rdf:type rdf:Property ;
    rdfs:label 'Staffing Plan' ;
    rdfs:comment 'Narrative description of the proposed staffing model for the engagement, including roles, seniority levels, and team composition (partner, associate, paralegal, support staff).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyToolsRequired rdf:type rdf:Property ;
    rdfs:label 'Technology Tools Required' ;
    rdfs:comment 'List of technology platforms, tools, or systems required for engagement delivery (e.g., eDiscovery platform, contract management system, data room, collaboration tools).' ;
    rdfs:domain ind:IntakeEngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientEngagementScopeId rdf:type rdf:Property ;
    rdfs:label 'Client Engagement Scope Id' ;
    rdfs:comment 'Reference to the engagement scope that this fee arrangement supports. Links the commercial agreement to the defined scope of legal services.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientEngagementScope .

ind:agreedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Fee Amount' ;
    rdfs:comment 'The total fee amount agreed for fixed fee, capped fee, or retainer arrangements. Null for hourly or contingency arrangements where the amount is variable. Represents the commercial commitment in the engagement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Business identifier for the fee arrangement, typically generated during intake negotiation. Used for tracking and reference in proposals and letters of engagement.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle status of the fee arrangement. Tracks progression from initial draft through negotiation to final approval or rejection. Superseded indicates a revised arrangement has replaced this one.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFeeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Billing Fee Arrangement Id' ;
    rdfs:comment 'Foreign key to billing.fee_arrangement.fee_arrangement_id' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendedRate rdf:type rdf:Property ;
    rdfs:label 'Blended Rate' ;
    rdfs:comment 'The single averaged hourly rate applied across all timekeepers for blended rate arrangements. Simplifies billing by eliminating individual rate variations. Null for non-blended arrangements.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capAmount rdf:type rdf:Property ;
    rdfs:label 'Cap Amount' ;
    rdfs:comment 'The maximum fee amount that can be billed for capped fee arrangements. Provides cost certainty to the client while allowing hourly billing up to the cap. Null for non-capped arrangements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The percentage of recovery or settlement that the firm will receive as its fee in contingency arrangements. Typically ranges from 10% to 40% depending on jurisdiction and matter type. Null for non-contingency arrangements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The username or identifier of the user who created this fee arrangement record. Typically a business development professional, partner, or pricing analyst involved in the intake process.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementHandling rdf:type rdf:Property ;
    rdfs:label 'Disbursement Handling' ;
    rdfs:comment 'Defines how disbursements (out-of-pocket expenses such as court fees, filing fees, expert fees) are treated in the fee arrangement. Included means absorbed in the fixed fee; pass-through means billed at cost; marked-up means billed with an administrative margin.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this fee arrangement becomes active and governs billing for the engagement. Typically aligns with the letter of engagement execution date.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeArrangementId rdf:type rdf:Property ;
    rdfs:label 'Fee Arrangement Id' ;
    rdfs:comment 'Foreign key linking to billing.fee_arrangement. Business justification: Proposed intake fee arrangements convert to active billing fee arrangements upon matter opening. Tracking this lineage enables analysis of proposal-to-execution variance, supports fee arrangement amen' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOutsideCounselGuidelineCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Outside Counsel Guideline Compliant' ;
    rdfs:comment 'Indicates whether this fee arrangement complies with the clients outside counsel guidelines. Many corporate clients impose billing guidelines that restrict rate increases, require task-based billing codes (UTBMS), and mandate electronic invoicing (LEDES).' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledesFormatRequired rdf:type rdf:Property ;
    rdfs:label 'Ledes Format Required' ;
    rdfs:comment 'Indicates whether invoices under this fee arrangement must be submitted in LEDES electronic format. LEDES is the industry standard for electronic billing data exchange between law firms and corporate clients.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loeReference rdf:type rdf:Property ;
    rdfs:label 'Loe Reference' ;
    rdfs:comment 'Reference number or identifier of the letter of engagement that formalizes this fee arrangement. Links the commercial agreement to the binding engagement contract.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFeeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Commitment' ;
    rdfs:comment 'The minimum total fee the client commits to pay over a defined period, regardless of actual work performed. Common in retainer and volume-based arrangements to guarantee revenue. Null if no minimum applies.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the user who last modified this fee arrangement record. Tracks accountability for changes during negotiation and approval.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Free-text notes capturing key points from fee negotiation discussions, client concerns, competitive pressures, and rationale for the final agreed terms. Supports knowledge management and future client interactions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Reference' ;
    rdfs:comment 'Reference to the rate schedule or rate card that underpins this fee arrangement. Links to the firms rate table in Elite 3E. Used for hourly and blended rate arrangements to track the base rates before discounts.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerPeriod rdf:type rdf:Property ;
    rdfs:label 'Retainer Period' ;
    rdfs:comment 'The recurring period for retainer fee arrangements. Defines how frequently the retainer fee is charged (e.g., monthly retainer for ongoing advisory services). Null for non-retainer arrangements.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier of this fee arrangement in the source system (e.g., Elite 3E fee arrangement ID). Enables traceability and reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Success Criteria Description' ;
    rdfs:comment 'Detailed description of the conditions that must be met to trigger the success fee. Defines measurable outcomes such as settlement amount thresholds, deal completion, or favorable court rulings.' ;
    rdfs:domain ind:IntakeFeeArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Success Fee Amount' ;
    rdfs:comment 'Additional fee payable upon achieving defined success criteria (e.g., favorable judgment, transaction close, regulatory approval). Common in M&A, litigation, and regulatory matters. Null if no success fee applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utbmsTaskCodeRequired rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code Required' ;
    rdfs:comment 'Indicates whether time entries under this fee arrangement must be coded using UTBMS task codes for billing compliance. Required by many corporate clients for invoice transparency and spend analytics.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictHitId rdf:type rdf:Property ;
    rdfs:label 'Conflict Hit Id' ;
    rdfs:comment 'Primary key for conflict_hit' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictPartyId rdf:type rdf:Property ;
    rdfs:label 'Conflict Party Id' ;
    rdfs:comment 'Foreign key to conflict.conflict_party.conflict_party_id' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictParty .

ind:intakePartyId rdf:type rdf:Property ;
    rdfs:label 'Intake Party Id' ;
    rdfs:comment 'Foreign key linking to intake.intake_party. Business justification: Conflict hits may be associated with specific intake parties. This links the conflict hit to the party for traceability, enabling tracking of which parties generated conflict hits. The existing matche' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:matchedMatterId rdf:type rdf:Property ;
    rdfs:label 'Matched Matter Id' ;
    rdfs:comment 'Reference to the existing matter record that contains the conflicting party or relationship. Null if the match is at client level only.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Matter .

ind:primaryConflictAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Attorney Profile Id' ;
    rdfs:comment 'Reference to the attorney or conflicts analyst assigned to review and disposition this hit. Typically a partner or conflicts counsel.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryConflictSearchId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Search Id' ;
    rdfs:comment 'Reference to the parent conflict search request that generated this hit. Links to the conflict search entity in the intake domain.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictSearch .

ind:tertiaryConflictEscalatedToAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Conflict Escalated To Attorney Profile Id' ;
    rdfs:comment 'Reference to the senior reviewer or committee to whom this hit was escalated. Null if no escalation occurred.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:triggeringConflictSearchId rdf:type rdf:Property ;
    rdfs:label 'Triggering Conflict Search Id' ;
    rdfs:comment 'FK to intake.conflict_search.conflict_search_id — Each conflict hit is a result of a specific conflict search. Parent-child relationship required for hit resolution tracking.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictSearch .

ind:assignedReviewerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Reviewer Name' ;
    rdfs:comment 'Full name of the assigned reviewer for display and notification purposes.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Detailed explanation of the disposition decision, including rationale, mitigating factors, and any conditions imposed. Subject to Legal Professional Privilege (LPP).' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToName rdf:type rdf:Property ;
    rdfs:label 'Escalated To Name' ;
    rdfs:comment 'Full name of the senior reviewer or committee to whom this hit was escalated.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalWallRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Required Flag' ;
    rdfs:comment 'Indicates whether an ethical wall (information barrier) must be established to mitigate the conflict and allow the engagement to proceed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hitIdentifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hit Identified Timestamp' ;
    rdfs:comment 'Date and time when the conflict hit was first identified by the conflict checking system. Marks the start of the review clock.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hit Sequence Number' ;
    rdfs:comment 'Sequential ordering of this hit within the parent conflict search. Used to maintain display order and priority ranking.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitSeverity rdf:type rdf:Property ;
    rdfs:label 'Hit Severity' ;
    rdfs:comment 'Classification of the conflict severity. Actual conflicts require declination or waiver; potential conflicts require further review; waivable conflicts may proceed with client consent; informational hits are for awareness only.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitStatus rdf:type rdf:Property ;
    rdfs:label 'Hit Status' ;
    rdfs:comment 'Current workflow status of the conflict hit within the intake review process. Tracks progression from identification through resolution.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedMatterDescription rdf:type rdf:Property ;
    rdfs:label 'Matched Matter Description' ;
    rdfs:comment 'Brief description of the matter containing the conflict. Provides context for conflict assessment without requiring full matter access.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Nature of the relationship between the matched party and the existing matter or client. Determines conflict severity and waivability. [ENUM-REF-CANDIDATE: client|adverse_party|co_counsel|opposing_counsel|related_entity|affiliate|subsidiary|parent_company|officer|director|shareholder|witness|expert|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartnerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Partner Name' ;
    rdfs:comment 'Full name of the partner responsible for the matched matter. Displayed for conflict review context.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the conflict hit review was completed and a disposition was recorded. Marks the end of the review cycle.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Urgency level for reviewing this hit. Critical and high priority hits require immediate attention to avoid intake delays.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when a reviewer first opened this hit for assessment. Used to track review cycle time.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemHitReference rdf:type rdf:Property ;
    rdfs:label 'Source System Hit Reference' ;
    rdfs:comment 'Original hit identifier from the source conflict checking system. Used for traceability and audit purposes.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Obtained Flag' ;
    rdfs:comment 'Indicates whether the required conflict waiver has been successfully obtained and documented.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Required Flag' ;
    rdfs:comment 'Indicates whether a formal conflict waiver must be obtained from affected clients before proceeding with the engagement.' ;
    rdfs:domain ind:ConflictHit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlKycProgramId rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.aml_kyc_program. Business justification: Parties being onboarded are screened against the firms AML/KYC program requirements for PEP, sanctions, and adverse media. Real process: party-level compliance screening during intake.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlKycProgram .

ind:sanctionsCheckId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_check. Business justification: Parties identified in intake undergo sanctions screening against OFAC, UN, EU lists. Real process: party-level sanctions verification before client/matter acceptance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsCheck .

ind:amlScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Date' ;
    rdfs:comment 'The date when AML screening was completed for this party. Required for compliance documentation and regulatory reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Status of the AML screening process for this party. Tracks sanctions list checks, PEP screening, and adverse media searches required for regulatory compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'The first line of the partys primary business address. For individuals, the primary residence or business location.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'The second line of the partys primary business address, including suite, floor, or building information.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'The city of the partys primary business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the partys primary business address. Used for jurisdiction analysis and regulatory compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the partys primary business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'The state or province of the partys primary business address.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Date' ;
    rdfs:comment 'The date when the conflict check was performed for this party. Required for ethics compliance and audit documentation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Description' ;
    rdfs:comment 'Detailed description of any identified conflicts, including the nature of the conflict, related matters, and affected parties. Used for conflict resolution and waiver analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Identified Flag' ;
    rdfs:comment 'Indicates whether a conflict of interest was identified for this party during conflict checking. True requires conflict resolution or engagement rejection.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictWaiverObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Obtained Flag' ;
    rdfs:comment 'Indicates whether informed consent waivers have been obtained from all affected parties to proceed despite an identified conflict.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'The legal classification of the party. Determines applicable conflict checking rules, KYC requirements, and regulatory obligations. [ENUM-REF-CANDIDATE: corporation|individual|partnership|government|non-profit|trust|llc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Incorporation' ;
    rdfs:comment 'The legal jurisdiction where the party is incorporated, registered, or domiciled. For individuals, the jurisdiction of primary residence. Critical for conflict checking and regulatory compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Date' ;
    rdfs:comment 'The date when KYC screening was completed for this party. Used for compliance audit trails and periodic re-screening requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Status' ;
    rdfs:comment 'Status of the KYC due diligence process for this party. Tracks completion of identity verification, sanctions screening, and AML checks required before engagement.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityName rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Name' ;
    rdfs:comment 'The name of the parent or controlling entity if this party is a subsidiary or affiliate. Used to identify corporate family relationships for comprehensive conflict searches.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyIntakeRequestFk rdf:type rdf:Property ;
    rdfs:label 'Party Intake Request Fk' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Parties are associated with a specific intake request for conflict checking purposes. Core operational link.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partyName rdf:type rdf:Property ;
    rdfs:label 'Party Name' ;
    rdfs:comment 'The full legal name of the party as it appears in official records. For individuals, includes full given and family names. For organizations, the registered legal entity name.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'The role this party plays in the intake request. Client represents the prospective client, adverse represents opposing parties, related represents affiliated entities, guarantor represents financial guarantors, co-counsel represents collaborating law firms, and subsidiary represents dependent entities.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party within the intake process. Pending indicates initial capture, screening indicates KYC/AML checks in progress, cleared indicates conflict-free and approved, rejected indicates conflicts identified or failed screening, escalated indicates manual review required.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary contact for this party. Used for intake communications and engagement correspondence.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The name of the primary contact person for this party during the intake process. For organizations, the key decision-maker or authorized representative.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The phone number of the primary contact for this party. Used for intake discussions and engagement negotiations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration or incorporation number assigned by the jurisdiction of incorporation. Used for entity verification and due diligence.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Match Flag' ;
    rdfs:comment 'Indicates whether the party matched any sanctions lists during screening (OFAC, UN, EU, etc.). True indicates a match requiring investigation or rejection.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The tax identification number for the party (EIN for US entities, VAT number for EU entities, etc.). Required for billing and tax reporting.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateParentEntityName rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Entity Name' ;
    rdfs:comment 'The name of the ultimate beneficial owner or top-level parent entity in the corporate hierarchy. Essential for identifying all related parties in conflict analysis.' ;
    rdfs:domain ind:IntakeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL for the party. Used for background research and entity verification during intake.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycScreeningId rdf:type rdf:Property ;
    rdfs:label 'Kyc Screening Id' ;
    rdfs:comment 'Unique identifier for the KYC screening record. Primary key.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIntakePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Intake Party Id' ;
    rdfs:comment 'FK to intake.intake_party.intake_party_id — KYC screenings are performed on specific intake parties. Required for compliance traceability.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntakeParty .

ind:adverseMediaHitFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether adverse media or negative news was found associated with the party. True if adverse media found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Detailed notes or rationale provided by the compliance officer explaining the approval or rejection decision, including any conditions or mitigating factors.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Final approval status determined by the compliance officer: approved (client may be onboarded), rejected (onboarding declined), conditional (approved with restrictions), or pending (awaiting decision).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional free-text comments or notes related to the screening process, findings, or decision-making rationale.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data classification level assigned to this screening record based on sensitivity and regulatory requirements.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eddCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Edd Completion Date' ;
    rdfs:comment 'Date on which Enhanced Due Diligence procedures were completed, if required.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eddRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edd Required Flag' ;
    rdfs:comment 'Boolean indicator of whether Enhanced Due Diligence is required for this party based on risk rating or regulatory requirements. True if EDD required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Risk Level' ;
    rdfs:comment 'Risk level associated with the jurisdiction or country of the party being screened, based on FATF assessments, corruption indices, and regulatory environment.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:party rdf:type rdf:Property ;
    rdfs:label 'Party' ;
    rdfs:comment 'FK to intake.party.party_id — KYC/AML screenings are performed on specific parties. This link is essential for compliance audit trails.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepHitFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether the party is identified as a Politically Exposed Person or close associate. True if PEP match found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Screening Required Flag' ;
    rdfs:comment 'Boolean indicator of whether periodic re-screening is required for this party. True if re-screening required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a Suspicious Activity Report (SAR) or other regulatory filing is required based on the screening results. True if filing required, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the compliance officer or staff member who reviewed and approved or rejected the screening.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned to the party based on the screening results: low, medium, high, or critical.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score assigned by the screening provider or internal risk model, typically on a scale of 0-100.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sanctionsHitFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Hit Flag' ;
    rdfs:comment 'Boolean indicator of whether the party matched any sanctions lists (OFAC, UN, EU, HMT, etc.). True if match found, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Date' ;
    rdfs:comment 'Date on which a Suspicious Activity Report was filed with the relevant authority (e.g., National Crime Agency in UK, FinCEN in US) based on screening findings.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sar Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory authority upon submission of the Suspicious Activity Report.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningCostAmount rdf:type rdf:Property ;
    rdfs:label 'Screening Cost Amount' ;
    rdfs:comment 'Cost incurred for conducting the screening, typically charged by the third-party screening provider.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Screening Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the screening cost amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Screening Expiry Date' ;
    rdfs:comment 'Date on which the current screening results expire and re-screening is required, typically based on firm policy or regulatory requirements (e.g., annual re-screening).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Screening Outcome' ;
    rdfs:comment 'Final outcome of the screening: cleared (no issues found), escalated (flagged for further review), rejected (onboarding declined), pending review, or requires EDD (Enhanced Due Diligence).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningParty rdf:type rdf:Property ;
    rdfs:label 'Screening Party' ;
    rdfs:comment 'FK to intake.party.party_id — KYC/AML screenings are performed on specific intake parties. Required for compliance audit trail.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningProvider rdf:type rdf:Property ;
    rdfs:label 'Screening Provider' ;
    rdfs:comment 'Name of the third-party screening service provider or internal system used to conduct the screening (e.g., Dow Jones Risk & Compliance, LexisNexis Bridger, World-Check, internal compliance database).' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type of due diligence screening performed: KYC (Know Your Client), AML (Anti-Money Laundering), sanctions list check, PEP (Politically Exposed Person) check, adverse media search, or credit check.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether the source of funds or wealth for the party has been verified as part of the KYC process. True if verified, False otherwise.' ;
    rdfs:domain ind:KycScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRequestApprovedByPartnerAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Request Approved By Partner Attorney Profile Id' ;
    rdfs:comment 'Identifier of the partner or committee member who granted final approval for the engagement.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:primaryRequestingTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Requesting Timekeeper Id' ;
    rdfs:comment 'Identifier of the attorney or business development professional who submitted the intake request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:requestOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Request Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the system user who last modified the intake request record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:adverseParties rdf:type rdf:Property ;
    rdfs:label 'Adverse Parties' ;
    rdfs:comment 'Names of opposing parties, counterparties, or other entities adverse to the clients interests. Critical for conflict checking and ethical wall determination.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Completed Timestamp' ;
    rdfs:comment 'Date and time when the conflict check process was completed and a determination was made.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conflictWaiverObtained rdf:type rdf:Property ;
    rdfs:label 'Conflict Waiver Obtained' ;
    rdfs:comment 'Indicates whether a formal conflict waiver was obtained from affected parties to proceed despite an identified conflict.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intakeStatus rdf:type rdf:Property ;
    rdfs:label 'Intake Status' ;
    rdfs:comment 'Current stage of the intake request in the workflow lifecycle. Progresses from submission through conflict clearance, compliance screening, approval, and matter opening. [ENUM-REF-CANDIDATE: Submitted|Conflict Check In Progress|KYC In Progress|Pending Approval|Approved|Rejected|Matter Opened|Withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeExecutedDate rdf:type rdf:Property ;
    rdfs:label 'Loe Executed Date' ;
    rdfs:comment 'Date on which the engagement letter was signed by both the firm and the client, formalizing the attorney-client relationship.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loeRequired rdf:type rdf:Property ;
    rdfs:label 'Loe Required' ;
    rdfs:comment 'Indicates whether a formal letter of engagement or engagement letter must be executed before matter opening.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterOpenedFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Opened Flag' ;
    rdfs:comment 'Indicates whether the matter has been successfully opened in Elite 3E and the intake process is complete.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proposedClientName rdf:type rdf:Property ;
    rdfs:label 'Proposed Client Name' ;
    rdfs:comment 'Name of the prospective client or organization for whom legal services are being requested. May be an existing client for a new matter or a completely new client.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedFeeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Proposed Fee Arrangement Type' ;
    rdfs:comment 'Type of billing arrangement proposed for the matter. May be traditional hourly or an alternative fee arrangement negotiated with the client. [ENUM-REF-CANDIDATE: Hourly|Fixed Fee|Contingency|Blended|Capped Fee|Success Fee|Retainer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedParties rdf:type rdf:Property ;
    rdfs:label 'Related Parties' ;
    rdfs:comment 'Names of other parties involved in the matter who are not adverse but require conflict screening (e.g., co-counsel, transaction participants, witnesses).' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the intake request, typically formatted as office code followed by sequential number. Used for tracking and reference in communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMatterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Target Matter Open Date' ;
    rdfs:comment 'Requested or target date by which the matter should be opened in Elite 3E and work can commence.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:urgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Urgency Flag' ;
    rdfs:comment 'Indicates whether this intake request requires expedited processing due to time-sensitive business needs, court deadlines, or transaction timelines.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSearchId rdf:type rdf:Property ;
    rdfs:label 'Conflict Search Id' ;
    rdfs:comment 'Primary key for conflict_search' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConflictTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Timekeeper Id' ;
    rdfs:comment 'Reference to the employee (typically intake coordinator, conflicts analyst, or attorney) who initiated the conflict search.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:alternateNamesSearched rdf:type rdf:Property ;
    rdfs:label 'Alternate Names Searched' ;
    rdfs:comment 'Comma-separated list of alternate names, aliases, DBA names, former names, or related entity names included in the conflict search parameters to ensure comprehensive coverage.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedSearchFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Search Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether this conflict search was triggered automatically by system workflow rules (True) or manually initiated by a user (False).' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:databaseSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Database Snapshot Timestamp' ;
    rdfs:comment 'The timestamp of the relationship and matter database snapshot against which this search was executed, important for understanding data currency and reproducibility.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Technical error message or exception details if the conflict search failed or encountered issues during execution. Null for successful searches.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmOfficeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Firm Office Location Code' ;
    rdfs:comment 'Code identifying the firm office location from which the conflict search was initiated, used for multi-office conflict management and jurisdiction-specific rules.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'High Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged by the system as high-risk conflicts requiring immediate escalation and review by conflicts counsel.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionFilter rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Filter' ;
    rdfs:comment 'Geographic or legal jurisdiction filter applied to the conflict search to limit results to matters in specific regions or court systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'Low Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged as low-risk or informational matches that may not constitute actual conflicts but warrant awareness.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Match Threshold Percentage' ;
    rdfs:comment 'The minimum similarity percentage threshold (0-100) used to determine whether a potential match is included in search results. Lower thresholds return more results but may include false positives.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matterTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Matter Type Filter' ;
    rdfs:comment 'The matter type or practice area filter applied to the conflict search (e.g., M&A, litigation, IP prosecution) to narrow results to relevant engagements.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediumRiskHitsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Risk Hits Count' ;
    rdfs:comment 'Number of search results flagged as medium-risk conflicts requiring standard review and potential waiver or ethical wall consideration.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partyNameSearched rdf:type rdf:Property ;
    rdfs:label 'Party Name Searched' ;
    rdfs:comment 'The primary party name (individual or organization) that was the subject of this conflict search. May be client, adverse party, or related entity.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classification of the party being searched: individual person, corporate/organizational entity, or government/public sector entity.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultsExportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Results Export Timestamp' ;
    rdfs:comment 'Date and time when the conflict search results were exported. Null if results have not been exported.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultsExportedFlag rdf:type rdf:Property ;
    rdfs:label 'Results Exported Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether the conflict search results were exported to external format (PDF, Excel, or report) for distribution or review.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchAlgorithmType rdf:type rdf:Property ;
    rdfs:label 'Search Algorithm Type' ;
    rdfs:comment 'The matching algorithm used for this conflict search. Exact_match requires precise name matches; fuzzy_match allows for spelling variations; phonetic_match uses soundex-style matching; ai_enhanced uses natural language processing and machine learning.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Completed Timestamp' ;
    rdfs:comment 'Date and time when the conflict search processing completed and results were returned. Null if search is still in progress or failed.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Search Date Range End' ;
    rdfs:comment 'End date of the matter date range filter applied to the conflict search, if search_scope is specific_date_range. Null for other scopes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Search Date Range Start' ;
    rdfs:comment 'Start date of the matter date range filter applied to the conflict search, if search_scope is specific_date_range. Null for other scopes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Search Engine Version' ;
    rdfs:comment 'Version identifier of the Intapp Conflicts search engine used to execute this search, important for audit trail and result reproducibility.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Executed Timestamp' ;
    rdfs:comment 'Date and time when the conflict search was executed against the relationship and matter database. This is the principal business event timestamp for the search.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchExecutionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Search Execution Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds from search initiation to completion, used for performance monitoring and system optimization.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchIntake rdf:type rdf:Property ;
    rdfs:label 'Search Intake' ;
    rdfs:comment 'FK to intake.intake_request.intake_request_id — Conflict searches are executed as part of an intake request workflow. Required for tracking which searches belong to which intake.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchNotes rdf:type rdf:Property ;
    rdfs:label 'Search Notes' ;
    rdfs:comment 'Free-text notes entered by the searcher documenting search rationale, special considerations, or preliminary assessment of results. May contain attorney work product.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchPriority rdf:type rdf:Property ;
    rdfs:label 'Search Priority' ;
    rdfs:comment 'The business priority assigned to this conflict search. Urgent indicates time-sensitive RFP or pitch deadline; high indicates important prospective client; normal indicates standard intake workflow; low indicates preliminary inquiry.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Search Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the conflict search, typically generated by Intapp Conflicts system in format CS-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchRetryCount rdf:type rdf:Property ;
    rdfs:label 'Search Retry Count' ;
    rdfs:comment 'Number of times this conflict search was re-executed due to technical failures, timeout errors, or user-requested refinement. Zero indicates first successful execution.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchScope rdf:type rdf:Property ;
    rdfs:label 'Search Scope' ;
    rdfs:comment 'The temporal scope of the conflict search. Current_matters searches only active engagements; all_matters includes historical; closed_matters searches only concluded engagements; specific_date_range searches a defined period.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchStatus rdf:type rdf:Property ;
    rdfs:label 'Search Status' ;
    rdfs:comment 'Current lifecycle status of the conflict search execution. Pending indicates queued; in_progress indicates actively running; complete indicates search finished with results; escalated indicates potential conflicts requiring review; cancelled indicates search was aborted; failed indicates technical error.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searcherName rdf:type rdf:Property ;
    rdfs:label 'Searcher Name' ;
    rdfs:comment 'Full name of the individual who executed the conflict search, captured for audit trail purposes.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHitsReturned rdf:type rdf:Property ;
    rdfs:label 'Total Hits Returned' ;
    rdfs:comment 'The total number of potential conflict matches (matters, clients, or relationships) returned by the search engine. Zero indicates no conflicts found; higher numbers indicate potential issues requiring review.' ;
    rdfs:domain ind:ConflictSearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pitchModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Pitch Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified the pitch record.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:pitchOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Pitch Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created the pitch record, typically a BD professional or partner.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryPitchLegalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Pitch Legal Document Id' ;
    rdfs:comment 'Reference to the pitch deck or credentials presentation document stored in the Document Management System (iManage Work or NetDocuments).' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalDocument .

ind:primaryRfpSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfp Submission Id' ;
    rdfs:comment 'FK to intake.rfp_submission.rfp_submission_id — Pitches are made in response to RFPs. This is the core pipeline progression link. Without it, cannot trace RFP→pitch→opportunity flow.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpSubmission .

ind:sourceRfpSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Source Rfp Submission Id' ;
    rdfs:comment 'FK to intake.rfp_submission.rfp_submission_id — Pitches are made in response to RFPs — this FK links the response activity to the triggering request. Critical for win/loss analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpSubmission .

ind:clientAttendees rdf:type rdf:Property ;
    rdfs:label 'Client Attendees' ;
    rdfs:comment 'Names and titles of client representatives who attended the pitch, captured for relationship tracking and follow-up. Comma-separated list.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingFirms rdf:type rdf:Property ;
    rdfs:label 'Competing Firms' ;
    rdfs:comment 'Names of known competing law firms participating in the pitch process, if disclosed by the client. Comma-separated list.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Context' ;
    rdfs:comment 'Indicates whether the pitch was sole-sourced or competitive, and if competitive, the approximate number of competing firms: sole_pitch (no competition), competitive_2_firms, competitive_3_firms, competitive_4plus_firms, or unknown.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated total cost to the firm of pursuing the pitch, including attorney time, travel, materials, and external consultants. Used for BD ROI analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the pitch presentation in minutes, including Q&A if applicable.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which post-pitch follow-up actions must be completed, if applicable.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether post-pitch follow-up actions are required (e.g., additional information requests, clarifications, supplemental proposals). True if follow-up is needed, False otherwise.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location or virtual platform where the pitch was delivered (e.g., client office address, firm office, video conference platform).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Code' ;
    rdfs:comment 'Standardized code or category explaining why the pitch was lost, if applicable (e.g., fee too high, lack of experience, conflict of interest, relationship with competitor, client chose incumbent). Used for win/loss analysis and BD strategy refinement.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the pitch: won (firm selected and engagement awarded), lost (firm not selected), pending (decision not yet received), withdrawn (firm withdrew from consideration), or no_decision (client did not proceed with engagement).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date on which the pitch outcome was communicated to the firm by the client or became known.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Date' ;
    rdfs:comment 'The date on which the pitch was delivered or presented to the prospective client.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchName rdf:type rdf:Property ;
    rdfs:label 'Pitch Name' ;
    rdfs:comment 'Descriptive name or title of the pitch, typically reflecting the matter type or client engagement scope being pursued.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchStatus rdf:type rdf:Property ;
    rdfs:label 'Pitch Status' ;
    rdfs:comment 'Current lifecycle status of the pitch: scheduled (pitch date set but not yet delivered), delivered (pitch completed, awaiting outcome), won (firm selected), lost (firm not selected), pending (outcome not yet known), withdrawn (firm withdrew from consideration), or no_decision (client did not proceed with engagement). [ENUM-REF-CANDIDATE: scheduled|delivered|won|lost|pending|withdrawn|no_decision — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchType rdf:type rdf:Property ;
    rdfs:label 'Pitch Type' ;
    rdfs:comment 'Classification of the pitch format: beauty parade (competitive multi-firm presentation), credentials deck (written credentials submission), oral presentation (in-person or virtual pitch), written proposal (detailed written submission), panel interview (Q&A with client panel), or finalist presentation (final round competitive pitch).' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationHours rdf:type rdf:Property ;
    rdfs:label 'Preparation Hours' ;
    rdfs:comment 'Total non-billable hours invested by the firm in preparing for the pitch, including research, deck creation, rehearsal, and travel. Used for BD cost analysis.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedFeeArrangement rdf:type rdf:Property ;
    rdfs:label 'Proposed Fee Arrangement' ;
    rdfs:comment 'Type of fee arrangement proposed in the pitch: hourly (standard time-based billing), fixed_fee (flat fee for scope), capped_fee (hourly with upper limit), contingency (success-based), blended_rate (single rate for all timekeepers), afa_other (alternative fee arrangement not otherwise specified), retainer (ongoing monthly/quarterly fee), or success_fee (bonus upon outcome). [ENUM-REF-CANDIDATE: hourly|fixed_fee|capped_fee|contingency|blended_rate|afa_other|retainer|success_fee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Internal qualitative or quantitative score assigned to the pitch performance by the pitch team or BD leadership, used for continuous improvement. Scale and methodology defined by firm policy.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Total number of attorneys and professionals from the firm who participated in the pitch presentation or preparation.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winLossNotes rdf:type rdf:Property ;
    rdfs:label 'Win Loss Notes' ;
    rdfs:comment 'Free-text narrative capturing detailed feedback from the client or internal debrief regarding the pitch outcome, including strengths, weaknesses, and lessons learned.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReasonCode rdf:type rdf:Property ;
    rdfs:label 'Win Reason Code' ;
    rdfs:comment 'Standardized code or category explaining why the pitch was won, if applicable (e.g., expertise, relationship, fee competitiveness, innovation, diversity). Used for win/loss analysis and BD strategy refinement.' ;
    rdfs:domain ind:Pitch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Engagement Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified the opportunity record.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:opportunityOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created the opportunity record.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:practiceAreaId rdf:type rdf:Property ;
    rdfs:label 'Practice Area Id' ;
    rdfs:comment 'Foreign key linking to service.practice_area. Business justification: Opportunities tracked by practice area for pipeline reporting, resource forecasting, capacity planning, and practice-level revenue projections. Critical for business development dashboards and partner' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:primaryEngagementAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Attorney Profile Id' ;
    rdfs:comment 'Reference to the partner leading the business development effort and expected to be the originating or responsible partner if the matter opens.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:tertiaryProspectId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Prospect Id' ;
    rdfs:comment 'FK to intake.prospect.prospect_id — Each engagement opportunity is associated with a prospect. This is the core CRM pipeline link.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date the opportunity was closed (won or lost).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:afaType rdf:type rdf:Property ;
    rdfs:label 'Afa Type' ;
    rdfs:comment 'Type of fee arrangement under consideration or negotiated for this opportunity. [ENUM-REF-CANDIDATE: hourly|fixed_fee|capped_fee|contingency|blended_rate|success_fee|retainer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competing law firm or ALSP that won the engagement, if known.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Completed Date' ;
    rdfs:comment 'Date the conflict check was completed and cleared (or waived) for this opportunity.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dynamicsOpportunityGuid rdf:type rdf:Property ;
    rdfs:label 'Dynamics Opportunity Guid' ;
    rdfs:comment 'Globally unique identifier (GUID) of the corresponding Opportunity record in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteMatterNumber rdf:type rdf:Property ;
    rdfs:label 'Elite Matter Number' ;
    rdfs:comment 'The matter number assigned in Elite 3E if the opportunity was converted to an active matter.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Summary' ;
    rdfs:comment 'High-level description of the anticipated scope of work and services to be provided.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Forecasted date by which the opportunity will reach a closed-won or closed-lost decision.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedMatterOpenDate rdf:type rdf:Property ;
    rdfs:label 'Expected Matter Open Date' ;
    rdfs:comment 'Anticipated date the matter will be opened in Elite 3E if the opportunity is won.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or method through which the opportunity was generated. [ENUM-REF-CANDIDATE: referral|existing_client|rfp|conference|website|cold_outreach|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason the opportunity was lost (e.g., fee, competitor selected, timing, conflict).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterOpenedInEliteFlag rdf:type rdf:Property ;
    rdfs:label 'Matter Opened In Elite Flag' ;
    rdfs:comment 'Indicates whether a corresponding matter has been opened in Elite 3E following a closed-won opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the engagement opportunity, typically reflecting the matter type or transaction name.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Business-facing unique identifier for the opportunity, typically generated by Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityStage rdf:type rdf:Property ;
    rdfs:label 'Opportunity Stage' ;
    rdfs:comment 'Current stage of the opportunity in the business development pipeline.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchTeamNotes rdf:type rdf:Property ;
    rdfs:label 'Pitch Team Notes' ;
    rdfs:comment 'Internal notes and observations from the pitch team regarding client needs, competitive positioning, and strategy.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Percent' ;
    rdfs:comment 'Estimated probability of converting this opportunity to a matter, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalDueDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Due Date' ;
    rdfs:comment 'Deadline by which the firm must submit its proposal or pitch to the prospect.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Date' ;
    rdfs:comment 'Date the firm submitted its formal proposal or pitch to the prospect.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Received Date' ;
    rdfs:comment 'Date the firm received the RFP or initial inquiry from the prospect.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceCampaign rdf:type rdf:Property ;
    rdfs:label 'Source Campaign' ;
    rdfs:comment 'Marketing campaign or business development initiative that generated this opportunity.' ;
    rdfs:domain ind:EngagementOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaDeliveryConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Practice Area Delivery Configuration Id' ;
    rdfs:comment 'Primary key for practice_area_delivery_configuration' ;
    rdfs:domain ind:PracticeAreaDeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Configuration Id' ;
    rdfs:comment 'Primary key uniquely identifying each practice area delivery configuration record' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryConfiguration .

ind:deliveryModelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Id' ;
    rdfs:comment 'Foreign key linking to the delivery model through which the practice area can be delivered' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryModel .

ind:capacityAllocationFte rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Fte' ;
    rdfs:comment 'Number of full-time equivalent staff allocated to deliver this specific practice area through this specific delivery model. Used for capacity planning and resource forecasting. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PracticeAreaDeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientDemandRating rdf:type rdf:Property ;
    rdfs:label 'Client Demand Rating' ;
    rdfs:comment 'Assessment of client demand for this practice area delivered through this delivery model, based on RFP requests, client inquiries, and market analysis.' ;
    rdfs:domain ind:PracticeAreaDeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this practice area-delivery model configuration. Active configurations are in production use, pilot configurations are being tested, inactive are temporarily suspended, and deprecated are retired.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEfficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Cost Efficiency Score' ;
    rdfs:comment 'Calculated score (0-100) representing the cost efficiency of delivering this practice area through this delivery model, based on cost per matter, realization rates, and resource utilization.' ;
    rdfs:domain ind:PracticeAreaDeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this practice area-delivery model configuration was retired or deprecated. Null for currently active configurations. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this practice area-delivery model configuration became active and available for use in client engagements and capacity planning. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Strategic importance of this practice area-delivery model combination to the firm. Strategic combinations receive priority in capacity allocation and investment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Assessment of the quality and effectiveness of delivering this practice area through this delivery model, based on client feedback, matter outcomes, and internal quality reviews. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Percentage' ;
    rdfs:comment 'Target utilization rate (percentage of billable hours to total available hours) for resources delivering this practice area through this delivery model. Used for performance management and capacity optimization. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualId rdf:type rdf:Property ;
    rdfs:label 'Individual Id' ;
    rdfs:comment 'Foreign key linking to client.individual. Business justification: Prospects can be individuals (personal legal services, estate planning, etc.) before becoming formal clients. This FK links individual prospects to the individual master. is_new_attribute=true because' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Individual .

ind:organisationId rdf:type rdf:Property ;
    rdfs:label 'Organisation Id' ;
    rdfs:comment 'Foreign key linking to client.organisation. Business justification: Prospects in legal services are often organizations before they become formal clients. This FK links corporate prospects to the organisation master. is_new_attribute=true because organisation_id is no' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:primaryProspectAttorneyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Prospect Attorney Profile Id' ;
    rdfs:comment 'Identifier of the attorney who owns the relationship with this prospect and is responsible for business development and intake progression.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttorneyProfile .

ind:competitorFirms rdf:type rdf:Property ;
    rdfs:label 'Competitor Firms' ;
    rdfs:comment 'Names of competing law firms known to be pitching for the same engagement. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Conflicts System Reference' ;
    rdfs:comment 'External identifier linking this prospect to the new business intake record in Intapp Conflicts system. Used for conflict check workflow integration.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedToClientDate rdf:type rdf:Property ;
    rdfs:label 'Converted To Client Date' ;
    rdfs:comment 'Date on which the prospect was successfully converted to a formal client upon Letter of Engagement (LOE) execution and matter opening. Nullable until conversion occurs.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'External identifier linking this prospect to the corresponding account or lead record in Microsoft Dynamics 365 CRM. Enables bi-directional synchronization.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason for disqualifying or declining the prospect opportunity. Populated when pipeline stage moves to lost or declined. Used for loss analysis and process improvement.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated matter value. Supports multi-currency pipeline reporting.' ;
    rdfs:domain ind:Intake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Decision Date' ;
    rdfs:comment 'Anticipated date by which the prospect is expected to make a decision on the engagement. Used for pipeline forecasting and follow-up scheduling.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the prospect in the new business intake pipeline. Tracks progression from initial lead through to engagement or disqualification. [ENUM-REF-CANDIDATE: lead|qualified|pitch_scheduled|proposal_submitted|negotiation|won|lost|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'The legal or trading name of the prospective client organization or individual. For organizations, this is the registered business name; for individuals, the full legal name.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospect entity type. Determines the intake workflow, KYC requirements, and conflict checking scope.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date on which the prospect was referred to the firm. Nullable if the prospect source is not a referral. Used for referral attribution and relationship tracking.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSourceType rdf:type rdf:Property ;
    rdfs:label 'Referral Source Type' ;
    rdfs:comment 'Classification of the referring party when the prospect source is a referral. Used for referral network analytics and attribution reporting.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringPartyName rdf:type rdf:Property ;
    rdfs:label 'Referring Party Name' ;
    rdfs:comment 'Name of the individual or organization that referred this prospect. Nullable if the prospect source is not a referral.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Response Due Date' ;
    rdfs:comment 'Deadline for submitting the proposal or RFP response to the prospect. Used for intake workflow prioritization and resource scheduling.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Estimated probability of winning the engagement expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting and resource planning.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientContactId rdf:type rdf:Property ;
    rdfs:label 'Client Contact Id' ;
    rdfs:comment 'Reference to the primary client contact person who issued or is managing the RFP on behalf of the issuing organisation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:issuingOrganisationId rdf:type rdf:Property ;
    rdfs:label 'Issuing Organisation Id' ;
    rdfs:comment 'Reference to the prospective or existing client organisation that issued this RFP.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organisation .

ind:rfpLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Rfp Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this RFP submission record.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:submissionOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Submission Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user (business development staff or partner) who created this RFP submission record.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:competitiveFirms rdf:type rdf:Property ;
    rdfs:label 'Competitive Firms' ;
    rdfs:comment 'Names or identifiers of other law firms known to be competing for this RFP, if disclosed by the client or identified through market intelligence.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Decision Received Date' ;
    rdfs:comment 'The date on which the firm received notification of the clients decision regarding the RFP (awarded, declined, or no decision).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'The reason why the firm declined to respond to the RFP or why the client declined the firms proposal. [ENUM-REF-CANDIDATE: conflict_of_interest|capacity_constraints|fee_expectations|practice_area_mismatch|strategic_fit|competitive_pricing|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Notes' ;
    rdfs:comment 'Additional free-text notes providing context or details about the decline reason.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Amount' ;
    rdfs:comment 'The estimated monetary value of the engagement or matter if it proceeds, as assessed by the business development team during initial qualification.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the RFP and proposed engagement scope comply with GDPR requirements, relevant for EU-based clients or matters involving EU personal data.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text internal notes and observations recorded by the pitch team, business development, or intake staff regarding this RFP submission.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExistingClient rdf:type rdf:Property ;
    rdfs:label 'Is Existing Client' ;
    rdfs:comment 'Boolean flag indicating whether the issuing organisation is an existing client of the firm (True) or a prospective new client (False).' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date on which the RFP was received by the firm. This is the principal business event timestamp marking the start of the intake process.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresPanelApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Panel Approval' ;
    rdfs:comment 'Boolean flag indicating whether this RFP requires approval from a clients legal panel or preferred provider list.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the firm must submit its response to the RFP, as specified by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Time' ;
    rdfs:comment 'The precise timestamp (including time of day) by which the RFP response must be submitted, if specified by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rfpDescription rdf:type rdf:Property ;
    rdfs:label 'Rfp Description' ;
    rdfs:comment 'Detailed description of the legal services being requested, including scope, objectives, and key requirements outlined in the RFP document.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Reference Number' ;
    rdfs:comment 'The external reference number or identifier assigned by the issuing organisation to this RFP. This is the business identifier used in client communications.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpTitle rdf:type rdf:Property ;
    rdfs:label 'Rfp Title' ;
    rdfs:comment 'The title or subject of the RFP as provided by the issuing organisation.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel or method through which the RFP was received by the firm (e.g., email, client portal, direct mail, referral, existing client relationship). [ENUM-REF-CANDIDATE: email|portal|direct_mail|referral|existing_client|conference|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'The current lifecycle status of the RFP submission within the firms intake workflow (received, under review, declined, responded, withdrawn, awarded).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percentage' ;
    rdfs:comment 'The estimated probability (0-100%) that the firm will win this RFP, as assessed by the pitch team or business development team.' ;
    rdfs:domain ind:RfpSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Unique identifier for the service eligibility rule. Primary key for this entity.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityLastModifiedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Last Modified By Timekeeper Id' ;
    rdfs:comment 'Reference to the user (timekeeper, business development manager, or system administrator) who most recently modified this eligibility rule record.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:legalServiceId rdf:type rdf:Property ;
    rdfs:label 'Legal Service Id' ;
    rdfs:comment 'Reference to the legal service offering to which this eligibility rule applies (e.g., M&A advisory, litigation, IP counsel, regulatory compliance counseling).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:primaryEligibilityTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Eligibility Timekeeper Id' ;
    rdfs:comment 'Reference to the partner, practice group leader, or business development manager responsible for defining and maintaining this eligibility rule.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:ruleOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Rule Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user (timekeeper, business development manager, or system administrator) who created this eligibility rule record.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal approval is required before this rule can be activated. True if approval workflow must be completed, false otherwise.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Client Type Filter' ;
    rdfs:comment 'Pipe-separated list of client types to which this rule applies (e.g., corporate|government, individual, nonprofit). Empty if rule applies to all client types. [ENUM-REF-CANDIDATE: corporate|government|individual|nonprofit|partnership|trust|estate|public_sector|private_sector — promote to reference product]' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Severity of the rule enforcement: hard block (prevents engagement from proceeding without exception), advisory warning (requires partner override to proceed), or soft warning (informational only, does not block).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationLogic rdf:type rdf:Property ;
    rdfs:label 'Evaluation Logic' ;
    rdfs:comment 'Structured expression or pseudo-code defining how the rule is evaluated during intake workflow. May reference client attributes, matter attributes, clearance outcomes, or external data sources.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySectorExclusion rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Exclusion' ;
    rdfs:comment 'Pipe-separated list of industry sectors (e.g., NAICS or SIC codes) that are excluded from eligibility for this legal service. Empty if no sector exclusions apply.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterValueThreshold rdf:type rdf:Property ;
    rdfs:label 'Matter Value Threshold' ;
    rdfs:comment 'Minimum estimated matter value (in base currency) required for the client or matter to qualify for the legal service. Null if no value threshold applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authority Level' ;
    rdfs:comment 'The minimum authority level required to override this rule when enforcement level is advisory warning (e.g., partner, managing partner, practice group leader, general counsel). Null if rule cannot be overridden.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaFilter rdf:type rdf:Property ;
    rdfs:label 'Practice Area Filter' ;
    rdfs:comment 'Pipe-separated list of practice area codes or identifiers to which this rule applies (e.g., M&A, litigation, IP, employment). Empty if rule applies to all practice areas.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteClearanceStatusRequired rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Clearance Status Required' ;
    rdfs:comment 'The clearance status outcome required from the prerequisite clearance process for the rule to pass (e.g., approved, cleared, passed). Null if no prerequisite applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteClearanceType rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Clearance Type' ;
    rdfs:comment 'Type of prerequisite clearance required before the legal service can be offered: conflict check (from conflict domain), KYC (Know Your Client), AML (Anti-Money Laundering), sanctions screening, or none if no prerequisite applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code for the eligibility rule, used for reference in intake workflows and RFP qualification processes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of the eligibility rule, including the rationale, business context, and any special considerations for application during new business intake.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the eligibility rule, describing its purpose (e.g., Corporate Client Minimum Matter Value, Government Sector Exclusion).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Numeric priority for rule evaluation order when multiple rules apply to the same service. Lower numbers indicate higher priority. Used by intake workflow engine to sequence rule checks.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility rule: active (enforced), inactive (not enforced), draft (under development), suspended (temporarily disabled), or retired (no longer used).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of eligibility rule defining the nature of the constraint: client-type restrictions (corporate, government, individual), minimum matter value thresholds, jurisdictional licensing constraints, industry sector exclusions, prerequisite clearance requirements (conflict check, KYC, AML), or practice area restrictions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version number of this eligibility rule, incremented with each substantive change to evaluation logic or enforcement parameters. Supports rule change tracking and audit.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the matter value threshold (e.g., USD, GBP, EUR). Null if no value threshold applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpmTemplateId rdf:type rdf:Property ;
    rdfs:label 'Lpm Template Id' ;
    rdfs:comment 'Unique identifier for the Legal Project Management template. Primary key.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knowledgeAssetId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Asset Id' ;
    rdfs:comment 'Foreign key linking to knowledge.knowledge_asset. Business justification: LPM templates reference specific knowledge assets as required inputs for matter phases and deliverables. Used in matter planning, resource estimation, and scope definition. Enables tracking which know' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeAsset .

ind:primaryLegalServiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Legal Service Id' ;
    rdfs:comment 'FK to service.legal_service.legal_service_id — LPM templates are created for specific service types. A litigation LPM template differs fundamentally from a transactional one. This link enables correct template selection at matter opening.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalService .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the partner or practice group leader who approved this template for use.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated budget amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Client Reporting Frequency' ;
    rdfs:comment 'Standard frequency for client progress reporting defined in this template (Weekly, Bi-Weekly, Monthly, Quarterly, Milestone-Based, Ad-Hoc).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Complexity classification of matters that should use this template, indicating resource requirements and risk profile (Low, Medium, High, Very High).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Total number of standard deliverables (documents, reports, opinions) defined in this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentTemplateReferences rdf:type rdf:Property ;
    rdfs:label 'Document Template References' ;
    rdfs:comment 'Comma-separated list of document template IDs or codes that are standard deliverables for this LPM template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Standard estimated budget amount for matters using this template, used for initial scoping and client proposals.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Days' ;
    rdfs:comment 'Standard estimated duration in calendar days for matters following this template, from matter opening to closure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteRequirement rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement' ;
    rdfs:comment 'Estimated total Full-Time Equivalent (FTE) resource requirement for the duration of a matter using this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Comma-separated list of jurisdictions or countries where this template is applicable (e.g., USA, GBR, EU, Global).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeArticleReferences rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article References' ;
    rdfs:comment 'Comma-separated list of knowledge management article IDs or practice notes that support this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this template was most recently used to instantiate a new matter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of key milestones defined across all phases in this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseCount rdf:type rdf:Property ;
    rdfs:label 'Phase Count' ;
    rdfs:comment 'Total number of project phases defined in this template (e.g., Intake, Planning, Execution, Review, Closure).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceRoleRequirements rdf:type rdf:Property ;
    rdfs:label 'Resource Role Requirements' ;
    rdfs:comment 'Comma-separated list of required resource roles for this template (e.g., Partner, Senior Associate, Junior Associate, Paralegal, Legal Secretary).' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Risk Checkpoint Count' ;
    rdfs:comment 'Number of formal risk assessment checkpoints defined in the template for matter governance and quality control.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of legal service this template supports (e.g., Advisory, Transactional, Contentious, Compliance, Due Diligence, Drafting).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Service Level Agreement (SLA) target duration in days for matter completion when using this template.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskCount rdf:type rdf:Property ;
    rdfs:label 'Task Count' ;
    rdfs:comment 'Total number of standard tasks defined in the template task sequence.' ;
    rdfs:domain ind:LpmTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Business identifier code for the LPM template, used for quick reference and system integration (e.g., MA_STANDARD, LIT_COMPLEX, IP_PATENT).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the LPM template, including its purpose, scope, typical use cases, and key deliverables.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the LPM template describing the project structure and service type (e.g., Standard M&A Transaction Template, Complex Commercial Litigation Template).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the LPM template (Draft, Active, Under Review, Deprecated, Archived).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of matters that have been instantiated using this template, used for template effectiveness analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utbmsTaskCodes rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Codes' ;
    rdfs:comment 'Comma-separated list of Uniform Task-Based Management System (UTBMS) task codes applicable to this template for standardized billing and reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Name or identifier of the user who created this template record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique identifier for the service line. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:modifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Timekeeper Id' ;
    rdfs:comment 'The identifier of the user who last modified this service line record. Used for audit trail and accountability tracking.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:parentLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Id' ;
    rdfs:comment 'Self-referencing FK on line (parent_line_id)' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:averageMatterDurationDays rdf:type rdf:Property ;
    rdfs:label 'Average Matter Duration Days' ;
    rdfs:comment 'The typical duration in days from matter opening to closure for matters in this service line. Used for resource planning, WIP forecasting, and client expectation management.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageMatterValue rdf:type rdf:Property ;
    rdfs:label 'Average Matter Value' ;
    rdfs:comment 'The average total billed value (in firm base currency) of matters in this service line. Used for pipeline forecasting, partner compensation modeling, and lateral hiring business case analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModelDefault rdf:type rdf:Property ;
    rdfs:label 'Billing Model Default' ;
    rdfs:comment 'The predominant billing model used by this service line. Hourly = traditional time-based billing. Fixed Fee = flat fee per matter. Contingency = success-based fee. AFA (Alternative Fee Arrangement) = value-based or outcome-based pricing. Hybrid = combination. Retainer = ongoing monthly/quarterly fee.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Client Facing Flag' ;
    rdfs:comment 'Indicates whether this service line is used in client-facing branding, marketing materials, and RFP responses (True) or is purely an internal financial reporting construct (False).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Sensitivity Level' ;
    rdfs:comment 'The typical conflict-of-interest sensitivity for matters in this service line. High = frequent conflicts requiring ethical walls (e.g., M&A, litigation). Medium = occasional conflicts. Low = rare conflicts. Used to inform conflict checking protocols.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellingAffinityScore rdf:type rdf:Property ;
    rdfs:label 'Cross Selling Affinity Score' ;
    rdfs:comment 'A calculated score (0-100) representing the likelihood of cross-selling opportunities between this service line and other service lines. Based on historical client engagement patterns. Used for business development targeting.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversity Target Percentage' ;
    rdfs:comment 'The firms diversity representation target (as a percentage) for this service lines attorney population. Used for DEI reporting, lateral hiring decisions, and client diversity scorecard requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date when this service line was discontinued or sunset. Null for active service lines. Used for historical P&L reporting and partner compensation reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fteCountCurrent rdf:type rdf:Property ;
    rdfs:label 'Fte Count Current' ;
    rdfs:comment 'The current total FTE headcount (partners, associates, paralegals, and support staff) allocated to this service line. Used for utilization analysis, capacity planning, and revenue per FTE calculations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:knowledgeManagementRepository rdf:type rdf:Property ;
    rdfs:label 'Knowledge Management Repository' ;
    rdfs:comment 'The primary knowledge management system or repository used by this service line for precedent documents, practice notes, and matter templates (e.g., Thomson Reuters Practical Law, iManage Work, internal KM system).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Short alphanumeric code used internally for financial reporting, practice management systems, and partner compensation allocation (e.g., CORP, DISP, REG, TRANS, IP, EMP).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed description of the service lines scope, including the types of legal services, practice areas, and client matters it encompasses. Used for business development, RFP responses, and strategic planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'The official name of the service line as used in firm communications, financial reporting, and client-facing materials (e.g., Corporate Advisory, Disputes & Investigations, Regulatory & Government Affairs, Transactional, Intellectual Property, Employment & Labor).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current operational status of the service line. Active lines are fully operational with revenue targets and partner assignments. Inactive lines are no longer accepting new matters. Under review indicates strategic evaluation. Sunset indicates planned phase-out.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPositioning rdf:type rdf:Property ;
    rdfs:label 'Market Positioning' ;
    rdfs:comment 'The firms market positioning and competitive differentiation statement for this service line. Used in business development, RFP responses, and lateral partner recruitment.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCount rdf:type rdf:Property ;
    rdfs:label 'Partner Count' ;
    rdfs:comment 'The number of equity and non-equity partners primarily assigned to this service line. Used for RPE (Revenue Per Equity Partner) and PPP (Profit Per Partner) calculations.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:practiceAreaTaxonomy rdf:type rdf:Property ;
    rdfs:label 'Practice Area Taxonomy' ;
    rdfs:comment 'Comma-separated list or structured taxonomy of practice areas that roll up into this service line (e.g., M&A, Securities, Private Equity for Corporate Advisory service line). Used for matter classification and lateral hiring decisions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Allocation Percentage' ;
    rdfs:comment 'The target percentage of this service lines total hours to be allocated to pro bono work. Used for ABA pro bono reporting and associate development planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizationRateTarget rdf:type rdf:Property ;
    rdfs:label 'Realization Rate Target' ;
    rdfs:comment 'The target realization rate (percentage of standard rates actually collected) for this service line. Expressed as a percentage (e.g., 92.50 for 92.5%). Used for pricing strategy and partner performance evaluation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryOversightBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Body' ;
    rdfs:comment 'Primary regulatory or professional body governing the legal services provided by this service line (e.g., SEC for securities practice, USPTO for patent prosecution, State Bar for general practice). Used for compliance tracking and CPD planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAnnual rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Annual' ;
    rdfs:comment 'The annual revenue target (in firm base currency) set for this service line during strategic planning. Used for partner compensation, performance evaluation, and resource allocation decisions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Level' ;
    rdfs:comment 'The firms strategic investment priority for this service line. Tier 1 = high growth investment. Tier 2 = selective growth. Tier 3 = maintain current scale. Maintain = stable revenue focus. Divest = planned wind-down or sale.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatformPrimary rdf:type rdf:Property ;
    rdfs:label 'Technology Platform Primary' ;
    rdfs:comment 'The primary technology platform or specialized software used by this service line (e.g., Relativity for eDiscovery, LexisNexis for legal research, Thomson Reuters for transactional work). Used for IT budgeting and training planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'Percentage of service delivery cost allocated to this specific delivery model when multiple models are used for the same service. Used in financial planning and client billing allocation.' ;
    rdfs:domain ind:DeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this service-delivery configuration was first created in the system.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp of the most recent modification to this service-delivery configuration record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this delivery model is the preferred or recommended approach for delivering this specific service. Used in RFP responses and capacity planning to prioritize delivery model selection.' ;
    rdfs:domain ind:DeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaOverride rdf:type rdf:Property ;
    rdfs:label 'Sla Override' ;
    rdfs:comment 'Service Level Agreement override or adjustment specific to this service-delivery model combination. Captures deviations from standard SLAs defined in either the service or delivery model when this specific pairing requires different commitments.' ;
    rdfs:domain ind:DeliveryConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timekeeperId rdf:type rdf:Property ;
    rdfs:label 'Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this delivery model record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:applicablePracticeAreas rdf:type rdf:Property ;
    rdfs:label 'Applicable Practice Areas' ;
    rdfs:comment 'Comma-separated list of legal practice areas for which this delivery model is suitable (e.g., M&A, Litigation, IP Prosecution, Regulatory Compliance, Employment Law).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of service type codes or names that can be delivered using this model (e.g., advisory, transactional, dispute_resolution, compliance_counseling).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Level of authority required to approve use of this delivery model for a new engagement: partner (individual partner discretion), practice_group_head (practice leader approval), managing_partner (firm leadership approval), executive_committee (board-level approval).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Pct' ;
    rdfs:comment 'Target utilization rate (percentage of billable hours to total available hours) for resources operating under this delivery model, used for capacity planning and profitability analysis.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientInteractionModel rdf:type rdf:Property ;
    rdfs:label 'Client Interaction Model' ;
    rdfs:comment 'Level and frequency of direct client engagement: high_touch (frequent partner/senior attorney interaction), medium_touch (periodic check-ins), low_touch (minimal direct contact), self_service (client portal-driven), or hybrid (varies by phase).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Required' ;
    rdfs:comment 'Indicates whether formal conflict checking is mandatory before engaging this delivery model (True for traditional attorney-led models, may be False for certain ALSP or administrative services).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costStructureBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Structure Basis' ;
    rdfs:comment 'Primary pricing and cost structure associated with this delivery model: hourly_rate (traditional billable hour), fixed_fee (project-based), capped_fee (not-to-exceed), contingency (success-based), retainer (ongoing access), subscription (periodic flat fee), outcome_based (performance-linked), or blended_rate (averaged hourly rate across team). [ENUM-REF-CANDIDATE: hourly_rate|fixed_fee|capped_fee|contingency|retainer|subscription|outcome_based|blended_rate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSecurityTier rdf:type rdf:Property ;
    rdfs:label 'Data Security Tier' ;
    rdfs:comment 'Level of data security and confidentiality controls applied to this delivery model: standard (baseline firm security), enhanced (additional encryption and access controls), maximum (air-gapped or highly restricted), client_specific (bespoke security per client requirements).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModelDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Description' ;
    rdfs:comment 'Detailed narrative description of the delivery model, including operational characteristics, typical use cases, and distinguishing features.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModelStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Model Status' ;
    rdfs:comment 'Current lifecycle status of the delivery model: active (in production use), inactive (temporarily suspended), pilot (under trial), deprecated (phasing out), retired (no longer offered).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalWallSupport rdf:type rdf:Property ;
    rdfs:label 'Ethical Wall Support' ;
    rdfs:comment 'Indicates whether this delivery model supports the establishment of ethical walls (information barriers) to manage conflicts of interest (True for models with segregated teams, False for fully integrated teams).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteRequirementMax rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement Max' ;
    rdfs:comment 'Maximum number of full-time equivalent staff typically allocated to this delivery model for scalability planning.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteRequirementMin rdf:type rdf:Property ;
    rdfs:label 'Fte Requirement Min' ;
    rdfs:comment 'Minimum number of full-time equivalent staff required to operate this delivery model effectively for a typical engagement.' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationMaturity rdf:type rdf:Property ;
    rdfs:label 'Innovation Maturity' ;
    rdfs:comment 'Maturity level of innovation and technology adoption in this delivery model: traditional (established methods), emerging (adopting new tools), innovative (leading-edge practices), cutting_edge (experimental or pioneering approaches).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the delivery model for business reference and system integration (e.g., TRAD_PARTNER, ALSP_HYBRID, MLS_ONSITE).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Full business name of the delivery model (e.g., Traditional Partner-Led Team, Alternative Legal Service Provider (ALSP) Co-Delivery, Managed Legal Services).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Primary classification of the delivery model: traditional (partner-led attorney teams), ALSP (Alternative Legal Service Provider co-delivery), MLS (Managed Legal Services), LPO (Legal Process Outsourcing), secondment (client-embedded counsel), or hybrid (combination of multiple models).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMatterSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Matter Size' ;
    rdfs:comment 'Optimal matter or engagement size for which this delivery model is best suited: small (low-value, short-duration), medium (moderate complexity and duration), large (high-value, extended engagement), enterprise (multi-year, strategic), or any (flexible across all sizes).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeliveryGeography rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic location from which services are delivered (e.g., USA, GBR, IND for offshore centers).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceApproach rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Approach' ;
    rdfs:comment 'Primary quality control mechanism for work delivered under this model: partner_review (senior attorney sign-off), peer_review (colleague validation), automated_qa (technology-driven checks), external_audit (third-party review), iso_certified (ISO 9001 quality management), or none (no formal QA).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Scope' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks and compliance requirements applicable to this delivery model (e.g., GDPR, CCPA, SOX, AML, Legal Professional Privilege (LPP), Solicitors Regulation Authority (SRA) standards).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceComposition rdf:type rdf:Property ;
    rdfs:label 'Resource Composition' ;
    rdfs:comment 'Textual description of the typical team composition, including ratios of partners, associates, paralegals, legal technologists, and support staff (e.g., 1 partner : 3 associates : 2 paralegals).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scalabilityRating rdf:type rdf:Property ;
    rdfs:label 'Scalability Rating' ;
    rdfs:comment 'Assessment of how easily this delivery model can scale up or down to meet fluctuating demand: low (fixed team, limited flexibility), medium (moderate scaling with lead time), high (rapid scaling capability), elastic (on-demand scaling with minimal lead time).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryDeliveryGeography rdf:type rdf:Property ;
    rdfs:label 'Secondary Delivery Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for secondary or backup delivery location, if applicable (e.g., nearshore support center).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Standard response time commitment in hours for client inquiries under this delivery model, as defined in typical Service Level Agreements (SLAs).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTurnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Time Days' ;
    rdfs:comment 'Standard turnaround time commitment in business days for deliverable completion under this delivery model, as defined in typical Service Level Agreements (SLAs).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffingModel rdf:type rdf:Property ;
    rdfs:label 'Staffing Model' ;
    rdfs:comment 'Defines the primary resource composition and leadership structure: partner-led (senior attorney oversight), associate-led (mid-level attorney execution), paralegal-led (support-staff driven), mixed-tier (blended seniority), offshore/nearshore/onshore (geographic staffing), or client-site (embedded at client location). [ENUM-REF-CANDIDATE: partner_led|associate_led|paralegal_led|mixed_tier|offshore|nearshore|onshore|client_site — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyEnablement rdf:type rdf:Property ;
    rdfs:label 'Technology Enablement' ;
    rdfs:comment 'Degree of technology integration in the delivery model: manual (minimal tech), standard_tools (DMS and research platforms), advanced_automation (workflow automation and RPA), ai_assisted (AI/ML for document review, contract analysis), or full_digital (end-to-end digital delivery).' ;
    rdfs:domain ind:DeliveryModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Scope Amendment Id' ;
    rdfs:comment 'Unique identifier for the service scope amendment record. Primary key.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Amendment Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this amendment record.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryScopeClientContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Scope Client Contact Id' ;
    rdfs:comment 'Reference to the contact (client or internal) who initiated or requested the scope amendment.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:scopeModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Scope Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this amendment record.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:supersededByScopeAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Scope Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment. Null if this is the current active amendment.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScopeAmendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative describing the changes being made to the engagement scope, including business rationale and impact summary.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Document Reference' ;
    rdfs:comment 'Reference identifier or Document Management System (DMS) path to the formal amendment document or Letter of Engagement (LOE) addendum.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment, typically sequential within a matter or engagement (e.g., AMD-001, AMD-002).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary business reason for the amendment: scope creep (unplanned work expansion), client request (client-initiated change), regulatory change (compliance-driven), cost overrun (budget exceeded), timeline extension (schedule change), or service upgrade (enhanced service level).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment: draft (being prepared), pending approval (awaiting client or partner sign-off), approved (authorized but not yet executed), rejected (declined), executed (in force), or superseded (replaced by a later amendment).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the nature of the scope amendment: scope expansion (additional work added), scope reduction (work removed), fee renegotiation (pricing changes), SLA modification (service level changes), AFA restructuring (Alternative Fee Arrangement changes), or service addition (new service lines added).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Billing Impact Notes' ;
    rdfs:comment 'Detailed notes on how this amendment affects billing arrangements, including changes to billing frequency, payment terms, or invoicing procedures.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Client Approval Date' ;
    rdfs:comment 'Date on which the client formally approved the scope amendment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the amendment was formally executed and became binding, typically when all parties have signed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Amount' ;
    rdfs:comment 'Monetary value of the fee change resulting from this amendment. Positive for increases, negative for decreases, zero for no change.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAdjustmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fee adjustment amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeImpactType rdf:type rdf:Property ;
    rdfs:label 'Fee Impact Type' ;
    rdfs:comment 'Classification of how the amendment affects fees: increase (higher fees), decrease (lower fees), no change (scope change without fee impact), or restructure (fee model changed).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityExposureImpact rdf:type rdf:Property ;
    rdfs:label 'Indemnity Exposure Impact' ;
    rdfs:comment 'Assessment of how this amendment affects the firms professional indemnity insurance exposure: increased (higher risk), decreased (lower risk), unchanged (no material impact), or under review (being assessed).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScopeReference rdf:type rdf:Property ;
    rdfs:label 'Original Scope Reference' ;
    rdfs:comment 'Reference identifier or clause number from the original Letter of Engagement (LOE) or engagement scope document that is being amended.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date on which the scope amendment was formally requested.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedByParty rdf:type rdf:Property ;
    rdfs:label 'Requested By Party' ;
    rdfs:comment 'Indicates which party initiated the amendment request: client (client-driven), firm (law firm-driven), or mutual (jointly agreed).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedFeeArrangementType rdf:type rdf:Property ;
    rdfs:label 'Revised Fee Arrangement Type' ;
    rdfs:comment 'The fee arrangement model after this amendment: hourly (time-based), fixed fee (flat rate), contingency (outcome-based), capped fee (not-to-exceed), blended rate (averaged hourly), success fee (performance bonus), or retainer (ongoing engagement). [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|capped_fee|blended_rate|success_fee|retainer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedSlaTerms rdf:type rdf:Property ;
    rdfs:label 'Revised Sla Terms' ;
    rdfs:comment 'Description of the modified SLA terms, including response times, deliverable deadlines, and performance commitments.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Notes' ;
    rdfs:comment 'Internal notes documenting risk considerations, conflict implications, and professional responsibility issues arising from the scope amendment.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Change Summary' ;
    rdfs:comment 'Concise summary of the specific scope changes, including work added, removed, or modified.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Change Indicator' ;
    rdfs:comment 'Flag indicating whether this amendment includes changes to Service Level Agreement (SLA) terms (True) or not (False).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wipAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Adjustment Amount' ;
    rdfs:comment 'Monetary value of Work in Progress (WIP) adjustments resulting from this amendment (write-offs, re-ratings, or accruals).' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Wip Impact Assessment' ;
    rdfs:comment 'Assessment of how this amendment affects existing Work in Progress (WIP), including whether unbilled time will be written off, re-rated, or carried forward under new terms.' ;
    rdfs:domain ind:ScopeAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCoverageId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Coverage Id' ;
    rdfs:comment 'Unique identifier for the jurisdiction coverage record. Primary key.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key to matter.jurisdiction.jurisdiction_id' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:admissionRequired rdf:type rdf:Property ;
    rdfs:label 'Admission Required' ;
    rdfs:comment 'Indicates whether formal admission or bar membership is required to practice in this jurisdiction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admissionRequirements rdf:type rdf:Property ;
    rdfs:label 'Admission Requirements' ;
    rdfs:comment 'Detailed description of admission or licensing requirements for practicing in this jurisdiction (e.g., bar exam, character and fitness review, Continuing Legal Education requirements).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adrServicesAvailable rdf:type rdf:Property ;
    rdfs:label 'Adr Services Available' ;
    rdfs:comment 'Indicates whether Alternative Dispute Resolution services (arbitration, mediation, conciliation) are available in this jurisdiction.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlKycComplianceAvailable rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Compliance Available' ;
    rdfs:comment 'Indicates whether AML and KYC compliance counseling services are available in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckScope rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Scope' ;
    rdfs:comment 'Indicates the scope of conflict checking required for this jurisdiction coverage: full (comprehensive conflict check required), limited (partial check), or excluded (no conflict check needed).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the jurisdiction (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Court Access Level' ;
    rdfs:comment 'Level of court access available in this jurisdiction: full (can appear in all courts), limited (specific courts only), none (no court appearances), advisory_only (counsel only, no litigation).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageNotes rdf:type rdf:Property ;
    rdfs:label 'Coverage Notes' ;
    rdfs:comment 'Additional notes, comments, or guidance regarding service coverage in this jurisdiction, including special considerations, recent regulatory changes, or operational caveats.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of service coverage in this jurisdiction. Active indicates full service availability; restricted indicates limited scope; suspended indicates temporary unavailability.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Scope' ;
    rdfs:comment 'Description of data privacy and protection compliance counseling available in this jurisdiction (e.g., GDPR, CCPA, DPA, sector-specific privacy laws).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecfAccess rdf:type rdf:Property ;
    rdfs:label 'Ecf Access' ;
    rdfs:comment 'Indicates whether the firm has Electronic Case Filing access in this jurisdiction for federal or state court filings.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalArbitrationVenue rdf:type rdf:Property ;
    rdfs:label 'International Arbitration Venue' ;
    rdfs:comment 'Indicates whether this jurisdiction is recognized as an international arbitration venue under ICC, LCIA, or other international arbitration frameworks.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipPortfolioManagementAvailable rdf:type rdf:Property ;
    rdfs:label 'Ip Portfolio Management Available' ;
    rdfs:comment 'Indicates whether IP portfolio management services (patent, trademark, copyright prosecution and maintenance) are available in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Jurisdictional Restrictions' ;
    rdfs:comment 'Detailed description of any restrictions, caveats, or limitations on service delivery in this jurisdiction (e.g., cannot appear in court, advisory only, regulatory compliance counseling excluded).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which legal services must or can be delivered in this jurisdiction (e.g., English, French, Spanish). Relevant for multi-lingual jurisdictions or international matters.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCounselNotes rdf:type rdf:Property ;
    rdfs:label 'Local Counsel Notes' ;
    rdfs:comment 'Additional notes or guidance on local counsel requirements, including circumstances when local counsel may be waived or specific qualifications needed.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCounselRequired rdf:type rdf:Property ;
    rdfs:label 'Local Counsel Required' ;
    rdfs:comment 'Indicates whether local counsel must be engaged for matters in this jurisdiction when the primary attorney is not admitted.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matterStaffingPriority rdf:type rdf:Property ;
    rdfs:label 'Matter Staffing Priority' ;
    rdfs:comment 'Priority ranking for staffing matters in this jurisdiction (1 = highest priority, higher numbers = lower priority). Used for multi-jurisdictional matter staffing decisions.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiJurisdictionalFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Jurisdictional Flag' ;
    rdfs:comment 'Indicates whether this coverage is part of a multi-jurisdictional service offering spanning multiple states, provinces, or countries.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacerAccess rdf:type rdf:Property ;
    rdfs:label 'Pacer Access' ;
    rdfs:comment 'Indicates whether the firm has PACER access for retrieving court records in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentBarRequired rdf:type rdf:Property ;
    rdfs:label 'Patent Bar Required' ;
    rdfs:comment 'Indicates whether patent bar admission (USPTO registration for patent prosecution) is required for IP services in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceAreaRestrictions rdf:type rdf:Property ;
    rdfs:label 'Practice Area Restrictions' ;
    rdfs:comment 'Description of any practice area limitations or restrictions in this jurisdiction (e.g., certain IP matters require patent bar admission, criminal defense requires state bar membership).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proHacViceAvailable rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Available' ;
    rdfs:comment 'Indicates whether pro hac vice admission (temporary admission for a specific case) is available in this jurisdiction for attorneys not admitted to the local bar.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proHacViceRequirements rdf:type rdf:Property ;
    rdfs:label 'Pro Hac Vice Requirements' ;
    rdfs:comment 'Description of requirements and procedures for obtaining pro hac vice admission in this jurisdiction (e.g., motion filing, local counsel sponsorship, fee payment).' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpEligible rdf:type rdf:Property ;
    rdfs:label 'Rfp Eligible' ;
    rdfs:comment 'Indicates whether this jurisdiction coverage qualifies the firm to respond to RFPs requiring service delivery in this jurisdiction.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Standard code for the state or province within the country (e.g., NY, CA, ON). Null for country-level or international jurisdictions.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Identifier of the user or system that last updated this jurisdiction coverage record.' ;
    rdfs:domain ind:JurisdictionCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringVersionId rdf:type rdf:Property ;
    rdfs:label 'Offering Version Id' ;
    rdfs:comment 'Unique identifier for this version of the service offering. Primary key for the service offering version record.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferingVersion .

ind:offeringCreatedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Offering Created By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this service offering version record. Links to workforce/user master data for audit purposes.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:offeringLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Offering Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who last modified this service offering version record. Links to workforce/user master data for audit purposes.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:supersededOfferingVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Offering Version Id' ;
    rdfs:comment 'Reference to the previous service offering version that this version replaces. Nullable for initial versions. Enables version lineage tracking.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferingVersion .

ind:versionOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Version Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner or senior lawyer who approved this service offering version for use. Links to workforce/partner master data.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:activeMattersCount rdf:type rdf:Property ;
    rdfs:label 'Active Matters Count' ;
    rdfs:comment 'Current count of active matters using this service offering version. Supports impact analysis for version deprecation decisions.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveFlag rdf:type rdf:Property ;
    rdfs:label 'Archive Flag' ;
    rdfs:comment 'Indicates whether this service offering version has been archived and is no longer available for selection in operational systems, while retained for historical audit and compliance review.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating why this new version was created. Supports audit trail and version history analysis. [ENUM-REF-CANDIDATE: initial|pricing_update|scope_expansion|scope_reduction|regulatory_change|market_adjustment|client_feedback|quality_improvement|error_correction — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed explanation of the business rationale and specific changes made in this version compared to the previous version.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesList rdf:type rdf:Property ;
    rdfs:label 'Deliverables List' ;
    rdfs:comment 'Structured list or description of tangible outputs and work products included in this service offering (e.g., opinion letters, drafted agreements, research memoranda, court filings).' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementLetterTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Engagement Letter Template Reference' ;
    rdfs:comment 'Reference to the standard Letter of Engagement (LOE) template document that should be used when this service offering is sold.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHoursMax rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours Max' ;
    rdfs:comment 'Maximum estimated hours required to deliver this service. Provides upper bound for resource allocation and budget planning.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedHoursMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours Min' ;
    rdfs:comment 'Minimum estimated hours required to deliver this service. Used for scoping, resource planning, and client expectation setting.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionsDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusions Description' ;
    rdfs:comment 'Explicit statement of what is NOT included in this service offering version. Clarifies scope boundaries and manages client expectations.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisitesDescription rdf:type rdf:Property ;
    rdfs:label 'Prerequisites Description' ;
    rdfs:comment 'Required conditions, client inputs, or prior steps that must be satisfied before this service can be delivered (e.g., completed conflict check, signed engagement letter, provided documents).' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Fee structure methodology for this service version. Includes traditional hourly billing, Alternative Fee Arrangement (AFA) models, and hybrid approaches. [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|retainer|afa_capped|afa_blended|afa_success|value_based|hybrid — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standard rate amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Documentation of how this service version complies with applicable regulatory requirements, bar association rules, and professional conduct standards.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Rfp Template Reference' ;
    rdfs:comment 'Reference to standard Request for Proposal (RFP) response templates or proposal documents associated with this service offering version.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Comprehensive textual description of what is included in this service offering version. Details deliverables, activities, and boundaries of the service.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Days' ;
    rdfs:comment 'Committed delivery timeframe in days for completion of standard service deliverables. Part of the Service Level Agreement (SLA) terms.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Terms Description' ;
    rdfs:comment 'Detailed textual description of all Service Level Agreement (SLA) commitments, performance metrics, and remedies for this service version.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRateAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Rate Amount' ;
    rdfs:comment 'Base rate or fee amount for this service version in the firms standard currency. For hourly models, represents the standard hourly rate; for fixed-fee models, represents the package price.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetClientSegment rdf:type rdf:Property ;
    rdfs:label 'Target Client Segment' ;
    rdfs:comment 'Intended client profile or market segment for this service offering (e.g., Fortune 500 Corporates, Mid-Market Private Equity, Government Entities, Individual High Net Worth).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Business-friendly name or label for this version (e.g., Standard M&A Package 2024, Enhanced IP Counsel Q1). Used in client-facing documents and internal communications.' ;
    rdfs:domain ind:OfferingVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this service offering version. Tracks progression from draft through approval to active use and eventual retirement. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|deprecated|retired|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterServiceMappingId rdf:type rdf:Property ;
    rdfs:label 'Matter Service Mapping Id' ;
    rdfs:comment 'Unique identifier for the matter-service mapping record. Primary key.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceId rdf:type rdf:Property ;
    rdfs:label 'Clearance Id' ;
    rdfs:comment 'Identifier of the conflict clearance record that authorized this service engagement, ensuring ethical compliance.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:mappingOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Mapping Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this service mapping record.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Identifier of the bundled service package (if applicable) that groups multiple legal services for this matter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:primaryMatterApprovedByTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Matter Approved By Timekeeper Id' ;
    rdfs:comment 'Identifier of the timekeeper (partner or senior attorney) who approved this service mapping.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryPricingModelId rdf:type rdf:Property ;
    rdfs:label 'Primary Pricing Model Id' ;
    rdfs:comment 'FK to service.pricing_model.pricing_model_id — The mapping must capture which pricing model applies to this specific matter-service combination, as it may differ from the service default due to negotiation.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingModel .

ind:primarySlaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Primary Sla Template Id' ;
    rdfs:comment 'FK to service.sla_template.sla_template_id — Each matter-service mapping must reference the SLA template in effect for that engagement, enabling SLA monitoring and breach detection.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTemplate .

ind:tertiaryMatterLeadAssociateTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Matter Lead Associate Timekeeper Id' ;
    rdfs:comment 'Identifier of the lead associate assigned to execute the service work for this matter.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to service.service_tier. Business justification: Matter service mappings reference a service tier. Normalize by linking to service_tier master. The service_tier STRING column is a code/name reference.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The number of post-opening amendments made to this service mapping. Tracks scope changes and service adjustments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The budgeted amount allocated for this service on this matter. Used for cost tracking and variance analysis.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Estimated total hours required to deliver this service for the matter. Used for resource planning and capacity management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryService rdf:type rdf:Property ;
    rdfs:label 'Is Primary Service' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary service for the matter (true) or a secondary/ancillary service (false).' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment to this service mapping. Null if no amendments have been made.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matterPricingModelFk rdf:type rdf:Property ;
    rdfs:label 'Matter Pricing Model Fk' ;
    rdfs:comment 'FK to service.pricing_model.pricing_model_id — Each matter-service mapping records the agreed pricing model for that engagement. Required for billing code alignment and WIP calculation.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matterSlaTemplateFk rdf:type rdf:Property ;
    rdfs:label 'Matter Sla Template Fk' ;
    rdfs:comment 'FK to service.sla_template.sla_template_id — Each matter-service mapping references the active SLA template governing service delivery commitments for that engagement.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Service Completion Date' ;
    rdfs:comment 'The date on which service delivery was completed for this mapping. Null if service is ongoing.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'The actual date on which service delivery commenced for this mapping. May differ from effective_start_date.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'The tier of service delivery (standard, premium, enterprise, custom) indicating the level of resource allocation and priority.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierFk rdf:type rdf:Property ;
    rdfs:label 'Service Tier Fk' ;
    rdfs:comment 'FK to service.service_tier.service_tier_id — The mapping records which service tier was agreed for the engagement, determining scope and pricing.' ;
    rdfs:domain ind:MatterServiceMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utbmsActivityCode rdf:type rdf:Property ;
    rdfs:label 'Utbms Activity Code' ;
    rdfs:comment 'UTBMS activity code aligned to this service mapping for granular work activity classification per LEDES standards.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Sla Template Id' ;
    rdfs:comment 'Unique identifier for the SLA template. Primary key.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityCommitment rdf:type rdf:Property ;
    rdfs:label 'Availability Commitment' ;
    rdfs:comment 'Timekeeper availability commitment specified in the SLA (e.g., 24/7 emergency access, business hours only, named partner availability).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Historical count of SLA breaches across all matters using this template, used for template refinement and risk assessment.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Percentage' ;
    rdfs:comment 'Percentage threshold over target time that constitutes an SLA breach (e.g., 110.00 means 10% over target triggers breach).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientTier rdf:type rdf:Property ;
    rdfs:label 'Client Tier' ;
    rdfs:comment 'Client segmentation tier for which this SLA template is designed, reflecting service level differentiation in client relationship management.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Specified communication channels and protocols for SLA-governed matters (e.g., email, secure portal, phone, video conference, encrypted messaging).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Threshold value (in same unit as response/turnaround time) at which SLA breach triggers escalation to senior counsel or practice group leader.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationUnit rdf:type rdf:Property ;
    rdfs:label 'Escalation Unit' ;
    rdfs:comment 'Unit of measure for escalation threshold: hours, business days, or calendar days.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which this SLA template expires or is superseded by a newer version. Null indicates no expiration.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Percentage' ;
    rdfs:comment 'Percentage fee adjustment (reduction or credit) applied upon SLA breach as specified in remediation terms.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matterComplexity rdf:type rdf:Property ;
    rdfs:label 'Matter Complexity' ;
    rdfs:comment 'Target matter complexity level for which this SLA template is appropriate, enabling proper SLA-to-matter matching.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this SLA template record.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Description of the quality standards and deliverable expectations associated with this SLA template (e.g., peer review required, cite-checking standards, document formatting requirements).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this SLA template includes specific regulatory compliance commitments (e.g., GDPR response times, SOX filing deadlines, CCPA data subject request turnaround).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationTerms rdf:type rdf:Property ;
    rdfs:label 'Remediation Terms' ;
    rdfs:comment 'Contractual remediation terms and client remedies in the event of SLA breach (e.g., fee reduction, credit, expedited service on next matter).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Response Time Target' ;
    rdfs:comment 'Target response time commitment in the unit specified by response_time_unit (e.g., 24 hours for initial client inquiry response).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeUnit rdf:type rdf:Property ;
    rdfs:label 'Response Time Unit' ;
    rdfs:comment 'Unit of measure for response time target: hours, business days, or calendar days.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA template by commitment category: matter response time, document turnaround, court filing deadline adherence, regulatory submission timeliness, client communication response, or legal research delivery.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Target' ;
    rdfs:comment 'Target turnaround time for deliverable completion in the unit specified by turnaround_time_unit (e.g., 5 business days for contract review).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeUnit rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Unit' ;
    rdfs:comment 'Unit of measure for turnaround time target: hours, business days, calendar days, or weeks.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Package Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Reference to the user who most recently modified this service package record.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:packageOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Package Owner Timekeeper Id' ;
    rdfs:comment 'Reference to the user who created this service package record in the system.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primaryPackageApprovedByPartnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Primary Package Approved By Partner Timekeeper Id' ;
    rdfs:comment 'Reference to the partner who provided final approval for this service package to be offered to clients.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:primarySupersededByPackageId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Package Id' ;
    rdfs:comment 'Reference to the newer service package that replaces this one, enabling version lineage tracking and client migration paths.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the service package is currently active and available for new client engagements. True = active and available.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when this service package received final approval and became available for client engagements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:averageEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Average Engagement Value' ;
    rdfs:comment 'Average revenue per engagement for this service package calculated from historical billing data. Used for forecasting and business development.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'Standard base price for the service package before any client-specific adjustments or discounts. Used as starting point for pricing negotiations.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossSellEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Eligible Flag' ;
    rdfs:comment 'Indicates whether this package is eligible for cross-selling to existing clients with other active engagements. True = eligible for cross-sell campaigns.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentManagementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Document Management Required Flag' ;
    rdfs:comment 'Indicates whether this package requires use of firm DMS (iManage Work or NetDocuments) for document storage, version control, and collaboration.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesEdiscoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Includes Ediscovery Flag' ;
    rdfs:comment 'Indicates whether the package includes electronic discovery services using platforms such as Relativity for document review and production.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesLegalResearchFlag rdf:type rdf:Property ;
    rdfs:label 'Includes Legal Research Flag' ;
    rdfs:comment 'Indicates whether the package includes access to legal research platforms such as LexisNexis or Thomson Reuters Practical Law.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCoverage rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Coverage' ;
    rdfs:comment 'Comma-separated list of jurisdictions or countries where this package can be delivered based on firm licensing and practice rights (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCollateralUrl rdf:type rdf:Property ;
    rdfs:label 'Marketing Collateral Url' ;
    rdfs:comment 'URL or document path to client-facing marketing materials, brochures, or pitch decks for this service package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEngagementTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Engagement Term Months' ;
    rdfs:comment 'Minimum commitment period in months required for this package. Null indicates no minimum term requirement.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known unique business identifier for the service package used in RFP responses, client proposals, and billing systems.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed description of the service package scope, objectives, and value proposition for client-facing materials and internal knowledge management.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the service package (e.g., Corporate Governance Bundle, M&A Full-Service Package, IP Portfolio Management Suite).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the service package structure determining engagement model and delivery approach.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model for the package. AFA = Alternative Fee Arrangement. Determines how the package is billed to clients.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresConflictCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Conflict Check Flag' ;
    rdfs:comment 'Indicates whether engagement under this package mandates formal conflict checking through Intapp Conflicts or equivalent system before matter intake.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresKycFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc Flag' ;
    rdfs:comment 'Indicates whether this package requires formal KYC and AML compliance checks before engagement commencement per regulatory obligations.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Days' ;
    rdfs:comment 'Target resolution time in business days for standard matters covered by this package under SLA commitments.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEngagementsCount rdf:type rdf:Property ;
    rdfs:label 'Total Engagements Count' ;
    rdfs:comment 'Cumulative count of client engagements or matters that have utilized this service package since inception. Used for performance tracking.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to client.client_segment. Business justification: Service tiers explicitly target client segments (premium tier for top-tier clients, standard for mid-market). Tier eligibility, SLA commitments, and pricing are segment-driven. Removes denormalized cl' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:afaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Afa Eligible Flag' ;
    rdfs:comment 'Indicates whether this tier is eligible for Alternative Fee Arrangements (AFA) such as fixed fees, capped fees, or success-based pricing. True if AFA options are available; False if only hourly billing applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afaModelsSupported rdf:type rdf:Property ;
    rdfs:label 'Afa Models Supported' ;
    rdfs:comment 'Comma-separated list of AFA models supported for this tier (e.g., Fixed Fee, Capped Fee, Blended Rate, Success Fee, Retainer). Used in pricing discussions and engagement structuring.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByPartner rdf:type rdf:Property ;
    rdfs:label 'Approved By Partner' ;
    rdfs:comment 'Name or identifier of the partner who approved this service tier configuration. Used for governance and accountability.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Base Hourly Rate' ;
    rdfs:comment 'Standard hourly billing rate for this tier in the firms base currency. Used as the starting point for rate negotiations and engagement pricing. May vary by timekeeper seniority within the tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Level' ;
    rdfs:comment 'Level of conflict checking required for engagements under this tier (standard, enhanced, comprehensive). Higher tiers may require more rigorous conflict analysis and ethical wall procedures.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionClassification rdf:type rdf:Property ;
    rdfs:label 'Data Protection Classification' ;
    rdfs:comment 'Data protection and confidentiality classification level for matters under this tier (standard, confidential, highly_confidential). Determines document handling, access controls, and encryption requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Document Retention Years' ;
    rdfs:comment 'Minimum document retention period in years for matters under this tier, as required by regulatory obligations and professional standards. Used in records management and DMS configuration.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedDeliverables rdf:type rdf:Property ;
    rdfs:label 'Included Deliverables' ;
    rdfs:comment 'Comma-separated or structured list of standard deliverables included in the tier (e.g., legal opinions, memoranda, contract drafts, compliance checklists). Used in RFP responses and engagement scoping.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycAmlLevel rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Level' ;
    rdfs:comment 'Level of KYC and AML due diligence required for clients engaging under this tier (basic, standard, enhanced, high_risk). Higher tiers or higher-risk practice areas may require enhanced due diligence.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this service tier record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Engagement Value' ;
    rdfs:comment 'Maximum total engagement value or cap applicable to this tier (if any). Null for uncapped tiers. Used in pricing and risk management.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Engagement Value' ;
    rdfs:comment 'Minimum total engagement value or retainer amount required to qualify for this tier. Used in client segmentation and engagement acceptance decisions.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Approval Required Flag' ;
    rdfs:comment 'Indicates whether partner-level approval is required to assign a matter to this tier. True if approval is mandatory; False if associates or practice managers can assign. Used in engagement workflow and governance.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeCommitmentHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Commitment Hours' ;
    rdfs:comment 'Maximum response time commitment in hours for initial client inquiries or urgent requests under this tier. Forms part of the Service Level Agreement (SLA) terms.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeOfCoverage rdf:type rdf:Property ;
    rdfs:label 'Scope Of Coverage' ;
    rdfs:comment 'Detailed definition of the legal services and deliverables included in this tier (e.g., advisory opinions, document review, representation in proceedings, regulatory filings). Used to set client expectations and scope engagement letters (LOE).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Full text or reference to the Service Level Agreement (SLA) terms applicable to this tier, including response times, escalation procedures, and performance guarantees. Used in engagement letters (LOE) and client contracts.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the service tier (e.g., STD, PREM, ENT, BESPOKE). Used in system integrations and billing configurations.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the service tier, including scope of coverage, key differentiators, and target client segments. Used in business development materials and RFP responses.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Numeric ranking of the tier within the service hierarchy (e.g., 1=Standard, 2=Premium, 3=Enterprise, 4=Bespoke). Used for sorting and eligibility logic.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full business name of the service tier (e.g., Standard, Premium, Enterprise, Bespoke). Used in client-facing documents, RFPs, and engagement letters (LOE).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the service tier. Active tiers are available for new engagements; deprecated tiers are honored for existing matters but not offered to new clients.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelOwnerTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Model Owner Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who created this pricing model record.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:pricingLastModifiedByUserTimekeeperId rdf:type rdf:Property ;
    rdfs:label 'Pricing Last Modified By User Timekeeper Id' ;
    rdfs:comment 'Identifier of the user who last modified this pricing model record.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timekeeper .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Required advance payment or retainer deposit amount. Null if no advance payment is required.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentRequired rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Required' ;
    rdfs:comment 'Flag indicating whether an advance payment or retainer deposit is required before work commences under this pricing model. True = advance required; False = no advance.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afaIndicator rdf:type rdf:Property ;
    rdfs:label 'Afa Indicator' ;
    rdfs:comment 'Flag indicating whether this pricing model represents an Alternative Fee Arrangement (non-traditional hourly billing). True = AFA; False = traditional hourly.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdictions where this pricing model is approved for use (e.g., USA, GBR, CAN). Ensures compliance with local bar association fee rules.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether partner or management approval is required before applying this pricing model to a matter. True = approval required; False = no approval needed.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The standard rate amount for this pricing model. For hourly models, this is the hourly rate; for fixed fee, this is the base fee amount. Null if rate varies by timekeeper or matter.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingIncrementMinutes rdf:type rdf:Property ;
    rdfs:label 'Billing Increment Minutes' ;
    rdfs:comment 'Time increment used for rounding billable time entries (e.g., 6 minutes = 0.1 hour, 15 minutes = 0.25 hour). Common values: 6, 10, 15.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Amount' ;
    rdfs:comment 'Single averaged hourly rate applied across all timekeepers on a matter, regardless of individual seniority. Used in blended rate pricing models.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The foundational method used to calculate fees under this model. Time-based = hours worked; Matter-based = per matter/case; Transaction Value = percentage of deal value; Outcome-based = tied to result; Hybrid = combination of methods.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Expense Markup Percentage' ;
    rdfs:comment 'Percentage markup applied to reimbursable expenses (e.g., 10% administrative fee on disbursements). Null if no markup applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseReimbursementPolicy rdf:type rdf:Property ;
    rdfs:label 'Expense Reimbursement Policy' ;
    rdfs:comment 'Policy governing how disbursements and expenses are handled under this pricing model. Full = all expenses billed separately; Capped = expenses up to limit; Included = expenses absorbed in fee; No Reimbursement = client pays directly.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentInterestRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Interest Rate' ;
    rdfs:comment 'Annual interest rate applied to overdue invoices under this pricing model. Null if no late payment interest applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ledesFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Ledes Format Version' ;
    rdfs:comment 'LEDES billing format version supported by this pricing model (e.g., LEDES1998BI, LEDES1998BIV2). Ensures billing data compatibility with client systems.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Amount' ;
    rdfs:comment 'The maximum fee cap for capped fee arrangements. Fees will not exceed this amount regardless of time spent. Null if no cap applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'The minimum fee that will be charged under this pricing model, regardless of time or effort expended. Null if no minimum applies.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModelDescription rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Description' ;
    rdfs:comment 'Detailed description of the pricing model, including its intended use cases, calculation methodology, and any special terms or conditions.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Status' ;
    rdfs:comment 'Current lifecycle status of the pricing model. Active = in use; Inactive = not available for new matters; Draft = under development; Archived = historical; Under Review = pending approval; Approved = ready for activation.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainerFrequency rdf:type rdf:Property ;
    rdfs:label 'Retainer Frequency' ;
    rdfs:comment 'Billing frequency for retainer-based pricing models. Indicates how often the retainer fee is charged.' ;
    rdfs:domain ind:PricingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Unique identifier for the rate card record. Primary key.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Area Id' ;
    rdfs:comment 'FK to service.practice_area.practice_area_id — Rate cards are structured by practice area (litigation rates differ from corporate rates). This is a fundamental billing configuration relationship.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:supersededByRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Id' ;
    rdfs:comment 'Reference to the rate card that supersedes this one. Null if this is the current active rate card.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:billingGuidelineCompliant rdf:type rdf:Property ;
    rdfs:label 'Billing Guideline Compliant' ;
    rdfs:comment 'Boolean flag indicating whether this rate complies with the clients outside counsel billing guidelines (True = compliant, False = non-compliant or requires review).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'Classification of the client segment to which this rate applies (e.g., Fortune 500, mid-market, small business, government, non-profit, individual).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The billing rate per hour for the timekeepers services under this rate card. Used for time-based billing calculations in Elite 3E and Aderant Expert.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultRate rdf:type rdf:Property ;
    rdfs:label 'Is Default Rate' ;
    rdfs:comment 'Boolean flag indicating whether this is the default rate to be applied when no client-specific or matter-specific rate is defined (True = default, False = not default).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumChargeIncrementMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Increment Minutes' ;
    rdfs:comment 'Minimum time increment for billing purposes (e.g., 6 minutes for 0.1 hour increments, 15 minutes for 0.25 hour increments). Used in time entry rounding.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateCapAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Cap Amount' ;
    rdfs:comment 'Maximum hourly rate cap agreed with the client, regardless of timekeeper seniority or standard rate. Null if no cap applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Card Description' ;
    rdfs:comment 'Detailed description of the rate card, including its purpose, scope, and any special terms or conditions.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Descriptive name or label for this rate card (e.g., 2024 Standard Corporate Rates, Client XYZ Preferred Rates, Litigation Blended Rate).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Floor Amount' ;
    rdfs:comment 'Minimum hourly rate floor below which billing cannot fall. Null if no floor applies.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin or basis for this rate (firm_standard = firms published standard rates, client_negotiated = negotiated with client, engagement_letter = specified in Letter of Engagement (LOE), rfp_response = proposed in RFP response, afa_agreement = part of Alternative Fee Arrangement, market_benchmark = based on market survey).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the billing rate structure (standard = firm standard rate, preferred = client-specific preferred rate, blended = averaged rate across multiple timekeepers, discounted = reduced rate, negotiated = custom negotiated rate, afa = Alternative Fee Arrangement rate).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number of this rate card, incremented with each revision or update. Used for rate history tracking and audit purposes.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Seniority classification of the timekeeper (e.g., equity partner, non-equity partner, of counsel, senior associate, mid-level associate, junior associate, paralegal, legal assistant, contract attorney). [ENUM-REF-CANDIDATE: equity_partner|non_equity_partner|of_counsel|senior_associate|mid_level_associate|junior_associate|paralegal|legal_assistant|contract_attorney — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScaleId rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Id' ;
    rdfs:comment 'Primary key for rating_scale' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatingScale .

ind:primarySupersededRatingScaleId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded Rating Scale Id' ;
    rdfs:comment 'Self-referencing FK on rating_scale (superseded_rating_scale_id)' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatingScale .

ind:allowsDecimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Allows Decimal Precision' ;
    rdfs:comment 'Indicates whether the rating scale permits decimal precision beyond half-points (e.g., 3.75, 4.25). True if decimal precision is allowed, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsHalfPoints rdf:type rdf:Property ;
    rdfs:label 'Allows Half Points' ;
    rdfs:comment 'Indicates whether the rating scale permits half-point increments (e.g., 3.5 on a 1-5 scale). True if half-points are allowed, False if only whole numbers are permitted.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableToAttorneys rdf:type rdf:Property ;
    rdfs:label 'Applicable To Attorneys' ;
    rdfs:comment 'Indicates whether this rating scale is used for attorney performance evaluations, competency assessments, or partner reviews. True if applicable to attorneys, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableToPartners rdf:type rdf:Property ;
    rdfs:label 'Applicable To Partners' ;
    rdfs:comment 'Indicates whether this rating scale is used for equity partner, non-equity partner, or senior partner evaluations. True if applicable to partners, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableToStaff rdf:type rdf:Property ;
    rdfs:label 'Applicable To Staff' ;
    rdfs:comment 'Indicates whether this rating scale is used for non-attorney staff evaluations (paralegals, legal assistants, administrative staff). True if applicable to staff, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The organizational level required to approve ratings using this scale: none (no approval needed), manager (direct supervisor), practice_leader (practice group head), compensation_committee (firm compensation committee), managing_partner (firm managing partner).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentsRequired rdf:type rdf:Property ;
    rdfs:label 'Comments Required' ;
    rdfs:comment 'Indicates whether evaluators must provide written comments or justification when assigning ratings using this scale. True if comments are mandatory, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric value controlling the display order of this rating scale in user interfaces and selection lists. Lower numbers appear first.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCurveType rdf:type rdf:Property ;
    rdfs:label 'Distribution Curve Type' ;
    rdfs:comment 'The type of distribution curve applied when forced distribution is required: none (no forced distribution), bell_curve (normal distribution), top_grading (A/B/C player model), rank_and_yank (bottom percentage must be rated low).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excellenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Excellence Threshold' ;
    rdfs:comment 'The rating value at or above which performance is considered excellent or exceeds expectations. Used for identifying high performers and bonus eligibility.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'The unique identifier for this rating scale in the source system (e.g., SAP SuccessFactors rating scale ID). Used for system integration and data reconciliation.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forcedDistributionRequired rdf:type rdf:Property ;
    rdfs:label 'Forced Distribution Required' ;
    rdfs:comment 'Indicates whether this rating scale requires forced distribution (e.g., only 20% can receive the highest rating, 10% must be in the lowest tier). True if forced distribution applies, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incrementStep rdf:type rdf:Property ;
    rdfs:label 'Increment Step' ;
    rdfs:comment 'The numeric increment between valid rating values (e.g., 1.0 for integer scales, 0.5 for half-point scales, 0.1 for decimal scales).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultScale rdf:type rdf:Property ;
    rdfs:label 'Is Default Scale' ;
    rdfs:comment 'Indicates whether this is the default rating scale used when no specific scale is designated for a performance review or assessment. True if this is the default scale, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedToCompensation rdf:type rdf:Property ;
    rdfs:label 'Linked To Compensation' ;
    rdfs:comment 'Indicates whether ratings on this scale directly influence compensation decisions such as bonuses, salary increases, or profit-sharing distributions. True if linked to compensation, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedToPromotion rdf:type rdf:Property ;
    rdfs:label 'Linked To Promotion' ;
    rdfs:comment 'Indicates whether ratings on this scale are a factor in promotion decisions (e.g., associate to senior associate, counsel to partner). True if linked to promotion, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'The highest numeric value on the rating scale (e.g., 5 for a 1-5 scale, 100 for a 0-100 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midpointValue rdf:type rdf:Property ;
    rdfs:label 'Midpoint Value' ;
    rdfs:comment 'The midpoint or neutral value on the rating scale, often representing meets expectations or satisfactory performance.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'The lowest numeric value on the rating scale (e.g., 1 for a 1-5 scale, 0 for a 0-100 scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passingThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Threshold' ;
    rdfs:comment 'The minimum rating value required to be considered passing or acceptable performance. Used in competency assessments and mandatory training evaluations.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peerReviewAllowed rdf:type rdf:Property ;
    rdfs:label 'Peer Review Allowed' ;
    rdfs:comment 'Indicates whether this rating scale can be used for peer-to-peer evaluations (e.g., associate reviewing another associate, partner reviewing another partner). True if peer review is allowed, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCalibration rdf:type rdf:Property ;
    rdfs:label 'Requires Calibration' ;
    rdfs:comment 'Indicates whether ratings using this scale must go through a calibration process with peer review or management committee to ensure consistency across evaluators. True if calibration is required, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleCode rdf:type rdf:Property ;
    rdfs:label 'Scale Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the rating scale for system integration and reporting (e.g., PERF-5PT, COMP-10PT, PARTNER-EVAL).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleDescription rdf:type rdf:Property ;
    rdfs:label 'Scale Description' ;
    rdfs:comment 'Detailed business description of the rating scale, its purpose, and usage context within performance management, talent development, or compensation processes.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleDirection rdf:type rdf:Property ;
    rdfs:label 'Scale Direction' ;
    rdfs:comment 'Indicates whether higher values represent better performance (ascending) or lower values represent better performance (descending). Most legal industry scales are ascending.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleName rdf:type rdf:Property ;
    rdfs:label 'Scale Name' ;
    rdfs:comment 'The business name of the rating scale (e.g., Annual Performance Review Scale, Partner Evaluation Scale, Associate Competency Scale).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Categorical classification of the rating scale purpose: performance (annual reviews), competency (skill assessments), potential (succession planning), behavior (conduct evaluations), skill (technical proficiency), client_feedback (client satisfaction).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Allowed' ;
    rdfs:comment 'Indicates whether timekeepers can use this rating scale to perform self-assessments as part of the performance review process. True if self-assessment is allowed, False otherwise.' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Status' ;
    rdfs:comment 'Current lifecycle status of the rating scale: active (in use), inactive (temporarily suspended), draft (under development), retired (no longer used), under_review (being evaluated for changes).' ;
    rdfs:domain ind:RatingScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'The primary business context in which this rating scale is applied: annual_review (year-end performance), mid_year_review (interim check-in), probation_review (new hire evaluation), promotion_review (advancement consideration), compensation_review (bonus and salary decisions), succession_planning (leadership pipeline assessment).' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPracticeAreaId rdf:type rdf:Property ;
    rdfs:label 'Parent Practice Area Id' ;
    rdfs:comment 'Reference to the parent practice area in the hierarchical taxonomy, enabling roll-up reporting from sub-specializations to broader practice groups. Null for top-level practice areas.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeArea .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether time and disbursements in this practice area are typically billable to clients. False for internal practice areas such as professional development, pro bono coordination, or firm administration.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'High-level classification of the practice area by the nature of legal work performed. Transactional covers M&A (Mergers and Acquisitions), corporate deals; Advisory covers counseling and opinions; Litigation covers dispute resolution; Regulatory covers compliance and government relations; Hybrid covers mixed-mode practices; Specialized covers niche areas like IP (Intellectual Property) prosecution.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Cpd Requirement Hours' ;
    rdfs:comment 'Annual CPD (Continuing Professional Development) or CLE (Continuing Legal Education) hours required for timekeepers practicing in this area, as mandated by the governing regulatory body. Used for compliance tracking and training program planning.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultBillingArrangement rdf:type rdf:Property ;
    rdfs:label 'Default Billing Arrangement' ;
    rdfs:comment 'The most common fee arrangement type for matters in this practice area. Hourly for traditional time-based billing; Fixed Fee for scoped project work; Contingency for plaintiff litigation; AFA (Alternative Fee Arrangement) for value-based or risk-sharing models; Retainer for ongoing advisory; Capped Fee for budget-certainty arrangements; Blended Rate for team-based pricing; Success Fee for outcome-based compensation. [ENUM-REF-CANDIDATE: hourly|fixed_fee|contingency|afa|retainer|capped_fee|blended_rate|success_fee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Requirement' ;
    rdfs:comment 'Specific professional indemnity or malpractice insurance coverage requirements for this practice area, including minimum coverage amounts and specialized endorsements. Critical for high-risk areas like securities litigation, M&A (Mergers and Acquisitions), or medical malpractice defense.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeManagementCategory rdf:type rdf:Property ;
    rdfs:label 'Knowledge Management Category' ;
    rdfs:comment 'Classification used by the firms knowledge management system to organize precedents, practice notes, standard documents, and checklists for this practice area. Maps to DMS (Document Management System) taxonomy and knowledge repository structure.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Practice Area Description' ;
    rdfs:comment 'Detailed narrative describing the scope, services, and typical matters handled within this practice area. Used for RFP (Request for Proposal) responses, business development materials, and knowledge management.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaName rdf:type rdf:Property ;
    rdfs:label 'Practice Area Name' ;
    rdfs:comment 'Full business name of the practice area as recognized by clients and used in marketing materials, engagement letters, and matter classifications.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceAreaStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Area Status' ;
    rdfs:comment 'Current lifecycle status of the practice area. Active areas are available for new matter intake and timekeeper assignment. Inactive areas are no longer offered but may have legacy matters. Suspended areas are temporarily unavailable. Archived areas are historical records only.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceLine rdf:type rdf:Property ;
    rdfs:label 'Primary Service Line' ;
    rdfs:comment 'The primary revenue-generating service line or business unit to which this practice area contributes. Used for P&L (Profit and Loss) allocation, partner compensation, and strategic planning.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proBonoEligible rdf:type rdf:Property ;
    rdfs:label 'Pro Bono Eligible' ;
    rdfs:comment 'Indicates whether this practice area is commonly used for pro bono matters. True for areas like immigration, civil rights, family law; False for highly specialized commercial areas. Used for pro bono reporting and CLE (Continuing Legal Education) credit tracking.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBodyAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Alignment' ;
    rdfs:comment 'Primary regulatory or professional body whose standards, ethics rules, and CPD (Continuing Professional Development) requirements govern this practice area. Examples include ABA (American Bar Association), SRA (Solicitors Regulation Authority), IBA (International Bar Association), state bar associations, or specialized bodies like USPTO for IP (Intellectual Property) practice.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Indicates whether timekeepers working in this practice area typically require government or client security clearance due to the nature of matters (e.g., defense contracting, national security, classified government work).' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSpecialization rdf:type rdf:Property ;
    rdfs:label 'Requires Specialization' ;
    rdfs:comment 'Indicates whether this practice area requires specialized certification, licensing, or accreditation beyond general legal practice admission. True for areas like patent prosecution (USPTO registration), tax law (CPA or LLM), or admiralty law (specialized bar admission).' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the practice area used in internal reporting, dashboards, and space-constrained displays.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatformRequirement rdf:type rdf:Property ;
    rdfs:label 'Technology Platform Requirement' ;
    rdfs:comment 'Specialized technology platforms or tools typically required for matters in this practice area. Examples: Relativity for eDiscovery (Electronic Discovery) in litigation; LexisNexis for legal research; CLM (Contract Lifecycle Management) systems for transactional work; IP (Intellectual Property) docketing systems for patent prosecution.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalMatterDurationDays rdf:type rdf:Property ;
    rdfs:label 'Typical Matter Duration Days' ;
    rdfs:comment 'Average or median duration in days for matters in this practice area, from matter opening to closure. Used for resource planning, pipeline forecasting, and WIP (Work in Progress) aging analysis. Null for ongoing advisory relationships without defined end dates.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utbmsActivityCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Utbms Activity Code Prefix' ;
    rdfs:comment 'Standard UTBMS (Uniform Task-Based Management System) activity code prefix applicable to this practice area, providing granular activity-level coding for time entries and expense tracking in client billing.' ;
    rdfs:domain ind:PracticeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utbmsTaskCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Utbms Task Code Prefix' ;
    rdfs:comment 'Standard UTBMS (Uniform Task-Based Management System) task code prefix applicable to this practice area, enabling standardized time entry coding and client billing compliance. Examples: L for Litigation, C for Case Management, A for ADR (Alternative Dispute Resolution), T for Transactional.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowsAfa rdf:type rdf:Property ;
    rdfs:label 'Allows Afa' ;
    rdfs:comment 'Indicates whether this service offering is eligible for Alternative Fee Arrangement (AFA) pricing models including fixed fees, capped fees, success fees, or blended rates.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossSellServices rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Services' ;
    rdfs:comment 'Comma-separated list of related service codes that are commonly cross-sold or bundled with this offering. Used in business development, client relationship management, and revenue optimization.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableTypes rdf:type rdf:Property ;
    rdfs:label 'Deliverable Types' ;
    rdfs:comment 'Comma-separated list of typical deliverable types produced by this service. Examples include legal opinions, contracts, court filings, compliance reports, due diligence memoranda, or advisory presentations.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleClientSegments rdf:type rdf:Property ;
    rdfs:label 'Eligible Client Segments' ;
    rdfs:comment 'Comma-separated list of client segments or types eligible for this service offering. Used to filter service catalog visibility in business development and RFP response systems. [ENUM-REF-CANDIDATE: corporate|government|individual|nonprofit|startup|enterprise|sme — promote to reference product]' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Typical or average duration in hours required to deliver this service. Used for resource planning, capacity management, and client expectation setting in engagement letters.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required' ;
    rdfs:comment 'Indicates whether specialized professional indemnity insurance coverage is required for this service offering beyond standard firm coverage. Relevant for high-risk or specialized services.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this service is typically billed to clients or provided as a non-billable internal or pro bono service. Controls time entry classification and revenue recognition.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knowledgeAssets rdf:type rdf:Property ;
    rdfs:label 'Knowledge Assets' ;
    rdfs:comment 'Comma-separated list of knowledge management asset identifiers (practice notes, precedent documents, checklists, templates) from the knowledge management system that support delivery of this service.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterTypeMapping rdf:type rdf:Property ;
    rdfs:label 'Matter Type Mapping' ;
    rdfs:comment 'Comma-separated list of matter types in the practice management system that typically utilize this service offering. Enables service-to-matter linkage for analytics and cross-selling.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredExpertiseLevel rdf:type rdf:Property ;
    rdfs:label 'Required Expertise Level' ;
    rdfs:comment 'Minimum attorney seniority or expertise level required to lead delivery of this service. Used for resource allocation, staffing decisions, and quality assurance.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresConflictCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Conflict Check' ;
    rdfs:comment 'Indicates whether this service offering mandates a formal conflict check through the conflict checking system before engagement. Ensures compliance with ethical rules and Legal Professional Privilege (LPP) requirements.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresKyc rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc' ;
    rdfs:comment 'Indicates whether this service offering requires Know Your Client (KYC) and Anti-Money Laundering (AML) verification before engagement. Ensures compliance with Financial Action Task Force (FATF) standards.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the service offering in business development systems, Request for Proposal (RFP) responses, and Letter of Engagement (LOE) documents. Used as the external business identifier.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Full business name of the legal service offering as presented to clients and used in marketing materials, RFP responses, and engagement letters.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'Standard billing rate or base fee for this service offering in the firms primary operating currency. For hourly services, represents the blended or standard hourly rate. For fixed-fee services, represents the base package price.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyRequirements rdf:type rdf:Property ;
    rdfs:label 'Technology Requirements' ;
    rdfs:comment 'Comma-separated list of specialized technology platforms or tools required to deliver this service. Examples include eDiscovery platforms, contract lifecycle management systems, legal research databases, or document automation tools.' ;
    rdfs:domain ind:LegalService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Primary key for department' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:parentDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Department Id' ;
    rdfs:comment 'Reference to the parent department in a hierarchical organizational structure. Null for top-level departments. Enables multi-tier departmental reporting and roll-up analytics.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total annual operating budget allocated to the department for the current fiscal year, including personnel costs, overhead, and discretionary spending.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Target annual revenue goal for the department for the current fiscal year. Applicable to billable practice departments. Used for performance management and compensation planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attorneyCount rdf:type rdf:Property ;
    rdfs:label 'Attorney Count' ;
    rdfs:comment 'Total number of attorneys (partners, counsel, associates) assigned to the department. Used for workload distribution and expertise capacity planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Financial accounting code used to track expenses, overhead allocation, and budgetary performance for this department. Aligns with the firms general ledger structure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Classification of the department by its primary function within the firm. Practice departments are client-facing legal service delivery units; administrative, support, executive, operations, and business development are non-billable support functions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentDescription rdf:type rdf:Property ;
    rdfs:label 'Department Description' ;
    rdfs:comment 'Detailed narrative description of the departments mission, scope of services, key responsibilities, and strategic focus areas.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date when the department was officially dissolved, merged, or permanently closed. Null for active departments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the department used for general inquiries, client communication, and internal correspondence.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the department was officially established or created within the firms organizational structure.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extension rdf:type rdf:Property ;
    rdfs:label 'Extension' ;
    rdfs:comment 'Internal phone extension number for the department within the firms telecommunications system.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Physical floor number or level within the office building where the department is primarily located.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'Total full-time equivalent headcount allocated to the department, including attorneys, paralegals, and support staff. Used for capacity planning and utilization analysis.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Full official name of the department as recognized within the firm organizational structure.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paralegalCount rdf:type rdf:Property ;
    rdfs:label 'Paralegal Count' ;
    rdfs:comment 'Total number of paralegals assigned to the department. Used for support resource planning and matter staffing.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the department. Used for client communication and internal coordination.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Financial accounting code used to track revenue, profitability, and financial performance for revenue-generating departments. Applicable primarily to practice departments.' ;
    rdfs:domain ind:Legal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Realization Target Percentage' ;
    rdfs:comment 'Target realization rate (collected revenue as a percentage of billed revenue) for the department. Used to measure billing effectiveness and client payment performance.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentStatus rdf:type rdf:Property ;
    rdfs:label 'Department Status' ;
    rdfs:comment 'Current operational status of the department within the firm. Active departments are fully operational; inactive departments are temporarily non-operational; suspended departments are under review; merged departments have been consolidated into another unit; dissolved departments have been permanently closed.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

