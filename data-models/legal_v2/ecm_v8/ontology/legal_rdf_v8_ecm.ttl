    rdfs:comment 'Security model governing how user permissions and access rights are assigned and enforced for this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCode rdf:type rdf:Property ;
    rdfs:label 'Billing Code' ;
    rdfs:comment 'Code used to associate workspace activity and storage costs with client billing and matter accounting.' ;
    rdfs:domain ind:Workspace ;
