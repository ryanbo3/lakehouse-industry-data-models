    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionCreatedByUserId rdf:type rdf:Property ;
    rdfs:label 'Execution Created By User Id' ;
    rdfs:comment 'Reference to the user who created this workflow definition.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:executionModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Execution Modified By User Id' ;
    rdfs:comment 'Reference to the user who last modified this workflow definition.' ;
    rdfs:domain ind:ExecutionWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:User .

ind:ownerUserId rdf:type rdf:Property ;
    rdfs:label 'Owner User Id' ;
    rdfs:comment 'Reference to the user or attorney who owns and maintains this workflow definition.' ;
