    rdfs:range xsd:date .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'North American Industry Classification System code for the operator\'s primary activity.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCategory rdf:type rdf:Property ;
    rdfs:label 'Operator Category' ;
    rdfs:comment 'Business segment in which the operator primarily operates.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorRole rdf:type rdf:Property ;
    rdfs:label 'Operator Role' ;
    rdfs:comment 'Specific role the entity plays in lease and production arrangements.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorStatus rdf:type rdf:Property ;
    rdfs:label 'Operator Status' ;
    rdfs:comment 'Current lifecycle status of the operator.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership the parent operator holds in this entity.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Standard Industrial Classification code for the operator.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'State Of Incorporation' ;
    rdfs:comment 'U.S. state or jurisdiction where the operator was incorporated.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date on which the current status became effective.' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cumulativeGasProduced rdf:type rdf:Property ;
    rdfs:label 'Cumulative Gas Produced' ;
    rdfs:comment 'Total gas produced to date, measured in thousand standard cubic feet (Mscf).' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeOilProduced rdf:type rdf:Property ;
    rdfs:label 'Cumulative Oil Produced' ;
    rdfs:comment 'Total oil produced to date, measured in barrels.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthFt rdf:type rdf:Property ;
    rdfs:label 'Depth Ft' ;
    rdfs:comment 'Average true vertical depth of the field in feet.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldDescription rdf:type rdf:Property ;
    rdfs:label 'Field Description' ;
    rdfs:comment 'Free-form description of the field\'s characteristics and history.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatus rdf:type rdf:Property ;
    rdfs:label 'Field Status' ;
    rdfs:comment 'Current lifecycle status of the field.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldType rdf:type rdf:Property ;
    rdfs:label 'Field Type' ;
    rdfs:comment 'Geological/operational classification of the field.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointVentureSharePercent rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Share Percent' ;
    rdfs:comment 'Percentage ownership interest held by joint-venture partners.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Date' ;
    rdfs:comment 'Date the most recent regulatory report was filed.' ;
    rdfs:domain ind:Field ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Parent Regulatory Authority Id' ;
    rdfs:comment 'Self-referencing FK on regulatory_authority (parent_regulatory_authority_id)' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Common short form or acronym used for the authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current operational status of the authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Classification of the authority by its governance level.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScope rdf:type rdf:Property ;
    rdfs:label 'Compliance Scope' ;
    rdfs:comment 'Primary regulatory domain(s) the authority oversees.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary public email address for contacting the authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Submission Method' ;
    rdfs:comment 'Preferred method for submitting data to the authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Description' ;
    rdfs:comment 'Free-form description of the authority\'s mandate and responsibilities.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Official full name of the regulatory authority (e.g., Environmental Protection Agency).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Code' ;
    rdfs:comment 'Internal or industry code used to reference the authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCommitteeMemberId rdf:type rdf:Property ;
    rdfs:label 'Operating Committee Member Id' ;
    rdfs:comment 'Primary key for the operating_committee_member association' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'The governance role held by this partner representative on the operating committee. Chairperson presides over meetings; Alternates can vote in absence of primary representative.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberWiPercentage rdf:type rdf:Property ;
    rdfs:label 'Member Wi Percentage' ;
    rdfs:comment 'The working interest percentage held by this partner in the joint venture associated with this operating committee. Determines voting weight in committee decisions.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'The date on which this partner\'s representation on the operating committee ceased, due to working interest divestiture, JOA termination, or committee dissolution. Null for active memberships.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'The date on which this partner\'s representation on the operating committee became effective, typically aligned with JOA execution or working interest acquisition.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current status of this committee membership. Active memberships have full voting rights; Suspended may occur during dispute resolution; Terminated indicates historical membership.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyDesignation rdf:type rdf:Property ;
    rdfs:label 'Proxy Designation' ;
    rdfs:comment 'The name or identifier of the alternate representative authorized to vote on behalf of this partner when the primary representative cannot attend committee meetings. Only applicable if the JOA permits proxy voting.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeEmail rdf:type rdf:Property ;
    rdfs:label 'Representative Email' ;
    rdfs:comment 'The email address of the partner representative for committee correspondence and meeting notices.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeName rdf:type rdf:Property ;
    rdfs:label 'Representative Name' ;
    rdfs:comment 'The full name of the individual representing this partner on the operating committee.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'The percentage of voting rights allocated to this partner representative on the operating committee. Typically aligned with working interest but may differ based on JOA provisions.' ;
    rdfs:domain ind:OperatingCommitteeMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crudeAllocationId rdf:type rdf:Property ;
    rdfs:label 'Crude Allocation Id' ;
    rdfs:comment 'Unique identifier for the crude allocation record. Primary key for the crude_allocation association product.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedBy rdf:type rdf:Property ;
    rdfs:label 'Allocated By' ;
    rdfs:comment 'The name or identifier of the crude scheduler, process engineer, or planning system user who created this allocation record.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedVolumeBbl rdf:type rdf:Property ;
    rdfs:label 'Allocated Volume Bbl' ;
    rdfs:comment 'The volume of crude oil in barrels allocated from this crude receipt to this feedstock blend. This is the portion of the crude_receipt.net_volume_bbl assigned to this specific blend.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The date when this crude volume was allocated to the feedstock blend by the crude scheduler or refinery planning system.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes recorded by the crude scheduler regarding the rationale for this allocation, quality considerations, or operational constraints.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'The precise date and time when this crude allocation record was created in the refinery scheduling system.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeFractionPct rdf:type rdf:Property ;
    rdfs:label 'Volume Fraction Pct' ;
    rdfs:comment 'The percentage of the feedstock blend total volume represented by this crude allocation. Used in blend recipe calculations and feedstock optimization.' ;
    rdfs:domain ind:CrudeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleUnitPlanId rdf:type rdf:Property ;
    rdfs:label 'Schedule Unit Plan Id' ;
    rdfs:comment 'Unique identifier for this schedule-unit planning record. Primary key.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualThroughputBpd rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Bpd' ;
    rdfs:comment 'Actual achieved throughput rate for this unit during this schedule period. Enables planned vs. actual variance analysis at the unit level.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cduThroughputTargetBpd rdf:type rdf:Property ;
    rdfs:label 'Cdu Throughput Target Bpd' ;
    rdfs:comment 'Planned daily throughput rate for the Crude Distillation Unit in barrels per day. Key operational target for primary refining capacity utilization. [Moved from refinery_schedule: This attribute represents a unit-specific throughput target (CDU = Crude Distillation Unit) that should be modeled as a schedule_unit_plan record for the CDU process unit, not as a schedule-level attribute. Moving to association enables proper normalization where each unit has its own plan record.]' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fccThroughputTargetBpd rdf:type rdf:Property ;
    rdfs:label 'Fcc Throughput Target Bpd' ;
    rdfs:comment 'Planned daily throughput rate for the Fluid Catalytic Cracking unit in barrels per day. Critical for gasoline and light olefin production optimization. [Moved from refinery_schedule: This attribute represents a unit-specific throughput target (FCC = Fluid Catalytic Cracking) that should be modeled as a schedule_unit_plan record for the FCC process unit, not as a schedule-level attribute. Moving to association enables proper normalization.]' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hdsThroughputTargetBpd rdf:type rdf:Property ;
    rdfs:label 'Hds Throughput Target Bpd' ;
    rdfs:comment 'Planned daily throughput rate for the Hydrodesulfurization unit in barrels per day. Targets sulfur removal capacity to meet EPA emissions and product quality standards. [Moved from refinery_schedule: This attribute represents a unit-specific throughput target (HDS = Hydrodesulfurization) that should be modeled as a schedule_unit_plan record for the HDS process unit, not as a schedule-level attribute. Moving to association enables proper normalization.]' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Flag' ;
    rdfs:comment 'Indicates whether this unit is scheduled for maintenance during this schedule period. Critical for coordinating turnarounds and managing refinery-wide capacity.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalMode rdf:type rdf:Property ;
    rdfs:label 'Operational Mode' ;
    rdfs:comment 'Planned operational state for this process unit during this schedule period. Determines throughput expectations and resource allocation.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedThroughputBpd rdf:type rdf:Property ;
    rdfs:label 'Planned Throughput Bpd' ;
    rdfs:comment 'Target daily throughput rate for this specific process unit during this schedule period, measured in barrels per day. This is the core planning parameter that schedulers set per unit per schedule.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Date when this unit plan ends within the schedule period. Critical for planning maintenance windows and turnarounds.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceBpd rdf:type rdf:Property ;
    rdfs:label 'Variance Bpd' ;
    rdfs:comment 'Calculated variance between planned and actual throughput for this unit in this schedule. Supports unit-level performance tracking.' ;
    rdfs:domain ind:ScheduleUnitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselScheduleAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Vessel Schedule Assignment Id' ;
    rdfs:comment 'Unique identifier for this vessel schedule assignment record. Primary key.' ;
    rdfs:domain ind:VesselScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Name or identifier of the marine logistics planner or scheduler who made this vessel assignment decision.' ;
    rdfs:domain ind:VesselScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLoadingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Loading Date' ;
    rdfs:comment 'Planned date when this vessel is scheduled to commence loading operations for this shipping schedule. Critical for berth planning and terminal coordination.' ;
    rdfs:domain ind:VesselScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vesselRole rdf:type rdf:Property ;
    rdfs:label 'Vessel Role' ;
    rdfs:comment 'Role of the vessel in this shipping schedule assignment. Values: primary_lifter (main vessel for scheduled liftings), backup_vessel (contingency vessel), spot_charter (short-term charter), term_charter (long-term charter agreement).' ;
    rdfs:domain ind:VesselScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulePortCallId rdf:type rdf:Property ;
    rdfs:label 'Schedule Port Call Id' ;
    rdfs:comment 'Unique identifier for this schedule port call. Primary key.' ;
    rdfs:domain ind:SchedulePortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Date' ;
    rdfs:comment 'Planned date and time when the vessel is scheduled to arrive at this terminal for loading or discharge operations' ;
    rdfs:domain ind:SchedulePortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Date' ;
    rdfs:comment 'Planned date and time when the vessel is scheduled to depart from this terminal after completing cargo operations' ;
    rdfs:domain ind:SchedulePortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portCallSequence rdf:type rdf:Property ;
    rdfs:label 'Port Call Sequence' ;
    rdfs:comment 'Sequential order of this port call within the shipping schedule (1 for first port, 2 for second, etc.)' ;
    rdfs:domain ind:SchedulePortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portCallStatus rdf:type rdf:Property ;
    rdfs:label 'Port Call Status' ;
    rdfs:comment 'Current operational status of this port call indicating its execution state' ;
    rdfs:domain ind:SchedulePortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
