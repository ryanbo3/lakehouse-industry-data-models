ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business rationale for establishing or changing the transfer price (e.g., cost alignment, market parity).' ;
    rdfs:domain ind:FoodBeverage ;
