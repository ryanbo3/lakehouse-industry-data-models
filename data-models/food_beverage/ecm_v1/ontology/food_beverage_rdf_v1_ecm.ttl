ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the pricing model for reference in ERP and pricing systems.' ;
    rdfs:domain ind:CostPlusModel ;
