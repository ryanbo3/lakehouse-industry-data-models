    rdfs:comment 'Total monetary value of the contract as agreed with the service provider.' ;
    rdfs:domain ind:MaintenanceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveredAssetCategory rdf:type rdf:Property ;
