    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceBudgetId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Budget Id' ;
    rdfs:comment 'Unique system-generated identifier for each maintenance budget record.' ;
