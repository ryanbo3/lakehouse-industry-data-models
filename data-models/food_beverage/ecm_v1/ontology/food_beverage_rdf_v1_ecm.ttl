    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Classification of the NPS score: promoter (9-10), passive (7-8), detractor (0-6).' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Indicates if the respondent is a business (B2B) or consumer (B2C) entity.' ;
