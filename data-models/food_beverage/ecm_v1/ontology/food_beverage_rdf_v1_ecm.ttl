    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the sales pipeline for the opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDistributionPoints rdf:type rdf:Property ;
    rdfs:label 'Target Distribution Points' ;
    rdfs:comment 'Number of distribution points (e.g., stores) targeted for placement.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Required for General Ledger posting of order revenue; financial statements and tax reporting depend on linking each sales order to its revenue GL account.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:salesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Id' ;
    rdfs:comment 'FK to sales.sales_organization' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:edi850Reference rdf:type rdf:Property ;
