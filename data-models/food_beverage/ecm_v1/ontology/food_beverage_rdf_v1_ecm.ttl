    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'Number of line items included on the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postedToLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Ledger Flag' ;
    rdfs:comment 'Indicates whether the invoice has been posted to the general ledger.' ;
