    rdfs:range xsd:string .

ind:preferredProductCategory rdf:type rdf:Property ;
    rdfs:label 'Preferred Product Category' ;
    rdfs:comment 'Primary product category the consumer prefers (e.g., snacks, beverages, dairy). [ENUM-REF-CANDIDATE: snacks|beverages|dairy|convenience|organic|health|other — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPurchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Purchase Channel' ;
    rdfs:comment 'Channel through which the consumer most often purchases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sugarContentPreference rdf:type rdf:Property ;
