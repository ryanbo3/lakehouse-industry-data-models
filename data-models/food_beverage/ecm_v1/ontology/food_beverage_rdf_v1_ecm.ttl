    rdfs:comment 'Code representing the specific area or zone within the plant for the inspection round.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of the inspection round completed (0-100).' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Actual date and time when the inspection round was performed.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total time spent executing the inspection round, measured in minutes.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionRoundStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Round Status' ;
    rdfs:comment 'Current workflow state of the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutonomous rdf:type rdf:Property ;
    rdfs:label 'Is Autonomous' ;
    rdfs:comment 'Indicates whether the round is part of an autonomous maintenance (AM) program.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfDefects rdf:type rdf:Property ;
    rdfs:label 'Number Of Defects' ;
    rdfs:comment 'Count of defects identified during the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfInspectionPoints rdf:type rdf:Property ;
    rdfs:label 'Number Of Inspection Points' ;
    rdfs:comment 'Total count of distinct inspection points included in the round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfWorkOrders rdf:type rdf:Property ;
    rdfs:label 'Number Of Work Orders' ;
    rdfs:comment 'Count of maintenance work orders generated from defects discovered in the round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundName rdf:type rdf:Property ;
    rdfs:label 'Round Name' ;
    rdfs:comment 'Descriptive name of the inspection round (e.g., "Morning Equipment Care").' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Human-readable code or number assigned to the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundType rdf:type rdf:Property ;
    rdfs:label 'Round Type' ;
    rdfs:comment 'Category of the inspection round indicating its purpose.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Narrative description of the inspection route or path taken during the round.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFrequency rdf:type rdf:Property ;
    rdfs:label 'Scheduled Frequency' ;
    rdfs:comment 'Frequency at which the inspection round is scheduled to recur.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lubricationEventId rdf:type rdf:Property ;
    rdfs:label 'Lubrication Event Id' ;
    rdfs:comment 'System-generated unique identifier for the lubrication event record.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lubePointId rdf:type rdf:Property ;
    rdfs:label 'Lube Point Id' ;
    rdfs:comment 'Identifier of the specific lubrication point on the asset.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LubePoint .

ind:lubricationRouteId rdf:type rdf:Property ;
    rdfs:label 'Lubrication Route Id' ;
    rdfs:comment 'Identifier of the predefined lubrication route applied to the asset.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LubricationRoute .

ind:primaryLubricationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lubrication Employee Id' ;
    rdfs:comment 'Unique identifier of the technician who performed the lubrication.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLubricationUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lubrication Updated By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the lubrication event record.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationMethod rdf:type rdf:Property ;
    rdfs:label 'Application Method' ;
    rdfs:comment 'Method used to apply the lubricant.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage at the time of lubrication.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether the lubrication task is classified as critical for production continuity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lubePointCondition rdf:type rdf:Property ;
    rdfs:label 'Lube Point Condition' ;
    rdfs:comment 'Observed condition of the lubrication point at the time of service.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lubricantNsfClassification rdf:type rdf:Property ;
    rdfs:label 'Lubricant Nsf Classification' ;
    rdfs:comment 'NSF food-grade classification of the lubricant (H1, H2, 3H, or none).' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lubricantProductName rdf:type rdf:Property ;
    rdfs:label 'Lubricant Product Name' ;
    rdfs:comment 'Commercial name of the lubricant product used.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lubricantType rdf:type rdf:Property ;
    rdfs:label 'Lubricant Type' ;
    rdfs:comment 'Category of lubricant applied (e.g., grease, oil, synthetic, food-grade).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lubricationEventStatus rdf:type rdf:Property ;
    rdfs:label 'Lubrication Event Status' ;
    rdfs:comment 'Current lifecycle state of the lubrication event.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Planned date for the next lubrication event.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Applied' ;
    rdfs:comment 'Amount of lubricant applied during the event.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyDataSheetVersion rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Version' ;
    rdfs:comment 'Version identifier of the safety data sheet associated with the lubricant.' ;
    rdfs:domain ind:LubricationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCrewId rdf:type rdf:Property ;
    rdfs:label 'Responsible Crew Id' ;
    rdfs:comment 'Identifier of the maintenance crew responsible for executing the route.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:averageMechanicalEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Average Mechanical Efficiency Pct' ;
    rdfs:comment 'Target mechanical efficiency percentage for equipment after lubrication.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference to SOP, work instruction, or external document governing the route.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated total time required to complete the route, expressed in hours.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodGradeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Food Grade Compliance Flag' ;
    rdfs:comment 'True if the route uses NSF H1/H2 food-grade lubricants; otherwise false.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'True if the route complies with GMP requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpControlPoint rdf:type rdf:Property ;
    rdfs:label 'Haccp Control Point' ;
    rdfs:comment 'Indicates whether the route is a critical control point under HACCP.' ;
