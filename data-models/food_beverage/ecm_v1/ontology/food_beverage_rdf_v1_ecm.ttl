    rdfs:comment 'Current status of required regulatory approvals for the contract.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDate rdf:type rdf:Property ;
