    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationValue rdf:type rdf:Property ;
    rdfs:label 'Calculation Value' ;
    rdfs:comment 'Numeric value used by the calculation type (e.g., 5.0 for 5%).' ;
