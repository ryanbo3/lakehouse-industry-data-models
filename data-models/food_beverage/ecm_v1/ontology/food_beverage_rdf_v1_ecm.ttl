ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Category of the maintenance agreement (e.g., Annual Maintenance Contract, OEM Service Agreement, Time-and-Material, Fixed-Price, SLA-Based).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
