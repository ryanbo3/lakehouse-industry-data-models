    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Date and time when the latest audit was performed.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ccpCode rdf:type rdf:Property ;
    rdfs:label 'Ccp Code' ;
    rdfs:comment 'Business identifier code for the CCP, often used in documentation and labeling.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPointCategory rdf:type rdf:Property ;
    rdfs:label 'Control Point Category' ;
    rdfs:comment 'Broad category of the control point measurement.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionProcedure rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Procedure' ;
    rdfs:comment 'Standard operating procedure to follow when a deviation occurs.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointName rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Name' ;
    rdfs:comment 'Descriptive name of the CCP, e.g., "Cooking Temperature Check".' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointStatus rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Status' ;
    rdfs:comment 'Current lifecycle status of the CCP.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Unit' ;
    rdfs:comment 'Unit of measure associated with the critical limit value.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitValue rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Value' ;
    rdfs:comment 'Numeric threshold that must not be exceeded (or must be met) for the hazard.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationTrigger rdf:type rdf:Property ;
    rdfs:label 'Deviation Trigger' ;
    rdfs:comment 'Condition that triggers a deviation (e.g., "temperature > 75°C").' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation steps and contacts when a deviation occurs.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Last Measured Value' ;
    rdfs:comment 'Numeric value recorded in the most recent observation.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasurementStatus rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Status' ;
    rdfs:comment 'Result of the most recent observation (pass, fail, or out of range).' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastObservedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Observed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent monitoring observation for this CCP.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Specific type of measurement captured at the CCP.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency Minutes' ;
    rdfs:comment 'How often the CCP must be monitored, expressed in minutes.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Specific manufacturing step or operation where the CCP is applied.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Minutes' ;
    rdfs:comment 'How often sampling is performed, expressed in minutes.' ;
