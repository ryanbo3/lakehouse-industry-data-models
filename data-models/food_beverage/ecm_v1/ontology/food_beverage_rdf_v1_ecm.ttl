    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Price' ;
    rdfs:comment 'Floor price enforced by the model to prevent under-pricing.' ;
