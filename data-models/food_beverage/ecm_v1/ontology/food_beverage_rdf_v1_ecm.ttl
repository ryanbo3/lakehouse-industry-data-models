    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Classification of revenue (e.g., gross sales, trade spend, net revenue).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of line net amounts before discounts, freight, and tax.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final amount payable after all discounts, freight, and tax.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityAccountId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Account Id' ;
    rdfs:comment 'Internal identifier of the target customer.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:targetCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Target Customer Account Id' ;
    rdfs:comment 'FK to customer.account' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Date when the opportunity was actually closed (won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected annual revenue in US dollars if the opportunity is won.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCaseVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Case Volume' ;
    rdfs:comment 'Projected number of cases (units) expected to be sold annually.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Projected date when the opportunity is expected to be closed.' ;
