    rdfs:range xsd:string .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Authorized transfer price amount expressed in the transaction currency.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'Method used to calculate the transfer price (e.g., Cost-Plus, Resale-Minus, Comparable Uncontrolled Price, Transactional Net Margin Method).' ;
    rdfs:domain ind:TransferPrice ;
