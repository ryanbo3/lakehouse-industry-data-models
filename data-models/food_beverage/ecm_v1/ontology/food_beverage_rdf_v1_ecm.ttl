ind:capacityConstraintId rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Id' ;
    rdfs:comment 'Foreign key linking to supply.capacity_constraint. Business justification: SURCHARGE CALCULATION: procedure step uses capacity constraint data to apply surcharges when lane capacity is limited.' ;
    rdfs:domain ind:FoodBeverage ;
