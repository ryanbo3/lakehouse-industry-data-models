    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Unique surrogate identifier for each supplier-material combination record in the Approved Vendor List. Primary key for the AVL entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Reference to the supplier/vendor master record. Identifies the approved supplier entity in this AVL entry.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allergenApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Approved Flag' ;
    rdfs:comment 'Indicates whether the supplier has been specifically assessed and approved for allergen management controls relevant to this material. Supports allergen matrix compliance and FSMA preventive controls.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text field capturing conditions, restrictions, or rationale associated with the approval decision. For example, conditional approvals may specify required corrective actions or usage limitations.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Sourcing tier designation for this supplier-material combination. \'primary\' = preferred first-source supplier; \'secondary\' = qualified backup supplier; \'contingency\' = emergency-use only supplier activated during supply disruptions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the most recent audit conducted for this supplier-material combination. \'first_party\' = self-assessment; \'second_party\' = customer-conducted; \'third_party\' = independent certification body; \'remote\' = virtual audit; \'desk_audit\' = document review only.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the AVL record, formatted as AVL-XXXXXXXX. Used for cross-system referencing between SAP MM and TraceGains.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertification rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification' ;
    rdfs:comment 'Primary food safety or quality certification held by the supplier for this material. SQF (Safe Quality Food), BRC (British Retail Consortium), FSSC 22000 (Food Safety System Certification), IFS (International Featured Standards). [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|IFS|GlobalGAP|Halal|Kosher|Organic|none — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsvpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fsvp Required Flag' ;
    rdfs:comment 'Indicates whether this supplier-material combination is subject to FSMA Foreign Supplier Verification Program requirements due to the material being imported from outside the United States.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Verified Flag' ;
    rdfs:comment 'Indicates whether the supplier has been verified as having an implemented and validated HACCP plan for this material, as required under FSMA preventive controls and GFSI standards.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Requalification Date' ;
    rdfs:comment 'Date of the most recent supplier requalification assessment for this material. Used to track compliance with periodic requalification requirements under FSMA and GFSI.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level classification of the material type the supplier is approved to provide. Drives procurement routing and compliance requirements. [ENUM-REF-CANDIDATE: ingredient|packaging|indirect|co-manufacturing|toll_manufacturing — promote to reference product if additional categories are added]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the Minimum Order Quantity (MOQ), aligned with SAP MM base unit of measure. Examples: KG (kilogram), LB (pound), L (liter), EA (each), CS (case), PAL (pallet), MT (metric ton). [ENUM-REF-CANDIDATE: KG|LB|L|GAL|EA|CS|PAL|MT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Date' ;
    rdfs:comment 'Scheduled date for the next supplier requalification review. Calculated based on requalification frequency policy and last requalification date. Drives procurement compliance calendar.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationBasis rdf:type rdf:Property ;
    rdfs:label 'Qualification Basis' ;
    rdfs:comment 'The primary quality and regulatory basis on which the supplier approval was granted. Indicates the type of evidence used to qualify the supplier for this material. [ENUM-REF-CANDIDATE: audit|certificate|questionnaire|third_party_cert|historical_performance|regulatory_approval — promote to reference product]' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInfoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Info Record Number' ;
    rdfs:comment 'SAP MM Purchasing Info Record number (EINE-INFNR) linking this AVL entry to the corresponding purchasing conditions and pricing data in SAP S/4HANA.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for this material, representing a single-source supply risk. Triggers supply risk alerts and dual-sourcing initiatives.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceListIndicator rdf:type rdf:Property ;
    rdfs:label 'Source List Indicator' ;
    rdfs:comment 'Indicates whether this supplier-material combination is included in the SAP MM Source List (EORD), making it eligible for automatic source determination in purchase requisitions and orders.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierRiskTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Risk Tier' ;
    rdfs:comment 'Risk classification assigned to this supplier-material combination based on food safety hazard severity, supply criticality, and supplier performance history. Drives frequency of verification activities under FSMA.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason code or description explaining why the supplier-material approval was suspended or revoked. Populated when approval_status is \'suspended\' or \'revoked\'. Supports CAPA (Corrective and Preventive Action) tracking.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracegainsDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Tracegains Document Code' ;
    rdfs:comment 'Reference to the primary compliance document (e.g., supplier specification, audit report, certificate of analysis) stored in TraceGains Document Management that supports this AVL approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSavingsTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Savings Target Usd' ;
    rdfs:comment 'Targeted procurement savings in US dollars for this category in the current strategy period. Represents the expected reduction in total cost of ownership (TCO) through sourcing initiatives, negotiations, and demand management. Feeds into annual procurement planning and EBITDA improvement targets.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Usd' ;
    rdfs:comment 'Total annual procurement spend for this category in US dollars, based on the most recently completed fiscal year. Used to size the category, prioritize sourcing investment, and calculate savings targets. Classified confidential as it reveals commercial spend positioning.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSupplierTargetCount rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier Target Count' ;
    rdfs:comment 'Target number of approved suppliers to maintain on the Approved Vendor List (AVL) for this category. Balances supply security with supplier relationship management investment. Reviewed annually during strategic sourcing planning.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitOwner rdf:type rdf:Property ;
    rdfs:label 'Business Unit Owner' ;
    rdfs:comment 'Name or code of the primary business unit or division that owns and sponsors this category strategy (e.g., Snacks BU, Beverages BU, Dairy BU, Supply Chain). Supports category strategy alignment with business unit P&L and procurement planning.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the procurement category (e.g., DAIRY-ING, GRAIN-OIL, FLEX-PKG, CO-MFG, MRO). Sourced from SAP S/4HANA MM purchasing category hierarchy and used as the business key across ERP and sourcing systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Numeric level of this category within the procurement category hierarchy (e.g., 1 = top-level segment, 2 = category, 3 = sub-category). Supports hierarchical drill-down in spend analytics and category management dashboards.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Category Manager Email' ;
    rdfs:comment 'Corporate email address of the procurement category manager. Used for workflow notifications, strategy review communications, and stakeholder escalation. Classified confidential as it is an employee contact identifier.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Full name of the procurement category manager responsible for owning and executing this category strategy. Used for accountability, escalation routing, and category management reporting. Sourced from Workday HCM employee master.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'Classification of the category by commodity type. \'agricultural_commodity\' = exchange-traded raw materials (grains, dairy, oils); \'industrial_commodity\' = packaging materials, chemicals; \'manufactured_input\' = processed ingredients, co-pack services; \'service\' = logistics, co-manufacturing; \'indirect\' = MRO, facilities, IT. Drives hedging eligibility and pricing contract structure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Target contract duration in months for supplier agreements in this category. Informs negotiation strategy and contract renewal planning. Typical ranges: 12 months for commodity categories, 24–36 months for strategic categories with capital investment requirements.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dualSourceSplitPct rdf:type rdf:Property ;
    rdfs:label 'Dual Source Split Pct' ;
    rdfs:comment 'Target volume allocation percentage to the primary supplier when a dual-source policy is in effect (0.00–100.00%). For example, 70.00 means 70% to primary supplier and 30% to secondary. Null when supply_base_policy is \'single_source\' or \'multi_source\'. Supports supply continuity risk management.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicalSourcingStandard rdf:type rdf:Property ;
    rdfs:label 'Ethical Sourcing Standard' ;
    rdfs:comment 'Ethical sourcing and labor standards audit framework required for suppliers in this category. \'sedex\' = Supplier Ethical Data Exchange; \'smeta\' = Sedex Members Ethical Trade Audit; \'bsci\' = Business Social Compliance Initiative; \'sa8000\' = Social Accountability International; \'custom\' = company-specific standard; \'none\' = not applicable. Supports responsible sourcing programs.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyRequirement rdf:type rdf:Property ;
    rdfs:label 'Food Safety Requirement' ;
    rdfs:comment 'Minimum food safety certification or standard required for suppliers in this category. \'gmp\' = Good Manufacturing Practice; \'haccp\' = Hazard Analysis Critical Control Points; \'gfsi\' = Global Food Safety Initiative benchmarked scheme; \'sqf\' = Safe Quality Food; \'fssc22000\' = Food Safety System Certification 22000. Mandatory for direct food ingredient and packaging categories. Managed via TraceGains supplier compliance.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicSourcingScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Sourcing Scope' ;
    rdfs:comment 'Geographic scope of the approved supply base for this category. \'domestic\' = suppliers within the home country only; \'regional\' = suppliers within a defined trade region; \'global\' = worldwide supplier base; \'preferred_domestic\' = global scope with preference for domestic suppliers. Impacts trade compliance, tariff exposure, and supply chain resilience.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Hedge Coverage Target Pct' ;
    rdfs:comment 'Target percentage of forecasted commodity volume to be covered by hedging instruments (0.00–100.00%). For example, 75.00 means 75% of projected annual volume should be hedged. Supports COGS risk management and financial planning. Classified confidential as it reveals pricing risk posture.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgingStrategy rdf:type rdf:Property ;
    rdfs:label 'Hedging Strategy' ;
    rdfs:comment 'Commodity price risk management strategy applied to this category. \'no_hedge\' = market price accepted; \'forward_contract\' = fixed-price forward purchase agreements; \'futures\' = exchange-traded futures contracts (e.g., CBOT corn, CME dairy); \'options\' = price floor/ceiling options; \'index_pricing\' = contract pricing linked to published commodity index (e.g., USDA dairy price). Critical for COGS stability in food and beverage manufacturing.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationPriority rdf:type rdf:Property ;
    rdfs:label 'Innovation Priority' ;
    rdfs:comment 'Priority level assigned to supplier-led innovation and co-development activities for this category. \'high\' = active joint innovation programs with key suppliers (e.g., new ingredient technologies, sustainable packaging); \'medium\' = innovation considered in supplier reviews; \'low\' = transactional category with no formal innovation agenda. Supports NPD and R&D pipeline.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kraljicQuadrant rdf:type rdf:Property ;
    rdfs:label 'Kraljic Quadrant' ;
    rdfs:comment 'Strategic classification of the procurement category using the Kraljic Portfolio Matrix. \'strategic\' = high spend impact, high supply risk (e.g., specialty dairy cultures); \'leverage\' = high spend impact, low supply risk (e.g., commodity grains); \'bottleneck\' = low spend impact, high supply risk (e.g., proprietary flavors); \'non_critical\' = low spend impact, low supply risk (e.g., general MRO). Drives sourcing strategy and supplier relationship investment.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Target Days' ;
    rdfs:comment 'Target supplier lead time in calendar days from purchase order placement to delivery at the receiving DC or plant. Used in supply planning, safety stock policy design, and supplier SLA negotiations. Feeds into JDA/Blue Yonder supply planning parameters.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqPolicy rdf:type rdf:Property ;
    rdfs:label 'Moq Policy' ;
    rdfs:comment 'Policy governing Minimum Order Quantity (MOQ) requirements for this category. \'not_applicable\' = no MOQ constraints; \'supplier_standard\' = accept supplier-defined MOQs; \'negotiated\' = MOQs are negotiated as part of sourcing strategy; \'waived\' = MOQs formally waived in contract. Impacts inventory planning and working capital.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Parent Category Code' ;
    rdfs:comment 'Code of the parent category in the procurement category hierarchy, enabling multi-level category tree structures (e.g., INGREDIENTS as parent of DAIRY-ING). Supports roll-up spend analytics and hierarchical category reporting.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDays rdf:type rdf:Property ;
    rdfs:label 'Payment Term Days' ;
    rdfs:comment 'Standard payment term in days (net days) targeted for supplier contracts in this category (e.g., 30, 45, 60, 90). Longer payment terms improve working capital and cash conversion cycle. Negotiated as part of category sourcing strategy and reflected in SAP S/4HANA FI payment terms.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredIncoterm rdf:type rdf:Property ;
    rdfs:label 'Preferred Incoterm' ;
    rdfs:comment 'Preferred International Commercial Terms (Incoterms 2020) for supplier contracts in this category, defining the transfer of risk and responsibility for freight, insurance, and customs. Common food and beverage terms: FOB (Free on Board) for bulk commodities, DDP (Delivered Duty Paid) for finished ingredients. Impacts landed cost and supply chain risk allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which this category strategy is formally reviewed and refreshed. Strategic and bottleneck categories typically require quarterly reviews; leverage and non-critical categories may be reviewed annually. Drives the procurement planning calendar.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsTargetPct rdf:type rdf:Property ;
    rdfs:label 'Savings Target Pct' ;
    rdfs:comment 'Targeted procurement savings as a percentage of total annual category spend (0.00–100.00%). Provides a normalized savings ambition metric that enables cross-category comparison regardless of absolute spend size. Supports annual procurement planning cycles.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingApproach rdf:type rdf:Property ;
    rdfs:label 'Sourcing Approach' ;
    rdfs:comment 'Primary sourcing methodology applied to this category. \'competitive_bid\' = formal RFP/RFQ process; \'negotiated\' = direct negotiation with preferred suppliers; \'sole_source\' = single qualified supplier; \'consortium\' = industry buying group; \'spot_buy\' = open market transactional purchasing. Informs procurement execution strategy.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendImpactRating rdf:type rdf:Property ;
    rdfs:label 'Spend Impact Rating' ;
    rdfs:comment 'Assessed financial impact level of this category on total procurement spend and COGS. Used as one of the two axes in the Kraljic Matrix positioning. Combined with supply_risk_rating to determine the Kraljic quadrant classification.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendUnderManagementPct rdf:type rdf:Property ;
    rdfs:label 'Spend Under Management Pct' ;
    rdfs:comment 'Percentage of total category spend that is actively managed under formal procurement contracts and sourcing agreements (0.00–100.00%). A key procurement maturity KPI. Higher percentages indicate stronger category governance and compliance. Classified confidential as it reveals procurement control posture.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategyApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Strategy Approved Date' ;
    rdfs:comment 'Date on which this version of the category strategy was formally approved by procurement leadership or the category governance board. Marks the transition from \'approved\' to \'active\' status in the strategy lifecycle.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategyNotes rdf:type rdf:Property ;
    rdfs:label 'Strategy Notes' ;
    rdfs:comment 'Free-text field for additional strategic context, rationale, market intelligence, or special considerations relevant to this category strategy (e.g., market disruption notes, regulatory changes, geopolitical risk commentary). Supports category manager documentation and knowledge management.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the category strategy record. \'draft\' indicates the strategy is being developed; \'active\' means it is approved and in execution; \'under_review\' indicates a scheduled refresh cycle; \'approved\' means formally signed off pending activation; \'archived\' means superseded by a newer strategy version.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyVersion rdf:type rdf:Property ;
    rdfs:label 'Strategy Version' ;
    rdfs:comment 'Version identifier for the category strategy document (e.g., v1.0, v2.3). Supports version control and audit trail for strategy evolution across annual procurement planning cycles.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyBasePolicy rdf:type rdf:Property ;
    rdfs:label 'Supply Base Policy' ;
    rdfs:comment 'Approved supply base policy for this category defining whether the business maintains a single, dual, or multiple qualified suppliers. Dual/multi-source policies mitigate supply continuity risk for critical ingredients and packaging materials.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyRiskRating rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Rating' ;
    rdfs:comment 'Assessed supply continuity risk level for this category based on factors including supplier concentration, geographic concentration, commodity volatility, regulatory exposure, and lead time. Drives risk mitigation actions and safety stock policy. Reviewed at minimum annually.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Required' ;
    rdfs:comment 'Specific third-party sustainability certification standard required for suppliers in this category when sustainability_requirement is \'certified\' (e.g., Rainforest Alliance, RSPO, Fair Trade, SBTi, GFSI, Organic USDA). Null when no certification is required. Supports TraceGains supplier compliance document management.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRequirement rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirement' ;
    rdfs:comment 'Level of sustainability and ethical sourcing requirement applied to suppliers in this category. \'none\' = no formal requirement; \'preferred\' = sustainability criteria considered in sourcing decisions; \'required\' = mandatory sustainability standards in supplier contracts; \'certified\' = third-party certification required (e.g., Rainforest Alliance, RSPO, Fair Trade, SBTi). Supports ESG reporting and ISO 20400 compliance.' ;
    rdfs:domain ind:CategoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDocumentComplianceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Compliance Document Id' ;
    rdfs:comment 'Identifier of the previous version of the compliance document that this document replaces. Null if this is the first version.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceDocument .

ind:criticalNonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Critical Non Conformance Count' ;
    rdfs:comment 'Number of critical or major non-conformances identified during an audit that require immediate corrective action. Null for non-audit documents.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level classification grouping the compliance document by its primary business function or regulatory domain. [ENUM-REF-CANDIDATE: regulatory|quality|safety|sustainability|ethical_sourcing|allergen|nutritional|specification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Name of the supplier facility or production site covered by this compliance document as stated in the document.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the digital file containing the compliance document as stored in the document management system.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI path where the compliance document file is stored in the document management system or cloud storage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the organization, certification body, or regulatory agency that issued or certified the compliance document (e.g., FDA, USDA, third-party auditor, supplier laboratory).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority License Number' ;
    rdfs:comment 'License, accreditation, or registration number of the issuing authority demonstrating their authorization to certify or audit.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory standard, certification scheme, or compliance framework that this document satisfies (e.g., FSMA, GFSI, ISO 22000, Organic NOP, Non-GMO Project).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the compliance document must be retained to meet regulatory, legal, or business requirements.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingClerkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Clerk Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Receiving clerk identity is required for traceability, quality checks, and labor cost allocation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenDeclarationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided allergen declaration was received with the goods. Critical for allergen matrix management and food safety compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfAnalysisReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided certificate of analysis was received with the goods. Required for raw material release and TraceGains compliance documentation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The supplier-provided delivery note or packing slip number accompanying the shipment. Used for cross-reference with supplier documentation and ASN reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'The current lifecycle status of the goods receipt transaction. Tracks the receipt through posting, quality inspection, approval, and final disposition workflows.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Timestamp' ;
    rdfs:comment 'The precise date and time when the goods receipt transaction was posted in the system. Provides granular audit trail for receipt processing and system reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'The quality management inspection lot number assigned to this goods receipt for quality testing and approval. Links to quality inspection results and certificate of analysis.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving clerk documenting any observations, damage, discrepancies, or special handling instructions for the received goods.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt C' ;
    rdfs:comment 'The temperature of the received material at the time of receipt, measured in degrees Celsius. Critical for cold chain compliance and temperature-sensitive ingredient quality verification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The total monetary value of the goods receipt, calculated as received quantity multiplied by unit price. Used for inventory accounting and financial reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'The specific dock or unloading bay at the plant or distribution center where the goods were received. Supports warehouse operations and receiving efficiency analytics.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Determines how the procurement cost is assigned in financial accounting (e.g., to a cost center for indirect materials, to a production order for direct ingredients, to a project for capital expenditure). Critical for COGS and EBITDA reporting.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Required' ;
    rdfs:comment 'Indicates whether batch management is required for this material upon goods receipt, enabling lot traceability for food safety compliance (HACCP, FSMA). When true, a batch number must be assigned at goods receipt.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier via order acknowledgment or Advanced Shipping Notice (ASN). Used to calculate delivery variance against the requested date for OTIF performance tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Indicates whether this purchase order line has been marked for deletion in the source ERP system. Soft-delete flag used to exclude cancelled or obsolete lines from active procurement reporting while retaining audit history.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Indicates whether a goods receipt is required for this purchase order line before invoice payment can be processed. Mandatory for direct materials (ingredients, packaging) to enforce three-way match; may be waived for certain service lines.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of the material actually received against this purchase order line, expressed in the order unit of measure. Used to calculate open quantity, delivery completeness, and three-way match for invoice verification.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Indicates whether an invoice is expected for this purchase order line. When false, the system may use evaluated receipt settlement (ERS/self-billing) for high-volume ingredient suppliers.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier against this purchase order line. Used in three-way match (PO quantity vs. GR quantity vs. invoice quantity) for accounts payable processing and accrual management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP item category code defining the procurement type for this line (e.g., standard stock material, subcontracting for toll manufacturing/co-packing, consignment, service). Determines goods receipt and invoice verification behavior.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Classification code grouping materials by commodity or category (e.g., sweeteners, dairy ingredients, flexible packaging, corrugated). Used for spend analytics, category management, and sourcing strategy.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net monetary value of this purchase order line, calculated as (ordered_quantity / price_unit) × unit_price. Represents the committed spend for this line item and feeds into COGS and procurement spend analytics.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which the ordered quantity is expressed (e.g., KG, LB, L, EA, CS, MT). Must align with the material master order unit for accurate goods receipt and invoice verification.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the supplier may over-deliver against the ordered quantity without triggering a purchase order amendment. Common in bulk ingredient procurement where exact quantities are difficult to control.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the buyer or purchasing group responsible for managing this purchase order line. Used for workload distribution, buyer performance reporting, and escalation routing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the supplier may under-deliver against the ordered quantity and still have the line considered fully delivered. Prevents unnecessary open PO lines for minor quantity shortfalls.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract ownership is assigned to a specific employee for responsibility tracking and reporting.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:initiativeId rdf:type rdf:Property ;
    rdfs:label 'Initiative Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_initiative. Business justification: Procurement contracts are linked to internal sustainability initiatives they fund (e.g., carbon-reduction projects).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:allergenHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Requirements' ;
    rdfs:comment 'Specific allergen control and handling requirements stipulated in the contract to ensure compliance with allergen labeling and cross-contamination prevention (e.g., dedicated lines, allergen-free facility).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed contract document stored in the document management system.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleType rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Type' ;
    rdfs:comment 'Type of delivery arrangement under this contract. Scheduled deliveries follow a fixed calendar; just-in-time aligns with production schedules; vendor-managed inventory allows supplier to manage stock levels.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether this contract includes exclusivity terms requiring the buyer to source specified materials exclusively from this supplier, or vice versa.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foodSafetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Required' ;
    rdfs:comment 'Food safety certifications that the supplier must maintain to fulfill this contract (e.g., SQF Level 2, FSSC 22000, BRC, GFSI-recognized standard).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Text describing the force majeure provisions that excuse performance due to unforeseeable circumstances (natural disasters, pandemics, war, government actions).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms clause where risk and cost transfer occurs (e.g., Port of Los Angeles, Chicago DC).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Mechanism' ;
    rdfs:comment 'Method by which contract prices may be adjusted over time. Index-linked ties to commodity indices; cost-plus adjusts based on supplier cost changes; fixed prices remain constant; periodic reviews allow renegotiation.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'Name of the commodity or inflation index used for price escalation (e.g., USDA Dairy Index, CPI, PPI, CME Corn Futures). Applicable when price_adjustment_mechanism is index_linked.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'Date until which the pricing conditions remain valid. After this date, prices may be renegotiated or adjusted per escalation clauses.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Date from which the pricing conditions in this contract become effective.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the buyer or procurement team responsible for managing this contract and related purchase orders.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Code or name of the purchasing organization or business unit responsible for this contract within the enterprise.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Flag' ;
    rdfs:comment 'Indicates whether this contract includes volume-based rebate or discount tiers that provide retroactive price reductions when volume thresholds are met.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate applied when volume commitments or spend thresholds are achieved. May be tiered based on volume levels.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to contract expiration that termination notice must be provided to prevent automatic renewal.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'Detailed spend classification for analytics and category management (e.g., Dairy Ingredients, Flexible Packaging, Transportation Services).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for early termination of the contract by either party.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum monetary value committed under this contract across all line items and purchase orders. For value contracts, this is the spending limit; for quantity contracts, this is the estimated total value.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Quantity' ;
    rdfs:comment 'Total quantity committed to be purchased over the contract period. Used for volume-based pricing tiers and rebate calculations.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the volume commitment quantity.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketPoValueLimit rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Value Limit' ;
    rdfs:comment 'Maximum cumulative value authorized for release against a blanket purchase order or framework agreement. Applicable only when po_type = \'blanket_release\'. Used for spend control and contract compliance monitoring. Maps to SAP EKKO-KTWRT.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full delivery address of the destination plant or DC where goods are to be received. Includes street, city, state/province, postal code, and country. Used for logistics coordination and ASN matching.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyHoldIndicator rdf:type rdf:Property ;
    rdfs:label 'Food Safety Hold Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order or its associated materials are currently under a food safety hold pending quality inspection, allergen verification, or HACCP review. When True, goods receipt and production use are blocked until cleared by QA. Supports FSMA and HACCP compliance.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether any item on this purchase order is classified as a hazardous material requiring special handling, labeling, or transport documentation under DOT, IATA, or IMDG regulations. Relevant for chemical ingredients, cleaning agents, and certain food additives.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceVerificationIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Indicator' ;
    rdfs:comment 'Flag indicating whether invoice-based verification (LIV - Logistics Invoice Verification) is required for this PO. When False, evaluated receipt settlement (ERS) may apply. Maps to SAP EKPO-REPOS.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the purchase order was formally issued and transmitted to the supplier. This is the principal BUSINESS_EVENT_TIMESTAMP (date precision) for the procurement transaction. Maps to SAP EKKO-BEDAT.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Po Gross Amount' ;
    rdfs:comment 'Total gross value of the purchase order before discounts, taxes, and freight charges, expressed in the PO currency. Represents the sum of all line-level extended prices. Part of the MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. \'draft\' = created but not submitted; \'pending_approval\' = in approval workflow; \'approved\' = approved and transmitted to supplier; \'open\' = active with outstanding delivery; \'partially_received\' = goods receipt posted for some lines; \'closed\' = fully received and invoiced; \'cancelled\' = voided before fulfillment. LIFECYCLE_STATUS canonical category. Maps to SAP EKKO processing status. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|partially_received|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement strategy. \'standard\' = one-time discrete PO; \'blanket_release\' = release against a blanket/framework agreement; \'subcontracting\' = toll manufacturing or co-packing arrangement where components are supplied to the vendor; \'service\' = service entry sheet-based PO for indirect services; \'consignment\' = vendor-managed inventory replenishment. Maps to SAP EKKO-BSART document type.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the buying organization requests delivery of the ordered goods or services at the destination plant or DC. Used for supply planning, OTIF measurement, and SLA tracking. Maps to SAP EKPO-EINDT.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemPoKey rdf:type rdf:Property ;
    rdfs:label 'Source System Po Key' ;
    rdfs:comment 'The native primary key or document number of the purchase order in the originating source system (e.g., SAP EKKO-EBELN or Oracle PO header ID). Used for cross-system reconciliation, data lineage tracing, and support ticket resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Ordered' ;
    rdfs:comment 'Total quantity of goods or services ordered across all lines of this purchase order, expressed in the base unit of measure (uom_code). Used for inventory planning, receiving, and OTIF measurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityReceived rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Received' ;
    rdfs:comment 'Cumulative quantity of goods received against this purchase order as of the latest goods receipt posting, expressed in the base unit of measure. Used to calculate open PO quantity, OTIF fill rate, and goods receipt variance.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tracegainsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tracegains Compliance Status' ;
    rdfs:comment 'Compliance status of the supplier for this purchase order as tracked in TraceGains, the supplier compliance and document management platform. Reflects whether required supplier documents (COA, SQF certificate, allergen declaration, FSMA compliance) are current and approved. \'compliant\' = all documents valid; \'non_compliant\' = missing or expired documents; \'pending_review\' = documents submitted but under review; \'not_required\' = compliance check not applicable.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Base unit of measure code for the purchase order quantity (e.g., KG, LB, L, EA, CS, PAL). Aligns with SAP base UOM and is used for inventory valuation, recipe/BOM costing, and nutritional compliance calculations. Maps to SAP EKPO-MEINS.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPurchaseRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Requestor Employee Id' ;
    rdfs:comment 'Identifier of the employee who created or submitted the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Identifier of the approval workflow instance governing this purchase requisition, tracking routing and approval steps.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the purchase requisition was converted to a purchase order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition, calculated as quantity requested multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of measure for the requested material or service, used for budgeting and approval workflows.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account number to which the procurement expense will be posted in the financial system.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Boolean flag indicating whether the purchase requisition has been logically deleted or marked for archival.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the material or service requested in the purchase requisition, expressed in the base unit of measure.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the requestor for communication and notifications regarding the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who requested the procurement.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials or services must be delivered to meet operational or production requirements.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted by the requestor.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows. Typically 10-character alphanumeric code from SAP MM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_converted|fully_converted|cancelled|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer between plants, service procurement, or third-party direct delivery.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingBidId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Bid Id' ;
    rdfs:comment 'Unique identifier for the sourcing bid record. Primary key for the sourcing bid entity.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Reference to the parent sourcing event (RFQ, RFP, or e-auction) for which this bid was submitted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents or attachments (e.g., certifications, technical specifications, compliance documents) submitted with this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date when the award decision was made for this bid line.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Award Recommendation Flag' ;
    rdfs:comment 'Indicates whether this bid is recommended for award based on evaluation criteria and bid scoring.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardedQuantity rdf:type rdf:Property ;
    rdfs:label 'Awarded Quantity' ;
    rdfs:comment 'Quantity awarded to the supplier if this bid was selected. Null if bid was not awarded.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNotes rdf:type rdf:Property ;
    rdfs:label 'Bid Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the supplier or procurement team regarding this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Reference Number' ;
    rdfs:comment 'External business identifier for the bid, typically assigned by the supplier or procurement system for tracking and audit purposes.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidScore rdf:type rdf:Property ;
    rdfs:label 'Bid Score' ;
    rdfs:comment 'Composite score assigned to this bid based on evaluation criteria (price, quality, lead time, sustainability, supplier performance). Used for competitive bid comparison and award decision.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current lifecycle status of the bid in the sourcing workflow.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Destination location or facility where the supplier will deliver the item or service.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Score' ;
    rdfs:comment 'Score component reflecting the quoted lead time and supplier\'s on-time delivery performance history.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceScore rdf:type rdf:Property ;
    rdfs:label 'Price Score' ;
    rdfs:comment 'Score component reflecting the competitiveness of the quoted price against evaluation criteria.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificationCodes rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Codes' ;
    rdfs:comment 'Comma-separated list of quality certifications cited by the supplier (e.g., SQF, GFSI, ISO 9001, HACCP, GMP, FSSC 22000).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Score component reflecting the quality certifications, compliance documentation, and quality track record of the supplier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quoted Lead Time Days' ;
    rdfs:comment 'Number of days the supplier requires to deliver the item or service after order placement.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Unit price quoted by the supplier for the item or service in this bid line.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the supplier submitted this bid response to the sourcing event.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Email' ;
    rdfs:comment 'Email address of the supplier representative for bid-related communication.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactName rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Name' ;
    rdfs:comment 'Name of the supplier representative who submitted or is responsible for this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactPhone rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Phone' ;
    rdfs:comment 'Phone number of the supplier representative for bid-related communication.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCommitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Sustainability Commitment Description' ;
    rdfs:comment 'Detailed description of the sustainability commitments or certifications provided by the supplier in this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Commitment Flag' ;
    rdfs:comment 'Indicates whether the supplier has committed to sustainability requirements (e.g., carbon neutrality, sustainable sourcing, ethical labor practices) in this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Score component reflecting the supplier\'s sustainability commitments and certifications cited in the bid.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the sourcing event was awarded to the winning supplier(s). Null if event is not yet awarded or was cancelled.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardRationale rdf:type rdf:Property ;
    rdfs:label 'Award Rationale' ;
    rdfs:comment 'Business justification and rationale for the award decision, documenting why the winning supplier(s) were selected based on evaluation criteria.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Spend Amount' ;
    rdfs:comment 'Total contracted spend amount awarded to winning supplier(s) as a result of this sourcing event. Null if event not yet awarded.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Spend Amount' ;
    rdfs:comment 'Historical or budgeted spend amount for the commodity or service being sourced, used as the baseline for calculating savings achieved through the event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Bid Opening Date' ;
    rdfs:comment 'Date and time when submitted bids are opened and made visible to the evaluation team. For sealed bid events, this is when confidentiality is lifted.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bidReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Bid Received Count' ;
    rdfs:comment 'Total number of bids or quotes actually submitted by suppliers before the deadline.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Deadline' ;
    rdfs:comment 'Date and time by which suppliers must submit their bids or quotes. No late submissions accepted after this timestamp.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buyerEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Email' ;
    rdfs:comment 'Email address of the procurement buyer for supplier inquiries and event correspondence.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Full name of the procurement buyer or category manager responsible for this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason for cancelling the sourcing event if status is Cancelled. Null for non-cancelled events.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Procurement commodity category being sourced (e.g., Raw Materials - Dairy, Packaging - Flexible Film, Indirect - MRO). Aligns with spend classification taxonomy.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySubcategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Subcategory' ;
    rdfs:comment 'Detailed subcategory within the commodity category for granular spend analytics and category management.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the contract resulting from this sourcing event, expressed in months. Null if event does not result in a long-term contract.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCriteriaLeadTimeWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Lead Time Weight' ;
    rdfs:comment 'Percentage weight assigned to lead time and delivery performance in the overall bid evaluation scoring model.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaPriceWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Price Weight' ;
    rdfs:comment 'Percentage weight assigned to price in the overall bid evaluation scoring model. Part of multi-criteria evaluation framework.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaQualityWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Quality Weight' ;
    rdfs:comment 'Percentage weight assigned to quality criteria (certifications, audit scores, defect rates) in the overall bid evaluation scoring model.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaSustainabilityWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Sustainability Weight' ;
    rdfs:comment 'Percentage weight assigned to sustainability commitments and environmental certifications in the overall bid evaluation scoring model.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation End Date' ;
    rdfs:comment 'Target or actual date when bid evaluation is completed and award decision is finalized.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when the formal evaluation of supplier bids begins, following bid opening.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed description of the sourcing event scope, requirements, and objectives. May include technical specifications, quality standards, and delivery expectations.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Descriptive title of the sourcing event, summarizing the scope and purpose for internal and supplier reference.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiYearContract rdf:type rdf:Property ;
    rdfs:label 'Is Multi Year Contract' ;
    rdfs:comment 'Boolean flag indicating whether the resulting contract spans multiple years (True) or is a single-year or spot buy (False).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participatingSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Participating Supplier Count' ;
    rdfs:comment 'Total number of suppliers invited to participate in the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementOrganization rdf:type rdf:Property ;
    rdfs:label 'Procurement Organization' ;
    rdfs:comment 'Procurement organization or business unit conducting the sourcing event (e.g., North America Procurement, EMEA Procurement, Global Indirect).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when the sourcing event was published and made available to invited suppliers.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresFssc22000Certification rdf:type rdf:Property ;
    rdfs:label 'Requires Fssc 22000 Certification' ;
    rdfs:comment 'Boolean flag indicating whether suppliers must hold FSSC 22000 certification to be eligible for award. Part of GFSI-recognized food safety standards.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresGmpCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Gmp Certification' ;
    rdfs:comment 'Boolean flag indicating whether suppliers must hold GMP (Good Manufacturing Practice) certification to be eligible for award. Critical for food safety compliance.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:savingsAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Amount' ;
    rdfs:comment 'Total cost savings achieved through the sourcing event, calculated as baseline spend minus awarded spend. Null if event not yet awarded.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Savings Percentage' ;
    rdfs:comment 'Percentage savings achieved relative to baseline spend. Calculated as (savings_amount / baseline_spend_amount) * 100.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Unique identifier of the sourcing event in the source operational system, used for traceability and reconciliation.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracegainsComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Tracegains Compliance Required' ;
    rdfs:comment 'Boolean flag indicating whether suppliers must maintain active compliance documentation in TraceGains (supplier compliance and document management system) to be eligible.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendTransactionId rdf:type rdf:Property ;
    rdfs:label 'Spend Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each procurement spend transaction record at the invoice/purchase order (PO) line level in the Silver Layer lakehouse. Primary key for the spend_transaction data product.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Internal Category Code' ;
    rdfs:comment 'Food Beverage internal commodity category code from the company\'s proprietary procurement taxonomy (e.g., RAW-ING-DAIRY, PKG-FLEX-FILM, IND-MRO). Used alongside UNSPSC for category management, sourcing strategy, and spend cube construction.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Number' ;
    rdfs:comment 'Line item number within the supplier invoice document corresponding to this spend transaction. Supports granular invoice-level spend reconciliation and dispute resolution.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContractSpend rdf:type rdf:Property ;
    rdfs:label 'Is Contract Spend' ;
    rdfs:comment 'Boolean flag indicating whether this spend transaction was executed under an approved procurement contract (True) or represents off-contract/maverick spend (False). Key metric for contract compliance rate and spend under management reporting.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment must be made to the supplier to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date and payment terms; stored for accounts payable aging and cash flow management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'Sequential line item number within the purchase order document identifying the specific goods or services line that generated this spend transaction. Enables granular PO line-level spend analysis.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppvAmount rdf:type rdf:Property ;
    rdfs:label 'Ppv Amount' ;
    rdfs:comment 'Purchase Price Variance (PPV) amount calculated as the difference between the actual invoice price and the standard cost, multiplied by the invoiced quantity. Positive PPV indicates overspend vs. standard; negative indicates savings. Key metric for procurement performance and COGS management.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the invoiced quantity (e.g., KG, LB, L, EA, CS, MT). Required for accurate spend-per-unit analysis, minimum order quantity (MOQ) compliance, and cross-supplier price benchmarking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Gross spend amount for this procurement transaction line in the transaction currency as invoiced by the supplier. Represents the actual purchase price multiplied by the invoiced quantity before any discounts or adjustments. Core metric for spend analytics and category management.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Spend Amount Local' ;
    rdfs:comment 'Spend amount converted to the company code local currency (e.g., USD for US entities) using the exchange rate at the time of posting. Enables consistent spend aggregation and reporting across multi-currency procurement transactions.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendClassification rdf:type rdf:Property ;
    rdfs:label 'Spend Classification' ;
    rdfs:comment 'High-level classification of the procurement spend indicating whether it is direct (raw materials, ingredients, packaging used in finished goods), indirect (MRO, services, overhead), capital expenditure (capex), or operating expenditure (opex). Critical dimension for spend analytics and financial reporting.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the currency in which the supplier invoice was issued (e.g., USD, EUR, GBP). Required for multi-currency spend analytics and foreign exchange exposure reporting.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit United Nations Standard Products and Services Code (UNSPSC) classifying the procured commodity or service into a standardized global taxonomy. Enables cross-supplier, cross-category spend benchmarking and category management.' ;
    rdfs:domain ind:SpendTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenControlProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Program Flag' ;
    rdfs:comment 'Indicates whether the supplier has a documented and audited allergen control program in place at their manufacturing facility. Critical for managing allergen cross-contact risk in the Food Beverage supply chain per FSMA Preventive Controls requirements.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedVendorListFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Flag' ;
    rdfs:comment 'Indicates whether the supplier is currently on the Approved Vendor List (AVL), meaning they have passed all required quality, food safety, and compliance assessments and are authorized to supply materials or services to Food Beverage.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Categorical outcome of the most recent supplier audit. A \'conditional_pass\' requires corrective action within a defined timeframe. A \'fail\' triggers supplier suspension pending remediation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Supplier diversity category indicating ownership classification for ESG reporting and supplier diversity program tracking. Used to measure spend with diverse suppliers as required by corporate sustainability commitments and certain customer contracts.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet Data Universal Numbering System (DUNS) nine-digit identifier for the supplier legal entity. Used for supplier financial risk screening, credit assessment, and global supplier deduplication.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Food Safety Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the supplier\'s primary food safety certification. Triggers automated re-certification alerts in TraceGains and may result in supplier suspension if not renewed before expiry.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure applicable to the MOQ field (e.g., KG, LB, CS, EA, L). Aligns with SAP S/4HANA base unit of measure for the purchasing info record.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which invoices from this supplier are settled. Drives foreign exchange exposure tracking and multi-currency accounts payable processing.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalRegistrationFlag rdf:type rdf:Property ;
    rdfs:label 'Portal Registration Flag' ;
    rdfs:comment 'Indicates whether the supplier has completed self-registration in Food Beverage\'s supplier portal (SAP Ariba or equivalent), enabling self-service document submission, invoice tracking, and compliance certificate uploads.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall supply chain risk rating assigned to the supplier based on food safety audit results, financial stability, geographic risk, single-source dependency, and regulatory compliance history. Used to prioritize supplier monitoring and contingency planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the sole approved source for one or more critical raw materials or ingredients. Single-source suppliers require enhanced risk monitoring, safety stock buffers, and business continuity planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Supplier Flag' ;
    rdfs:comment 'Indicates whether the supplier is classified as a strategic partner under Food Beverage\'s supplier relationship management (SRM) program, warranting executive-level engagement, joint business planning, and preferred sourcing status.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Strategic tier classification indicating the supplier\'s position in the supply chain hierarchy. Tier 1 suppliers have a direct commercial relationship with Food Beverage; Tier 2 and Tier 3 are sub-suppliers providing materials or services to Tier 1 suppliers.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier by the nature of goods or services provided. Direct material suppliers provide ingredients and packaging; co-packers and toll manufacturers produce finished goods; 3PL/logistics providers handle distribution; service providers cover indirect spend. [ENUM-REF-CANDIDATE: direct_material|indirect_material|co_packer|toll_manufacturer|3pl_logistics|service_provider — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracegainsSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Tracegains Supplier Code' ;
    rdfs:comment 'Unique supplier identifier assigned within the TraceGains supplier compliance and document management platform. Used to cross-reference food safety certifications, specification documents, and audit records between SAP and TraceGains.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or commercial trade name of the supplier, which may differ from the legal entity name. Used in commercial communications, purchase orders, and supplier-facing documents.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Id' ;
    rdfs:comment 'Unique identifier for the supplier audit record. Primary key for the supplier audit entity.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit Assignment process requires linking internal auditor employee to each supplier audit for accountability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditClosureDate rdf:type rdf:Property ;
    rdfs:label 'Audit Closure Date' ;
    rdfs:comment 'Date on which the audit and all associated Corrective Action and Preventive Action (CAPA) activities were formally closed, indicating all findings have been satisfactorily resolved.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit End Timestamp' ;
    rdfs:comment 'Precise date and time when the audit was concluded.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required frequency of audits for this supplier in months (e.g., 12 for annual, 24 for biennial), based on risk assessment and regulatory requirements.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or context related to the audit that do not fit into structured fields.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'External business identifier for the audit, used for tracking and communication with suppliers and auditors.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific processes, product categories, facility areas, and compliance standards evaluated during the audit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Start Timestamp' ;
    rdfs:comment 'Precise date and time when the on-site or remote audit commenced.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditorCertification rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification' ;
    rdfs:comment 'Professional certification or accreditation held by the auditor (e.g., GFSI-recognized, ISO 22000 Lead Auditor, HACCP Certified).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the third-party auditing organization or certification body that performed the audit (e.g., NSF, SGS, Bureau Veritas, Intertek).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Capa Approval Date' ;
    rdfs:comment 'Date on which the submitted Corrective Action and Preventive Action (CAPA) plan was reviewed and approved by the quality assurance team.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Date by which the supplier must submit their Corrective Action and Preventive Action (CAPA) response for all audit findings.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Boolean indicator of whether Corrective Action and Preventive Action (CAPA) is required based on audit findings. True if any findings require formal CAPA response.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date on which the supplier submitted their Corrective Action and Preventive Action (CAPA) response documentation.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Date' ;
    rdfs:comment 'Date on which the effectiveness of the implemented Corrective Action and Preventive Action (CAPA) was verified.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Method' ;
    rdfs:comment 'Method used to verify that the supplier has effectively implemented the Corrective Action and Preventive Action (CAPA) plan (e.g., document review, follow-up audit, remote verification, supplier self-assessment, photographic evidence, test results).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Status' ;
    rdfs:comment 'Current status of the Corrective Action and Preventive Action (CAPA) verification process (e.g., pending, verified effective, verified ineffective, requires additional action, closed).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Total number of critical non-conformances identified during the audit. Critical findings represent immediate food safety or quality risks requiring urgent corrective action.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Address' ;
    rdfs:comment 'Complete physical address of the audited supplier facility, including street, city, state/province, and postal code.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the location of the audited facility (e.g., USA, MEX, CHN, DEU).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Recognized Flag' ;
    rdfs:comment 'Boolean indicator of whether this audit was conducted under a Global Food Safety Initiative (GFSI)-recognized certification scheme (e.g., SQF, BRC, FSSC 22000, IFS).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Total number of major non-conformances identified during the audit. Major findings represent significant deviations from standards that could lead to food safety or quality issues.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Total number of minor non-conformances identified during the audit. Minor findings represent low-risk deviations that should be addressed but do not pose immediate threats.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Planned date for the next scheduled audit of this supplier facility, based on audit frequency requirements and previous audit outcomes.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Total number of observations or opportunities for improvement noted during the audit that do not constitute non-conformances but represent best practice recommendations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierRiskId rdf:type rdf:Property ;
    rdfs:label 'Supplier Risk Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier risk assessment record. Primary key for this entity.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Reference to the supplier master record against which this risk is assessed.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualSpend rdf:type rdf:Property ;
    rdfs:label 'Annual Spend' ;
    rdfs:comment 'Total annual procurement spend with this supplier in the reporting currency, used to contextualize the financial significance of the risk and prioritize mitigation investment. Sourced from SAP S/4HANA spend analytics.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVendorListStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Status' ;
    rdfs:comment 'Current status of the supplier on the Approved Vendor List (AVL) at the time of risk assessment. A risk event may trigger a change from approved to conditional or suspended status. Aligns with TraceGains supplier qualification workflows.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingReference rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Reference' ;
    rdfs:comment 'Reference number or identifier linking this risk record to a specific supplier audit finding, non-conformance report (NCR), or corrective action request (CAR) from a GMP, SQF, or GFSI audit.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Contingency Lead Time Days' ;
    rdfs:comment 'Estimated number of days required to activate and onboard the contingency supplier and resume supply in the event the primary supplier fails. Used in business continuity planning and safety stock calculations.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFinancialExposure rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Exposure' ;
    rdfs:comment 'Estimated monetary value of the business impact if the risk event materializes, expressed in the reporting currency. Includes potential supply disruption costs, expediting fees, reformulation costs, and lost revenue. Used in risk prioritization and EBITDA impact analysis.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated_financial_exposure amount (e.g., USD, EUR, GBP). Supports multi-currency risk reporting.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStabilityRating rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Rating' ;
    rdfs:comment 'External or internally-assessed financial stability rating for the supplier (e.g., Dun & Bradstreet PAYDEX, credit rating agency score, or internal procurement rating). Indicates risk of supplier insolvency or financial distress impacting supply continuity.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Food Safety Risk Flag' ;
    rdfs:comment 'Indicates whether this risk record involves a food safety dimension, including HACCP critical control point failures, allergen cross-contamination risk, microbiological contamination (CFU exceedance), or GMP non-compliance. Triggers mandatory escalation per FSMA and GFSI protocols.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Fsma Verification Required' ;
    rdfs:comment 'Indicates whether this risk triggers a mandatory FSMA Foreign Supplier Verification Program (FSVP) or domestic supplier verification activity under 21 CFR Part 117. True = verification activity required.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geopoliticalRegion rdf:type rdf:Property ;
    rdfs:label 'Geopolitical Region' ;
    rdfs:comment 'Geographic region or country (ISO 3166-1 alpha-3 code) where the supplier operates, used to assess geopolitical, trade, and climate-related risk exposure for agricultural commodities and raw material sourcing.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Calendar date on which the supplier risk was first formally identified and logged in the risk register. Used for aging analysis and risk trend reporting.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Numeric score (1–5) representing the assessed severity of business impact if the risk event materializes. 1 = negligible, 5 = catastrophic. Considers supply disruption, financial loss, food safety, and regulatory exposure.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isSingleSource rdf:type rdf:Property ;
    rdfs:label 'Is Single Source' ;
    rdfs:comment 'Indicates whether this supplier is the sole approved source for the associated material or ingredient, creating a single-source dependency risk. True = single source; False = multiple qualified sources exist. Critical for business continuity planning.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Numeric score (1–5) representing the assessed probability that the identified risk event will materialize within the review horizon. 1 = rare, 5 = almost certain. Used in risk matrix calculations.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Completed Date' ;
    rdfs:comment 'Actual date on which the mitigation strategy was fully executed and verified. Compared against mitigation_target_date to measure timeliness of risk treatment.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current execution status of the mitigation strategy for this risk. Tracks whether corrective or preventive actions have been initiated, are in progress, completed, or placed on hold.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Documented strategy to reduce or eliminate the identified risk, including actions such as dual-sourcing, safety stock build, supplier development programs, contractual protections, or regulatory corrective action plans.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Target Date' ;
    rdfs:comment 'Target completion date for the mitigation strategy actions. Used to track on-time execution of risk treatment plans and escalate overdue mitigations.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryComplianceRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Risk Flag' ;
    rdfs:comment 'Indicates whether this risk involves a regulatory compliance dimension, such as FDA labeling violations, USDA inspection failures, EFSA authorization issues, or FSSC 22000 certification lapses. Triggers compliance review workflows.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Risk rating remaining after mitigation actions have been applied. Represents the accepted level of risk exposure post-treatment. Distinct from risk_rating which reflects the inherent (pre-mitigation) risk level.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Broader business category grouping for the risk, used for portfolio-level risk reporting and supply chain resilience dashboards. Distinct from risk_type which captures the specific risk driver.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClosedDate rdf:type rdf:Property ;
    rdfs:label 'Risk Closed Date' ;
    rdfs:comment 'Date on which the risk was formally closed, either through successful mitigation, risk acceptance, or supplier disqualification. Null if the risk remains open.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the identified risk, including the specific risk event, root cause drivers, and potential business consequences. Authored by the procurement risk analyst.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOpenDate rdf:type rdf:Property ;
    rdfs:label 'Risk Open Date' ;
    rdfs:comment 'Date on which the risk record was formally opened and entered into the active risk register. May differ from identified_date if there is a lag between identification and formal registration.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskOwner rdf:type rdf:Property ;
    rdfs:label 'Risk Owner' ;
    rdfs:comment 'Name or employee identifier of the procurement professional or category manager accountable for monitoring and managing this supplier risk. Aligns with risk ownership principles in ISO 31000.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the risk record, used in cross-functional communications, audit trails, and regulatory submissions. Format: SR-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskReviewer rdf:type rdf:Property ;
    rdfs:label 'Risk Reviewer' ;
    rdfs:comment 'Name or employee identifier of the individual who conducted the most recent risk review or assessment. Distinct from risk_owner who holds ongoing accountability.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the supplier risk record. Tracks progression from initial identification through mitigation, acceptance, or closure. Drives workflow routing in procurement risk management processes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Classification of the risk category associated with the supplier. Covers geopolitical instability, financial stability of the supplier, food safety and HACCP compliance failures, single-source dependency exposure, climate or weather-driven agricultural commodity risk, and regulatory compliance risk (FDA, FSMA, EFSA). [ENUM-REF-CANDIDATE: geopolitical|financial_stability|food_safety|single_source_dependency|climate_weather|regulatory_compliance — promote to reference product]' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyCategory rdf:type rdf:Property ;
    rdfs:label 'Supply Category' ;
    rdfs:comment 'Procurement spend category or commodity group associated with this risk (e.g., raw ingredients, packaging materials, indirect services, agricultural commodities). Aligns with the procurement category hierarchy in SAP S/4HANA MM.' ;
    rdfs:domain ind:SupplierRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierScorecardId rdf:type rdf:Property ;
    rdfs:label 'Supplier Scorecard Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier performance scorecard record. Primary key. Entity role: TRANSACTION_HEADER — a periodic business event capturing quantitative KPI snapshots across quality, delivery, service, cost, and compliance dimensions for a supplier.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Scorecard evaluation is performed by internal employees; linking evaluator enables performance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Allergen Compliance Rate' ;
    rdfs:comment 'Percentage of shipments where the supplier\'s allergen matrix declarations matched the received product\'s actual allergen profile during the evaluation period. Critical food safety KPI under FDA FSMA and EU Food Information Regulation.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'Current status of the supplier on the Approved Vendor List (AVL) as determined by this scorecard evaluation. Approved: cleared for procurement; Conditional: approved with restrictions; Suspended: temporarily blocked pending corrective action; Removed: delisted.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Rate' ;
    rdfs:comment 'Percentage of inbound shipments accompanied by a valid, specification-compliant Certificate of Analysis (CoA) during the evaluation period. Mandatory for food-grade raw materials and ingredients under FDA FSMA and GFSI requirements.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Weighted performance score for the regulatory and food safety compliance dimension, incorporating audit results, certificate currency, FSMA/HACCP documentation completeness, and allergen matrix accuracy. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan (CAP) has been triggered as a result of this scorecard evaluation. True when overall score or any critical dimension falls below the defined threshold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costScore rdf:type rdf:Property ;
    rdfs:label 'Cost Score' ;
    rdfs:comment 'Weighted performance score for the cost dimension, incorporating invoice accuracy, pricing compliance against contract, and cost reduction contribution. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Critical Nonconformance Count' ;
    rdfs:comment 'Number of non-conformances classified as critical severity (e.g., food safety risk, allergen contamination, HACCP critical control point failure) during the evaluation period. Critical NCRs may trigger immediate supplier suspension.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRatePpm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Ppm' ;
    rdfs:comment 'Number of defective or rejected units per one million units received from the supplier during the evaluation period. Industry-standard quality metric (PPM). Sourced from SAP QM goods receipt inspection results.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'Last calendar date of the performance measurement window covered by this scorecard. Defines the inclusive end of the data aggregation period for all KPI calculations.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'First calendar date of the performance measurement window covered by this scorecard. Defines the inclusive start of the data aggregation period for all KPI calculations.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Frequency classification of the scorecard evaluation cycle. Quarterly scorecards are standard for strategic suppliers; annual for approved vendor list (AVL) renewal; ad-hoc for corrective action follow-up.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity actually delivered by the supplier during the evaluation period. Measures supply availability and capacity reliability. Calculated as (quantity delivered / quantity ordered) × 100.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyAuditResult rdf:type rdf:Property ;
    rdfs:label 'Food Safety Audit Result' ;
    rdfs:comment 'Outcome of the most recent food safety audit conducted against the supplier during or immediately preceding the evaluation period. Audits may be conducted under GFSI-benchmarked schemes (SQF, BRC, FSSC 22000) or internal GMP standards.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertificationScheme rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Scheme' ;
    rdfs:comment 'GFSI-benchmarked or regulatory food safety certification scheme under which the supplier is currently certified. Determines the rigor of the supplier\'s food safety management system and influences AVL approval status. [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|ISO_22000|HACCP|GMP|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of supplier invoices that matched the corresponding purchase order and goods receipt without discrepancy during the evaluation period. Sourced from SAP FI three-way match results.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimePerformanceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Performance Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier met the agreed lead time (from PO issuance to confirmed delivery) during the evaluation period. Complements OTIF by isolating the lead time adherence component.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count' ;
    rdfs:comment 'Total number of non-conformance reports (NCRs) raised against this supplier during the evaluation period. Includes quality deviations, specification failures, and food safety non-conformances logged in SAP QM or TraceGains.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifRate rdf:type rdf:Property ;
    rdfs:label 'Otif Rate' ;
    rdfs:comment 'Percentage of purchase order lines delivered both on time and in full quantity during the evaluation period. Industry-standard KPI for supply chain reliability. Calculated as (OTIF deliveries / total deliveries) × 100.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite weighted performance score for the supplier across all evaluation dimensions (quality, delivery, service, cost, compliance) for the evaluation period. Expressed as a percentage (0.00–100.00). Drives supplier tiering and AVL renewal decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceRate rdf:type rdf:Property ;
    rdfs:label 'Price Variance Rate' ;
    rdfs:comment 'Percentage deviation of actual invoiced prices from contracted purchase prices during the evaluation period. Positive values indicate supplier overcharging; negative values indicate favorable pricing. Sourced from SAP MM/FI purchase price variance analysis.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Qualitative-to-quantitative score (0.00–100.00) measuring the supplier\'s speed and quality of response to inquiries, issue escalations, corrective action requests, and change notifications during the evaluation period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Date' ;
    rdfs:comment 'The principal business event date on which the scorecard was formally issued or generated. Distinct from the evaluation period dates and from audit timestamps.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Externally-known business identifier for the scorecard document, formatted as SC-{YYYY}-{NNNNNN}. Used for cross-referencing in SAP MM supplier evaluation reports and TraceGains compliance documents.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current workflow lifecycle state of the scorecard. Draft: data being compiled; In Review: under procurement/quality review; Approved: signed off by category manager; Published: shared with supplier; Archived: superseded by newer period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScore rdf:type rdf:Property ;
    rdfs:label 'Service Score' ;
    rdfs:comment 'Weighted performance score for the service dimension, incorporating responsiveness score, issue resolution time, and communication quality. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Compliance Rate' ;
    rdfs:comment 'Percentage of inbound shipments meeting the minimum remaining shelf life requirement at time of receipt, as defined in the supplier specification and procurement contract. Supports FEFO inventory management.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the supplier has formally acknowledged receipt and acceptance of the scorecard results. Required for closed-loop supplier performance management and dispute resolution.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Classification of the supplier by the type of goods or services procured. Drives which KPI weights and thresholds apply in the scorecard model. Co-packer and toll manufacturer categories are specific to food and beverage outsourced production. [ENUM-REF-CANDIDATE: raw_material|ingredient|packaging|indirect|co_packer|toll_manufacturer|service — promote to reference product]' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Letter-grade rating of the supplier\'s environmental, social, and governance (ESG) performance, including carbon footprint, water usage, ethical sourcing, and packaging recyclability. Increasingly required for Scope 3 emissions reporting and retailer sustainability mandates.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseOrders rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders' ;
    rdfs:comment 'Total number of purchase orders (POs) issued to this supplier during the evaluation period. Provides volume context for interpreting rate-based KPIs such as OTIF rate and invoice accuracy rate.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total procurement spend with this supplier during the evaluation period in the reporting currency. Used for spend analytics, strategic sourcing prioritization, and COGS impact assessment.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualProductionCapacity rdf:type rdf:Property ;
    rdfs:label 'Annual Production Capacity' ;
    rdfs:comment 'Declared annual production or throughput capacity of the supplier site in the site\'s primary unit of measure. Used for supply assurance assessments, dual-sourcing decisions, and demand planning stress tests.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether the supplier site holds a current Hazard Analysis Critical Control Points (HACCP) certification. Required for sites supplying direct food ingredients or food-contact packaging.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityContactName rdf:type rdf:Property ;
    rdfs:label 'Quality Contact Name' ;
    rdfs:comment 'Full name of the quality or food safety contact at the supplier site. Used for HACCP documentation requests, corrective action plan (CAP) communications, and audit coordination.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Procurement risk classification for the supplier site based on factors including food safety criticality, single-source dependency, geographic risk, and spend concentration. Drives audit frequency, safety stock levels, and contingency sourcing plans.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this supplier site, used in purchase orders, EDI transactions, and ASN communications. Corresponds to the vendor sub-range or delivery address code in SAP MM.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteEmail rdf:type rdf:Property ;
    rdfs:label 'Site Email' ;
    rdfs:comment 'Primary email address for the supplier site, used for purchase order transmission, ASN notifications, and compliance document requests via TraceGains.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the supplier site (e.g., \'Acme Ingredients — Chicago Plant\', \'Global Packaging — Rotterdam DC\'). Used in procurement documents, scorecards, and audit reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitePhone rdf:type rdf:Property ;
    rdfs:label 'Site Phone' ;
    rdfs:comment 'Primary telephone number for the supplier site, used for procurement communications, quality escalations, and logistics coordination.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the supplier site record. Controls whether the site is eligible for purchase order creation and sourcing. \'suspended\' indicates a temporary hold pending audit or corrective action.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the supplier site by its primary operational function. Drives sourcing decisions, compliance requirements, and audit frequency. [ENUM-REF-CANDIDATE: manufacturing_plant|warehouse|distribution_hub|co_packer|toll_manufacturer|service_delivery|laboratory|office — promote to reference product]' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Formulation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks employee owning formulation for BOM, needed in formulation approval and cost allocation.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchSizeMaximum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Maximum' ;
    rdfs:comment 'The largest production batch size that can be manufactured using this BOM. Driven by equipment capacity, mixing vessel size, or quality control limits.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Minimum' ;
    rdfs:comment 'The smallest production batch size that can be manufactured using this BOM. Driven by equipment constraints, minimum order quantities (MOQ) for ingredients, or quality requirements.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, externally known and used across manufacturing, procurement, and quality systems. Unique within the manufacturing site or globally depending on business rules.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM based on its manufacturing context. Production BOMs are for standard in-house manufacturing, co-pack BOMs are for third-party co-packing arrangements, toll manufacturing BOMs are for contract manufacturing, rework BOMs are for reprocessing, sample BOMs are for R&D samples, and trial BOMs are for new product development trials.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsGmoFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Gmo Flag' ;
    rdfs:comment 'Indicates whether this formulation contains genetically modified ingredients. Used for labeling compliance and consumer transparency.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Amount' ;
    rdfs:comment 'Estimated cost of goods sold (COGS) for producing one base quantity of this BOM. Calculated from ingredient costs, packaging costs, and manufacturing overhead. Used for pricing, margin analysis, and product profitability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost estimate amount. Typically the local currency of the manufacturing plant.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plm Approval Date' ;
    rdfs:comment 'The date when the BOM received final PLM approval. Nullable for BOMs that have not yet been approved.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Plm Approval Status' ;
    rdfs:comment 'Approval status from the PLM system indicating whether this BOM has passed cross-functional review by R&D, quality, regulatory, and operations teams. Required before a BOM can be activated for production.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this formulation requires pre-market regulatory approval or notification before production and sale. Applicable for novel ingredients, health claims, or regulated product categories.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date when this BOM revision was created or last modified. Used for audit trails and change tracking.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version identifier for the BOM. Incremented each time the formulation is changed. Supports traceability and change history for regulatory compliance and quality management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBomSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Supplier Id' ;
    rdfs:comment 'Foreign key reference to the primary or preferred supplier for this component, used for procurement planning and vendor management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'The base unit of measure for the component quantity (e.g., KG, LB, L, GAL, EA, M, FT).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line (active, inactive, pending approval, obsolete).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'The engineering change order or product lifecycle management (PLM) change number that authorized this BOM line modification, used for traceability and compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCategory rdf:type rdf:Property ;
    rdfs:label 'Component Category' ;
    rdfs:comment 'Classification of the component type within the BOM structure (e.g., raw material, ingredient, packaging, label, co-product). [ENUM-REF-CANDIDATE: raw_material|ingredient|flavoring|preservative|packaging|label|co_product|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Human-readable description of the component material, including brand, grade, or specification details.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentItemNumber rdf:type rdf:Property ;
    rdfs:label 'Component Item Number' ;
    rdfs:comment 'The material number or SKU code of the component (raw material, ingredient, packaging, label, or co-product) required for production.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalAllergenFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or is derived from a major food allergen (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame) requiring allergen matrix tracking and labeling compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glutenFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Flag' ;
    rdfs:comment 'Indicates whether this component is certified gluten-free (less than 20 ppm gluten), used for gluten-free product formulation and FDA labeling compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before production start that this component must be available, used for procurement planning and scheduling.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeMultiple rdf:type rdf:Property ;
    rdfs:label 'Lot Size Multiple' ;
    rdfs:comment 'The lot size increment in which this component must be ordered (e.g., multiples of 100 units), used for procurement planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonGmoFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Flag' ;
    rdfs:comment 'Indicates whether this component is verified as non-GMO, used for clean label claims and consumer transparency.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityPerBaseUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Base Uom' ;
    rdfs:comment 'The quantity of this component required to produce one unit of the parent finished good, expressed in the base unit of measure.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veganFlag rdf:type rdf:Property ;
    rdfs:label 'Vegan Flag' ;
    rdfs:comment 'Indicates whether this component is free from all animal-derived ingredients, used for vegan product formulation and labeling.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit' ;
    rdfs:comment 'Unit of measure for batch size: kg (kilogram), L (liter), gal (gallon), lb (pound).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Compliant Flag' ;
    rdfs:comment 'Indicates whether this formulation meets clean label criteria (no artificial ingredients, preservatives, or additives). True if compliant, False otherwise.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingTemperature rdf:type rdf:Property ;
    rdfs:label 'Cooling Temperature' ;
    rdfs:comment 'Target cooling temperature in degrees Celsius after thermal processing. Critical for product safety and quality preservation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this formulation specification. Used across R&D, PLM, and manufacturing systems.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable name or title of the formulation specification. Typically includes product name and variant descriptor.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Status' ;
    rdfs:comment 'Current lifecycle status of the formulation: draft (in development), under_review (pending approval), approved (ready for use), active (in production), obsolete (no longer used), superseded (replaced by newer version).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Classification of the formulation stage: bench (lab-scale R&D), pilot (pilot plant trial), commercial (approved for production), experimental (early research), prototype (concept validation), scale_up (transitioning to commercial scale).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingTime rdf:type rdf:Property ;
    rdfs:label 'Holding Time' ;
    rdfs:comment 'Required holding time in minutes at specified temperature or condition before next processing step. Critical for chemical reactions, flavor development, or safety.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homogenizationPressure rdf:type rdf:Property ;
    rdfs:label 'Homogenization Pressure' ;
    rdfs:comment 'Target homogenization pressure in pounds per square inch (PSI) for emulsion stability and particle size reduction. Critical for dairy and beverage products.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingSpeed rdf:type rdf:Property ;
    rdfs:label 'Mixing Speed' ;
    rdfs:comment 'Target mixing speed in revolutions per minute (RPM) for blending operations. Critical for achieving proper dispersion and emulsification.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingTime rdf:type rdf:Property ;
    rdfs:label 'Mixing Time' ;
    rdfs:comment 'Required mixing or blending time in minutes to achieve homogeneous formulation. Critical process parameter for quality consistency.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentTarget rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Target' ;
    rdfs:comment 'Target moisture content as percentage of total weight. Critical for shelf life, texture, and microbial stability in dry and semi-moist products.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pasteurizationTemperature rdf:type rdf:Property ;
    rdfs:label 'Pasteurization Temperature' ;
    rdfs:comment 'Target pasteurization temperature in degrees Celsius for thermal processing. Critical control point (CCP) under HACCP for pathogen elimination.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pasteurizationTime rdf:type rdf:Property ;
    rdfs:label 'Pasteurization Time' ;
    rdfs:comment 'Target pasteurization hold time in seconds at specified temperature. Critical control point (CCP) under HACCP for achieving required lethality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory approval was granted for this formulation. Required for compliance tracking and audit trails.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetBrix rdf:type rdf:Property ;
    rdfs:label 'Target Brix' ;
    rdfs:comment 'Target sugar content measurement in degrees Brix for this formulation. Critical quality parameter for beverages and sweet products. Measured as percentage of dissolved solids.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhMax rdf:type rdf:Property ;
    rdfs:label 'Target Ph Max' ;
    rdfs:comment 'Maximum acceptable pH (acidity/alkalinity) level for this formulation. Critical for food safety, shelf life, and organoleptic properties. Scale 0-14.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhMin rdf:type rdf:Property ;
    rdfs:label 'Target Ph Min' ;
    rdfs:comment 'Minimum acceptable pH (acidity/alkalinity) level for this formulation. Critical for food safety, shelf life, and organoleptic properties. Scale 0-14.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetViscosity rdf:type rdf:Property ;
    rdfs:label 'Target Viscosity' ;
    rdfs:comment 'Target viscosity measurement for this formulation in centipoise (cP). Critical for product texture, mouthfeel, and processing characteristics.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityUnit rdf:type rdf:Property ;
    rdfs:label 'Viscosity Unit' ;
    rdfs:comment 'Unit of measure for viscosity specification: cP (centipoise), mPa·s (millipascal-second), Pa·s (pascal-second).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterActivityAw rdf:type rdf:Property ;
    rdfs:label 'Water Activity Aw' ;
    rdfs:comment 'Target water activity (Aw) level for this formulation. Scale 0.0-1.0. Critical food safety parameter controlling microbial growth. Values below 0.85 inhibit most pathogens.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Unique identifier for each GTIN registry record. Primary key for the GTIN registry data product.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Associates GTIN registry changes with employee, needed for traceability and audit logs.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which this GTIN became active and available for commercial use in transactions, scanning, and EDI. May differ from assignment date if there is a staging period.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barcodeSymbology rdf:type rdf:Property ;
    rdfs:label 'Barcode Symbology' ;
    rdfs:comment 'The specific barcode encoding format used to represent this GTIN on the physical packaging. Determines the visual barcode pattern printed on labels and packaging materials.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwnerGln rdf:type rdf:Property ;
    rdfs:label 'Brand Owner Gln' ;
    rdfs:comment 'The 13-digit GS1 Global Location Number identifying the legal entity that owns the brand associated with this GTIN. Used for supply chain partner identification and EDI transactions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesPerPallet rdf:type rdf:Property ;
    rdfs:label 'Cases Per Pallet' ;
    rdfs:comment 'The standard number of cases stacked on one pallet when this GTIN represents a pallet-level packaging tier. Used for transportation planning and warehouse slotting.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The single-digit checksum calculated using the GS1 check digit algorithm to validate the integrity of the GTIN. Always the last digit of the GTIN.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment 'The 13-digit EAN barcode number used internationally (especially Europe) for consumer unit scanning. Equivalent to GTIN-13 format.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'The total weight of the trade item including product, packaging, and any inner materials, expressed in kilograms. Used for logistics planning, freight calculations, and warehouse capacity management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gs1CompanyPrefix rdf:type rdf:Property ;
    rdfs:label 'Gs1 Company Prefix' ;
    rdfs:comment 'The unique company prefix assigned by GS1 to the brand owner or manufacturer. This prefix is the first segment of all GTINs issued by this company and identifies the organization globally within the GS1 system.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1RegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registration Date' ;
    rdfs:comment 'The date on which this GTIN was registered with GS1. Required for compliance with GS1 standards and for inclusion in the GS1 Global Registry.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gs1RegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registration Status' ;
    rdfs:comment 'Indicates whether this GTIN has been formally registered with GS1 and is in good standing. Registration is required for global trade and ensures GTIN uniqueness across the industry.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinChangeReason rdf:type rdf:Property ;
    rdfs:label 'Gtin Change Reason' ;
    rdfs:comment 'Free-text explanation of why this GTIN was assigned or changed. GS1 rules require a new GTIN when there are material changes to formulation, net content, allergens, or packaging that affect consumer purchasing decisions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinStatus rdf:type rdf:Property ;
    rdfs:label 'Gtin Status' ;
    rdfs:comment 'Current lifecycle status of this GTIN assignment. Active GTINs are in commercial use, pending are awaiting launch, reserved are allocated but not yet assigned, retired are discontinued, and recalled are withdrawn from market.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinType rdf:type rdf:Property ;
    rdfs:label 'Gtin Type' ;
    rdfs:comment 'The specific GTIN format variant used for this trade item. GTIN-8 for small items, GTIN-12 for UPC (North America consumer units), GTIN-13 for EAN (international consumer units), GTIN-14 for case and pallet codes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUnit rdf:type rdf:Property ;
    rdfs:label 'Is Base Unit' ;
    rdfs:comment 'Boolean flag indicating whether this GTIN represents the base unit of measure for inventory and sales tracking. Typically the each or consumer unit level. All other packaging levels are multiples of the base unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsumerUnit rdf:type rdf:Property ;
    rdfs:label 'Is Consumer Unit' ;
    rdfs:comment 'Boolean flag indicating whether this GTIN represents a consumer-facing unit intended for individual sale at retail point of sale. Consumer units require full regulatory labeling including nutritional panels and allergen declarations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Boolean flag indicating whether this GTIN can be ordered directly by customers or retailers. Some GTINs (e.g., display shippers) may be non-orderable and exist only for scanning and tracking purposes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemReference rdf:type rdf:Property ;
    rdfs:label 'Item Reference' ;
    rdfs:comment 'The company-assigned portion of the GTIN that uniquely identifies the specific product within the company prefix namespace. Combined with company prefix and check digit to form the complete GTIN.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerGln rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Gln' ;
    rdfs:comment 'The 13-digit GS1 Global Location Number identifying the physical manufacturing location or co-packer that produces the item with this GTIN. May differ from brand owner for toll manufacturing arrangements.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentUom rdf:type rdf:Property ;
    rdfs:label 'Net Content Uom' ;
    rdfs:comment 'The unit of measure for the net content value. Must comply with regulatory requirements for the target market (metric for most international markets, US customary for USA). [ENUM-REF-CANDIDATE: g|kg|mg|oz|lb|ml|l|fl_oz|gal|count|each — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'The numeric quantity of product contained in this packaging level, expressed in the unit specified by net_content_uom. Required for regulatory labeling and consumer transparency.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'The weight of the product itself excluding all packaging materials, expressed in kilograms. Required for nutritional labeling calculations and regulatory compliance.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDepthCm rdf:type rdf:Property ;
    rdfs:label 'Package Depth Cm' ;
    rdfs:comment 'The front-to-back depth dimension of the trade item packaging in centimeters. Used for warehouse slotting, planogram design, and transportation cube calculations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageHeightCm rdf:type rdf:Property ;
    rdfs:label 'Package Height Cm' ;
    rdfs:comment 'The vertical dimension of the trade item packaging in centimeters. Used for warehouse slotting, planogram design, and transportation cube calculations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageWidthCm rdf:type rdf:Property ;
    rdfs:label 'Package Width Cm' ;
    rdfs:comment 'The horizontal width dimension of the trade item packaging in centimeters. Used for warehouse slotting, planogram design, and transportation cube calculations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'The hierarchical packaging tier that this GTIN represents within the product packaging hierarchy. Each level from consumer unit up to pallet requires a unique GTIN for supply chain traceability and EDI transactions. [ENUM-REF-CANDIDATE: each|consumer_unit|inner_pack|display_shipper|case|master_case|pallet|mixed_pallet — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorGtin rdf:type rdf:Property ;
    rdfs:label 'Predecessor Gtin' ;
    rdfs:comment 'The previous GTIN that this GTIN replaces, if applicable. Used to maintain continuity in sales history and retailer item setup when a GTIN change is required per GS1 rules.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresFreezing rdf:type rdf:Property ;
    rdfs:label 'Requires Freezing' ;
    rdfs:comment 'Boolean flag indicating whether this trade item must be stored and transported under frozen conditions. Drives frozen supply chain and warehouse requirements.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRefrigeration rdf:type rdf:Property ;
    rdfs:label 'Requires Refrigeration' ;
    rdfs:comment 'Boolean flag indicating whether this trade item must be stored and transported under refrigerated conditions to maintain food safety and quality. Drives cold chain logistics requirements.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'The maximum safe storage temperature for this trade item in degrees Celsius. Critical for cold chain compliance and food safety management per HACCP principles.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'The minimum safe storage temperature for this trade item in degrees Celsius. Critical for cold chain compliance and food safety management per HACCP principles.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsPerCase rdf:type rdf:Property ;
    rdfs:label 'Units Per Case' ;
    rdfs:comment 'The number of consumer units (each) contained within one case when this GTIN represents a case-level packaging tier. Used for order quantity calculations and warehouse management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelSpecId rdf:type rdf:Property ;
    rdfs:label 'Label Spec Id' ;
    rdfs:comment 'Unique identifier for the label specification record. Primary key for the label specification entity.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artworkApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Artwork Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Links artwork approval to employee for GMP and brand compliance reporting.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adhesiveType rdf:type rdf:Property ;
    rdfs:label 'Adhesive Type' ;
    rdfs:comment 'Type of adhesive used on the label. Critical for packaging line performance and consumer experience, especially for refrigerated or frozen products.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenWarningText rdf:type rdf:Property ;
    rdfs:label 'Allergen Warning Text' ;
    rdfs:comment 'Mandatory allergen declaration text listing major food allergens present in the product or manufacturing facility. Required by FSMA (Food Safety Modernization Act) and FALCPA (Food Allergen Labeling and Consumer Protection Act).' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Artwork Approval Date' ;
    rdfs:comment 'Date when the label artwork received final approval and was released for production use.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:artworkApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Artwork Approval Status' ;
    rdfs:comment 'Current approval status of the label artwork in the PLM workflow. Tracks progression through legal, regulatory, and quality reviews before production release. [ENUM-REF-CANDIDATE: draft|pending_review|legal_review|regulatory_review|approved|rejected|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkFilePath rdf:type rdf:Property ;
    rdfs:label 'Artwork File Path' ;
    rdfs:comment 'File system path or URI to the approved digital artwork file for this label specification. Used by printing vendors and packaging lines.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'Type of barcode symbology used on the label for product identification and traceability. Must align with retail and supply chain scanning requirements.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeValue rdf:type rdf:Property ;
    rdfs:label 'Barcode Value' ;
    rdfs:comment 'Numeric value encoded in the barcode. Typically the GTIN (Global Trade Item Number), UPC (Universal Product Code), or EAN (European Article Number) for the SKU.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributorAddress rdf:type rdf:Property ;
    rdfs:label 'Distributor Address' ;
    rdfs:comment 'Physical address of the distributor if different from the manufacturer. Required for co-packed or toll manufactured products.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorName rdf:type rdf:Property ;
    rdfs:label 'Distributor Name' ;
    rdfs:comment 'Legal name of the distributor if different from the manufacturer. Used when products are co-packed or toll manufactured.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelHeightMm rdf:type rdf:Property ;
    rdfs:label 'Label Height Mm' ;
    rdfs:comment 'Physical height of the label in millimeters. Critical for printing specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Classification of the label by its position and purpose on the product packaging. Determines which regulatory and marketing content is required. [ENUM-REF-CANDIDATE: front_panel|back_panel|nutrition_panel|ingredient_panel|neck_label|cap_label|case_label|pallet_label|promotional_sticker — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version identifier for the label specification. Tracks revisions and updates to label artwork, claims, or regulatory text. Incremented with each approved change.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelWidthMm rdf:type rdf:Property ;
    rdfs:label 'Label Width Mm' ;
    rdfs:comment 'Physical width of the label in millimeters. Critical for printing specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandatoryClaimText rdf:type rdf:Property ;
    rdfs:label 'Mandatory Claim Text' ;
    rdfs:comment 'Legally required text that must appear on the label per regulatory jurisdiction. Includes statements mandated by FDA, USDA, EFSA, or other governing bodies.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Physical address of the manufacturer or distributor. Required on label for consumer contact and regulatory traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuantityStatement rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Statement' ;
    rdfs:comment 'Regulatory-compliant statement of the net quantity of contents in the package. Must include both metric and US customary units where required by jurisdiction.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printVendorCode rdf:type rdf:Property ;
    rdfs:label 'Print Vendor Code' ;
    rdfs:comment 'Identifier for the approved printing vendor responsible for producing this label. Used for vendor management and quality traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeUrl rdf:type rdf:Property ;
    rdfs:label 'Qr Code Url' ;
    rdfs:comment 'URL encoded in the QR code on the label. Typically links to product information, traceability data, or consumer engagement content.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingInstructions rdf:type rdf:Property ;
    rdfs:label 'Recycling Instructions' ;
    rdfs:comment 'Consumer-facing instructions for proper disposal and recycling of the package and label. Required in many jurisdictions for environmental compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code identifying the regulatory jurisdiction for which this label specification is designed. Determines applicable food safety and labeling laws.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Instructions for special handling, storage, or preparation of the product. Examples include refrigeration requirements, shake before use, or heating instructions.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Substrate Material' ;
    rdfs:comment 'Type of material used for the label substrate. Impacts sustainability reporting, recycling instructions, and environmental compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClaimText rdf:type rdf:Property ;
    rdfs:label 'Sustainability Claim Text' ;
    rdfs:comment 'Marketing claims related to sustainability, environmental impact, or corporate social responsibility. Must be substantiated per FTC (Federal Trade Commission) Green Guides.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Reference identifier for the formal approval document, change request, or workflow instance that authorized this lifecycle event. Links to PLM, quality management, or regulatory systems for traceability.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which customer notification was completed (e.g., EDI 832 Price/Sales Catalog sent, ASN updated, or direct communication sent). Null if notification is not required or still pending.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this lifecycle event requires formal notification to retail customers, distributors, or foodservice partners. True for discontinuations, allergen changes, or major repacks.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Current status of the customer notification process for this lifecycle event. Tracks whether downstream partners (retailers, distributors, 3PLs) have been informed of the change.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of this lifecycle event in the company\'s reporting currency. Positive for cost savings or revenue opportunities; negative for write-offs, obsolescence, or lost sales. Used for portfolio management and business case validation.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessmentCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Completed Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a formal cross-functional impact assessment (covering quality, supply chain, finance, regulatory, and commercial) was completed before this lifecycle event was approved.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Reference' ;
    rdfs:comment 'Reference identifier for the impact assessment document or workflow instance. Links to PLM or quality management system for detailed analysis and stakeholder sign-offs.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryWriteOffRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Write Off Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this lifecycle event triggers an inventory write-off or obsolescence charge. True for permanent discontinuations, regulatory holds, or major reformulations requiring disposal of existing stock.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newAllergenMatrix rdf:type rdf:Property ;
    rdfs:label 'New Allergen Matrix' ;
    rdfs:comment 'Comma-separated list or structured representation of allergens declared for the SKU after this lifecycle event. Used to track allergen additions, removals, or cross-contamination risk changes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newGtin rdf:type rdf:Property ;
    rdfs:label 'New Gtin' ;
    rdfs:comment 'The 14-digit GTIN assigned to the SKU after this lifecycle event. Used when a material change (formula, packaging, allergen) requires a new GTIN per GS1 standards.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPlmStage rdf:type rdf:Property ;
    rdfs:label 'New Plm Stage' ;
    rdfs:comment 'The PLM stage or product status that the SKU transitioned to as a result of this lifecycle event. Captures the \'to\' state in the state transition.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newProductName rdf:type rdf:Property ;
    rdfs:label 'New Product Name' ;
    rdfs:comment 'The consumer-facing product name or description that became effective after this lifecycle event. Used for rebranding, label updates, or marketing claim changes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'New Shelf Life Days' ;
    rdfs:comment 'The number of days of shelf life assigned to the SKU after this lifecycle event. Used when reformulation, packaging change, or preservative adjustment impacts product stability.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newUpc rdf:type rdf:Property ;
    rdfs:label 'New Upc' ;
    rdfs:comment 'The 12-digit UPC assigned to the SKU after this lifecycle event. Used when packaging or product changes require a new UPC.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAllergenMatrix rdf:type rdf:Property ;
    rdfs:label 'Prior Allergen Matrix' ;
    rdfs:comment 'Comma-separated list or structured representation of allergens (e.g., milk, eggs, peanuts, tree nuts, soy, wheat, fish, shellfish) that were declared for the SKU before this lifecycle event. Critical for reformulation and regulatory hold events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorGtin rdf:type rdf:Property ;
    rdfs:label 'Prior Gtin' ;
    rdfs:comment 'The 14-digit GTIN that was assigned to the SKU before this lifecycle event. Captured for repack, label change, or reformulation events where GTIN may change per GS1 standards.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPlmStage rdf:type rdf:Property ;
    rdfs:label 'Prior Plm Stage' ;
    rdfs:comment 'The PLM stage or product status that the SKU was in immediately before this lifecycle event occurred. Captures the \'from\' state in the state transition for historical analysis.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorProductName rdf:type rdf:Property ;
    rdfs:label 'Prior Product Name' ;
    rdfs:comment 'The consumer-facing product name or description that was in use before this lifecycle event. Captured for label change, reformulation, or rebranding events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Prior Shelf Life Days' ;
    rdfs:comment 'The number of days of shelf life that was assigned to the SKU before this lifecycle event. Captured for reformulation or specification change events that impact product stability.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorUpc rdf:type rdf:Property ;
    rdfs:label 'Prior Upc' ;
    rdfs:comment 'The 12-digit UPC that was assigned to the SKU before this lifecycle event. Captured for North American market SKUs undergoing repack or label changes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority was formally notified of this lifecycle event. Null if no notification was required. Used for compliance audit and FSMA traceability.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Reference' ;
    rdfs:comment 'Reference number or confirmation code received from the regulatory authority upon notification submission. Used for audit trail and compliance evidence.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this lifecycle event requires formal notification to regulatory authorities (FDA, USDA, EFSA, etc.). True for events impacting food safety, allergens, or nutritional claims.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'Name or code of the business unit, division, or brand team that owns and initiated this lifecycle event. Used for accountability, reporting hierarchy, and cross-functional coordination.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Notification Date' ;
    rdfs:comment 'Date on which internal supply chain systems (ERP, WMS, MES) were updated and stakeholders notified of the lifecycle event. Used for operational readiness tracking.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyChainNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Notification Status' ;
    rdfs:comment 'Current status of internal supply chain notification for this lifecycle event. Tracks whether manufacturing, distribution centers, and logistics partners have been informed and systems updated.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringReasonCode rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason Code' ;
    rdfs:comment 'Standardized code representing the primary business driver or root cause that initiated this lifecycle event. Used for trend analysis, portfolio management, and regulatory inquiries. [ENUM-REF-CANDIDATE: regulatory_change|cost_reduction|consumer_complaint|market_exit|retailer_delisting|quality_issue|supply_disruption|strategic_portfolio_review|innovation_pipeline|seasonal_demand|competitive_response|sustainability_initiative|allergen_management|nutrition_improvement|packaging_optimization|end_of_contract|low_sales_volume|manufacturing_constraint|ingredient_availability|merger_acquisition|brand_rationalization|channel_strategy — 22 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Triggering Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the specific circumstances, business context, or regulatory requirement that triggered this lifecycle event. Provides narrative detail beyond the standardized reason code.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npdProjectId rdf:type rdf:Property ;
    rdfs:label 'Npd Project Id' ;
    rdfs:comment 'Unique identifier for the NPD project record. Primary key.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNpdExistingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Npd Existing Sku Id' ;
    rdfs:comment 'Identifier of the existing SKU being reformulated or renovated. Null for net-new products.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:rdLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rd Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assigns R&D lead employee for NPD project, required for project governance and resource planning.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date when the product was commercially launched. Null if not yet launched.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessCaseApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Business Case Approved Flag' ;
    rdfs:comment 'Indicates whether the business case for this project has been formally approved by leadership.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalInvestmentRequired rdf:type rdf:Property ;
    rdfs:label 'Capital Investment Required' ;
    rdfs:comment 'Total capital investment required for equipment, tooling, or facility modifications to support the new product.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumerAcceptanceScore rdf:type rdf:Property ;
    rdfs:label 'Consumer Acceptance Score' ;
    rdfs:comment 'Overall consumer acceptance score from sensory panel testing, typically on a scale of 1-9 (hedonic scale) or percentage acceptance.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumerTestingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Consumer Testing Completion Date' ;
    rdfs:comment 'Date when consumer testing was completed. Null if not yet completed or not applicable.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Testing Required Flag' ;
    rdfs:comment 'Indicates whether consumer sensory testing or market research is required for this project.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCogsImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cogs Impact' ;
    rdfs:comment 'Estimated change in COGS per unit resulting from reformulation (positive for cost increase, negative for cost reduction).' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedIncrementalRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Incremental Revenue' ;
    rdfs:comment 'Projected incremental annual revenue expected from the new product launch in the first full year.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateDecision rdf:type rdf:Property ;
    rdfs:label 'Gate Decision' ;
    rdfs:comment 'Decision outcome from the most recent gate review (Go: proceed to next stage, Conditional Go: proceed with conditions, Hold: pause, Kill: terminate, Recycle: return to previous stage).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStage rdf:type rdf:Property ;
    rdfs:label 'Gate Stage' ;
    rdfs:comment 'Current stage-gate milestone in the NPD process (Gate 0: Idea, Gate 1: Concept, Gate 2: Feasibility, Gate 3: Development, Gate 4: Validation, Gate 5: Launch, Post-Launch Review). [ENUM-REF-CANDIDATE: gate_0|gate_1|gate_2|gate_3|gate_4|gate_5|post_launch_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationType rdf:type rdf:Property ;
    rdfs:label 'Innovation Type' ;
    rdfs:comment 'Classification of the innovation level: breakthrough (new-to-world), platform (new-to-company), derivative (line extension), or packaging-only change.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Gate Review Date' ;
    rdfs:comment 'Date of the most recent stage-gate review meeting for this project.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingLead rdf:type rdf:Property ;
    rdfs:label 'Marketing Lead' ;
    rdfs:comment 'Name of the marketing manager responsible for brand positioning, consumer insights, and go-to-market strategy for the project.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Gate Review Date' ;
    rdfs:comment 'Scheduled date for the next stage-gate review meeting.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCloseDate rdf:type rdf:Property ;
    rdfs:label 'Project Close Date' ;
    rdfs:comment 'Date when the NPD project was formally closed after commercialization or cancellation.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the NPD project for tracking and reference across PLM, ERP, and project management systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed description of the NPD project objectives, scope, and key deliverables.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the NPD project describing the innovation or renovation initiative.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPriority rdf:type rdf:Property ;
    rdfs:label 'Project Priority' ;
    rdfs:comment 'Business priority level assigned to the NPD project for resource allocation and portfolio management.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSponsor rdf:type rdf:Property ;
    rdfs:label 'Project Sponsor' ;
    rdfs:comment 'Name of the executive or senior leader sponsoring and accountable for the NPD project.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Date when the NPD project was officially initiated and resources allocated.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the NPD project in the stage-gate process from concept through commercialization. [ENUM-REF-CANDIDATE: concept|feasibility|development|validation|launch|commercialized|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the NPD project type indicating the nature of the product development initiative. [ENUM-REF-CANDIDATE: new_sku|line_extension|reformulation|repack|cost_reduction|seasonal_limited_edition|co_brand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reformulationFlag rdf:type rdf:Property ;
    rdfs:label 'Reformulation Flag' ;
    rdfs:comment 'Indicates whether this project involves reformulation of an existing SKU (True) or is a net-new product (False).' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date when regulatory submission was filed with FDA, USDA, or other governing body. Null if not applicable.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCogs rdf:type rdf:Property ;
    rdfs:label 'Target Cogs' ;
    rdfs:comment 'Target cost of goods sold per unit for the new product, used for financial feasibility and margin planning.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Target Distribution Channel' ;
    rdfs:comment 'Primary distribution channel targeted for the new product launch. [ENUM-REF-CANDIDATE: retail|foodservice|direct_to_consumer|e_commerce|club|convenience|mass_merchandiser — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned date for commercial launch of the product resulting from this NPD project.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarketGeography rdf:type rdf:Property ;
    rdfs:label 'Target Market Geography' ;
    rdfs:comment 'Geographic market or region where the product will be launched (e.g., USA, CAN, MEX, EUR).' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRsp rdf:type rdf:Property ;
    rdfs:label 'Target Rsp' ;
    rdfs:comment 'Target recommended selling price per unit for the new product at retail.' ;
    rdfs:domain ind:NpdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalPanelId rdf:type rdf:Property ;
    rdfs:label 'Nutritional Panel Id' ;
    rdfs:comment 'Primary key for nutritional_panel' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedSugarsDvPercent rdf:type rdf:Property ;
    rdfs:label 'Added Sugars Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for added sugars per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addedSugarsGrams rdf:type rdf:Property ;
    rdfs:label 'Added Sugars Grams' ;
    rdfs:comment 'Added sugar content per serving, expressed in grams. Required under updated FDA regulations (2016+).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:additionalNutrientsJson rdf:type rdf:Property ;
    rdfs:label 'Additional Nutrients Json' ;
    rdfs:comment 'JSON-formatted string capturing additional vitamins, minerals, and nutrients not covered by standard fields (e.g., Vitamin B6, B12, Zinc, Magnesium, Folate). Allows flexibility for jurisdiction-specific or voluntary nutrient declarations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calciumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Calcium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for calcium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calciumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Calcium Milligrams' ;
    rdfs:comment 'Calcium content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caloriesFromFat rdf:type rdf:Property ;
    rdfs:label 'Calories From Fat' ;
    rdfs:comment 'Calories derived from fat per serving. Required in some jurisdictions (e.g., older FDA format), optional in others.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caloriesPerServing rdf:type rdf:Property ;
    rdfs:label 'Calories Per Serving' ;
    rdfs:comment 'Total caloric energy per serving, expressed in kilocalories (kcal).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cholesterolDvPercent rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for cholesterol per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cholesterolMilligrams rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Milligrams' ;
    rdfs:comment 'Cholesterol content per serving, expressed in milligrams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dietaryFiberDvPercent rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for dietary fiber per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dietaryFiberGrams rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber Grams' ;
    rdfs:comment 'Dietary fiber content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the FDA submission or notification associated with this nutritional panel. Critical for FSMA compliance and audit trail.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientStatement rdf:type rdf:Property ;
    rdfs:label 'Ingredient Statement' ;
    rdfs:comment 'Full ingredient list as it appears on the nutritional panel or label, in descending order of predominance by weight.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironDvPercent rdf:type rdf:Property ;
    rdfs:label 'Iron Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for iron per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMilligrams rdf:type rdf:Property ;
    rdfs:label 'Iron Milligrams' ;
    rdfs:comment 'Iron content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Reference' ;
    rdfs:comment 'Reference number or identifier for the third-party laboratory analysis report that substantiates the nutritional values declared on this panel.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monounsaturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Monounsaturated Fat Grams' ;
    rdfs:comment 'Monounsaturated fat content per serving, expressed in grams. Voluntary declaration in most jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelFormatStandard rdf:type rdf:Property ;
    rdfs:label 'Panel Format Standard' ;
    rdfs:comment 'The regulatory format standard that this nutritional panel follows (e.g., FDA Nutrition Facts, EU Nutrition Declaration, Health Canada Nutrition Facts).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the nutritional panel record (draft, pending approval, approved, active, superseded, retired).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelVersion rdf:type rdf:Property ;
    rdfs:label 'Panel Version' ;
    rdfs:comment 'Version number of the nutritional panel to track changes over time due to formulation updates or regulatory changes. Format: major.minor (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyunsaturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Polyunsaturated Fat Grams' ;
    rdfs:comment 'Polyunsaturated fat content per serving, expressed in grams. Voluntary declaration in most jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Potassium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for potassium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Potassium Milligrams' ;
    rdfs:comment 'Potassium content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinDvPercent rdf:type rdf:Property ;
    rdfs:label 'Protein Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for protein per serving. Optional unless a protein claim is made.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinGrams rdf:type rdf:Property ;
    rdfs:label 'Protein Grams' ;
    rdfs:comment 'Protein content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'The rounding methodology applied to nutritional values per regulatory requirements (e.g., FDA Standard, EU Standard, Custom).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturatedFatDvPercent rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for saturated fat per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat Grams' ;
    rdfs:comment 'Saturated fat content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSize rdf:type rdf:Property ;
    rdfs:label 'Serving Size' ;
    rdfs:comment 'The standardized serving size for this product as displayed on the nutritional panel, including unit of measure (e.g., 1 cup (240 mL), 2 cookies (30g)).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeGrams rdf:type rdf:Property ;
    rdfs:label 'Serving Size Grams' ;
    rdfs:comment 'Numeric serving size expressed in grams for standardized analysis and comparison across products.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingsPerContainer rdf:type rdf:Property ;
    rdfs:label 'Servings Per Container' ;
    rdfs:comment 'Number of servings contained in the package. May be a decimal for products with variable servings (e.g., about 2.5).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Sodium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for sodium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Sodium Milligrams' ;
    rdfs:comment 'Sodium content per serving, expressed in milligrams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sugarAlcoholsGrams rdf:type rdf:Property ;
    rdfs:label 'Sugar Alcohols Grams' ;
    rdfs:comment 'Sugar alcohol content per serving, expressed in grams. Voluntary declaration unless a sugar-related claim is made.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateDvPercent rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for total carbohydrate per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateGrams rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate Grams' ;
    rdfs:comment 'Total carbohydrate content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatDvPercent rdf:type rdf:Property ;
    rdfs:label 'Total Fat Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for total fat per serving, based on a 2,000 calorie diet (FDA) or reference intake (EU).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatGrams rdf:type rdf:Property ;
    rdfs:label 'Total Fat Grams' ;
    rdfs:comment 'Total fat content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsGrams rdf:type rdf:Property ;
    rdfs:label 'Total Sugars Grams' ;
    rdfs:comment 'Total sugar content per serving, expressed in grams. Includes naturally occurring and added sugars.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatGrams rdf:type rdf:Property ;
    rdfs:label 'Trans Fat Grams' ;
    rdfs:comment 'Trans fat content per serving, expressed in grams. Must be declared even if no daily value is established.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Usda Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the USDA submission or approval associated with this nutritional panel, applicable for meat, poultry, and egg products.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminAIu rdf:type rdf:Property ;
    rdfs:label 'Vitamin A Iu' ;
    rdfs:comment 'Vitamin A content per serving, expressed in international units. Voluntary under updated FDA regulations but may be required in other jurisdictions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminCMilligrams rdf:type rdf:Property ;
    rdfs:label 'Vitamin C Milligrams' ;
    rdfs:comment 'Vitamin C content per serving, expressed in milligrams. Voluntary under updated FDA regulations but may be required in other jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDDvPercent rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for Vitamin D per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMicrograms rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Micrograms' ;
    rdfs:comment 'Vitamin D content per serving, expressed in micrograms. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingSpecId rdf:type rdf:Property ;
    rdfs:label 'Packaging Spec Id' ;
    rdfs:comment 'Unique identifier for the packaging specification record.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingComplianceId rdf:type rdf:Property ;
    rdfs:label 'Packaging Compliance Id' ;
    rdfs:comment 'Foreign key linking to regulatory.packaging_compliance. Business justification: Packaging compliance verification requires each packaging spec to reference the compliance record for material and recycling regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingCompliance .

ind:barrierProperties rdf:type rdf:Property ;
    rdfs:label 'Barrier Properties' ;
    rdfs:comment 'Description of the packaging barrier characteristics (oxygen barrier, moisture barrier, light barrier, gas barrier) critical for shelf life preservation.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioBasedContentPercent rdf:type rdf:Property ;
    rdfs:label 'Bio Based Content Percent' ;
    rdfs:comment 'Percentage of bio-based or renewable material content in the packaging, supporting clean label and sustainability initiatives.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bpaFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Bpa Free Flag' ;
    rdfs:comment 'Indicates whether the packaging is free from Bisphenol A (BPA), supporting clean label and consumer health claims.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casesPerLayer rdf:type rdf:Property ;
    rdfs:label 'Cases Per Layer' ;
    rdfs:comment 'Number of cases in one horizontal layer on a pallet, used for pallet pattern optimization and warehouse slotting.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childResistantFlag rdf:type rdf:Property ;
    rdfs:label 'Child Resistant Flag' ;
    rdfs:comment 'Indicates whether the packaging meets child-resistant packaging standards per CPSC regulations (applicable for certain products).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure or sealing mechanism (e.g., screw cap, snap lid, pull tab, peel seal, twist-off, cork, pump dispenser).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compostableCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compostable Certified Flag' ;
    rdfs:comment 'Indicates whether the packaging is certified compostable per ASTM D6400 or EN 13432 standards.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Specific form of the packaging container (e.g., bottle, can, pouch, jar, tray, carton, bag, tube).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthMm rdf:type rdf:Property ;
    rdfs:label 'Depth Mm' ;
    rdfs:comment 'Depth of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Diameter of cylindrical packaging containers in millimeters (applicable for bottles, cans, jars).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Ml' ;
    rdfs:comment 'Nominal fill volume of liquid or semi-liquid products in milliliters, as declared on the label.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodContactApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Contact Approved Flag' ;
    rdfs:comment 'Indicates whether the packaging material is approved for direct food contact per FDA and EU regulations.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freezerSafeFlag rdf:type rdf:Property ;
    rdfs:label 'Freezer Safe Flag' ;
    rdfs:comment 'Indicates whether the packaging is suitable for freezer storage without material degradation or product quality loss.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossWeightG rdf:type rdf:Property ;
    rdfs:label 'Gross Weight G' ;
    rdfs:comment 'Total weight including product and packaging in grams, used for freight cost calculation and logistics planning.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Height of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelPanelCount rdf:type rdf:Property ;
    rdfs:label 'Label Panel Count' ;
    rdfs:comment 'Number of distinct label panels on the packaging (front, back, side panels) used for regulatory compliance and marketing content.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:layersPerPallet rdf:type rdf:Property ;
    rdfs:label 'Layers Per Pallet' ;
    rdfs:comment 'Number of vertical layers stacked on a standard pallet, used for pallet pattern optimization and transportation planning.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Primary material composition of the packaging component (e.g., PET, HDPE, glass, aluminum, paperboard, flexible film). [ENUM-REF-CANDIDATE: PET|HDPE|LDPE|PP|PS|PVC|glass|aluminum|steel|paperboard|corrugated|flexible_film|multi_layer_laminate|biodegradable — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microwaveSafeFlag rdf:type rdf:Property ;
    rdfs:label 'Microwave Safe Flag' ;
    rdfs:comment 'Indicates whether the packaging is certified safe for microwave heating, relevant for Ready-to-Eat (RTE) products.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightG rdf:type rdf:Property ;
    rdfs:label 'Net Weight G' ;
    rdfs:comment 'Net weight of the product content excluding packaging in grams, as declared on the nutritional panel.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date when this packaging specification was or will be retired from active use.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingSpecStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Spec Status' ;
    rdfs:comment 'Current lifecycle status of the packaging specification in the Product Lifecycle Management (PLM) system.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPattern rdf:type rdf:Property ;
    rdfs:label 'Pallet Pattern' ;
    rdfs:comment 'Description of the case arrangement pattern on the pallet (e.g., column stack, interlocked, pinwheel) for load stability and cube optimization.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletTiHi rdf:type rdf:Property ;
    rdfs:label 'Pallet Ti Hi' ;
    rdfs:comment 'Pallet configuration expressed as Ti (cases per layer) x Hi (layers per pallet), standard logistics notation.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrContentPercent rdf:type rdf:Property ;
    rdfs:label 'Pcr Content Percent' ;
    rdfs:comment 'Percentage of post-consumer recycled material in the packaging, used for sustainability reporting and environmental compliance.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recyclabilityCode rdf:type rdf:Property ;
    rdfs:label 'Recyclability Code' ;
    rdfs:comment 'Resin identification code (1-7) indicating the material recyclability classification per ISO 1043 and local recycling standards.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Unique business identifier for the packaging specification used in Product Lifecycle Management (PLM) and Manufacturing Execution System (MES).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specVersion rdf:type rdf:Property ;
    rdfs:label 'Spec Version' ;
    rdfs:comment 'Version number of the packaging specification to track revisions and changes over time.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:srpConfiguration rdf:type rdf:Property ;
    rdfs:label 'Srp Configuration' ;
    rdfs:comment 'Configuration type for shelf-ready packaging that allows direct placement on retail shelves without additional unpacking.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidentFlag rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Flag' ;
    rdfs:comment 'Indicates whether the packaging includes tamper-evident features (e.g., safety seal, breakable cap, shrink band) per FDA requirements.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tareWeightG rdf:type rdf:Property ;
    rdfs:label 'Tare Weight G' ;
    rdfs:comment 'Weight of the empty packaging material in grams, used for sustainability reporting and material cost analysis.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Width of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentNodeHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Hierarchy Id' ;
    rdfs:comment 'Reference to the parent node in the hierarchy structure. Null for top-level Division nodes. Enables recursive hierarchy traversal and roll-up reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:allergenCategory rdf:type rdf:Property ;
    rdfs:label 'Allergen Category' ;
    rdfs:comment 'High-level allergen classification for products in this hierarchy node (e.g., \'Contains Dairy\', \'Gluten-Free\', \'Nut-Free Facility\'). Used for allergen matrix management and regulatory labeling compliance. [ENUM-REF-CANDIDATE: contains_milk|contains_eggs|contains_fish|contains_shellfish|contains_tree_nuts|contains_peanuts|contains_wheat|contains_soybeans|allergen_free — promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwner rdf:type rdf:Property ;
    rdfs:label 'Brand Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the brand or product line represented by this hierarchy node. Used for financial reporting, royalty tracking, and portfolio management.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCaptainFlag rdf:type rdf:Property ;
    rdfs:label 'Category Captain Flag' ;
    rdfs:comment 'Indicates whether this brand or product line holds category captain status with key retail partners. Category captains lead category management initiatives and planogram optimization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Strategy' ;
    rdfs:comment 'Primary distribution channel strategy for products in this hierarchy node. Retail includes grocery and mass merchandisers; DSD is Direct Store Delivery; foodservice includes restaurants and institutions; ecommerce includes online retail; convenience includes c-stores and gas stations; club includes warehouse clubs; natural includes natural/organic specialty stores. [ENUM-REF-CANDIDATE: retail|foodservice|dsd|ecommerce|convenience|club|natural|specialty — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depth rdf:type rdf:Property ;
    rdfs:label 'Depth' ;
    rdfs:comment 'Numeric depth of this node in the hierarchy tree, with Division=1, Category=2, etc. Used for hierarchy navigation and reporting level filtering.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of this hierarchy node. Active nodes are in use for classification and reporting; inactive nodes are historical; pending nodes are planned but not yet launched; discontinued nodes represent retired product lines.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationPlatformFlag rdf:type rdf:Property ;
    rdfs:label 'Innovation Platform Flag' ;
    rdfs:comment 'Indicates whether this hierarchy node represents an innovation platform for New Product Development (NPD). Innovation platforms receive priority for R&D investment and accelerated commercialization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iriCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iri Category Code' ;
    rdfs:comment 'IRI syndicated data category code mapping for this hierarchy node. Enables integration with IRI panel data and assortment analytics. Aligns with IRI category taxonomy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelCode rdf:type rdf:Property ;
    rdfs:label 'Level Code' ;
    rdfs:comment 'Code indicating the level of this node within the product hierarchy structure. Defines whether this node represents a Division, Category, Sub-Category, Brand, Sub-Brand, Product Line, Variant, or Pack Size. [ENUM-REF-CANDIDATE: DIVISION|CATEGORY|SUBCATEGORY|BRAND|SUBBRAND|PRODUCTLINE|VARIANT|PACKSIZE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Category Code' ;
    rdfs:comment 'Nielsen syndicated data category code mapping for this hierarchy node. Enables integration with Nielsen market tracking data and competitive benchmarking. Aligns with Nielsen category taxonomy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Detailed description of this hierarchy node, including its scope, purpose, and business context within the product portfolio.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full hierarchical path from root to this node, typically formatted as slash-delimited string (e.g., \'/Beverages/RTD/Premium Cola/Diet/12oz\'). Enables efficient ancestor queries and reporting roll-ups.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Tier' ;
    rdfs:comment 'Strategic portfolio classification for this hierarchy node. Core brands receive sustained investment; growth brands receive accelerated investment; emerging brands are in test-and-learn phase; harvest brands are managed for cash flow; divest brands are planned for exit.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'FDA or USDA regulatory category for products in this hierarchy node (e.g., \'Conventional Food\', \'Dietary Supplement\', \'Meat Product\', \'Beverage - Non-Alcoholic\'). Determines applicable regulatory requirements and labeling standards.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort sequence for displaying this node among its siblings at the same hierarchy level. Used for consistent ordering in reports, planograms, and user interfaces.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether products under this hierarchy node carry third-party sustainability certifications (Rainforest Alliance, Fair Trade, B Corp, etc.). Used for ESG reporting and marketing claims.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetConsumerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment' ;
    rdfs:comment 'Primary consumer demographic or psychographic segment targeted by products in this hierarchy node. Examples: \'Health-Conscious Millennials\', \'Family Households\', \'Premium Adult Consumers\'. Used for marketing strategy and trade promotion planning.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStandardCostId rdf:type rdf:Property ;
    rdfs:label 'Product Standard Cost Id' ;
    rdfs:comment 'Primary key for standard_cost' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copackerTollFee rdf:type rdf:Property ;
    rdfs:label 'Copacker Toll Fee' ;
    rdfs:comment 'Third-party manufacturing fee per unit when production is outsourced to a co-packer or toll manufacturer. Includes processing fee, packaging service, and contract manufacturing markup. Zero for internally manufactured SKUs.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Per Unit' ;
    rdfs:comment 'Difference between current standard cost per unit and prior period cost per unit. Positive values indicate cost increases; negative values indicate cost reductions. Key metric for cost management and margin protection.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage change in standard cost per unit compared to prior period. Calculated as (cost_variance_per_unit / prior_period_cost_per_unit) * 100. Used for executive dashboards and cost escalation alerts.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'Identifies the type of cost record: current standard (active production cost), prior year (historical comparison), budget (annual plan), forecast (updated projection), planned (future state), or actual (realized cost). Enables variance analysis and cost trend tracking.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'Inventory valuation method applied to this SKU: standard (predetermined cost), average (moving average), First In First Out (FIFO), Last In First Out (LIFO), or weighted average. Determines how inventory is valued on the balance sheet.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingRunDate rdf:type rdf:Property ;
    rdfs:label 'Costing Run Date' ;
    rdfs:comment 'The date on which the cost estimate was executed and this standard cost was calculated. Supports cost history tracking and regulatory compliance for cost substantiation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Overhead Cost' ;
    rdfs:comment 'Allocated manufacturing overhead per unit including utilities, equipment depreciation, plant supervision, maintenance, quality assurance, and facility costs. Allocated based on cost center rates and activity drivers per Good Manufacturing Practice (GMP) standards.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Total cost of all packaging materials per unit including primary packaging (bottles, pouches, wrappers), secondary packaging (cartons, trays), and tertiary packaging (pallets, shrink wrap). Sourced from BOM packaging line items.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Prior Period Cost Per Unit' ;
    rdfs:comment 'Total standard cost per unit from the previous costing period. Enables period-over-period variance analysis and cost trend tracking for Earnings Before Interest Taxes Depreciation and Amortization (EBITDA) reporting.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardCostPerCase rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost Per Case' ;
    rdfs:comment 'Fully-loaded standard cost per case or shipping unit. Calculated as total_standard_cost_per_unit multiplied by units per case. Primary cost metric for trade promotion Return on Investment (ROI) analysis and Distribution Center (DC) valuation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost Per Unit' ;
    rdfs:comment 'Fully-loaded standard cost per individual unit (e.g., per bottle, per pouch, per bar). Sum of raw material, packaging, direct labor, manufacturing overhead, co-packer fee, and freight-in costs. Used for unit-level profitability analysis and Recommended Selling Price (RSP) calculation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeSpecId rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Spec Id' ;
    rdfs:comment 'Unique identifier for the shelf life specification record. Primary key for this entity.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceleratedTestingFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Testing Flag' ;
    rdfs:comment 'Indicates whether the shelf life was determined using accelerated shelf life testing methods rather than real-time aging studies.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerDateFormat rdf:type rdf:Property ;
    rdfs:label 'Consumer Date Format' ;
    rdfs:comment 'Format pattern for the consumer-facing date label (e.g., MM/DD/YYYY, DD-MMM-YYYY). Must comply with regional open-dating regulations.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerDateLabelType rdf:type rdf:Property ;
    rdfs:label 'Consumer Date Label Type' ;
    rdfs:comment 'Type of date label printed on consumer packaging. Best By indicates peak quality date, Use By indicates safety date, Sell By is for retailer inventory management, Expires On indicates absolute expiration.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Date Calculation Method' ;
    rdfs:comment 'Method used to calculate the best-by or use-by date. Manufacture_plus_offset adds shelf life days to manufacture date, fixed_calendar uses a predetermined calendar date, batch_specific requires manual entry per batch.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcReceivingStandard rdf:type rdf:Property ;
    rdfs:label 'Dc Receiving Standard' ;
    rdfs:comment 'Specific receiving standard or policy that distribution centers must enforce when accepting this product (e.g., minimum remaining shelf life percentage, temperature verification requirements).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frozenShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Frozen Shelf Life Days' ;
    rdfs:comment 'Shelf life in days when product is stored in frozen conditions. Null if product is not suitable for freezing.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsma204TraceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma 204 Traceability Flag' ;
    rdfs:comment 'Indicates whether this product is subject to FSMA 204 enhanced traceability requirements for foods on the Food Traceability List.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightSensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Light Sensitivity Flag' ;
    rdfs:comment 'Indicates whether the product is sensitive to light exposure and requires storage in dark or light-protected conditions.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrslDays rdf:type rdf:Property ;
    rdfs:label 'Mrsl Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at the time of shipment to customers or distribution centers. Used to enforce retailer receiving standards (e.g., Walmart 2/3 life remaining policy).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openDatingRegulation rdf:type rdf:Property ;
    rdfs:label 'Open Dating Regulation' ;
    rdfs:comment 'Reference to the specific open-dating regulation that governs date labeling for this product (e.g., state-level US requirements, EU 1169/2011 Article 9). May vary by jurisdiction.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postOpeningShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Post Opening Shelf Life Days' ;
    rdfs:comment 'Number of days the product remains safe and of acceptable quality after the package is opened by the consumer. Null if not applicable or if product is single-serve.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityHoldThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Threshold Days' ;
    rdfs:comment 'Number of days before expiration at which inventory should be placed on quality hold for review or disposition. Used to prevent shipment of short-dated product.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailerComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Retailer Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting specific retailer requirements or compliance considerations (e.g., Walmart 2/3 life remaining policy, Target temperature monitoring requirements).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationRule rdf:type rdf:Property ;
    rdfs:label 'Rotation Rule' ;
    rdfs:comment 'Inventory rotation method to be applied. FIFO (First In First Out) rotates by receipt date, FEFO (First Expired First Out) rotates by expiration date, LIFO (Last In First Out) is rarely used in food and beverage.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeSpecStatus rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Spec Status' ;
    rdfs:comment 'Current lifecycle status of the shelf life specification. Draft specifications are under development, active specifications are in use, superseded specifications have been replaced by newer versions, and obsolete specifications are no longer valid.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTestingProtocol rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Testing Protocol' ;
    rdfs:comment 'Reference to the laboratory testing protocol or study used to establish the shelf life specification. Links to quality assurance documentation.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCode rdf:type rdf:Property ;
    rdfs:label 'Specification Code' ;
    rdfs:comment 'Business identifier for the shelf life specification, typically used in quality management and PLM systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of this shelf life specification, incremented when specification parameters change.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Percent' ;
    rdfs:comment 'Maximum relative humidity percentage allowed during storage to prevent product degradation. Null if humidity control is not required.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Min Percent' ;
    rdfs:comment 'Minimum relative humidity percentage required during storage to prevent product degradation. Null if humidity control is not required.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required to maintain product quality and safety throughout shelf life. Exceeding this temperature may compromise product integrity.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain product quality and safety throughout shelf life. Critical for cold chain integrity.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionToleranceHours rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Tolerance Hours' ;
    rdfs:comment 'Maximum number of hours the product can tolerate temperature excursions outside the specified range without compromising safety or quality. Null if no tolerance is allowed.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Life Days' ;
    rdfs:comment 'Total number of days from manufacture date to end of shelf life (best-by or use-by date). Critical for FEFO inventory rotation and retailer compliance.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Product Owner assignment in SKU lifecycle governance report.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abv rdf:type rdf:Property ;
    rdfs:label 'Abv' ;
    rdfs:comment 'Alcohol by volume percentage for alcoholic beverage products. Null for non-alcoholic products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenMatrix rdf:type rdf:Property ;
    rdfs:label 'Allergen Matrix' ;
    rdfs:comment 'Comprehensive list of major food allergens present in or potentially cross-contaminating the product (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brixTarget rdf:type rdf:Property ;
    rdfs:label 'Brix Target' ;
    rdfs:comment 'Target Brix measurement representing sugar content percentage for beverages and fruit products. Used for quality control and formulation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flavorVariety rdf:type rdf:Property ;
    rdfs:label 'Flavor Variety' ;
    rdfs:comment 'Specific flavor, variety, or variant of the product (e.g., Original, Chocolate, Strawberry, Spicy, Mild).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form and preparation state of the product (Ready to Eat, Ready to Drink, Concentrate, Powder, Frozen, Refrigerated, Shelf Stable, Fresh). [ENUM-REF-CANDIDATE: ready to eat|ready to drink|concentrate|powder|frozen|refrigerated|shelf stable|fresh — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netVolume rdf:type rdf:Property ;
    rdfs:label 'Net Volume' ;
    rdfs:comment 'Net volume of the product contents for liquid or pourable products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Net weight of the product contents excluding packaging.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Primary packaging format and material (e.g., Bottle, Can, Pouch, Box, Bag, Jar, Tray, Carton).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phMax rdf:type rdf:Property ;
    rdfs:label 'Ph Max' ;
    rdfs:comment 'Maximum acceptable pH level (acidity measure) for the product. Critical for food safety and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMin rdf:type rdf:Property ;
    rdfs:label 'Ph Min' ;
    rdfs:comment 'Minimum acceptable pH level (acidity measure) for the product. Critical for food safety and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmStage rdf:type rdf:Property ;
    rdfs:label 'Plm Stage' ;
    rdfs:comment 'Current stage in the Product Lifecycle Management process (Concept, Development, Validation, Commercialization, Growth, Maturity, Decline). [ENUM-REF-CANDIDATE: concept|development|validation|commercialization|growth|maturity|decline — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Product line or sub-brand classification within the brand portfolio (e.g., Premium, Organic, Kids, Family Size).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the SKU (Active, Discontinued, On Hold, Seasonal, Pending Launch, Phase Out).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether the primary packaging is recyclable through standard municipal recycling programs.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTemperatureMax rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max' ;
    rdfs:comment 'Maximum storage temperature in Celsius required to maintain product quality and safety.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMin rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min' ;
    rdfs:comment 'Minimum storage temperature in Celsius required to maintain product quality and safety.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vegetarianFlag rdf:type rdf:Property ;
    rdfs:label 'Vegetarian Flag' ;
    rdfs:comment 'Indicates whether the product is suitable for vegetarian diets (no meat, poultry, fish, or slaughter by-products).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionRuleId rdf:type rdf:Property ;
    rdfs:label 'Substitution Rule Id' ;
    rdfs:comment 'Primary key for substitution_rule' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySubstitutionSubstituteSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Substitution Substitute Sku Id' ;
    rdfs:comment 'The SKU that can replace the source SKU. References the replacement product that can be used when the source SKU is unavailable or being phased out.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:sourceSkuId rdf:type rdf:Property ;
    rdfs:label 'Source Sku Id' ;
    rdfs:comment 'The SKU that is being substituted or replaced. References the original product requested in order fulfillment, production, or distribution scenarios.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenCompatibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Compatibility Verified Flag' ;
    rdfs:comment 'Indicates whether the allergen matrices of source and substitute SKUs have been reviewed and confirmed compatible. Critical for food safety and regulatory compliance under Food Safety Modernization Act (FSMA) and allergen labeling requirements.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segments or account types to which this substitution rule applies. Examples include national_accounts, regional_chains, independent_retailers, club_stores. Empty or null indicates rule applies to all customer types.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions, countries, or market areas where this substitution rule is valid. Uses ISO 3166-1 alpha-3 country codes or internal region codes. Empty or null indicates global applicability.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoSubstituteFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Substitute Flag' ;
    rdfs:comment 'Indicates whether this substitution can be applied automatically by order management or warehouse management systems without manual approval. True enables automatic substitution; false requires manual review and authorization for each substitution instance.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The most recent date when this substitution rule was applied in a business transaction. Used to identify inactive rules that may be candidates for archival.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Name or identifier of the user who last modified this substitution rule record. Supports change tracking and accountability.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalEquivalenceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Nutritional Equivalence Verified Flag' ;
    rdfs:comment 'Indicates whether the nutritional panels of source and substitute SKUs have been compared and confirmed substantially equivalent. Important for institutional foodservice contracts and nutritional program compliance.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentType rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Type' ;
    rdfs:comment 'Defines how pricing is handled when substitution occurs. no_adjustment uses standard substitute SKU price; match_source charges the original source SKU price; use_substitute charges the substitute SKU price; percentage_discount applies a discount percentage; fixed_discount applies a fixed amount discount.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Value' ;
    rdfs:comment 'Numeric value for price adjustment when price_adjustment_type is percentage_discount or fixed_discount. For percentage_discount, represents the discount percentage (e.g., 5.00 for 5% off). For fixed_discount, represents the discount amount in base currency.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionDirection rdf:type rdf:Property ;
    rdfs:label 'Substitution Direction' ;
    rdfs:comment 'Indicates whether the substitution is one-way (source can be replaced by substitute only) or bidirectional (either SKU can replace the other). Bidirectional typically applies to equivalent products.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionRatio rdf:type rdf:Property ;
    rdfs:label 'Substitution Ratio' ;
    rdfs:comment 'Conversion factor for quantity substitution. Indicates how many units of the substitute SKU are needed to replace one unit of the source SKU. For example, 1.5 means 1.5 units of substitute replace 1 unit of source.' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Business reason for establishing this substitution rule. Discontinuation indicates source SKU is being phased out; supply_shortage indicates temporary unavailability; cost_optimization indicates more economical alternative; quality_improvement indicates enhanced product; regulatory_change indicates compliance-driven substitution; packaging_change or formulation_change indicate product updates; seasonal_transition indicates seasonal variant swap; inventory_depletion indicates planned stock runout; customer_request indicates retailer-mandated equivalent. [ENUM-REF-CANDIDATE: discontinuation|supply_shortage|cost_optimization|quality_improvement|regulatory_change|packaging_change|formulation_change|seasonal_transition|inventory_depletion|customer_request — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubstitutionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMatrixId rdf:type rdf:Property ;
    rdfs:label 'Allergen Matrix Id' ;
    rdfs:comment 'Primary key for allergen_matrix' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specQualitySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Spec Quality Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Allergen matrix defines allergen profile for SKUs; linking to specification centralizes product quality attributes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:allergenCelery rdf:type rdf:Property ;
    rdfs:label 'Allergen Celery' ;
    rdfs:comment 'Indicates presence of celery or celery extracts.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenControlMeasures rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Measures' ;
    rdfs:comment 'Textual description of controls (e.g., dedicated equipment, cleaning procedures) used to mitigate allergen risk.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenEgg rdf:type rdf:Property ;
    rdfs:label 'Allergen Egg' ;
    rdfs:comment 'Indicates presence of egg proteins.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenLupin rdf:type rdf:Property ;
    rdfs:label 'Allergen Lupin' ;
    rdfs:comment 'Indicates presence of lupin protein.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMatrixStatus rdf:type rdf:Property ;
    rdfs:label 'Allergen Matrix Status' ;
    rdfs:comment 'Current lifecycle status of the allergen matrix record.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMollusk rdf:type rdf:Property ;
    rdfs:label 'Allergen Mollusk' ;
    rdfs:comment 'Indicates presence of mollusk allergens (e.g., clams, mussels).' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMustard rdf:type rdf:Property ;
    rdfs:label 'Allergen Mustard' ;
    rdfs:comment 'Indicates presence of mustard seeds or derivatives.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenPeanut rdf:type rdf:Property ;
    rdfs:label 'Allergen Peanut' ;
    rdfs:comment 'Indicates if peanuts are present, may be present, or absent in the product.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenSoy rdf:type rdf:Property ;
    rdfs:label 'Allergen Soy' ;
    rdfs:comment 'Indicates presence of soy proteins.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenSulfites rdf:type rdf:Property ;
    rdfs:label 'Allergen Sulfites' ;
    rdfs:comment 'Indicates presence of sulfite additives above regulatory thresholds.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenTreeNut rdf:type rdf:Property ;
    rdfs:label 'Allergen Tree Nut' ;
    rdfs:comment 'Status of tree nut allergens (e.g., almond, walnut) in the product.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningValidationDate rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Date' ;
    rdfs:comment 'Date when the most recent cleaning validation was performed.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cleaningValidationNotes rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Notes' ;
    rdfs:comment 'Free-form notes from the cleaning validation activity.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Status' ;
    rdfs:comment 'Current status of cleaning validation for allergen control.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossContactRisk rdf:type rdf:Property ;
    rdfs:label 'Cross Contact Risk' ;
    rdfs:comment 'Assessed risk of allergen cross-contact during manufacturing.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelDeclarationRequired rdf:type rdf:Property ;
    rdfs:label 'Label Declaration Required' ;
    rdfs:comment 'Indicates whether the allergen must be declared on the consumer label.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Indicates whether the matrix follows the standard regulatory template or a custom internal version.' ;
    rdfs:domain ind:AllergenMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numeric score (0-100) summarizing overall allergen risk for the SKU.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Identifier of the customer complaint that initiated this CAPA, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:relatedAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Related Audit Finding Id' ;
    rdfs:comment 'Identifier of the audit finding linked to this CAPA, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:attachedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Attached Document Count' ;
    rdfs:comment 'Number of supporting documents attached to the CAPA record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-visible CAPA reference number assigned by quality management (e.g., CAPA-2023-001).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the record is a corrective action or a preventive action.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccnNumber rdf:type rdf:Property ;
    rdfs:label 'Ccn Number' ;
    rdfs:comment 'Identifier of the critical control point (CCP) related to the CAPA.' ;
