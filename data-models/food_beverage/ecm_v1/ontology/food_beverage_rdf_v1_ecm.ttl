    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFacings rdf:type rdf:Property ;
    rdfs:label 'Total Facings' ;
    rdfs:comment 'Sum of all facings across SKUs in the planogram.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLinearFeet rdf:type rdf:Property ;
