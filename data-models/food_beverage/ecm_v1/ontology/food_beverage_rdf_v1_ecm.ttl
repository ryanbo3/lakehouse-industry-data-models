    rdfs:range xsd:string .

ind:responseSource rdf:type rdf:Property ;
    rdfs:label 'Response Source' ;
    rdfs:comment 'Origin of the response within the organization (e.g., web portal, mobile app, call center, in-store kiosk).' ;
