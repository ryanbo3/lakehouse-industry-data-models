    rdfs:comment 'Name of the person who performed the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Primary key for certificate_of_analysis' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:alcoholByVolume rdf:type rdf:Property ;
    rdfs:label 'Alcohol By Volume' ;
    rdfs:comment 'Alcohol content expressed as a percentage of volume.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenPresence rdf:type rdf:Property ;
    rdfs:label 'Allergen Presence' ;
    rdfs:comment 'Indicates whether declared allergens were detected.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Name of the laboratory analyst who performed the test.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the person who approved the CoA.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brix rdf:type rdf:Property ;
    rdfs:label 'Brix' ;
    rdfs:comment 'Sugar content expressed in degrees Brix.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Status' ;
    rdfs:comment 'Current lifecycle state of the CoA record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaType rdf:type rdf:Property ;
    rdfs:label 'Coa Type' ;
    rdfs:comment 'Classification of the CoA source: internal lab, supplier-provided, or third-party laboratory.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDocumentUri rdf:type rdf:Property ;
