    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'State or province component of the billing address.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Charges for transportation and logistics associated with the invoice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCreditMemo rdf:type rdf:Property ;
    rdfs:label 'Is Credit Memo' ;
    rdfs:comment 'Indicates whether the invoice is a credit memo (true) or not (false).' ;
