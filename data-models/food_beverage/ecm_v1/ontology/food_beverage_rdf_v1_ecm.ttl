    rdfs:range xsd:date .

ind:resolutionTimeSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Sla Minutes' ;
    rdfs:comment 'Maximum time in minutes to resolve a reported issue after response.' ;
