    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:formulationId rdf:type rdf:Property ;
    rdfs:label 'Formulation Id' ;
    rdfs:comment 'Reference to the approved formulation (recipe) used for this batch. Links to the bill of materials and ingredient specifications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulation .

ind:formulationVersionId rdf:type rdf:Property ;
    rdfs:label 'Formulation Version Id' ;
    rdfs:comment 'Foreign key linking to research.formulation_version. Business justification: Batch traceability to the specific R&D formulation version used is required for product recall, shelf-life, and regulatory documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormulationVersion .

ind:primaryBatchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Employee Id' ;
    rdfs:comment 'Reference to the primary production operator responsible for executing this batch. Used for accountability, training verification, and performance tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBatchQaReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Batch Qa Reviewer Employee Id' ;
    rdfs:comment 'Reference to the quality assurance professional who reviewed and approved this batch for release. Required for batch disposition decision and regulatory compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteGenerationId rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_generation. Business justification: Waste generation reports are produced per batch; linking batch_record to waste_record enables accurate waste accounting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteGeneration .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'The actual quantity of finished goods produced and approved from this batch. May differ from batch size due to process losses, quality rejections, or overproduction.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenStatement rdf:type rdf:Property ;
    rdfs:label 'Allergen Statement' ;
    rdfs:comment 'The allergen declaration for this batch as it appears on the product label. Lists all major allergens present (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame) and may-contain statements for cross-contact allergens. Critical for consumer safety and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNotes rdf:type rdf:Property ;
    rdfs:label 'Batch Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special instructions related to this batch. May include process notes, quality observations, equipment issues, or other relevant information not captured in structured fields.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'The planned or target quantity of finished goods to be produced in this batch. Represents the theoretical yield based on the formulation and production order.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch record. Tracks the batch through manufacturing execution, quality approval, and release stages. In-process indicates active manufacturing; pending QA indicates awaiting quality approval; released indicates approved for distribution; rejected indicates failed quality checks; quarantine indicates isolated pending investigation; on hold indicates regulatory or quality hold.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackerFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packer Flag' ;
    rdfs:comment 'Indicates whether this batch was manufactured by a third-party co-packer (contract manufacturer) rather than in-house. True indicates co-packer production; False indicates internal manufacturing. Critical for supply chain visibility and quality accountability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'The total number of manufacturing deviations, exceptions, or non-conformances recorded during batch execution. Includes process parameter excursions, equipment failures, and procedural deviations. Zero indicates perfect execution. Used for quality trending and CAPA analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glutenFreeClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Claim Flag' ;
    rdfs:comment 'Indicates whether this batch carries a gluten-free claim on the label. True indicates gluten-free claim present; False indicates no claim. Must meet FDA gluten-free standard of less than 20 ppm gluten. Requires testing and validation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Haccp Signoff Status' ;
    rdfs:comment 'Status of HACCP critical control point verification and approval for this batch. Indicates whether all critical control points were monitored and within acceptable limits. Pending indicates awaiting review; approved indicates all CCPs passed; rejected indicates CCP failure; not applicable for products not requiring HACCP.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certification Flag' ;
    rdfs:comment 'Indicates whether this batch is certified halal per Islamic dietary law. True indicates halal certified; False indicates not certified. Requires halal certificate and compliance documentation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certification Flag' ;
    rdfs:comment 'Indicates whether this batch is certified kosher by a recognized kosher certification agency. True indicates kosher certified; False indicates not certified. Requires kosher certificate and supervision records.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'The date and time when batch manufacturing execution was completed. Marks the completion of all processing steps and final packaging. Used for cycle time analysis and OEE calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'The date and time when batch manufacturing execution began. Marks the start of raw material dispensing and processing. Critical for shelf life calculation and FIFO/FEFO inventory management.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nonGmoVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Verified Flag' ;
    rdfs:comment 'Indicates whether this batch is verified as non-genetically modified organism (non-GMO) by a third-party certification program. True indicates non-GMO verified; False indicates not verified or contains GMO ingredients.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Flag' ;
    rdfs:comment 'Indicates whether this batch is certified organic per USDA NOP or equivalent organic standards. True indicates certified organic; False indicates conventional. Requires organic certificate and audit trail.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Description of the primary and secondary packaging used for this batch. Includes package type, size, and material. Examples: 12oz PET bottle 24-pack, 500g stand-up pouch, 1L Tetra Pak carton. Links to packaging specification.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Number' ;
    rdfs:comment 'The batch number of the original batch from which reworked material was sourced. Populated only when rework_flag is True. Maintains traceability chain for reworked batches.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Timestamp' ;
    rdfs:comment 'The date and time when the quality assurance reviewer approved this batch for release to distribution. Marks the transition from pending QA to released status.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this batch is under regulatory hold pending investigation or approval from regulatory authorities (FDA, USDA, etc.). True indicates hold in place; False indicates no regulatory restriction. Prevents distribution until cleared.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Free-text description of the reason for regulatory hold. Populated only when regulatory_hold_flag is True. Documents the specific regulatory concern, investigation, or pending approval.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this batch includes reworked material from a previous batch. True indicates rework present; False indicates all new material. Rework must be documented per GMP requirements.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterilizationMethod rdf:type rdf:Property ;
    rdfs:label 'Sterilization Method' ;
    rdfs:comment 'The thermal or non-thermal sterilization process applied to this batch. Pasteurization indicates low-temperature short-time treatment; UHT indicates ultra-high temperature; retort indicates in-container sterilization; aseptic indicates sterile processing and packaging; none indicates no sterilization (e.g., dry goods); other for alternative methods. Critical for food safety and shelf life.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturingFlag rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturing Flag' ;
    rdfs:comment 'Indicates whether this batch was produced under a toll manufacturing arrangement where the company provides raw materials and the toll manufacturer provides processing services. True indicates toll manufacturing; False indicates standard production. Distinct from co-packing where the manufacturer may source materials.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeoverId rdf:type rdf:Property ;
    rdfs:label 'Changeover Id' ;
    rdfs:comment 'Unique identifier for the changeover event. Primary key for the changeover data product.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeoverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Changeover Employee Id' ;
    rdfs:comment 'Identifier of the QA (Quality Assurance) operator who signed off on the changeover verification.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeoverProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Changeover Production Order Id' ;
    rdfs:comment 'Identifier of the production order that was running before the changeover event.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:changeoverProductionOrderToProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Changeover Production Order To Production Order Id' ;
    rdfs:comment 'Identifier of the production order that will run after the changeover event.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:changeoverSanitationCrewLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Changeover Sanitation Crew Lead Employee Id' ;
    rdfs:comment 'Identifier of the sanitation crew lead responsible for executing the changeover and cleaning procedures.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeoverSkuId rdf:type rdf:Property ;
    rdfs:label 'Changeover Sku Id' ;
    rdfs:comment 'Identifier of the SKU (Stock Keeping Unit) that was being produced before the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:changeoverSkuToSkuId rdf:type rdf:Property ;
    rdfs:label 'Changeover Sku To Sku Id' ;
    rdfs:comment 'Identifier of the SKU (Stock Keeping Unit) that will be produced after the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual end date and time when the changeover event was completed in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual start date and time when the changeover event began in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allergenClearanceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Clearance Verified Flag' ;
    rdfs:comment 'Indicates whether allergen clearance was verified and approved. True if verified, False if not applicable or not verified.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenFrom rdf:type rdf:Property ;
    rdfs:label 'Allergen From' ;
    rdfs:comment 'Allergen present in the SKU being produced before the changeover. Used for allergen management and clearance verification.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenTo rdf:type rdf:Property ;
    rdfs:label 'Allergen To' ;
    rdfs:comment 'Allergen present in the SKU being produced after the changeover. Used for allergen management and clearance verification.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpRluValue rdf:type rdf:Property ;
    rdfs:label 'Atp Rlu Value' ;
    rdfs:comment 'Numeric RLU (Relative Light Units) value from the ATP swab test. Lower values indicate cleaner surfaces.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpSwabTestResult rdf:type rdf:Property ;
    rdfs:label 'Atp Swab Test Result' ;
    rdfs:comment 'Result of the ATP (Adenosine Triphosphate) swab test used to detect organic contamination on surfaces.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfuCount rdf:type rdf:Property ;
    rdfs:label 'Cfu Count' ;
    rdfs:comment 'CFU (Colony Forming Units) count from the microbiological swab test. Indicates the level of bacterial contamination.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chemicalAgentUsed rdf:type rdf:Property ;
    rdfs:label 'Chemical Agent Used' ;
    rdfs:comment 'Name or code of the chemical cleaning agent used during the sanitation process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Chemical Concentration Percent' ;
    rdfs:comment 'Concentration level of the chemical agent used, expressed as a percentage.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipCycleCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Cycle Completed Flag' ;
    rdfs:comment 'Indicates whether the CIP (Clean-in-Place) cycle was completed successfully. True if completed, False if not applicable or incomplete.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationMinutes rdf:type rdf:Property ;
    rdfs:label 'Deviation Minutes' ;
    rdfs:comment 'Deviation from planned duration in minutes. Positive values indicate the changeover took longer than planned; negative values indicate it was faster.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationNotes rdf:type rdf:Property ;
    rdfs:label 'Deviation Notes' ;
    rdfs:comment 'Free-text notes explaining any deviations, issues, or special circumstances encountered during the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Reason Code' ;
    rdfs:comment 'Code indicating the reason for any deviation from the planned changeover duration or procedure.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineClearanceChecklistCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Line Clearance Checklist Completed Flag' ;
    rdfs:comment 'Indicates whether the line clearance checklist was completed. True if completed, False if incomplete.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:microbiologicalSwabResult rdf:type rdf:Property ;
    rdfs:label 'Microbiological Swab Result' ;
    rdfs:comment 'Result of the microbiological swab test to detect bacterial contamination.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPassFailStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Pass Fail Status' ;
    rdfs:comment 'Overall pass or fail status of the changeover event based on all verification tests and procedures.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionClearanceGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Production Clearance Granted Flag' ;
    rdfs:comment 'Indicates whether production clearance was granted to resume operations after the changeover. True if granted, False if pending or denied.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rinseVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Rinse Verification Result' ;
    rdfs:comment 'Result of the rinse verification test to ensure all chemical residues have been removed.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sanitation Procedure Code' ;
    rdfs:comment 'Standard operating procedure code for the sanitation method used during the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationType rdf:type rdf:Property ;
    rdfs:label 'Sanitation Type' ;
    rdfs:comment 'Type of sanitation procedure performed during the changeover event. None indicates no sanitation was required.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Reference Code' ;
    rdfs:comment 'Reference code linking the changeover event to the production schedule or planning system.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date and time for the changeover event in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned start date and time for the changeover event in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:copackingOrderId rdf:type rdf:Property ;
    rdfs:label 'Copacking Order Id' ;
    rdfs:comment 'Unique identifier for the co-packing or toll manufacturing order. Primary key for this entity.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copackerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Copacker Supplier Id' ;
    rdfs:comment 'Reference to the third-party co-manufacturer (co-packer) supplier who will execute the production. Links to procurement supplier master.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualProductionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Date' ;
    rdfs:comment 'The actual date when production was completed by the co-packer.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualQuantityProduced rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Produced' ;
    rdfs:comment 'The actual quantity of finished goods units produced by the co-packer upon order completion.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenControlVerified rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Verified' ;
    rdfs:comment 'Indicates whether allergen control procedures at the co-packer facility have been verified for this order. True if verified, False if not verified.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copackerBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Copacker Batch Number' ;
    rdfs:comment 'The batch or lot number assigned by the co-packer to the production run.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copackingOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Copacking Order Number' ;
    rdfs:comment 'Business-facing unique order number for the co-packing arrangement, used for external communication with co-packer and internal tracking.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Flag' ;
    rdfs:comment 'Indicates whether the co-packer facility is compliant with FSMA (Food Safety Modernization Act) requirements. True if compliant, False if non-compliant.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme' ;
    rdfs:comment 'The specific GFSI-recognized certification scheme held by the co-packer (e.g., SQF, BRC, FSSC 22000, IFS).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Audit Date' ;
    rdfs:comment 'Date of the most recent GMP audit conducted at the co-packer facility.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Audit Status' ;
    rdfs:comment 'Status of the co-packer facility\'s GMP (Good Manufacturing Practice) audit: current (audit valid), expired (audit needs renewal), pending (audit scheduled), not-audited (no audit on file).' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date when the co-packed finished goods were received into our inventory.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number generated when the co-packed finished goods are received into inventory.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Compliance Flag' ;
    rdfs:comment 'Indicates whether the co-packer has documented compliance with HACCP (Hazard Analysis Critical Control Points) critical control points for this production run. True if compliant, False if non-compliant or not verified.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Batch Number' ;
    rdfs:comment 'Our internal batch or lot number assigned to the co-packed production for traceability and inventory management.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the co-packing order: planned (order created), in-production (manufacturing underway), received (goods received), quality-hold (pending quality clearance), closed (order completed), cancelled (order terminated).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Production Date' ;
    rdfs:comment 'The scheduled date when production is planned to start or be completed at the co-packer facility.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The planned quantity of finished goods units to be produced by the co-packer as per the order.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier of the specific production line at the co-packer facility used for this order.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Status' ;
    rdfs:comment 'Indicates whether the co-packed goods are currently on quality hold pending inspection and release. True if on hold, False if released or not applicable.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawMaterialsSuppliedBy rdf:type rdf:Property ;
    rdfs:label 'Raw Materials Supplied By' ;
    rdfs:comment 'Indicates who supplies the raw materials for production: us (we supply), copacker (co-packer supplies), or mixed (both parties supply components).' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWarehouseCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Warehouse Code' ;
    rdfs:comment 'Code of the warehouse or distribution center where the co-packed goods are received.' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sqfCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Sqf Certification Level' ;
    rdfs:comment 'The level of SQF certification held by the co-packer (Level 1: Food Safety Fundamentals, Level 2: Food Safety Plans, Level 3: Comprehensive Food Safety and Quality).' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sqfCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Sqf Certification Status' ;
    rdfs:comment 'Status of the co-packer\'s SQF (Safe Quality Food) or GFSI (Global Food Safety Initiative) certification: certified (valid certification), expired (needs renewal), pending (application in progress), not-certified (no certification).' ;
    rdfs:domain ind:CopackingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assigns a primary maintenance owner to each equipment, supporting preventive-maintenance scheduling and CAPA accountability.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or total capitalized cost of acquiring and installing the equipment, used for asset valuation and depreciation calculations.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenHandlingCapability rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Capability' ;
    rdfs:comment 'Description of allergen types this equipment is qualified to handle, or designation as allergen-free equipment. Critical for allergen control and production scheduling to prevent cross-contamination.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Asset Owner Department' ;
    rdfs:comment 'Department or business unit responsible for the ownership, budgeting, and strategic decisions related to this equipment asset.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Number of days between required calibration activities as defined by regulatory requirements, manufacturer specifications, or internal quality standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the rated capacity value, indicating how production throughput is quantified for this equipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Capable Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment is designed for automated clean-in-place sanitation without disassembly, enabling efficient changeover and sanitation cycles.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business justification or reason for decommissioning the equipment (e.g., end of life, obsolescence, facility closure, technology upgrade).' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionRatingKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Rating Kwh' ;
    rdfs:comment 'Rated or average energy consumption of the equipment per operating hour, used for sustainability tracking and operational cost analysis.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level grouping of equipment by operational category for reporting and analysis purposes.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable descriptive name of the equipment asset (e.g., \'Line 3 Filling Machine\', \'Pasteurizer Unit A\').' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTagNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to the equipment asset for operational tracking and maintenance purposes. This is the externally-known business identifier used in MES systems, work orders, and maintenance schedules.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the equipment by its primary production function within the manufacturing process. [ENUM-REF-CANDIDATE: filling_machine|mixer|blender|pasteurizer|extruder|packaging_line|labeler|metal_detector|checkweigher|cip_system|oven|cooler|conveyor|palletizer|wrapper|sealer — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodContactSurfaceFlag rdf:type rdf:Property ;
    rdfs:label 'Food Contact Surface Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment has surfaces that come into direct contact with food products, requiring specific sanitation and material compliance standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment is classified as GMP-critical, requiring enhanced documentation, validation, and change control procedures.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesAssetTag rdf:type rdf:Property ;
    rdfs:label 'Mes Asset Tag' ;
    rdfs:comment 'Unique identifier used by the MES system (Aveva/Wonderware) to track this equipment in real-time production monitoring, batch execution, and performance analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration or verification activity to maintain equipment qualification status.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeBaselineTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Baseline Target Percent' ;
    rdfs:comment 'Target OEE percentage established as the performance baseline for this equipment, used for monitoring and continuous improvement initiatives. OEE measures availability, performance, and quality.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventiveMaintenanceScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Schedule Code' ;
    rdfs:comment 'Reference code linking this equipment to its preventive maintenance plan schedule defining frequency and tasks for routine maintenance activities.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'Maximum production capacity of the equipment as specified by the manufacturer or validated during commissioning, expressed in the unit of measure appropriate to the equipment type.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Code' ;
    rdfs:comment 'Reference code or identifier for safety certifications held by this equipment (e.g., UL, CE, CSA), documenting compliance with electrical and mechanical safety standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Document Code' ;
    rdfs:comment 'Reference identifier for the technical specification document containing detailed engineering specifications, operating parameters, and maintenance procedures for this equipment.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpEventId rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Id' ;
    rdfs:comment 'Unique identifier for the GMP compliance event record. Primary key.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGmpReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gmp Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who reported or documented the GMP event. Supports accountability and recognition of quality culture.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGmpClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Gmp Closed By Employee Id' ;
    rdfs:comment 'Reference to the employee or quality manager who approved closure of the GMP event. Null if event is not yet closed.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference number linking this GMP event to a formal CAPA record in the quality management system. Null if no CAPA was initiated.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpNumber rdf:type rdf:Property ;
    rdfs:label 'Ccp Number' ;
    rdfs:comment 'The specific HACCP Critical Control Point number if this event relates to a CCP. Null if the event does not involve a CCP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDatetime rdf:type rdf:Property ;
    rdfs:label 'Closure Datetime' ;
    rdfs:comment 'The date and time when the GMP event was formally closed after all corrective actions were verified as effective. Null if event is not yet closed.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDatetime rdf:type rdf:Property ;
    rdfs:label 'Event Datetime' ;
    rdfs:comment 'The date and time when the GMP event was observed or occurred on the production floor. This is the actual event timestamp, distinct from when it was recorded in the system.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalAuditReference rdf:type rdf:Property ;
    rdfs:label 'External Audit Reference' ;
    rdfs:comment 'Reference number or identifier linking this GMP event to an external audit finding from FDA, USDA, GFSI auditor, or customer audit. Null if not related to an external audit.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Notification Required Flag' ;
    rdfs:comment 'Indicates whether this GMP event requires specific notification to the FDA under food safety regulations. True if FDA notification is required, false otherwise.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpEventDescription rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Description' ;
    rdfs:comment 'Detailed narrative description of the GMP event, including what was observed, the circumstances, and any immediate context. This field captures the full story of the event for investigation and audit purposes.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Flag' ;
    rdfs:comment 'Indicates whether this GMP event occurred at or relates to a HACCP Critical Control Point. True if the event involves a CCP, false otherwise. Critical for food safety risk assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate containment or corrective actions taken at the time the GMP event was discovered. Documents the initial response to prevent further impact.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Detailed assessment of the potential or actual impact of the GMP event on product quality, food safety, regulatory compliance, and business operations. Documents the risk evaluation performed.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Datetime' ;
    rdfs:comment 'The date and time when the investigation of the GMP event was completed and root cause determined. Null if investigation is still in progress.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Datetime' ;
    rdfs:comment 'The date and time when formal investigation of the GMP event began. Used to track investigation cycle time and compliance with internal SLAs.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousEventReference rdf:type rdf:Property ;
    rdfs:label 'Previous Event Reference' ;
    rdfs:comment 'Reference to the event number of a previous related GMP event if this is a recurrence. Null if this is a first occurrence or not linked to a prior event.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'Final disposition decision for the product batch affected by the GMP event. Released indicates product approved for distribution, rework indicates product requires reprocessing, regrade indicates product downgraded to alternate use, quarantine indicates product held pending further evaluation, destroy indicates product must be disposed of, under evaluation indicates disposition not yet determined.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'The quantity of product affected by the GMP event, measured in the product\'s base unit of measure. Used to assess the scale of impact and potential financial exposure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the quantity affected field. Common units include kg (kilograms), lb (pounds), l (liters), gal (gallons), ea (each), case, or pallet. [ENUM-REF-CANDIDATE: kg|lb|l|gal|ea|case|pallet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this GMP event is a recurrence of a previously documented event with the same or similar root cause. True if recurrence, false if first occurrence. Used to identify systemic issues.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'The date and time when the GMP event was formally reported and recorded in the quality management system. May differ from event_datetime if there was a delay in reporting.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usdaNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Usda Notification Required Flag' ;
    rdfs:comment 'Indicates whether this GMP event requires specific notification to the USDA, typically for meat, poultry, or egg product manufacturing. True if USDA notification is required, false otherwise.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master document record in Veeva Vault QMS where the complete GMP event investigation file, attachments, and audit trail are stored.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpLogId rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Log Id' ;
    rdfs:comment 'Unique identifier for the HACCP critical control point monitoring log entry. Primary key for the log record.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHaccpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Haccp Employee Id' ;
    rdfs:comment 'Reference to the operator or quality technician who performed and verified the CCP monitoring. Establishes accountability and traceability for compliance audits.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ccpIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ccp Identifier' ;
    rdfs:comment 'The unique code or identifier for the critical control point as defined in the HACCP plan (e.g., CCP-1, CCP-2-PASTEURIZE).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpName rdf:type rdf:Property ;
    rdfs:label 'Ccp Name' ;
    rdfs:comment 'The descriptive name of the critical control point being monitored (e.g., Pasteurization Temperature, Metal Detection, pH Check, Brix Measurement, Allergen Verification).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a corrective action is required based on the CCP monitoring result (True = corrective action needed, False = no action needed).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalLimitLower rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Lower' ;
    rdfs:comment 'The minimum acceptable value for this CCP as defined in the HACCP plan. Values below this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Upper' ;
    rdfs:comment 'The maximum acceptable value for this CCP as defined in the HACCP plan. Values above this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationSeverity rdf:type rdf:Property ;
    rdfs:label 'Deviation Severity' ;
    rdfs:comment 'Classification of the severity of the CCP deviation if one occurred (minor = slight deviation with low risk, major = significant deviation requiring investigation, critical = severe deviation with immediate food safety risk).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'The category of food safety hazard that this CCP is designed to control (biological, chemical, physical, or allergen).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inLimitFlag rdf:type rdf:Property ;
    rdfs:label 'In Limit Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value falls within the defined critical limits (True = within limits, False = out of specification).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual measured or observed value at the critical control point (e.g., temperature reading, pH level, Brix degree, metal detector sensitivity test result).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'The required frequency of monitoring for this CCP as defined in the HACCP plan (e.g., continuous, every 15 minutes, every batch, hourly).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'The method or procedure used to monitor this CCP (e.g., calibrated thermometer, pH meter, metal detector test, visual inspection, laboratory analysis).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'The exact date and time when the CCP measurement or observation was recorded. Critical for establishing real-time compliance and traceability.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Modified Timestamp' ;
    rdfs:comment 'The date and time when this CCP log record was last modified. Critical for audit trail and data integrity compliance.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryHoldTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Triggered Flag' ;
    rdfs:comment 'Boolean indicator of whether this CCP deviation triggered a regulatory hold on the batch, preventing release until investigation and disposition are complete (True = hold triggered, False = no hold).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this CCP log entry requires supervisor or quality manager review due to deviation or other exceptional circumstances (True = review required, False = no review needed).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the CCP monitoring record was verified and signed off by the responsible operator or quality personnel.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Lot Consumption Id' ;
    rdfs:comment 'Unique identifier for the lot consumption transaction record. Primary key for the lot consumption entity.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption was automatically backflushed based on production confirmation (True) or manually posted (False). Backflushing automates material consumption based on BOM and production output.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomQuantity rdf:type rdf:Property ;
    rdfs:label 'Bom Quantity' ;
    rdfs:comment 'The planned or standard quantity of this material specified in the Bill of Materials for the production order. Used to calculate consumption variance.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'The current status of the consumption transaction in the system workflow: confirmed (posted to inventory), pending (awaiting approval), rejected (not accepted), or reversed (cancelled after posting).' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumption Quantity' ;
    rdfs:comment 'The quantity of material consumed from the specified lot during production. Recorded in the unit of measure specified in the unit_of_measure field.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoFefoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order in which lots were consumed according to FIFO or FEFO inventory management rules. Lower numbers indicate earlier consumption priority.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lot Expiry Date' ;
    rdfs:comment 'The expiration or best-before date of the consumed lot. Used to enforce FEFO consumption rules and ensure materials are used before expiration.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between actual consumption quantity and the BOM planned quantity. Positive values indicate over-consumption; negative values indicate under-consumption.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'The storage location or warehouse from which the material lot was withdrawn for consumption. Links to the warehouse management system location master.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeEventId rdf:type rdf:Property ;
    rdfs:label 'Oee Event Id' ;
    rdfs:comment 'Unique identifier for the OEE event record. Primary key for the OEE event entity.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOeeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Oee Employee Id' ;
    rdfs:comment 'Reference to the production operator who was responsible for the work center when the event occurred.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Precise timestamp when the OEE loss event ended and normal production resumed, captured from the MES system.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Identifies the source system that captured and reported this OEE event (e.g., Aveva Wonderware MES, SCADA system, manual entry).' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the OEE loss event began, captured from the MES system in real-time.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Technical fault code or alarm code captured from the equipment control system at the time of the event, used for detailed troubleshooting and maintenance analysis.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpImpactedFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Impacted Flag' ;
    rdfs:comment 'Indicates whether this OEE event impacted a HACCP Critical Control Point, requiring food safety review and documentation. True if CCP was impacted, False otherwise.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Category' ;
    rdfs:comment 'Indicates whether the loss event was planned (scheduled maintenance, changeover) or unplanned (breakdown, quality issue, material shortage).' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Code' ;
    rdfs:comment 'Standardized reason code from MES that categorizes the root cause of the loss event (e.g., mechanical failure, electrical fault, material shortage, utility failure, operator error, quality hold, sanitation hold).' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Number' ;
    rdfs:comment 'The work order number from the maintenance management system if a maintenance work order was raised in response to this event. Null if no work order was created.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWorkOrderRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Raised Flag' ;
    rdfs:comment 'Indicates whether a maintenance work order was created in response to this OEE event. True if a work order was raised, False otherwise.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeComponentImpacted rdf:type rdf:Property ;
    rdfs:label 'Oee Component Impacted' ;
    rdfs:comment 'Identifies which of the three OEE components (availability, performance, quality) is primarily impacted by this loss event.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorNotes rdf:type rdf:Property ;
    rdfs:label 'Operator Notes' ;
    rdfs:comment 'Free-text notes entered by the production operator providing additional context, observations, or details about the OEE event.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Quantity of production units lost or not produced due to this OEE event, measured in the unit of measure of the product being manufactured.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stoppageCategory rdf:type rdf:Property ;
    rdfs:label 'Stoppage Category' ;
    rdfs:comment 'Detailed classification of downtime events into categories such as mechanical failure, electrical fault, material shortage, utility failure, operator error, quality hold, or sanitation hold. Applicable only when event_type is downtime.' ;
    rdfs:domain ind:OeeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldStorageCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Cold Storage Capacity Pallets' ;
    rdfs:comment 'Refrigerated and frozen storage capacity at the plant site measured in standard pallet positions for temperature-sensitive products and ingredients.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum daily production capacity of the plant measured in standard production units per day. Used for capacity planning, demand allocation, and OEE (Overall Equipment Effectiveness) calculations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the plant was permanently closed and ceased all production operations. Null for active facilities.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'FDA facility registration number required for food manufacturing facilities under FSMA (Food Safety Modernization Act) regulations. Mandatory for US-based facilities and importers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Boolean indicator of whether the plant holds current GMP (Good Manufacturing Practice) certification required for food and beverage manufacturing quality standards.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesSiteCode rdf:type rdf:Property ;
    rdfs:label 'Mes Site Code' ;
    rdfs:comment 'Site or facility identifier used in the Manufacturing Execution System (Aveva/Wonderware MES) for production scheduling, batch management, and OEE tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines or manufacturing lines within the plant used for production scheduling and line allocation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Standard number of operating days per week for the plant (typically 5, 6, or 7) used for production planning and capacity calculations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Per Day' ;
    rdfs:comment 'Standard operating hours per day for the plant used for capacity planning and OEE calculations. Typically 8, 16, or 24 hours depending on shift structure.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCertifyingBody rdf:type rdf:Property ;
    rdfs:label 'Organic Certifying Body' ;
    rdfs:comment 'Name of the accredited organic certification body that issued the organic certification (e.g., QAI, CCOF, Oregon Tilth, Ecocert).' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Official business name of the manufacturing plant or production facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantStatus rdf:type rdf:Property ;
    rdfs:label 'Plant Status' ;
    rdfs:comment 'Current operational status of the plant in its lifecycle. Active indicates full production operations, idle indicates temporarily not producing but maintained, decommissioned indicates permanently closed, under construction indicates new facility being built, and temporarily closed indicates short-term shutdown for maintenance or seasonal operations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the facility type indicating ownership and operational model. Owned manufacturing indicates company-operated production facilities, co-packer indicates third-party contract manufacturing, toll manufacturer indicates facilities where the company provides ingredients and the manufacturer provides processing, pilot plant indicates small-scale testing facilities, R&D facility indicates research and development sites, and distribution center indicates warehousing and logistics hubs.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Product Category' ;
    rdfs:comment 'Primary product category or product line manufactured at this plant (e.g., beverages, snacks, dairy, bakery, confectionery) used for portfolio planning and specialization tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Business-defined geographic region or market area for reporting and planning purposes (e.g., North America, EMEA, APAC, Latin America).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Establishment Number' ;
    rdfs:comment 'USDA establishment number assigned to facilities that process meat, poultry, or egg products under USDA inspection. Required for facilities producing USDA-regulated products.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Warehouse Capacity Pallets' ;
    rdfs:comment 'Total warehouse storage capacity at the plant site measured in standard pallet positions for finished goods and raw material inventory management.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter reading record.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this parameter reading triggered an alarm or alert in the MES system due to exceeding control limits or deviation thresholds.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Assessment of the reliability of this parameter reading: valid (normal operation), suspect (potential sensor issue), invalid (known bad data), or estimated (interpolated due to sensor failure).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'Calculated percentage deviation of the measured value from the target value, enabling quick assessment of process variation and capability.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineeringUnit rdf:type rdf:Property ;
    rdfs:label 'Engineering Unit' ;
    rdfs:comment 'Unit of measure for the parameter value (e.g., Celsius, Fahrenheit, PSI, bar, pH units, degrees Brix, liters/min, RPM, Nm, percent RH, CFU/ml, percent ABV).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inSpecFlag rdf:type rdf:Property ;
    rdfs:label 'In Spec Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the measured value falls within the acceptable control limits (LCL to UCL). False indicates an out-of-spec event requiring investigation.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Minimum acceptable value for this parameter; readings below this threshold indicate an out-of-specification condition requiring corrective action per SPC and HACCP protocols.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'Classification of the parameter type: temperature, pressure, pH (acidity measure), Brix (sugar content), flow rate, speed, torque, humidity, CFU (Colony Forming Units) count, or ABV (Alcohol by Volume). [ENUM-REF-CANDIDATE: temperature|pressure|ph|brix|flow_rate|speed|torque|humidity|cfu_count|abv — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterDescription rdf:type rdf:Property ;
    rdfs:label 'Parameter Description' ;
    rdfs:comment 'Human-readable description of the process parameter being measured (e.g., \'Pasteurization Tank 3 Temperature\', \'Filling Line 2 pH Probe\').' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterTagName rdf:type rdf:Property ;
    rdfs:label 'Parameter Tag Name' ;
    rdfs:comment 'Unique tag identifier from the MES historian system (Aveva/Wonderware) representing the specific sensor or control point.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPhase rdf:type rdf:Property ;
    rdfs:label 'Process Phase' ;
    rdfs:comment 'Stage or phase of the production process during which this parameter was measured (e.g., \'mixing\', \'pasteurization\', \'cooling\', \'filling\', \'packaging\'). Enables phase-specific process capability analysis.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Precise date and time when the parameter measurement was captured from the sensor or manually entered, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Laboratory or in-process sample identifier if this parameter reading was associated with a physical sample taken for testing or verification.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift identifier during which this parameter was captured (e.g., \'A\', \'B\', \'C\', \'Day\', \'Night\'). Enables shift-based performance analysis and OEE tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The intended or setpoint value for this parameter as defined in the production recipe or process specification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Maximum acceptable value for this parameter; readings above this threshold indicate an out-of-specification condition requiring corrective action per SPC and HACCP protocols.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingProductionBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Production Bom Id' ;
    rdfs:comment 'Unique identifier for the production BOM record. Primary key for the production BOM entity.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryManufacturingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Employee Id' ;
    rdfs:comment 'The user ID of the quality or production manager who approved this BOM for production use.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenDeclarationFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Flag' ;
    rdfs:comment 'Indicates whether this BOM contains any of the major allergens requiring declaration per FDA and FSMA regulations.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeBomGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Group' ;
    rdfs:comment 'Groups alternative BOMs for the same SKU (e.g., seasonal formulations, regional variants, equipment-specific recipes). Null if no alternatives exist.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Production Flag' ;
    rdfs:comment 'Indicates whether this BOM has passed all quality, regulatory, and operational reviews and is authorized for commercial production.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The standard batch size for which component quantities are defined. Typically expressed in production units (e.g., 1000 kg, 500 cases).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Batch Record Template Code' ;
    rdfs:comment 'Reference to the master batch record template used for GMP documentation when executing this BOM.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomUsageType rdf:type rdf:Property ;
    rdfs:label 'Bom Usage Type' ;
    rdfs:comment 'The primary purpose of this BOM. Production BOMs are executable; costing BOMs are used for standard cost calculation; engineering BOMs are R&D prototypes.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'The expected time in minutes required to changeover equipment from the previous product to this BOM. Critical for production scheduling optimization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Compliance Flag' ;
    rdfs:comment 'Indicates whether this BOM meets clean label criteria (no artificial ingredients, preservatives, or additives) for marketing and consumer transparency.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coPackingArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packing Arrangement Flag' ;
    rdfs:comment 'Indicates whether this BOM is executed under a co-packing or toll manufacturing arrangement with a third-party manufacturer (3PL).' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costEstimateVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Version' ;
    rdfs:comment 'Links to the standard cost estimate version used for COGS calculation based on this BOM\'s component costs.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Critical Flag' ;
    rdfs:comment 'Indicates whether this BOM includes HACCP critical control points requiring enhanced monitoring and documentation during production.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryConsumptionMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Consumption Method' ;
    rdfs:comment 'The method used to consume component inventory during production. FIFO (First In First Out) or FEFO (First Expired First Out) are standard for food and beverage to ensure freshness and minimize waste.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The date when this BOM was last reviewed for accuracy, regulatory compliance, and cost optimization. BOMs should be reviewed annually or upon ingredient changes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmFormulationReference rdf:type rdf:Property ;
    rdfs:label 'Plm Formulation Reference' ;
    rdfs:comment 'Reference to the R&D formulation record in the PLM system from which this production BOM was derived. Maintains traceability from innovation to manufacturing.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineAssignment rdf:type rdf:Property ;
    rdfs:label 'Production Line Assignment' ;
    rdfs:comment 'The specific production line or work center where this BOM is typically executed. Supports line-specific BOMs for equipment constraints.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'The FDA, USDA, or other regulatory body approval or registration number for this BOM formulation, if required for the product category.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'The expected production cycle time in minutes to produce one base quantity batch. Used for capacity planning and OEE calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditionsRequired rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions Required' ;
    rdfs:comment 'The required storage conditions for the finished product (e.g., ambient, refrigerated 2-8°C, frozen below -18°C). Critical for warehouse management and distribution planning.' ;
    rdfs:domain ind:ManufacturingProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Expected yield percentage accounting for normal production losses, evaporation, and waste. Used for accurate material requirements planning (MRP).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: Production orders are created from demand plans; linking enables S&OP reconciliation and demand-supply variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Standard or planned batch size for this production run. Represents the nominal production lot size for the SKU on the assigned line.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'SAP PP confirmation document number generated by CO11N transaction. Links to detailed confirmation records including time, quantity, and goods movements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the production confirmation was posted in SAP PP via CO11N transaction.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Type of production confirmation: partial (interim confirmation during production run) or final (completion confirmation closing the order).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoLotConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Lot Consumption Flag' ;
    rdfs:comment 'Boolean flag indicating whether raw material lot consumption for this order followed FEFO inventory management rules (consuming lots with nearest expiration first). True if FEFO was enforced, False otherwise. Critical for perishable food and beverage ingredients.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoLotConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Lot Consumption Flag' ;
    rdfs:comment 'Boolean flag indicating whether raw material lot consumption for this order followed FIFO inventory management rules. True if FIFO was enforced, False otherwise.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsMovementDocument rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Document' ;
    rdfs:comment 'SAP MM material document number for the goods receipt posting (MIGO 101 movement type) that moved confirmed quantity into finished goods inventory.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpLogReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Log Reference' ;
    rdfs:comment 'Reference identifier to the HACCP CCP monitoring log for this production order. Links to detailed records of critical control point measurements (temperature, pH, time, etc.) taken during production.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesWorkOrderReference rdf:type rdf:Property ;
    rdfs:label 'Mes Work Order Reference' ;
    rdfs:comment 'Work order identifier from Aveva/Wonderware MES system. Provides linkage between SAP PP production order and detailed MES execution records including real-time process data, equipment performance, and operator actions.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'SAP PP production order number - the externally-known business identifier for this manufacturing execution record. Typically 10-12 alphanumeric characters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkDisposition rdf:type rdf:Property ;
    rdfs:label 'Rework Disposition' ;
    rdfs:comment 'Final disposition of reworked material: reprocessed (successfully reworked to original spec), downgraded (reworked to lower-grade product), scrapped (could not be salvaged), returned_to_vendor (raw material defect). Applicable only when order_type is rework.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework or reprocessing. This quantity is typically moved to a rework order for corrective processing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rework Reason Code' ;
    rdfs:comment 'Code identifying the reason for rework when order_type is rework. Examples: quality defect, packaging error, labeling error, contamination, off-spec product. Null for non-rework orders.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version identifier of the production routing or recipe used for this order. Defines the sequence of operations and process parameters.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned completion date for production order execution as determined by production scheduling or SAP IBP.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned start date for production order execution as determined by production scheduling or SAP IBP.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of product scrapped or discarded during production due to quality defects, process failures, or other non-conformances. Measured in base unit of measure.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollManufacturerName rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturer Name' ;
    rdfs:comment 'Name of the toll manufacturing partner when order_type is toll. In toll arrangements, the customer provides raw materials and the toll manufacturer provides processing services. Null for non-toll orders.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Percentage' ;
    rdfs:comment 'Variance between planned and actual yield, calculated as (actual_yield - planned_yield) / planned_yield * 100. Positive values indicate over-yield, negative values indicate under-yield.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergenChangeoverRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Changeover Required' ;
    rdfs:comment 'Flag indicating whether allergen-related line clearance and deep cleaning is required before this production run due to allergen matrix considerations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Batch Size Target' ;
    rdfs:comment 'Target batch size for this production run, expressed in the same UOM as planned quantity. Used for batch manufacturing and Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned utilization percentage of the work center\'s available capacity for this schedule entry. Used for capacity planning and bottleneck analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewSizeRequired rdf:type rdf:Property ;
    rdfs:label 'Crew Size Required' ;
    rdfs:comment 'Number of operators or crew members required to execute this production schedule entry. Used for labor capacity planning.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Completion Timestamp' ;
    rdfs:comment 'The date and time when the actual production execution for this schedule entry was completed and confirmed by the MES. Used for schedule vs. actual performance analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'The forecasted demand quantity that this schedule entry is intended to fulfill. Used for demand-driven planning and forecast accuracy tracking.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCcpApplicable rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Applicable' ;
    rdfs:comment 'Flag indicating whether this production schedule entry involves HACCP Critical Control Points that require monitoring and documentation per food safety regulations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReplanningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Replanning Timestamp' ;
    rdfs:comment 'The date and time when this schedule entry was last revised or replanned. Used for tracking schedule stability and replanning frequency.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotNumberPlanned rdf:type rdf:Property ;
    rdfs:label 'Lot Number Planned' ;
    rdfs:comment 'Pre-assigned lot number for traceability purposes. Enables First In First Out (FIFO) and First Expired First Out (FEFO) inventory consumption tracking and lot genealogy.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Material Availability Status' ;
    rdfs:comment 'Status indicating whether all required raw materials and ingredients are available for this scheduled production. Confirmed indicates full availability; partial indicates some materials available; pending indicates materials not yet checked; shortage indicates insufficient inventory.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetDate rdf:type rdf:Property ;
    rdfs:label 'Otif Target Date' ;
    rdfs:comment 'The target delivery date for On Time In Full (OTIF) performance measurement. Used to track schedule adherence and customer service level.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the planned quantity (e.g., cases, kilograms, liters, pallets). Aligns with SKU base UOM.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'The planning time bucket or horizon this schedule belongs to (e.g., weekly, daily, shift-level). Indicates the granularity of the planning cycle.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether this production run requires in-process or post-production quality inspection per Quality Management (QM) protocols.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedToMesTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released To Mes Timestamp' ;
    rdfs:comment 'The date and time when this schedule entry was released to the Manufacturing Execution System (MES) for execution. Marks the transition from planning to execution.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replanningReason rdf:type rdf:Property ;
    rdfs:label 'Replanning Reason' ;
    rdfs:comment 'Business reason for the most recent replanning event (e.g., demand change, material shortage, equipment breakdown, customer request). Used for root cause analysis of schedule instability.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockTarget rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target' ;
    rdfs:comment 'Target safety stock level that this production schedule entry is intended to maintain or replenish. Used for inventory optimization.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or comments from the planner regarding special considerations, constraints, or instructions for this schedule entry.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the production schedule. Allows tracking of schedule revisions and replanning iterations (e.g., V1, V2, V2.1).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Minutes' ;
    rdfs:comment 'Total planned production duration in minutes, including run time but excluding changeover time. Used for Overall Equipment Effectiveness (OEE) baseline calculations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'The planned date and time when production for this schedule entry is expected to be completed. Used for capacity planning and On Time In Full (OTIF) tracking.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'The planned date and time when production for this schedule entry is expected to begin. Used for capacity planning and sequencing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:setupInstructions rdf:type rdf:Property ;
    rdfs:label 'Setup Instructions' ;
    rdfs:comment 'Special setup or configuration instructions for the work center to execute this schedule entry. May reference standard operating procedures (SOPs) or work instructions.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the production routing master record.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this routing for production use.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this routing record.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Employee Id' ;
    rdfs:comment 'Reference to the production planner or scheduler responsible for maintaining this routing and resolving production issues.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this routing record.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingSupplierId rdf:type rdf:Property ;
    rdfs:label 'Routing Supplier Id' ;
    rdfs:comment 'Reference to the third-party co-packing supplier if this routing represents externally manufactured production. Null for internal production.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:routingTollManufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Routing Toll Manufacturer Supplier Id' ;
    rdfs:comment 'Reference to the toll manufacturing supplier if this routing represents production where the company provides raw materials and the supplier provides processing. Null for internal or co-packed production.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allergenHandlingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Required Flag' ;
    rdfs:comment 'Indicates whether this routing requires special allergen handling procedures, such as line changeover cleaning or dedicated equipment, to prevent cross-contact.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'The minimum production lot size for which this routing is valid. Supports lot-size-dependent routing selection.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'The maximum production lot size for which this routing is valid. Null indicates no upper limit.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'The largest production quantity that can be produced in a single batch using this routing, constrained by equipment capacity or process limits.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'The smallest production quantity that can be economically or technically produced using this routing, expressed in the base UOM.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'The total number of sequential operations (work center steps) defined in this routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Allowed Flag' ;
    rdfs:comment 'Indicates whether non-conforming product from this routing can be reworked through a defined rework operation sequence.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Free-text description of the routing, typically summarizing the production method or key process characteristics (e.g., \'High-speed aseptic filling line\', \'Manual batch mixing and packaging\').' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. The externally-known unique code used to reference this routing in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production order creation; draft and under-review routings are in development; inactive and obsolete routings are no longer used.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing. Standard routings are the default production method; alternative routings provide flexibility for capacity or material constraints; trial routings support NPD; co-packing and toll manufacturing routings reflect external production arrangements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'The expected percentage of material loss or waste across all operations in this routing, used for material planning and costing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Standard Production Time Minutes' ;
    rdfs:comment 'The sum of all operation standard times (setup, machine, labor) across the routing, expressed in minutes. Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'The business purpose for which this routing is maintained. Production routings drive MES execution; costing routings feed standard cost calculations; maintenance and quality inspection routings support non-production work orders.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Environmental Instrument Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_instrument. Business justification: Renewable Energy Certificates are allocated to specific equipment/work centers for compliance and reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalInstrument .

ind:responsibleSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Supervisor Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scadaNodeId rdf:type rdf:Property ;
    rdfs:label 'Scada Node Id' ;
    rdfs:comment 'SCADA system node identifier for real-time monitoring and control of this work center\'s automation equipment.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when this work center became operational and available for production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when this work center was decommissioned or taken out of service. Null for currently active work centers.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergenCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Capable Flag' ;
    rdfs:comment 'Indicates whether this work center is capable of processing products containing major food allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans). Critical for allergen control and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of specific allergen types that this work center is approved to handle (e.g., milk, peanuts, tree nuts, soy). Empty if allergen_capable_flag is false. [ENUM-REF-CANDIDATE: milk|eggs|fish|shellfish|tree_nuts|peanuts|wheat|soybeans|sesame|sulfites — promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center based on shift pattern and planned maintenance windows.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cip Cycle Time Minutes' ;
    rdfs:comment 'Standard duration in minutes for a complete CIP cleaning cycle on this work center. Null if CIP is not required.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Required Flag' ;
    rdfs:comment 'Indicates whether this work center requires automated clean-in-place procedures between production runs. Critical for liquid processing, dairy, and beverage lines.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coPackingApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packing Approved Flag' ;
    rdfs:comment 'Indicates whether this work center is approved for co-packing or toll manufacturing operations for third-party brands.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP hygiene classification level of the work center determining the sanitation, personnel, and environmental control requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the work center by its primary production process type. Determines the type of operations and products that can be manufactured on this line. [ENUM-REF-CANDIDATE: mixing|filling|packaging|pasteurization|fermentation|extrusion|co-packing|blending|bottling|canning — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRunSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Run Size' ;
    rdfs:comment 'Maximum production quantity that can be manufactured on this work center in a single run due to equipment, storage, or process constraints.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRunSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Run Size' ;
    rdfs:comment 'Minimum production quantity that can be economically manufactured on this work center in a single run. Used to enforce MOQ constraints in production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance shutdown for this work center. Used for production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this work center representing the product of availability, performance, and quality rates. Industry benchmark for world-class manufacturing is 85%.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionArea rdf:type rdf:Property ;
    rdfs:label 'Production Area' ;
    rdfs:comment 'Physical production area or zone within the plant where the work center is located (e.g., Mixing Room, Filling Hall, Packaging Wing, Cold Storage).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Units Per Hour' ;
    rdfs:comment 'Maximum theoretical production capacity of the work center expressed in units per hour under optimal operating conditions. Used for production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runSizeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Run Size Unit Of Measure' ;
    rdfs:comment 'Unit of measure for minimum and maximum run sizes. [ENUM-REF-CANDIDATE: cases|bottles|cans|pounds|kilograms|liters|gallons|batches — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to prepare the work center for a production run, including equipment configuration, material staging, and pre-operational checks.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard operating shift pattern for this work center determining its available production hours per day.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean, sanitize, and restore the work center after a production run. Critical for GMP compliance and allergen control.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'High-level categorization of the work center by its functional role in the manufacturing process.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Business identifier code for the work center used in production planning and scheduling systems. Typically alphanumeric code assigned by manufacturing operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed description of the work center including its purpose, capabilities, and operational characteristics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Descriptive name of the work center for human identification and reporting purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center indicating its availability for production scheduling and execution.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConsumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Brand strategy defines a target consumer segment; FK replaces the denormalized segment name, enabling segment-based budgeting and compliance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:allergenFreeClaims rdf:type rdf:Property ;
    rdfs:label 'Allergen Free Claims' ;
    rdfs:comment 'Comma-separated list of allergen-free claims associated with the brand (e.g., \'gluten-free, nut-free, dairy-free\'). Derived from the allergen matrix managed in TraceGains. Must comply with FDA FALCPA (Food Allergen Labeling and Consumer Protection Act) and FSMA requirements. Used in consumer marketing and retail planogram placement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget' ;
    rdfs:comment 'Total approved annual marketing investment budget allocated to the brand, expressed in the functional currency. Includes above-the-line (ATL) advertising, below-the-line (BTL) shopper marketing, digital, and trade promotion spend. Confidential financial data managed in Oracle Cloud ERP Financials and SAP CO cost centers.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the brand within the corporate brand architecture hierarchy. \'masterbrand\' = umbrella brand covering multiple product lines; \'sub_brand\' = brand operating under a masterbrand; \'endorsed\' = independent brand with parent brand endorsement; \'standalone\' = fully independent brand; \'private_label\' = retailer-owned brand manufactured by Food Beverage under co-packing or toll manufacturing arrangements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessPct rdf:type rdf:Property ;
    rdfs:label 'Awareness Pct' ;
    rdfs:comment 'Unaided or total brand awareness percentage among the target consumer segment, expressed as a value between 0.00 and 100.00. Sourced from Nielsen/IRI consumer panel studies or commissioned brand health tracking research. Key input to brand equity score calculation and marketing investment justification.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary consumer product category to which the brand belongs (e.g., \'Snacks\', \'Beverages\', \'Dairy\', \'Packaged Foods\', \'RTD Coffee\', \'RTE Cereals\'). Aligns with Nielsen/IRI/SPINS syndicated data category taxonomy for market tracking and ACV/TDP reporting. [ENUM-REF-CANDIDATE: snacks|beverages|dairy|packaged_foods|rte_cereals|rtd_beverages|condiments|frozen_foods|confectionery|other — promote to reference product]' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Official commercial name of the brand as registered and used in consumer-facing marketing, packaging, and trade communications. This is the primary human-readable identifier for the brand (e.g., \'SunCrisp\', \'HydraFlow\'). Must align with FTC-approved marketing claims and FDA labeling requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual marketing budget (e.g., \'USD\', \'EUR\', \'GBP\'). Ensures correct financial reporting and multi-currency consolidation in Oracle Cloud ERP and SAP S/4HANA FI.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelCertified rdf:type rdf:Property ;
    rdfs:label 'Clean Label Certified' ;
    rdfs:comment 'Indicates whether the brand carries a clean label certification or commitment (no artificial colors, flavors, preservatives, or GMO ingredients). Drives consumer marketing claims, shelf placement in natural/organic sections, and SPINS natural channel data eligibility. Must be substantiated per FTC claim guidelines.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmBrandCode rdf:type rdf:Property ;
    rdfs:label 'Crm Brand Code' ;
    rdfs:comment 'Brand identifier as recorded in Salesforce CRM (Sales Cloud / Marketing Cloud). Used for cross-system reconciliation between the lakehouse brand master and Salesforce campaign and consumer engagement records. Enables brand-level marketing performance attribution.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPresenceUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Presence Url' ;
    rdfs:comment 'Primary website URL for the brand\'s consumer-facing digital presence (e.g., \'https://www.suncrisp.com\'). Used in Salesforce Marketing Cloud digital campaign management, SEO tracking, and consumer engagement analytics.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Calendar date on which the brand was officially discontinued or withdrawn from the market. Null if the brand is currently active. Used for portfolio rationalization analysis, regulatory deregistration, and historical reporting in Nielsen/IRI market tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary route-to-market channel through which the brand\'s products are sold. \'retail\' = traditional grocery/mass/drug; \'foodservice\' = restaurants/institutions; \'dsd\' = Direct Store Delivery; \'dtc\' = Direct-to-Consumer; \'ecommerce\' = online retail; \'club\' = club/warehouse channel. Drives trade promotion strategy (TPM/TPO) and supply chain configuration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Composite brand equity score derived from consumer research inputs including awareness, consideration, preference, and loyalty metrics. Scored on a 0-100 scale. Sourced from Nielsen/IRI brand health tracking studies and internal NPS panel data. Confidential strategic metric used in portfolio investment decisions and brand valuation.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpBrandCode rdf:type rdf:Property ;
    rdfs:label 'Erp Brand Code' ;
    rdfs:comment 'Brand identifier as recorded in the source ERP system (SAP S/4HANA or Oracle Cloud ERP). Used for cross-system reconciliation between the lakehouse silver layer brand master and operational ERP brand records. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertification rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification' ;
    rdfs:comment 'GFSI-benchmarked food safety certification scheme applicable to the brand\'s manufacturing operations. \'sqf\' = Safe Quality Food (SQF); \'brc\' = British Retail Consortium Global Standard; \'fssc_22000\' = Food Safety System Certification 22000; \'ifs\' = International Featured Standards; \'global_gap\' = GlobalG.A.P.; \'none\' = no GFSI certification. Tracked in Veeva Vault and TraceGains supplier compliance.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpPlanReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Reference' ;
    rdfs:comment 'Reference identifier for the HACCP plan document associated with the brand\'s manufacturing process, stored in Veeva Vault Document Control. HACCP (Hazard Analysis Critical Control Points) is a mandatory food safety management system under FDA FSMA and USDA FSIS regulations. Used for audit traceability and regulatory compliance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Calendar date on which the brand was first commercially launched and made available to consumers in its primary market. Used for brand age calculations, anniversary marketing campaigns, and PLM lifecycle tracking. Aligns with SAP PLM product launch milestones.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the brand within its commercial lifecycle. \'active\' = currently marketed and sold; \'discontinued\' = no longer produced or sold; \'pipeline\' = in NPD/R&D phase, not yet launched; \'divested\' = sold or transferred to another entity; \'archived\' = historical record retained for compliance. Drives PLM alignment and portfolio management decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL pointing to the master brand logo asset stored in the digital asset management (DAM) system. Used by Salesforce Marketing Cloud, packaging design teams, and agency partners for consistent brand identity application across all consumer touchpoints.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDivision rdf:type rdf:Property ;
    rdfs:label 'Owner Division' ;
    rdfs:comment 'Internal business division or operating unit that owns and manages the brand (e.g., \'North America Snacks\', \'Global Beverages\', \'International Dairy\'). Used for P&L attribution, marketing budget allocation, and organizational reporting in SAP CO and Oracle Financials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmProductLineCode rdf:type rdf:Property ;
    rdfs:label 'Plm Product Line Code' ;
    rdfs:comment 'Reference code linking the brand to its associated product line in the PLM system (SAP PLM or equivalent). Enables traceability between brand master data and the SKU/product hierarchy managed in PLM. Used for NPD pipeline tracking and BOM management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Internal strategic statement articulating the brand\'s unique value proposition, competitive differentiation, and reason-to-believe for the target consumer segment. Confidential business strategy document used in brand planning, NPD briefs, and agency briefings. Not for external distribution.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s primary brand color as defined in the brand identity guidelines (e.g., \'#FF6B35\'). Used for consistent visual identity application across digital marketing, packaging, and trade materials in Salesforce Marketing Cloud and design systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the brand\'s primary commercial market (e.g., \'USA\', \'GBR\', \'DEU\'). Determines applicable regulatory frameworks (FDA, EFSA, USDA), labeling requirements, and market data sourcing (Nielsen/IRI for USA, SPINS for natural channel).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promise rdf:type rdf:Property ;
    rdfs:label 'Promise' ;
    rdfs:comment 'Consumer-facing articulation of the core benefit or commitment the brand makes to its consumers (e.g., \'Real ingredients, real taste\'). Used in marketing communications, packaging copy, and Salesforce Marketing Cloud campaign messaging. Must comply with FTC advertising claim substantiation requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the brand\'s official social media presence (e.g., \'@SunCrispSnacks\'). Used for social media monitoring, influencer partnership management, and Salesforce Marketing Cloud social engagement tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClaim rdf:type rdf:Property ;
    rdfs:label 'Sustainability Claim' ;
    rdfs:comment 'Sustainability or environmental claim associated with the brand (e.g., \'Carbon Neutral\', \'Rainforest Alliance Certified\', \'B Corp Certified\', \'Recyclable Packaging\'). Must be substantiated per FTC Green Guides (16 CFR Part 260) and EPA environmental compliance standards. Supports ESG reporting and consumer engagement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Commercial positioning tier of the brand within the portfolio pricing and consumer value ladder. \'super_premium\' = ultra-high-end, limited distribution; \'premium\' = above-mainstream RSP positioning; \'mainstream\' = mass-market EDLP positioning; \'value\' = price-entry or economy positioning. Drives RSP strategy, trade promotion investment, and retail planogram placement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Expiry Date' ;
    rdfs:comment 'Date on which the brand\'s trademark registration expires and must be renewed to maintain legal protection. Used for IP lifecycle management and legal compliance tracking. Triggers renewal workflows in legal management systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official trademark registration number issued by the relevant intellectual property authority (e.g., USPTO, EUIPO, WIPO). Used for IP management, legal protection, and brand licensing agreements. Confidential business identifier managed in legal systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandEquityTrackerId rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Tracker Id' ;
    rdfs:comment 'Unique surrogate identifier for each brand equity measurement record in the tracker. Primary key for the brand_equity_tracker data product.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Id' ;
    rdfs:comment 'Reference to the consumer segment (e.g., millennials, health-conscious, heavy users) for which brand equity metrics are reported. Enables segment-level brand health analysis.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:marketId rdf:type rdf:Property ;
    rdfs:label 'Market Id' ;
    rdfs:comment 'Reference to the geographic market or region in which brand equity is being measured (e.g., US, UK, Germany). Supports multi-market brand health comparison.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Market .

ind:advertisingRecallPct rdf:type rdf:Property ;
    rdfs:label 'Advertising Recall Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who recall seeing or hearing advertising for the brand in the measurement period. Measures advertising effectiveness and media investment impact on brand awareness. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who recognize the brand when shown or told the brand name. Measures total brand recognition in the target market. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEquityStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Status' ;
    rdfs:comment 'Lifecycle status of this brand equity measurement record. \'preliminary\' indicates data is not yet finalized; \'final\' indicates validated and approved data; \'restated\' indicates a correction to a previously published record; \'archived\' indicates superseded records.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandHealthIndex rdf:type rdf:Property ;
    rdfs:label 'Brand Health Index' ;
    rdfs:comment 'Composite index score aggregating multiple brand equity dimensions (awareness, consideration, trial, repeat, love, NPS) into a single brand health measure. Methodology and weighting defined by the tracking study. Used for executive-level brand performance monitoring.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandLoveScore rdf:type rdf:Property ;
    rdfs:label 'Brand Love Score' ;
    rdfs:comment 'Composite score measuring the emotional affinity and loyalty consumers have toward the brand. Typically derived from survey questions on emotional connection, advocacy, and preference. Scale defined by the tracking study methodology.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPreferencePct rdf:type rdf:Property ;
    rdfs:label 'Brand Preference Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who prefer the brand over competitive alternatives in the category. Measures competitive brand positioning and differentiation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandQualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Brand Quality Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s product quality, including taste, freshness, ingredients, and overall product experience. Critical for food and beverage brand positioning and premium pricing strategy.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandTrustScore rdf:type rdf:Property ;
    rdfs:label 'Brand Trust Score' ;
    rdfs:comment 'Score measuring consumer trust in the brand, typically derived from survey questions on reliability, safety, and quality perceptions. Particularly relevant for food and beverage brands given food safety and clean label consumer expectations.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandValuePerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Brand Value Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s value for money relative to its price point. Supports Revenue Management and Pricing Strategy (RSP/EDLP) decisions and trade promotion effectiveness analysis.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'The product category in which the brand competes and is being measured (e.g., \'Carbonated Soft Drinks\', \'Salty Snacks\', \'Dairy Beverages\', \'Ready-to-Eat Cereals\'). Enables category-level brand equity benchmarking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Clean Label Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s commitment to clean label attributes (natural ingredients, no artificial additives, transparent labeling). Highly relevant in the food and beverage industry given growing consumer demand for clean label products.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSetLabel rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Label' ;
    rdfs:comment 'Label identifying the defined set of competitor brands included in the tracking study for benchmarking purposes (e.g., \'Core 5 Competitors\', \'Total Category Set\'). Ensures consistent competitive context across measurement waves.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Pct' ;
    rdfs:comment 'The margin of error (confidence interval) expressed as a percentage for the reported brand equity metrics, based on the sample size and study methodology. Typically ±2% to ±5%. Used to assess statistical significance of period-over-period changes.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationPct rdf:type rdf:Property ;
    rdfs:label 'Consideration Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who would consider purchasing the brand the next time they are in the market for the category. Measures brand relevance and purchase funnel progression. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'The primary methodology used to collect consumer survey data for this measurement wave (e.g., online panel, telephone interview, in-person interview, mobile survey). Affects comparability across waves and markets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detractorPct rdf:type rdf:Property ;
    rdfs:label 'Detractor Pct' ;
    rdfs:comment 'Percentage of surveyed consumers classified as detractors (NPS score 0-6) who are unlikely to recommend the brand and may actively discourage others. Component of the NPS calculation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the market in which brand equity is measured (e.g., \'USA\', \'GBR\', \'DEU\'). Enables standardized cross-market reporting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement period covered by this brand equity record. Together with measurement_period_start_date, defines the tracking wave window.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement period covered by this brand equity record. Used to define the temporal window of the tracking wave (e.g., Q1 start, monthly wave start).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodOverPeriodChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Period Over Period Change Flag' ;
    rdfs:comment 'Indicates whether the brand health index change from the prior measurement period is statistically significant based on the confidence interval. True = statistically significant change detected; False = change within margin of error. Supports brand performance alerting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoterPct rdf:type rdf:Property ;
    rdfs:label 'Promoter Pct' ;
    rdfs:comment 'Percentage of surveyed consumers classified as promoters (NPS score 9-10) who are highly likely to recommend the brand. Component of the NPS calculation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who indicate they intend to purchase the brand in the near future (typically next 30 days). A leading indicator of short-term sales performance. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatPurchasePct rdf:type rdf:Property ;
    rdfs:label 'Repeat Purchase Pct' ;
    rdfs:comment 'Percentage of consumers who have tried the brand and subsequently purchased it again. Measures brand loyalty and consumer retention. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchVendorName rdf:type rdf:Property ;
    rdfs:label 'Research Vendor Name' ;
    rdfs:comment 'Name of the third-party market research vendor or syndicated data provider that conducted the tracking study (e.g., Nielsen, IRI, SPINS, Kantar, Ipsos). Used for data lineage, vendor management, and methodology comparability.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of consumers surveyed in this measurement wave for the specified brand, market, and consumer segment combination. Used to assess statistical reliability and confidence of the reported brand equity metrics.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Social Media Sentiment Score' ;
    rdfs:comment 'Composite score reflecting the overall sentiment (positive, neutral, negative) of consumer conversations about the brand on social media platforms during the measurement period. Sourced from social listening tools integrated with Salesforce Marketing Cloud.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s sustainability credentials, including environmental responsibility, ethical sourcing, and packaging sustainability. Supports the Sustainability data domain and ESG reporting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingStudyCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Study Code' ;
    rdfs:comment 'Reference to the brand tracking study or research program that generated this measurement record. Links to the study design, methodology, and vendor details.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialPct rdf:type rdf:Property ;
    rdfs:label 'Trial Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who have ever purchased or tried the brand at least once. Measures brand penetration and new consumer acquisition effectiveness. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unaidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Unaided Awareness Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who spontaneously mention the brand when asked about brands in the category, without any prompting. A key top-of-mind brand health metric. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveLabel rdf:type rdf:Property ;
    rdfs:label 'Wave Label' ;
    rdfs:comment 'Human-readable label identifying the measurement wave (e.g., \'Q1 2024\', \'Wave 3 2024\', \'Jan 2024\'). Used for reporting and trend analysis across tracking periods.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Frequency classification of the measurement wave. Indicates whether the tracking study is conducted monthly, quarterly, bi-annually, annually, or on an ad hoc basis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'FK to marketing.agency' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:primarySkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign planning uses a primary SKU for messaging and budgeting; the Primary SKU field drives the Campaign Brief and media allocation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Total actual expenditure incurred for the campaign in US dollars as of the latest financial close. Compared against planned_budget_usd to track budget utilization and variance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvTargetPct rdf:type rdf:Property ;
    rdfs:label 'Acv Target Pct' ;
    rdfs:comment 'Target percentage of All Commodity Volume (ACV) distribution coverage for the campaign\'s featured products. ACV % is a standard food and beverage industry metric for measuring retail distribution breadth.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the campaign received final business approval to proceed. Used for governance audit trails and time-to-market measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Alphanumeric business identifier for the campaign used in ERP cost tracking, trade promotion management (TPM), and cross-system reconciliation. Follows internal naming convention (e.g., \'CAMP-2024-BEV-001\').' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign, including creative concept, key messages, promotional mechanics, and strategic rationale. Used for stakeholder briefings and campaign documentation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign (e.g., \'Summer Refresh 2024 — National TV Burst\'). Used in reporting, dashboards, and stakeholder communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (in development), planned (approved, not yet live), active (currently running), paused (temporarily halted), completed (finished), or cancelled (terminated before completion).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by its primary marketing objective: awareness (brand building), trial (new consumer acquisition), loyalty (retention), trade (retailer/channel incentive), shopper (in-store activation), or influencer (creator-led). [ENUM-REF-CANDIDATE: awareness|trial|loyalty|trade|shopper|influencer|sponsorship|sampling|digital|event — promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaClaimsCompliant rdf:type rdf:Property ;
    rdfs:label 'Fda Claims Compliant' ;
    rdfs:comment 'Indicates whether all product claims featured in the campaign (e.g., health claims, nutrient content claims, clean label statements) comply with FDA regulations. True = compliant; False = non-compliant or under review.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcClaimsReviewed rdf:type rdf:Property ;
    rdfs:label 'Ftc Claims Reviewed' ;
    rdfs:comment 'Indicates whether all marketing claims in this campaign have been reviewed for compliance with FTC guidelines on advertising and marketing claims (e.g., substantiation of health/nutrition claims). True = reviewed and cleared; False = not yet reviewed.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:influencerPartnership rdf:type rdf:Property ;
    rdfs:label 'Influencer Partnership' ;
    rdfs:comment 'Indicates whether this campaign includes a paid influencer or creator partnership component. True = influencer partnership present; False = no influencer component. Supports FTC disclosure compliance tracking.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP S/4HANA CO internal order number used to collect and settle campaign costs. Provides granular cost tracking at the campaign level within the ERP system.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaImpressionsTarget rdf:type rdf:Property ;
    rdfs:label 'Media Impressions Target' ;
    rdfs:comment 'Planned number of media impressions (total ad exposures) targeted for the campaign across all channels. Used as a key performance indicator (KPI) for reach planning and post-campaign evaluation against Nielsen/IRI data.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Free-text description of the primary business objective for the campaign (e.g., \'Drive 10% household penetration increase for RTD line in Q3\'). Supports brand marketing and consumer engagement planning.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Usd' ;
    rdfs:comment 'Total approved budget allocated to the campaign in US dollars at the time of planning. Used for financial planning, trade promotion management (TPM), and return on investment (ROI) analysis.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this campaign supports a private label product program rather than a branded product. True = private label campaign; False = branded campaign. Relevant for retailer co-marketing and private label program data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachTargetHouseholds rdf:type rdf:Property ;
    rdfs:label 'Reach Target Households' ;
    rdfs:comment 'Planned number of unique households targeted for campaign reach. Aligns with Nielsen household panel measurement methodology for consumer packaged goods (CPG) reach reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sfmcCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Sfmc Campaign Code' ;
    rdfs:comment 'External campaign identifier assigned by Salesforce Marketing Cloud (SFMC). Used to correlate lakehouse records with SFMC execution records for digital and email channel campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperMarketingFlag rdf:type rdf:Property ;
    rdfs:label 'Shopper Marketing Flag' ;
    rdfs:comment 'Indicates whether this campaign includes a shopper marketing activation (e.g., in-store display, planogram feature, digital coupon at point of sale). True = shopper marketing component present.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuScope rdf:type rdf:Property ;
    rdfs:label 'Sku Scope' ;
    rdfs:comment 'Comma-separated list or description of the specific SKUs (Stock Keeping Units) included in the campaign. Supports product-level performance attribution and trade promotion management (TPM) analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Geographic scope of the campaign (e.g., \'National US\', \'Northeast Region\', \'California DMA\'). Used for media buying, distribution alignment, and regional performance reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpTarget rdf:type rdf:Property ;
    rdfs:label 'Tdp Target' ;
    rdfs:comment 'Target Total Distribution Points (TDP) for the campaign\'s featured SKUs. TDP is a standard food and beverage metric combining distribution breadth and depth across retail accounts.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradePromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Flag' ;
    rdfs:comment 'Indicates whether this campaign includes a trade promotion component (e.g., retailer co-op, slotting fee, off-invoice discount). True = trade promotion included. Supports Trade Promotion Management (TPM) and Trade Promotion Optimization (TPO) workflows.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Unique surrogate identifier for each campaign execution record. Represents a single activation of a campaign flight across a specific channel, geography, and time period. Role: TRANSACTION_HEADER — primary key.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignExecution .

ind:digitalAssetId rdf:type rdf:Property ;
    rdfs:label 'Digital Asset Id' ;
    rdfs:comment 'Reference to the specific creative asset version deployed in this execution. Enables creative performance analysis and FTC compliance tracking for marketing claims.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalAsset .

ind:nutritionLabelId rdf:type rdf:Property ;
    rdfs:label 'Nutrition Label Id' ;
    rdfs:comment 'Foreign key linking to regulatory.nutrition_label. Business justification: Campaign Execution Compliance: execution must reference the nutrition label of the SKU to ensure advertised claims match label information.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NutritionLabel .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign execution references a specific SKU; FK replaces free-text SKU and aligns marketing spend with product master.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The actual media spend incurred for this execution flight as billed by the media vendor or agency. Used for ROI calculation and budget reconciliation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The format of the advertisement deployed in this execution (e.g., banner, video, carousel, sponsored product). Supports format-level performance and creative strategy analysis. [ENUM-REF-CANDIDATE: banner|video|carousel|native|sponsored_product|story|interstitial|rich_media — promote to reference product]' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the media agency or buying partner responsible for executing this campaign flight. Used for agency performance tracking and invoice reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingType rdf:type rdf:Property ;
    rdfs:label 'Buying Type' ;
    rdfs:comment 'The media buying model used for this execution (e.g., CPM — Cost Per Thousand, CPC — Cost Per Click, CPA — Cost Per Acquisition, CPV — Cost Per View, flat fee, programmatic). Drives cost structure and performance benchmarking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPlatform rdf:type rdf:Property ;
    rdfs:label 'Channel Platform' ;
    rdfs:comment 'Specific platform or publisher within the channel type where the execution runs (e.g., Facebook, Google, Instacart, Kroger Precision Marketing, YouTube). Enables platform-level performance benchmarking.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Compliance Status' ;
    rdfs:comment 'Regulatory compliance review status for marketing claims contained in this execution. Required when marketing_claim_flag is True. Supports FTC and FDA compliance audit trails.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'Total number of clicks recorded on the ad during this execution flight. Used to calculate click-through rate (CTR) and assess consumer engagement.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerThousandImpressions rdf:type rdf:Property ;
    rdfs:label 'Cost Per Thousand Impressions' ;
    rdfs:comment 'The cost per one thousand ad impressions for this execution, as negotiated with the media vendor. Standard media buying metric used for cross-channel efficiency benchmarking.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeVersion rdf:type rdf:Property ;
    rdfs:label 'Creative Version' ;
    rdfs:comment 'Version label of the creative asset deployed in this execution (e.g., v1.0, v2.3). Tracks which creative iteration was live during the flight for A/B testing and compliance audit.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Externally-known business identifier for this execution record, used in agency briefings, media plans, and vendor invoices. Format: CE-YYYY-NNNNNN. BUSINESS_IDENTIFIER per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle state of this campaign execution record. Tracks workflow from planning through completion. LIFECYCLE_STATUS per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'The date on which this campaign execution flight is scheduled to stop running in-market. Used for pacing, budget management, and post-campaign analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'The date on which this campaign execution flight begins running in-market. Represents the real-world activation date. BUSINESS_EVENT_TIMESTAMP per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of ad impressions delivered during this execution flight. A core digital media performance metric used for reach and frequency analysis. QUANTITATIVE_RESULT per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerPartnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Influencer Partnership Flag' ;
    rdfs:comment 'Indicates whether this execution involves a paid influencer or brand ambassador partnership. Triggers FTC endorsement disclosure compliance requirements.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Claim Flag' ;
    rdfs:comment 'Indicates whether this execution contains a regulated marketing claim (e.g., health claim, nutrient content claim, environmental claim). Triggers FTC and FDA compliance review workflow.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenMarketCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Market Code' ;
    rdfs:comment 'Nielsen-defined market or DMA (Designated Market Area) code associated with the geographic target of this execution. Enables alignment with Nielsen/IRI syndicated market data for sales lift analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'The specific ad placement or ad unit name within the platform (e.g., Facebook News Feed, Google Search Top, Instacart Sponsored Product). Supports granular placement-level performance analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'The budgeted media spend allocated to this execution flight in the media plan. Used for budget pacing and variance analysis against actual spend.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Total number of unique individuals exposed to the ad during this execution flight. Distinct from impressions (which counts total exposures including repeat). Key metric for brand awareness campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceActivityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activity Code' ;
    rdfs:comment 'The native activity or journey step identifier from Salesforce Marketing Cloud corresponding to this execution record. Enables direct traceability back to the source system of record.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the planned and actual spend amounts (e.g., USD, EUR, GBP). Required for multi-market campaign financial reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'The consumer audience segment targeted by this execution (e.g., Millennial Moms, Health-Conscious Shoppers, Snack Enthusiasts). Derived from consumer insights and CRM segmentation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeographyCode rdf:type rdf:Property ;
    rdfs:label 'Target Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code representing the primary geographic market targeted by this execution. Supports geo-level spend and performance reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegion rdf:type rdf:Property ;
    rdfs:label 'Target Region' ;
    rdfs:comment 'Sub-national region or market area targeted by this execution (e.g., Northeast US, California, EMEA). Supports regional marketing performance analysis and distribution center alignment.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRetailerName rdf:type rdf:Property ;
    rdfs:label 'Target Retailer Name' ;
    rdfs:comment 'Name of the specific retailer or trade account targeted by this shopper marketing or retail media execution (e.g., Walmart, Kroger, Target). Supports trade promotion and shopper marketing alignment.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'Urchin Tracking Module (UTM) campaign parameter appended to campaign URLs for this execution. Links digital traffic back to the specific campaign for attribution reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'Urchin Tracking Module (UTM) medium parameter appended to campaign URLs for this execution (e.g., cpc, email, social). Supports digital attribution and channel performance analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'Urchin Tracking Module (UTM) source parameter appended to campaign URLs for this execution. Used for digital attribution and web analytics tracking in Google Analytics and Salesforce Marketing Cloud.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Number' ;
    rdfs:comment 'The media vendor\'s or publisher\'s order or insertion order (IO) number associated with this execution. Used for invoice matching and vendor reconciliation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Proportion of video ad views that were completed to 100% of the video duration. Expressed as a decimal (e.g., 0.65 = 65%). Key metric for video creative effectiveness.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views recorded for video ad formats during this execution flight. Applicable when ad_format is video. Supports video completion rate analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimSubstantiationId rdf:type rdf:Property ;
    rdfs:label 'Claim Substantiation Id' ;
    rdfs:comment 'Unique surrogate identifier for each claim substantiation record. Primary key for the claim_substantiation data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelApprovalId rdf:type rdf:Property ;
    rdfs:label 'Label Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_approval. Business justification: Label Approval Reference: claim substantiation documents require a link to the label approval record that validates the claim.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelApproval .

ind:primaryClaimEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Claim Employee Id' ;
    rdfs:comment 'System user identifier of the individual who created this substantiation record. Supports electronic signature and audit trail requirements under FDA 21 CFR Part 11 and Veeva Vault Document Control.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByClaimSubstantiationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Claim Substantiation Id' ;
    rdfs:comment 'Reference to the newer claim_substantiation_id that replaces this record upon renewal or revision. Null if this is the current active version. Enables full substantiation lineage tracing across the claim lifecycle.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClaimSubstantiation .

ind:allergenClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Claim Flag' ;
    rdfs:comment 'Indicates whether the substantiated claim relates to allergen content (e.g., gluten-free, nut-free). True triggers additional FSMA and FDA allergen labeling compliance review.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Name' ;
    rdfs:comment 'Name or title of the individual, committee, or regulatory body that granted final approval for this substantiation record. Supports audit trail requirements for FTC and FDA compliance.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Role' ;
    rdfs:comment 'Functional role of the approving authority within the organization or regulatory body. Ensures the correct level of authority has signed off on the substantiation per internal governance policy.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Distribution or marketing channel(s) for which this substantiation is valid. Claim usage may be restricted to specific channels (e.g., a claim approved for retail packaging may not be approved for digital advertising).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'Regulatory classification of the claim type, determining the applicable substantiation standard and governing body oversight. Health claims require FDA pre-authorization; environmental claims are subject to FTC Green Guides. [ENUM-REF-CANDIDATE: health_claim|nutrient_content_claim|structure_function_claim|environmental_claim|organic_claim|clean_label_claim — promote to reference product]' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Verbatim consumer-facing claim statement that this substantiation record supports, as it appears on packaging, advertising, or digital media. Captured for FTC and FDA compliance audit trail.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfUse rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Use' ;
    rdfs:comment 'Specific conditions, disclaimers, or usage restrictions that must accompany the claim when used in consumer-facing communications. Examples include serving size qualifications or population-specific restrictions per FDA health claim regulations.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcChallengeRisk rdf:type rdf:Property ;
    rdfs:label 'Ftc Challenge Risk' ;
    rdfs:comment 'Internal risk assessment of the likelihood that the FTC would challenge this claim substantiation. Assigned by the Regulatory Affairs team. Classified confidential as it reflects internal legal risk posture.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Legal Review Outcome' ;
    rdfs:comment 'Outcome of the legal department review of the claim substantiation package. Approved with conditions may require claim text modification before consumer-facing use. Classified confidential due to legal privilege.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewReference rdf:type rdf:Property ;
    rdfs:label 'Legal Review Reference' ;
    rdfs:comment 'Internal legal department reference number for the legal review record associated with this substantiation. Links to the legal opinion or counsel sign-off document stored in Veeva Vault Document Control. Classified confidential due to attorney-client privilege considerations.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code identifying the market geography in which this substantiation is valid. Substantiation requirements vary by jurisdiction (e.g., FDA for USA, EFSA for EU member states).' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaTypeScope rdf:type rdf:Property ;
    rdfs:label 'Media Type Scope' ;
    rdfs:comment 'Media format(s) for which this substantiation authorizes claim usage. Ensures that claim deployment in Salesforce Marketing Cloud campaigns is restricted to approved media types.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary regulatory body whose standards govern the substantiation requirements for this claim. Determines the applicable evidentiary threshold and filing obligations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Number' ;
    rdfs:comment 'Official filing or docket number assigned by a regulatory authority (FDA, USDA, EFSA) for any pre-authorization, notification, or petition associated with this claim substantiation. Null if no regulatory filing is required.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this substantiation record requires periodic renewal before the expiry date. True triggers a re-substantiation workflow in Veeva Vault Quality Management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Study Publication Date' ;
    rdfs:comment 'Date on which the supporting scientific study or research was formally published or finalized. Used to assess currency and relevance of the evidentiary basis per FTC competent and reliable scientific evidence standards.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Study Reference Code' ;
    rdfs:comment 'External identifier for the supporting study, such as a PubMed ID, ClinicalTrials.gov NCT number, or internal R&D study code. Enables traceability to the source evidence document.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationNotes rdf:type rdf:Property ;
    rdfs:label 'Substantiation Notes' ;
    rdfs:comment 'Free-text field for Regulatory Affairs or Legal teams to document conditions, limitations, or caveats associated with this substantiation record. Classified confidential as notes may contain privileged legal commentary.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationNumber rdf:type rdf:Property ;
    rdfs:label 'Substantiation Number' ;
    rdfs:comment 'Externally-known business identifier for this substantiation record, used in regulatory filings, legal correspondence, and Veeva Vault document management. Format: SUB-YYYY-NNNNNN.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationStatus rdf:type rdf:Property ;
    rdfs:label 'Substantiation Status' ;
    rdfs:comment 'Current lifecycle state of the substantiation record within the approval workflow. Drives FTC and FDA compliance gating for consumer-facing claim activation. [ENUM-REF-CANDIDATE: draft|under_review|approved|rejected|expired|withdrawn — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationType rdf:type rdf:Property ;
    rdfs:label 'Substantiation Type' ;
    rdfs:comment 'Classification of the evidence type underpinning this substantiation record. Determines the evidentiary standard applied during legal and regulatory review per FTC competent and reliable scientific evidence requirements. [ENUM-REF-CANDIDATE: scientific_study|clinical_trial|meta_analysis|regulatory_filing|expert_opinion|consumer_survey — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingStudyTitle rdf:type rdf:Property ;
    rdfs:label 'Supporting Study Title' ;
    rdfs:comment 'Title of the primary scientific study, clinical trial, or research publication that provides the evidentiary basis for the claim. Stored as the human-readable reference for legal and regulatory review teams.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerified rdf:type rdf:Property ;
    rdfs:label 'Third Party Verified' ;
    rdfs:comment 'Indicates whether the substantiation evidence has been independently verified by a third-party organization (e.g., NSF International, GFSI-recognized body, or accredited laboratory). Enhances credibility and reduces FTC challenge risk.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyVerifierName rdf:type rdf:Property ;
    rdfs:label 'Third Party Verifier Name' ;
    rdfs:comment 'Name of the independent organization that verified the substantiation evidence. Populated only when third_party_verified is True. Examples include NSF International, SGS, Bureau Veritas, or a GFSI-recognized certification body.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Code' ;
    rdfs:comment 'Document identifier in Veeva Vault Document Control for the substantiation package, including study reports, legal opinions, and regulatory filings. Enables direct navigation to the source document from the Silver Layer.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerInsightId rdf:type rdf:Property ;
    rdfs:label 'Consumer Insight Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer research study or derived insight record. Primary key for the consumer_insight data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Commissioned By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Insight studies are commissioned by specific employees; linking enables Insight Commissioning cost allocation and performance tracking.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionPlanId rdf:type rdf:Property ;
    rdfs:label 'Promotion Plan Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_plan. Business justification: Consumer insights drive promotion-plan creation; this FK ties insights to the plan they inform.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionPlan .

ind:allergenRelevance rdf:type rdf:Property ;
    rdfs:label 'Allergen Relevance' ;
    rdfs:comment 'Indicates whether the study includes consumer insights related to allergen awareness, labeling preferences, or allergen-free product demand (True). Supports allergen matrix management and FDA FSMA compliance for labeling decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryScope rdf:type rdf:Property ;
    rdfs:label 'Category Scope' ;
    rdfs:comment 'The food and beverage product category or categories covered by the study (e.g., \'Salty Snacks\', \'RTD Beverages\', \'Dairy\', \'Packaged Foods\'). Aligns with Nielsen/IRI category taxonomy and internal PLM category hierarchy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelRelevance rdf:type rdf:Property ;
    rdfs:label 'Clean Label Relevance' ;
    rdfs:comment 'Indicates whether the study includes findings relevant to clean label consumer preferences (True) — e.g., natural ingredients, no artificial additives, transparency. Supports the clean label product development pipeline and marketing claims strategy.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conceptTestScore rdf:type rdf:Property ;
    rdfs:label 'Concept Test Score' ;
    rdfs:comment 'Top-2-box purchase intent or overall concept appeal score from concept testing studies (e.g., 72.50 = 72.5% top-2-box). Null for non-concept-test study types. Key NPD go/no-go gate metric used in the innovation funnel.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'The statistical confidence level (%) at which quantitative findings are reported (e.g., 90.00, 95.00, 99.00). Null for qualitative studies. Supports data quality assessment and decision-making thresholds for NPD go/no-go gates.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableDate rdf:type rdf:Property ;
    rdfs:label 'Deliverable Date' ;
    rdfs:comment 'The date on which the final research deliverable (report, topline, data file) was received from the vendor or published internally. Used for insight freshness tracking and NPD pipeline milestone management.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableReference rdf:type rdf:Property ;
    rdfs:label 'Deliverable Reference' ;
    rdfs:comment 'Document reference, URL, or Veeva Vault document ID pointing to the primary research deliverable (final report, topline deck, data file). Enables direct access to source documentation for audit, compliance, and deeper analysis.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldingEndDate rdf:type rdf:Property ;
    rdfs:label 'Fielding End Date' ;
    rdfs:comment 'The date on which data collection (fielding) concluded for the study. Together with fielding_start_date, defines the fieldwork window for temporal validity assessment of insights.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldingStartDate rdf:type rdf:Property ;
    rdfs:label 'Fielding Start Date' ;
    rdfs:comment 'The date on which data collection (fielding) commenced for the study. Used for timeline tracking, seasonal context analysis, and compliance with ESOMAR fieldwork documentation requirements.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic coverage of the study, expressed as country codes (ISO 3166-1 alpha-3), regions, or named markets (e.g., \'USA\', \'USA|CAN|MEX\', \'EMEA\', \'National US\'). Supports market-level filtering and cross-market insight comparison.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightAction rdf:type rdf:Property ;
    rdfs:label 'Insight Action' ;
    rdfs:comment 'The recommended business action or strategic implication derived from the key finding (e.g., \'Reformulate product X to reduce sodium\', \'Reposition Brand Y toward health-conscious millennials\'). Bridges research output to commercial decision-making.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightCategory rdf:type rdf:Property ;
    rdfs:label 'Insight Category' ;
    rdfs:comment 'Business domain classification of the primary insight derived from the study. Enables routing of insights to the correct brand, innovation, or commercial team. [ENUM-REF-CANDIDATE: brand_equity|product_innovation|packaging|pricing|consumer_segmentation|category_dynamics|shopper_behavior|advertising_effectiveness|sustainability|competitive_intelligence — promote to reference product]' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insight Expiry Date' ;
    rdfs:comment 'The date after which the insight is considered stale or no longer actionable due to market changes, product reformulation, or elapsed time. Supports insight lifecycle management and prevents outdated research from influencing current strategy.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insightPriority rdf:type rdf:Property ;
    rdfs:label 'Insight Priority' ;
    rdfs:comment 'Business priority rating assigned to the insight by the commissioning team, indicating urgency and strategic importance for action. Drives triage and resource allocation in the innovation funnel and brand planning cycle.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Key Finding Summary' ;
    rdfs:comment 'Concise narrative summary of the primary actionable insight or finding derived from the study (max ~2000 characters). This is the SSOT for the headline insight used in brand strategy decks, NPD briefs, and innovation funnel reviews.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npdPipelineFlag rdf:type rdf:Property ;
    rdfs:label 'Npd Pipeline Flag' ;
    rdfs:comment 'Indicates whether the insight is actively linked to or informing a New Product Development (NPD) initiative in the innovation pipeline (True). Enables filtering of insights that are driving active R&D and NPD gate decisions.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelRelevance rdf:type rdf:Property ;
    rdfs:label 'Private Label Relevance' ;
    rdfs:comment 'Indicates whether the study includes competitive analysis or consumer perception data related to private label products (True). Supports trade strategy, pricing, and brand differentiation decisions against private label competition.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Claim Flag' ;
    rdfs:comment 'Indicates whether the research study was conducted to substantiate a marketing or labeling claim (True) or is general consumer research (False). Critical for FTC compliance — claim substantiation studies require specific documentation and retention per FTC guidelines.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchMethodology rdf:type rdf:Property ;
    rdfs:label 'Research Methodology' ;
    rdfs:comment 'Specific research technique employed in the study (e.g., focus group, in-depth interview, online survey, sensory panel, organoleptic evaluation, ethnography, concept test, conjoint analysis, segmentation, U&A study, packaging test, pricing research, NPS survey). [ENUM-REF-CANDIDATE: focus_group|in_depth_interview|online_survey|sensory_panel|organoleptic_evaluation|concept_test|conjoint_analysis|segmentation|usage_and_attitude|packaging_test|pricing_research|nps_survey|ethnography|competitive_landscape — promote to reference product]' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchVendor rdf:type rdf:Property ;
    rdfs:label 'Research Vendor' ;
    rdfs:comment 'Name of the external research agency, syndicated data provider, or consultancy that conducted or supplied the study (e.g., Nielsen, IRI, SPINS, Ipsos, Kantar, Mintel, Numerator). Used for vendor performance tracking and contract management alignment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryScore rdf:type rdf:Property ;
    rdfs:label 'Sensory Score' ;
    rdfs:comment 'Composite sensory or organoleptic evaluation score from sensory panel studies (e.g., overall liking score on a 9-point hedonic scale). Applicable to sensory panel and organoleptic evaluation study types. Null for non-sensory studies. Supports product reformulation and quality assurance decisions.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Study Budget Usd' ;
    rdfs:comment 'Total approved budget for the research study in US Dollars (USD). Confidential financial data used for marketing spend tracking, COGS allocation, and ROI measurement of consumer insights investment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the research study by the commissioning team or research vendor (e.g., CI-2024-001234). Serves as the BUSINESS_IDENTIFIER for cross-system reference and vendor invoicing alignment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Full descriptive name of the consumer research study or insight initiative (e.g., \'Q3 2024 Snack Category Usage & Attitude Study — North America\'). Human-readable IDENTITY_LABEL used in reporting, presentations, and stakeholder communications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle state of the research study: planned (scoped, not yet fielded), fielding (data collection in progress), analysis (data collected, insights being synthesized), completed (final deliverable issued), cancelled, or on_hold. LIFECYCLE_STATUS for the consumer_insight entity.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'High-level classification of the research methodology: qualitative (focus groups, ethnography), quantitative (surveys, panels), mixed_method, syndicated (Nielsen/IRI/SPINS subscriptions), or proprietary commissioned research. Drives analytical approach and data governance treatment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRelevance rdf:type rdf:Property ;
    rdfs:label 'Sustainability Relevance' ;
    rdfs:comment 'Indicates whether the study captures consumer attitudes or behaviors related to sustainability, environmental impact, packaging recyclability, or ESG-related purchasing drivers (True). Supports sustainability reporting and EPA compliance communications.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'The consumer segment or audience profile that the study was designed to understand (e.g., \'Millennial Health-Conscious Snackers\', \'Hispanic Families 25-44\', \'Gen Z RTD Beverage Consumers\'). Aligns with brand segmentation frameworks and supports NPD pipeline targeting.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProjectCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Project Code' ;
    rdfs:comment 'The research vendor\'s own project or study reference number. Enables cross-referencing with vendor invoices, deliverable portals, and data feeds for reconciliation and audit purposes.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerPromotionId rdf:type rdf:Property ;
    rdfs:label 'Consumer Promotion Id' ;
    rdfs:comment 'Unique system-generated identifier for the consumer-facing promotion record. Primary key for the consumer_promotion data product in the marketing domain.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Actual Redemption Count' ;
    rdfs:comment 'Running total of confirmed redemptions processed against this promotion to date. Updated via clearinghouse feeds or digital redemption platform. Used for budget burn tracking and fraud monitoring.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRedemptionValue rdf:type rdf:Property ;
    rdfs:label 'Actual Redemption Value' ;
    rdfs:comment 'Total monetary value of all confirmed redemptions processed to date in currency_code. Represents the actual COGS impact of the promotion. Used for budget reconciliation and ROI calculation inputs.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearinghouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Code' ;
    rdfs:comment 'Identifier assigned by the coupon clearinghouse (e.g., Inmar, Quotient) for processing paper and digital coupon redemptions. Required for settlement and fraud detection. Null for non-coupon promotion types.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleSkuScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Sku Scope' ;
    rdfs:comment 'Defines the breadth of SKU eligibility for the promotion. \'specific_skus\' requires a linked SKU eligibility list. \'product_line\' applies to all SKUs within a product line. Used in redemption validation and planogram alignment.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this promotion has been flagged for suspected fraudulent redemption activity based on clearinghouse anomaly detection or internal audit rules. True triggers investigation workflow.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'Current status of the fraud investigation for this promotion. Only relevant when fraud_flag is True. Drives escalation and financial adjustment workflows.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Compliant' ;
    rdfs:comment 'Indicates whether this promotion has been reviewed and confirmed compliant with FTC guidelines on advertising, marketing claims, and promotional offers. Must be True before promotion_status can transition to \'active\'.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal marketing and finance team notes regarding promotion strategy, retailer negotiations, or execution considerations. Not consumer-facing. Confidential business information.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalTermsVersion rdf:type rdf:Property ;
    rdfs:label 'Legal Terms Version' ;
    rdfs:comment 'Version identifier of the legal terms and conditions document governing this promotion (e.g., v1.0, v2.3). Links to the approved legal document in Veeva Vault. Required for FTC compliance and consumer dispute resolution.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRedemptions rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions' ;
    rdfs:comment 'Maximum total number of times this promotion may be redeemed across all consumers. Controls promotion liability exposure. Null indicates no cap. When reached, promotion_status transitions to \'expired\'.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRedemptionsPerConsumer rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions Per Consumer' ;
    rdfs:comment 'Maximum number of times a single consumer household may redeem this promotion. Enforced at POS or digital redemption platform to prevent abuse. Null indicates no per-consumer limit.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum consumer purchase value (in currency_code) required to qualify for the promotion offer. Zero or null indicates no minimum purchase threshold. Used in redemption validation logic.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Quantity' ;
    rdfs:comment 'Minimum number of qualifying product units a consumer must purchase to redeem the promotion (e.g., buy 2 to get $1 off). Null or zero indicates no quantity threshold. Critical for BOGO and multi-buy mechanics.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Consumer-facing description of the promotion offer as it appears on the coupon, in-app notification, or marketing material (e.g., \'Save $1.00 on any two bags of Brand X Chips\'). Used for content management and legal review.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerValue rdf:type rdf:Property ;
    rdfs:label 'Offer Value' ;
    rdfs:comment 'The face value of the promotion offer expressed as a monetary amount (e.g., $1.00 off, $5.00 rebate) or as a percentage discount depending on offer_value_type. Represents the consumer-facing benefit. Part of the MONETARY_TRIPLET for this promotion.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerValueType rdf:type rdf:Property ;
    rdfs:label 'Offer Value Type' ;
    rdfs:comment 'Indicates whether the offer_value is a fixed monetary amount, a percentage discount, a free product award, or loyalty points. Determines how the offer is applied at redemption.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable marketing name of the promotion as it appears in consumer-facing materials, campaign briefs, and internal planning documents (e.g., \'Summer Savings Coupon\', \'Buy One Get One Free Chips\'). Serves as the IDENTITY_LABEL for this record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the consumer promotion. Controls execution eligibility and budget commitment. Drives workflow in Salesforce Marketing Cloud and SAP SD condition records.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the consumer promotion by offer mechanic. Determines redemption logic, legal requirements, and budget treatment. [ENUM-REF-CANDIDATE: coupon|rebate|sweepstakes|loyalty_reward|bogo|sampling|instant_win|cashback — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionBudget rdf:type rdf:Property ;
    rdfs:label 'Redemption Budget' ;
    rdfs:comment 'Portion of total_budget allocated specifically to cover consumer redemption liability (face value of offers redeemed). Distinct from production and distribution budget components. Used for financial accrual and COGS impact tracking.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionMechanism rdf:type rdf:Property ;
    rdfs:label 'Redemption Mechanism' ;
    rdfs:comment 'The channel or method through which the consumer redeems the promotion offer. Drives integration requirements with POS systems, Salesforce Marketing Cloud, and clearinghouse partners. [ENUM-REF-CANDIDATE: digital|paper|in_app|mail_in|loyalty_card|auto_apply — promote to reference product]' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerExclusivity rdf:type rdf:Property ;
    rdfs:label 'Retailer Exclusivity' ;
    rdfs:comment 'Indicates whether this promotion is exclusive to a specific retailer or retail channel. When True, the promotion may only be redeemed at the designated retailer(s). Impacts trade relationship management and slotting negotiations.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'State Registration Required' ;
    rdfs:comment 'Indicates whether this promotion type (e.g., sweepstakes, contest) requires registration or bonding in specific US states (e.g., New York, Florida). Triggers compliance workflow for legal filing.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes identifying the geographic markets where this promotion is valid (e.g., USA, CAN, GBR). Drives regulatory compliance checks and retailer eligibility.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudget rdf:type rdf:Property ;
    rdfs:label 'Total Budget' ;
    rdfs:comment 'Total approved budget allocated for this consumer promotion in currency_code. Covers offer redemption liability, production costs, and distribution costs. Used for budget reconciliation against actual spend. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upcQualifier rdf:type rdf:Property ;
    rdfs:label 'Upc Qualifier' ;
    rdfs:comment 'The Universal Product Code (UPC) company prefix or specific product code used to qualify eligible products at POS redemption. Encoded in GS1 coupon barcodes for automated clearinghouse processing. Null when eligible_sku_scope is \'all_skus\'.' ;
    rdfs:domain ind:ConsumerPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Asset approval must be signed off by a marketing employee; FK enables audit of asset approvals for regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAssetDigitalAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Digital Asset Id' ;
    rdfs:comment 'Reference to the parent digital asset record from which this asset was derived or adapted (e.g., a localized variant references its master asset). Enables asset lineage tracking and derivative management within the DAM hierarchy.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalAsset .

ind:allergenClaimPresent rdf:type rdf:Property ;
    rdfs:label 'Allergen Claim Present' ;
    rdfs:comment 'Indicates whether this digital asset (e.g., packaging artwork, nutritional panel, label) contains allergen declarations or claims. Triggers mandatory regulatory review workflow under FDA FSMA, USDA, and EFSA allergen labeling requirements before approval.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetSubtype rdf:type rdf:Property ;
    rdfs:label 'Asset Subtype' ;
    rdfs:comment 'Granular classification within the asset type (e.g., \'hero_banner\', \'product_photography\', \'tv_spot\', \'radio_jingle\', \'shelf_talker\', \'nutritional_panel_artwork\', \'copy_deck\'). Supports detailed taxonomy and omnichannel content routing. [ENUM-REF-CANDIDATE: hero_banner|product_photography|tv_spot|radio_jingle|shelf_talker|nutritional_panel_artwork|copy_deck|social_post|email_template|print_ad — promote to reference product]' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelCompliant rdf:type rdf:Property ;
    rdfs:label 'Clean Label Compliant' ;
    rdfs:comment 'Indicates whether this digital asset (particularly packaging artwork and labeling) meets the brand\'s clean label standards — free from artificial colors, flavors, preservatives, and non-consumer-friendly ingredients. Supports consumer transparency and brand positioning.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space or color profile of the digital asset (e.g., \'sRGB\' for digital/web, \'CMYK\' for print, \'Pantone\' for brand color-matched packaging). Critical for print production quality, packaging artwork compliance, and brand color consistency.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damAssetCode rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Code' ;
    rdfs:comment 'Externally-known unique business identifier assigned by the Digital Asset Management (DAM) system (e.g., Bynder, Widen, Canto) to this asset. Used for cross-system referencing and asset retrieval across omnichannel platforms.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damSystemReference rdf:type rdf:Property ;
    rdfs:label 'Dam System Reference' ;
    rdfs:comment 'External reference identifier or URL path within the source Digital Asset Management (DAM) system (e.g., Bynder asset URL, Widen asset ID, Canto folder path). Enables direct deep-linking to the asset in the originating DAM platform for retrieval and governance.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Playback duration of the digital asset in seconds. Applicable to video and audio asset types (e.g., TV spots, radio jingles, digital video ads). Used for media buying, broadcast compliance, and platform upload validation.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightPx rdf:type rdf:Property ;
    rdfs:label 'Height Px' ;
    rdfs:comment 'Vertical dimension of the digital asset in pixels. Used alongside width_px for aspect ratio validation and channel-specific dimension compliance (e.g., social media, e-commerce product imagery, digital shelf).' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerContent rdf:type rdf:Property ;
    rdfs:label 'Influencer Content' ;
    rdfs:comment 'Indicates whether this digital asset was created by or in partnership with an influencer or brand ambassador. Triggers mandatory FTC endorsement disclosure requirements (e.g., #ad, #sponsored) and influencer contract rights verification before deployment.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMasterAsset rdf:type rdf:Property ;
    rdfs:label 'Is Master Asset' ;
    rdfs:comment 'Indicates whether this record represents the master/original version of the asset (True) or a derivative/localized variant (False). Master assets serve as the source of truth for all downstream adaptations and channel-specific renditions.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the usage license or rights agreement for this digital asset expires. Assets must be retired from active deployment on or before this date to avoid IP infringement. Triggers automated expiry workflows in the DAM system.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'IETF BCP 47 locale code indicating the language and regional market for which this asset is localized (e.g., \'en_US\', \'fr_CA\', \'es_MX\'). Supports multilingual content management and regulatory labeling compliance across jurisdictions (FDA, EFSA, USDA).' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionClaimPresent rdf:type rdf:Property ;
    rdfs:label 'Nutrition Claim Present' ;
    rdfs:comment 'Indicates whether this digital asset contains nutritional or health claims (e.g., \'Low Fat\', \'High Protein\', \'No Added Sugar\'). Triggers FTC and FDA regulatory compliance review to ensure claims meet substantiation requirements under 21 CFR Part 101.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Status' ;
    rdfs:comment 'Status of the regulatory compliance review for this digital asset, particularly for packaging artwork, nutritional panels, and health/allergen claims. Ensures assets meet FDA, USDA, EFSA, FTC, and Codex Alimentarius requirements before market deployment.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Image or print resolution of the asset expressed in dots per inch (DPI). Critical for determining suitability for print vs. digital use. Standard print requires 300 DPI; digital display typically uses 72–96 DPI. Applies to image and document asset types.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsHolder rdf:type rdf:Property ;
    rdfs:label 'Rights Holder' ;
    rdfs:comment 'Name of the individual, agency, or organization that holds the intellectual property rights to this digital asset (e.g., photography agency, influencer, creative studio). Required for rights clearance, licensing compliance, and FTC disclosure obligations.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Classification of the intellectual property rights and usage licensing model governing this digital asset (e.g., \'royalty_free\', \'rights_managed\', \'creative_commons\', \'proprietary\', \'licensed\'). Determines permissible usage scope and commercial deployment eligibility.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'Fully qualified URL or cloud storage path where the digital asset file is physically stored (e.g., Azure Blob Storage URI, AWS S3 path, CDN endpoint). Used for asset retrieval, CDN delivery, and omnichannel content syndication.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagsKeywords rdf:type rdf:Property ;
    rdfs:label 'Tags Keywords' ;
    rdfs:comment 'Comma-separated list of searchable tags and keywords associated with this digital asset (e.g., \'summer,refresh,oat-milk,dairy-free,snack,packaging\'). Enables full-text search, content discovery, and AI-driven asset recommendation within the DAM system and Salesforce Marketing Cloud.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL of the low-resolution preview or thumbnail image for this digital asset. Used for visual browsing and search results in the DAM system, e-commerce product pages, and marketing portals without requiring full asset download.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Usage Restrictions' ;
    rdfs:comment 'Free-text description of any specific restrictions on how this digital asset may be used (e.g., \'Not for use in alcoholic beverage promotions\', \'Digital use only — no print\', \'North America markets only\', \'Influencer exclusivity period ends 2025-12-31\'). Supports FTC compliance and brand governance.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPx rdf:type rdf:Property ;
    rdfs:label 'Width Px' ;
    rdfs:comment 'Horizontal dimension of the digital asset in pixels. Used for responsive design validation, planogram compliance, and channel-specific dimension requirements (e.g., social media platform specs, retail display specs).' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Unique system-generated identifier for the influencer or brand ambassador record. Primary key for the influencer master data product.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Influencer .

ind:allergenClaimApproved rdf:type rdf:Property ;
    rdfs:label 'Allergen Claim Approved' ;
    rdfs:comment 'Indicates whether the influencer has been briefed and approved to make allergen-related claims about Food Beverage products in their content. Prevents unauthorized health or allergen claims that could violate FDA labeling regulations.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Audience Age Group' ;
    rdfs:comment 'Dominant age demographic of the influencer\'s audience based on platform analytics. Used to align influencer selection with target consumer segments for Food Beverage product lines.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceAuthenticityScore rdf:type rdf:Property ;
    rdfs:label 'Audience Authenticity Score' ;
    rdfs:comment 'Score (0.00–100.00) estimating the proportion of genuine (non-bot) followers in the influencer\'s audience, sourced from third-party fraud detection tools. Used to validate influencer quality and protect marketing ROI.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGenderSplitPct rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split Pct' ;
    rdfs:comment 'Percentage of the influencer\'s audience that identifies as female, based on platform-reported demographics (0.00–100.00). Used for gender-targeted campaign planning and consumer segment alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgPostReach rdf:type rdf:Property ;
    rdfs:label 'Avg Post Reach' ;
    rdfs:comment 'Average number of unique accounts reached per post on the influencer\'s primary platform, based on the most recent 90-day rolling period. Used for media value estimation and campaign ROI forecasting.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) assessing the influencer\'s content alignment with Food Beverage brand values and safety standards, based on content audits and third-party brand safety tools. Used in influencer vetting and renewal decisions.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Primary content niche or category the influencer creates content in. Used to match influencers to relevant Food Beverage product lines and target consumer segments. [ENUM-REF-CANDIDATE: food|lifestyle|fitness|parenting|beauty|travel|cooking|wellness|entertainment — promote to reference product]' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date on which the influencer partnership contract expires or is scheduled to terminate. Nullable for open-ended agreements. Triggers renewal workflow when approaching expiry.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date on which the influencer partnership contract becomes effective and binding. Used for contract lifecycle management and campaign eligibility validation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the influencer\'s contractual relationship with Food Beverage. Drives eligibility for campaign activation, payment processing, and compliance checks.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'Ratio of total engagements (likes, comments, shares, saves) to total followers expressed as a decimal (e.g., 0.0325 = 3.25%). Primary quality metric for evaluating influencer audience authenticity and content resonance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the influencer is contractually prohibited from promoting competing food and beverage brands during the contract period. Critical for competitive brand protection and FTC compliance.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines the scope of the exclusivity restriction: category-level (e.g., no competing beverages), brand-level, specific product, platform-specific, or full exclusivity across all channels. Applicable only when exclusivity_flag is True.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePerPost rdf:type rdf:Property ;
    rdfs:label 'Fee Per Post' ;
    rdfs:comment 'Agreed contractual fee in USD charged by the influencer per sponsored post or content deliverable. Used for campaign budget planning, Trade Promotion Management (TPM), and marketing spend tracking.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followerCount rdf:type rdf:Property ;
    rdfs:label 'Follower Count' ;
    rdfs:comment 'Total number of followers or subscribers on the influencer\'s primary platform at the time of last data refresh. Key metric for reach estimation and tier classification.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftcDisclosureCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Compliant' ;
    rdfs:comment 'Indicates whether the influencer\'s published content consistently includes required FTC-mandated sponsorship disclosures (e.g., #ad, #sponsored). Critical for regulatory compliance and brand legal risk management.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handle rdf:type rdf:Property ;
    rdfs:label 'Handle' ;
    rdfs:comment 'Primary social media username or handle of the influencer on their principal platform (e.g., @foodiequeen on Instagram). Used for content tracking, tagging, and campaign attribution.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthClaimApproved rdf:type rdf:Property ;
    rdfs:label 'Health Claim Approved' ;
    rdfs:comment 'Indicates whether the influencer is authorized to make FDA-regulated health or nutrient content claims about Food Beverage products in sponsored content. Prevents unauthorized claims that could trigger FDA or FTC enforcement.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostDate rdf:type rdf:Property ;
    rdfs:label 'Last Post Date' ;
    rdfs:comment 'Date of the most recent sponsored content post published by the influencer for a Food Beverage brand. Used to monitor influencer activity levels and identify dormant partnerships.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pastBrandPartnerships rdf:type rdf:Property ;
    rdfs:label 'Past Brand Partnerships' ;
    rdfs:comment 'Free-text or comma-delimited list of notable prior brand partnerships disclosed by the influencer during onboarding. Used for competitive conflict screening and partnership history context.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the influencer or their talent management representative. Used for urgent campaign coordination and contract discussions.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Primary social media platform on which the influencer creates and publishes content for Food Beverage brand partnerships. Drives platform-specific content strategy and performance benchmarking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postsDelivered rdf:type rdf:Property ;
    rdfs:label 'Posts Delivered' ;
    rdfs:comment 'Cumulative count of sponsored content posts actually published by the influencer against the current contract. Used to track delivery progress and trigger payment milestones.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredContentFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Content Format' ;
    rdfs:comment 'The influencer\'s primary content format used for brand collaborations (e.g., static post, reel, story, long-form video, live stream, blog). Used for creative brief development and platform-specific campaign planning.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code for the primary language in which the influencer creates content (e.g., en, es, fr). Used for audience targeting and localization strategy.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGiftingFlag rdf:type rdf:Property ;
    rdfs:label 'Product Gifting Flag' ;
    rdfs:comment 'Indicates whether the influencer receives Food Beverage product samples or gifts as part of the partnership arrangement (in addition to or instead of monetary compensation). Relevant for FTC disclosure requirements and COGS tracking.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether the influencer is eligible for contract renewal based on performance metrics, compliance history, and brand safety scores. Supports automated renewal workflow triggers.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalContractedPosts rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Posts' ;
    rdfs:comment 'Total number of sponsored content posts or deliverables committed by the influencer under the current contract term. Used for campaign delivery tracking and contract compliance monitoring.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Influencer Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for each influencer content activation record in the Silver Layer lakehouse. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the influencer partnership contract that governs the deliverables, payment terms, usage rights, and FTC compliance obligations for this engagement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseContract .

ind:activationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Activation Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this influencer content activation, used in agency briefs, purchase orders, and payment reconciliation. Format: INF-YYYY-NNNNNN.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliverableCount rdf:type rdf:Property ;
    rdfs:label 'Actual Deliverable Count' ;
    rdfs:comment 'Number of content pieces actually published by the influencer for this engagement. Compared against contracted_deliverable_count to assess fulfillment and trigger payment milestones.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Agency Managed Flag' ;
    rdfs:comment 'Indicates whether this influencer engagement was sourced and managed through a third-party influencer marketing agency rather than directly by the Food Beverage marketing team. Affects cost accounting and agency fee allocation.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceSize rdf:type rdf:Property ;
    rdfs:label 'Audience Size' ;
    rdfs:comment 'Total follower or subscriber count of the influencer on the specified platform at the time of content publication. Captured as a point-in-time snapshot for performance normalization and tier validation.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Content Approval Date' ;
    rdfs:comment 'Date on which the brand/legal team formally approved the influencer content for publication or confirmed post-publication compliance. Used for audit trail and payment milestone triggering.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Content Approval Status' ;
    rdfs:comment 'Status of the brand and legal review of the influencer content prior to or post publication. Ensures brand guidelines, nutritional claim accuracy, and FTC compliance are verified before payment release.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCaption rdf:type rdf:Property ;
    rdfs:label 'Content Caption' ;
    rdfs:comment 'The text caption or description accompanying the influencer post. Captured for FTC disclosure verification, brand claim compliance review, and consumer sentiment analysis.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Content Rights Expiry Date' ;
    rdfs:comment 'Date on which the brand\'s licensed rights to repurpose or amplify the influencer-created content expire. Critical for paid media amplification planning and legal compliance with content usage agreements.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Format classification of the influencer content deliverable (e.g., story, reel, static post, long-form video). Determines performance benchmarks, content rights, and contracted deliverable matching.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'Direct URL to the published influencer content on the social media platform. Used for compliance review, content archiving, FTC disclosure verification, and performance data pull.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedDeliverableCount rdf:type rdf:Property ;
    rdfs:label 'Contracted Deliverable Count' ;
    rdfs:comment 'Total number of content pieces (posts, stories, reels, videos) contractually obligated for this influencer engagement. Used to track fulfillment rate against contract terms.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedFee rdf:type rdf:Property ;
    rdfs:label 'Contracted Fee' ;
    rdfs:comment 'Gross monetary fee agreed in the influencer contract for this engagement, before any deductions or bonuses. Used for budget tracking, COGS allocation, and payment milestone management.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedMediaValue rdf:type rdf:Property ;
    rdfs:label 'Earned Media Value' ;
    rdfs:comment 'Estimated monetary value of the organic reach and engagement generated by the influencer content, calculated using platform-specific CPM/CPE benchmarks. Key metric for Return on Investment (ROI) reporting and brand equity tracking. Expressed in the contract currency.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the influencer content activation. Tracks workflow from initial brief through contract execution, content go-live, completion, and payment closure. [ENUM-REF-CANDIDATE: draft|contracted|live|completed|cancelled|disputed — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagements rdf:type rdf:Property ;
    rdfs:label 'Engagements' ;
    rdfs:comment 'Total count of all user interactions with the influencer content including likes, comments, shares, saves, and reactions. Core performance metric for consumer engagement analytics.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'Date through which the influencer is contractually prohibited from promoting competing food and beverage brands or products. Null if no exclusivity clause is in effect. Used for competitive conflict monitoring.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftcDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Status' ;
    rdfs:comment 'Compliance status indicating whether the influencer post includes the required FTC-mandated paid partnership or #ad disclosure. Critical for regulatory compliance and brand legal risk management.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcDisclosureTag rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Tag' ;
    rdfs:comment 'The specific disclosure label used in the post (e.g., #ad, #sponsored, #paidpartnership, platform-native \'Paid Partnership\' label). Captured verbatim for FTC audit evidence.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags included in the influencer post. Used to verify required campaign hashtags (e.g., #ad, #sponsored) and to track branded hashtag performance.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the influencer content was displayed to users on the platform, including repeat views by the same user. Primary reach metric for awareness-stage campaign measurement.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkClicks rdf:type rdf:Property ;
    rdfs:label 'Link Clicks' ;
    rdfs:comment 'Number of times users clicked on a trackable link (e.g., swipe-up, bio link, UTM-tagged URL) within the influencer content. Measures direct traffic and conversion intent driven by the activation.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidAmplificationFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Amplification Flag' ;
    rdfs:comment 'Indicates whether the organic influencer content was additionally boosted through paid media spend (e.g., Instagram Branded Content Ads, TikTok Spark Ads). Affects total media investment reporting and FTC disclosure requirements.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone Status' ;
    rdfs:comment 'Current status of the payment milestone associated with this influencer engagement. Tracks the accounts payable workflow from deliverable approval through payment execution in Oracle Cloud ERP.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBonus rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus' ;
    rdfs:comment 'Additional monetary bonus payable to the influencer upon achieving contractually defined performance thresholds (e.g., impressions floor, engagement rate target). Nullable if no bonus clause exists.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postDate rdf:type rdf:Property ;
    rdfs:label 'Post Date' ;
    rdfs:comment 'The calendar date on which the influencer published the content to their social media platform. This is the principal real-world business event date for this activation record.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the influencer content was published on the platform. Used for time-of-day analytics, algorithm optimization, and audit trail.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productClaimType rdf:type rdf:Property ;
    rdfs:label 'Product Claim Type' ;
    rdfs:comment 'Classification of any product-related marketing claim made in the influencer content (e.g., health claim, nutrient content claim, structure/function claim). Critical for FDA and FTC regulatory compliance review of food and beverage advertising.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign Code' ;
    rdfs:comment 'UTM campaign parameter appended to trackable links in the influencer content for attribution in web analytics platforms. Enables direct traffic, conversion, and Return on Investment (ROI) measurement from influencer-driven clicks.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Related Flag' ;
    rdfs:comment 'Indicates whether this claim is related to allergen absence or management (True = allergen-related, e.g., \'Gluten-Free\', \'Peanut-Free\', \'Dairy-Free\'; False = not allergen-related). Triggers additional substantiation and HACCP review requirements per FSMA and FDA allergen labeling rules.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the third-party certification supporting this claim expires and must be renewed. Triggers renewal workflow to prevent lapse in claim validity. Null for claims without external certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certificate or license number issued by the certifying body for this claim. Used for regulatory audit trails and label compliance verification. Null for non-certified claims.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Marketing channel(s) on which this claim is approved for use: packaging = on-pack label; digital = website, social media, e-commerce; advertising = TV, print, radio; in_store = shelf talkers, POS displays; foodservice = menu boards, distributor materials; all = approved for all channels. Drives Salesforce Marketing Cloud campaign governance and FTC compliance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCode rdf:type rdf:Property ;
    rdfs:label 'Claim Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the marketing claim (e.g., CLM-NONGMO001). Used as the business identifier across PLM, TraceGains, and Veeva Vault systems for cross-system traceability. Aligns with BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimName rdf:type rdf:Property ;
    rdfs:label 'Claim Name' ;
    rdfs:comment 'Short, human-readable label for the marketing claim as it appears in internal systems and reporting (e.g., \'Non-GMO\', \'Gluten-Free\', \'Heart Healthy\'). Serves as the IDENTITY_LABEL for the claim resource.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the marketing claim record. Controls whether the claim may be applied to SKUs and used in marketing materials. Aligns with LIFECYCLE_STATUS category for MASTER_RESOURCE role. \'draft\' = under development; \'pending_review\' = submitted for legal/regulatory review; \'approved\' = cleared for use; \'active\' = currently in use on packaging or advertising; \'suspended\' = temporarily halted pending investigation; \'expired\' = past effective end date; \'withdrawn\' = permanently retired. [ENUM-REF-CANDIDATE: draft|pending_review|approved|active|suspended|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Categorical classification of the claim by its primary business purpose: nutritional (e.g., low sodium, high fiber), environmental (e.g., sustainably sourced, recyclable packaging), lifestyle (e.g., keto-friendly, vegan), ingredient (e.g., no artificial colors), process (e.g., cold-pressed, small-batch), certification (e.g., USDA Organic, Non-GMO Project Verified). Aligns with CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Flag' ;
    rdfs:comment 'Indicates whether this claim is part of the company\'s clean label strategy (True = clean label claim; False = standard marketing claim). Clean label claims include \'No Artificial Ingredients\', \'Simple Ingredients\', \'Non-GMO\', etc. Supports clean label portfolio reporting and NPD strategy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorParityFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Parity Flag' ;
    rdfs:comment 'Indicates whether this claim is being made primarily to achieve competitive parity with market competitors (True = parity claim driven by competitive intelligence; False = differentiation or proprietary claim). Supports trade marketing and category captain strategy analysis.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerResearchRef rdf:type rdf:Property ;
    rdfs:label 'Consumer Research Ref' ;
    rdfs:comment 'Reference identifier for consumer research study (e.g., sensory panel, NPS survey, focus group) that validated consumer understanding and purchase intent impact of this claim. Supports FTC \'reasonable consumer\' substantiation standard and NPD claim strategy.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Claim Flag' ;
    rdfs:comment 'Indicates whether this claim makes an environmental or sustainability assertion (True = environmental claim subject to FTC Green Guides, e.g., \'Recyclable\', \'Carbon Neutral\', \'Sustainably Sourced\'; False = non-environmental claim). Environmental claims require specific substantiation per FTC 16 CFR Part 260.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Status of the legal department\'s review of this marketing claim for FTC compliance, IP considerations, and competitive claim accuracy. Distinct from regulatory approval — legal review focuses on advertising law, substantiation adequacy, and litigation risk.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the legal counsel who reviewed and approved or rejected this marketing claim. Provides accountability trail for FTC compliance and internal governance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic market or region where this claim is approved for use, expressed as ISO 3166-1 alpha-3 country code or regional grouping (e.g., \'USA\', \'CAN\', \'GBR\', \'DEU\'). Claims may have different regulatory approval status across markets. Supports multi-market labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOwner rdf:type rdf:Property ;
    rdfs:label 'Marketing Owner' ;
    rdfs:comment 'Name or employee identifier of the marketing team member responsible for managing this claim\'s lifecycle, including renewal, substantiation updates, and channel deployment. Primary business owner for claim governance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Claim Flag' ;
    rdfs:comment 'Indicates whether this claim involves an organic assertion (True = organic claim subject to USDA National Organic Program or equivalent; False = non-organic claim). Organic claims require USDA NOP certification and are subject to strict regulatory oversight.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingVersion rdf:type rdf:Property ;
    rdfs:label 'Packaging Version' ;
    rdfs:comment 'Specific version or revision of the packaging artwork on which this claim appears (e.g., \'v3.2\', \'PV-2024-A\'). Critical for traceability when packaging artwork is updated — ensures the claim is only associated with the correct packaging iteration. Aligns with PLM packaging version control.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Ref' ;
    rdfs:comment 'Reference number or identifier for the regulatory approval, filing, or notification associated with this claim in a specific market (e.g., FDA GRAS notification number, USDA organic certificate number, EFSA health claim authorization reference). Supports regulatory audit and labeling compliance verification.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewer rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reviewer' ;
    rdfs:comment 'Name or employee identifier of the regulatory affairs professional who reviewed this claim for compliance with FDA, USDA, EFSA, or other applicable regulations. Provides accountability trail for regulatory audit purposes.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemClaimCode rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Code' ;
    rdfs:comment 'The native identifier for this claim record in the originating operational system (e.g., TraceGains document ID, Veeva Vault record ID, SAP material specification number). Enables bidirectional traceability between the Silver Layer data product and the system of record.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationDocRef rdf:type rdf:Property ;
    rdfs:label 'Substantiation Doc Ref' ;
    rdfs:comment 'Reference identifier for the substantiation document stored in Veeva Vault or TraceGains that provides the scientific, regulatory, or third-party evidence supporting the claim (e.g., lab test results, certification body certificate, clinical study reference, supplier attestation). Required for FTC substantiation standard compliance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within the claim type (e.g., within \'nutritional\': \'health claim\', \'nutrient content claim\', \'structure/function claim\'; within \'environmental\': \'packaging\', \'sourcing\', \'carbon\'). Supports detailed regulatory mapping and clean label strategy analytics. [ENUM-REF-CANDIDATE: health_claim|nutrient_content_claim|structure_function_claim|allergen_free|organic|non_gmo|fair_trade|carbon_neutral|recyclable — promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the media plan record. Primary key for the media_plan data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'The non-working media portion of the budget allocated to agency fees (retainer, commission, or project-based fees) for this media plan. Supports agency cost governance and working vs. non-working media analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'The total approved Advertising & Promotion (A&P) budget allocated to this media plan in the plan currency. This is the marketing-owned working budget — the single source of truth (SSOT) distinct from the finance General Ledger (GL). Supports brand investment governance and EBITDA impact tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or employee identifier of the marketing manager or brand director who owns and is accountable for this media plan budget. The primary point of contact for budget governance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The difference between the approved budget and actual spend (approved_budget_amount minus actual_spend_amount). A positive value indicates underspend; negative indicates overspend. Supports marketing finance controls and budget reallocation decisions.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Spend Amount' ;
    rdfs:comment 'The portion of the approved budget that has been formally committed via purchase orders, agency contracts, or media buys. Represents legally or contractually obligated spend within the plan period.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Budget Amount' ;
    rdfs:comment 'Budget allocated to digital media channels (display, search, programmatic, video) within this plan. Supports digital investment tracking and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic market scope of this media plan (e.g., \'National\', \'Northeast Region\', \'Top 10 DMAs\'). Supports market-level investment analysis and regional brand equity tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Media Mix Strategy' ;
    rdfs:comment 'Narrative description of the media mix strategy for this plan, including rationale for channel weighting, sequencing, and integration approach. Supports brand investment decision documentation.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oohBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Ooh Budget Amount' ;
    rdfs:comment 'Budget allocated to Out-of-Home (OOH) media (billboards, transit, digital OOH) within this plan. Supports channel-level investment tracking and media mix reporting.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The calendar date on which media activity under this plan is scheduled to conclude. Defines the flight window for budget commitment and agency delivery.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the media plan, used in agency briefs, purchase orders, and finance reconciliation. Format: MP- followed by 4–20 alphanumeric characters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The calendar date on which media activity under this plan is scheduled to begin. Used for flight scheduling, agency briefing timelines, and budget pacing.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'The planned average number of times a member of the target audience is expected to be exposed to the media during the flight period. Used with reach to calculate GRPs and assess media weight sufficiency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrp rdf:type rdf:Property ;
    rdfs:label 'Planned Grp' ;
    rdfs:comment 'The total planned Gross Rating Points (GRPs) targeted for this media plan. GRP = Reach % × Frequency. A standard media weight metric used to evaluate TV and broadcast investment effectiveness.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReachPct rdf:type rdf:Property ;
    rdfs:label 'Planned Reach Pct' ;
    rdfs:comment 'The planned percentage of the target audience expected to be exposed to the media at least once during the flight period. A key media effectiveness metric alongside frequency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant media channel for this plan (e.g., TV, digital, social, shopper, Out-of-Home (OOH), streaming). Drives media mix strategy reporting and channel-level budget allocation analytics. [ENUM-REF-CANDIDATE: TV|digital|social|shopper|OOH|streaming|print|radio — promote to reference product]' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'Budget allocated to creative production costs (TV commercial production, digital asset creation, photography) within this plan. Part of non-working media spend.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Code' ;
    rdfs:comment 'The campaign identifier from Salesforce Marketing Cloud used to link this media plan to digital campaign execution, email journeys, and consumer engagement tracking. Supports cross-channel attribution.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Shopper Budget Amount' ;
    rdfs:comment 'Budget allocated to shopper marketing activations (in-store, retailer co-op, Point of Sale (POS) materials) within this plan. Supports trade and shopper investment governance.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Social Budget Amount' ;
    rdfs:comment 'Budget allocated to social media channels (paid social, influencer partnerships) within this plan. Supports social investment tracking and FTC endorsement compliance monitoring.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Streaming Budget Amount' ;
    rdfs:comment 'Budget allocated to streaming media platforms (audio streaming, video-on-demand, podcast) within this plan. Supports emerging channel investment tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Descriptive definition of the primary consumer target audience for this media plan (e.g., \'Adults 25–54, HHI $50K+, Snack Purchasers\'). Aligns with Nielsen/IRI panel demographic segmentation and brand strategy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tvBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Tv Budget Amount' ;
    rdfs:comment 'Budget allocated to television media (linear TV, connected TV) within this plan. Supports channel-level investment tracking and media mix optimization.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingMediaPct rdf:type rdf:Property ;
    rdfs:label 'Working Media Pct' ;
    rdfs:comment 'The percentage of the total approved budget allocated to working media (direct media placement costs) versus non-working media (agency fees, production costs). Industry benchmark for media efficiency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaSpendId rdf:type rdf:Property ;
    rdfs:label 'Media Spend Id' ;
    rdfs:comment 'Unique surrogate identifier for each media spend transaction record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of user clicks on the digital advertisement during the spend period. Primary engagement metric for digital and paid search media types.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Cost Per Click — the realized cost for each user click on the digital advertisement in the transaction currency. Primary efficiency metric for paid search and performance-based digital media.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost Per Mille (thousand impressions) — the negotiated or realized cost per 1,000 ad impressions in the transaction currency. Standard media efficiency metric for comparing cross-channel investment value.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the specific US television market where the media aired. Standard geographic unit for US broadcast media planning and spend reporting.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoMarketCode rdf:type rdf:Property ;
    rdfs:label 'Geo Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code identifying the geographic market where the media ran. Supports multi-market spend consolidation and regional budget governance.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'Gross Rating Points representing the total weight of a media schedule, calculated as reach multiplied by average frequency. Standard TV and broadcast media planning metric used to measure advertising pressure.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaChannel rdf:type rdf:Property ;
    rdfs:label 'Media Channel' ;
    rdfs:comment 'Specific media channel or platform within the media type (e.g., YouTube, Instagram, Google Search, NBC Primetime, Spotify, Times Square Billboard). Provides granular channel-level spend visibility beyond the media type classification.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaFormat rdf:type rdf:Property ;
    rdfs:label 'Media Format' ;
    rdfs:comment 'Creative format of the media placement (e.g., video, banner, native, audio, sponsorship, influencer, search text). Used for creative performance analysis and format-level spend allocation. [ENUM-REF-CANDIDATE: video|banner|native|audio|sponsorship|influencer|search_text|connected_tv — promote to reference product]' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'Classification of the advertising medium used for this spend record (e.g., TV, digital display, paid search, out-of-home, social, streaming). Drives channel-mix analysis and media planning optimization. [ENUM-REF-CANDIDATE: TV|digital_display|paid_search|OOH|social|streaming|print|radio — promote to reference product]' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiIndex rdf:type rdf:Property ;
    rdfs:label 'Roi Index' ;
    rdfs:comment 'Media ROI index score derived from marketing mix modeling or attribution analysis, representing the revenue return per unit of media spend. Sourced from Nielsen/IRI MMM outputs. Not a calculated aggregate — represents a point-in-time modeled index value assigned to this spend record.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The principal real-world business event date on which the media spend was incurred or the media ran. Used as the primary time dimension for spend reporting and period-over-period analysis.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Spend Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this media spend transaction, typically sourced from the media buying platform, agency, or SAP FI document number. Used for reconciliation with invoices and agency billing statements.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendStatus rdf:type rdf:Property ;
    rdfs:label 'Spend Status' ;
    rdfs:comment 'Current lifecycle state of the media spend record, tracking progression from planned budget through commitment, invoicing, and payment. Supports spend governance and budget control.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Working Media Flag' ;
    rdfs:comment 'Indicates whether this spend record represents working media (dollars directly purchasing audience exposure) as opposed to non-working spend (agency fees, production costs, research). Standard industry classification for advertising efficiency benchmarking.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shopperProgramId rdf:type rdf:Property ;
    rdfs:label 'Shopper Program Id' ;
    rdfs:comment 'Unique surrogate identifier for the shopper marketing program record in the Silver Layer lakehouse. Primary key. Entity role: TRANSACTION_HEADER — a discrete, lifecycle-managed shopper marketing activation event with budget, execution, and measurement attributes.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Reference to the product category (e.g., salty snacks, carbonated beverages, dairy) targeted by the shopper program. Used for category captain reporting, planogram alignment, and Nielsen/IRI syndicated data linkage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:retailerAccountId rdf:type rdf:Property ;
    rdfs:label 'Retailer Account Id' ;
    rdfs:comment 'Reference to the retailer account (e.g., Walmart, Kroger, Target) where the shopper program is executed. Links to the customer/account master in Salesforce CRM Sales Cloud or SAP S/4HANA SD customer master. Serves as the PARTY_REFERENCE for this transaction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:acvWeightedPct rdf:type rdf:Property ;
    rdfs:label 'Acv Weighted Pct' ;
    rdfs:comment 'ACV (All Commodity Volume) weighted distribution percentage representing the share of total retail sales volume covered by the stores participating in this shopper program. A standard Nielsen/IRI distribution metric used to assess program reach quality.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineSalesUsd rdf:type rdf:Property ;
    rdfs:label 'Baseline Sales Usd' ;
    rdfs:comment 'Estimated dollar sales volume that would have occurred without the shopper marketing program, derived from Nielsen/IRI syndicated data or internal POS baselines. Used as the denominator for incremental lift calculation. Currency: USD (ISO 4217).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponRedemptionRate rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Rate' ;
    rdfs:comment 'Ratio of coupons or digital offers redeemed to total coupons distributed or issued for FSI (Free Standing Insert) or digital coupon program types. Expressed as a decimal (e.g., 0.0250 = 2.50%). Applicable when program_type is fsi or digital_coupon.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponsDistributed rdf:type rdf:Property ;
    rdfs:label 'Coupons Distributed' ;
    rdfs:comment 'Total number of coupons or digital offers distributed to shoppers as part of an FSI or digital coupon program. Used with coupons_redeemed to compute coupon_redemption_rate. Applicable when program_type is fsi or digital_coupon.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Coupons Redeemed' ;
    rdfs:comment 'Total number of coupons or digital offers actually redeemed by shoppers during the program period. Used with coupons_distributed to compute coupon_redemption_rate. Sourced from retailer loyalty or clearinghouse data.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Rate' ;
    rdfs:comment 'Percentage of planned retail store locations where the display or program tactic was confirmed as correctly executed (actual_store_count / planned_store_count × 100). A key shopper marketing execution KPI. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsdProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Program Flag' ;
    rdfs:comment 'Indicates whether this shopper program is executed through a DSD (Direct Store Delivery) distribution model, where the manufacturer\'s sales representative directly manages in-store execution. DSD programs have distinct compliance and display audit workflows.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Number of product facings (shelf-facing units visible to the shopper) allocated to the brand or SKU as part of the shopper program planogram agreement. A standard planogram metric in Food and Beverage retail. Applicable for endcap and in-store display program types.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fdaLabelCompliant rdf:type rdf:Property ;
    rdfs:label 'Fda Label Compliant' ;
    rdfs:comment 'Indicates whether all product labeling and nutritional claims featured in the shopper program materials comply with FDA (Food and Drug Administration) labeling regulations (21 CFR). Critical for programs featuring health, nutrient content, or structure/function claims.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incrementalLiftPct rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Pct' ;
    rdfs:comment 'Percentage increase in sales attributable to the shopper marketing program above the baseline, calculated as ((promoted_sales_usd - baseline_sales_usd) / baseline_sales_usd) × 100. Primary effectiveness KPI for post-event evaluation (PEE). Expressed as a percentage.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'The planned number of calendar days the shopper program is scheduled to run at retail. Used for display compliance tracking, retailer SLA management, and program efficiency benchmarking.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postEventEvalStatus rdf:type rdf:Property ;
    rdfs:label 'Post Event Eval Status' ;
    rdfs:comment 'Status of the post-event evaluation (PEE) process for this shopper program. PEE captures incremental lift, ROI, display compliance, and learnings to inform future program investment. Drives TPO feedback loop in JDA/Blue Yonder.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programObjective rdf:type rdf:Property ;
    rdfs:label 'Program Objective' ;
    rdfs:comment 'Primary business objective driving the shopper marketing program. Determines KPI selection for post-event evaluation and TPO alignment. [ENUM-REF-CANDIDATE: trial_generation|repeat_purchase|basket_building|brand_awareness|competitive_defense|new_item_launch|seasonal_activation — promote to reference product]' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the shopper marketing program. Drives workflow routing in TPM and reporting inclusion logic. Values: draft (initial creation), planned (approved, not yet live), active (currently executing at retail), completed (post-event evaluation phase), cancelled (terminated before execution).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotedSalesUsd rdf:type rdf:Property ;
    rdfs:label 'Promoted Sales Usd' ;
    rdfs:comment 'Actual dollar sales volume recorded during the shopper program execution period, sourced from POS data or Nielsen/IRI syndicated data. Used alongside baseline_sales_usd to compute incremental lift. Currency: USD (ISO 4217).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailerChannel rdf:type rdf:Property ;
    rdfs:label 'Retailer Channel' ;
    rdfs:comment 'The retail trade channel in which the shopper program is executed. Used for channel-specific effectiveness benchmarking and ACV (All Commodity Volume) weighting in lift analysis. [ENUM-REF-CANDIDATE: mass|grocery|club|drug|convenience|dollar|natural|online|foodservice — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPct rdf:type rdf:Property ;
    rdfs:label 'Roi Pct' ;
    rdfs:comment 'Return on Investment (ROI) for the shopper marketing program, expressed as a percentage. Calculated as ((incremental gross profit - total program spend) / total program spend) × 100. Core metric for TPO alignment and future program investment decisions.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slottingFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Slotting Fee Usd' ;
    rdfs:comment 'Dollar amount paid to the retailer as a slotting fee for securing shelf placement, endcap, or display space as part of this shopper program. A standard cost component in Food and Beverage retail trade. Currency: USD (ISO 4217).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCountActual rdf:type rdf:Property ;
    rdfs:label 'Store Count Actual' ;
    rdfs:comment 'Number of retail store locations where the shopper program was confirmed to have executed, as verified through display compliance audits or retailer POS data. Compared against store_count_planned to compute display compliance rate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Store Count Planned' ;
    rdfs:comment 'Number of retail store locations where the shopper program is planned to execute. Used for display compliance rate calculation (actual vs. planned stores) and TDP (Total Distribution Points) impact assessment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicatedDataSource rdf:type rdf:Property ;
    rdfs:label 'Syndicated Data Source' ;
    rdfs:comment 'Identifies the primary syndicated or POS data source used to measure program lift and effectiveness. Determines the measurement methodology and data quality confidence level for reported KPIs.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpImpact rdf:type rdf:Property ;
    rdfs:label 'Tdp Impact' ;
    rdfs:comment 'Change in TDP (Total Distribution Points) attributable to the shopper program, measured as the net gain or loss in distribution points across participating retailers. TDP = number of items × ACV weighted distribution. Sourced from Nielsen/IRI syndicated data.' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved budget allocated to the shopper marketing program in US dollars, inclusive of all tactic costs (display, FSI, digital, sampling). Used for spend tracking, ROI calculation, and annual shopper marketing budget management. Currency: USD (ISO 4217).' ;
    rdfs:domain ind:ShopperProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicatedMarketDataId rdf:type rdf:Property ;
    rdfs:label 'Syndicated Market Data Id' ;
    rdfs:comment 'Unique surrogate primary key for each syndicated market data record ingested from Nielsen, IRI, or SPINS data feeds.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvDistributionPct rdf:type rdf:Property ;
    rdfs:label 'Acv Distribution Pct' ;
    rdfs:comment 'The percentage of All Commodity Volume (ACV) in stores carrying the SKU. ACV-weighted distribution measures the quality of distribution by weighting store presence by store sales volume, not just store count. Key distribution health metric.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgBasePrice rdf:type rdf:Property ;
    rdfs:label 'Avg Base Price' ;
    rdfs:comment 'Average non-promoted (everyday) retail price per unit for the SKU, excluding promotional price reductions. Used to separate base demand from incremental lift driven by trade promotions in TPM/TPO analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Avg Selling Price' ;
    rdfs:comment 'Average retail selling price per unit (dollar sales divided by unit sales) for the SKU in the specified market and period. Used for price positioning analysis, price elasticity modeling, and RSP (Recommended Selling Price) compliance monitoring.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataAggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Aggregation Level' ;
    rdfs:comment 'Indicates the level of product hierarchy at which this syndicated data record is aggregated. Records may be at SKU/UPC level, brand level, subcategory, category, or manufacturer level depending on the data pull configuration.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Load Timestamp' ;
    rdfs:comment 'The timestamp when this syndicated market data record was ingested into the Databricks Silver Layer. Used for data freshness monitoring, pipeline auditing, and identifying the most recent data refresh from each syndicated data provider.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataVintageDate rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Date' ;
    rdfs:comment 'The date on which the syndicated data provider published or released this data extract. Distinct from the period_end_date (what was measured) and data_load_timestamp (when ingested). Used to track data latency and manage version conflicts when providers restate historical data.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayPct rdf:type rdf:Property ;
    rdfs:label 'Display Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU had incremental in-store display (off-shelf, end-cap, secondary placement) during the period. Measures the breadth of display support and is a key input to trade promotion optimization (TPO) models.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSales rdf:type rdf:Property ;
    rdfs:label 'Dollar Sales' ;
    rdfs:comment 'Total retail dollar sales (in USD) for the SKU/brand/category in the specified market and period as measured by the syndicated data provider. The primary revenue performance metric used in brand and category management reviews.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSalesChangePct rdf:type rdf:Property ;
    rdfs:label 'Dollar Sales Change Pct' ;
    rdfs:comment 'Year-over-year percentage change in dollar sales for the SKU/brand in the specified market and period as reported by the syndicated data provider. Used for trend analysis and brand performance reporting in category reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSharePct rdf:type rdf:Property ;
    rdfs:label 'Dollar Share Pct' ;
    rdfs:comment 'The percentage share of total category dollar sales captured by this brand/SKU in the specified market and period. Core brand equity and competitive performance KPI reported in category management reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equivalentUnitSales rdf:type rdf:Property ;
    rdfs:label 'Equivalent Unit Sales' ;
    rdfs:comment 'Unit sales normalized to a standard equivalent unit (e.g., single-serve equivalent, ounce-equivalent) to enable cross-pack-size volume comparisons. Used in volume share and velocity benchmarking across different pack configurations.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featurePct rdf:type rdf:Property ;
    rdfs:label 'Feature Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU was featured in retailer advertising (circular, digital ad) during the period. Measures the breadth of feature support and is a key input to trade promotion optimization (TPO) models.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOwnBrand rdf:type rdf:Property ;
    rdfs:label 'Is Own Brand' ;
    rdfs:comment 'Indicates whether this record represents a Food Beverage owned brand (True) or a competitor brand (False). Enables filtering of internal versus competitive data in brand performance dashboards and market share reports.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this record represents a private label (store brand) product (True) or a branded product (False). Used to track private label competitive pressure and category penetration in brand strategy analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'The named geographic or retail market as defined by the syndicated data provider (e.g., \'Total US\', \'New York Metro\', \'Walmart National\', \'MULO+C\'). Represents the geographic or account-level scope of the measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Classification of the market geography scope: Total US (national aggregate), Regional (geographic sub-market), Account-Specific (retailer-level market), or Channel (e.g., grocery, mass, drug, club, natural). Drives market share calculation methodology.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericDistributionPct rdf:type rdf:Property ;
    rdfs:label 'Numeric Distribution Pct' ;
    rdfs:comment 'Percentage of total stores in the market carrying the SKU (stores_selling / total_stores_in_market × 100). Unweighted distribution measure used alongside ACV distribution to assess distribution breadth versus quality.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'The consumer-facing pack size descriptor for the SKU as reported by the syndicated data provider (e.g., \'12oz\', \'2L\', \'6-Pack\', \'24-Count\'). Used for price-per-unit normalization and pack-size mix analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceReductionPct rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU was sold at a temporary price reduction (TPR) without feature or display support. Used to isolate the impact of price-only promotions on volume lift in trade promotion analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedDollarSales rdf:type rdf:Property ;
    rdfs:label 'Promoted Dollar Sales' ;
    rdfs:comment 'Dollar sales generated while the SKU was on promotion (feature, display, price reduction, or combination). Used to calculate promotional lift and evaluate trade promotion effectiveness in TPM analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedUnitSales rdf:type rdf:Property ;
    rdfs:label 'Promoted Unit Sales' ;
    rdfs:comment 'Unit sales generated while the SKU was on promotion. Combined with promoted_dollar_sales to calculate promotional price per unit and assess volume lift from trade promotion activities.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The aggregation period granularity of the syndicated data record as defined by the data provider. Common periods include 4-Week, 12-Week, and 52-Week rolling windows used in category management and brand performance reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailChannel rdf:type rdf:Property ;
    rdfs:label 'Retail Channel' ;
    rdfs:comment 'The retail trade channel in which sales were measured (e.g., Grocery, Mass Merchandise, Drug, Club, Dollar, Convenience, Natural/Specialty, E-Commerce). Used for channel-level performance benchmarking and distribution strategy. [ENUM-REF-CANDIDATE: Grocery|Mass|Drug|Club|Dollar|Convenience|Natural|E-Commerce|Foodservice — promote to reference product]' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'The human-readable product description for the SKU as reported by the syndicated data provider (e.g., \'Brand X Cola 12oz Can 12-Pack\'). Used for product identification in reports and dashboards when internal product master data is unavailable.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storesSelling rdf:type rdf:Property ;
    rdfs:label 'Stores Selling' ;
    rdfs:comment 'The count of retail stores in the market that recorded at least one unit sale of the SKU during the reporting period. Used to assess numeric distribution and identify distribution gaps versus total stores in the market.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategoryName rdf:type rdf:Property ;
    rdfs:label 'Subcategory Name' ;
    rdfs:comment 'The product subcategory within the broader category hierarchy as defined by the syndicated data provider (e.g., \'Regular CSD\', \'Diet CSD\' within Carbonated Soft Drinks). Supports granular category management analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdp rdf:type rdf:Property ;
    rdfs:label 'Tdp' ;
    rdfs:comment 'Total Distribution Points (TDP) — the sum of ACV distribution percentages across all items in a brand or category. Measures the breadth of a brand\'s distribution footprint. Used in distribution gap analysis and new item launch tracking.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStoresInMarket rdf:type rdf:Property ;
    rdfs:label 'Total Stores In Market' ;
    rdfs:comment 'The total number of retail stores in the defined market universe as reported by the syndicated data provider. Used as the denominator for numeric distribution calculations and store-count-based share metrics.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitSales rdf:type rdf:Property ;
    rdfs:label 'Unit Sales' ;
    rdfs:comment 'Total consumer units sold for the SKU/brand/category in the specified market and period. Used for volume performance tracking, velocity calculations, and distribution efficiency analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitSalesChangePct rdf:type rdf:Property ;
    rdfs:label 'Unit Sales Change Pct' ;
    rdfs:comment 'Year-over-year percentage change in unit sales for the SKU/brand in the specified market and period as reported by the syndicated data provider. Complements dollar sales change to reveal volume versus pricing dynamics.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitSharePct rdf:type rdf:Property ;
    rdfs:label 'Unit Share Pct' ;
    rdfs:comment 'The percentage share of total category unit sales captured by this brand/SKU in the specified market and period. Complements dollar share to reveal pricing and mix dynamics versus competitors.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The 12-digit Universal Product Code (UPC) identifying the specific SKU measured in this record. Primary product identifier used to link syndicated data to internal product master data in SAP S/4HANA MM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityPerStorePerWeek rdf:type rdf:Property ;
    rdfs:label 'Velocity Per Store Per Week' ;
    rdfs:comment 'Average dollar or unit sales per store selling per week (SPSW). Measures the rate of sale for a SKU in stores where it is distributed. Critical for evaluating item productivity and justifying shelf space in planogram negotiations.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPriceId rdf:type rdf:Property ;
    rdfs:label 'Channel Price Id' ;
    rdfs:comment 'System-generated unique identifier for the channel price record.' ;
    rdfs:domain ind:ChannelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Code representing the commercial channel (e.g., retail, foodservice, direct-to-consumer).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPriceStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Price Status' ;
    rdfs:comment 'Current lifecycle status of the price record.' ;
    rdfs:domain ind:ChannelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Authorized selling price for the SKU in the specified channel, expressed in the transaction currency.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'Classification of the price level (e.g., standard, premium, discount, promotional).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVersion rdf:type rdf:Property ;
    rdfs:label 'Price Version' ;
    rdfs:comment 'Sequential version number for the price record, incremented on each change.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorPriceId rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Id' ;
    rdfs:comment 'System-generated unique identifier for each competitor price observation record.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeId rdf:type rdf:Property ;
    rdfs:label 'Store Id' ;
    rdfs:comment 'Internal identifier of the specific store or location where the price was captured.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Store .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Legal name of the competitor brand or company offering the observed product.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorSkuCode rdf:type rdf:Property ;
    rdfs:label 'Competitor Sku Code' ;
    rdfs:comment 'Identifier used by the competitor for the product (e.g., UPC, GTIN, SKU).' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Data Capture Method' ;
    rdfs:comment 'Method used to capture the price observation.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyRegion rdf:type rdf:Property ;
    rdfs:label 'Geography Region' ;
    rdfs:comment 'Broad geographic region (e.g., North America, EMEA) for analytical grouping.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotion rdf:type rdf:Property ;
    rdfs:label 'Is Promotion' ;
    rdfs:comment 'Indicates whether the observed price is a promotional price (true) or regular price (false).' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observedPrice rdf:type rdf:Property ;
    rdfs:label 'Observed Price' ;
    rdfs:comment 'Base retail price observed for the competitor product (excluding promotions).' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the observed price.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Derived price per standard unit (e.g., per ounce, per liter).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerVolume rdf:type rdf:Property ;
    rdfs:label 'Price Per Volume' ;
    rdfs:comment 'Derived price per volume measure where applicable.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'Discounted price observed when the product was on promotion.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailerName rdf:type rdf:Property ;
    rdfs:label 'Retailer Name' ;
    rdfs:comment 'Name of the retail outlet or chain where the price was observed.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfPrice rdf:type rdf:Property ;
    rdfs:label 'Shelf Price' ;
    rdfs:comment 'Price displayed on the shelf label, may include taxes or fees.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCity rdf:type rdf:Property ;
    rdfs:label 'Store City' ;
    rdfs:comment 'City of the store location.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCountry rdf:type rdf:Property ;
    rdfs:label 'Store Country' ;
    rdfs:comment 'Three-letter ISO country code of the store location.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeState rdf:type rdf:Property ;
    rdfs:label 'Store State' ;
    rdfs:comment 'State or province of the store location.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlusModelId rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Model Id' ;
    rdfs:comment 'Unique surrogate key for the cost-plus pricing model record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostPlusModel .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'Product category or segment to which the model is applicable.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlusModelDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Model Description' ;
    rdfs:comment 'Free-form description of the model purpose, assumptions, and scope.' ;
    rdfs:domain ind:CostPlusModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlusModelStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Model Status' ;
    rdfs:comment 'Current lifecycle state of the pricing model.' ;
    rdfs:domain ind:CostPlusModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSourceCode rdf:type rdf:Property ;
    rdfs:label 'Cost Source Code' ;
    rdfs:comment 'Reference to the standard cost record used as the base cost for this model.' ;
    rdfs:domain ind:CostPlusModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Type of cost used as the base for markup calculations.' ;
    rdfs:domain ind:CostPlusModel ;
