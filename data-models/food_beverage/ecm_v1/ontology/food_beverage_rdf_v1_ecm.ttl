ind:nextScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Timestamp' ;
    rdfs:comment 'Planned date and time for the next execution of the route.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nsfH1H2Certification rdf:type rdf:Property ;
    rdfs:label 'Nsf H1 H2 Certification' ;
    rdfs:comment 'NSF certification level of the lubricant used on this route.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPoints rdf:type rdf:Property ;
    rdfs:label 'Number Of Points' ;
