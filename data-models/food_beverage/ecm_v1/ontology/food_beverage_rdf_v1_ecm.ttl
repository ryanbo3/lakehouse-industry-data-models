    rdfs:range ind:Employee .

ind:bodyPart rdf:type rdf:Property ;
    rdfs:label 'Body Part' ;
    rdfs:comment 'Body part(s) impacted by the injury. [ENUM-REF-CANDIDATE: hand|arm|leg|head|torso|face|eye|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAway rdf:type rdf:Property ;
    rdfs:label 'Days Away' ;
