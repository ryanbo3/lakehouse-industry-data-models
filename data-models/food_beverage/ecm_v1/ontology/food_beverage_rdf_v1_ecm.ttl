    rdfs:range ind:Account .

ind:promotionAccountId rdf:type rdf:Property ;
    rdfs:label 'Promotion Account Id' ;
    rdfs:comment 'FK to customer.account.account_id — Trade promotions target specific customer accounts. Without this FK, cannot query which promotions are planned for which retailer — core TPM functionality.' ;
    rdfs:domain ind:PromotionPlan ;
