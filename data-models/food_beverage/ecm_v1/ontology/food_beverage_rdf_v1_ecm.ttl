    rdfs:comment 'Category or classification of equipment/assets covered (e.g., Production Line, HVAC, Elevator).' ;
    rdfs:domain ind:MaintenanceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredAssetIds rdf:type rdf:Property ;
