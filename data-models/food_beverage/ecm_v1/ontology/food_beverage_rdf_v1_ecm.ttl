    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaintenanceSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Supplier Id' ;
    rdfs:comment 'Identifier of the external service provider (references procurement.supplier).' ;
