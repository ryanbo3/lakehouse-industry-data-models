    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Id' ;
    rdfs:comment 'System-generated unique identifier for each segment assignment record.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date on which the segment assignment was initially made.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business rationale or trigger for assigning the segment (e.g., new product launch, market shift).' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'True if the assignment is currently effective (today falls between start and end dates).' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the segment assignment record.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Numeric priority of the segment; lower numbers indicate higher priority.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Version' ;
    rdfs:comment 'Version identifier of the segment definition used at assignment time.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Delivery Routing maps each ship-to location to its serving distribution center (network node), essential for logistics optimization and carrier planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Assigning a ship-to address to an internal storage location supports dedicated inventory allocation and location-based availability reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:capacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Meters' ;
    rdfs:comment 'Maximum volume the location can store, expressed in cubic meters.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for the primary contact at the location.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the ship-to location.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for the primary contact at the location.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Time' ;
    rdfs:comment 'Latest time a delivery may be accepted at this location.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Time' ;
    rdfs:comment 'Earliest time a delivery may be accepted at this location.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dockRequirements rdf:type rdf:Property ;
    rdfs:label 'Dock Requirements' ;
    rdfs:comment 'Specific dock or equipment requirements for receiving shipments (e.g., dock height, trailer type).' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy M' ;
    rdfs:comment 'Estimated accuracy of the geocoded coordinates in meters.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary ship-to address for the parent account.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude of the location in decimal degrees.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude of the location in decimal degrees.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum weight the location can receive per delivery, in kilograms.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingHours rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours' ;
    rdfs:comment 'Standard hours during which the location accepts deliveries (e.g., 08:00-17:00).' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Status' ;
    rdfs:comment 'Current lifecycle status of the location record.' ;
    rdfs:domain ind:ShipToLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Any additional handling or access instructions for deliveries.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control category required for the location.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceShipNoticeId rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Id' ;
    rdfs:comment 'Unique identifier for the advanced shipping notice record. Primary key.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Identifier of the transportation carrier responsible for delivering this shipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Assigns ASN processing costs to a cost center, enabling accurate cost allocation for inbound logistics.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks the employee responsible for ASN creation, required for traceability and regulatory audit reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Reference to the fulfillment order that this ASN is fulfilling. Links ASN to the originating customer order or purchase order.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:shipFromLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Id' ;
    rdfs:comment 'Identifier of the originating facility (distribution center, manufacturing plant, co-packer, or supplier warehouse) from which goods are shipped.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the physical shipment record associated with this ASN. Links ASN to warehouse management and transportation execution systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: ASN originates from the supplying vendor; linking to supplier supports performance tracking and compliance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date when the shipment departed from the origin facility. Used for OTIF performance measurement.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Business identifier for the ASN transmitted to customers or received from suppliers. Externally-known unique reference number.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN. Tracks progression from creation through transmission, acknowledgment, and final receipt or rejection. [ENUM-REF-CANDIDATE: draft|transmitted|acknowledged|in_transit|received|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN direction and purpose. Outbound ASNs are sent to customers/retailers; inbound ASNs are received from suppliers, co-packers, or contract manufacturers.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued bill of lading number for the shipment. Legal document serving as receipt and contract of carriage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether continuous temperature monitoring and cold chain documentation is required for this shipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the trading partner acknowledged receipt of the ASN via EDI 997 functional acknowledgment.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ediControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Control Number' ;
    rdfs:comment 'Unique control number assigned to the EDI 856 transaction for tracking and reconciliation purposes.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'EDI transaction set identifier. ASNs use the 856 Ship Notice/Manifest transaction set.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Timestamp' ;
    rdfs:comment 'Date and time when the ASN was transmitted via EDI to the trading partner. Used for compliance and SLA tracking.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned date when the shipment will arrive at the destination facility. Critical for DC receiving planning and retailer compliance.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Time Window End' ;
    rdfs:comment 'End of the delivery appointment window. Late arrivals may result in chargebacks or rejected shipments.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Time Window Start' ;
    rdfs:comment 'Start of the delivery appointment window. Many retailers require precise time-slot delivery for dock scheduling.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'Planned date when the shipment will depart from the origin facility.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials requiring special handling and documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this ASN record was last modified. Used for audit trail and data synchronization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer or supplier purchase order number that this ASN is fulfilling. Used for cross-reference and compliance validation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'Primary street address line of the destination location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City of the destination location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the destination location.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the destination location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State or province code of the destination location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or cases included in this shipment. Used for receiving verification and inventory accuracy.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets included in this shipment. Used for dock space planning and receiving resource allocation.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolume rdf:type rdf:Property ;
    rdfs:label 'Total Volume' ;
    rdfs:comment 'Total cubic volume of the shipment. Used for trailer utilization and warehouse space planning.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeight rdf:type rdf:Property ;
    rdfs:label 'Total Weight' ;
    rdfs:comment 'Total weight of the shipment including packaging. Used for freight cost validation and carrier capacity planning.' ;
    rdfs:domain ind:AdvanceShipNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for real-time shipment visibility and proof of delivery.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for shipment volume. CF=cubic feet, CBM=cubic meters, L=liters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUom rdf:type rdf:Property ;
    rdfs:label 'Weight Uom' ;
    rdfs:comment 'Unit of measure for shipment weight. LB=pounds, KG=kilograms, TON=US tons, MT=metric tonnes.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal name of the transportation carrier organization as registered with regulatory authorities.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier in the approved carrier network. Controls eligibility for load assignment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of carrier business model: asset-based (owns equipment), non-asset-based (brokerage), third-party logistics provider, private fleet (company-owned), or Direct Store Delivery fleet.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio Percentage' ;
    rdfs:comment 'Percentage of shipments resulting in damage, loss, or shortage claims over the past 12 months. Used for carrier risk assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable Flag' ;
    rdfs:comment 'Indicates whether the carrier has temperature-controlled equipment and processes certified for transporting refrigerated and frozen food products.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedRateTier rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Tier' ;
    rdfs:comment 'Rate tier classification based on contracted pricing agreement. Tier 1 represents preferred pricing, spot market represents non-contracted rates.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPhone rdf:type rdf:Property ;
    rdfs:label 'Dispatch Phone' ;
    rdfs:comment '24/7 dispatch phone number for load tendering, driver coordination, and real-time shipment tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier issued by the US Department of Transportation Federal Motor Carrier Safety Administration for interstate commercial carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether the carrier supports EDI transaction sets for load tendering, status updates, and Advanced Shipping Notice (ASN) processing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediProtocol rdf:type rdf:Property ;
    rdfs:label 'Edi Protocol' ;
    rdfs:comment 'Technical protocol used for electronic data interchange with the carrier: ANSI X12, EDIFACT, API integration, or none.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Total number of power units (tractors, trucks) operated by the carrier. Used for capacity planning and carrier capability assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Certification Date' ;
    rdfs:comment 'Date when the carrier received FSMA Sanitary Transportation compliance certification. Used to track recertification cycles.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliant Flag' ;
    rdfs:comment 'Indicates whether the carrier meets FSMA Sanitary Transportation of Human and Animal Food requirements including temperature control, equipment sanitation, and training documentation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers FSMA Sanitary Transportation compliance certification. Triggers recertification workflow.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'Primary street address line for the carriers corporate headquarters location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carriers corporate headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the carriers headquarters location (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the carriers corporate headquarters location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province code where the carriers corporate headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number for the carriers liability and cargo insurance certificate on file. Required for carrier qualification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers current insurance policy. Carrier status automatically suspended if insurance lapses.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent carrier compliance audit covering safety, food safety, insurance, and operational standards.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when the carrier master record was most recently updated. Used for change tracking and data synchronization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by FMCSA for for-hire interstate carriers. Required for carriers transporting regulated commodities.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next carrier compliance audit. Used to trigger audit planning and carrier notification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the carrier was approved and onboarded into the approved carrier network. Marks the start of the business relationship.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Percentage' ;
    rdfs:comment 'Rolling 12-month percentage of shipments delivered on-time and in-full without damage or shortage. Key performance indicator for carrier evaluation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days from invoice date for carrier freight charges (e.g., Net 30, Net 45).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification based on On-Time In-Full (OTIF) delivery, claims ratio, and service quality metrics. Determines load allocation priority.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Flag' ;
    rdfs:comment 'Indicates whether the carrier is designated as a preferred partner with priority load allocation and strategic relationship status.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Federal Motor Carrier Safety Administration safety rating based on compliance review. Satisfactory rating required for carrier approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association (NMFTA) for transportation companies. Used in EDI transactions and shipping documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCoverageRegion rdf:type rdf:Property ;
    rdfs:label 'Service Coverage Region' ;
    rdfs:comment 'Geographic regions where the carrier provides transportation services. Free-text description of coverage area (e.g., US Midwest, Eastern Seaboard, National).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Primary mode of transportation service offered by the carrier. Defines equipment type and service level capability. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|intermodal|refrigerated|dry_van|flatbed|tanker — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature in Celsius that the carriers refrigerated equipment can maintain. Critical for chilled food distribution.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature in Celsius that the carriers refrigerated equipment can maintain. Critical for frozen food distribution.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainEventId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Event Id' ;
    rdfs:comment 'Unique identifier for the cold chain monitoring event record.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Cold-chain compliance monitoring per batch requires linking temperature events to the batch record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to marketing.brand. Business justification: Temperature compliance reports are often brand-specific; linking events to brand enables brand-wise quality monitoring.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:productRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Product Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.product_registration. Business justification: Temperature excursion reports must reference the product registration to satisfy FDA and FSMA traceability requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRegistration .

ind:alertNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether an automated alert notification was sent to responsible personnel when the excursion was detected (True if sent, False if not sent).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertRecipientList rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user IDs that received the temperature excursion alert notification.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Asset Identifier' ;
    rdfs:comment 'Unique identifier or code for the specific cold chain asset (e.g., trailer number, zone code, reefer unit serial number).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Type of cold chain asset being monitored (trailer, distribution center zone, reefer unit, container, warehouse room, or transport vehicle).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brixMeasurement rdf:type rdf:Property ;
    rdfs:label 'Brix Measurement' ;
    rdfs:comment 'Sugar content measurement in degrees Brix if applicable to the product being monitored (primarily for beverages and fruit products).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective action implemented in response to a temperature excursion or monitoring alert.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when corrective action was initiated in response to the temperature excursion.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Code identifying the destination location (retail store, distribution center, or customer site) for the cold chain shipment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Final disposition decision for the product following temperature excursion review (approved for sale, rejected, quarantined, pending review, or destroyed).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the temperature monitoring event was recorded in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the temperature remained outside the acceptable range during the excursion event.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Boolean indicator of whether the recorded temperature exceeded the acceptable range (True if excursion occurred, False if within range).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'Classification of the temperature excursion severity based on duration and deviation magnitude (minor, moderate, major, or critical).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cold chain asset at the time of the temperature reading.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cold chain asset at the time of the temperature reading.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the cold chain event monitoring and response met HACCP critical control point requirements (True if compliant, False if non-compliant).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage in the cold chain environment if monitored alongside temperature.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the product being monitored for traceability purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the origin location (distribution center, manufacturing plant, or warehouse) where the cold chain monitoring began.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phMeasurement rdf:type rdf:Property ;
    rdfs:label 'Ph Measurement' ;
    rdfs:comment 'Acidity or alkalinity measurement on the pH scale if applicable to the product being monitored (critical for food safety and quality).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level category of food or beverage product being transported or stored in the cold chain asset. [ENUM-REF-CANDIDATE: dairy|beverage|frozen|fresh_produce|meat|seafood|prepared_foods — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether the product was placed on quality hold due to the temperature excursion (True if on hold, False if released).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordedTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Recorded Temperature Celsius' ;
    rdfs:comment 'Actual temperature reading captured by the sensor in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Recorded Temperature Fahrenheit' ;
    rdfs:comment 'Actual temperature reading captured by the sensor in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the temperature excursion severity requires reporting to regulatory authorities such as FDA or USDA (True if reporting required, False if not required).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report was submitted to the appropriate governing body if required.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the cold chain event was reviewed and disposition decision was made.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Unique identifier for the temperature monitoring sensor or device that captured the reading.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature threshold for the cold chain asset in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMaxFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max Fahrenheit' ;
    rdfs:comment 'Maximum acceptable temperature threshold for the cold chain asset in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature threshold for the cold chain asset in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min Fahrenheit' ;
    rdfs:comment 'Minimum acceptable temperature threshold for the cold chain asset in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryRouteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Id' ;
    rdfs:comment 'Unique identifier for the delivery route. Primary key for the delivery route entity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryRoute .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Reference to the specific vehicle (truck, trailer, van) assigned to this route execution. Populated for execution records, may be null for route master templates.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:centerId rdf:type rdf:Property ;
    rdfs:label 'Center Id' ;
    rdfs:comment 'Reference to the distribution center or warehouse that serves as the origin point for this route. All deliveries on this route originate from this DC.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:rdProjectId rdf:type rdf:Property ;
    rdfs:label 'Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.rd_project. Business justification: Supports Route Planning for R&D sample kit deliveries, required by the Sample Distribution Schedule.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdProject .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Reference to the sales or distribution territory to which this route is assigned. Used for territory management and sales alignment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:actualMileage rdf:type rdf:Property ;
    rdfs:label 'Actual Mileage' ;
    rdfs:comment 'Actual total mileage driven during route execution, captured from vehicle telematics or odometer readings. Used for cost analysis and route optimization.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesDelivered rdf:type rdf:Property ;
    rdfs:label 'Cases Delivered' ;
    rdfs:comment 'Total number of product cases successfully delivered to customers during route execution. Used for fill rate calculation and revenue recognition.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesLoaded rdf:type rdf:Property ;
    rdfs:label 'Cases Loaded' ;
    rdfs:comment 'Total number of product cases loaded onto the vehicle at route start. Used for inventory reconciliation and load planning analysis.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casesRefused rdf:type rdf:Property ;
    rdfs:label 'Cases Refused' ;
    rdfs:comment 'Total number of product cases refused by customers during delivery due to quality issues, order discrepancies, or receiving problems. Subset of cases_returned.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casesReturned rdf:type rdf:Property ;
    rdfs:label 'Cases Returned' ;
    rdfs:comment 'Total number of product cases returned to the distribution center undelivered. Includes unsold inventory from DSD routes and refused deliveries.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashCollected rdf:type rdf:Property ;
    rdfs:label 'Cash Collected' ;
    rdfs:comment 'Total cash payments collected from customers during route execution. Applicable primarily to DSD routes with cash-on-delivery transactions. Used for cash reconciliation.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkCollected rdf:type rdf:Property ;
    rdfs:label 'Check Collected' ;
    rdfs:comment 'Total check payments collected from customers during route execution. Applicable primarily to DSD routes. Used for accounts receivable reconciliation.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this route requires temperature-controlled (refrigerated or frozen) transportation to maintain product quality and food safety compliance. True if any stop requires cold chain.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when this route master definition became active and available for scheduling. Used for route lifecycle management and historical analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Actual timestamp when the driver returned to the distribution center and completed route execution. Used for route duration analysis and driver shift management.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Planned total duration for route completion in minutes, including drive time, stop time, and loading/unloading. Used for driver scheduling and shift planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedMileage rdf:type rdf:Property ;
    rdfs:label 'Estimated Mileage' ;
    rdfs:comment 'Planned total mileage for the route in miles, based on stop sequence and routing optimization. Used for cost estimation and vehicle assignment.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The specific date on which this route instance was executed. For route execution records, this is the primary business event date. For route master records, this field may be null.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fillRatePct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Pct' ;
    rdfs:comment 'Percentage of ordered cases that were successfully delivered on this route. Calculated as (cases_delivered / cases_loaded) * 100. Key metric for order fulfillment performance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Scheduled frequency at which this route is executed. DAILY for every business day, WEEKLY for once per week, BIWEEKLY for every two weeks, MONTHLY for once per month, ON_DEMAND for ad-hoc execution.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumedGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Gallons' ;
    rdfs:comment 'Total fuel consumed during route execution in gallons. Captured from vehicle telematics or fuel card transactions. Used for cost allocation and sustainability reporting.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handheldDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Handheld Device Code' ;
    rdfs:comment 'Identifier of the mobile handheld device (scanner, tablet, or mobile computer) used by the driver for proof of delivery, order capture, and route tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether this route transports hazardous materials requiring special handling, placarding, and driver certification per DOT regulations.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifPerformancePct rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Pct' ;
    rdfs:comment 'Percentage of deliveries on this route that met both on-time and in-full criteria. Key performance indicator for distribution service level. Calculated as (on-time and in-full deliveries / total planned deliveries) * 100.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Business identifier for the route, used for operational reference and scheduling. Typically alphanumeric code assigned by transportation management system.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Route Completion Status' ;
    rdfs:comment 'Overall completion status of the route execution instance. COMPLETED indicates all planned stops were attempted, PARTIAL indicates some stops were skipped, CANCELLED indicates route was aborted, IN_PROGRESS indicates route is currently being executed, NOT_STARTED indicates route has not yet begun.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the route, often including geographic or customer references (e.g., \'Downtown Chicago Loop\', \'Northeast Territory A\').' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the route template. ACTIVE routes are in regular operation, INACTIVE are temporarily not in use, SUSPENDED are on hold pending review, PLANNED are designed but not yet operational, RETIRED are permanently discontinued.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on delivery model. DSD (Direct Store Delivery) for direct-to-retail routes, DC_TO_RETAIL for distribution center to retail, FOODSERVICE for restaurant/institutional delivery, DTC for direct-to-consumer, CROSS_DOCK for cross-docking operations, BACKHAUL for return logistics.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Days Of Week' ;
    rdfs:comment 'Comma-separated list of days when route is scheduled to run (e.g., \'MON,WED,FRI\'). Applicable for WEEKLY and BIWEEKLY frequency routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Actual timestamp when the driver departed the distribution center to begin route execution. Used for OTIF (On Time In Full) performance tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopCount rdf:type rdf:Property ;
    rdfs:label 'Stop Count' ;
    rdfs:comment 'Number of planned delivery stops on this route. Used for route complexity assessment and driver workload planning.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Stops Completed' ;
    rdfs:comment 'Number of delivery stops successfully completed during this route execution. Used to calculate route completion rate and identify service failures.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Stops Planned' ;
    rdfs:comment 'Number of delivery stops planned for this route execution instance. Used to calculate route completion rate.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRangeMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max F' ;
    rdfs:comment 'Maximum acceptable temperature in Fahrenheit for cold chain routes. Used for temperature monitoring and compliance verification. Null for non-cold-chain routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min F' ;
    rdfs:comment 'Minimum acceptable temperature in Fahrenheit for cold chain routes. Used for temperature monitoring and compliance verification. Null for non-cold-chain routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Type of vehicle required to execute this route based on cargo volume, weight, and special handling requirements. Determines vehicle assignment from fleet.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: Links each distribution center to its pricing zone, supporting regional price-zone based pricing strategies and zone-specific cost allocation reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the distribution center physical location including street number and name.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building, suite, or unit number. Nullable.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Ambient Zone Flag' ;
    rdfs:comment 'Indicates whether the distribution center has ambient temperature storage zones for dry goods and shelf-stable products.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centerName rdf:type rdf:Property ;
    rdfs:label 'Center Name' ;
    rdfs:comment 'Official business name of the distribution center facility.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Primary contact email address for the distribution center facility for operational communications and coordination.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary contact phone number for the distribution center facility for operational coordination and emergency contact.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Capable Flag' ;
    rdfs:comment 'Indicates whether the distribution center has cross-docking capabilities to transfer products directly from inbound to outbound without storage.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cubicCapacity rdf:type rdf:Property ;
    rdfs:label 'Cubic Capacity' ;
    rdfs:comment 'Total cubic footage storage capacity of the distribution center for volumetric capacity planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems and external communications. Typically alphanumeric facility code.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directStoreDeliveryHubFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Store Delivery Hub Flag' ;
    rdfs:comment 'Indicates whether the distribution center serves as a hub for Direct Store Delivery operations to retail locations.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Total number of loading dock doors available for inbound and outbound shipments. Critical for throughput capacity analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecommerceFulfillmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Fulfillment Flag' ;
    rdfs:comment 'Indicates whether the distribution center handles direct-to-consumer e-commerce order fulfillment and last-mile delivery.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'Plant or location code in the ERP system (SAP S/4HANA) representing this distribution center for financial and supply chain transactions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the distribution center based on primary storage and handling capability. Ambient for dry goods, refrigerated for chilled products, frozen for sub-zero storage, multi-temperature for mixed zones, cross-dock for flow-through operations, consolidation for order aggregation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frozenZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Frozen Zone Flag' ;
    rdfs:comment 'Indicates whether the distribution center has frozen storage zones for products requiring sub-zero temperature storage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the current GFSI certification. Used for compliance monitoring and audit scheduling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gfsiCertificationScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Scheme' ;
    rdfs:comment 'Specific GFSI-recognized certification scheme held by the facility (e.g., SQF Level 2, BRC Storage and Distribution, FSSC 22000). Nullable if not certified. [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|IFS|GLOBALG.A.P.|GRMS|PrimusGFS|CanadaGAP — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Status' ;
    rdfs:comment 'Current status of GFSI-recognized certification (e.g., SQF, BRC, FSSC 22000) for the distribution center. Critical for food safety compliance and customer requirements.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified Flag' ;
    rdfs:comment 'Indicates whether the distribution center has HACCP certification for food safety management. Required for facilities handling high-risk food products.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to receiving inbound shipments from suppliers and manufacturing plants.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the distribution center has ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Expiration date of the facility lease agreement for leased distribution centers. Nullable for owned facilities. Used for real estate planning and renewal management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays (Monday-Friday) in format HH:MM-HH:MM (e.g., 06:00-22:00). Used for scheduling and service level planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends (Saturday-Sunday) in format HH:MM-HH:MM. Nullable if facility does not operate on weekends.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date when the distribution center began operational activities and started processing inventory and shipments.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the distribution center in its lifecycle. Active indicates full operations, inactive for non-operational but maintained, under construction for facilities being built, decommissioned for permanently closed, seasonal for periodic operations, temporarily closed for short-term shutdowns.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to shipping outbound orders to customers, retail stores, and distribution points.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Ownership and operational control model for the distribution center. Company-owned for internal facilities, third-party logistics (3PL) for outsourced operations, leased for rented facilities with internal operations, co-managed for hybrid arrangements.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPositionCapacity rdf:type rdf:Property ;
    rdfs:label 'Pallet Position Capacity' ;
    rdfs:comment 'Maximum number of pallet positions available for storage in the distribution center. Key metric for inventory capacity planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Service Region' ;
    rdfs:comment 'Geographic region or market area primarily served by this distribution center for distribution network planning and territory management.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refrigeratedZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Zone Flag' ;
    rdfs:comment 'Indicates whether the distribution center has refrigerated storage zones for chilled products requiring cold chain management.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Storage Square Footage' ;
    rdfs:comment 'Square footage dedicated to product storage areas excluding staging, dock, and administrative space.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZoneCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Count' ;
    rdfs:comment 'Number of distinct temperature-controlled zones within the distribution center for managing products with different storage requirements.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyLogisticsProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Provider' ;
    rdfs:comment 'Name of the third-party logistics provider managing the facility if ownership model is 3PL or co-managed. Null for company-owned facilities.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total building square footage of the distribution center facility including all storage, staging, and administrative areas.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twentyFourSevenOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Operation Flag' ;
    rdfs:comment 'Indicates whether the distribution center operates 24 hours a day, 7 days a week for continuous fulfillment operations.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wmsSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Wms System Identifier' ;
    rdfs:comment 'Identifier for the Warehouse Management System instance managing this distribution center. Used for system integration and data reconciliation.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique identifier for the freight invoice record. Primary key.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Links each freight invoice to the GL account for proper posting of freight expense in the general ledger.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Freight invoices are billed to the purchase order that initiated the shipment, enabling financial reconciliation and OTIF analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Total of all accessorial charges (liftgate, inside delivery, residential delivery, detention, redelivery, etc.).' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Payment Amount' ;
    rdfs:comment 'The amount approved for payment after audit and dispute resolution. May differ from total billed amount if short-paid or adjusted.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'The current status of the freight audit process for this invoice. Indicates whether the invoice has been reviewed, approved, or flagged for dispute.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audited Timestamp' ;
    rdfs:comment 'The timestamp when the freight audit was completed for this invoice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'The Bill of Lading number associated with this shipment. Legal document issued by carrier to shipper.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'The expected total amount based on the contracted rate agreement with the carrier for this shipment profile.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the shipment was delivered to the destination location.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'The city to which the shipment was delivered.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code to which the shipment was delivered (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'The postal code to which the shipment was delivered.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'The state or province to which the shipment was delivered.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Any discount applied to the invoice based on contracted rates or promotional agreements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes describing the details of the dispute, including supporting documentation references and resolution actions.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'The code identifying the reason for disputing this invoice (e.g., rate discrepancy, duplicate charge, incorrect accessorial, service failure).' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'The distance traveled for this shipment in miles, as calculated by the carrier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge' ;
    rdfs:comment 'The fuel surcharge applied to the shipment based on current fuel prices and carrier fuel surcharge tables.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the carrier issued the freight invoice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDueDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Due Date' ;
    rdfs:comment 'The date by which payment is due to the carrier per the payment terms.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The carrier-issued invoice number. This is the externally-known unique identifier for this freight invoice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineHaulCharge rdf:type rdf:Property ;
    rdfs:label 'Line Haul Charge' ;
    rdfs:comment 'The base transportation charge for moving the freight from origin to destination, excluding accessorials and surcharges.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'The city from which the shipment originated.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code from which the shipment originated (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCode rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code' ;
    rdfs:comment 'The postal code from which the shipment originated.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStateProvince rdf:type rdf:Property ;
    rdfs:label 'Origin State Province' ;
    rdfs:comment 'The state or province from which the shipment originated.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date payment was issued to the carrier for this invoice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number of the payment transaction (check number, wire transfer ID, ACH trace number) used to pay this invoice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'The current payment status of this freight invoice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'The carrier-assigned Progressive Rotating Order (PRO) number used to track the shipment. Standard identifier in LTL and truckload freight.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Variance Amount' ;
    rdfs:comment 'The variance between the billed amount and the contracted rate amount. Positive values indicate overbilling; negative values indicate underbilling.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when the freight invoice was received by the organization (via EDI, email, or carrier portal).' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The specific service level provided by the carrier (e.g., Standard, Expedited, Next Day, Two Day, White Glove, Temperature Controlled).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'The date the shipment was picked up by the carrier from the origin location.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'The total amount billed by the carrier on this invoice, including line haul, fuel surcharge, accessorials, and any adjustments.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightActual rdf:type rdf:Property ;
    rdfs:label 'Weight Actual' ;
    rdfs:comment 'The actual weight of the shipment as measured or certified by the carrier.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Order attribution to marketing campaigns is required for sales-to-campaign performance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: Traceability report links each fulfillment order to the production order that created the shipped product.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Assigns revenue from each fulfillment order to a profit center for profitability analysis and reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Identifier for the delivery route to which this fulfillment order has been assigned. Used for Direct Store Delivery (DSD) route optimization and last-mile logistics planning.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryRoute .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order that triggered this fulfillment order. Links the distribution execution back to the commercial transaction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Identifier for the picking wave or batch to which this fulfillment order has been assigned. Waves group multiple orders for efficient picking and resource optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date the order was delivered to the customer location. Captured from proof of delivery (POD) or carrier tracking systems. Used for OTIF performance measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Timestamp' ;
    rdfs:comment 'The date and time the Advanced Shipping Notice was transmitted to the customer. Used for EDI compliance tracking and customer service level measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order is designated for cross-docking operations, where goods move directly from receiving to shipping without intermediate storage. True indicates cross-dock handling; false indicates standard warehouse flow with putaway and storage.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The precise date and time the order was delivered to the customer. Captured from proof of delivery or carrier tracking. Used for OTIF measurement and service level compliance.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying the type of exception or disruption encountered during fulfillment execution. Examples include inventory shortage, damaged product, carrier delay, address error, or customer request change. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of the exception or disruption encountered during fulfillment. Provides context for resolution actions and root cause investigation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Status' ;
    rdfs:comment 'Current status of exception resolution efforts. Open indicates exception has been identified but not yet addressed; in_progress indicates resolution actions are underway; resolved indicates exception has been successfully resolved; escalated indicates exception requires management intervention.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'The percentage of the order quantity that was successfully fulfilled and shipped. Calculated as shipped quantity divided by ordered quantity. Used for service level measurement and inventory availability analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The business channel through which this order is being fulfilled. Determines handling requirements, service level expectations, and routing logic. Retail represents traditional grocery and mass merchandiser channels; foodservice represents restaurant and institutional channels; direct-to-consumer (DTC) represents online orders shipped to individual consumers; direct store delivery (DSD) represents orders delivered directly to retail stores bypassing DC consolidation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Business-readable unique identifier for the fulfillment order. Used for operational tracking, communication with warehouse staff, and customer service inquiries.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle status of the fulfillment order within the distribution execution process. Released indicates order is available for wave assignment; wave_assigned indicates order is assigned to a picking wave; picking indicates order is actively being picked; picked indicates picking is complete; packing indicates order is being packed; packed indicates packing is complete; staged indicates order is staged for loading; loaded indicates order is loaded on carrier vehicle; shipped indicates order has departed the DC; in_transit indicates order is en route to destination; delivered indicates order has been received by customer; exception indicates order has encountered a problem requiring intervention; cancelled indicates order has been cancelled. [ENUM-REF-CANDIDATE: released|wave_assigned|picking|picked|packing|packed|staged|loaded|shipped|in_transit|delivered|exception|cancelled — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Release Timestamp' ;
    rdfs:comment 'The date and time the fulfillment order was released from the order management system to the warehouse management system for execution. Marks the start of the fulfillment lifecycle.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the fulfillment order based on handling and processing requirements. Standard represents normal replenishment orders; rush represents expedited orders requiring priority handling; cross-dock represents orders that bypass storage and move directly from receiving to shipping; drop-ship represents orders shipped directly from supplier to customer; sample represents non-commercial product samples; promotional represents orders tied to marketing campaigns or trade promotions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Target Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order is included in On-Time In-Full performance measurement. True indicates order is subject to OTIF service level agreements; false indicates order is excluded from OTIF metrics (e.g., sample orders, internal transfers).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Complete Timestamp' ;
    rdfs:comment 'The date and time when all picking operations were completed for this fulfillment order. Used for cycle time analysis and throughput measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Start Timestamp' ;
    rdfs:comment 'The date and time when picking operations began for this fulfillment order. Used for cycle time analysis and warehouse productivity measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The date the distribution center plans to ship the order based on capacity, inventory availability, and carrier schedules. May differ from requested ship date due to operational constraints.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to the fulfillment order for warehouse resource allocation and sequencing. Critical represents emergency orders requiring immediate processing; high represents time-sensitive orders with tight delivery windows; normal represents standard priority orders; low represents orders that can be delayed if capacity constraints exist.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date committed to the customer for delivery of the order. Used for On-Time In-Full (OTIF) performance measurement and customer service level tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date the customer or sales order requested the order to ship from the distribution center. Used for planning and scheduling warehouse operations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'The precise date and time the order departed the distribution center. Used for transit time calculation and carrier performance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCases rdf:type rdf:Property ;
    rdfs:label 'Total Order Cases' ;
    rdfs:comment 'The total number of cases or cartons in the fulfillment order. Used for warehouse productivity measurement, handling cost allocation, and load planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderLines rdf:type rdf:Property ;
    rdfs:label 'Total Order Lines' ;
    rdfs:comment 'The total number of distinct line items or SKUs in the fulfillment order. Used for picking complexity assessment and labor planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderPallets rdf:type rdf:Property ;
    rdfs:label 'Total Order Pallets' ;
    rdfs:comment 'The total number of pallets in the fulfillment order, including partial pallets expressed as decimal values. Used for transportation planning, dock scheduling, and freight cost calculation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'The total cubic volume of the fulfillment order in cubic meters. Used for warehouse space planning, vehicle capacity utilization, and freight cost calculation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'The total gross weight of the fulfillment order in kilograms, including product and packaging. Used for carrier selection, freight cost calculation, and load planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Line Id' ;
    rdfs:comment 'Unique identifier for the fulfillment order line item. Primary key for this entity.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingredientLotId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Lot Id' ;
    rdfs:comment 'Foreign key linking to ingredient.lot. Business justification: Recall Management Process: order lines need the exact ingredient lot to enable precise product recalls.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:palletId rdf:type rdf:Property ;
    rdfs:label 'Pallet Id' ;
    rdfs:comment 'Identifier for the pallet or shipping unit containing this line item. Used for pallet-level tracking and cross-docking operations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pallet .

ind:priceListLineId rdf:type rdf:Property ;
    rdfs:label 'Price List Line Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list_line. Business justification: Captures the exact price list line used for each order line, enabling line-level margin calculations and price change impact reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceListLine .

ind:promotionLineId rdf:type rdf:Property ;
    rdfs:label 'Promotion Line Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_line. Business justification: Each order line may be driven by a specific promotion line; linking enables accurate promotion ROI and claim reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionLine .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when inventory was allocated to this line. Marks the beginning of the fulfillment process.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether unfulfilled quantity from this line was placed on backorder for future fulfillment. Used for backorder management and customer service.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Number of cartons or cases used to fulfill this line. Used for packaging and freight calculation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catchWeightActual rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Actual' ;
    rdfs:comment 'Actual weight for catch-weight items where weight varies by unit. Used for variable-weight products like fresh produce, meat, or cheese.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightUom rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Uom' ;
    rdfs:comment 'Unit of measure for catch weight. Defines whether weight is expressed in pounds, kilograms, ounces, or grams.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity of the SKU confirmed for fulfillment and actually picked. May differ from ordered quantity due to inventory availability or allocation rules.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fefoPickFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Pick Flag' ;
    rdfs:comment 'Indicates whether this line was picked using FEFO logic to ensure oldest expiration dates are shipped first. Critical for perishable food and beverage products.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global trade item number (UPC/EAN) for the product. Standardized identifier used across the supply chain for product identification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the fulfillment order. Determines the ordering and position of this line item in the order.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current fulfillment status of the order line. Tracks the line through the warehouse execution lifecycle from allocation to shipment. [ENUM-REF-CANDIDATE: pending|allocated|picked|packed|shipped|cancelled|short_shipped — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value for this line (quantity × unit price). Used for order value calculation and financial reporting.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally ordered by the customer. Represents the requested amount before any adjustments or shortages.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'Original SKU that was ordered if a substitution was made. Null if no substitution occurred.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'Date and time when the line was packed for shipment. Used for packing efficiency and order completion tracking.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse zone or area where the product was picked. Used for labor planning and zone-based picking strategies.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'Date and time when the line was physically picked from warehouse inventory. Used for pick productivity and cycle time analysis.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date the product was manufactured or packaged. Used for shelf life calculation and quality tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Trade promotion or discount code applied to this line. Used for TPM tracking and promotional effectiveness analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Flag' ;
    rdfs:comment 'Indicates whether this line underwent quality inspection before shipment. Used for quality assurance and food safety compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for serialized inventory items. Used for high-value products requiring individual unit tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity of the SKU shipped to the customer. Final quantity that left the distribution center.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when the line was shipped from the distribution center. Used for OTIF calculation and ASN generation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code explaining why the line was short-shipped or not fully fulfilled. Used for fill rate analysis and root cause investigation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether a product substitution was made for this line due to stockout or customer approval. Used for substitution rate tracking.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit for this line item. Used for invoice generation and revenue recognition.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure for the line quantity. Defines whether quantities are expressed in cases, eaches, pallets, or other packaging units.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Specific warehouse bin or location from which the product was picked. Used for inventory accuracy and slotting optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifRecordId rdf:type rdf:Property ;
    rdfs:label 'Otif Record Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement record.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer account for which OTIF performance is being measured.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Identifies the employee accountable for OTIF compliance, used in OTIF performance and penalty reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The actual date and time when the shipment was delivered to the customer location.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:casesOrdered rdf:type rdf:Property ;
    rdfs:label 'Cases Ordered' ;
    rdfs:comment 'The total number of cases ordered by the customer in the fulfillment order.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackReference rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reference' ;
    rdfs:comment 'Reference number for the retailer chargeback or deduction associated with this OTIF failure.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Window End' ;
    rdfs:comment 'The end of the delivery time window committed to the customer, used to determine on-time performance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Window Start' ;
    rdfs:comment 'The start of the delivery time window committed to the customer, used to determine on-time performance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference to the corrective action plan or ticket created to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'First line of the delivery destination address.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City of the delivery destination.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the delivery destination (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDestinationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination Type' ;
    rdfs:comment 'The type of destination location for the delivery (e.g., retail store, distribution center, foodservice, direct-to-consumer).' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery destination.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province of the delivery destination.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether this OTIF failure has been escalated to senior management due to severity or repeat occurrence.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Boolean indicator of whether the full ordered quantity was delivered without shortages (True = in-full, False = short).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date on which the OTIF performance was measured and recorded.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Boolean indicator of whether the delivery was completed within the committed time window (True = on-time, False = late).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Otif Composite Score' ;
    rdfs:comment 'The composite OTIF performance score, typically expressed as a percentage (0-100), representing the combined on-time and in-full achievement.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyFineAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Fine Amount' ;
    rdfs:comment 'The monetary penalty or fine amount assessed by the retailer for OTIF non-compliance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference to the proof of delivery document or electronic signature confirming receipt.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the OTIF record (e.g., created, under investigation, resolved, penalty paid, closed). [ENUM-REF-CANDIDATE: created|under_investigation|root_cause_identified|corrective_action_assigned|resolved|penalty_paid|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational unit or individual responsible for managing this OTIF record and corrective actions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerOtifProgram rdf:type rdf:Property ;
    rdfs:label 'Retailer Otif Program' ;
    rdfs:comment 'The specific retailer OTIF compliance program under which this delivery performance is measured (e.g., Walmart OTIF, Target In-Stock, Kroger On-Time Delivery).' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the OTIF miss (e.g., carrier delay, DC late release, inventory shortage, weather event). [ENUM-REF-CANDIDATE: carrier_delay|dc_late_release|inventory_short|weather|traffic|equipment_failure|labor_shortage|system_error|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause analysis for the OTIF failure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentReference rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference' ;
    rdfs:comment 'The shipment identifier associated with this OTIF measurement, linking to the physical delivery.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether cold chain temperature requirements were maintained throughout delivery (True = compliant, False = breach).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Unique identifier for the proof of delivery record.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Reference to the delivery order fulfilled by this delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:casesDeliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Delivered Quantity' ;
    rdfs:comment 'Actual number of cases successfully delivered and accepted by the receiver, used for fill rate calculation.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesOrderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Ordered Quantity' ;
    rdfs:comment 'Total number of cases that were originally ordered and scheduled for delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesRefusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Refused Quantity' ;
    rdfs:comment 'Number of cases refused or rejected by the receiver at the time of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainCompliant rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant' ;
    rdfs:comment 'Indicates whether the delivery met cold chain temperature requirements throughout transit and at delivery, ensuring food safety and quality for perishable products.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryConditionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition Code' ;
    rdfs:comment 'Standardized code indicating the overall condition of the delivered goods at the time of receipt.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition Notes' ;
    rdfs:comment 'Free-text notes describing the condition of the delivered goods, including any damage, quality concerns, or packaging issues observed at delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPhotoCaptured rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Captured' ;
    rdfs:comment 'Indicates whether photographic evidence of the delivery was captured via mobile device or ePOD system.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Url' ;
    rdfs:comment 'URL or storage path to the delivery photo image file, used for proof of delivery and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the delivery in its lifecycle workflow.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaised rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised' ;
    rdfs:comment 'Indicates whether a delivery dispute has been raised by the customer or carrier regarding this proof of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time of delivery, used for delivery verification and route optimization analytics.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time of delivery, used for delivery verification and route optimization analytics.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceMatched rdf:type rdf:Property ;
    rdfs:label 'Invoice Matched' ;
    rdfs:comment 'Indicates whether the proof of delivery has been successfully matched to the corresponding invoice for three-way matching (PO, receipt, invoice).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifCompliant rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant' ;
    rdfs:comment 'Indicates whether the delivery met On Time In Full (OTIF) performance criteria: delivered on scheduled date within time window and with full ordered quantity.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'Method used to capture the proof of delivery: electronic POD device, paper scan, EDI 214 Transportation Carrier Shipment Status Message, mobile application, or no signature required.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'Externally-known unique business identifier for the proof of delivery document, used for tracking and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'Full name of the individual who received and signed for the delivery at the customer location.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature Captured' ;
    rdfs:comment 'Indicates whether a digital or physical signature was captured from the receiver as proof of receipt.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiverTitle rdf:type rdf:Property ;
    rdfs:label 'Receiver Title' ;
    rdfs:comment 'Job title or role of the individual who received the delivery (e.g., Store Manager, Receiving Clerk, Warehouse Supervisor).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for refusal or rejection of delivered goods. [ENUM-REF-CANDIDATE: damaged|expired|wrong_product|overage|quality_issue|no_order|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional detail about the reason for refusal, used for dispute resolution and quality investigation.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for the delivery, used for On Time In Full (OTIF) measurement and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window End' ;
    rdfs:comment 'End of the scheduled delivery time window, used for precise delivery appointment tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window Start' ;
    rdfs:comment 'Start of the scheduled delivery time window, used for precise delivery appointment tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or storage path to the digital signature image file captured via electronic Proof of Delivery (ePOD) device.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Sequential stop number on the delivery route, used for route optimization and last-mile logistics tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureAtDeliveryCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Delivery Celsius' ;
    rdfs:comment 'Recorded temperature of the delivery at the time of receipt, critical for cold chain compliance and food safety verification for refrigerated and frozen products.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion (deviation from acceptable range) occurred during transit or at delivery, requiring quality review.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Id' ;
    rdfs:comment 'Unique identifier for the returns receipt record. Primary key.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalOrderId rdf:type rdf:Property ;
    rdfs:label 'Original Order Id' ;
    rdfs:comment 'Identifier of the original customer order that included this product. Used for order-to-cash reconciliation.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:originalShipmentId rdf:type rdf:Property ;
    rdfs:label 'Original Shipment Id' ;
    rdfs:comment 'Identifier of the original outbound shipment from which this product is being returned. Used for root cause analysis and OTIF tracking.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:primaryReturnsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Returns Employee Id' ;
    rdfs:comment 'Identifier of the quality inspector who evaluated the returned product.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether the returned product maintained proper temperature control during transit and storage. False indicates potential quality compromise.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'The physical and quality condition of the returned product upon receipt. Determines disposition path.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoReference rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Reference' ;
    rdfs:comment 'Reference number of the credit memo issued to the customer for this return. Links to accounts receivable and financial reconciliation.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'The final decision on how the returned product will be handled. Drives inventory adjustment and financial accounting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'The date and time when the disposition decision was executed (restocked, destroyed, donated, etc.).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'The date and time when quality inspection was completed for the returned product.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Identifier of the pallet on which the returned product was received. Used for warehouse location tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the returned product requires quality inspection before disposition decision is finalized.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'The quantity of product returned, expressed in the unit of measure specified.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this return is part of a product recall event. Triggers special handling and regulatory reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official recall event identifier if this return is associated with a product recall. Used for regulatory reporting and traceability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The date and time when the returned product was physically received at the distribution center. Critical for FEFO compliance and shelf life tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'The externally-known authorization number issued to approve the return. Used for tracking and reconciliation with customer service and sales systems.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Return Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional context on the reason for the return. Captured from customer service or driver input.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnSourceType rdf:type rdf:Property ;
    rdfs:label 'Return Source Type' ;
    rdfs:comment 'The type of originating source from which the product was returned.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the reason for the return. Drives disposition logic and financial treatment.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Return Value Amount' ;
    rdfs:comment 'The monetary value of the returned product, used for credit calculation and financial reporting.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the returns receipt record. Tracks progression from receipt through final disposition.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintId rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_footprint. Business justification: Required for logistics GHG reporting per shipment (Scope 3 emissions) used in ESG disclosures and carbon accounting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonFootprint .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed to assign internal drivers to shipments for safety incident tracking and driver performance dashboards.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.plant. Business justification: Logistics planning requires knowing the originating plant for each shipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:retailerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retailer Agreement Id' ;
    rdfs:comment 'Foreign key linking to trade.retailer_agreement. Business justification: Compliance reporting requires each shipment to be linked to the retailer agreement governing delivery windows, fees, and penalties.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailerAgreement .

ind:actualDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Datetime' ;
    rdfs:comment 'Actual date and time when the shipment was delivered to the destination location, used for OTIF and SLA compliance tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Datetime' ;
    rdfs:comment 'Actual date and time when the carrier picked up the shipment from the origin DC, used for OTIF performance tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Datetime' ;
    rdfs:comment 'Date and time when the ASN was transmitted to the customer, used for EDI compliance and customer notification tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnSentFlag rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Flag' ;
    rdfs:comment 'Indicates whether an EDI 856 Advanced Shipping Notice has been transmitted to the customer or receiving facility.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Total number of cases or cartons included in the shipment across all pallets.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Code indicating any delivery exception or issue encountered during shipment (e.g., damaged product, refused delivery, address error, weather delay).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Notes' ;
    rdfs:comment 'Free-text notes describing any delivery exceptions, issues, or special circumstances encountered during shipment execution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Flag' ;
    rdfs:comment 'Indicates whether this shipment is part of a DSD route where products are delivered directly to retail stores, bypassing retailer DCs.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight cost charged by the carrier for this shipment, used for freight spend analysis and accrual.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight cost amount.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingSequence rdf:type rdf:Property ;
    rdfs:label 'Loading Sequence' ;
    rdfs:comment 'Instructions or sequence identifier for how pallets should be loaded into the trailer to optimize delivery route and unloading efficiency.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for the shipment to maintain product quality and safety during transit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for the shipment to maintain product quality and safety during transit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment met OTIF performance criteria (delivered on time and with complete order quantity), a key supply chain KPI.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets or handling units included in the shipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'Name of the person who signed for the delivery at the destination location, captured as part of proof of delivery.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time when the proof of delivery was captured, typically matching or closely following the actual delivery datetime.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proofOfDeliveryReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received Flag' ;
    rdfs:comment 'Indicates whether proof of delivery documentation (signature, photo, or electronic confirmation) has been received from the carrier or customer.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Datetime' ;
    rdfs:comment 'Planned date and time when the shipment is scheduled to arrive at the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledPickupDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Datetime' ;
    rdfs:comment 'Planned date and time when the carrier is scheduled to pick up the shipment from the origin DC.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the trailer or container to ensure tamper-evidence and cargo integrity during transit.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known business identifier for the shipment, used for tracking and communication with carriers and customers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the outbound logistics workflow.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequence rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence' ;
    rdfs:comment 'The sequence number of this delivery stop within the overall route, used for route planning and driver instructions.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Temperature control requirement for the shipment to maintain cold chain compliance and product quality (ambient, refrigerated, frozen, or controlled).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZoneSegregationFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Segregation Flag' ;
    rdfs:comment 'Indicates whether the shipment contains products requiring segregation into multiple temperature zones within the same trailer.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyLogisticsFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Flag' ;
    rdfs:comment 'Indicates whether this shipment was fulfilled by a third-party logistics provider rather than a company-owned distribution center.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cube M3' ;
    rdfs:comment 'Total volumetric cube of the shipment in cubic meters, used for load planning and carrier billing.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including product, packaging, and pallets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'The trailer, container, or vehicle identification number assigned to this shipment for physical transport.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of trailer or container capacity utilized by this shipment, calculated based on weight or cube constraints.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentStopId rdf:type rdf:Property ;
    rdfs:label 'Shipment Stop Id' ;
    rdfs:comment 'Unique identifier for the shipment stop record. Primary key.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Each inbound shipment stop occurs at a supplier site; linking enables logistics planning and carrier-supplier coordination.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the vehicle arrived at the stop location. Captured via driver mobile app, GPS telematics, or manual entry. Used for OTIF calculation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Cases Delivered' ;
    rdfs:comment 'Number of cases actually delivered and accepted at this stop. Used for fill rate and OTIF measurement.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time the vehicle departed from the stop location after completing delivery or pickup. Used for dwell time and route efficiency analysis.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Actual Volume M3' ;
    rdfs:comment 'Actual volume in cubic meters of goods delivered or picked up at this stop. May differ from planned due to refusals or adjustments.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual weight in kilograms of goods delivered or picked up at this stop. May differ from planned due to refusals or adjustments.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesPickedUp rdf:type rdf:Property ;
    rdfs:label 'Cases Picked Up' ;
    rdfs:comment 'Number of cases picked up from the customer location (e.g., returns, empties, reverse logistics). Applicable when stop_type is pickup or return.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions for the driver at this stop (e.g., use rear entrance, call upon arrival, leave at loading dock). Provided by customer or route planner.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Total time in minutes spent at the stop location, calculated as the difference between actual_arrival_timestamp and actual_departure_timestamp. Used for route efficiency and driver productivity analysis.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureNotes rdf:type rdf:Property ;
    rdfs:label 'Failure Notes' ;
    rdfs:comment 'Free-text notes explaining the failure reason in detail. Captured by driver or dispatcher when a stop cannot be completed.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating why the stop failed if stop_status is failed. Used for root cause analysis and service improvement. [ENUM-REF-CANDIDATE: customer_closed|access_denied|address_incorrect|product_refused|vehicle_breakdown|weather|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Planned Cases Delivered' ;
    rdfs:comment 'Number of cases scheduled for delivery at this stop according to the route plan. Used for load planning and fill rate calculation.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Planned Volume M3' ;
    rdfs:comment 'Total planned volume in cubic meters of goods to be delivered or picked up at this stop. Used for vehicle capacity planning and cube utilization.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Weight Kg' ;
    rdfs:comment 'Total planned weight in kilograms of goods to be delivered or picked up at this stop. Used for vehicle load planning and compliance with weight regulations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podPhotoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Photo Captured Flag' ;
    rdfs:comment 'Indicates whether a photo proof of delivery was captured at this stop (True = photo taken, False = no photo). Used for contactless delivery verification.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a proof of delivery signature was captured at this stop (True = signature obtained, False = no signature). Required for delivery confirmation and dispute resolution.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for arrival at the stop location. Used for customer communication and route planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledArrivalTimeEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time End' ;
    rdfs:comment 'End of the scheduled arrival time window. Defines the latest acceptable arrival time for on-time performance measurement.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledArrivalTimeStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time Start' ;
    rdfs:comment 'Beginning of the scheduled arrival time window. Used for customer appointment scheduling and OTIF (On Time In Full) measurement.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Number' ;
    rdfs:comment 'Business identifier for the stop, typically a sequential or formatted code used in route planning and driver manifests.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current lifecycle status of the stop: scheduled (planned but not started), in_transit (en route), arrived (vehicle at location), completed (delivery/pickup finished), failed (unable to complete), cancelled (stop removed from route).' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the stop activity: delivery (outbound to customer), pickup (inbound from supplier or return), cross-dock (transfer between vehicles), return (product return), or inspection (quality check point).' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtDeliveryC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Delivery C' ;
    rdfs:comment 'Product temperature in Celsius recorded at the time of delivery. Captured via temperature monitoring device or manual thermometer reading. Required for cold chain compliance.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether the delivery maintained required cold chain temperature throughout the stop (True = compliant, False = excursion detected). Critical for food safety and FSMA compliance.' ;
    rdfs:domain ind:ShipmentStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wmsTransactionId rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Id' ;
    rdfs:comment 'Unique identifier for the WMS transaction record. Primary key for all warehouse movement events within distribution centers.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonId rdf:type rdf:Property ;
    rdfs:label 'Carton Id' ;
    rdfs:comment 'Carton or case identifier for case-level tracking. Used for serialized shipment tracking and ASN generation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carton .

ind:experimentalFormulaId rdf:type rdf:Property ;
    rdfs:label 'Experimental Formula Id' ;
    rdfs:comment 'Foreign key linking to research.experimental_formula. Business justification: Enables inventory traceability of experimental formula batches during pilot manufacturing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalFormula .

ind:lifecycleAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Assessment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.lifecycle_assessment. Business justification: Links warehouse transactions to product LCA data to calculate real-time carbon intensity per move.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LifecycleAssessment .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Regulatory and audit need: WMS transaction must reference the specific stock position moved to ensure traceability and accurate valuation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:catchWeight rdf:type rdf:Property ;
    rdfs:label 'Catch Weight' ;
    rdfs:comment 'Actual weight for variable-weight products (meat, produce, cheese). Used when product weight varies from standard case weight.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dockDoor rdf:type rdf:Property ;
    rdfs:label 'Dock Door' ;
    rdfs:comment 'Dock door number for receipt and loading transactions. Used for yard management and carrier coordination.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Compliance Flag' ;
    rdfs:comment 'Indicates whether this pick transaction followed FEFO logic (picking the lot with the nearest expiration date first). Critical for food safety and waste reduction.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fromLocation rdf:type rdf:Property ;
    rdfs:label 'From Location' ;
    rdfs:comment 'Source warehouse location for the transaction. Format typically zone-aisle-bay-level (e.g., A-12-05-C). Null for receipt transactions.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase order number for receipt transactions. Links warehouse receipts to procurement orders.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of product moved in this transaction. Positive for receipts and putaways, negative for picks and adjustments out.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Reason code for adjustment and transfer transactions: damage (product damage), expiration (expired product), quality_hold (QA hold), customer_return (returned goods), overage (excess inventory), shortage (missing inventory), cycle_count_variance (count discrepancy), system_correction (ERP sync adjustment). [ENUM-REF-CANDIDATE: damage|expiration|quality_hold|customer_return|overage|shortage|cycle_count_variance|system_correction — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Original transaction identifier from the source WMS system. Used for audit trail and reconciliation with operational WMS.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'Warehouse zone classification for the transaction location: reserve (long-term storage), pick_face (active picking area), bulk (pallet storage), cross_dock (direct transfer), quarantine (quality hold), staging (outbound prep), returns (customer returns), damaged (defective goods). [ENUM-REF-CANDIDATE: reserve|pick_face|bulk|cross_dock|quarantine|staging|returns|damaged — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toLocation rdf:type rdf:Property ;
    rdfs:label 'To Location' ;
    rdfs:comment 'Destination warehouse location for the transaction. Format typically zone-aisle-bay-level (e.g., B-08-12-A). Null for pick and loading transactions.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Wave or batch identifier for grouped order fulfillment. Links pick transactions to wave planning and release events. Null for non-pick transactions.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Wms Source System' ;
    rdfs:comment 'Source WMS system identifier (e.g., Manhattan, Blue Yonder, SAP EWM, HighJump). Used for multi-WMS environments and data lineage.' ;
    rdfs:domain ind:WmsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardManagementId rdf:type rdf:Property ;
    rdfs:label 'Yard Management Id' ;
    rdfs:comment 'System-generated unique identifier for each yard management event record.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentReference rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference' ;
    rdfs:comment 'External appointment or booking number tied to the trailer\'s scheduled yard time.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detention End Timestamp' ;
    rdfs:comment 'Date-time when detention ended; null if still detained.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detentionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detention Start Timestamp' ;
    rdfs:comment 'Date-time when detention or demurrage clock started for the trailer.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dockDoorAssigned rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assigned' ;
    rdfs:comment 'Identifier of the dock door where the trailer is staged or loaded.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full name of the driver associated with the yard event.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-assigned sequential identifier for the yard event, used for tracking and reference.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the yard event record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of yard activity captured (e.g., trailer check-in, dock assignment, internal yard move, or check-out).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDetained rdf:type rdf:Property ;
    rdfs:label 'Is Detained' ;
    rdfs:comment 'True if the trailer is currently under detention or demurrage.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Load Weight Kg' ;
    rdfs:comment 'Weight of the cargo loaded onto the trailer, measured in kilograms.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether the trailer/event is marked as high priority for processing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Recorded ambient temperature of the trailer or yard spot at event time.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'True if the trailer requires temperature control (refrigerated or frozen).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trailerStatus rdf:type rdf:Property ;
    rdfs:label 'Trailer Status' ;
    rdfs:comment 'Current operational status of the trailer within the yard.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Unload Weight Kg' ;
    rdfs:comment 'Weight of the cargo removed from the trailer, measured in kilograms.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardMoveDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Yard Move Distance Meters' ;
    rdfs:comment 'Distance the trailer was moved within the yard, measured in meters.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardSpotLocation rdf:type rdf:Property ;
    rdfs:label 'Yard Spot Location' ;
    rdfs:comment 'Alphanumeric code of the specific yard spot or parking location assigned to the trailer.' ;
    rdfs:domain ind:YardManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the accounts payable invoice record in the Silver Layer lakehouse. Primary key for this entity. Entity role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: ap_invoice belongs to a legal entity; replace string code with FK to company_code' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt document confirming physical receipt of goods or services, used in three-way match (PO, GR, invoice) verification. Enables FIFO/FEFO inventory costing alignment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'The identifier of the SAP automatic payment program run (F110) that processed this invoice payment. Used for batch payment reconciliation, bank file tracing, and payment run audit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'The reason code explaining why an invoice has been placed on payment hold (e.g., price variance, quantity variance, quality hold, missing GR, duplicate invoice). Used for dispute management and supplier performance tracking. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|quality_hold|missing_gr|duplicate|missing_po|terms_dispute — promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the invoice was cleared in the AP subledger, confirming full settlement. Used for DPO calculation, working capital reporting, and financial close reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Indicates whether the invoice has been fully cleared (paid and matched), partially cleared, or remains open in the AP subledger. \'reversed\' indicates a posting reversal. Used for AP aging analysis and period-end close.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCaptured rdf:type rdf:Property ;
    rdfs:label 'Discount Captured' ;
    rdfs:comment 'Indicates whether the early payment discount was successfully captured at time of payment. Used to measure discount capture rate KPI and evaluate treasury performance against working capital targets.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The deadline by which payment must be made to capture the early payment discount offered by the vendor (e.g., 2% if paid within 10 days). Used for dynamic discounting and working capital optimization programs.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Calculated from invoice_date and payment_terms_code. Critical for cash flow forecasting and working capital management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Reference' ;
    rdfs:comment 'The EDI transaction identifier for invoices received electronically via EDI 810 (Invoice) transaction set. Used for automated invoice matching, EDI reconciliation, and supplier EDI compliance tracking in F&B procurement.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date the invoice was entered into the SAP system (BKPF.CPUDT). Used for invoice processing cycle time analysis and SLA compliance tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert the invoice currency to the local company code currency at the time of posting. Used for FX variance analysis and treasury reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal posting period (01–12 for regular periods, 13–16 for special periods) within the fiscal year. Used for monthly financial close, accrual management, and period-over-period variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this invoice posting belongs (SAP BKPF.GJAHR). Used for period-end financial close, EBITDA reporting, and budget variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this invoice is posted for financial reporting (e.g., COGS raw materials, packaging expense, logistics cost). Enables P&L line item analysis and EBITDA reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the invoice before tax deductions and discounts, as stated on the vendor invoice. Part of the MONETARY_TRIPLET required for TRANSACTION_HEADER role. Used for COGS accruals, cash flow forecasting, and working capital analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReferenceText rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Text' ;
    rdfs:comment 'Free-text reference or description field from the vendor invoice or AP clerk entry (SAP BKPF.BKTXT). May contain delivery note numbers, contract references, or service period descriptions. Used for invoice search and dispute resolution.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the AP invoice through the payables workflow. Satisfies LIFECYCLE_STATUS category for TRANSACTION_HEADER role. \'blocked\' indicates a hold pending resolution (price, quantity, or quality discrepancy).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. \'credit_memo\' represents vendor credits for returns or adjustments. \'intercompany\' covers transactions between legal entities within the Food Beverage group. Drives accounting treatment and workflow routing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this invoice represents a transaction between two legal entities within the Food Beverage corporate group. Intercompany invoices require elimination in consolidated financial statements per IFRS IAS 27.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this invoice is part of a recurring payment schedule (e.g., monthly 3PL service fees, lease payments, SaaS subscriptions). Used for automated accrual management and cash flow forecasting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The net invoice amount translated to the company code local currency (e.g., USD for US entities) using the exchange rate at posting date. Used for consolidated financial reporting and EBITDA calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Indicates the result of the three-way match process comparing the purchase order, goods receipt, and vendor invoice. \'three_way_matched\' confirms all three documents align within tolerance. Critical for invoice approval and COGS accuracy.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net payable amount after tax and discount adjustments (gross_amount minus discounts plus tax_amount). Part of the MONETARY_TRIPLET. Represents the actual cash obligation to the vendor for payment execution.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The SAP FI accounting document number generated when the payment was executed (clearing document). Links the invoice to its payment for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument used to settle this invoice (ACH electronic transfer, wire transfer, check, virtual card, or direct debit). Drives payment run configuration and bank reconciliation processes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The SAP payment terms key (e.g., NT30, 2/10NET30) defining the due date calculation and early payment discount conditions. Drives cash flow forecasting, working capital optimization, and early-payment discount capture strategy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The SAP plant code identifying the manufacturing facility, distribution center, or warehouse that received the goods or services invoiced. Used for plant-level COGS analysis and supply chain cost allocation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the invoice was posted to the general ledger in SAP FI (BKPF.BUDAT). Determines the accounting period for financial close and COGS accrual recognition.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'Business spend category classifying the nature of the goods or services invoiced. Enables COGS vs. SG&A allocation, category spend analytics, and supplier segmentation. [ENUM-REF-CANDIDATE: raw_material|packaging|co_packing|3pl_logistics|indirect_services|capex|toll_manufacturing|marketing|utilities|maintenance — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI accounting document number assigned upon invoice posting (BKPF.BELNR). Used for cross-referencing with general ledger entries and financial close processes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The total tax amount (VAT, GST, sales tax) applied to this invoice. Part of the MONETARY_TRIPLET. Used for tax reporting, input tax recovery, and compliance with FDA/USDA indirect cost regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBankAccount rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'The vendor\'s bank account identifier used for payment execution (masked/tokenized for security). Required for ACH and wire payment processing. Classified as confidential financial data per PCI DSS and internal treasury controls.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number as printed on the vendor\'s invoice document. Used for vendor reconciliation, dispute resolution, and audit trail. Satisfies BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the accounts receivable invoice record in the Silver layer lakehouse. Primary key. Entity role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:billingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Company Code' ;
    rdfs:comment 'SAP company code of the legal entity issuing the invoice. Required for intercompany reconciliation, statutory reporting, and multi-entity financial consolidation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Externally-known SAP SD billing document number (VBELN) that uniquely identifies this invoice in the source system and on customer-facing documents. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Commercial channel through which the sale was made. Enables channel-level revenue reporting, trade spend analysis, and margin management across retail, foodservice, DTC, and e-commerce.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number (AUGBL) assigned when the invoice is fully or partially cleared against a payment or credit memo. Null for open items.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Dollar value of customer-taken deductions against this invoice (e.g., promotional allowances, freight claims, shortage claims). Central to F&B deduction management and trade spend reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Code' ;
    rdfs:comment 'Standardized code classifying the reason for a customer deduction (e.g., promotional allowance, freight claim, shortage, pricing dispute). Enables deduction analytics and recovery tracking. [ENUM-REF-CANDIDATE: promo_allowance|freight_claim|shortage|pricing_dispute|quality_claim|early_pay_discount|other — promote to reference product]' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text or coded description of the reason the customer has disputed this invoice (e.g., pricing discrepancy, quantity shortage, quality issue). Supports root cause analysis and deduction recovery.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any customer dispute raised against this invoice. Enables dispute management workflow tracking and deduction resolution reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP distribution channel code (VTWEG) indicating the route-to-market for this invoice (e.g., wholesale, DSD, e-commerce). Supports channel profitability and trade spend analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice sent to the customer for this invoice. Used to schedule next dunning action and track collections activity.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections escalation) level assigned to this invoice in SAP FI-AR, ranging from 0 (no dunning) to the maximum configured level. Drives collections workflow and customer communication.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Amount' ;
    rdfs:comment 'Monetary value of the cash discount available to the customer if payment is received by the early payment discount date. Used for discount accrual and deduction validation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Date' ;
    rdfs:comment 'Last date by which the customer may pay to qualify for the early payment (cash) discount defined in the payment terms (e.g., the \'10\' in 2/10NET30). Supports cash discount accrual and working capital optimization.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Status' ;
    rdfs:comment 'Transmission status of the invoice via EDI (Electronic Data Interchange) or customer portal. Tracks whether the invoice was successfully delivered electronically to the customer, supporting straight-through processing and dispute prevention.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'Identifier of the bank lockbox processing batch in which this invoice\'s payment was received. Enables reconciliation between bank lockbox files and SAP FI-AR cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice after applying all payments, credits, and deductions. Drives DSO calculation, aging bucket reporting, and dunning level determination.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount of cash received and applied to this invoice. May differ from net_amount due to short payments, deductions, or partial payments.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Document Number' ;
    rdfs:comment 'Customer-provided remittance advice document number accompanying the payment, used to match incoming cash to open invoices during cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in the general ledger per FASB ASC 606 / IFRS 15 five-step model. May differ from invoice_date for consignment, bill-and-hold, or multi-element arrangements.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP sales organization (VKORG) responsible for the sale, defining the selling entity, pricing procedures, and revenue assignment for this invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Short Payment Amount' ;
    rdfs:comment 'Amount by which the customer\'s remittance falls short of the invoiced net amount, excluding valid deductions. Triggers deduction investigation and collections follow-up.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Contractual trade discount applied to the gross invoice amount, reflecting negotiated off-invoice allowances, promotional pricing, or volume rebates. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'System-generated unique identifier for the bank account record.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashPoolId rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Id' ;
    rdfs:comment 'Identifier of the cash pool to which the account belongs, if applicable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashPool .

ind:legalEntityCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Company Code Id' ;
    rdfs:comment 'Reference to the legal entity (company code) that owns the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:balanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Timestamp' ;
    rdfs:comment 'Timestamp when the daily balance was recorded.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Account Status' ;
    rdfs:comment 'Current lifecycle state of the bank account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Address' ;
    rdfs:comment 'Physical address of the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Name or code of the specific branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountry rdf:type rdf:Property ;
    rdfs:label 'Bank Country' ;
    rdfs:comment 'Three-letter ISO country code where the bank is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal code of the bank branch address.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankState rdf:type rdf:Property ;
    rdfs:label 'Bank State' ;
    rdfs:comment 'State or province of the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date the bank account was closed or scheduled for closure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dailyBalance rdf:type rdf:Property ;
    rdfs:label 'Daily Balance' ;
    rdfs:comment 'End-of-day cash balance for the account, used for cash positioning.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'Standardized international account identifier for cross-border transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'True if the account is part of a consolidated cash pool.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciledDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Date' ;
    rdfs:comment 'Date of the most recent successful bank reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date the bank account was opened.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationGlAccount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Gl Account' ;
    rdfs:comment 'General Ledger account used for bank reconciliation postings.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBic rdf:type rdf:Property ;
    rdfs:label 'Swift Bic' ;
    rdfs:comment 'Bank Identifier Code used for international wire transfers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treasuryCenter rdf:type rdf:Property ;
    rdfs:label 'Treasury Center' ;
    rdfs:comment 'Organizational unit responsible for the account within treasury.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key for the budget data product.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'User ID or employee ID of the budget owner responsible for managing and monitoring this budget line. Typically the cost center manager or department head.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryFinanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Finance Employee Id' ;
    rdfs:comment 'User ID or employee ID of the person who approved the budget. Null if not yet approved.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_target. Business justification: Annual budgeting allocates funds to each sustainability target; the FK enables traceability of spend.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Target .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The planned budget amount for the specified fiscal period, cost center, and GL account. Represents the financial target or allocation in the budget currency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the budget was approved by the authorized approver. Null if not yet approved.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval status of the budget record. DRAFT = In preparation, SUBMITTED = Awaiting approval, APPROVED = Approved for use, REJECTED = Not approved, LOCKED = Finalized and locked for the period.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Categorization of the budget planning approach. ANNUAL = Annual fixed budget, ROLLING = Rolling forecast budget, SUPPLEMENTAL = Additional budget allocation, CONTINGENCY = Reserve or contingency budget.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by financial category. OPEX = Operating Expenses, CAPEX = Capital Expenditures, REVENUE = Revenue Budget, HEADCOUNT = Workforce Budget, COGS = Cost of Goods Sold, TRADE_SPEND = Trade Promotion and Marketing Spend.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area code for cross-company code reporting. Represents a business segment that may span multiple legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'Four-character code representing the controlling area for cost accounting and management reporting. Aligns with SAP CO controlling area structure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area code for classifying budget by business function (e.g., Manufacturing, Sales, R&D, Marketing, Supply Chain).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Geographic region code for regional budget planning (e.g., NORAM, EMEA, APAC, LATAM). Enables regional financial target setting and variance analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCarryForward rdf:type rdf:Property ;
    rdfs:label 'Is Carry Forward' ;
    rdfs:comment 'Boolean flag indicating whether this budget line represents a carry-forward from a previous fiscal period. True = Carry-forward budget, False = New budget allocation.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Boolean flag indicating whether the budget record is locked for editing. True = Locked (no further changes allowed), False = Unlocked (editable). Used to freeze budgets after approval or period close.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'Product category or product line code for product-specific budget allocation (e.g., Snacks, Beverages, Dairy). Used for category-level financial planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the budget quantity (e.g., FTE for headcount, MT for metric tons, EA for each). Provides context for the budget_quantity field.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source Record Key' ;
    rdfs:comment 'Primary key or unique identifier of the budget record in the source system. Used for traceability and reconciliation back to the source system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Code identifying the version of the budget (e.g., ORIGINAL, REVISED, LE1, LE2, FORECAST). Enables tracking of budget iterations and revisions throughout the fiscal year.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Descriptive name for the budget version (e.g., Original Budget, Q2 Revised Budget, Latest Estimate). Provides human-readable context for the version code.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The primary accounting standard under which this company code prepares its statutory financial statements. Determines recognition, measurement, and disclosure rules for revenue, inventory (COGS/FIFO), fixed assets, and trade spend accruals. Drives parallel ledger configuration in SAP.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCity rdf:type rdf:Property ;
    rdfs:label 'Address City' ;
    rdfs:comment 'City of the registered office of the legal entity. Used in statutory filings, regulatory submissions, and legal correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered office of the legal entity. Used for tax jurisdiction determination, regulatory filings, and statutory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressRegion rdf:type rdf:Property ;
    rdfs:label 'Address Region' ;
    rdfs:comment 'State, province, or region of the registered office. Used for sub-national tax jurisdiction determination, state-level regulatory compliance (e.g., California Prop 65 for food labeling), and regional statutory reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStreet rdf:type rdf:Property ;
    rdfs:label 'Address Street' ;
    rdfs:comment 'Street address of the registered office of the legal entity as recorded in the official company registry. Used for statutory correspondence, regulatory filings with FDA/USDA/EFSA, and legal notices. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code representing the operational division or segment within the Food Beverage group (e.g., North America Snacks, EMEA Beverages, APAC Dairy). Used for segment-level financial reporting, cross-company-code balance sheet preparation, and divisional P&L analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The SAP chart of accounts key assigned to this company code, defining the general ledger account structure used for financial postings. Governs the GL account hierarchy, COGS account assignments, revenue accounts, and trade spend accrual accounts. Maps to SAP KTOPL field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'The four-character alphanumeric SAP FI company code that uniquely identifies the legal entity within the ERP system. This is the externally-known business identifier used across all SAP modules (FI, CO, MM, SD, PP) and in intercompany transactions, statutory reporting, and financial consolidation. Maps directly to the BUKRS field in SAP.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code within the Food Beverage group. Controls whether the entity is available for posting, planning, and reporting. Inactive or dormant entities are excluded from operational processes but retained for historical audit and statutory purposes.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Company Registration Number' ;
    rdfs:comment 'Official company registration number issued by the national company registry (e.g., Companies House in the UK, SEC in the US, Handelsregister in Germany). Used for statutory filings, regulatory submissions, and legal entity verification in trade agreements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation group or reporting unit to which this company code belongs within the Food Beverage group financial consolidation structure. Used in SAP Group Reporting or BPC to aggregate financial results for segment reporting, EBITDA roll-ups, and statutory consolidated accounts.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationIndicator rdf:type rdf:Property ;
    rdfs:label 'Consolidation Indicator' ;
    rdfs:comment 'Flag indicating whether this company code is included in the Food Beverage group consolidated financial statements. Entities with this flag set to false (e.g., dormant shells, entities below materiality threshold) are excluded from group EBITDA reporting and multi-entity consolidation runs.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP Controlling (CO) area to which this company code is assigned. The controlling area defines the organizational unit for management accounting, cost center accounting, profit center accounting, COGS variance analysis, and standard costing. A single controlling area may span multiple company codes for cross-entity cost allocation. Maps to SAP KOKRS field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area assigned to this company code, governing customer credit limit management, accounts receivable exposure monitoring, and credit risk controls for trade customers. Relevant for revenue management and trade spend credit exposure. Maps to SAP KKBER field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which the company code was deactivated or blocked for new postings in SAP FI. Null for currently active entities. Used to manage the lifecycle of dormant, liquidated, or divested entities within the Food Beverage group and to control consolidation scope.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity within the Food Beverage corporate group structure. Drives consolidation treatment, intercompany elimination rules, and statutory reporting obligations. [ENUM-REF-CANDIDATE: subsidiary|joint_venture|holding|branch|associate|operating_entity — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemInstance rdf:type rdf:Property ;
    rdfs:label 'Erp System Instance' ;
    rdfs:comment 'Identifier of the SAP S/4HANA or Oracle Cloud ERP system instance from which this company code record is sourced. Relevant for Food Beverage entities that operate across multiple ERP landscapes (e.g., post-acquisition entities not yet migrated to the central SAP instance). Supports data lineage and source system traceability.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal calendar structure for this company code — including whether the fiscal year is calendar-year aligned or offset (e.g., April–March, October–September), and the number of posting periods. Critical for period-end close, budgeting cycles, and demand planning alignment. Maps to SAP PERIV field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Food Safety License Number' ;
    rdfs:comment 'Regulatory license or registration number issued by the applicable food safety authority (e.g., FDA Food Facility Registration Number, USDA Establishment Number, EFSA authorization number) for this legal entity. Required for manufacturing, importing, or distributing food and beverage products. Critical for FSMA compliance and GFSI certification tracking.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyIndicator rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Indicator' ;
    rdfs:comment 'Flag indicating whether the local currency of this company code is also its functional currency as defined under IFRS IAS 21. When false, a separate functional currency determination is required, impacting foreign currency translation adjustments in the consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the Food Beverage group reporting currency used in consolidated financial statements, EBITDA reporting, and multi-entity consolidation. Typically USD or EUR for global food and beverage groups. Enables currency translation for intercompany eliminations.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gstApplicable rdf:type rdf:Property ;
    rdfs:label 'Gst Applicable' ;
    rdfs:comment 'Flag indicating whether Goods and Services Tax (GST) or equivalent consumption tax applies to transactions of this company code. Relevant for entities operating in GST jurisdictions (e.g., Australia, Canada, India, Singapore). Drives tax code determination in SAP SD and MM for food and beverage product sales.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was formally incorporated and registered with the relevant national company registry. Used for entity age calculations, statutory anniversary filings, and historical financial consolidation scope determination.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this company code participates in intercompany transactions within the Food Beverage group. When true, the entity is subject to intercompany elimination rules during group consolidation, transfer pricing policies, and intercompany billing processes. Maps to SAP intercompany configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageKey rdf:type rdf:Property ;
    rdfs:label 'Language Key' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the primary language used for correspondence, statutory documents, and regulatory filings for this company code. Drives language-specific output for invoices, financial statements, and FDA/EFSA regulatory submissions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'SAP ledger group assigned to this company code, enabling parallel accounting under multiple accounting standards (e.g., IFRS and local GAAP simultaneously). Supports multi-GAAP reporting requirements for Food Beverage entities operating across jurisdictions with different statutory requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full registered legal name of the incorporated entity as it appears in the official company registry of the country of incorporation. Used for statutory reporting, regulatory filings, intercompany agreements, and financial consolidation disclosures.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code' ;
    rdfs:comment 'The SAP company code of the immediate parent entity within the Food Beverage group legal entity hierarchy. Enables traversal of the corporate ownership structure for intercompany elimination, transfer pricing, and group consolidation. Self-referencing for the ultimate holding entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'SAP posting period variant that controls which fiscal periods are open or closed for financial postings in this company code. Governs the financial close process, period-end accruals, and trade spend accrual postings. Maps to SAP XVPER field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandard rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard' ;
    rdfs:comment 'Default SAP profit center assigned to this company code for management accounting purposes. Profit centers align to business units (e.g., Snacks, Beverages, Dairy) and are used for internal P&L reporting, EBITDA analysis by segment, and revenue management reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the company code master record was first created in the source ERP system (SAP FI or Oracle Cloud ERP). Represents the business creation event, not the lakehouse ingestion time. Used for audit trail, data lineage, and entity lifecycle tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the company code master record in the source ERP system. Used for change data capture (CDC), incremental lakehouse loads, and audit trail compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or trading name of the legal entity used in internal reporting, dashboards, and operational communications where the full legal name is impractical. Corresponds to the SAP company code short description field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code identifying the specific federal, state/province, and local tax authority applicable to this company code. Used for automated tax calculation on sales orders, purchase orders, and intercompany transactions. Drives compliance with FDA, USDA, and local food safety levy requirements. Maps to SAP TXJCD field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) or equivalent national tax identification number assigned to the legal entity by the relevant tax authority. Used for statutory tax filings, payroll tax reporting, and regulatory submissions to FDA and USDA.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD-approved transfer pricing method applied to intercompany transactions involving this company code. Governs how intercompany prices are set for goods (e.g., finished snacks, beverages transferred between manufacturing and distribution entities) and services. Critical for tax compliance and EBITDA integrity across the group. [ENUM-REF-CANDIDATE: CUP|resale_price|cost_plus|TNMM|profit_split|not_applicable — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) registration number issued by the tax authority of the country of incorporation. Required for EU VAT compliance, cross-border trade invoicing, and regulatory reporting to EFSA and national tax authorities. Used in intercompany billing and trade documentation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Establishment Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.establishment_registration. Business justification: Cost centers are assigned to specific production facilities; linking to establishment registration enables facility-level cost tracking for regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstablishmentRegistration .

ind:packagingProfileId rdf:type rdf:Property ;
    rdfs:label 'Packaging Profile Id' ;
    rdfs:comment 'Foreign key linking to sustainability.packaging_profile. Business justification: Cost centers manage packaging initiatives; the FK ties financial cost allocation to specific packaging profiles.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingProfile .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Employee ID of the manager accountable for costs incurred by this cost center. Used for budget ownership, variance reporting, and approval workflows. Maps to SAP field VERAK (Person Responsible). Sourced from Workday HCM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Primary activity type code associated with this cost center, representing the unit of output used for direct activity allocation (e.g., machine hours, labor hours, production runs). Used in standard costing and variance analysis. Maps to SAP CO activity type (LSTAR).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects (orders, products, other cost centers). Drives COGS calculation accuracy and variance analysis. \'direct_activity\' uses activity types; \'assessment\' and \'distribution\' use cycle-based allocation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Approved annual budget for this cost center in the cost center currency for the current fiscal year. Used as the baseline for budget vs. actual variance reporting and EBITDA forecasting. Sourced from SAP CO budget planning (KPF6).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2025) to which the budget_amount applies. Enables multi-year budget tracking and year-over-year variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changedByUser rdf:type rdf:Property ;
    rdfs:label 'Changed By User' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center master record in SAP CO. Supports change audit trail and Sarbanes-Oxley internal control documentation. Maps to SAP field AENAM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRelevant rdf:type rdf:Property ;
    rdfs:label 'Cogs Relevant' ;
    rdfs:comment 'Indicates whether costs incurred by this cost center are included in COGS calculation (True) or classified as operating expenses (False). Production and quality cost centers are typically COGS-relevant; administrative and marketing cost centers are not.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Functional classification of the cost center indicating its primary business activity. Drives COGS allocation methodology and EBITDA reporting segmentation. Maps to SAP field KOSAR (Cost Center Category). CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code uniquely identifying the cost center within the controlling area, as assigned in SAP CO. Used in journal entries, purchase orders, and COGS allocation. Maps to SAP field KOSTL (Cost Center). BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Long-form description of the cost center\'s business purpose, scope of operations, and organizational context. Provides additional detail beyond the short name for reporting and governance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable short name of the cost center (e.g., \'Chicago Snack Plant\', \'R&D Lab - Beverages\', \'North America Sales Region\'). Maps to SAP field KTEXT. IDENTITY_LABEL category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle state of the cost center record. \'locked\' prevents new postings; \'pending_deletion\' marks records flagged for archival after period close. Maps to SAP deletion flag and lock indicators. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Operational classification distinguishing how costs flow: \'direct\' cost centers incur costs directly attributable to production (e.g., production lines); \'indirect\' and \'overhead\' centers accumulate shared costs for allocation; \'service\' centers provide internal services charged to other cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'SAP cost element group associated with this cost center, defining the set of cost elements (G/L accounts) that can be posted to it. Supports cost reporting by cost element category (material, labor, overhead, depreciation).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP user ID of the person who created this cost center master record in SAP CO. Supports audit trail and change management governance. Maps to SAP field ERNAM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department code to which this cost center belongs (e.g., \'MFG-OPS\', \'FIN-CTRL\', \'MKT-BRAND\'). Supports departmental cost rollup reporting and aligns with HR organizational structure from Workday HCM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region associated with this cost center (e.g., \'North America\', \'Europe\', \'Asia Pacific\'). Supports regional P&L reporting, trade spend analysis, and sales region cost allocation. [ENUM-REF-CANDIDATE: north_america|europe|asia_pacific|latin_america|middle_east_africa|global — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node identifier within the standard cost center hierarchy (SAP standard hierarchy) to which this cost center belongs. Enables hierarchical cost rollup reporting from individual cost centers to plant, region, and enterprise levels. Maps to SAP field KHINR.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Indicates whether this cost center is locked (True) to prevent new actual cost postings, typically applied during period-end close or when a cost center is being restructured. Maps to SAP CO lock indicator (SPERRK).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (True) used only for informational reporting without actual cost postings, or a real cost center (False) that receives actual cost allocations. Maps to SAP CO statistical indicator.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Key' ;
    rdfs:comment 'SAP overhead key assigned to this cost center, determining the overhead surcharge rates applied during product costing. Links to overhead costing sheets used in standard cost estimates for manufactured goods. Maps to SAP field ZUORD.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Code of the profit center to which this cost center is assigned for internal profitability reporting. Enables P&L reporting at the profit center level and supports EBITDA analysis by business segment. Maps to SAP field PRCTR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'Planned cost rate per unit of activity for this cost center, used in standard costing to value production orders and calculate COGS. Expressed in the cost center currency per activity unit. Variances between standard and actual rates are reported in period-end variance analysis. MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center is active and available for cost postings. Supports time-dependent master data management and ensures costs are only allocated to active cost centers. Maps to SAP field DATAB. EFFECTIVE_FROM category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date after which this cost center is no longer active for cost postings. A null or far-future date (e.g., 9999-12-31) indicates an open-ended cost center. Maps to SAP field DATBI. EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'Work Breakdown Structure element code linking this cost center to a specific capital project or R&D initiative in SAP PS (Project System). Relevant for NPD project cost tracking and capital expenditure allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Primary key for fiscal_period' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Posting Status' ;
    rdfs:comment 'Posting authorization status for asset account types (fixed assets, depreciation). Controls whether asset transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Boolean flag indicating whether detailed audit logging is enabled for all transactions posted in this fiscal period for compliance and forensic purposes.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceSheetReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Reconciliation Status' ;
    rdfs:comment 'Status of balance sheet account reconciliation process for this period, ensuring all balance sheet accounts are substantiated and reconciled to sub-ledgers.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Blocked Close Tasks' ;
    rdfs:comment 'Count of close tasks that are currently blocked due to unmet dependencies or issues requiring resolution.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeActualDate rdf:type rdf:Property ;
    rdfs:label 'Close Actual Date' ;
    rdfs:comment 'The actual calendar date when the financial close process was completed and certified.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeCycleName rdf:type rdf:Property ;
    rdfs:label 'Close Cycle Name' ;
    rdfs:comment 'Descriptive name of the financial close cycle for this period (e.g., January 2024 Close, Q1 2024 Close, FY2024 Year-End Close).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDelayDays rdf:type rdf:Property ;
    rdfs:label 'Close Delay Days' ;
    rdfs:comment 'Number of calendar days by which the close process exceeded the target date. Zero or negative if close was on time or early.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeSlaMet rdf:type rdf:Property ;
    rdfs:label 'Close Sla Met' ;
    rdfs:comment 'Boolean indicator of whether the close process met the target SLA (True if actual close date is on or before target date, False otherwise).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeStartDate rdf:type rdf:Property ;
    rdfs:label 'Close Start Date' ;
    rdfs:comment 'The calendar date when the financial close process for this period was initiated.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Overall status of the period-end close process: not_started (close not initiated), in_progress (tasks underway), complete (all tasks finished), certified (final sign-off and SOX attestation complete).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTargetDate rdf:type rdf:Property ;
    rdfs:label 'Close Target Date' ;
    rdfs:comment 'The planned target date by which the financial close process should be completed, per the close calendar and SLA (Service Level Agreement).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Completed Close Tasks' ;
    rdfs:comment 'Count of close tasks that have been marked as complete for this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Status' ;
    rdfs:comment 'Status of cost center and internal order allocation cycles (assessment, distribution, overhead allocation) for this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRunStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Status' ;
    rdfs:comment 'Status of the periodic depreciation calculation and posting run for fixed assets in this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expensePostingStatus rdf:type rdf:Property ;
    rdfs:label 'Expense Posting Status' ;
    rdfs:comment 'Posting authorization status for expense account types (COGS, operating expenses). Controls whether expense transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Status' ;
    rdfs:comment 'Status of financial statement preparation and approval workflow for this period: not_started, draft (in preparation), review (under management review), approved (signed off), published (externally released).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year. Regular periods are 1-12; special adjustment periods are 13-16 for year-end close activities.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Reconciliation Status' ;
    rdfs:comment 'Status of intercompany transaction reconciliation for this period: not_started, in_progress, reconciled (balanced), or variance (unresolved differences requiring investigation).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Liability Posting Status' ;
    rdfs:comment 'Posting authorization status for liability account types (accounts payable, accrued expenses). Controls whether liability transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the fiscal period when transactions can be posted.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the fiscal period when transactions can be posted.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Overall status of the fiscal period controlling whether any posting activity is allowed: not_opened (future period), open (active posting), closed (period-end complete), locked (archived, no changes).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the fiscal period: regular (monthly operating periods 1-12), special (adjustment periods 13-16), year_end (final close period), or opening (initial balance period).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAuthorityOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Posting Authority Override Allowed' ;
    rdfs:comment 'Boolean flag indicating whether authorized users can override posting restrictions for this period (typically False for closed periods to maintain data integrity).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleController rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller' ;
    rdfs:comment 'Name or identifier of the financial controller or accounting manager responsible for overseeing the close process for this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Status' ;
    rdfs:comment 'Posting authorization status for revenue account types (sales revenue, other income). Controls whether revenue transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The calendar date when the sign-off owner provided final certification for this fiscal period close.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffOwner rdf:type rdf:Property ;
    rdfs:label 'Sign Off Owner' ;
    rdfs:comment 'Name or identifier of the executive (CFO, Controller, VP Finance) who provides final certification and sign-off for this fiscal period close.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Status' ;
    rdfs:comment 'Status of SOX internal control certification for this period: not_required (non-SOX entity), pending (awaiting sign-off), certified (controls attested), exception (control deficiency identified).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Total Close Tasks' ;
    rdfs:comment 'Total count of close tasks defined for this fiscal period across all task types and responsible teams.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key for the fixed asset entity. Inferred role: MASTER_RESOURCE.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since the asset was placed in service. Calculated as the sum of all periodic depreciation postings.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date the asset was acquired or placed in service. Used as the starting point for depreciation calculation and useful life tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code that categorizes the asset type (e.g., manufacturing equipment, building, vehicle, IT hardware). Determines depreciation rules, useful life, and GL account assignment in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset, including make, model, capacity, and distinguishing characteristics (e.g., \'High-Speed Bottling Line - Line 3 - 600 BPM\').' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Detailed physical location of the asset within the plant or facility (e.g., \'Production Floor - Line 3 - Bay 12\'). Used for asset tracking, maintenance scheduling, and physical inventory.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique business identifier for the fixed asset, typically assigned by the ERP system (SAP FI-AA asset master number). Used for asset tracking, reporting, and cross-system reference.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Active assets are in service and depreciating; under construction assets are capitalized but not yet depreciating; retired/disposed assets are no longer in use.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical barcode or RFID tag number affixed to the asset for inventory tracking and physical verification during asset audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was capitalized on the balance sheet. May differ from acquisition date for assets under construction (AUC) that are capitalized upon completion.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger account number for accumulated depreciation (contra-asset account, e.g., 1509 - Accumulated Depreciation - Machinery). Used for balance sheet presentation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate periodic depreciation expense. Straight-line is most common for F&B manufacturing assets; units of production may be used for high-utilization equipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date the asset was physically disposed, sold, or scrapped. May differ from retirement date if there is a lag between decommissioning and disposal.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal (proceeds minus net book value).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Expense Gl Account Code' ;
    rdfs:comment 'General ledger account number for depreciation expense postings (e.g., 6800 - Depreciation Expense). Used for income statement reporting and COGS allocation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized on the asset when its recoverable amount falls below net book value. Recorded as a write-down and reduces the carrying value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'Date the impairment loss was recognized. Triggers adjustment to net book value and may affect future depreciation calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date the asset was last physically verified during a fixed asset inventory audit. Used to ensure asset register accuracy and compliance with SOX controls.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the equipment manufacturer or vendor (e.g., \'Tetra Pak\', \'Krones\', \'Siemens\'). Used for vendor management, spare parts sourcing, and warranty claims.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model or part number for the asset. Used for technical specifications, spare parts identification, and maintenance planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset on the balance sheet, calculated as original cost minus accumulated depreciation. Represents the remaining capitalized value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'Initial acquisition or construction cost of the asset at capitalization, including purchase price, freight, installation, and directly attributable costs. Represents the gross book value before depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Number of years remaining in the assets useful life as of the current reporting period. Calculated as useful life minus elapsed time since capitalization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date the asset was retired from service or disposed. Triggers final depreciation calculation and removal from active asset register.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Depreciation is calculated on (original cost - salvage value). Often zero for F&B manufacturing equipment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetKey rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Key' ;
    rdfs:comment 'Composite key from SAP FI-AA (company code + asset number + sub-number) used for exact source system reconciliation and traceability.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected economic useful life of the asset in years, as determined by asset class and business policy. Used to calculate straight-line depreciation rate (1 / useful life).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the vendor or supplier from whom the asset was purchased. Used for vendor performance tracking and warranty claims.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty expires. Used to determine whether repairs are covered under warranty or must be expensed.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Primary key for forecast' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:forecastApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the manager or executive who approved this forecast version. Supports governance and audit trail.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:forecastEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Employee Id' ;
    rdfs:comment 'Employee or user identifier of the person responsible for submitting and maintaining this forecast line. Typically a finance business partner or profit center controller.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Identifier linking this financial forecast to the corresponding S&OP cycle. Ensures alignment between demand planning, supply planning, and financial forecasting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the forecast was formally approved. Marks the transition from draft to official forecast.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'High-level business unit or division code (e.g., Snacks, Beverages, Dairy). Used for executive-level reporting and strategic planning.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentary rdf:type rdf:Property ;
    rdfs:label 'Commentary' ;
    rdfs:comment 'Free-text narrative explaining key assumptions, risks, opportunities, or changes from prior forecast. Provides qualitative context for quantitative projections.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Subjective confidence rating assigned by the forecast owner. Indicates reliability and risk associated with the forecast estimate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverType rdf:type rdf:Property ;
    rdfs:label 'Driver Type' ;
    rdfs:comment 'Primary business driver or assumption category underlying the forecast (e.g., volume growth, pricing action, product mix shift, foreign exchange impact). Enables driver-based planning and variance explanation. [ENUM-REF-CANDIDATE: volume|price|mix|fx|inflation|productivity|investment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The date when this forecast version was created or submitted. Represents the as-of date for the forecast snapshot.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record. Tracks progression from draft through approval to publication.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by planning horizon and frequency. Rolling forecasts are continuously updated; annual/quarterly/monthly are fixed-period; reforecast is a mid-cycle update; flash is a rapid preliminary estimate.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Amount' ;
    rdfs:comment 'The projected financial value for this forecast line in the specified currency. Represents the current best estimate of revenue, cost, or profit for the period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCategory rdf:type rdf:Property ;
    rdfs:label 'Gl Account Category' ;
    rdfs:comment 'High-level financial statement line item category for the forecasted amount. Enables aggregation and variance analysis by P&L component. [ENUM-REF-CANDIDATE: revenue|cogs|gross_profit|operating_expense|ebitda|depreciation|ebit|interest|tax|net_income — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the forecast owner for display and reporting purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Amount' ;
    rdfs:comment 'The forecasted amount from the previous forecast version for the same period and account. Enables trend analysis and revision tracking.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the forecast was published to executive dashboards and investor relations. Indicates availability for external guidance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Planning scenario for the forecast (e.g., base case, upside, downside). Supports scenario planning and risk assessment for investor guidance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Budget Amount' ;
    rdfs:comment 'The difference between the forecasted amount and the budget amount (forecasted_amount - budget_amount). Positive values indicate favorable variance for revenue, unfavorable for costs.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast Amount' ;
    rdfs:comment 'The difference between the current forecast and the prior forecast (forecasted_amount - prior_forecast_amount). Tracks forecast revision magnitude.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_disclosure. Business justification: Specific GL accounts capture environmental expenses; ESG disclosure references these accounts for transparent reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgDisclosure .

ind:houseBankAccountId rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Id' ;
    rdfs:comment 'Reference to the house bank account associated with this GL account, applicable for bank GL accounts. Links the GL account to the physical bank account for cash management and bank reconciliation. Corresponds to SAP SKB1.HBKID + HKTID. Used in treasury and cash management for F&B global banking relationships.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'High-level categorization indicating whether the account is a balance sheet account (carries forward balances) or a profit and loss account (cleared at year-end). Statistical and memo accounts are used for internal tracking without impacting financial statements. Drives year-end closing procedures and EBITDA reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Account Created By' ;
    rdfs:comment 'User ID or name of the person who created the GL account master record. Supports audit trail requirements and Sarbanes-Oxley (SOX) internal controls over financial reporting. Corresponds to SAP SKA1.ERNAM.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreationDate rdf:type rdf:Property ;
    rdfs:label 'Account Creation Date' ;
    rdfs:comment 'The date on which the GL account master record was originally created in the chart of accounts. Used for audit trail, account lifecycle management, and compliance reporting. Corresponds to SAP SKA1.ERDAT.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'Account group that controls the number range and field selection for the GL account. In SAP, this is the KTOKS field on SKA1 (e.g., \'GKON\' for reconciliation accounts, \'SAKO\' for general accounts). Governs which fields are required, optional, or suppressed during account master maintenance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Node' ;
    rdfs:comment 'The node identifier within the GL account hierarchy (e.g., SAP Financial Statement Version node, Oracle account hierarchy node) to which this account is assigned. Enables roll-up reporting from individual accounts to subtotals and totals in financial statements. Supports EBITDA reporting, segment reporting, and management reporting structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name of the GL account providing full business context beyond the short name. Used in detailed financial reporting, account reconciliation documentation, and audit trails. Corresponds to SAP SKA1.TXT50.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'Further classification of the GL account within its primary account type, providing granular categorization for financial reporting and analytics. Examples: for assets — current_asset, fixed_asset, intangible_asset; for expenses — cogs, selling_expense, admin_expense, rd_expense, trade_spend. Supports COGS calculation, EBITDA reporting, and trade promotion management (TPM) accrual tracking in F&B. [ENUM-REF-CANDIDATE: current_asset|fixed_asset|intangible_asset|current_liability|long_term_liability|cogs|gross_revenue|net_revenue|trade_spend|selling_expense|admin_expense|rd_expense — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for local statutory reporting or group consolidation mapping. Enables mapping between the operating chart of accounts and a group/country chart of accounts. Corresponds to SAP SKB1.ALTKT. Supports multi-GAAP and consolidation reporting for global F&B operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether this account is a balance sheet account whose balance carries forward to the next fiscal year without being closed. Balance sheet accounts represent assets, liabilities, and equity. Used in financial close processes, intercompany reconciliation, and fixed asset reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier of the chart of accounts to which this GL account belongs. In SAP, this is the KTOPL field (e.g., \'INT\', \'CAUS\'). Enterprises may maintain multiple charts of accounts for different legal entities or reporting frameworks (GAAP, IFRS). Drives account assignment and financial statement version mapping.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagement rdf:type rdf:Property ;
    rdfs:label 'Commitment Management' ;
    rdfs:comment 'Indicates whether commitment management (funds commitment tracking) is active for this GL account. When true, purchase orders and other commitments are tracked against budget for this account. Relevant for capital expenditure accounts and trade promotion spend management in F&B. Corresponds to SAP SKB1 commitment management indicator.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code (or Oracle legal entity code) for which this GL account is extended. A single chart of accounts account may be extended to multiple company codes with different settings. Represents the smallest organizational unit for which a complete self-contained set of accounts can be drawn up. Corresponds to SAP SKB1.BUKRS.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodePostingBlock rdf:type rdf:Property ;
    rdfs:label 'Company Code Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are blocked at the company code level (as opposed to the chart of accounts level). Allows selective blocking for specific legal entities while keeping the account active in others. Corresponds to SAP SKB1.XSPEB.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classifies the GL account as a primary cost element (originating from FI postings, e.g., material costs, labor), secondary cost element (internal allocations only, e.g., overhead rates, activity allocations), or not applicable (balance sheet accounts). In SAP S/4HANA, primary cost elements are unified with GL accounts. Drives COGS calculation, variance analysis, and cost center accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'Numeric type code classifying the cost element behavior in controlling (CO). Examples: 1=primary costs/cost-reducing revenues, 3=accrual/deferral per surcharge, 4=accrual/deferral per debit=actual, 11=revenues, 12=sales deductions, 22=external settlement. Corresponds to SAP CSKA.KATYP. Drives cost allocation, variance analysis, and profitability reporting. [ENUM-REF-CANDIDATE: 1|3|4|11|12|22|41|42|43|50|51|61 — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this GL account has been flagged for deletion and is pending archival. Accounts flagged for deletion cannot receive new postings and will be removed during the next archiving run. Corresponds to SAP SKA1.XLOEV. Supports master data lifecycle management and chart of accounts housekeeping.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Controls which fields are required, optional, or suppressed when posting to this GL account. Determines the entry screen layout for journal entries. Corresponds to SAP SKB1.FSTAG. Critical for enforcing data quality on financial postings (e.g., requiring cost center on expense accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'The financial statement version (FSV) to which this account is assigned for statutory and management reporting. Controls how the account is grouped and displayed in balance sheets and income statements. In SAP, corresponds to the VERSN field in T011T. Supports parallel reporting under GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Classifies the GL account by business function for cost-of-sales accounting and segment reporting (e.g., manufacturing/COGS, sales and distribution, general and administrative, research and development, marketing). Enables income statement reporting by function of expense per IFRS IAS 1. Critical for F&B P&L reporting by function. Corresponds to SAP FKBER.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflationIndex rdf:type rdf:Property ;
    rdfs:label 'Inflation Index' ;
    rdfs:comment 'Reference to the inflation index used for inflation accounting adjustments on this GL account. Applicable in high-inflation economies where F&B operations require IAS 29 (Financial Reporting in Hyperinflationary Economies) compliance. Corresponds to SAP SKB1 inflation index assignment.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Indicator' ;
    rdfs:comment 'Indicator controlling whether and how interest is calculated on balances in this GL account. Used for intercompany loan accounts, overdue receivables, and cash pool accounts. Corresponds to SAP SKB1.ZINRT. Supports intercompany transaction management and treasury operations in F&B.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Boolean flag indicating whether this GL account is designated as a reconciliation account for a subledger (AP, AR, or fixed assets). When true, direct manual postings are blocked and all entries must originate from the corresponding subledger. Supports subledger-to-GL reconciliation controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'The date on which the GL account master record was last changed. Supports change management tracking, audit trail, and SOX compliance for master data governance. Corresponds to SAP SKA1.LAEDA.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayed for this GL account. When true, users can drill down to individual postings. Required for accounts subject to audit or detailed reconciliation. Corresponds to SAP SKB1.XKRES. Impacts storage requirements and reporting granularity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlyBalancesInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Only Balances In Local Currency' ;
    rdfs:comment 'When true, the system only manages balances in local (company code) currency for this account, suppressing foreign currency balance management. Typically set for cash and bank accounts. Corresponds to SAP SKB1.XSALH. Impacts foreign currency revaluation processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account. When true, individual line items remain open until cleared against an offsetting entry (e.g., GR/IR clearing accounts, bank clearing accounts). Essential for reconciliation of goods receipt/invoice receipt accounts in F&B procurement. Corresponds to SAP SKB1.XOPVW.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Indicates the level at which financial planning and budgeting is performed for this account (e.g., cost center level, profit center level, company code level). Drives integration with SAP IBP and budgeting tools for demand planning, COGS forecasting, and trade spend budgeting in F&B operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are currently blocked at the chart of accounts level. When true, no journal entries can be posted to this account across all company codes. Used during account restructuring, period-end controls, or when an account is being retired. Corresponds to SAP SKA1.XSPEB.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Profit Center Default' ;
    rdfs:comment 'Default profit center assigned to this GL account for automatic profit center derivation during posting. Ensures that balance sheet items and certain P&L items are assigned to the correct profit center for segment reporting. Corresponds to SAP SKB1.PRCTR. Supports F&B brand/category P&L reporting and IFRS 8 segment disclosure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitLossStatementAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Statement Account' ;
    rdfs:comment 'Indicates whether this account is a profit and loss (income statement) account. P&L accounts are closed to retained earnings at fiscal year-end. Complements account_category for explicit P&L identification used in EBITDA reporting, trade spend accruals, and revenue management analytics.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Indicates whether this GL account serves as a reconciliation account for a subledger (accounts payable, accounts receivable, fixed assets) or is a standard posting account. Reconciliation accounts cannot be posted to directly; postings flow through the subledger. Corresponds to SAP SKB1.MITKZ. Critical for AP/AR and fixed asset subledger integrity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationIndicator rdf:type rdf:Property ;
    rdfs:label 'Revaluation Indicator' ;
    rdfs:comment 'Indicates whether this GL account is subject to foreign currency revaluation at period-end. When true, open items or balances in foreign currency are revalued to the current exchange rate. Critical for F&B companies with multi-currency operations. Corresponds to SAP SKB1 revaluation settings. Supports IFRS IAS 21 and GAAP ASC 830 compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Defines the field used to populate the allocation field in line items posted to this account, enabling sorting and grouping of line items in account statements. Common values: \'001\' (posting date), \'012\' (document number), \'031\' (material number). Corresponds to SAP SKB1.ZUAWA. Supports efficient account analysis and reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Specifies the tax category applicable to this GL account, controlling which tax codes can be used when posting to this account. Blank indicates no tax is applicable. Values such as \'+\' (all tax codes allowed), \'-\' (only input tax), or specific tax category codes. Critical for VAT/GST compliance in F&B operations across jurisdictions. Corresponds to SAP SKB1.MWSKZ. [ENUM-REF-CANDIDATE: input_tax|output_tax|all|none|input_only|output_only — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Assigns the GL account to a tolerance group that defines acceptable payment difference limits for clearing open items. Controls automatic write-off of small differences during payment processing and account clearing. Corresponds to SAP SKB1.TOGRU. Relevant for AR/AP clearing in F&B trade management.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for this entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nettingRunId rdf:type rdf:Property ;
    rdfs:label 'Netting Run Id' ;
    rdfs:comment 'Unique identifier of the intercompany netting run in which this transaction was included. Format NET followed by 8-digit date stamp. Null if transaction has not been netted.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingRun .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: intercompany_transaction sender entity; replace string with FK to company_code' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The business date when the intercompany transaction was created or initiated. May differ from posting date due to period-end processing or backdated entries.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique business document number assigned to this intercompany transaction in the ERP system. Ten-character alphanumeric identifier used for audit trail and reconciliation purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Elimination Document Number' ;
    rdfs:comment 'The consolidation system document number that records the elimination entry for this intercompany transaction. Populated only after consolidation processing. Used for audit trail and reconciliation between legal entity and group reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this intercompany transaction must be eliminated during the consolidation process for statutory reporting. True indicates the transaction will be reversed in consolidated financial statements to avoid double-counting revenue and expenses within the group.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency (typically USD or EUR) for consolidated financial statements. Essential for EBITDA reporting and corporate performance analysis.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID of the person who last modified this intercompany transaction record. Used for audit trail and change tracking in financial controls.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction is included in the periodic intercompany netting process to reduce cash movements between entities. Not netted indicates standalone settlement; included in netting means eligible for next netting run; netted indicates already processed; excluded indicates manual settlement required.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving the intercompany charge or transfer. Four-character alphanumeric code identifying the receiving entity in the corporate structure.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the intercompany reconciliation process indicating whether the sending and receiving entity records match. Matched indicates both sides agree; unmatched indicates discrepancy; disputed indicates formal disagreement; under review indicates investigation in progress.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this intercompany transaction to the originating business document such as a sales order, purchase order, invoice, or goods receipt. Provides traceability to the underlying operational transaction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag (True/False) indicating whether this intercompany transaction is a reversal of a previously posted transaction. True indicates this is a correcting entry; False indicates an original transaction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original intercompany transaction that this entry reverses. Populated only when reversal indicator is True. Provides audit trail for corrections and cancellations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'The trading partner code identifying the counterparty entity in intercompany reporting. Used in consolidation systems to match and eliminate reciprocal transactions between group entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary value of the intercompany transaction in the transaction currency before any adjustments, taxes, or discounts. Represents the base charge or transfer value between entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency in which the intercompany transaction was originally denominated. This is the currency agreed upon between the sending and receiving entities for the transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the intercompany transaction amount for cross-border payments subject to tax treaty provisions. Typically applies to royalties, interest, and service fees. Zero for domestic transactions or exempt categories.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the Silver Layer lakehouse. Primary key for the journal_entry data product. Entity role: TRANSACTION_HEADER — represents a discrete financial posting event in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-text or structured assignment field used for sorting and matching open items (e.g., invoice number, payment reference, purchase order number). Critical for automated payment clearing, dunning, and accounts payable/receivable reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP cost center code identifying the organizational unit responsible for cost incurrence (e.g., a manufacturing plant, distribution center, or functional department). Drives COGS allocation, overhead absorption, and variance analysis in the CO module.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level providing business context for the posting (e.g., \'Monthly COGS accrual — Plant 1001\', \'Trade spend settlement Q3\', \'Intercompany recharge — Snacks Division\'). Supports audit review and financial close commentary.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current workflow state of the journal entry in the financial close process. \'draft\' = not yet posted; \'posted\' = active in GL; \'parked\' = saved but not posted pending approval; \'reversed\' = offset by a reversal document; \'cleared\' = open items matched; \'blocked\' = held for review.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character SAP document type code classifying the nature of the journal entry (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AB=Asset Posting, WA=Goods Issue, ML=Material Ledger). Controls number range assignment and field selection. [ENUM-REF-CANDIDATE: SA|KR|DR|AB|WA|ML|KZ|DZ|RE|RV — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General Ledger account number from the chart of accounts to which the journal entry is posted. Determines the financial statement line (P&L or balance sheet) affected. Drives trial balance, COGS calculation, trade spend accruals, and regulatory reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP internal order number used to collect costs for a specific project, campaign, or temporary cost object (e.g., a new product launch, capital project, or trade promotion). Enables granular cost tracking beyond cost center level for NPD and trade spend management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryType rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Type' ;
    rdfs:comment 'Business classification of the journal entry by its accounting purpose. \'standard\' = regular transaction posting; \'accrual\' = period-end accrual; \'reversal\' = offset of prior posting; \'recurring\' = periodic template-based entry; \'statistical\' = non-financial reporting entry; \'intercompany\' = cross-entity transaction. Drives financial close workflow and EBITDA reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory financial reporting in the country of the legal entity. Enables translation of document-currency amounts to local currency for balance sheet and P&L.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit SAP posting key controlling the debit/credit indicator, account type, and field selection for the journal entry. Standard values include 40 (GL debit), 50 (GL credit), 31 (vendor credit), 21 (vendor debit), 01 (customer debit), 11 (customer credit). Drives account determination and field status.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Period Status' ;
    rdfs:comment 'Status of the fiscal period to which this journal entry belongs at the time of analysis. \'open\' = period accepting postings; \'closed\' = period locked after financial close; \'blocked\' = temporarily restricted; \'future\' = not yet open. Supports period-end close monitoring and financial reporting integrity.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP profit center code identifying the organizational unit responsible for revenue and cost accountability (e.g., a brand, product line, or geographic market). Enables profitability analysis, brand-level P&L, and EBITDA reporting by business unit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Accounting document number of the corresponding reversal or reversed document. Populated when reversal_indicator is True (this is the reversal) or when this document has been reversed by another. Enables bidirectional audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code identifying the business reason for reversing the journal entry (e.g., \'01\'=Reversal in current period, \'02\'=Reversal in next period, \'03\'=Accrual reversal, \'04\'=Error correction). Supports financial close governance and SOX control documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Two-character SAP tax code identifying the applicable tax condition (e.g., V1=Input VAT 10%, A1=Output VAT 10%, I0=Zero-rated, X0=Tax-exempt). Drives automatic tax calculation, tax account determination, and VAT/GST reporting to tax authorities.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of all credit line item amounts in the document currency for this journal entry. Must equal total_debit_amount for a balanced entry. Used for trial balance validation, financial statement generation, and double-entry integrity checks.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmountLc rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount Lc' ;
    rdfs:comment 'Sum of all credit line item amounts translated to the company code\'s local (functional) currency. Paired with total_debit_amount_lc for local-currency trial balance and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit line item amounts in the document currency for this journal entry. Must equal total_credit_amount for a balanced entry (double-entry bookkeeping). Used for trial balance validation, financial statement generation, and EBITDA reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmountLc rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount Lc' ;
    rdfs:comment 'Sum of all debit line item amounts translated to the company code\'s local (functional) currency. Used for statutory financial reporting, local GAAP compliance, and country-level P&L and balance sheet preparation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure element code for project-based cost assignment (e.g., capital expenditure projects, plant expansion, new production line installation). Enables project cost tracking, capitalization decisions, and fixed asset accounting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Profit center performance reports need the manager\'s employee ID for responsibility tracking and compensation alignment.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Code of the brand associated with this profit center when the profit center represents a brand-level P&L segment. Enables brand-level EBITDA decomposition, brand equity tracking, and trade promotion management (TPM) analysis. Null for non-brand profit centers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Budget Period End' ;
    rdfs:comment 'End date of the current active budget period for this profit center. Defines the boundary for budget vs. actual comparisons, financial close processes, and period-end accruals for trade spend and COGS.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start' ;
    rdfs:comment 'Start date of the current active budget period for this profit center. Used in budgeting, forecasting, and EBITDA variance analysis to align actuals against planned financial targets within the correct fiscal window.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dummyProfitCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Dummy Profit Center Flag' ;
    rdfs:comment 'Indicates whether this is the SAP dummy profit center used to capture postings that cannot be assigned to a real profit center (e.g., balance sheet items, unassigned transactions). The dummy profit center is a standard SAP CO-PCA construct and must be identifiable for exclusion from P&L reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP GL account group associated with the profit center, defining the range of general ledger accounts that can post to this profit center. Ensures correct account assignment for revenue, COGS, trade spend accruals, and intercompany transactions.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the standard hierarchy node in SAP CO-PCA to which this profit center is assigned. Defines the position of the profit center within the enterprise profit center hierarchy, enabling roll-up reporting from individual profit centers to business units, divisions, and corporate level.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether the profit center is locked for financial postings in SAP CO-PCA. When true, no new journal entries, cost allocations, or revenue postings can be made to this profit center. Used during period-end close, organizational restructuring, or audit holds.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'Code of the immediate parent profit center in the internal hierarchy, enabling self-referential tree traversal for roll-up P&L reporting. Null for top-level profit centers. Supports brand-level and channel-level EBITDA decomposition across hierarchical levels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code of the product line (e.g., RTD beverages, RTE snacks, dairy) associated with this profit center when the profit center represents a product-line-level P&L segment. Supports product-line-level revenue management, pricing strategy (RSP/EDLP), and COGS variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Free-text long description of the profit center\'s business purpose, scope, and organizational context. Provides additional context beyond the short name for financial analysts, auditors, and data stewards. Sourced from SAP CO-PCA long text field.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Center Group' ;
    rdfs:comment 'SAP profit center group to which this profit center belongs, enabling grouped reporting and planning across related profit centers (e.g., all beverage profit centers grouped under \'GRP_BEVERAGES\'). Used in planning layouts, report painter reports, and EBITDA roll-up structures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Profit Center Level' ;
    rdfs:comment 'Numeric level of the profit center within the enterprise profit center hierarchy (e.g., 1 = corporate, 2 = division, 3 = brand/channel, 4 = sub-brand). Enables hierarchical roll-up queries and drill-down analysis in EBITDA reporting and financial dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center as defined in SAP CO-PCA (e.g., \'North America Snacks\', \'EMEA Beverages\', \'DTC Channel\'). Used as the IDENTITY_LABEL in financial dashboards, EBITDA reports, and brand-level P&L decomposition.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center in SAP CO-PCA. \'active\' — operational and accepting postings; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings (e.g., during restructuring); \'in_planning\' — set up for future fiscal year; \'archived\' — decommissioned and closed. Serves as the LIFECYCLE_STATUS category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by the dimension it represents for internal P&L reporting. Supports brand-level (e.g., a specific snack brand), product-line-level (e.g., RTD beverages), geographic-region-level (e.g., LATAM), or channel-level (e.g., retail, foodservice, DTC) EBITDA decomposition. Serves as the CLASSIFICATION_OR_TYPE category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center is subject to external regulatory financial reporting requirements (e.g., FDA facility-level reporting, USDA program reporting, SEC segment disclosures). When true, additional data governance controls and audit trails are applied.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapProfitCenterKey rdf:type rdf:Property ;
    rdfs:label 'Sap Profit Center Key' ;
    rdfs:comment 'The natural composite key from SAP CO-PCA combining controlling area and profit center code (e.g., \'1000/PC_SNACKS_NA\'). Preserved in the Silver Layer for traceability back to the source system and for cross-system reconciliation with Oracle Cloud ERP or other financial systems.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostingEnabled rdf:type rdf:Property ;
    rdfs:label 'Standard Costing Enabled' ;
    rdfs:comment 'Indicates whether standard costing is activated for this profit center. When true, product costs are valued at standard cost and variances (price, quantity, efficiency) are tracked against actuals. Critical for COGS calculation, margin analysis, and manufacturing variance reporting in F&B operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilitySegment rdf:type rdf:Property ;
    rdfs:label 'Sustainability Segment' ;
    rdfs:comment 'Classification of the profit center\'s product portfolio or operations by sustainability commitment level. Supports ESG reporting, sustainability-linked financial targets, and green revenue tracking. \'sustainable\' — meets defined sustainability criteria; \'transitioning\' — in progress toward sustainability targets; \'conventional\' — standard operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Method' ;
    rdfs:comment 'Method used for intercompany transfer pricing when goods or services are exchanged between profit centers. \'cost_plus\' — cost plus a markup; \'market_price\' — prevailing market rate; \'negotiated\' — bilaterally agreed price; \'none\' — no intercompany transfers. Required for intercompany reconciliation and tax compliance.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this profit center is valid and active for financial postings in SAP CO-PCA. Supports time-dependent master data management and ensures correct period assignment during financial close and historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date until which this profit center is valid for financial postings. After this date, the profit center is locked for new postings. Null indicates an open-ended validity. Used for decommissioning profit centers during organizational restructuring or brand divestitures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeStandardCostId rdf:type rdf:Property ;
    rdfs:label 'Finance Standard Cost Id' ;
    rdfs:comment 'Unique identifier for the standard cost record. Primary key for the standard cost master and variance analysis entity.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Base unit of measure for the standard cost (e.g., EA for each, KG for kilogram, LB for pound, CS for case). Must match the material master base UOM for consistency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackingCost rdf:type rdf:Property ;
    rdfs:label 'Co Packing Cost' ;
    rdfs:comment 'Standard cost component for third-party co-packing or toll manufacturing services per unit. Applicable when production is outsourced to contract manufacturers or co-packers.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Change Amount' ;
    rdfs:comment 'Absolute change in standard cost per unit from previous to current period. Positive indicates cost increase; negative indicates cost reduction. Drives inventory revaluation and margin impact analysis.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Change Percentage' ;
    rdfs:comment 'Percentage change in standard cost from previous to current period. Key metric for cost inflation tracking, procurement performance, and pricing strategy decisions.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costComponentStructure rdf:type rdf:Property ;
    rdfs:label 'Cost Component Structure' ;
    rdfs:comment 'Configuration key defining the cost component split schema (e.g., which cost elements roll into raw material, labor, overhead categories). Ensures consistent cost classification across products and plants.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'Unique identifier for the detailed cost estimate calculation that produced this standard cost. Links to the itemized cost roll-up with BOM explosion, routing operations, and overhead allocation details.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Status' ;
    rdfs:comment 'Lifecycle status of the cost estimate. Only released estimates are activated as standard costs for inventory valuation. Created and calculated are preliminary; marked for deletion are superseded.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'Production lot size used as the basis for standard cost calculation. Fixed costs are spread across this quantity. Larger lot sizes reduce per-unit fixed overhead; smaller lots increase it, creating lot-size variance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingVariant rdf:type rdf:Property ;
    rdfs:label 'Costing Variant' ;
    rdfs:comment 'Costing methodology variant used for standard cost calculation (e.g., PPC1 for product costing, PC01 for material ledger). Determines valuation approach, cost component structure, and overhead allocation rules.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'Version number for the standard cost estimate. Allows multiple cost scenarios (current, planned, simulated) to coexist for comparison and what-if analysis before release.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directLaborCost rdf:type rdf:Property ;
    rdfs:label 'Direct Labor Cost' ;
    rdfs:comment 'Standard cost component for direct production labor per unit. Calculated from routing operation times multiplied by labor rates. Includes line operators, batch mixers, and packaging crew.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Fixed Overhead Cost' ;
    rdfs:comment 'Standard cost component for fixed manufacturing overhead per unit. Includes depreciation, plant supervision, property taxes, insurance, and fixed maintenance allocated based on normal capacity utilization.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInCost rdf:type rdf:Property ;
    rdfs:label 'Freight In Cost' ;
    rdfs:comment 'Standard cost component for inbound freight and logistics per unit. Includes transportation of raw materials and packaging to the manufacturing plant, allocated to finished goods.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique identifier for the material or SKU (Stock Keeping Unit) in the ERP system. Links to the product master for finished goods, semi-finished goods, raw materials, and packaging components.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherCost rdf:type rdf:Property ;
    rdfs:label 'Other Cost' ;
    rdfs:comment 'Standard cost component for miscellaneous manufacturing costs not classified in other categories. May include quality testing, rework allowance, or special handling charges.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Cost' ;
    rdfs:comment 'Standard cost component for primary, secondary, and tertiary packaging materials per unit. Includes bottles, cans, cartons, labels, shrink wrap, pallets, and shipping materials.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Price' ;
    rdfs:comment 'Prior period standard cost per unit before the current cost roll. Used to calculate cost change impact, revaluation amounts, and year-over-year cost trend analysis.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Valuation method indicator: S for standard price (predetermined cost), V for moving average price (actual cost). Food and beverage finished goods typically use standard price; raw materials may use moving average.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the standard price is defined (e.g., 1, 10, 100, 1000). Standard price per unit is divided by price unit to get per-base-unit cost. Commonly 1 for finished goods, may be higher for low-value materials.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'Standard cost component for raw materials and ingredients per unit. Derived from BOM (Bill of Materials) quantities multiplied by component standard prices. Largest cost driver in food and beverage manufacturing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the cost estimate was released and activated as the official standard cost. Marks the transition from preliminary to production-ready cost. Critical for audit trail and variance analysis cutover.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasedByUser rdf:type rdf:Property ;
    rdfs:label 'Released By User' ;
    rdfs:comment 'User ID of the cost accountant or controller who released the standard cost estimate. Provides accountability for cost master changes and supports SOX (Sarbanes-Oxley) compliance audit requirements.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Price Per Unit' ;
    rdfs:comment 'Total standard cost per base unit of measure. Used for inventory valuation, COGS (Cost of Goods Sold) calculation, and gross margin reporting. Sum of all cost component splits.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Material valuation class determining GL (General Ledger) account assignment for inventory and COGS postings. Links material type to chart of accounts for financial reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Variable Overhead Cost' ;
    rdfs:comment 'Standard cost component for variable manufacturing overhead per unit. Includes utilities, indirect materials, consumables, and variable maintenance that scale with production volume.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary value of the variance (actual cost minus standard cost). Positive variance indicates unfavorable (actual higher than standard); negative indicates favorable (actual lower than standard). Aggregated for EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Classification of manufacturing variance type. Price variance: material cost differences. Quantity variance: usage differences. Scrap variance: waste. Mix variance: recipe substitution. Yield variance: output differences. Lot-size variance: volume impact on fixed costs. Overhead variance: absorption differences. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|scrap_variance|mix_variance|yield_variance|lot_size_variance|overhead_variance|resource_usage_variance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance amount expressed as a percentage of standard cost. Used for materiality assessment, exception reporting, and operational performance scorecards. Thresholds trigger management review.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique identifier for the tax transaction record. Primary key for the tax_record product.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reverseChargeIndicator rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction is subject to reverse charge VAT mechanism, where the buyer (not the seller) accounts for VAT. True if reverse charge applies, False otherwise.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The tax amount converted to the company code local currency using the exchange rate. Used for statutory tax reporting and consolidation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the tax authority or regulatory body to which this tax is remitted. Examples: IRS (US), HMRC (UK), Bundeszentralamt für Steuern (Germany), Direction Générale des Finances Publiques (France).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Tax Document Date' ;
    rdfs:comment 'The date of the source document (invoice date, receipt date) that triggered the tax transaction. Used for tax point determination and VAT reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'The unique document number assigned to this tax transaction in the source ERP system (SAP FI tax module). This is the externally-known identifier for audit and reconciliation purposes.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The certificate or authorization number issued by the tax authority granting exemption for this transaction. Required for audit trail when tax_exemption_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction qualifies for tax exemption under applicable regulations. True if exempt, False otherwise. Examples: export sales (zero-rated VAT), essential food items (sales tax exempt).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason Code' ;
    rdfs:comment 'The code representing the legal basis for tax exemption. Examples: EXP (export), ESS (essential goods), RES (resale), GOV (government entity). Populated only when tax_exemption_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Line Item Number' ;
    rdfs:comment 'Line item sequence number within the parent financial document, distinguishing multiple tax postings on a single invoice or journal entry.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxPostingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Date' ;
    rdfs:comment 'The date on which the tax transaction was posted to the general ledger. This is the accounting date for tax liability or receivable recognition.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate applied to the taxable base amount, expressed as a percentage. Examples: 20.00 (UK VAT standard rate), 19.00 (German VAT), 5.50 (reduced rate), 0.00 (zero-rated).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The tax authority reporting period to which this transaction belongs. Format varies by jurisdiction: YYYY-MM (monthly VAT), YYYY-QQ (quarterly sales tax), YYYY (annual excise duty). Examples: 2024-03, 2024-Q1, 2024.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current lifecycle status of the tax transaction. Posted: initial posting complete. Cleared: tax liability settled or input tax recovered. Reversed: transaction reversed due to credit note or correction. Adjusted: manual adjustment applied. Under_audit: flagged for tax authority audit. Disputed: under dispute with tax authority.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax transaction by tax category: input VAT (recoverable tax on purchases), output VAT (tax collected on sales), sales tax, excise duty (alcohol, tobacco, fuel), sugar levy (sugar content tax on beverages), customs duty, withholding tax, use tax, or reverse charge VAT. [ENUM-REF-CANDIDATE: input_vat|output_vat|sales_tax|excise_duty|sugar_levy|customs_duty|withholding_tax|use_tax|reverse_charge — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The net amount on which the tax is calculated, before tax is applied. This is the invoice line total or cost base subject to taxation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany tax transactions. Populated only when intercompany_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenId rdf:type rdf:Property ;
    rdfs:label 'Allergen Id' ;
    rdfs:comment 'Primary key for allergen' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Id' ;
    rdfs:comment 'Reference to the raw material or ingredient for which this allergen declaration applies. Links to the ingredient master data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'The specific allergen category as defined by FDA FALCPA and EU Regulation 1169/2011. Identifies which of the major allergen groups this declaration addresses. [ENUM-REF-CANDIDATE: peanut|tree_nut|milk|egg|wheat_gluten|soy|fish|shellfish|sesame|mustard|celery|lupin|molluscs|sulphites — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the quality assurance professional who approved this allergen declaration for use in finished goods labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Document Number' ;
    rdfs:comment 'The unique document identifier for the Certificate of Analysis that supports this allergen declaration. Used for traceability and audit purposes.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, clarifications, or special handling instructions related to this allergen declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossContactRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Cross Contact Risk Level' ;
    rdfs:comment 'Assessment of the risk that the ingredient may be cross-contaminated with the allergen during manufacturing, processing, or transportation. Used to determine may-contain declarations.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationBasis rdf:type rdf:Property ;
    rdfs:label 'Declaration Basis' ;
    rdfs:comment 'The method or source used to determine the allergen status. Indicates whether the declaration is based on ingredient formulation, supplier-provided documentation, laboratory testing, or facility risk assessment.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the allergen declaration record. Tracks the approval workflow and validity state.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'The nature of the allergen declaration indicating whether the allergen is intentionally present, potentially present due to cross-contact, or absent from the ingredient.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitPpm rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Ppm' ;
    rdfs:comment 'The minimum concentration level in parts per million at which the allergen can be reliably detected by the test method. Applicable only when declaration is based on laboratory testing.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next mandatory review of this allergen declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:precautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement' ;
    rdfs:comment 'The specific precautionary allergen labeling statement to be used on finished goods (e.g., \'May contain traces of peanuts\', \'Processed in a facility that also processes milk\'). Used for label generation.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'The number of days between required reviews of this allergen declaration. Used to ensure declarations remain current and accurate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharedEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Equipment Flag' ;
    rdfs:comment 'Indicates whether the ingredient is processed on equipment that is also used for allergen-containing products. True if shared equipment is used, False otherwise.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Facility Flag' ;
    rdfs:comment 'Indicates whether the ingredient is manufactured in a facility that also processes allergen-containing products. True if shared facility, False otherwise.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The unique identifier of this allergen declaration in the source operational system. Used for traceability and reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'The specific analytical method or protocol used if the allergen declaration is based on laboratory testing (e.g., ELISA, PCR, mass spectrometry). Empty if not lab-tested.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier Id' ;
    rdfs:comment 'Primary key for approved_supplier' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApprovedIngredientRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Ingredient Raw Material Id' ;
    rdfs:comment 'Unique identifier for the approved supplier-ingredient relationship record. Primary key for the approved supplier list entry.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:allergenDeclarationOnFile rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration On File' ;
    rdfs:comment 'Indicates whether a current allergen declaration document is on file for this supplier-ingredient combination. Critical for FSMA compliance and allergen management programs.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must be provided with each shipment of this ingredient from this supplier. COAs verify ingredient specifications and quality parameters.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the master purchase contract or supply agreement governing this supplier-ingredient relationship. Links to contract management systems for terms and conditions.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating where the ingredient is sourced or manufactured by the supplier. Critical for FSMA (Food Safety Modernization Act) traceability and customs compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certificate Expiry Date' ;
    rdfs:comment 'The expiration date of the suppliers GFSI certification. Suppliers must maintain valid certification to remain on the approved supplier list.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gfsiCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certificate Number' ;
    rdfs:comment 'The unique certificate number issued by the GFSI certification body. Used for verification and audit trail purposes.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertificationType rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Type' ;
    rdfs:comment 'The type of GFSI (Global Food Safety Initiative) certification held by the supplier. Common schemes include SQF (Safe Quality Food), BRC (Brand Reputation Compliance), FSSC 22000 (Food Safety System Certification), IFS (International Featured Standards), GLOBALG.A.P., and PrimusGFS.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Status' ;
    rdfs:comment 'The GMO (Genetically Modified Organism) status of the ingredient from this supplier. GMO = contains genetically modified material; Non-GMO = does not contain GMO; Non-GMO Verified = third-party verified; Organic = certified organic (inherently non-GMO).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertified rdf:type rdf:Property ;
    rdfs:label 'Halal Certified' ;
    rdfs:comment 'Indicates whether this supplier is certified to provide this ingredient as Halal-compliant. Required for products targeting Muslim consumers and certain export markets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'The Incoterms rule governing the delivery, risk transfer, and cost responsibilities between buyer and supplier. Common terms include EXW (Ex Works), FOB (Free On Board), CIF (Cost Insurance Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kosherCertified rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified' ;
    rdfs:comment 'Indicates whether this supplier is certified to provide this ingredient as Kosher-compliant. Required for products targeting Jewish consumers and certain retail channels.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditScore rdf:type rdf:Property ;
    rdfs:label 'Last Audit Score' ;
    rdfs:comment 'The numerical score from the most recent supplier audit, typically on a 0-100 scale. Higher scores indicate better compliance and performance. Used for supplier risk assessment and scorecard evaluation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of calendar days from purchase order placement to expected delivery at the receiving facility. Critical for demand planning and inventory optimization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'The minimum order quantity (MOQ) required by the supplier for this ingredient. Represents the smallest amount that can be ordered in a single purchase order.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'The unit of measure for the minimum order quantity, such as kg, lbs, liters, gallons, cases, pallets. Must align with supplier pricing and ordering systems.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertified rdf:type rdf:Property ;
    rdfs:label 'Organic Certified' ;
    rdfs:comment 'Indicates whether this supplier is certified to provide this ingredient as organic (USDA Organic, EU Organic, or equivalent). Required for clean-label and organic product lines.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is designated as a preferred supplier for this ingredient. Preferred suppliers receive priority in sourcing decisions based on quality, reliability, and cost performance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricePerUom rdf:type rdf:Property ;
    rdfs:label 'Price Per Uom' ;
    rdfs:comment 'The negotiated price per unit of measure for this ingredient from this supplier. Used for cost estimation and procurement decisions. Business-confidential pricing information.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'The unit of measure basis for the price, such as per kg, per lb, per liter, per case. Must be clearly defined for accurate cost calculations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reapprovalDueDate rdf:type rdf:Property ;
    rdfs:label 'Reapproval Due Date' ;
    rdfs:comment 'The date by which the supplier must be re-evaluated and re-approved for continued authorization. Ensures periodic review of supplier compliance and quality performance.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierItemCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Code' ;
    rdfs:comment 'The unique item code or SKU (Stock Keeping Unit) that the supplier uses to identify this ingredient in their catalog. Used for purchase orders and supplier communication.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierItemDescription rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Description' ;
    rdfs:comment 'The suppliers description of the ingredient item, which may differ from internal nomenclature. Provides supplier-specific product naming and specification details.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costId rdf:type rdf:Property ;
    rdfs:label 'Cost Id' ;
    rdfs:comment 'Primary key for cost' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cost records are approved by finance staff; cost approval workflow needs employee reference for audit and variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commodityIndexReference rdf:type rdf:Property ;
    rdfs:label 'Commodity Index Reference' ;
    rdfs:comment 'Reference to the commodity market index used for index-linked pricing (e.g., CME Corn Futures, ICE Sugar No. 11, CBOT Wheat). Applies when price_type is index_linked.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference to the purchasing contract number under which this cost is negotiated. Applies when price_type is contract.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPrice rdf:type rdf:Property ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'Negotiated contract price per unit of measure agreed with the supplier. Applies when price_type is contract.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of this cost record: active (currently in use), pending (approved but not yet effective), expired (past expiry_date), superseded (replaced by newer record), or draft (not yet approved).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Duty Cost Per Unit' ;
    rdfs:comment 'Import duty or tariff cost per unit of measure for this ingredient. Applies to imported raw materials and contributes to landed cost.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this cost record ceases to be valid. End of the validity period. Null indicates open-ended validity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Unit' ;
    rdfs:comment 'Freight or transportation cost per unit of measure allocated to this ingredient. Used to calculate total landed cost.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Three-letter Incoterms code defining the delivery terms and transfer of risk (e.g., FOB, CIF, EXW, DDP). Impacts landed cost calculation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMultiplier rdf:type rdf:Property ;
    rdfs:label 'Index Multiplier' ;
    rdfs:comment 'Multiplier applied to the commodity index value to calculate the index-linked price. Used in formula: price = index_value * index_multiplier + base_adjustment.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicePrice rdf:type rdf:Property ;
    rdfs:label 'Invoice Price' ;
    rdfs:comment 'Actual invoiced price per unit of measure from the supplier invoice. Represents the final settled price including any adjustments.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentCost rdf:type rdf:Property ;
    rdfs:label 'Is Current Cost' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active cost record for the ingredient-supplier-plant-purchasing_org combination. True for the most recent active record, False for historical records.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landedCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Per Unit' ;
    rdfs:comment 'Total landed cost per unit of measure including base price, freight, duty, and other procurement-related costs. Represents the true total cost of the ingredient delivered to the plant.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'The most recent actual purchase price per unit of measure paid for this ingredient from this supplier.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum order quantity required by the supplier for this ingredient at the specified price. Expressed in the unit_of_measure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Rolling moving average price per unit of measure calculated from historical purchase transactions. Used for valuation in moving average price materials.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPrice rdf:type rdf:Property ;
    rdfs:label 'Planned Price' ;
    rdfs:comment 'Forecasted or budgeted price per unit of measure for future procurement planning and cost modeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the cost record indicating the pricing mechanism: standard (standard cost estimate), contract (negotiated contract price), spot (market spot price), index_linked (commodity index-based price), moving_average (rolling average price), planned (forecasted future price), or historical (actual past purchase price). [ENUM-REF-CANDIDATE: standard|contract|spot|index_linked|moving_average|planned|historical — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Variance Percentage' ;
    rdfs:comment 'Percentage variance between current and prior period price, calculated as ((current_price - prior_price) / prior_price) * 100. Expressed as a decimal (e.g., 5.25 for 5.25%).' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceVsPriorPeriod rdf:type rdf:Property ;
    rdfs:label 'Price Variance Vs Prior Period' ;
    rdfs:comment 'Variance between the current period price and the prior period price for the same ingredient and supplier. Used for trend analysis and price escalation tracking.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderLineItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Item' ;
    rdfs:comment 'Line item number within the purchase order for this ingredient. Five-digit line item number.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'Four-character code identifying the purchasing organization responsible for procuring this ingredient. Aligns with SAP purchasing organization structure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotPrice rdf:type rdf:Property ;
    rdfs:label 'Spot Price' ;
    rdfs:comment 'Current market spot price per unit of measure for the ingredient. Applies when price_type is spot.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The standard cost per unit of measure as defined in the cost estimate. Used as the baseline for Cost of Goods Sold (COGS) calculation and variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit of measure for which the cost is expressed (e.g., KG for kilogram, LB for pound, LT for liter, EA for each). Aligns with SAP UOM master data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateReason rdf:type rdf:Property ;
    rdfs:label 'Update Reason' ;
    rdfs:comment 'Business reason or justification for the cost update or change (e.g., annual contract renewal, commodity price increase, supplier negotiation, standard cost cycle update).' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceVsStandard rdf:type rdf:Property ;
    rdfs:label 'Variance Vs Standard' ;
    rdfs:comment 'Variance between the actual cost (invoice_price or last_purchase_price) and the standard_cost. Positive values indicate unfavorable variance (actual > standard), negative values indicate favorable variance.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationLineId rdf:type rdf:Property ;
    rdfs:label 'Formulation Line Id' ;
    rdfs:comment 'Primary key for formulation_line' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Foreign key reference to the parent BOM header record representing the finished good or intermediate SKU. Links this line item to its parent formulation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:finishedGoodSkuId rdf:type rdf:Property ;
    rdfs:label 'Finished Good Sku Id' ;
    rdfs:comment 'Reference to the finished good or intermediate product SKU that this BOM line contributes to. Enables traceability from raw material to final product.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryFormulationSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Formulation Supplier Id' ;
    rdfs:comment 'Reference to the approved supplier for this ingredient in this formulation. Links to the approved vendor list (AVL) for procurement and traceability.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Reference to the ingredient specification document that defines quality parameters, tolerances, and acceptance criteria (e.g., Brix, pH, CFU limits).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:additionSequence rdf:type rdf:Property ;
    rdfs:label 'Addition Sequence' ;
    rdfs:comment 'The order in which this ingredient is added within its phase of addition. Ensures proper sequencing for recipe execution and quality control.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'The current lifecycle status of this BOM line item. Controls whether the formulation can be used in production planning and manufacturing execution.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier for the BOM formulation. Tracks changes to formulations over time for product lifecycle management (PLM) and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed description of the change made to this BOM line item. Provides context for formulation modifications and supports regulatory documentation.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'The business reason for creating or modifying this BOM line item. Supports change management and audit trail for formulation changes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the cost per unit. Supports multi-currency cost management for global operations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'The standard cost per unit of measure for this ingredient at the time of BOM creation. Used for cost of goods sold (COGS) calculation and margin analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAllergen rdf:type rdf:Property ;
    rdfs:label 'Is Allergen' ;
    rdfs:comment 'Indicates whether this ingredient is a declared allergen or contains allergen components. Used for allergen matrix management and labeling compliance.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalIngredient rdf:type rdf:Property ;
    rdfs:label 'Is Critical Ingredient' ;
    rdfs:comment 'Indicates whether this ingredient is critical to product safety, quality, or regulatory compliance. Critical ingredients require enhanced traceability and certificate of analysis (COA) verification.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmo rdf:type rdf:Property ;
    rdfs:label 'Is Gmo' ;
    rdfs:comment 'Indicates whether this ingredient is genetically modified or contains GMO components. Required for clean-label claims and regulatory compliance in certain jurisdictions.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalal rdf:type rdf:Property ;
    rdfs:label 'Is Halal' ;
    rdfs:comment 'Indicates whether this ingredient is halal certified. Supports halal product formulation and labeling for Muslim consumers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosher rdf:type rdf:Property ;
    rdfs:label 'Is Kosher' ;
    rdfs:comment 'Indicates whether this ingredient is kosher certified. Supports kosher product formulation and labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicCertified rdf:type rdf:Property ;
    rdfs:label 'Is Organic Certified' ;
    rdfs:comment 'Indicates whether this ingredient is certified organic. Required for organic product labeling and USDA National Organic Program (NOP) compliance.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemSequence rdf:type rdf:Property ;
    rdfs:label 'Line Item Sequence' ;
    rdfs:comment 'Sequential ordering of the BOM line item within the parent BOM header. Determines the order of ingredient addition in manufacturing processes.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseOfAddition rdf:type rdf:Property ;
    rdfs:label 'Phase Of Addition' ;
    rdfs:comment 'The manufacturing phase or stage at which this ingredient is added to the formulation (e.g., mixing, blending, coating, filling). Critical for manufacturing execution system (MES) scheduling and process control.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerBatch rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Batch' ;
    rdfs:comment 'The quantity of raw material required per production batch of the finished good. Used for material requirements planning (MRP) and cost of goods sold (COGS) calculation.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'The expected scrap or waste percentage for this ingredient during production. Used for accurate material planning and waste management tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Factor Percent' ;
    rdfs:comment 'The expected yield percentage for this ingredient in the manufacturing process. Accounts for material loss during processing (e.g., evaporation, trimming). Used to calculate actual material requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsmaTraceabilityId rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Id' ;
    rdfs:comment 'Primary key for fsma_traceability' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verifier Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FSMA traceability verification is performed by a qualified employee; verifier_employee_id links verification to responsible staff for regulatory reporting.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this traceability record against FSMA Section 204 requirements. Indicates whether all required KDEs are present and accurate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingDate rdf:type rdf:Property ;
    rdfs:label 'Cooling Date' ;
    rdfs:comment 'Date when the ingredient was cooled (for produce and other temperature-sensitive items). Required KDE for certain FTL items.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cteDate rdf:type rdf:Property ;
    rdfs:label 'Cte Date' ;
    rdfs:comment 'Date when the Critical Tracking Event occurred. Required Key Data Element (KDE) for FSMA 204 compliance. Must enable 24-hour FDA traceability response.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cte Timestamp' ;
    rdfs:comment 'Precise timestamp when the Critical Tracking Event occurred, including time zone. Provides granular traceability for time-sensitive food safety investigations.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cteType rdf:type rdf:Property ;
    rdfs:label 'Cte Type' ;
    rdfs:comment 'Type of Critical Tracking Event as defined by FSMA Section 204. Receiving CTE is owned by ingredient domain; transformation and shipping CTEs are owned by manufacturing and distribution domains respectively.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system from which this traceability record was captured (e.g., SAP Batch Management, TraceGains, FoodLogiQ, Rfxcel). Enables data lineage tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason for exemption from FSMA 204 traceability requirements, if applicable. Certain small businesses and specific food types may be exempt.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaFacilityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Facility Registration Number' ;
    rdfs:comment 'FDA-assigned facility registration number for the location where the CTE occurred. Required KDE for FSMA 204 compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlClassification rdf:type rdf:Property ;
    rdfs:label 'Ftl Classification' ;
    rdfs:comment 'Classification of the ingredient according to the FDA Food Traceability List. Identifies which FTL category the ingredient belongs to (e.g., leafy greens, fresh-cut fruit, shell eggs, nut butters, finfish, crustaceans, mollusks, prepared ready-to-eat deli salads, tropical tree fruits, cheeses).' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlItemCode rdf:type rdf:Property ;
    rdfs:label 'Ftl Item Code' ;
    rdfs:comment 'Standardized code identifying the specific FTL item. Used for consistent classification across the supply chain.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number identifying the physical location where the CTE occurred. Provides standardized location identification for supply chain traceability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growingLocation rdf:type rdf:Property ;
    rdfs:label 'Growing Location' ;
    rdfs:comment 'Geographic location where the ingredient was grown or harvested. Required KDE for certain FTL items to enable rapid source tracing during outbreaks.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harvestDate rdf:type rdf:Property ;
    rdfs:label 'Harvest Date' ;
    rdfs:comment 'Date when the ingredient was harvested (for agricultural products). Required KDE for certain FTL items such as leafy greens and fresh produce.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:immediatePreviousSourceAddress rdf:type rdf:Property ;
    rdfs:label 'Immediate Previous Source Address' ;
    rdfs:comment 'Physical address of the immediate previous source facility. Required for FSMA traceability to enable rapid source identification during food safety events.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediatePreviousSourceName rdf:type rdf:Property ;
    rdfs:label 'Immediate Previous Source Name' ;
    rdfs:comment 'Name of the immediate previous source (supplier, grower, processor) who provided the ingredient. Required KDE for receiving CTE.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediatePreviousSourcePhone rdf:type rdf:Property ;
    rdfs:label 'Immediate Previous Source Phone' ;
    rdfs:comment 'Contact phone number for the immediate previous source. Enables rapid communication during food safety investigations and recalls.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Description of the physical location where the CTE occurred. May include facility name, warehouse, production line, or receiving dock identifier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingDate rdf:type rdf:Property ;
    rdfs:label 'Packing Date' ;
    rdfs:comment 'Date when the ingredient was initially packed. Required KDE for certain FTL items to track the packing CTE.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Description of the ingredient or food product subject to traceability. Required KDE for FSMA 204 compliance to clearly identify the traceable item.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document supporting this traceability record. Examples include Bill of Lading (BOL), Purchase Order (PO), Advanced Shipping Notice (ASN), production record, or Certificate of Analysis (COA). [ENUM-REF-CANDIDATE: BOL|PO|ASN|production_record|COA|receiving_report|batch_record|shipping_manifest — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlcSource rdf:type rdf:Property ;
    rdfs:label 'Tlc Source' ;
    rdfs:comment 'Origin of the traceability lot code. Indicates whether the TLC was assigned by the supplier, internally generated, or provided by the original grower/processor.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlcSourceReference rdf:type rdf:Property ;
    rdfs:label 'Tlc Source Reference' ;
    rdfs:comment 'Reference identifier linking the TLC to the source system or document where it was originally assigned. Enables upstream traceability to the immediate previous source.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityLotCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Lot Code' ;
    rdfs:comment 'Unique lot code assigned to the ingredient batch for FSMA traceability purposes. The TLC is the core identifier linking all CTEs for a specific ingredient lot throughout the supply chain.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Traceability Plan Version' ;
    rdfs:comment 'Version identifier of the FSMA traceability plan under which this record was created. Enables audit trail of traceability process changes.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when this traceability record was last verified for accuracy and completeness. Supports audit readiness for FDA inspections.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of data verification for this traceability record. Indicates whether the record has been validated against source documents and supplier data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Primary key for lot' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:fsmaRecordId rdf:type rdf:Property ;
    rdfs:label 'Fsma Record Id' ;
    rdfs:comment 'Foreign key linking to regulatory.fsma_record. Business justification: FSMA compliance requires each ingredient lot to be associated with a specific FSMA record for traceability and audit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FsmaRecord .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_shipment. Business justification: REQUIRED: FSMA traceability report needs to link each raw-material lot to its inbound shipment for recall and compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Lot-level quality inspections are recorded; linking lot to inspection_lot enables traceability reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: FSMA traceability: link ingredient lot to sales order to identify which orders contain the lot for recall and compliance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Comma-separated list of allergens present in or potentially cross-contaminated with this ingredient lot.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'Date until which the ingredient maintains optimal quality characteristics, may still be usable after this date subject to quality review.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Coa Received Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was received from the supplier.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Reason for the current disposition status of the lot (e.g., failed specification, expired, contamination risk).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fefo Sequence Number' ;
    rdfs:comment 'Sequence number used to prioritize lot consumption based on expiry date, ensuring oldest lots are used first.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether the ingredient lot is certified halal by a recognized halal certification body.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date when a quality hold or quarantine status was released, allowing the lot to be used in production.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalLotNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Lot Number' ;
    rdfs:comment 'Company-assigned unique lot number for internal traceability and inventory management. Primary business identifier for the lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether the ingredient lot is certified kosher by a recognized kosher certification agency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the ingredient lot indicating its availability for production use.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date when the ingredient was manufactured or produced by the supplier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organicCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Organic Certificate Number' ;
    rdfs:comment 'Certificate number from the organic certification body if the lot is organic certified.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether the ingredient lot is certified organic by a recognized certification body.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of quality inspection and testing for the ingredient lot.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current available quantity of the ingredient lot after consumption, adjustments, and reservations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Total quantity of ingredient received in this lot, measured in the unit of measure specified.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the lot is under quarantine pending quality inspection and approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the ingredient lot was physically received at the plant or distribution center.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional notes, observations, or special handling instructions related to the ingredient lot.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date when the ingredient lot must be retested to confirm continued compliance with specifications before further use.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'GS1 Serial Shipping Container Code for pallet or container-level traceability in the supply chain.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required environmental storage condition for the ingredient lot to maintain quality and safety.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'Lot or batch number assigned by the supplier, used for backward traceability to supplier production records.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceipt rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt' ;
    rdfs:comment 'Measured temperature of the ingredient lot at the time of receipt, critical for temperature-sensitive materials.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Status' ;
    rdfs:comment 'Certification status of the supplier at the time this lot was received, indicating compliance with company quality standards.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalProfileId rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile Id' ;
    rdfs:comment 'Primary key for nutritional_profile' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nutritionalRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Nutritional Raw Material Id' ;
    rdfs:comment 'FK to ingredient.raw_material' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:primaryNutritionalRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Nutritional Raw Material Id' ;
    rdfs:comment 'Foreign key reference to the ingredient master record for which this nutritional profile is defined.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:qualitySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Nutritional panels must conform to nutrition specifications; linking enables compliance dashboards.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:addedSugarsG rdf:type rdf:Property ;
    rdfs:label 'Added Sugars G' ;
    rdfs:comment 'Added sugar content in grams per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'Date when the nutritional analysis was performed by the laboratory or R&D team.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Analytical Method' ;
    rdfs:comment 'Laboratory analytical method or protocol used to determine the nutritional composition. Examples include AOAC methods, wet chemistry, NIR spectroscopy, or chromatography techniques.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calciumMg rdf:type rdf:Property ;
    rdfs:label 'Calcium Mg' ;
    rdfs:comment 'Calcium content in milligrams per serving size. Essential mineral for bone health and mandatory FDA declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cholesterolMg rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Mg' ;
    rdfs:comment 'Cholesterol content in milligrams per serving size. Required for FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis document that contains the detailed nutritional test results for this ingredient batch or lot.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Origin of the nutritional data. Indicates whether values are from direct laboratory analysis, supplier-provided specifications, USDA nutrient database, published literature, or calculated from recipe formulation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryFiberG rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber G' ;
    rdfs:comment 'Dietary fiber content in grams per serving size. Includes soluble and insoluble fiber components.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyKcal rdf:type rdf:Property ;
    rdfs:label 'Energy Kcal' ;
    rdfs:comment 'Energy content expressed in kilocalories (kcal) per serving size. Required for FDA Nutrition Facts Panel and EU nutritional declaration.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyKj rdf:type rdf:Property ;
    rdfs:label 'Energy Kj' ;
    rdfs:comment 'Energy content expressed in kilojoules (kJ) per serving size. Required for EU nutritional declaration and optional for FDA labeling.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMg rdf:type rdf:Property ;
    rdfs:label 'Iron Mg' ;
    rdfs:comment 'Iron content in milligrams per serving size. Essential mineral for blood health and mandatory FDA declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the laboratory or testing facility that performed the nutritional analysis. May be internal R&D lab or third-party accredited laboratory.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile Status' ;
    rdfs:comment 'Current lifecycle status of the nutritional profile record. Indicates whether the data is draft, approved for use in finished goods labeling, under regulatory review, expired, or superseded by a newer version.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potassiumMg rdf:type rdf:Property ;
    rdfs:label 'Potassium Mg' ;
    rdfs:comment 'Potassium content in milligrams per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinG rdf:type rdf:Property ;
    rdfs:label 'Protein G' ;
    rdfs:comment 'Protein content in grams per serving size. Essential macronutrient for nutritional labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat G' ;
    rdfs:comment 'Saturated fatty acid content in grams per serving size. Required nutrient declaration for cardiovascular health labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSizeUom rdf:type rdf:Property ;
    rdfs:label 'Serving Size Uom' ;
    rdfs:comment 'Unit of measure for the serving size. Common values include grams (g), milliliters (ml), ounces (oz), or standardized serving units. [ENUM-REF-CANDIDATE: g|ml|oz|cup|tbsp|tsp|serving — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeValue rdf:type rdf:Property ;
    rdfs:label 'Serving Size Value' ;
    rdfs:comment 'Numeric value representing the serving size for which nutritional values are declared. Typically expressed per 100g or per defined serving unit.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Mg' ;
    rdfs:comment 'Sodium content in milligrams per serving size. Critical for cardiovascular health and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateG rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate G' ;
    rdfs:comment 'Total carbohydrate content in grams per serving size, including sugars, starches, and dietary fiber.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatG rdf:type rdf:Property ;
    rdfs:label 'Total Fat G' ;
    rdfs:comment 'Total fat content in grams per serving size. Includes all fatty acids and lipid components.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsG rdf:type rdf:Property ;
    rdfs:label 'Total Sugars G' ;
    rdfs:comment 'Total sugar content in grams per serving size, including naturally occurring and added sugars.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatG rdf:type rdf:Property ;
    rdfs:label 'Trans Fat G' ;
    rdfs:comment 'Trans fatty acid content in grams per serving size. Mandatory declaration under FDA and many international regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for the nutritional profile record. Supports change tracking and audit trail for ingredient nutritional data updates.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminAMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin A Mcg' ;
    rdfs:comment 'Vitamin A content in micrograms per serving size, expressed as retinol activity equivalents (RAE).' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminCMg rdf:type rdf:Property ;
    rdfs:label 'Vitamin C Mg' ;
    rdfs:comment 'Vitamin C (ascorbic acid) content in milligrams per serving size.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Mcg' ;
    rdfs:comment 'Vitamin D content in micrograms per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCertificationId rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Id' ;
    rdfs:comment 'Unique identifier for the organic certification record. Primary key.' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certified organic ingredient is approved for use in production based on current certification status.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date of the most recent organic compliance audit conducted by the certifying body.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'Digital document reference or file path to the scanned organic certificate stored in the document management system.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or hyperlink to access the digital organic certificate document in the document management system.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the certifying body for this organic certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationGrade rdf:type rdf:Property ;
    rdfs:label 'Certification Grade' ;
    rdfs:comment 'The organic grade or classification level of the certified ingredient (100% Organic, Organic, Made with Organic).' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The organic standard or regulation under which the certification was granted.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the organic certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedIngredientName rdf:type rdf:Property ;
    rdfs:label 'Certified Ingredient Name' ;
    rdfs:comment 'The ingredient name as it appears on the organic certificate, which may differ from internal nomenclature.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedScope rdf:type rdf:Property ;
    rdfs:label 'Certified Scope' ;
    rdfs:comment 'Description of the scope of certification, including specific products, processes, or operations covered by the certificate.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the accredited organization that issued the organic certification (e.g., USDA NOP, ECOCERT, Soil Association, JAS).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyCode rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Code' ;
    rdfs:comment 'Standardized code or accreditation number of the certifying body.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Additional notes or comments regarding organic compliance, audit findings, or special conditions of the certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the organic certification was issued by the certifying body.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next organic compliance audit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether any non-compliance issues have been identified with this organic certification.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicPercentage rdf:type rdf:Property ;
    rdfs:label 'Organic Percentage' ;
    rdfs:comment 'The percentage of organic content in the certified ingredient, expressed as a decimal (e.g., 95.00 for 95% organic).' ;
    rdfs:domain ind:OrganicCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionRegion rdf:type rdf:Property ;
    rdfs:label 'Production Region' ;
    rdfs:comment 'The specific geographic region or state within the country where the organic ingredient was produced.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the certification renewal process.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'Unique traceability code linking this organic certification to supply chain tracking systems for FSMA compliance.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person or team who last verified the organic certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientPriceHistoryId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Price History Id' ;
    rdfs:comment 'Unique identifier for each ingredient price history record.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselinePrice rdf:type rdf:Property ;
    rdfs:label 'Baseline Price' ;
    rdfs:comment 'The baseline or reference price used for variance calculation. May represent prior period price, budget price, or standard cost.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Included Flag' ;
    rdfs:comment 'Boolean flag indicating whether freight and logistics costs are included in the stated price. Critical for total landed cost calculation.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indexValue rdf:type rdf:Property ;
    rdfs:label 'Index Value' ;
    rdfs:comment 'The value of the commodity index at the time this price was set, if index-linked pricing is used.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The minimum order quantity required by the supplier to receive this price. Critical for procurement planning and inventory optimization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationReference rdf:type rdf:Property ;
    rdfs:label 'Negotiation Reference' ;
    rdfs:comment 'Reference to the sourcing event, RFQ, or negotiation process that resulted in this price. Enables traceability to procurement strategy execution.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Price Approval Status' ;
    rdfs:comment 'Approval workflow status for this price record. Supports procurement governance and compliance controls.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business reason or justification for the price change (e.g., commodity market increase, supplier negotiation, volume discount, currency fluctuation, quality upgrade).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceConditionType rdf:type rdf:Property ;
    rdfs:label 'Price Condition Type' ;
    rdfs:comment 'SAP MM condition type code representing the pricing element (e.g., PB00 for gross price, RA01 for discount). Enables detailed price breakdown analysis.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'The source system or document from which this price record was captured (e.g., purchase order, contract, purchasing info record, invoice, market data feed, manual entry).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of this price record: active (currently in use), expired (past expiry date), superseded (replaced by newer price), pending (not yet effective), or cancelled (voided).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityRegion rdf:type rdf:Property ;
    rdfs:label 'Price Validity Region' ;
    rdfs:comment 'Geographic region or market for which this price is valid (e.g., North America, EMEA, APAC). Supports multi-region procurement operations.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'The absolute variance in price compared to the prior period or baseline price. Used for cost trend analysis and procurement performance tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code identifying the purchasing organization or plant that negotiated or received this price. Aligns with SAP MM purchasing organization structure.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Update Flag' ;
    rdfs:comment 'Boolean flag indicating whether this price record triggered or should trigger an update to the ingredient\'s standard cost in the ERP system. Supports standard cost update cycles.' ;
    rdfs:domain ind:IngredientPriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Included Flag' ;
    rdfs:comment 'Boolean flag indicating whether taxes (VAT, GST, sales tax) are included in the stated price.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryStrategyId rdf:type rdf:Property ;
    rdfs:label 'Category Strategy Id' ;
    rdfs:comment 'Foreign key linking to procurement.category_strategy. Business justification: REQUIRED: Sourcing strategy reports assign each raw material to a category strategy defining risk, spend, and sustainability targets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CategoryStrategy .

ind:qualityHaccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Quality Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.haccp_plan. Business justification: Raw material hazard categories are incorporated into HACCP plans; FK supports hazard-based control documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:allergenEggs rdf:type rdf:Property ;
    rdfs:label 'Allergen Eggs' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from eggs. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenFish rdf:type rdf:Property ;
    rdfs:label 'Allergen Fish' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from fish. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenMilk rdf:type rdf:Property ;
    rdfs:label 'Allergen Milk' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from milk. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenPeanuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Peanuts' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from peanuts. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSesame rdf:type rdf:Property ;
    rdfs:label 'Allergen Sesame' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from sesame. Required for FDA FASTER Act allergen labeling compliance (effective 2023).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenShellfish rdf:type rdf:Property ;
    rdfs:label 'Allergen Shellfish' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from crustacean shellfish. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenSoybeans rdf:type rdf:Property ;
    rdfs:label 'Allergen Soybeans' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from soybeans. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTreeNuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Tree Nuts' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from tree nuts. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenWheat rdf:type rdf:Property ;
    rdfs:label 'Allergen Wheat' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from wheat. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by Chemical Abstracts Service to every chemical substance. Critical for regulatory compliance and supplier specifications.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL1 rdf:type rdf:Property ;
    rdfs:label 'Category L1' ;
    rdfs:comment 'Top-level hierarchical category classification (e.g., Dairy, Sweeteners, Proteins, Fats & Oils, Spices & Seasonings). First tier of ingredient taxonomy.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL2 rdf:type rdf:Property ;
    rdfs:label 'Category L2' ;
    rdfs:comment 'Second-level hierarchical category classification providing more granular segmentation within L1 class (e.g., under Dairy: Milk Powders, Whey Products, Cheese Cultures).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL3 rdf:type rdf:Property ;
    rdfs:label 'Category L3' ;
    rdfs:comment 'Third-level hierarchical category classification providing most specific ingredient type within L2 sub-class (e.g., under Milk Powders: Skim Milk Powder, Whole Milk Powder, Buttermilk Powder).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelEligible rdf:type rdf:Property ;
    rdfs:label 'Clean Label Eligible' ;
    rdfs:comment 'Indicates whether the ingredient meets clean-label criteria (recognizable, simple ingredients without artificial additives). Key attribute for consumer-facing product claims and NPD.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eNumber rdf:type rdf:Property ;
    rdfs:label 'E Number' ;
    rdfs:comment 'EU-assigned code for food additives approved for use in the European Economic Area. Required for EU labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairTradeCertified rdf:type rdf:Property ;
    rdfs:label 'Fair Trade Certified' ;
    rdfs:comment 'Indicates the ingredient has been sourced under fair trade standards, ensuring ethical labor practices and fair compensation to producers.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glutenFree rdf:type rdf:Property ;
    rdfs:label 'Gluten Free' ;
    rdfs:comment 'Indicates the ingredient is free from gluten proteins (wheat, barley, rye, triticale). Required for gluten-free product formulation and FDA gluten-free labeling compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoClassification rdf:type rdf:Property ;
    rdfs:label 'Gmo Classification' ;
    rdfs:comment 'Classification of the ingredients GMO status. Critical for regulatory compliance, labeling requirements, and consumer transparency.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Gmo Verification Method' ;
    rdfs:comment 'Method used to verify the GMO status of the ingredient. Documents the rigor of GMO status validation for compliance and audit purposes.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityPreserved rdf:type rdf:Property ;
    rdfs:label 'Identity Preserved' ;
    rdfs:comment 'Indicates the ingredient has been kept segregated throughout the supply chain to maintain its specific identity characteristics (e.g., non-GMO, organic, specific variety). Critical for premium ingredient sourcing and traceability.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciName rdf:type rdf:Property ;
    rdfs:label 'Inci Name' ;
    rdfs:comment 'Standardized INCI name for the ingredient, used for regulatory labeling and international ingredient identification.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientClass rdf:type rdf:Property ;
    rdfs:label 'Ingredient Class' ;
    rdfs:comment 'High-level classification of the ingredient type. Primary categorical segmentation for procurement, formulation, and regulatory purposes. [ENUM-REF-CANDIDATE: raw material|flavor|preservative|colorant|packaging component|additive|processing aid|nutrient fortification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the raw material in the PLM system. Governs availability for new formulations and procurement authorization.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique business identifier for the raw material, typically sourced from ERP system (SAP MM Material Master). Used across procurement, manufacturing, and quality systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name of the raw material, additive, flavor, preservative, or packaging component. Primary identity label for business users.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureSensitive rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitive' ;
    rdfs:comment 'Indicates the ingredient is sensitive to moisture and requires special handling or packaging to prevent degradation. Impacts storage, handling, and packaging specifications.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialColors rdf:type rdf:Property ;
    rdfs:label 'No Artificial Colors' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic or artificial color additives. Supports clean-label and natural product positioning.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialFlavors rdf:type rdf:Property ;
    rdfs:label 'No Artificial Flavors' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic or artificial flavor compounds. Critical for natural and clean-label claims.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialPreservatives rdf:type rdf:Property ;
    rdfs:label 'No Artificial Preservatives' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic preservatives. Supports clean-label and natural product claims.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonGmoProjectVerified rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Project Verified' ;
    rdfs:comment 'Indicates the ingredient has been verified by the Non-GMO Project, the leading third-party verification program for non-GMO products in North America.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertificationBody rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Body' ;
    rdfs:comment 'Name of the organization that issued the organic certification (e.g., USDA, EU Organic, IFOAM). Required for organic claim substantiation and audit trails.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Source origin classification of the raw material. Critical for dietary compliance, allergen management, and clean-label positioning.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantBased rdf:type rdf:Property ;
    rdfs:label 'Plant Based' ;
    rdfs:comment 'Indicates the ingredient is derived from plant sources. Supports plant-based product positioning and consumer trend alignment.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRestrictionProfile rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Profile' ;
    rdfs:comment 'Summary of regulatory restrictions or usage limitations by jurisdiction (e.g., banned in EU, restricted use levels in US, requires warning label in CA). Critical for global product formulation and compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryAppearance rdf:type rdf:Property ;
    rdfs:label 'Sensory Appearance' ;
    rdfs:comment 'Standard sensory profile description for visual appearance characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryAroma rdf:type rdf:Property ;
    rdfs:label 'Sensory Aroma' ;
    rdfs:comment 'Standard sensory profile description for aroma characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryColor rdf:type rdf:Property ;
    rdfs:label 'Sensory Color' ;
    rdfs:comment 'Standard sensory profile description for color characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryFlavor rdf:type rdf:Property ;
    rdfs:label 'Sensory Flavor' ;
    rdfs:comment 'Standard sensory profile description for flavor characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryTexture rdf:type rdf:Property ;
    rdfs:label 'Sensory Texture' ;
    rdfs:comment 'Standard sensory profile description for texture and mouthfeel characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Expected shelf life of the raw material in days under specified storage conditions. Critical for inventory management, FEFO rotation, and formulation planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the raw material (e.g., ambient, refrigerated 2-8°C, frozen -18°C, controlled humidity). Essential for warehouse management and quality preservation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegan rdf:type rdf:Property ;
    rdfs:label 'Vegan' ;
    rdfs:comment 'Indicates the ingredient contains no animal-derived components or by-products. Essential for vegan product formulation and certification.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:religiousCertId rdf:type rdf:Property ;
    rdfs:label 'Religious Cert Id' ;
    rdfs:comment 'Primary key for religious_cert' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of religious dietary certification. Halal certifies compliance with Islamic dietary law. Kosher certifications include Pareve (neutral, contains no meat or dairy), Dairy (contains dairy or dairy equipment), Meat (contains meat or meat equipment), and Passover (meets additional Passover requirements).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceDetails rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Details' ;
    rdfs:comment 'Description of any non-compliance issues, deviations, or corrective actions required. Populated when non_compliance_flag is True.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date on which the certification was last renewed or is scheduled for renewal. Used for tracking renewal cycles and planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'Primary key for substitution' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Substitution Raw Material Id' ;
    rdfs:comment 'Reference to the primary raw material or ingredient that is being substituted. Links to the ingredient master data.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:substitutionSubstituteIngredientRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Substitution Substitute Ingredient Raw Material Id' ;
    rdfs:comment 'Reference to the approved alternative raw material or ingredient that can replace the primary ingredient. Links to the ingredient master data.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:allergenEquivalenceFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Equivalence Flag' ;
    rdfs:comment 'Indicates whether the substitute ingredient has the same allergen profile as the primary ingredient. True = same allergen declaration, False = different allergen profile requiring label review.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanLabelCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Compatible Flag' ;
    rdfs:comment 'Indicates whether the substitute ingredient maintains clean label status (free from artificial additives, preservatives, and highly processed ingredients). Critical for products marketed as natural or clean label.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis must be provided with each batch of the substitute ingredient. True for ingredients with critical quality or safety parameters.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Percentage' ;
    rdfs:comment 'Percentage change in raw material cost when using the substitute versus the primary ingredient. Positive values indicate cost increase, negative values indicate cost savings. Used for COGS (Cost of Goods Sold) analysis.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalEquivalenceNotes rdf:type rdf:Property ;
    rdfs:label 'Functional Equivalence Notes' ;
    rdfs:comment 'Detailed technical notes describing how the substitute ingredient performs the same functional role as the primary ingredient. Includes chemical properties, processing behavior, and performance characteristics.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoStatusMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Gmo Status Match Flag' ;
    rdfs:comment 'Indicates whether the substitute ingredient has the same GMO status as the primary ingredient. True = both GMO or both non-GMO, False = different GMO status requiring label and certification review.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelChangeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Label Change Required Flag' ;
    rdfs:comment 'Indicates whether using the substitute ingredient requires changes to product labeling, including ingredient list, allergen statements, or nutritional panel.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Impact Notes' ;
    rdfs:comment 'Detailed notes on how the substitution affects manufacturing processes, including equipment settings, processing times, temperature adjustments, and yield impacts.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumSubstitutionPercentage rdf:type rdf:Property ;
    rdfs:label 'Maximum Substitution Percentage' ;
    rdfs:comment 'Maximum allowable percentage of the primary ingredient that can be replaced by the substitute in a formulation. Range 0.00 to 100.00. Critical for maintaining product quality and regulatory compliance.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or employee identifier of the person who last modified the substitution record. Supports audit trail and accountability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Match Flag' ;
    rdfs:comment 'Indicates whether the substitute ingredient maintains the same organic certification status as the primary ingredient. Critical for products with USDA Organic or equivalent certifications.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Ranking of this substitution option when multiple substitutes exist for the same primary ingredient. Lower numbers indicate higher priority. Used by manufacturing execution systems to select optimal substitute.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualitySpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Reference' ;
    rdfs:comment 'Reference to the quality specification document that defines acceptance criteria for the substitute ingredient, including Brix, pH, CFU (Colony Forming Units), and other quality parameters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Required Flag' ;
    rdfs:comment 'Indicates whether the substitution requires formal regulatory review and approval before implementation. True when substitution impacts nutritional panel, allergen declaration, or regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensoryImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Sensory Impact Assessment' ;
    rdfs:comment 'Evaluation of the substitutes impact on organoleptic properties (taste, texture, aroma, appearance). None = no detectable difference, Minor = slight variation within acceptable range, Moderate = noticeable but acceptable, Significant = substantial change requiring consumer testing.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Code' ;
    rdfs:comment 'Business identifier for the substitution rule. Externally-known code used in manufacturing and procurement systems.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionStatus rdf:type rdf:Property ;
    rdfs:label 'Substitution Status' ;
    rdfs:comment 'Current lifecycle status of the substitution rule. Tracks approval workflow and operational readiness. [ENUM-REF-CANDIDATE: draft|pending_review|approved|active|suspended|expired|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of the substitution rule. Full = complete replacement at 100%, Partial = limited percentage replacement, Emergency = crisis-driven short-term use, Temporary = time-bound approval, Permanent = long-term approved alternative.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Approval Status' ;
    rdfs:comment 'Status of supplier qualification and approval for the substitute ingredient. Tracks whether the substitute ingredient supplier has passed quality audits and compliance checks.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyContinuityReason rdf:type rdf:Property ;
    rdfs:label 'Supply Continuity Reason' ;
    rdfs:comment 'Business justification for establishing the substitution rule. Examples: primary ingredient supply risk, cost optimization, seasonal availability, supplier diversification, quality improvement.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityLotControlFlag rdf:type rdf:Property ;
    rdfs:label 'Traceability Lot Control Flag' ;
    rdfs:comment 'Indicates whether the substitute ingredient requires lot-level traceability tracking for FSMA compliance and recall readiness. True for high-risk ingredients.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times the substitution rule has been applied in production batches. Tracks actual utilization and validates business value of maintaining the substitution rule.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierDocumentId rdf:type rdf:Property ;
    rdfs:label 'Supplier Document Id' ;
    rdfs:comment 'Unique identifier for the supplier document record. Primary key.' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedFacilityPlantId rdf:type rdf:Property ;
    rdfs:label 'Linked Facility Plant Id' ;
    rdfs:comment 'Reference to the supplier facility or site that this document certifies. Null if the document applies to the supplier organization as a whole.' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:linkedIngredientRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Linked Ingredient Raw Material Id' ;
    rdfs:comment 'Reference to the specific ingredient or raw material that this document applies to. Null if the document applies to multiple ingredients or the supplier in general.' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:supersededByDocumentSupplierDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Supplier Document Id' ;
    rdfs:comment 'Reference to the newer supplier document that replaces this one. Null if this is the current version.' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierDocument .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Qualitative grade or rating assigned by the certifying body for GFSI audit certificates (e.g., AA, A, B, C for BRC; Excellent, Good for SQF). Null for non-audit documents.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score assigned by the certifying body during a GFSI audit (e.g., SQF, BRC, FSSC 22000, IFS). Typically expressed as a percentage or points out of a maximum. Null for non-audit documents.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the primary language of the document (e.g., \'en\' for English, \'es\' for Spanish, \'fr\' for French).' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageReference rdf:type rdf:Property ;
    rdfs:label 'Document Storage Reference' ;
    rdfs:comment 'URI, file path, or storage system reference pointing to the digital copy of the document in the document management system (e.g., TraceGains, SharePoint, S3 bucket).' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full title or name of the supplier document as it appears on the original certificate or statement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version number or revision identifier of the document, used to track updates and amendments.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the stored document.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certified Flag' ;
    rdfs:comment 'Boolean indicator of whether this document is a GFSI-benchmarked audit certificate (SQF, BRC, FSSC 22000, IFS).' ;
    rdfs:domain ind:SupplierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this document record is currently active and should be used for compliance verification. False indicates the record has been archived or soft-deleted.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Number of non-conformances or deficiencies identified during a GFSI audit. Zero indicates full compliance. Null for non-audit documents.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Target date by which the supplier must submit a renewed or updated version of the document to maintain continuous compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the document was reviewed and an approval decision was made.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Comments or observations recorded by the reviewer during the document review process, including reasons for rejection or conditions for approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the supplier submitted the document to the organization for review and approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Primary key for test_result' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Laboratory test results are generated by an analyst; analyst_employee_id links result to the responsible lab employee for QA.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_claim. Business justification: Claim substantiation process references lab test results; linking test_result to the specific marketing claim it supports enables audit trails.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claim .

ind:originalTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Id' ;
    rdfs:comment 'Reference to the original test result record if this is a retest. Null for initial tests.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier for the physical sample taken from the ingredient lot for testing. Links laboratory result to sample chain of custody.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:coaDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Coa Document Url' ;
    rdfs:comment 'Link to the digital COA document stored in the document management system.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Unique certificate of analysis document number issued by the testing laboratory or supplier. Primary business identifier for the test result.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether the test result triggered a quality deviation or non-conformance requiring investigation.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Reference number of the quality deviation or non-conformance record if the test failed specification.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Release Status' ;
    rdfs:comment 'Current disposition status of the ingredient lot based on test results. Determines whether lot can be used in production.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation' ;
    rdfs:comment 'Accreditation standard or certification held by the testing laboratory (e.g., ISO 17025, A2LA, UKAS).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Disposition of the test result against specification limits. Determines whether the ingredient lot meets quality requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system that created this test result record (e.g., SAP QM, TraceGains, Veeva Vault, LIMS).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this test is mandated by regulatory authority (FDA, USDA, EFSA) versus internal quality control.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation if the ingredient lot was rejected based on test results. Documents root cause of failure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test result is a retest of a previously failed or inconclusive test.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the quality assurance reviewer who verified and approved the test result.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date when the sample was collected from the ingredient lot for laboratory testing.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationMax rdf:type rdf:Property ;
    rdfs:label 'Specification Max' ;
    rdfs:comment 'Maximum acceptable value for the test parameter as defined in the ingredient specification. Null if no upper limit applies.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationMin rdf:type rdf:Property ;
    rdfs:label 'Specification Min' ;
    rdfs:comment 'Minimum acceptable value for the test parameter as defined in the ingredient specification. Null if no lower limit applies.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationTarget rdf:type rdf:Property ;
    rdfs:label 'Specification Target' ;
    rdfs:comment 'Target or nominal value for the test parameter. Represents the ideal value within the acceptable range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the laboratory test was completed and results were finalized.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testCost rdf:type rdf:Property ;
    rdfs:label 'Test Cost' ;
    rdfs:comment 'Cost incurred for performing the laboratory test. Used for quality cost tracking and analysis.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Test Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the test cost amount.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the laboratory test was performed. Principal business event timestamp for the test result.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'Specific characteristic or property being measured (e.g., Total Plate Count, pH, Moisture Content, Brix, Salmonella, Aflatoxin).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPriority rdf:type rdf:Property ;
    rdfs:label 'Test Priority' ;
    rdfs:comment 'Priority level assigned to the test based on business urgency or regulatory requirement.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultValue rdf:type rdf:Property ;
    rdfs:label 'Test Result Value' ;
    rdfs:comment 'Measured value or observation from the laboratory test. May be numeric, qualitative (detected/not detected), or descriptive depending on test type.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Category of laboratory test performed on the ingredient lot. Classifies the analytical method domain. [ENUM-REF-CANDIDATE: microbiological|chemical|physical|sensory|nutritional|allergen|contaminant|shelf_life — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the laboratory that performed the test (internal lab or third-party contract lab).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentStockId rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Id' ;
    rdfs:comment 'Unique identifier for the consignment stock record.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Identifier of the material or SKU being consigned.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:primaryConsignmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Consignment Employee Id' ;
    rdfs:comment 'Identifier of the user who created the record.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consignmentAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Consignment Agreement Number' ;
    rdfs:comment 'External reference number for the consignment agreement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Quantity' ;
    rdfs:comment 'Current quantity of the material held on consignment at the partner location.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockStatus rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Status' ;
    rdfs:comment 'Current lifecycle status of the consignment stock record.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentType rdf:type rdf:Property ;
    rdfs:label 'Consignment Type' ;
    rdfs:comment 'Type of consignment arrangement, e.g., Vendor Managed Inventory, Direct Store Delivery, or Standard.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionToDate rdf:type rdf:Property ;
    rdfs:label 'Consumption To Date' ;
    rdfs:comment 'Cumulative quantity of the consigned material that has been consumed or sold to date.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fefoFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Flag' ;
    rdfs:comment 'Indicates whether First-Expired-First-Out logic is applied.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Flag' ;
    rdfs:comment 'Indicates whether First-In-First-Out logic is applied.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastConsumptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Date' ;
    rdfs:comment 'Date when the most recent consumption of consigned stock occurred.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'Date of the most recent replenishment transaction.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Text description of the consigned material.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Replenishment Date' ;
    rdfs:comment 'Planned date for the next replenishment based on trigger logic.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Quantity' ;
    rdfs:comment 'Standard quantity to replenish when the trigger is met.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentTriggerQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Quantity' ;
    rdfs:comment 'Quantity threshold that triggers a replenishment order.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency of financial settlement for the consignment stock.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Free-text description of settlement terms and conditions.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeRemainingDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Remaining Days' ;
    rdfs:comment 'Number of days remaining before the product reaches end of shelf life.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Amount' ;
    rdfs:comment 'Monetary valuation of the consignment stock on hand.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:counterAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Counter Assigned Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cycle Count Counter Assignment report requires identifying the employee performing the count; creates clear accountability.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Calculated inventory accuracy percentage for this cycle count, representing the ratio of items counted correctly to total items counted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCountDate rdf:type rdf:Property ;
    rdfs:label 'Actual Count Date' ;
    rdfs:comment 'Actual date when the physical count was performed. May differ from scheduled date due to operational constraints.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date when audit review of the cycle count was completed and findings documented. Null if no audit required or not yet completed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this cycle count is subject to internal or external audit review due to materiality or compliance requirements. True if audit required, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Completion Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count activity was completed and all items were counted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Count Duration Minutes' ;
    rdfs:comment 'Total duration in minutes from count start to count completion. Used for labor efficiency analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used to perform the physical count: manual (paper-based), barcode scan (handheld scanner), RFID (radio frequency identification), automated system (WMS-driven), blind count (no system quantity shown), or guided count (system quantity visible).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countPlanReference rdf:type rdf:Property ;
    rdfs:label 'Count Plan Reference' ;
    rdfs:comment 'Reference to the master cycle count plan or schedule that triggered this count event. Used for planned cycle counts.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count activity was initiated. Used to track count duration and labor efficiency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Type of inventory count being performed: full physical inventory (complete stock take), cycle count (scheduled rotation), spot check (ad-hoc verification), wall-to-wall (complete facility count), ABC cycle (frequency based on value), or perpetual inventory (continuous counting).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterAssigned rdf:type rdf:Property ;
    rdfs:label 'Counter Assigned' ;
    rdfs:comment 'Name or employee ID of the warehouse worker or team assigned to perform the physical count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count: planned (scheduled but not started), in-progress (counting underway), completed (count finished, awaiting reconciliation), reconciled (variances resolved and posted), cancelled (count aborted), or on-hold (temporarily suspended).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze End Timestamp' ;
    rdfs:comment 'Timestamp when inventory freeze was lifted and normal operations resumed. Null if no freeze applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freezeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze Start Timestamp' ;
    rdfs:comment 'Timestamp when inventory movements were frozen for the count. Null if no freeze applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryFreezeFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Freeze Flag' ;
    rdfs:comment 'Indicates whether inventory movements were frozen during the count to ensure accuracy. True if frozen, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotTraceabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Required Flag' ;
    rdfs:comment 'Indicates whether lot-level traceability is required for items in this cycle count due to FSMA or food safety regulations. True if lot tracking required, False otherwise.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalInventoryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document Number' ;
    rdfs:comment 'SAP physical inventory document number generated for this cycle count event. Maps to SAP MI01/MI04 document.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when inventory variances were reconciled and adjustments posted to the general ledger and inventory records.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes documenting the reconciliation process, root cause analysis of variances, and corrective actions taken.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Recount Completion Date' ;
    rdfs:comment 'Date when the recount was completed, if a recount was required. Null if no recount performed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to variances exceeding threshold or data quality concerns. True if recount needed, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the cycle count to be performed. Set during count planning phase.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific storage location code within the plant or DC where inventory is counted. Aligns with SAP WM storage location.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorAssigned rdf:type rdf:Property ;
    rdfs:label 'Supervisor Assigned' ;
    rdfs:comment 'Name or employee ID of the supervisor responsible for overseeing and validating the cycle count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Items Counted' ;
    rdfs:comment 'Total number of distinct SKUs or line items included in this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceItems rdf:type rdf:Property ;
    rdfs:label 'Total Variance Items' ;
    rdfs:comment 'Number of items where physical count differed from book inventory, exceeding the variance threshold.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'Total financial value of inventory variances identified during the cycle count, calculated using standard cost or moving average price.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of book quantity before a recount or investigation is triggered.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Quantity' ;
    rdfs:comment 'Acceptable variance threshold in quantity units before a recount or investigation is triggered. Set based on item value and criticality.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountLineId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Line Id' ;
    rdfs:comment 'Unique identifier for the line record within a cycle count event.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for the adjustment made.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Type of inventory adjustment applied to resolve the variance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Date and time when the physical count was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalQuantity rdf:type rdf:Property ;
    rdfs:label 'Final Quantity' ;
    rdfs:comment 'Quantity after adjustments and reconciliation.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Method used to value inventory for this line (e.g., FIFO, FEFO).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalItem rdf:type rdf:Property ;
    rdfs:label 'Is Critical Item' ;
    rdfs:comment 'True if the item is high-value, regulated, or otherwise critical to business operations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityBook rdf:type rdf:Property ;
    rdfs:label 'Quantity Book' ;
    rdfs:comment 'Quantity recorded in the system (booked) for the material/lot.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCounted rdf:type rdf:Property ;
    rdfs:label 'Quantity Counted' ;
    rdfs:comment 'Quantity physically counted during the cycle count.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between counted quantity and book quantity (counted – book).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether a recount is required for this line (true = recount needed).' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryLotStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lot Status' ;
    rdfs:comment 'Regulatory state of the lot (e.g., released for sale, quarantined).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Code of the storage bin or location where the material is stored.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard cost per unit of the material for valuation purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standard code indicating why a variance occurred.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Identifier of the distribution center, DC, or 3PL location.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Unique identifier for the goods movement transaction. Primary key for this entity. Serves as the immutable reference for all inventory state changes across the enterprise.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGoodsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Employee Id' ;
    rdfs:comment 'The system user ID of the person who posted the goods movement. Used for audit trail and accountability.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionEventId rdf:type rdf:Property ;
    rdfs:label 'Promotion Event Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_event. Business justification: Movement of promotional goods must be tied to the promotion event for traceability and cost allocation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionEvent .

ind:amountLc rdf:type rdf:Property ;
    rdfs:label 'Amount Lc' ;
    rdfs:comment 'The financial value of the movement in the local currency of the plant. Calculated as quantity × standard cost or moving average price. Positive for receipts, negative for issues. Used for COGS posting and inventory valuation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The timestamp when the movement was approved. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Nullable if approval is not required or still pending.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The lot or batch identifier for the material being moved. Critical for traceability, FEFO/FIFO lot management, shelf life monitoring, and recall execution. Nullable for non-batch-managed materials.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer identifier for goods issue movements to external customers or for customer returns. Nullable for internal movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'For transfer movements, the plant to which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'For transfer movements, the storage location to which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The system timestamp when the goods movement was posted in the ERP system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Distinct from posting_date which is the financial effective date.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Item' ;
    rdfs:comment 'Line item number within the material document. Allows multiple movements to be grouped under a single document header.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'The SAP MM material document number generated upon posting. Unique identifier for the goods movement in the source ERP system. Ten-digit numeric string.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'The fiscal year in which the material document was created. Part of the compound key in SAP MM (material_document_number + material_document_year).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'High-level classification of the movement direction and purpose. Receipt increases stock, issue decreases stock, transfer moves between locations, adjustment corrects quantity or value, reversal cancels a prior posting, reclassification changes stock type without location change.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code defining the nature of the inventory transaction. Examples: 101 (GR for PO), 201 (GI for cost center), 261 (GI for production order), 301 (plant-to-plant transfer), 311 (storage location transfer), 551 (scrapping without PO), 561 (initial entry of stock balance), 701 (GR from blocked stock), 702 (GI to blocked stock). Determines debit/credit logic and account determination. [ENUM-REF-CANDIDATE: 101|102|201|202|261|262|301|302|311|312|321|322|343|344|411|412|551|552|561|562|701|702|711|712 — 24 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'Line item number within the reference document. Nullable for document types without line items.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Year' ;
    rdfs:comment 'The fiscal year of the original posting that this movement reverses. Nullable if reversal_indicator is false.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'For transfer movements, the plant from which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location' ;
    rdfs:comment 'For transfer movements, the storage location from which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The inventory status category of the material. Unrestricted is available for use, quality_inspection is awaiting QA clearance, blocked is not usable, restricted has limited use, returns is customer-returned stock.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The storage location within the plant where the material is physically located. Sub-division of plant for inventory management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Split valuation category for materials with multiple valuation classes (e.g., domestic vs imported, organic vs conventional). Nullable if not split-valuated.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Supplier identifier for goods receipt movements from external vendors. Nullable for internal movements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'System-generated unique identifier for the inventory adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentReclassTargetLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reclass Target Location Storage Location Id' ;
    rdfs:comment 'Destination location identifier for inventory reclassification adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:adjustmentReclassTargetMaterialSkuId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reclass Target Material Sku Id' ;
    rdfs:comment 'Destination material (SKU) identifier for reclassification adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:adjustmentSkuId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Sku Id' ;
    rdfs:comment 'Identifier of the material (SKU) being adjusted.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:adjustmentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Storage Location Id' ;
    rdfs:comment 'Warehouse, distribution center, or 3PL location where the adjustment took place.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'Identifier of the financial document generated by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'Quantity change resulting from the adjustment (positive for increase, negative for decrease).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value Amount' ;
    rdfs:comment 'Monetary value of the quantity adjustment before accounting postings.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business identifier assigned to the adjustment (e.g., posting number).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Date and time when the adjustment event occurred in the business process.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditAccount rdf:type rdf:Property ;
    rdfs:label 'Credit Account' ;
    rdfs:comment 'General ledger account credited by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAccount rdf:type rdf:Property ;
    rdfs:label 'Debit Account' ;
    rdfs:comment 'General ledger account debited by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier linking to an external system record (e.g., EDI message).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Net monetary impact of the adjustment after accounting entries.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isQualityHold rdf:type rdf:Property ;
    rdfs:label 'Is Quality Hold' ;
    rdfs:comment 'True if the inventory is placed on quality hold as part of the adjustment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityHoldReason rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason' ;
    rdfs:comment 'Reason why the inventory was placed on quality hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level category grouping of adjustment reasons.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the adjustment reason.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the originating event (e.g., cycle count document).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'Type of the originating document that triggered the adjustment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxImplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Implication Flag' ;
    rdfs:comment 'Indicates whether the adjustment has tax consequences.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'System-generated unique identifier for each inventory valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Valuation Preparation Report mandates the employee who performed the valuation for compliance and audit purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustments applied during valuation (e.g., price variance, revaluation).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Code that groups materials for accounting purposes (e.g., raw material, finished goods).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Valuation Amount' ;
    rdfs:comment 'Total value before any adjustments (quantity_on_hand * unit_cost).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Net Valuation Amount' ;
    rdfs:comment 'Final valuation amount after adjustments (gross - adjustments).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the material in stock at the valuation date.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Amount added or subtracted to align inventory value with current market or cost changes.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Costing method used for the valuation (Standard Cost, Moving Average, FIFO, LIFO).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Number' ;
    rdfs:comment 'External reference number assigned to the valuation transaction for audit and traceability.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current processing state of the valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valuation Timestamp' ;
    rdfs:comment 'Date and time when the inventory valuation was performed.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotTraceId rdf:type rdf:Property ;
    rdfs:label 'Lot Trace Id' ;
    rdfs:comment 'Unique identifier for each lot traceability record.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downstreamLotRefs rdf:type rdf:Property ;
    rdfs:label 'Downstream Lot Refs' ;
    rdfs:comment 'Identifiers of finished-goods or shipment lots derived from this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaOneUpOneDownFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma One Up One Down Flag' ;
    rdfs:comment 'True when the lot must satisfy FSMA one-up/one-down traceability.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCostAmount rdf:type rdf:Property ;
    rdfs:label 'Lot Cost Amount' ;
    rdfs:comment 'Monetary cost attributed to the lot (e.g., material cost).' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Creation Timestamp' ;
    rdfs:comment 'Date-time when the lot traceability record was first created.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotOwner rdf:type rdf:Property ;
    rdfs:label 'Lot Owner' ;
    rdfs:comment 'Name of the party that owns or supplied the lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Category indicating whether the lot is raw material, intermediate, finished good, or packaging.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Descriptive name of the product associated with the lot.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Result of the most recent quality check performed on the lot.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Traceability Status' ;
    rdfs:comment 'Indicates the one-up/one-down traceability configuration for the lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationEventCode rdf:type rdf:Property ;
    rdfs:label 'Transformation Event Code' ;
    rdfs:comment 'Identifier of the manufacturing or co-packing event that transformed upstream lots into this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upstreamLotRefs rdf:type rdf:Property ;
    rdfs:label 'Upstream Lot Refs' ;
    rdfs:comment 'Identifiers of ingredient or packaging lots that were combined to create this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'System-generated unique identifier for each quarantine hold record.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQuarantineEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quarantine Employee Id' ;
    rdfs:comment 'Identifier of the quality manager who authorized or reviewed the hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Foreign key linking to regulatory.recall_event. Business justification: Quarantine holds are often triggered by recall events; linking enables the recall management process to track affected inventory.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:tertiaryQuarantineModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quarantine Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the hold record.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether the hold is due to allergen cross-contact risk.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Review Timestamp' ;
    rdfs:comment 'Planned date and time for the hold to be reviewed or resolved.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdInitiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiation Timestamp' ;
    rdfs:comment 'Date and time when the quarantine hold was placed on inventory.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'External reference number used by quality teams to track the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Free-text description providing detailed justification for the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the hold was officially released (nullable if not yet released).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Hold Source System' ;
    rdfs:comment 'Name of the source system that originated the hold record (e.g., SAP QM).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Category of the hold indicating the underlying reason such as quality inspection, regulatory, allergen cross-contact, recall, or supplier deviation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'Amount of inventory (in the unit defined by unit_of_measure) placed under quarantine.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Primary key for reservation' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reservation Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who initially created the reservation record.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reservationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reservation Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the reservation, if an approval step is required.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reservationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reservation Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who performed the most recent update to the reservation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancelledReason rdf:type rdf:Property ;
    rdfs:label 'Cancelled Reason' ;
    rdfs:comment 'Reason provided for cancelling the reservation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'Indicates whether the reserved inventory is currently frozen for audit or regulatory purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether the reserved stock requires temperature-controlled handling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestingPartyCode rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Code' ;
    rdfs:comment 'Identifier of the internal or external party that initiated the reservation (e.g., production planner, sales representative, customer).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'Date by which the reserved inventory must be available for the downstream process.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'External business identifier assigned to the reservation, used in operational communications and reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationSource rdf:type rdf:Property ;
    rdfs:label 'Reservation Source' ;
    rdfs:comment 'Origin of the reservation request indicating whether it was generated by a system process, entered manually, or received via an API.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation indicating whether it is still being planned, has been allocated, completed, or terminated.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'The exact date and time when the reservation was created or became effective in the business process.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classifies the purpose of the reservation such as production order, sales order, promotional allocation, maintenance, or stock transfer.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the material that is earmarked for the reservation, expressed in the unit of measure.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Reserved Value Amount' ;
    rdfs:comment 'Monetary value of the reserved quantity based on current cost or price.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeMonitorId rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Monitor Id' ;
    rdfs:comment 'System-generated unique identifier for each shelf-life monitoring record.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShelfEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shelf Employee Id' ;
    rdfs:comment 'Identifier of the user or process that created the record.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Flag' ;
    rdfs:comment 'Indicates whether an expiry or FEFO rotation alert has been generated for the lot.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Date-time when the expiry/rotation alert was created.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Days' ;
    rdfs:comment 'Number of days before expiry at which an alert is triggered.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryStatus rdf:type rdf:Property ;
    rdfs:label 'Expiry Status' ;
    rdfs:comment 'Current status of the lot based on remaining shelf life.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Date-time of the most recent inventory transaction affecting the lot.' ;
    rdfs:domain ind:ShelfLifeMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'Date-time when the shelf-life observation was captured.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Calculated days remaining before the lot reaches its expiration date.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Monetary value of the lot based on the chosen inventory valuation method.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: REQUIRED: Stock aging and cost allocation reports must trace each inventory lot back to its originating purchase order line for financial and quality audits.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and velocity. A items are high-value/high-velocity requiring frequent monitoring; B items are moderate; C items are low-value/low-velocity; X items are obsolete or non-moving.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenSegregationFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Segregation Flag' ;
    rdfs:comment 'Indicates whether the stock contains major allergens and requires physical segregation to prevent cross-contamination.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count verification for this stock position. Used to track count frequency and accuracy.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCountVariance rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance' ;
    rdfs:comment 'Difference between system quantity and physical count quantity from the most recent cycle count. Positive indicates overage; negative indicates shortage.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent goods movement transaction affecting this stock position (receipt, issue, transfer, or adjustment).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotTraceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Code' ;
    rdfs:comment 'External lot or batch code used for supply chain traceability and recall management. May differ from internal lot ID.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBlocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Blocked' ;
    rdfs:comment 'Quantity restricted from use due to quality issues, regulatory holds, or pending disposition (rework, scrap, return to vendor).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Quantity currently in movement between locations (plant-to-DC, DC-to-DC, or inbound from supplier) but not yet received at destination.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Quantity Quality Inspection' ;
    rdfs:comment 'Quantity under quality inspection hold pending QA release. Cannot be used until inspection results are approved.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity allocated to specific sales orders, production orders, or transfer orders but not yet physically moved.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Flag' ;
    rdfs:comment 'Indicates whether this stock position is designated as safety stock buffer to protect against demand variability and supply disruptions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Date after which the product should not be sold or consumed. Critical for FEFO lot management and food safety compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Classification for non-standard stock ownership or purpose. Consignment is vendor-owned stock at customer location; customer-owned is stock held on behalf of customer; project is allocated to specific project; sample is for testing; promotional is for marketing programs. [ENUM-REF-CANDIDATE: consignment|customer_owned|vendor_owned|project|sample|promotional|standard — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAgeDays rdf:type rdf:Property ;
    rdfs:label 'Stock Age Days' ;
    rdfs:comment 'Number of days since the stock was received at the storage location. Used for slow-moving and obsolete inventory analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of stock status indicating availability and restrictions. On-hand is total physical stock; available is unrestricted and not reserved; reserved is allocated to orders; in-transit is goods in movement; quality-inspection is under QA hold; blocked is restricted due to quality or regulatory issues.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the valuation amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorLotNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Lot Number' ;
    rdfs:comment 'Supplier-provided lot or batch number for raw materials and co-packed products. Used for upstream traceability.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Unique identifier for the stock transfer order. Primary key for this entity.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Storage Location Id' ;
    rdfs:comment 'Identifier of the receiving location to which stock is being transferred. May reference plant, distribution center, or third-party logistics (3PL) facility.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryStockEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Employee Id' ;
    rdfs:comment 'User identifier of the person or system that created this transfer order. Used for audit trail and accountability.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryStockStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Storage Location Id' ;
    rdfs:comment 'Identifier of the originating location from which stock is being transferred. May reference plant, distribution center, or third-party logistics (3PL) facility.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:tertiaryStockApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Stock Approved By User Employee Id' ;
    rdfs:comment 'User identifier of the person who approved this transfer order for execution. Required for high-value or cross-region transfers.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transferPriceId rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.transfer_price. Business justification: Inter-plant transfer orders are priced using a transfer price record for cost allocation and profitability analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date when stock was received at the destination location. Captured at goods receipt posting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Shipment Date' ;
    rdfs:comment 'Actual date when stock was shipped from the source location. Captured at goods issue posting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Maximum Temperature C' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for this transfer. Used for cold chain monitoring and compliance verification.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Minimum Temperature C' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for this transfer. Used for cold chain monitoring and compliance verification.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTransferDate rdf:type rdf:Property ;
    rdfs:label 'Planned Transfer Date' ;
    rdfs:comment 'Target date for initiating the stock transfer. Used for planning warehouse resources, transportation capacity, and inventory positioning.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity received at destination location. May differ from confirmed quantity due to damage, loss, or discrepancies during transit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Planned quantity to be transferred as specified in the transfer order. Represents the target amount for the transfer.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Special handling requirements for this transfer. Determines warehouse handling procedures, packaging requirements, and transportation mode.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Cost Amount' ;
    rdfs:comment 'Total cost associated with this stock transfer including transportation, handling, and administrative costs. Used for supply chain cost analysis.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-known business identifier for the stock transfer order. Used for tracking and reference across systems and documents.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason or trigger for the stock transfer. Used for analytics, cost allocation, and supply chain optimization.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the stock transfer order. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer based on source and destination location types. Determines routing, handling requirements, and approval workflows.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Location Management & Safety Inspection process; links each storage location to its overseeing manager employee.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenSegregationClass rdf:type rdf:Property ;
    rdfs:label 'Allergen Segregation Class' ;
    rdfs:comment 'Allergen segregation classification for the storage location. Ensures physical separation of allergen-containing products to prevent cross-contamination. [ENUM-REF-CANDIDATE: none|peanut|tree_nut|dairy|gluten|soy|shellfish|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions available in this storage location. Key metric for warehouse slotting and inventory planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Total storage capacity of the location measured in cubic meters. Used for space utilization analytics and capacity planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms. Critical for structural safety and load planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Erp Storage Location' ;
    rdfs:comment 'Storage location code as defined in the ERP system (e.g., SAP S/4HANA storage location). Used for financial valuation and inventory accounting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FEFO lot rotation based on expiration dates is enforced at this storage location. Critical for perishable goods management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FIFO lot rotation is enforced at this storage location. True if FIFO rules are active.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the storage location meets GMP standards for food safety and quality. True if GMP compliant.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the storage location is certified to store hazardous materials. True if HAZMAT certification is active.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent quality or safety inspection of the storage location. Used for compliance tracking and audit readiness.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required inspection of the storage location. Supports proactive compliance management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Max' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for this storage location. Exceeding this threshold triggers quality alerts.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Min' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for this storage location. Used for cold chain monitoring and compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Wms Location Code' ;
    rdfs:comment 'External location identifier used by the warehouse management system. Enables integration with WMS for real-time inventory tracking.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStockId rdf:type rdf:Property ;
    rdfs:label 'Wip Stock Id' ;
    rdfs:comment 'System-generated unique identifier for each WIP stock record.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Production Line Work Center Id' ;
    rdfs:comment 'Identifier of the specific production line within the work center.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:productionShiftId rdf:type rdf:Property ;
    rdfs:label 'Production Shift Id' ;
    rdfs:comment 'Identifier of the work shift during which the WIP was recorded.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionShift .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Identifier of the work center or production line handling the WIP.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Timestamp when the WIP was actually completed.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Timestamp' ;
    rdfs:comment 'Planned timestamp when the WIP is expected to be completed.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFefo rdf:type rdf:Property ;
    rdfs:label 'Is Fefo' ;
    rdfs:comment 'True if the WIP is managed using First-Expired-First-Out (FEFO) logic.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFifo rdf:type rdf:Property ;
    rdfs:label 'Is Fifo' ;
    rdfs:comment 'True if the WIP is managed using First-In-First-Out (FIFO) logic.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLotTraceable rdf:type rdf:Property ;
    rdfs:label 'Is Lot Traceable' ;
    rdfs:comment 'Indicates whether the WIP lot is subject to traceability requirements (true/false).' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQualityChecked rdf:type rdf:Property ;
    rdfs:label 'Is Quality Checked' ;
    rdfs:comment 'Indicates whether the WIP has passed quality inspection (true/false).' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'External production order number associated with the WIP inventory.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Descriptive name of the WIP stage (e.g., raw mix, in-process).' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStockStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Stock Status' ;
    rdfs:comment 'Current lifecycle status of the WIP record.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipType rdf:type rdf:Property ;
    rdfs:label 'Wip Type' ;
    rdfs:comment 'Classification of the WIP inventory type.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Valuation Amount' ;
    rdfs:comment 'Monetary value of the WIP inventory at the time of capture.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetGroupId rdf:type rdf:Property ;
    rdfs:label 'Asset Group Id' ;
    rdfs:comment 'Foreign key linking to maintenance.asset_group. Business justification: Assets are organized into groups; adding asset_group_id links each asset to its group.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetGroup .

ind:assetHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Asset Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to maintenance.asset_hierarchy. Business justification: Each asset belongs to a hierarchy node; adding asset_hierarchy_id creates the required parent relationship.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetHierarchy .

ind:assignedResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Asset Maintenance Responsibility Report requires linking each asset to the employee accountable for its upkeep, enabling compliance tracking and cost allocation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAssetId rdf:type rdf:Property ;
