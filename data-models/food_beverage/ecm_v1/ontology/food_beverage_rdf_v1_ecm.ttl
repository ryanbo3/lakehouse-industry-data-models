ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-assigned alphanumeric identifier for the incident, used for tracking and reporting.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
