    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfClose rdf:type rdf:Property ;
    rdfs:label 'Probability Of Close' ;
    rdfs:comment 'Likelihood of winning the opportunity expressed as a percentage.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or market territory assigned to the opportunity.' ;
