    rdfs:range xsd:string .

ind:respondentPhone rdf:type rdf:Property ;
    rdfs:label 'Respondent Phone' ;
    rdfs:comment 'Contact phone number of the respondent.' ;
    rdfs:domain ind:NpsSurvey ;
