ind:receivingEntityCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Company Code Id' ;
    rdfs:comment 'Identifier of the legal entity (company code) that receives the goods or materials.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:cupReference rdf:type rdf:Property ;
    rdfs:label 'Cup Reference' ;
