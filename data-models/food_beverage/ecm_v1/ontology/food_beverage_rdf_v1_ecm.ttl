    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalSuccessRatePct rdf:type rdf:Property ;
    rdfs:label 'Historical Success Rate Pct' ;
    rdfs:comment 'Percentage of past executions that met all quality and safety criteria.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent internal audit of the route.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Date and time when the route was most recently executed.' ;
    rdfs:domain ind:LubricationRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lubricantQuantityPerPointMl rdf:type rdf:Property ;
    rdfs:label 'Lubricant Quantity Per Point Ml' ;
    rdfs:comment 'Standard volume of lubricant applied at each point, measured in milliliters.' ;
