    rdfs:range xsd:decimal .

ind:plannedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Cost' ;
    rdfs:comment 'Projected labor expense for the budget period.' ;
    rdfs:domain ind:MaintenanceBudget ;
