    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: Needed for equipment lease tracking; each asset is provisioned under a sales contract, enabling contract compliance and revenue recognition reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContract .

ind:assetCategory rdf:type rdf:Property ;
