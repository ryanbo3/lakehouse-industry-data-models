ind:targetRevenue rdf:type rdf:Property ;
    rdfs:label 'Target Revenue' ;
    rdfs:comment 'Planned revenue target for the promotion.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSalesVolume rdf:type rdf:Property ;
    rdfs:label 'Target Sales Volume' ;
    rdfs:comment 'Planned sales volume target (units) for the promotion.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendBudgetId rdf:type rdf:Property ;
    rdfs:label 'Spend Budget Id' ;
    rdfs:comment 'Foreign key linking to trade.spend_budget. Business justification: promotion_line has budget_amount, total_funding_amount, and funding_amount_per_unit — these represent draws against a spend budget. Linking promotion_line to spend_budget enables line-level budget con' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendBudget .

ind:targetCustomerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: REQUIRED: Promotion lines are built to target specific customer segments; the segment ID is needed for segment-based promotion planning reports.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:billBackRate rdf:type rdf:Property ;
    rdfs:label 'Bill Back Rate' ;
    rdfs:comment 'Rate used for bill-back calculations on promotional sales.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoodsSoldPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Per Unit' ;
    rdfs:comment 'COGS for the SKU used to calculate margin on promotional sales.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingAmountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Funding Amount Per Unit' ;
    rdfs:comment 'Funding allocated to the retailer per unit sold under the promotion.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Incremental Volume Target' ;
    rdfs:comment 'Targeted additional units to be sold beyond baseline.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPerUnit rdf:type rdf:Property ;
    rdfs:label 'Margin Per Unit' ;
    rdfs:comment 'Profit margin per unit after accounting for promotion funding.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offInvoiceAllowanceRate rdf:type rdf:Property ;
    rdfs:label 'Off Invoice Allowance Rate' ;
    rdfs:comment 'Rate of off-invoice allowance expressed as a decimal (e.g., 0.10 = 10%).' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedVolumeLift rdf:type rdf:Property ;
    rdfs:label 'Planned Volume Lift' ;
    rdfs:comment 'Projected increase in units sold due to the promotion.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionCategory rdf:type rdf:Property ;
    rdfs:label 'Promotion Category' ;
    rdfs:comment 'High-level category of the promotion strategy.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionLineStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Line Status' ;
    rdfs:comment 'Current lifecycle status of the promotion line.' ;
    rdfs:domain ind:PromotionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanBackRate rdf:type rdf:Property ;
    rdfs:label 'Scan Back Rate' ;
    rdfs:comment 'Rate applied to retailer-scanned sales for reimbursement.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStoreType rdf:type rdf:Property ;
    rdfs:label 'Target Store Type' ;
    rdfs:comment 'Type of store (e.g., supermarket, convenience) targeted by the promotion.' ;
