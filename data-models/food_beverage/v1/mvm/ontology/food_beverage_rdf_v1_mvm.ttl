ind:commissionGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Commission Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Broker commission payments in F&B are posted to a specific GL account (commission expense). Role-prefix \'commission_\' used because broker may reference multiple GL accounts; this specifically identifi' ;
    rdfs:domain ind:Broker ;
    rdf:type owl:ObjectProperty ;
