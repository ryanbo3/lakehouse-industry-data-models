ind:primaryLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.location. Business justification: Each retail store is served from a primary distribution location (DC or cross-dock) in F&B network planning. This link drives service-level assignment, lead-time calculation, and distribution network ' ;
    rdfs:domain ind:Store ;
