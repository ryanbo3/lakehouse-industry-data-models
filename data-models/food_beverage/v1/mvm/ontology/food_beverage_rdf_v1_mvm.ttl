# RDFS Schema for Business: Food Beverage

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/food_beverage#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Food Beverage ---
ind:FoodBeverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Food Beverage' ;
    rdfs:comment 'Food and Beverage is a global consumer industry manufacturing, marketing, and distributing a diverse portfolio of snacks, beverages, dairy products, and packaged foods through retail, foodservice, and direct-to-consumer channels.' .

# --- Domain Classes ---
ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Product' ;
    rdfs:comment 'Single source of truth for all finished goods master data across the F&B portfolio — SKUs, GTINs, UPCs, BOMs, formulations, recipes, nutritional panels, allergen matrices, packaging specifications, shelf life, and product lifecycle management (PLM) from NPD through commercialization and discontinuation. Governs product hierarchy from brand down to individual pack size and variant.' .

ind:Ingredient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Ingredient' ;
    rdfs:comment 'Authoritative domain for all raw materials, additives, flavors, preservatives, and packaging components used in F&B manufacturing. Manages ingredient specifications, supplier-approved ingredient lists, Brix/pH/CFU tolerances, clean-label attributes, allergen declarations, GMO status, organic certifications, certificates of analysis (COA), and ingredient traceability for FSMA compliance.' .

ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Manages production execution data including batch records, production orders, work centers, MES data (Aveva/Wonderware), OEE metrics, line performance, changeovers, GMP compliance events, HACCP critical control point logs, co-packing and toll manufacturing arrangements, production scheduling, and FIFO/FEFO inventory consumption with lot traceability.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Owns food safety and quality assurance data including HACCP plans, critical control points (CCPs), sensory panels, organoleptic testing, microbiological testing (CFU counts), shelf life studies, non-conformances, CAPA, SQF/BRC/FSSC 22000 audit and certification records, inspection lots, and Veeva Vault QMS document control.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Governs end-to-end supply chain planning and execution — demand sensing, IBP/S&OP cycles (SAP IBP), inventory optimization, safety stock parameters, FIFO/FEFO rotation policies, replenishment signals, supply-demand balancing, inbound logistics, MOQ management, and network design across DC network and 3PL partners.' .

ind:Distribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Distribution' ;
    rdfs:comment 'Owns physical distribution and outbound logistics execution — DC operations, WMS transactions, order fulfillment, carrier management, route optimization, OTIF/fill rate KPIs, cold chain compliance, ASN processing, 3PL performance, cross-docking, DSD route management, proof of delivery, and last-mile logistics for retail, foodservice, and DTC fulfillment.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Commercial sales operations including sales orders, EDI transactions, contracts, pricing (RSP, EDLP), POS data integration, category management, planograms, facings, ACV/TDP metrics, sales force automation, and revenue capture across retail, foodservice, and DTC channels.' .

ind:Trade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Trade' ;
    rdfs:comment 'Trade promotion management and optimization (TPM/TPO) including promotional planning, accruals, deductions, chargebacks, slotting fees, retailer agreement terms, category captain agreements, trade spend analytics, and promotional ROI measurement.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Customer' ;
    rdfs:comment 'SSOT for all customer identities across retail, foodservice, and DTC channels — retailer accounts, foodservice operators, distributors, wholesalers, end consumers, and e-commerce buyers. Manages customer hierarchy, account segmentation, ship-to/bill-to locations, credit terms, loyalty programs, NPS scores, and CRM interactions across B2B and B2C channels.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Brand management, consumer engagement, campaigns, advertising spend, marketing claims (FTC compliance), digital and shopper marketing, social media, influencer partnerships, market research, Nielsen/IRI/SPINS syndicated data, consumer insights, private label program data, and brand equity tracking. Supports Salesforce Marketing Cloud execution.' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Sourcing and procurement of raw materials, ingredients, packaging, indirect materials, and services. Includes supplier master data, purchase orders, MOQs, contracts, supplier performance scorecards, supplier audits, TraceGains compliance documents, approved vendor lists, raw material pricing contracts, and spend analytics.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Single source of truth for all finished goods, WIP, and raw material stock positions across plants, DCs, and 3PL locations. Manages lot traceability, FEFO/FIFO lot management, shelf life monitoring, stock aging, inventory valuation, and cycle count reconciliation aligned with SAP WM/EWM.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Authoritative domain for all financial data — general ledger, cost centers, accounts payable/receivable, COGS calculation, standard costing, variance analysis, budgeting, forecasting, EBITDA reporting, revenue management, RSP/pricing strategy, trade spend accruals, intercompany transactions, fixed assets, and financial close processes.' .

ind:Regulatory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:FoodBeverage ;
    rdfs:label 'Regulatory' ;
    rdfs:comment 'Manages all regulatory compliance and government reporting obligations — FDA/USDA registration and inspection records, EFSA dossiers, nutrition and allergen labeling compliance (21 CFR Part 101), FSMA recordkeeping, EPA packaging compliance, country-of-origin declarations, import/export permits, tariff classifications, and regulatory change management.' .

# --- Data Product Classes (Tables) ---
ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master record for each brand in the F&B portfolio — captures brand identity, positioning, tier (premium, mainstream, value), brand architecture (masterbrand, sub-brand, endorsed), target consumer segment, brand equity score inputs, launch date, and lifecycle status. SSOT for brand identity across the enterprise. Supports brand equity tracking and PLM alignment.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for each marketing campaign executed across channels — TV, digital, shopper, social, influencer, in-store. Captures campaign name, type (awareness, trial, loyalty, trade), objective, target audience, start/end dates, budget, status, owning brand, and Salesforce Marketing Cloud campaign ID. Supports Brand Marketing and Consumer Engagement process.' .

ind:CampaignExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Execution' ;
    rdfs:comment 'Transactional record capturing the actual execution of a campaign flight — channel activation, flight dates, creative asset version deployed, placement details, targeted geography, targeted retailer/account, impressions delivered, clicks, reach, frequency, and execution status. One campaign may have multiple execution records across channels and time periods.' .

ind:MediaSpend rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Media Spend' ;
    rdfs:comment 'Transactional record of advertising and media spend by campaign, channel, market, and time period. Captures planned vs. actual spend, media type (TV, digital display, paid search, OOH, social, streaming), vendor/media partner, invoice reference, cost-per-thousand (CPM), cost-per-click (CPC), and ROI metrics. Supports advertising spend governance and FTC compliance.' .

ind:MediaPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Media Plan' ;
    rdfs:comment 'Master record for marketing investment planning and budget governance by brand, campaign, channel, and fiscal period. Captures approved A&P budget, channel allocation (TV, digital, social, shopper, OOH, streaming), planned GRPs, reach/frequency targets, media mix strategy, agency assignments, committed vs. actual spend, variance, budget owner, and approval status. SSOT for marketing-owned working budget — distinct from finance GL. Supports brand investment decisions, planned-vs-actual reconciliation, and marketing finance controls.' .

ind:ConsumerInsight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Consumer Insight' ;
    rdfs:comment 'Master record for all consumer research studies and their derived insights — encompasses qualitative and quantitative studies (focus groups, sensory panels, organoleptic evaluations, NPS surveys, concept tests, U&A studies, segmentation, packaging tests, pricing research, competitive landscape studies). Captures study metadata (study name, research vendor, methodology, sample size, geography, category scope, fielding dates, status, key deliverable reference), key findings, insight category, target segment, and source system. SSOT for all commissioned/subscribed research and the actionable insights derived from them. Supports NPD pipeline, brand strategy, and innovation funnel.' .

ind:SyndicatedMarketData rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Syndicated Market Data' ;
    rdfs:comment 'Transactional record ingesting Nielsen/IRI/SPINS syndicated market data — captures period, market/geography, category, brand, SKU/UPC, dollar sales, unit sales, ACV (All Commodity Volume), TDP (Total Distribution Points), velocity, market share, and price per unit. Source system tagged (Nielsen, IRI, SPINS). Supports category management and brand performance tracking.' .

ind:BrandEquityTracker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Brand Equity Tracker' ;
    rdfs:comment 'Periodic measurement record of brand equity KPIs — awareness (aided/unaided), consideration, trial, repeat purchase, brand love score, NPS, purchase intent, and brand health index. Captured by brand, market, consumer segment, and measurement period. Sourced from tracking studies and panel data. Supports brand equity monitoring over time.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Master record for all marketing and labeling claims made on packaging, advertising, and digital channels — e.g., No Artificial Colors, Non-GMO, Gluten-Free, Heart Healthy, Clean Label. Captures claim text, claim type (nutritional, environmental, lifestyle), regulatory basis (FDA, FTC, USDA), substantiation document reference, approval status, effective/expiry dates, and SKU-level applicability including which claims appear on which packaging versions in which markets (SKU identifier, packaging version, market/region, regulatory approval reference). SSOT for both claim definition and claim-to-SKU traceability. Supports FTC/FDA labeling compliance and clean label strategy.' .

ind:DemandPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Plan' ;
    rdfs:comment 'Statistical and consensus-based demand forecast at SKU/DC/time-period granularity, serving as the primary input to supply planning and inventory optimization. Captures baseline statistical forecast, adjusted forecast, consensus volume, demand sensing signals (POS data, syndicated data, customer orders), uplift/downlift factors, confidence intervals, and sensing horizon. Supports both monthly S&OP planning horizons and daily/weekly demand signal refresh for near-term supply execution. Generated through demand sensing and S&OP consensus cycles.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Constrained supply plan defining planned production quantities, planned receipts, planned shipments, and supply-demand balance positions at SKU/plant/DC level across the planning horizon. Supports full version management with plan snapshots for cycle-over-cycle comparison, version numbering, creation timestamps, planning cycle references, planner attribution, approval workflows, and plan-vs-plan variance analysis. Drives replenishment signals, production scheduling, and allocation decisions when supply is constrained. Each plan instance captures approval status, key volume metrics (total planned production, total planned receipts), and maintains audit trail for IBP governance.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Planned or released replenishment order generated by MRP or supply planning to move finished goods or raw materials between plants, DCs, and 3PL locations. Captures order type (stock transfer, purchase requisition, planned order), source and destination locations, requested quantity, MOQ compliance, priority, and order status lifecycle (planned → firmed → released → received). Foundation for inbound shipment creation and OTIF measurement.' .

ind:SafetyStockPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Safety Stock Policy' ;
    rdfs:comment 'Inventory buffer policy defining safety stock levels and reorder parameters per SKU per location across the DC network. Captures safety stock quantity, safety days of supply, reorder point, maximum stock level, min/max replenishment bands, and calculation method (statistical, manual, days-of-supply). Governs when replenishment is triggered and how much buffer inventory is maintained to protect against demand variability and supply uncertainty.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Inbound logistics record capturing the full lifecycle of materials moving from suppliers, co-packers, or inter-company transfers to plants and DCs — from advance ship notice (ASN) through physical goods receipt and putaway. Captures carrier, expected and actual arrival dates, quantity shipped, quantity received, receipt posting date, batch/lot assignment (FIFO/FEFO), purchase order reference, delivery note, storage location, valuation details, and receipt variances. Triggers inventory updates upon confirmed receipt. Supports inbound visibility, carrier performance tracking, receipt-vs-order reconciliation, and accounts payable posting.' .

ind:SopCycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sop Cycle' ;
    rdfs:comment 'Sales and Operations Planning (S&OP) / Integrated Business Planning (IBP) cycle record governing the cadence of cross-functional supply-demand alignment. Captures planning period, cycle type (monthly S&OP, weekly demand review, executive IBP), cycle status, key milestone dates (demand review, supply review, pre-S&OP, executive review), consensus decisions, attendees, action items, and financial reconciliation outcomes. Drives the rhythm of planning activities, scenario approvals, and cross-functional accountability across demand, supply, finance, and commercial teams in the F&B organization.' .

ind:NetworkNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Network Node' ;
    rdfs:comment 'Master record for each physical node in the supply chain network — manufacturing plants, distribution centers, 3PL warehouses, co-packer facilities, and cross-dock points. Captures node type, geographic coordinates, capacity (pallet positions, throughput rate), operating model (owned, leased, 3PL-operated), service level parameters, and network tier (national DC, regional DC, forward DC). Foundation entity for network design, lane definition, capacity planning, and safety stock policy assignment.' .

ind:Lane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Lane' ;
    rdfs:comment 'Defined transportation lane between two network nodes (origin-destination pair) used for supply chain routing, freight cost estimation, and replenishment lead time calculation. Captures origin node, destination node, transit time, freight mode (TL, LTL, intermodal, parcel), carrier assignments, lane distance, standard freight cost per unit, and active/inactive status. Supports network optimization, carrier bid management, and transportation cost modeling.' .

ind:CapacityConstraint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Capacity Constraint' ;
    rdfs:comment 'Production and logistics capacity constraint record used in constrained supply planning and DC capacity management. Captures resource type (production line, DC throughput, transportation lane, dock doors), capacity bucket (daily, weekly, monthly), available vs. utilized capacity, constraint type (hard/soft), and DC-specific metrics (pallet positions, labor hours, dock door utilization). Enables finite capacity planning, bottleneck identification, and network rebalancing decisions.' .

ind:InboundReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Receipt' ;
    rdfs:comment 'Goods receipt transaction recorded in SAP S/4HANA MM when inbound materials or finished goods are physically received at a plant or DC. Captures purchase order reference, delivery note, material, batch/lot number, quantity received, unit of measure, storage location, valuation price, and posting date. Triggers inventory update and accounts payable posting.' .

ind:OtifPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Otif Performance' ;
    rdfs:comment 'Supply chain service performance record measuring On-Time In-Full (OTIF) delivery compliance and order fill rates at shipment, customer, and SKU/DC levels. Captures requested vs. actual delivery dates, ordered vs. delivered quantities, on-time flag, in-full flag, OTIF composite score, case fill rate, line fill rate, root cause category (supply shortage, carrier delay, DC error), retailer penalty exposure (e.g., OTIF fines), and backorder/substitution flags. Primary KPI for supply chain customer service and retailer scorecard compliance.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers, vendors, co-packers, toll manufacturers, and service providers in the F&B procurement network. SSOT for supplier identity, classification, tier, payment terms, lead times, MOQ thresholds, onboarding status, and key contact information. Sourced from SAP S/4HANA MM vendor master and TraceGains supplier compliance records. Covers direct material suppliers (ingredients, packaging), indirect suppliers, 3PL/logistics service providers, and co-manufacturers.' .

ind:SupplierSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Site' ;
    rdfs:comment 'Physical or logical site/location record for each supplier — manufacturing plants, warehouses, distribution hubs, and service delivery locations. Captures site address, country of origin, site-level certifications (SQF, GFSI, FSSC 22000), site capacity, and site-specific lead times. A single supplier may have multiple sites with different compliance profiles and capabilities relevant to F&B sourcing decisions.' .

ind:ApprovedVendorList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Approved Vendor List' ;
    rdfs:comment 'Approved Vendor List (AVL) — the authoritative register of supplier-material combinations that are approved for use in F&B production. Tracks approval status, approval date, expiry date, approved material categories (ingredients, packaging, indirect), approval tier (primary, secondary, contingency), and the quality/regulatory basis for approval. Directly supports FSMA, HACCP, and GFSI compliance requirements. Managed in TraceGains and synchronized with SAP MM.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Core procurement transaction record representing a formal purchase order (PO) issued to a supplier for raw materials, ingredients, packaging, indirect materials, or services. Captures PO number, PO type (standard, blanket release, subcontracting, service), order date, requested delivery date, plant/DC destination, total PO value, currency, payment terms, Incoterms, and approval workflow status. Sourced from SAP S/4HANA MM purchasing module and Oracle Cloud Procurement.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line item within a purchase order, representing a specific material or service being procured. Captures line number, material/ingredient code, material description, ordered quantity, unit of measure, agreed unit price, net value, delivery schedule, storage location, batch requirements, and allergen/regulatory flags relevant to F&B ingredient procurement. Supports BOM-driven procurement and raw material cost tracking (COGS).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Procurement-side goods receipt (GR) transaction capturing physical receipt of raw materials, ingredients, packaging, or services at a plant or DC against a purchase order. Records GR number, GR date, received quantity, unit of measure, batch/lot number, shelf life/best-before date, storage location, FEFO/FIFO assignment, quality inspection trigger status, and quantity variance vs. PO. This is the procurement-owned PO-closure confirmation event — it triggers three-way match with finance (invoice verification) and signals inventory domain to update stock positions. SSOT boundary: procurement owns the receipt-against-PO confirmation; inventory domain owns resulting stock position changes. Sourced from SAP S/4HANA MM (MIGO). Critical for lot traceability, FSMA compliance, and PO closure.' .

ind:PurchaseContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Contract' ;
    rdfs:comment 'Long-term procurement contract or framework agreement with a supplier covering raw materials, ingredients, packaging, or services. Captures contract type (value contract, quantity contract, scheduling agreement), contract period, total contract value, pricing conditions (unit prices, price scales, volume tiers, index-linked escalation), volume commitments, MOQ terms, rebate tiers, exclusivity clauses, force majeure terms, and renewal/termination provisions. Includes pricing validity periods and price adjustment mechanisms. Sourced from SAP MM outline agreements and Oracle Cloud Procurement contracts.' .

ind:SupplierScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Scorecard' ;
    rdfs:comment 'Periodic supplier performance scorecard capturing quantitative KPIs across quality, delivery, service, cost, and compliance dimensions. Metrics include OTIF (On Time In Full) rate, fill rate, defect/rejection rate (PPM), non-conformance count and severity, certificate of analysis (CoA) compliance rate, invoice accuracy, responsiveness score, and sustainability rating. Scorecards are generated quarterly or annually and drive supplier tiering, preferred supplier status, AVL renewal decisions, and strategic sourcing decisions. Managed in TraceGains and SAP MM supplier evaluation.' .

ind:SupplierAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Audit' ;
    rdfs:comment 'Supplier audit and corrective action (CAPA) record capturing on-site or remote quality and food safety audits conducted at supplier facilities, plus all resulting Corrective Action and Preventive Action (CAPA) records linked to findings. Tracks audit type (GMP, HACCP, SQF, GFSI, social compliance, environmental), audit date, auditor, scope, findings by severity (critical, major, minor), audit score, pass/fail status, next scheduled audit. For each finding: CAPA reference number, root cause description, corrective action plan, supplier response due date, actual response date, verification method, verification status, closure date, and preventive action implemented. Managed in TraceGains and Veeva Vault. Required for FSMA supplier verification and GFSI compliance. This product is the SSOT for both audit execution and CAPA lifecycle management.' .

ind:ComplianceDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Compliance Document' ;
    rdfs:comment 'Supplier compliance document record managing certificates, specifications, and regulatory documents required for approved supplier status. Document types include: Certificate of Analysis (CoA), Certificate of Conformance (CoC), allergen declarations, GMO status declarations, Kosher/Halal certificates, organic certificates, GFSI audit certificates, FDA registration, USDA inspection records, and SDS sheets. Tracks document version, issue date, expiry date, and approval status. Managed in TraceGains Document Management.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal purchase requisition (PR) record representing a formal internal request to procure raw materials, ingredients, packaging, indirect materials, or services. Captures requisition number, requestor, plant/cost center, material/service description, required quantity, required delivery date, estimated value, approval workflow status, and conversion status to purchase order. Sourced from SAP S/4HANA MM (ME51N) and Oracle Cloud Procurement self-service.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger chart of accounts master — the authoritative SSOT for all GL account codes used across the F&B enterprise. Captures account number, account type (P&L vs balance sheet), financial statement version assignment, account group, currency, tax category, reconciliation account flag, posting block status, and account hierarchy classification. Every financial posting, budget line, and cost allocation references this master. Drives journal entry classification and all financial reporting.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center master data representing organizational units responsible for incurring costs — plants, production lines, sales regions, R&D labs, and corporate functions. Sourced from SAP CO. Captures cost center code, description, responsible manager, controlling area, company code, profit center assignment, cost center category (production, administration, marketing), valid-from/to dates, and currency. Foundational for COGS allocation, variance analysis, and EBITDA reporting.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center master representing autonomous business segments for internal P&L reporting — brands, product lines, geographic regions, or channels (retail, foodservice, DTC). Sourced from SAP CO-PCA. Captures profit center code, name, hierarchy node, responsible manager, company code, controlling area, segment classification, and currency. Enables brand-level and channel-level EBITDA decomposition critical to F&B revenue management.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity master representing each incorporated company within the Food Beverage group — subsidiaries, joint ventures, and holding entities across geographies. Sourced from SAP FI. Captures company code, legal name, country, currency, fiscal year variant, chart of accounts assignment, tax jurisdiction, VAT registration number, and intercompany indicator. Governs statutory reporting, intercompany eliminations, and multi-entity consolidation.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core financial posting document capturing every debit/credit transaction in the general ledger — the atomic unit of financial truth for the F&B enterprise. Encompasses document header (document number, company code, fiscal year, posting date, document type, currency, exchange rate, reversal indicator) and all constituent line items (line number, GL account, debit/credit indicator, amounts in document and local currency, cost center, profit center, tax code, assignment text, business area). Drives all financial statements, trial balance generation, regulatory reporting, COGS allocation, and variance drill-down for F&B manufacturing and trade spend.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable full lifecycle record encompassing invoice receipt through payment execution and settlement for all vendor obligations — raw material and ingredient suppliers, co-packers, 3PL providers, packaging vendors, and indirect service providers. Covers three-way match (PO, GR, invoice), invoice verification (vendor invoice number, vendor account, invoice date, payment terms, gross/tax/net amounts, match status, blocking reasons), payment execution (payment document, payment method including ACH/wire/check, bank account, payment date, discount captured, payment run ID), and clearing/settlement status. Sourced from SAP FI-AP. Critical for COGS accruals, cash flow forecasting, working capital optimization, supplier payment compliance, and early-payment discount capture in F&B procurement.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable full lifecycle record encompassing billing through cash application and settlement for all customer obligations — retail chains, foodservice distributors, convenience operators, and DTC consumers. Covers invoice issuance (customer account, billing document, invoice date, payment terms, gross/net amounts, EDI/portal status), dunning and collections management, payment receipt (remittance document, payment method, lockbox batch, remittance amount, short-payment amount, deduction code), cash application, and clearing status. Sourced from SAP FI-AR and SD billing integration. Drives revenue recognition, DSO management, cash application automation, and deduction identification for F&B commercial finance.' .

ind:FinanceStandardCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Standard Cost' ;
    rdfs:comment 'Standard cost master and variance analysis record for each SKU/material — combining the pre-determined cost used for inventory valuation and COGS calculation with actual manufacturing and purchase price variances. Captures material number, plant, costing variant, standard price per unit, cost component split (raw materials, direct labor, manufacturing overhead, packaging, freight-in), costing lot size, valid-from date, and release status. Also captures all variance records: production order or purchase order reference, variance category (price variance, quantity variance, scrap variance, mix variance, lot-size variance, overhead variance), variance amount and percentage, period, cost center, and settlement status. The financial backbone for F&B gross margin management, standard cost roll-up decisions, make-vs-buy analysis, and operational efficiency reporting.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Annual and rolling financial budget master capturing planned financial targets by cost center, profit center, GL account, and fiscal period. Sourced from SAP CO budgeting or Oracle Cloud EPM. Captures budget version (original, revised, latest estimate), fiscal year, period, company code, cost center, profit center, GL account, budget amount, currency, budget type (opex, capex, headcount), approval status, and budget owner. Foundational for variance-to-budget reporting and EBITDA target management in F&B.' .

ind:Forecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Forecast' ;
    rdfs:comment 'Rolling financial forecast record capturing updated revenue, cost, and EBITDA projections by period, profit center, and business unit. Distinct from budget (which is annual/fixed) — forecasts are updated monthly or quarterly. Captures forecast version, forecast date, fiscal year, period, company code, profit center, GL account category, forecasted amount, prior forecast amount, variance to budget, currency, and forecast owner. Supports S&OP financial integration and investor guidance for F&B.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master and complete lifecycle record for all capitalized property, plant, and equipment — manufacturing lines, filling equipment, refrigeration systems, DCs, vehicles, and IT infrastructure. Encompasses asset master data (asset number, class, description, acquisition date, useful life, depreciation method, net book value, plant/location, cost center) and all movement transactions (acquisitions, transfers, retirements, write-downs, depreciation postings with transaction type, amount, period, GL account, and document reference). Sourced from SAP FI-AA. Supports capex tracking, depreciation scheduling, asset impairment assessment, and asset ROI analysis for F&B manufacturing investments.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period management and financial close orchestration record defining accounting periods and all period-end close activities for each company code. Captures fiscal year, period number (1-12 plus special periods 13-16), start/end dates, period type (regular, special, year-end), open/close status per account type (assets, liabilities, revenue, expense), and posting authority controls. Also encompasses complete close task management: task name, task type (accrual posting, depreciation run, cost allocation, IC reconciliation, balance sheet reconciliation, financial statement preparation), responsible team, planned/actual completion dates, status (open, in-progress, complete, blocked), predecessor dependencies, sign-off owner, and SLA tracking. Controls posting windows and enables close cycle management, audit trail, SOX compliance evidence, and period-end SLA reporting for F&B financial operations.' .

ind:TaxRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Record' ;
    rdfs:comment 'Tax transaction record capturing VAT, GST, sales tax, excise duty, and sugar tax postings associated with customer invoices, vendor invoices, and intercompany transactions. Sourced from SAP FI tax module. Captures tax document reference, tax type (input, output, excise, sugar levy), tax code, tax jurisdiction, taxable base amount, tax amount, currency, tax rate, reporting period, and tax authority. Supports indirect tax compliance and regulatory reporting obligations across F&B global markets including FDA/USDA and EFSA jurisdictions.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Master record for every Stock Keeping Unit (SKU) in the F&B portfolio — the single source of truth for finished-good identity. Captures SKU code, GTIN/UPC/EAN barcodes, brand, sub-brand, product line, flavor/variety, pack size, net weight/volume, unit of measure, form factor (RTD, RTE, concentrate, powder, frozen), ABV where applicable, Brix target, pH range, product status (active, discontinued, on-hold, seasonal), launch date, discontinuation date, PLM stage, and product hierarchy classification. Anchor entity for the entire product domain and primary join key for all downstream domains (sales, supply, manufacturing, quality).' .

ind:Hierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Defines the multi-level product classification hierarchy from corporate portfolio down to individual SKU variant: Division → Category → Sub-Category → Brand → Sub-Brand → Product Line → Variant → Pack Size. Each node carries a hierarchy level code, parent node reference, hierarchy path string, and effective date range. Used for reporting roll-ups, trade promotion planning, category management, and planogram slotting. Aligns with Nielsen/IRI category taxonomy for syndicated data integration.' .

ind:BillOfMaterials rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bill Of Materials' ;
    rdfs:comment 'Bill of Materials (BOM) header record defining the formulation structure for each finished good or semi-finished SKU. Captures BOM number, BOM type (production, co-pack, toll manufacturing), base quantity, unit of measure, effective date range, revision number, PLM approval status, and the owning plant or manufacturing site. Links to BOM line items for individual ingredient quantities. Sourced from SAP S/4HANA PP module and TraceGains specification management.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual component line within a Bill of Materials (BOM), specifying each raw material, ingredient, flavoring, preservative, or packaging component required to produce one batch of the parent SKU. Captures component item number, quantity per base UOM, scrap/yield factor, component category (raw material, packaging, label, co-product), lead-offset, and whether the component is a critical allergen. Enables COGS calculation, procurement planning, and allergen matrix derivation.' .

ind:Formulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Formulation' ;
    rdfs:comment 'Approved product formulation and recipe specification managed through PLM and TraceGains. Captures formulation code, version, formulation type (bench, pilot, commercial), target Brix, target pH, target viscosity, moisture content, water activity (Aw), processing parameters (pasteurization temperature/time, homogenization pressure), yield percentage, batch size, and regulatory approval status. Distinct from BOM in that it captures the scientific/R&D specification rather than the manufacturing component list.' .

ind:NutritionalPanel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Nutritional Panel' ;
    rdfs:comment 'Regulatory nutritional facts panel data for each SKU per applicable jurisdiction (FDA Nutrition Facts, EU Nutrition Declaration, Health Canada). Captures serving size, servings per container, calories, total fat, saturated fat, trans fat, cholesterol, sodium, total carbohydrate, dietary fiber, total sugars, added sugars, protein, and all required vitamins/minerals with % Daily Value. Tracks panel version, effective date, regulatory jurisdiction, and FDA/USDA submission reference. Critical for FSMA compliance and retailer item setup.' .

ind:PackagingSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Packaging Spec' ;
    rdfs:comment 'Packaging specification for each SKU covering primary, secondary, and tertiary packaging. Captures packaging material type (PET, HDPE, glass, aluminum, paperboard, flexible film), container dimensions (height, width, depth, diameter), net weight, gross weight, fill volume, closure type, label panel count, recyclability code, PCR (post-consumer recycled) content percentage, shelf-ready packaging (SRP) configuration, and pallet pattern. Used for sustainability reporting, logistics cube optimization, and retailer compliance.' .

ind:ShelfLifeSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Shelf Life Spec' ;
    rdfs:comment 'Shelf life and storage condition specifications for each SKU, critical for FSMA 204 traceability compliance and retailer receiving standards. Captures total shelf life (days), minimum remaining shelf life at shipment (MRSL), best-by date calculation method (manufacture date + offset vs. fixed calendar), storage temperature range (min/max °C), humidity requirements, light sensitivity, FIFO/FEFO rotation rule, consumer-facing date format (Best By, Use By, Sell By), open-dating regulation compliance (state-level US, EU 1169/2011), and shelf life testing protocol reference. Governs FEFO inventory rotation, DC receiving standards, retailer compliance (e.g., Walmart 2/3 life remaining policy), and cold chain integrity requirements.' .

ind:LabelSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Label Spec' ;
    rdfs:comment 'Label specification and artwork management record for each SKU per market/jurisdiction. Captures label version, label type (front panel, back panel, neck label, cap label, case label), regulatory jurisdiction, language, label dimensions, mandatory claim text, marketing claims (clean label, non-GMO, organic, kosher, halal), warning statements, country of origin declaration, net quantity statement, manufacturer/distributor name and address, and artwork approval status. Tracks FDA/USDA/EFSA label compliance.' .

ind:ProductStandardCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Standard Cost' ;
    rdfs:comment 'Standard cost record for each SKU capturing the fully-loaded COGS build-up: raw material cost, packaging cost, direct labor, manufacturing overhead, co-pack/toll manufacturing fee, freight-in, and total standard cost per case and per unit. Tracks cost version (current standard, prior year, budget, forecast), effective date, plant/production site, currency, and variance to prior period. Owned by product domain as the authoritative product-level cost attribute; feeds pricing strategy (RSP, EDLP), trade promotion ROI, and financial reporting. Sourced from SAP S/4HANA CO module.' .

ind:RawMaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Raw Material' ;
    rdfs:comment 'Master record and Single Source of Truth for all raw materials, additives, flavors, preservatives, and packaging components used in F&B manufacturing. Captures INCI name, CAS number, E-number (EU additive code), ingredient class (raw material, flavor, preservative, colorant, packaging component), hierarchical category classification (L1 class > L2 sub-class > L3 type), origin type (animal, plant, mineral, synthetic), clean-label eligibility and consumer-facing claim attributes (no artificial colors/flavors/preservatives, gluten-free, vegan, plant-based, fair trade), dietary compliance flags (vegan, kosher, halal), organic certification status, GMO classification (non-GMO, GMO, GMO-derived), GMO verification method (supplier declaration, PCR testing, third-party certification), Non-GMO Project Verified flag, identity preservation flag, allergen declaration flags per FDA FALCPA and EFSA categories, shelf life parameters, storage conditions, moisture sensitivity, PLM lifecycle stage, sensory standard profile (appearance, color, aroma, flavor, texture descriptors), and regulatory restriction profile by jurisdiction. Referenced by every transactional record in this domain.' .

ind:ApprovedSupplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Approved Supplier' ;
    rdfs:comment 'Approved Supplier List (ASL) association between a specific supplier and a specific raw material, representing the authorized sourcing relationship. Captures supplier item code, supplier item description, supplier country of origin, approval status (approved, conditional, suspended, revoked), approval date, re-approval due date, GFSI certification type (SQF, BRC, FSSC 22000, IFS), GFSI certificate expiry, MOQ (Minimum Order Quantity), lead time days, price UOM, and last audit score. Sourced from TraceGains Supplier Compliance and SAP MM Source List.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Lot' ;
    rdfs:comment 'Lot-level traceability record for each received batch of raw material, enabling FSMA forward and backward traceability. Captures internal lot number, supplier lot number, GS1 SSCC (Serial Shipping Container Code), receipt date, expiry date, best-before date, quantity received (UOM), plant/DC received at, storage location, FEFO sequence number, quarantine flag, lot status (unrestricted, quality hold, blocked, consumed, expired), and disposition reason. Links to COA and purchase receipt. Sourced from SAP MM Batch Management.' .

ind:Allergen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Allergen' ;
    rdfs:comment 'Authoritative allergen declaration record for each raw material, capturing the presence, absence, or may-contain status of each major allergen category as required by FDA FALCPA, EU Regulation 1169/2011, and other jurisdictions. Captures allergen type (peanut, tree nut, milk, egg, wheat/gluten, soy, fish, shellfish, sesame, mustard, celery, lupin, molluscs, sulphites), declaration type (contains, may contain/cross-contact, free-from), declaration basis (formulation, supplier declaration, lab test), effective date, and jurisdiction. Supports allergen matrix generation for finished goods labeling.' .

ind:FormulationLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Formulation Line' ;
    rdfs:comment 'Bill of Materials (BOM) line-item record linking a finished good or intermediate SKU to its constituent raw materials and sub-components. Captures BOM header reference (finished good SKU), BOM version, line item sequence, raw material reference, quantity per batch (UOM), yield factor %, scrap factor %, phase of addition (mixing, blending, coating, filling), and BOM status (active, draft, obsolete). Enables formulation management, COGS calculation, and nutritional panel computation. Sourced from SAP PP BOM and PLM formulation records.' .

ind:NutritionalProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Nutritional Profile' ;
    rdfs:comment 'Nutritional composition record for each raw material, capturing per-100g and per-serving nutrient values required for finished goods nutritional labeling. Captures energy (kcal/kJ), total fat, saturated fat, trans fat, cholesterol, sodium, total carbohydrate, dietary fiber, total sugars, added sugars, protein, and micronutrients (vitamins A, C, D, calcium, iron, potassium) with unit of measure and analytical method. Supports FDA Nutrition Facts Panel and EU Regulation 1169/2011 nutritional declaration. Sourced from TraceGains and internal R&D lab data.' .

ind:TestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Laboratory test result and Certificate of Analysis record for raw material lots, capturing individual analytical test results, COA reference data, supplier COA receipt, and pass/fail disposition against specifications' .

ind:Cost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Single Source of Truth for all raw material pricing and cost data — current standard costs, contract prices, spot prices, AND complete historical purchase price records by supplier and purchasing organization. Captures standard cost per UOM, moving average price, last purchase price, planned price, contract price, spot price, index-linked price, invoice price, cost/price currency, validity period (from/to date), price type (standard, contract, spot, index-linked, historical), plant code, purchasing organization, supplier reference, commodity index reference (CME corn futures, ICE sugar, CBOT wheat), cost variance vs. standard, price variance vs. prior period, and price effective/expiry dates for time-series analysis. This is the SOLE authoritative source for both current and historical ingredient pricing — no other product in any domain stores raw material price records. Supports COGS calculation, formulation cost modeling, procurement negotiation benchmarking, commodity cost trend analysis, standard cost update cycles, and year-over-year price variance reporting. Sourced from SAP MM/CO standard cost estimates, purchase order history, and Oracle Procurement.' .

ind:FsmaTraceability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Fsma Traceability' ;
    rdfs:comment 'FSMA Section 204 Key Data Element (KDE) traceability record capturing Critical Tracking Events (CTEs) required for FDA Food Traceability Rule compliance for foods on the Food Traceability List (FTL). Captures CTE type (receiving, transformation, shipping), traceability lot code (TLC), TLC source reference, location description (FDA facility registration number, GLN), date of CTE, quantity and UOM, reference document type (BOL, PO, production record, ASN), reference document number, immediate previous source (IPS), and KDE data elements per FDA 21 CFR Part 1 Subpart S. This domain owns the ingredient-receiving CTE; manufacturing and distribution domains own transformation and shipping CTEs respectively. Enables 24-hour FDA traceability response capability as mandated by FSMA 204 (compliance deadline January 2026). Sourced from SAP Batch Management, TraceGains, and dedicated traceability platforms (FoodLogiQ, Rfxcel).' .

ind:ReligiousCert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ingredient ;
    rdfs:label 'Religious Cert' ;
    rdfs:comment 'Halal and Kosher certification record for a raw material from a specific supplier, capturing certification type (Halal, Kosher Pareve, Kosher Dairy, Kosher Meat, Kosher Passover), certifying body (Islamic Food and Nutrition Council, Orthodox Union, OK Kosher, Star-K, MUI, JAKIM), certificate number, certified scope, certificate issue date, certificate expiry date, renewal status, and digital certificate reference. Supports religious dietary compliance claims on finished goods and retailer/foodservice customer requirements.' .

ind:ProductionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Order' ;
    rdfs:comment 'Core manufacturing execution record representing a discrete production run, work order, or rework order issued against a finished goods SKU or semi-finished intermediate — serving as the complete lifecycle record from creation through confirmation and closure. Captures order type (standard, rework, trial), planned vs. actual quantities, scheduled start/end times, actual start/end times, production line assignment, shift, batch size, yield, scrap, rework quantities, order status (created, released, in-progress, confirmed, technically complete, closed), SAP PP production order number, MES work order reference, BOM version used, routing version, cost center, plant code, FIFO/FEFO lot consumption flags, rework reason code and originating order reference (if rework type), rework yield and disposition (if rework), confirmation number, confirmed quantity, yield variance percentage, scrap quantity confirmed, rework quantity confirmed, confirmation type (partial, final), goods movement document number, confirming operator ID, and confirmation datetime. Primary transactional anchor for manufacturing execution in SAP S/4HANA PP module. Rework orders are modeled as production orders with type=rework per SAP PP standard. Confirmations (CO11N) are lifecycle events on this entity — each production order carries its own confirmation records including partial and final confirmations, goods movements, and yield variance calculations.' .

ind:BatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Batch Record' ;
    rdfs:comment 'Electronic batch record (EBR) capturing the complete manufacturing history of a single production batch from raw material dispensing through finished goods release. Includes batch number (lot number), batch size, unit of measure, manufacturing date, expiry date, best-before date, shelf life days, batch status (in-process, pending QA, released, rejected, quarantine), GMP compliance flag, HACCP sign-off status, deviation count, operator IDs, line supervisor sign-off, co-packer flag, toll manufacturing flag, and regulatory hold indicator. Serves as the legal manufacturing record per FDA 21 CFR Part 211 and GMP requirements. Sourced from Aveva/Wonderware MES Batch Management module.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master data for all production work centers, lines, and cells within manufacturing plants. Captures work center code, description, plant, production area, line type (mixing, filling, packaging, pasteurization, fermentation, extrusion, co-packing), rated capacity (units/hour), standard cycle time, setup time, teardown time, OEE target, minimum run size, maximum run size, allergen capability flags, kosher/halal certification flag, clean-in-place (CIP) required flag, work center status (active, maintenance, decommissioned), and MES asset tag. SSOT for production line master data used in scheduling and OEE reporting. Sourced from SAP PP work center master and Aveva/Wonderware MES.' .

ind:ProductionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Schedule' ;
    rdfs:comment 'Forward-looking production schedule records generated by the planning system (SAP IBP / JDA Blue Yonder) and executed via MES. Captures schedule version, planning horizon, scheduled production order reference, work center assignment, SKU, planned quantity, scheduled start datetime, scheduled end datetime, schedule status (draft, firmed, released, executed, cancelled), schedule source (MRP, manual, IBP), changeover time allocated, sequence number on line, and last replanning timestamp. Enables sequencing optimization, changeover minimization, and OTIF performance tracking.' .

ind:HaccpCcpLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Haccp Ccp Log' ;
    rdfs:comment 'Real-time and operator-entered log of HACCP (Hazard Analysis Critical Control Points) critical control point (CCP) monitoring records for each production batch. Captures CCP identifier, CCP name (e.g., pasteurization temperature, metal detection, pH check, Brix measurement), production order, batch number, work center, monitoring timestamp, measured value, unit of measure, critical limit lower bound, critical limit upper bound, in-limit flag, corrective action required flag, corrective action taken description, verified by operator ID, and regulatory hold triggered flag. Mandatory for FDA FSMA compliance and GFSI certification. Sourced from Aveva/Wonderware MES and manual entry. SSOT boundary: This entity owns real-time CCP monitoring readings and corrective actions during production execution. The quality domain owns the HACCP plan definition, hazard analysis, and CCP validation/verification programs.' .

ind:LotConsumption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Lot Consumption' ;
    rdfs:comment 'Transactional records of raw material, ingredient, and packaging component lot consumption against production orders, implementing FIFO/FEFO inventory management. Captures production order, batch record, consumed material code, consumed lot number, consumption quantity, unit of measure, consumption timestamp, FIFO/FEFO sequence number, expiry date of consumed lot, warehouse storage location, consumption type (standard, rework, trial), variance from BOM quantity, and confirmation status. Provides full lot traceability from raw material to finished goods batch. Sourced from SAP S/4HANA MM goods movement and MES batch management.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Production routing master data defining the sequence of manufacturing operations (work center steps) required to produce a SKU. Captures routing number, routing version, SKU, plant, valid-from/to dates, routing status, total standard production time, and the ordered list of operations with their work center assignments, standard times (setup, machine, labor), and operation descriptions (e.g., mixing, pasteurization, filling, capping, labeling, palletizing). Sourced from SAP PP routing master. Distinct from the BOM (what goes in) — the routing defines how it is made and in what sequence.' .

ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master data for all manufacturing plants, co-packing facilities, and production sites operated or contracted by the business. Captures plant code, plant name, plant type (owned manufacturing, co-packer, toll manufacturer, pilot plant, R&D facility), address, country, region, plant manager, plant capacity (units/day), number of production lines, GMP certification status, GFSI scheme (SQF, BRC, FSSC 22000), certification expiry date, FDA registration number, USDA establishment number, kosher certification flag, halal certification flag, organic certification flag, plant status (active, idle, decommissioned), and ERP plant code. SSOT for manufacturing facility master data.' .

ind:EquipmentMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment Master' ;
    rdfs:comment 'Master data for all production equipment assets within manufacturing plants — filling machines, mixers, blenders, pasteurizers, extruders, packaging lines, labelers, metal detectors, checkweighers, and CIP systems. Captures equipment tag number, equipment name, equipment type, manufacturer, model, serial number, plant, work center assignment, installation date, commissioning date, rated capacity, current status (operational, under maintenance, decommissioned), preventive maintenance schedule reference, last calibration date, next calibration due date, calibration certificate number, OEE baseline target, and MES asset tag. SSOT for production equipment master data used in OEE, maintenance, and calibration tracking.' .

ind:Center rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Center' ;
    rdfs:comment 'Master record for each Distribution Center (DC) in the F&B network — physical facility attributes including location, type (ambient, refrigerated, frozen, cross-dock), storage capacity (pallet positions, cubic footage), temperature zones, dock door count, WMS system identifier, 3PL-managed flag, FDA facility registration number, GFSI certification status, and operational hours. SSOT for DC identity across the distribution domain.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all transportation carriers (TL, LTL, parcel, refrigerated, DSD fleet) used in outbound distribution. Captures SCAC code, DOT/MC number, carrier type, service modes, insurance certificates, FSMA Sanitary Transportation compliance status, cold chain capability flags, EDI capability, contracted rate tier, and performance tier classification. SSOT for carrier identity in the distribution domain.' .

ind:DeliveryRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Delivery Route' ;
    rdfs:comment 'Master definition and execution record for recurring outbound delivery routes used in DSD (Direct Store Delivery) and DC-to-customer distribution. Master attributes (relatively static, updated infrequently): route code, route type (DSD, DC-to-retail, foodservice, DTC), assigned territory, stop sequence template, estimated mileage, frequency, vehicle type requirement, cold chain requirement, and active status. Execution attributes (one record per route-day execution instance): execution date, driver, vehicle, start/end times, stops planned vs completed, cases loaded/delivered/returned/refused, cash/check collections, handheld device ID, and route completion status. The master portion defines the route template; execution instances capture daily operational performance against that template. SSOT for all route definition and route execution data in the distribution domain, including DSD operational performance. Supports route optimization, driver assignment, territory management, and DSD operational reporting.' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core outbound fulfillment order record representing a customer order released to the DC for picking, packing, and shipping. Captures fulfillment order number, source sales order reference, customer account, ship-to location, requested ship date, promised delivery date, fulfillment channel (retail, foodservice, DTC, DSD), order priority, wave/batch assignment, cross-dock flag, fulfillment status (released, wave-assigned, picking, packed, staged, shipped, delivered, exception), OTIF target flag, total order weight/cube, and any exception/disruption codes with resolution status. SSOT for outbound order execution lifecycle in the distribution domain.' .

ind:FulfillmentOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Fulfillment Order Line' ;
    rdfs:comment 'Line-level detail for each SKU within a fulfillment order. Captures line number, SKU/GTIN, ordered quantity (cases/eaches), confirmed quantity, UOM, lot number, expiration date, FEFO pick flag, catch-weight actual, line status, and any short-ship reason code. Enables lot traceability and FEFO compliance at the line level.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical shipment record consolidating one or more fulfillment orders onto a single carrier move, including load configuration details. Captures shipment number, carrier, service level, trailer/container number, seal number, origin DC, destination, scheduled/actual pickup and delivery datetimes, total weight, total cube, pallet count, utilization percentage, loading sequence, freight cost, temperature requirement (ambient/refrigerated/frozen), temperature zone segregation, and shipment status. Supports outbound logistics execution, carrier performance tracking, freight cost management, and cold chain compliance documentation.' .

ind:ProofOfDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Proof Of Delivery' ;
    rdfs:comment 'Electronic or paper Proof of Delivery (POD) record confirming receipt of goods at the customer location. Captures POD number, shipment reference, stop reference, delivery datetime, receiver name, receiver signature (digital), cases received, cases refused, refusal reason, temperature at delivery (cold chain), condition notes, and POD capture method (ePOD, paper scan, EDI 214). Critical for OTIF measurement, dispute resolution, and invoice matching.' .

ind:ColdChainEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Cold Chain Event' ;
    rdfs:comment 'Temperature monitoring event record for cold chain compliance during storage and transit. Captures event datetime, asset type (trailer, DC zone, reefer unit), asset identifier, sensor ID, recorded temperature (°F/°C), target temperature range (min/max), Brix or pH if applicable, excursion flag, excursion duration (minutes), corrective action taken, and FSMA/HACCP compliance status. Critical for food safety regulatory compliance and cold chain SLA management.' .

ind:OtifRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Otif Record' ;
    rdfs:comment 'On-Time In-Full (OTIF) performance measurement record capturing delivery performance against customer-committed windows at the shipment or fulfillment order level. Captures measurement date, customer account, retailer OTIF program (Walmart OTIF, Target In-Stock, Kroger OTD, Costco delivery compliance), shipment reference, fulfillment order reference, committed delivery window, actual delivery datetime, on-time flag, in-full flag, OTIF composite score, cases ordered, cases delivered, fill rate percentage, penalty/fine amount, chargeback reference, root cause code for misses (carrier delay, DC late release, inventory short, weather), and corrective action reference. Each record has an independent lifecycle: created at measurement, updated with root cause and corrective action, closed upon resolution or penalty payment. Supports retailer scorecard compliance, chargeback/penalty management, and continuous improvement programs.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Core master record representing the current stock balance for each material/SKU and lot at each storage location. Tracks stock categories (on-hand, available, reserved, in-transit, quality-inspection, blocked) and shelf life attributes (remaining days, SLED, BBD, expiry status). Serves as the single source of truth for real-time inventory balances across finished goods, WIP, and raw materials. Updated by every goods movement posting.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master reference for all physical and logical storage locations in the inventory network — plants, distribution centers, 3PL warehouses, cold storage facilities, staging areas, quarantine zones, and allergen-segregated zones. Captures location type, temperature zone (ambient, chilled, frozen), capacity, WMS location code, allergen segregation classification, and operational status. Enables location-level stock visibility and FEFO/FIFO enforcement.' .

ind:GoodsMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Movement' ;
    rdfs:comment 'Transactional record of every inventory state change — goods receipts, goods issues, stock transfers, returns postings, scrap disposals, write-offs, write-ups, reclassifications, cycle count adjustments, reconciliation corrections, and all other inventory adjustments. Each posting captures movement type, quantity, UoM, source/destination locations, lot reference, posting date, reference document, reason code, adjustment reason (for variance and correction postings), financial impact (debit/credit to inventory and COGS accounts), approver where required, and originating event reference (cycle count, quality inspection, production order, or manual correction). Serves as the single, authoritative audit trail for ALL inventory quantity and value changes — no other entity in this domain records stock state mutations. Foundation for inventory reconciliation, COGS postings, adjustment approval workflows, and regulatory traceability. Aligned with SAP MM movement types (101, 201, 301, 311, 551, 561, 701/702).' .

ind:StockTransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer Order' ;
    rdfs:comment 'Transactional record for planned and executed inter-location stock transfers — plant-to-plant, DC-to-DC, plant-to-DC, and 3PL replenishment transfers. Captures transfer order number, source and destination locations, material/SKU, lot/batch, requested quantity, confirmed quantity, transfer reason, priority, planned transfer date, actual shipment and receipt dates, temperature compliance flag, and transfer status (planned, released, in-transit, received, cancelled). Distinct from goods_movement: this entity represents the planning/execution document (the \'order\'), while goods_movement records the actual stock postings (issue at source, receipt at destination). Aligned with SAP WM Transfer Order (LT0A) and EWM Warehouse Task.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Master record for scheduled and ad-hoc physical inventory cycle count events at a storage location. Captures count plan reference, count type (full physical inventory, cycle count, spot check), scheduled date, actual count date, counter assigned, count status (planned, in-progress, completed, reconciled), and variance threshold. Aligned with SAP MI01/MI04 Physical Inventory Document. Supports continuous inventory accuracy programs and audit compliance.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Transactional record of inventory quantity and value adjustments resulting from cycle counts, quality holds, write-offs, scrap, and reconciliation corrections. Captures adjustment type (write-off, write-up, scrap, quality block, reclass), adjusted quantity, adjustment reason, financial impact (debit/credit to COGS or inventory account), approver, and reference to originating event (cycle count, quality inspection, or manual correction). Aligned with SAP MM inventory adjustment postings.' .

ind:Valuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Valuation' ;
    rdfs:comment 'Financial valuation record for inventory by material, plant, and valuation class. Captures valuation method (standard cost, moving average, FIFO), unit cost, total inventory value, price variance, and revaluation amounts. Supports COGS calculation, balance sheet inventory reporting, month-end close, and cost variance analysis.' .

ind:LotTrace rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot Trace' ;
    rdfs:comment 'Traceability record linking each lot/batch through its complete supply chain journey — from raw material receipt (supplier lot), through production (manufacturing batch), to finished goods lot and outbound shipment. Captures upstream lot references (ingredient lots, packaging lots), downstream lot references (finished goods lots, customer shipment lots), transformation events (production order, co-packing run), and traceability status. Supports FSMA one-up/one-down traceability requirements and recall execution.' .

ind:QuarantineHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Quarantine Hold' ;
    rdfs:comment 'Operational record for inventory placed under quality hold or quarantine status — pending quality inspection, regulatory hold, allergen cross-contact risk, or recall investigation. Captures hold type (quality inspection, regulatory, allergen, recall, supplier deviation), hold reason, quantity held, lot/batch reference, storage location, hold initiation date, expected review date, hold release date, disposition decision (release, rework, destroy, return to supplier), and authorizing quality manager. Aligned with SAP QM usage decision. Drives stock blocking in stock_position and triggers quality domain workflows.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Transactional record for inventory reservations that earmark specific stock quantities for planned consumption — production orders, sales orders, promotional allocations, or maintenance requirements. Captures reservation type, reserved quantity, requirement date, priority, and fulfillment status. Prevents double-allocation of constrained inventory and supports ATP (available-to-promise) calculations.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for all customer accounts across B2B and B2C channels — retailer accounts (grocery, mass, club, convenience), foodservice operators (QSR, casual dining, institutional), distributors, wholesalers, and DTC/e-commerce consumers. Each account has a unique business identity with attributes including account type, channel, status, credit rating, payment terms, assigned sales territory, key account flag, annual revenue band, and first-order date. The single authoritative source for \'who is our customer\' across all commercial systems.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contacts associated with B2B customer accounts — buyers, category managers, accounts payable contacts, foodservice operators, and DTC consumers. Stores full name, title, role, email, phone, preferred communication channel, opt-in/opt-out flags, and NPS survey eligibility. Sourced from Salesforce CRM Contact object.' .

ind:ShipToLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Ship To Location' ;
    rdfs:comment 'All ship-to delivery addresses for customer accounts — retail store locations, foodservice establishment addresses, DC receiving docks, and DTC consumer delivery addresses. Captures address, geolocation, delivery window constraints, dock requirements, temperature zone requirements (ambient, chilled, frozen), and active/inactive status. Supports OTIF and DSD routing.' .

ind:BillToLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Bill To Location' ;
    rdfs:comment 'Bill-to addresses and invoicing entities for customer accounts — corporate billing offices, AP departments, and DTC billing addresses. Stores billing address, invoicing currency, tax registration numbers (VAT/EIN), e-invoicing preferences, and EDI billing capability flags. Distinct from ship-to to support split billing scenarios common in retail and foodservice.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Parent-child hierarchy relationships for customer accounts — retail banner to store, foodservice chain to operator, distributor to sub-distributor, and corporate parent to subsidiary. Captures hierarchy level, parent account reference, hierarchy type (retail, foodservice, distributor), effective dates, and roll-up flags for ACV and TDP reporting. Enables consolidated reporting across account groups.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation taxonomy and account-to-segment assignment management — segment definitions (channel segment, tier classification, strategic priority, ACV band, Nielsen/IRI alignment) plus temporal assignment records linking accounts to segments with effective dating, assignment method (manual, rule-based, model-driven), primary segment flags, and assignment audit trail. Single product owns both the segment master data and the many-to-many account assignments. Supports trade promotion targeting, pricing strategy differentiation, demand planning segmentation, and account evolution tracking across the F&B customer lifecycle.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Credit and payment terms profile for B2B customer accounts — credit limit, credit rating, payment terms (Net 30, Net 60, COD), credit hold status, credit review date, outstanding balance threshold, Dun & Bradstreet rating, and credit insurance coverage. Sourced from SAP S/4HANA FI credit management and Oracle Cloud Financials.' .

ind:SegmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment Assignment' ;
    rdfs:comment 'Association table linking customer accounts to their active segment classifications with effective dating — segment assignment date, assigned-by user, assignment method (manual, rule-based, model-driven), effective start and end dates, and primary segment flag. Supports temporal segmentation changes as accounts evolve across channels and tiers.' .

ind:EdiTradingPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Edi Trading Partner' ;
    rdfs:comment 'EDI trading partner configuration for B2B customers — EDI partner ID, EDI standard (ANSI X12, EDIFACT), supported transaction sets (850 PO, 855 PO Ack, 856 ASN, 810 Invoice), communication protocol (AS2, SFTP, VAN), test vs production flag, EDI contact, and onboarding status. Manages electronic commerce connectivity for retail and distributor accounts.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Data privacy and marketing consent records for DTC and B2C consumers — consent type (marketing email, SMS, push notification, data sharing, profiling), consent status (granted, withdrawn, pending), consent date, withdrawal date, consent source (web form, mobile app, in-store), regulatory jurisdiction (GDPR, CCPA, CASL), and consent version. Supports FDA, FTC, and global privacy compliance obligations.' .

ind:PromotionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Promotion Plan' ;
    rdfs:comment 'Master record for trade promotion plans created by sales/trade marketing teams. Defines the complete promotional event including promotion type (TPR, display, feature ad, BOGO, scan-back), planned start/end dates, target retailer accounts, participating SKUs, funding source, promotional mechanic, approval status, and volume/ROI forecast. Includes planning-stage forecasts: baseline volume, incremental lift estimate, total promoted volume, net revenue impact, trade spend investment, estimated ROI, forecast method (statistical model, historical analogy, sales rep input), and forecast version. Serves as the authoritative header for all downstream execution, accrual, deduction, and settlement tracking. Sourced from SAP S/4HANA SD, TPM modules, and SAP IBP demand sensing.' .

ind:PromotionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Promotion Event' ;
    rdfs:comment 'Transactional record capturing the execution of a trade promotion event at a specific retailer account and store cluster. Tracks actual execution dates, participating store count, promotional mechanic deployed (e.g., end-cap display, circular feature, TPR shelf tag), compliance status, and field execution confirmation. Links to the parent promotion plan and captures variance between planned and actual execution. Sourced from Salesforce CRM Sales Cloud and field execution data.' .

ind:PromotionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Promotion Line' ;
    rdfs:comment 'Line-item detail within a trade promotion plan representing a specific SKU or product group included in the promotion. Captures planned promotional price, off-invoice allowance rate, scan-back rate, bill-back rate, planned volume lift, baseline volume, incremental volume target, and funding amount per unit. Enables SKU-level trade spend allocation and ROI measurement. Sourced from SAP S/4HANA SD condition records and TPM line detail.' .

ind:Fund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Fund' ;
    rdfs:comment 'Master record for trade spending funds and budgets allocated to retailer accounts, sales territories, or brand/category buckets. Tracks fund type (lump sum, accrual-based, fixed allowance), total approved budget, amount committed to promotion plans, amount accrued, amount paid, and remaining balance. Supports trade spend governance and budget control. Sourced from SAP S/4HANA CO and TPM fund management modules.' .

ind:Accrual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Accrual' ;
    rdfs:comment 'Transactional record capturing trade promotion accruals — the financial liability recognized as products are sold under a promotional agreement. Tracks accrual type (off-invoice, bill-back, scan-back, lump sum), accrual rate, accrual basis (per case, per unit, percentage of net sales), accrual period, accrued amount, reversal status, and GL posting reference. Critical for accurate P&L and COGS reporting. Sourced from SAP S/4HANA FI/CO accrual engine.' .

ind:Deduction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Deduction' ;
    rdfs:comment 'Transactional record for all trade-related deductions taken against invoices by retail customers and distributors — including short payments, promotional claims, chargebacks reconciling contracted vs. list price differences, and unauthorized deductions requiring resolution.' .

ind:RetailerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Retailer Agreement' ;
    rdfs:comment 'Master record for formal trade agreements with retail customers including annual joint business plans (JBPs), volume rebate agreements, promotional calendars, EDLP pricing commitments, and category captain agreements. Captures agreement type, effective dates, retailer account, committed volume targets, promotional event count, funding commitments, performance thresholds, and penalty/bonus clauses. Contains granular line-item terms as child records: each term specifies type (volume rebate tier, promotional funding rate, EDLP price commitment, display compliance requirement, scan-back rate, co-op advertising allowance, MDF allocation), applicable SKU or category scope, threshold conditions, rate or amount, measurement period, and compliance measurement method. Supports multi-term agreement governance, compliance monitoring, and earned income calculation. SSOT for all retailer commercial terms. Sourced from Salesforce CRM and SAP S/4HANA SD contracts.' .

ind:AgreementTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Agreement Term' ;
    rdfs:comment 'Line-item detail of specific commercial terms within a retailer agreement. Each record captures a single term type (volume rebate tier, promotional funding rate, EDLP price commitment, display compliance requirement, scan-back rate, co-op advertising allowance), the applicable SKU or category scope, threshold conditions, rate or amount, and measurement period. Enables granular tracking of multi-term retailer agreements and compliance monitoring.' .

ind:VolumeRebate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Volume Rebate' ;
    rdfs:comment 'Transactional record for volume-based rebates earned by retail customers upon achieving purchase volume thresholds defined in retailer agreements. Captures rebate program reference, measurement period, actual volume purchased, threshold tier achieved, rebate rate, earned rebate amount, payment method (credit memo, check, off-invoice), and settlement status. Supports accurate rebate liability accrual and settlement. Sourced from SAP S/4HANA SD rebate processing.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Transactional record for the financial settlement of trade promotion claims and deduction resolutions — the actual payment or credit issued to close a validated promotional claim, resolve a retailer deduction, or pay a volume rebate. Captures settlement type (credit memo, check, off-invoice deduction, wire transfer), settlement amount, original claim/deduction amount, variance, settlement date, payment reference, GL account, cost center, profit center, reconciliation status, and approval workflow state. Bridges trade promotion execution and accounts receivable/payable. Enables trade spend close-out reporting and period-end reconciliation. Sourced from SAP S/4HANA FI.' .

ind:PromotionClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Promotion Claim' ;
    rdfs:comment 'Transactional record for retailer-submitted promotional claims requesting reimbursement for executed trade promotions. Captures claim type (scan data, bill-back, off-invoice reconciliation), retailer account, promotion reference, claim period, claimed volume, claimed amount, supporting documentation reference, validation status, approved amount, rejection reason, and dispute flag. Central to the trade deduction management and claim validation workflow. Sourced from SAP S/4HANA SD and EDI claim transactions.' .

ind:SpendBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Trade ;
    rdfs:label 'Spend Budget' ;
    rdfs:comment 'Master record for all trade spending funds and budgets — the single source of truth for financial governance of trade investments. Encompasses annual brand/category/channel budgets, retailer account fund allocations, territory-level funds, and promotion-type-specific pools. Captures budget period, scope (brand, category, channel, customer tier), total approved budget, budget by promotion type (TPR, display, feature, slotting, co-op), phasing by period, fund type (lump sum, accrual-based, fixed allowance), committed amount, accrued amount, paid amount, remaining balance, budget owner, approval status, and last revision date. Supports real-time trade spend governance, promotion plan approval guardrails, and budget vs actual variance reporting. Sourced from SAP S/4HANA CO, TPM fund management modules, and Oracle Cloud Financials.' .

ind:EstablishmentRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Establishment Registration' ;
    rdfs:comment 'Master record of all FDA/USDA facility registrations for Food Beverage manufacturing plants, co-packers, and storage facilities. Captures FDA registration numbers, USDA establishment numbers, facility type, registration status, renewal dates, and applicable regulatory programs (FSMA, HACCP, SQF). Serves as the authoritative SSOT for all government-registered facilities.' .

ind:FacilityInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Facility Inspection' ;
    rdfs:comment 'Transactional records of all regulatory inspections conducted at Food Beverage facilities by FDA, USDA, EFSA, state agencies, and third-party GFSI auditors. Captures inspection date, inspector identity, inspection type (routine, for-cause, pre-approval), findings, observations (483s), corrective action deadlines, and final disposition. Links to establishment_registration.' .

ind:NutritionLabel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Nutrition Label' ;
    rdfs:comment 'Master record of approved Nutrition Facts Panel data for each SKU, compliant with 21 CFR Part 101. Stores serving size, calories, macro and micronutrient values, daily value percentages, allergen declarations, and label format version. Tracks FDA-mandated label updates and country-specific nutritional labeling variants (US, EU, Canada). SSOT for all nutrition label content.' .

ind:FsmaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Fsma Record' ;
    rdfs:comment 'FSMA-mandated recordkeeping entries covering all Food Safety Modernization Act programs: Preventive Controls for Human Food (21 CFR Part 117), Produce Safety Rule (21 CFR Part 112), Foreign Supplier Verification Program (FSVP, 21 CFR Part 1 Subpart L), Intentional Adulteration (21 CFR Part 121), and FDA Food Traceability Rule (21 CFR Part 204). Captures record type (preventive control verification, supplier verification, produce safety inspection, FSVP hazard analysis, IA vulnerability assessment), associated facility or supplier, importer of record (for FSVP), record date, responsible qualified individual, verification activity performed, verification frequency, and retention period. Consolidates all FSMA program recordkeeping into a single product with record_type discriminator.' .

ind:ProductRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Product Registration' ;
    rdfs:comment 'Country-level product registration and market authorization records for Food Beverage SKUs sold in regulated markets. Captures registration number, issuing authority (FDA, EFSA, Health Canada, ANVISA), registration status, approval date, expiry date, product category, and applicable regulatory dossier reference. Manages multi-country registration lifecycle for new product launches and reformulations.' .

ind:LabelApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Label Approval' ;
    rdfs:comment 'Workflow and approval records for all product label artwork, packaging copy, and packaging material compliance across all Food Beverage SKUs and markets. Tracks label version, submission date, regulatory reviewer, approval status, rejection reasons, required changes, final approval date, and effective date. Manages USDA pre-approval for meat/poultry labels, FDA label compliance sign-off, and nutrition facts panel verification. Covers allergen declaration accuracy, marketing claim regulatory basis, and ingredient statement compliance. Includes full packaging material regulatory compliance: EPA packaging requirements, EU Directive 94/62/EC heavy metal limits, recycled content percentage tracking, recyclability classification, extended producer responsibility (EPR) registration and state-level compliance, FTC Green Guides compliance for environmental marketing claims, and sustainability claims substantiation. Captures packaging component material type, compliance test results, and certification status. Links to nutrition_label and allergen_declaration. SSOT for all label and packaging regulatory approvals.' .

ind:ImportExportPermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Import Export Permit' ;
    rdfs:comment 'Trade compliance master for cross-border movement of Food Beverage products and raw materials. Consolidates import/export permits, phytosanitary certificates, country-of-origin declarations (COOL/USDA 7 CFR Part 60), Harmonized System tariff classifications (HS/HTS/CN codes), preferential trade agreement eligibility, customs documentation, and duty rate management. Captures permit type, issuing authority, origin/destination countries, commodity description, tariff codes with classification ruling references, applicable duty rates, country-of-origin determination method (substantial transformation, COOL rules), permit validity, and shipment references. Supports FDA Prior Notice, CBP entry compliance, Free Trade Agreement qualification, and origin substantiation for labeling. SSOT for all trade compliance and customs data.' .

ind:PackagingCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Packaging Compliance' ;
    rdfs:comment 'EPA and EU packaging compliance records for Food Beverage product packaging materials. Captures packaging component, material type, recyclability classification, recycled content percentage, heavy metal compliance (EU Directive 94/62/EC), extended producer responsibility (EPR) registration, state-level compliance status, and sustainability claims substantiation. Supports FTC Green Guides compliance for environmental marketing claims.' .

ind:RecallEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Recall Event' ;
    rdfs:comment 'Master record of product recall and market withdrawal events initiated voluntarily or mandated by FDA/USDA. Captures recall classification (Class I/II/III), recall reason (allergen, contamination, mislabeling), affected SKUs and lot numbers, distribution scope, recall strategy, press release reference, agency notification date, and recall effectiveness check status. SSOT for all recall lifecycle management.' .

ind:GfsiCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Gfsi Certification' ;
    rdfs:comment 'GFSI scheme certification records for Food Beverage facilities, including SQF, BRC, FSSC 22000, IFS, and GlobalG.A.P. certifications. Captures certification body, scheme version, scope, certification grade/level, issue date, expiry date, surveillance audit schedule, and certificate document reference. Tracks multi-site certification status and customer-required certification compliance.' .

ind:FoodSafetyPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Food Safety Plan' ;
    rdfs:comment 'Unified food safety plan master records covering both FSMA Preventive Controls (21 CFR Part 117) and USDA HACCP (9 CFR Part 417) requirements for each facility and product category. Documents hazard analysis, critical control points, preventive controls (process, allergen, sanitation, supply chain), critical limits, monitoring procedures, corrective action procedures, verification activities, and recall plan reference. Captures plan type (HACCP, Preventive Controls, combined), plan version, qualified individual sign-off, approval status, last review date, and reanalysis schedule. SSOT for all facility-level food safety documentation.' .

ind:HaccpPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Haccp Plan' ;
    rdfs:comment 'Master record for Hazard Analysis and Critical Control Points (HACCP) plans per production facility and product category, including all associated process validation, cleaning validation, and equipment qualification studies. Captures plan version, scope, hazard categories (biological, chemical, physical, radiological), regulatory basis (FDA FSMA Preventive Controls, USDA FSIS HACCP, Codex Alimentarius), approval status, effective dates, and responsible food safety team. Includes validation records: validation type (process/thermal, cleaning/CIP, equipment IQ/OQ/PQ, aseptic), scope, protocol reference, execution dates, acceptance criteria, test results summary, statistical confidence level, outcome (validated/failed), revalidation trigger conditions, and approval authority. Covers allergen changeover cleaning validation. SSOT for HACCP program governance, preventive control validation, process/cleaning/equipment qualification, and food safety plan management across all manufacturing sites.' .

ind:CriticalControlPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Critical Control Point' ;
    rdfs:comment 'Master entity defining each Critical Control Point (CCP) within a HACCP plan, plus all associated real-time monitoring observations recorded during production. Records the CCP number, process step, hazard type, critical limits (temperature, pH, Brix, water activity, time, metal detector sensitivity), monitoring method, monitoring frequency, corrective action procedure, verification activity, and responsible operator. Monitoring records capture each observation: batch/lot, timestamp, measured value, critical limit comparison, pass/fail result, operator ID, equipment/sensor ID, and deviation trigger with escalation path. Linked to the parent HACCP plan and specific production line. SSOT for CCP definition and all CCP monitoring data. Supports real-time food safety control and FSMA regulatory traceability.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'SAP QM-aligned entity representing quality inspection lots, their characteristic-level results, and statistical evaluations. Captures lot number, inspection type (incoming, in-process, final release), material/SKU, batch, plant, quantity, usage decision (accept/reject/hold), and stock posting outcome. Includes individual characteristic results: measured values (moisture, fat, pH, microbial count, organoleptic score), specification limits, valuation, inspection method, equipment used, and inspector. Supports statistical process control (SPC) with control charts, Cp/Cpk calculations, lot disposition decisions, and full quality inspection traceability across the supply chain. SSOT for all quality inspection events and measurements.' .

ind:NonConformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Non Conformance' ;
    rdfs:comment 'Master record for all quality non-conformance events (NCRs), customer/consumer complaints, and product hold/containment actions. Captures NCR number, source (in-process, supplier, customer complaint, consumer hotline, audit finding, CCP deviation), affected SKU/batch/lot, defect type, complaint details (category, channel — call center, retailer, social media, DTC — description, investigation status, resolution), severity classification, regulatory reportability (FDA MedWatch, USDA, Reportable Food Registry), hold/containment details (hold type, warehouse location, segregation status, hold duration, disposition authority), disposition decision (release, rework, scrap, return to supplier, hold, destroy), root cause category, and originating inspection lot or CCP deviation. SSOT for all quality failures, deviations, complaints, containment holds, and disposition actions across the enterprise.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) master record linked to non-conformances, audit findings, customer complaints, or CCP deviations. Captures CAPA number, type (corrective/preventive), root cause analysis method (5-Why, Fishbone), root cause description, corrective actions defined, preventive actions defined, responsible owner, target completion date, actual completion date, effectiveness verification method, and closure status. Managed within Veeva Vault QMS.' .

ind:MicroTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Micro Test Result' ;
    rdfs:comment 'Transactional record for microbiological testing including sample tracking and laboratory results. Covers sample registration (source, SKU/material, lot/batch, collection point, chain of custody, lab assignment, test panel requested) and test results (test method per AOAC/ISO/USDA FSIS, target organism — Salmonella, Listeria, E. coli O157:H7, TPC, Yeast & Mold — CFU count or presence/absence, detection limit, incubation conditions, lab accreditation, pass/fail). Applies to raw materials, WIP, finished goods, environmental swabs, and water samples. Critical for FSMA Preventive Controls and HACCP verification. SSOT for all microbiological sample-to-result tracking.' .

ind:FoodSafetyAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Food Safety Audit' ;
    rdfs:comment 'Master record for food safety and quality system audits (SQF, BRC, FSSC 22000, ISO 22000, GFSI-benchmarked schemes, internal audits, regulatory inspections), all findings, and the QMS controlled document library. Captures audit ID, type, certification scheme, auditing body, facility, date range, lead auditor, scope, overall grade, certification outcome, certificate number/expiry, and next audit due date. Includes finding-level detail: finding type (major NC, minor NC, observation, OFI), clause reference, description, risk level, required corrective action, response due date, and closure status. Manages QMS controlled documents: document ID, type (SOP, work instruction, form, policy, specification, HACCP plan, validation protocol), title, version, effective/expiry dates, owner, approval workflow, training requirement flag, and applicable sites. SSOT for audit management, certification status, GFSI scheme compliance, and QMS document governance per ISO 9001 Clause 7.5.' .

ind:Specification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Master record defining quality specifications for finished goods, raw materials, packaging, and WIP. Managed via TraceGains and SAP QM. Captures specification ID, material/SKU, specification type (finished product, raw material, packaging), version, effective date, physical parameters (weight, dimensions, color), chemical parameters (pH, Brix, moisture, fat, protein, sodium), microbiological limits (TPC, Salmonella, Listeria), organoleptic standards, and approval status. SSOT for quality acceptance criteria.' .

ind:CustomerComplaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Customer Complaint' ;
    rdfs:comment 'Transactional record for consumer and trade customer quality complaints received through all channels (call center, retailer, social media, DTC). Captures complaint ID, complaint source, product/SKU, batch/lot number, complaint category (foreign material, off-flavor, packaging defect, illness, labeling error), complaint description, severity, regulatory reportability flag (FDA MedWatch, USDA), investigation status, root cause, resolution action, and closure date. Supports FSMA reportable food registry obligations.' .

ind:ProductRecall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Product Recall' ;
    rdfs:comment 'Master record for product recall and withdrawal events. Captures recall ID, recall type (Class I, II, III per FDA / voluntary withdrawal), triggering event (micro failure, allergen mislabel, foreign material, regulatory action), affected SKUs, affected lot/date codes, quantity affected, distribution scope, recall initiation date, FDA/USDA notification date, press release issued flag, retailer notification status, product recovery quantity, and recall closure date. SSOT for recall management and regulatory reporting.' .

ind:SupplierQualityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Supplier Quality Assessment' ;
    rdfs:comment 'Transactional record for supplier quality evaluations and approved supplier assessments conducted by the quality team. Captures assessment ID, supplier, material/ingredient category, assessment type (questionnaire, on-site audit, desk review, third-party certificate review), assessment date, SQF/BRC/FSSC 22000 certification status, food safety score, quality score, approved supplier list (ASL) status, risk tier, and re-assessment due date. Supports TraceGains supplier compliance management.' .

ind:HoldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Hold Record' ;
    rdfs:comment 'Transactional record for product holds (quality, micro, allergen, regulatory, customer complaint) placed on finished goods, WIP, or raw materials pending quality disposition. Captures hold type, affected material/SKU, lot/batch, quantity, hold initiation date, reason, warehouse location, disposition decision (release, rework, destroy, return to supplier), disposition date, and authorizing quality manager. Integrates with warehouse management for physical segregation and supports FIFO/FEFO inventory management, lot traceability, and regulatory containment requirements.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Order' ;
    rdfs:comment 'Complete sales order document capturing all commercial sales transactions across retail, foodservice, and DTC channels, including both header-level and line-level detail in a single authoritative record. Header: order number, order date, requested delivery date, order type (standard, rush, blanket, standing), order status, channel, customer account reference, ship-to and bill-to locations, currency, payment terms, incoterms, total order value, EDI 850 reference, and ERP sales document number. Lines: line number, SKU/GTIN, ordered quantity, unit of measure (case, each, pallet), confirmed quantity, shipped quantity, open quantity, list price, net price after trade allowances, discount amount, line status, requested ship date, scheduled ship date, plant/DC assignment, batch number for FEFO compliance, and revenue recognition flag. SSOT for all outbound sales order commitments within the sales domain.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Complete commercial invoice document issued to customers upon shipment or delivery of goods, capturing both header-level and line-level detail in a single authoritative billing record for revenue recognition. Header: invoice number, invoice date, invoice type (standard, credit memo, debit memo, intercompany), customer account, billing address, currency, subtotal, trade discount, freight, tax, total amount, payment terms, EDI 810 reference, and SAP SD billing document number. Lines: line number, SKU/GTIN, billed quantity, unit of measure, list price, invoice unit price, line discount, line net amount, tax code, cost center, profit center, GL account code, and revenue category (gross sales, trade spend, net revenue). SSOT for accounts receivable origination within sales domain; finance domain owns downstream AR aging and collections.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Master commercial agreement between Food Beverage and a customer (retailer, foodservice operator, distributor) governing pricing, volume commitments, promotional terms, slotting fees, and service levels. Captures contract number, contract type (volume rebate, pricing agreement, distribution agreement, co-packing agreement, slotting agreement), effective dates, contracted volume, RSP commitments, EDLP pricing tiers, payment terms, exclusivity clauses, auto-renewal flag, and Salesforce CRM opportunity reference. For slotting-type contracts: includes retailer account, SKU/GTIN, store count, fee per store, total commitment, payment schedule, shelf section, launch date, minimum shelf duration, and velocity-based performance clauses. ADR: Slotting agreements are modeled as a contract_type within this product (not as a separate entity) because they are negotiated by sales/category teams during new item sell-in and directly tied to distribution point creation. Trade domain owns broader promotional agreements (TPM/TPO); this product owns the commercial commitment for shelf placement fees. Commission/incentive compensation calculation is owned by the finance/workforce domain; sales provides quota attainment data as input.' .

ind:Rep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rep' ;
    rdfs:comment 'Sales force master record for field sales representatives, key account managers, and broker/agent personnel responsible for managing customer relationships and driving revenue. Captures rep ID, full name, rep type (field sales, key account manager, national account manager, broker, DSD driver), assigned territory, assigned customer accounts, sales region, sales district, quota (annual revenue and case volume), manager reference, employment status, Salesforce CRM user ID, and SAP SD sales employee number. SSOT for sales force identity within the sales domain.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic and account-based sales territory definition used to assign sales reps, set quotas, and measure performance. Captures territory code, territory name, territory type (geographic, account-based, channel-based), region, district, country, state/province list, assigned channel (retail, foodservice, DTC), ACV (All Commodity Volume) coverage target, TDP (Total Distribution Points) target, number of assigned accounts, effective start and end dates, and territory manager reference. Enables territory planning, quota allocation, and sales performance measurement.' .

ind:Quota rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quota' ;
    rdfs:comment 'Sales quota assignment record defining revenue, volume, and distribution targets for a sales rep or territory over a defined period. Captures quota period (month, quarter, year), quota type (revenue, case volume, new distribution points, TDP), assigned rep or territory, target value, stretch target value, quota currency, quota status (draft, approved, active), approval date, approver reference, and quota source (top-down allocation, bottom-up submission). Enables sales performance management and incentive compensation calculation.' .

ind:PosTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Pos Transaction' ;
    rdfs:comment 'Point-of-sale scan data record capturing consumer purchase activity at the retail store level, sourced from retailer POS feeds, syndicated data providers (Nielsen/IRI/Circana/SPINS), and direct retailer data sharing programs (e.g., Walmart Luminate, Kroger 84.51°). Captures store ID, retailer banner, UPC/GTIN, transaction date/week, units sold, dollar sales, average retail price, promoted/display/feature flags, and data source. SSOT for raw/ingested POS scan data within the enterprise; analytics and insights domains consume this data for derived metrics (market share, promotional lift, price elasticity) but do not own the source records. Enables sell-through velocity analysis, promotional lift measurement, share tracking, and category management insights at the store-week-SKU grain.' .

ind:DistributionPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Distribution Point' ;
    rdfs:comment 'SSOT for SKU-level distribution presence, measurement, and periodic syndicated metric snapshots at retail and foodservice locations. Captures store/outlet ID, retailer banner, SKU/GTIN, distribution status (authorized, active, voided), ACV weighted distribution percentage, TDP (Total Distribution Points) contribution, numeric distribution percentage, velocity (units per point of distribution), in-stock status, void date, and periodic snapshot data by time period (weekly, 4-week, 13-week, 52-week) including snapshot date, market area, data source (Nielsen/IRI/Circana), and period-over-period change metrics. Enables distribution health monitoring, new item launch tracking, void management, TDP target attainment reporting, ACV trend analysis, and syndicated data reconciliation. Subsumes all periodic ACV/TDP snapshot reporting previously modeled separately.' .

ind:Broker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Broker' ;
    rdfs:comment 'Master record for food and beverage sales brokers and manufacturer representatives who sell Food Beverage products on behalf of the company in specific channels or geographies. Captures broker ID, broker company name, broker type (retail broker, foodservice broker, DSD broker, export agent), coverage territory, covered channels, covered customer accounts, commission rate structure, commission basis (gross sales, net sales, cases), contract effective dates, performance tier, primary contact, and SAP vendor number. SSOT for broker identity and commercial terms within the sales domain; customer domain owns the broader customer/partner entity but sales owns the broker-as-selling-agent relationship, commission structures, and performance management. Enables broker management, commission calculation, and channel coverage governance.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Bank account master record for all Food Beverage corporate bank accounts used in payment processing, cash pooling, and treasury management. Captures bank key, account number, IBAN, SWIFT/BIC, bank name, country, currency, account type (operating, payroll, concentration, investment), GL reconciliation account, daily balance, and status. Governs cash position reporting, payment file generation, and bank reconciliation across F&B global operations.' .

ind:RebateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rebate Agreement' ;
    rdfs:comment 'Customer rebate agreement master record defining volume-based or growth-based rebate programs offered to retail and foodservice accounts — captures agreement terms, qualifying thresholds, rebate percentages, settlement frequency, and accrual method' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Distribution ;
    rdfs:label 'Location' ;
    rdfs:comment 'Master reference table for location. Referenced by ship_from_location_id.' .

ind:ProductionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Master reference table for production_line. Referenced by production_line_id.' .

ind:Market rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Market' ;
    rdfs:comment 'Master reference table for market. Referenced by market_id.' .

ind:Store rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Store' ;
    rdfs:comment 'Master reference table for store. Referenced by store_id.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Category' ;
    rdfs:comment 'Master reference table for category. Referenced by category_id.' .

ind:ContractStoreCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Contract Store Coverage' ;
    rdfs:comment 'This association product represents the Contract between sales_contract and store. It captures the specific stores covered under a master sales contract (chain-wide slotting, EDLP, or distribution agreement) and the per-store financial and operational terms. Each record links one sales_contract to one store with attributes that exist only in the context of this relationship, such as per-store fees, effective dates, and minimum shelf duration commitments.. Existence Justification: In Food & Beverage retail, master sales contracts (chain-wide slotting agreements, EDLP pricing agreements, distribution agreements) routinely cover multiple stores within a retail chain, and each store participates in multiple contracts simultaneously (e.g., a store may be covered by a slotting agreement for Brand A, an EDLP agreement for Brand B, and a promotional agreement for Brand C). The business actively manages contract-store coverage as a recognized operational entity in trade spend management systems, tracking per-store fees, coverage dates, and shelf duration commitments.' .

ind:CampaignClaimUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Claim Usage' ;
    rdfs:comment 'This association product represents the deployment of marketing claims within specific campaigns. It captures which regulatory-approved claims (e.g., Non-GMO, Gluten-Free, Heart Healthy) are used in which marketing campaigns, along with channel-specific compliance tracking, effective dates, and creative version references. Each record links one campaign to one claim with attributes that exist only in the context of this claim deployment relationship. Supports FTC/FDA compliance tracking and marketing legal review workflows.. Existence Justification: In F&B marketing operations, campaigns routinely deploy multiple regulatory-approved claims (e.g., a Summer Refresh campaign may feature Non-GMO, Gluten-Free, and Heart Healthy claims across different SKUs and channels), and individual claims are reused across multiple campaigns over time (e.g., the Non-GMO claim appears in brand awareness campaigns, product launch campaigns, and trade promotions). Marketing legal teams actively manage claim deployment as a distinct compliance process, tracking which claims are approved for which campaigns, on which channels, with campaign-specific effective dates and creative version references.' .

ind:CycleCountItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count Item' ;
    rdfs:comment 'This association product represents the physical inventory count line item linking a cycle count event to a specific stock position. It captures the system quantity, counted quantity, variance, and count status for each SKU/lot counted during the cycle count event. Each record represents one stock position being counted as part of one cycle count, with attributes that exist only in the context of this specific count activity. Aligned with SAP MI01 Physical Inventory Document Item.. Existence Justification: In warehouse inventory operations, a cycle count event physically verifies multiple stock positions (SKU/lot/location combinations), and each stock position is counted across multiple cycle count events over time for continuous accuracy verification. The cycle count line item is a well-established operational business entity in SAP WM/EWM (Physical Inventory Document Item) that warehouse workers actively create during count execution, supervisors review for variance approval, and auditors query for compliance verification.' .

ind:HaccpPlanSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Haccp Plan Specification' ;
    rdfs:comment 'This association product represents the regulatory linkage between HACCP plans and quality specifications. It captures the formal relationship between hazard control plans and the critical limit specifications they reference. Each record links one HACCP plan to one specification with effective dates, version tracking, and hazard category mapping that exist only in the context of this regulatory compliance relationship.. Existence Justification: In food manufacturing operations, HACCP plans reference multiple quality specifications to define critical limits for different hazard control points (e.g., temperature specs for thermal processing, pH specs for acidified foods, microbial limits for finished products), and each specification is referenced by multiple HACCP plans across different facilities, product lines, and process stages. The FDA FSMA Preventive Controls rule and USDA HACCP regulations require documented, version-controlled linkage between HACCP hazard analyses and the specifications that define critical limits, making this a regulatory compliance requirement that food safety teams actively manage.' .

# --- Attribute Properties ---
ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Unique surrogate identifier for each brand record in the Food Beverage portfolio. Primary key for the brand master data product. Serves as the enterprise-wide SSOT reference for brand identity across PLM, ERP, CRM, and marketing systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:contractManufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Contract Manufacturer Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Food & beverage brands frequently use contract manufacturers/co-packers to produce products. Tracks primary manufacturing supplier for brand quality audits, FSMA traceability, supplier performance rev' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:foodSafetyPlanId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Plan Id' ;
    rdfs:comment 'Foreign key linking to regulatory.food_safety_plan. Business justification: Each brand operates under a food safety plan governing its manufacturing processes. Critical for FSMA compliance, brand risk management, and linking marketing claims to validated safety controls. Supp' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyPlan .

ind:marketId rdf:type rdf:Property ;
    rdfs:label 'Market Id' ;
    rdfs:comment 'Foreign key linking to marketing.market. Business justification: brand.primary_market is a denormalized string representing the brand\'s primary geographic market. Adding market_id FK to the market reference table normalizes this to the authoritative market master, ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Market .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Brand performance is aggregated in profit centers for P&L reporting; FK enables profit-center level analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:targetConsumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Brand strategy defines a target consumer segment; FK replaces the denormalized segment name, enabling segment-based budgeting and compliance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:allergenFreeClaims rdf:type rdf:Property ;
    rdfs:label 'Allergen Free Claims' ;
    rdfs:comment 'Comma-separated list of allergen-free claims associated with the brand (e.g., \'gluten-free, nut-free, dairy-free\'). Derived from the allergen matrix managed in TraceGains. Must comply with FDA FALCPA (Food Allergen Labeling and Consumer Protection Act) and FSMA requirements. Used in consumer marketing and retail planogram placement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget' ;
    rdfs:comment 'Total approved annual marketing investment budget allocated to the brand, expressed in the functional currency. Includes above-the-line (ATL) advertising, below-the-line (BTL) shopper marketing, digital, and trade promotion spend. Confidential financial data managed in Oracle Cloud ERP Financials and SAP CO cost centers.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the brand within the corporate brand architecture hierarchy. \'masterbrand\' = umbrella brand covering multiple product lines; \'sub_brand\' = brand operating under a masterbrand; \'endorsed\' = independent brand with parent brand endorsement; \'standalone\' = fully independent brand; \'private_label\' = retailer-owned brand manufactured by Food Beverage under co-packing or toll manufacturing arrangements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessPct rdf:type rdf:Property ;
    rdfs:label 'Awareness Pct' ;
    rdfs:comment 'Unaided or total brand awareness percentage among the target consumer segment, expressed as a value between 0.00 and 100.00. Sourced from Nielsen/IRI consumer panel studies or commissioned brand health tracking research. Key input to brand equity score calculation and marketing investment justification.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary consumer product category to which the brand belongs (e.g., \'Snacks\', \'Beverages\', \'Dairy\', \'Packaged Foods\', \'RTD Coffee\', \'RTE Cereals\'). Aligns with Nielsen/IRI/SPINS syndicated data category taxonomy for market tracking and ACV/TDP reporting. [ENUM-REF-CANDIDATE: snacks|beverages|dairy|packaged_foods|rte_cereals|rtd_beverages|condiments|frozen_foods|confectionery|other — promote to reference product]' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the brand, used across SAP S/4HANA, Oracle ERP, and trade systems. Serves as the natural key for cross-system integration and EDI transactions. Example: \'SNKBR-001\', \'BEV-RTD-02\'.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Official commercial name of the brand as registered and used in consumer-facing marketing, packaging, and trade communications. This is the primary human-readable identifier for the brand (e.g., \'SunCrisp\', \'HydraFlow\'). Must align with FTC-approved marketing claims and FDA labeling requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual marketing budget (e.g., \'USD\', \'EUR\', \'GBP\'). Ensures correct financial reporting and multi-currency consolidation in Oracle Cloud ERP and SAP S/4HANA FI.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelCertified rdf:type rdf:Property ;
    rdfs:label 'Clean Label Certified' ;
    rdfs:comment 'Indicates whether the brand carries a clean label certification or commitment (no artificial colors, flavors, preservatives, or GMO ingredients). Drives consumer marketing claims, shelf placement in natural/organic sections, and SPINS natural channel data eligibility. Must be substantiated per FTC claim guidelines.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the brand record was first created in the enterprise data platform (Databricks Silver Layer). Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for data lineage, audit trail, and record lifecycle management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmBrandCode rdf:type rdf:Property ;
    rdfs:label 'Crm Brand Code' ;
    rdfs:comment 'Brand identifier as recorded in Salesforce CRM (Sales Cloud / Marketing Cloud). Used for cross-system reconciliation between the lakehouse brand master and Salesforce campaign and consumer engagement records. Enables brand-level marketing performance attribution.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPresenceUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Presence Url' ;
    rdfs:comment 'Primary website URL for the brand\'s consumer-facing digital presence (e.g., \'https://www.suncrisp.com\'). Used in Salesforce Marketing Cloud digital campaign management, SEO tracking, and consumer engagement analytics.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Calendar date on which the brand was officially discontinued or withdrawn from the market. Null if the brand is currently active. Used for portfolio rationalization analysis, regulatory deregistration, and historical reporting in Nielsen/IRI market tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary route-to-market channel through which the brand\'s products are sold. \'retail\' = traditional grocery/mass/drug; \'foodservice\' = restaurants/institutions; \'dsd\' = Direct Store Delivery; \'dtc\' = Direct-to-Consumer; \'ecommerce\' = online retail; \'club\' = club/warehouse channel. Drives trade promotion strategy (TPM/TPO) and supply chain configuration.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Composite brand equity score derived from consumer research inputs including awareness, consideration, preference, and loyalty metrics. Scored on a 0-100 scale. Sourced from Nielsen/IRI brand health tracking studies and internal NPS panel data. Confidential strategic metric used in portfolio investment decisions and brand valuation.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpBrandCode rdf:type rdf:Property ;
    rdfs:label 'Erp Brand Code' ;
    rdfs:comment 'Brand identifier as recorded in the source ERP system (SAP S/4HANA or Oracle Cloud ERP). Used for cross-system reconciliation between the lakehouse silver layer brand master and operational ERP brand records. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiCertification rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification' ;
    rdfs:comment 'GFSI-benchmarked food safety certification scheme applicable to the brand\'s manufacturing operations. \'sqf\' = Safe Quality Food (SQF); \'brc\' = British Retail Consortium Global Standard; \'fssc_22000\' = Food Safety System Certification 22000; \'ifs\' = International Featured Standards; \'global_gap\' = GlobalG.A.P.; \'none\' = no GFSI certification. Tracked in Veeva Vault and TraceGains supplier compliance.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpPlanReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Reference' ;
    rdfs:comment 'Reference identifier for the HACCP plan document associated with the brand\'s manufacturing process, stored in Veeva Vault Document Control. HACCP (Hazard Analysis Critical Control Points) is a mandatory food safety management system under FDA FSMA and USDA FSIS regulations. Used for audit traceability and regulatory compliance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Calendar date on which the brand was first commercially launched and made available to consumers in its primary market. Used for brand age calculations, anniversary marketing campaigns, and PLM lifecycle tracking. Aligns with SAP PLM product launch milestones.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Legally registered name of the brand as filed with trademark authorities (USPTO, EUIPO, etc.). May differ from the commercial brand name. Used for regulatory filings, contract management, and IP protection tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the brand within its commercial lifecycle. \'active\' = currently marketed and sold; \'discontinued\' = no longer produced or sold; \'pipeline\' = in NPD/R&D phase, not yet launched; \'divested\' = sold or transferred to another entity; \'archived\' = historical record retained for compliance. Drives PLM alignment and portfolio management decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL pointing to the master brand logo asset stored in the digital asset management (DAM) system. Used by Salesforce Marketing Cloud, packaging design teams, and agency partners for consistent brand identity application across all consumer touchpoints.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) for the brand, measuring consumer likelihood to recommend on a -100 to +100 scale. Sourced from consumer panel surveys and Salesforce Marketing Cloud feedback programs. Used as a leading indicator of brand health and consumer loyalty in brand equity tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertified rdf:type rdf:Property ;
    rdfs:label 'Organic Certified' ;
    rdfs:comment 'Indicates whether the brand holds USDA National Organic Program (NOP) certification or equivalent international organic certification (e.g., EU Organic). Enables organic marketing claims on packaging and in trade communications. Tracked in TraceGains supplier compliance and Veeva Vault document control.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerDivision rdf:type rdf:Property ;
    rdfs:label 'Owner Division' ;
    rdfs:comment 'Internal business division or operating unit that owns and manages the brand (e.g., \'North America Snacks\', \'Global Beverages\', \'International Dairy\'). Used for P&L attribution, marketing budget allocation, and organizational reporting in SAP CO and Oracle Financials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmProductLineCode rdf:type rdf:Property ;
    rdfs:label 'Plm Product Line Code' ;
    rdfs:comment 'Reference code linking the brand to its associated product line in the PLM system (SAP PLM or equivalent). Enables traceability between brand master data and the SKU/product hierarchy managed in PLM. Used for NPD pipeline tracking and BOM management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Internal strategic statement articulating the brand\'s unique value proposition, competitive differentiation, and reason-to-believe for the target consumer segment. Confidential business strategy document used in brand planning, NPD briefs, and agency briefings. Not for external distribution.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s primary brand color as defined in the brand identity guidelines (e.g., \'#FF6B35\'). Used for consistent visual identity application across digital marketing, packaging, and trade materials in Salesforce Marketing Cloud and design systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promise rdf:type rdf:Property ;
    rdfs:label 'Promise' ;
    rdfs:comment 'Consumer-facing articulation of the core benefit or commitment the brand makes to its consumers (e.g., \'Real ingredients, real taste\'). Used in marketing communications, packaging copy, and Salesforce Marketing Cloud campaign messaging. Must comply with FTC advertising claim substantiation requirements.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of regulatory approval for the brand\'s product claims and labeling across applicable jurisdictions. \'approved\' = all required regulatory approvals obtained; \'pending\' = applications submitted, awaiting decision; \'under_review\' = regulatory authority review in progress; \'rejected\' = approval denied, remediation required; \'not_required\' = no regulatory approval needed for this brand type. Managed in Veeva Vault Quality Management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Sub-category or segment within the broader product category (e.g., \'Salty Snacks\', \'Energy Drinks\', \'Greek Yogurt\', \'Plant-Based\'). Used for granular market share analysis via IRI/SPINS syndicated data and for internal portfolio segmentation reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the brand\'s official social media presence (e.g., \'@SunCrispSnacks\'). Used for social media monitoring, influencer partnership management, and Salesforce Marketing Cloud social engagement tracking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClaim rdf:type rdf:Property ;
    rdfs:label 'Sustainability Claim' ;
    rdfs:comment 'Sustainability or environmental claim associated with the brand (e.g., \'Carbon Neutral\', \'Rainforest Alliance Certified\', \'B Corp Certified\', \'Recyclable Packaging\'). Must be substantiated per FTC Green Guides (16 CFR Part 260) and EPA environmental compliance standards. Supports ESG reporting and consumer engagement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Commercial positioning tier of the brand within the portfolio pricing and consumer value ladder. \'super_premium\' = ultra-high-end, limited distribution; \'premium\' = above-mainstream RSP positioning; \'mainstream\' = mass-market EDLP positioning; \'value\' = price-entry or economy positioning. Drives RSP strategy, trade promotion investment, and retail planogram placement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Expiry Date' ;
    rdfs:comment 'Date on which the brand\'s trademark registration expires and must be renewed to maintain legal protection. Used for IP lifecycle management and legal compliance tracking. Triggers renewal workflows in legal management systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official trademark registration number issued by the relevant intellectual property authority (e.g., USPTO, EUIPO, WIPO). Used for IP management, legal protection, and brand licensing agreements. Confidential business identifier managed in legal systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the brand record in the enterprise data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture (CDC), data freshness monitoring, and audit compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Unique surrogate identifier for each marketing campaign record in the lakehouse silver layer. Primary key.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: F&B marketing campaigns are scoped to product categories (e.g., \'snacks category summer campaign\'). Category-level campaign planning, budget allocation, and ROI reporting require a structured FK to th' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Campaign budgets are charged to cost centers; linking enables budget vs. actual financial analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Campaign financial transactions need a GL account for posting; creates traceable accounting entries.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:primarySkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign planning uses a primary SKU for messaging and budgeting; the Primary SKU field drives the Campaign Brief and media allocation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:productRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Product Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.product_registration. Business justification: Campaigns promote products that must be registered in target markets. Ensures marketing launch timing aligns with regulatory clearance, prevents promotion of unregistered products, and supports market' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRegistration .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Campaign planning uses defined customer segments for targeting; linking enables segment-level ROI reporting and compliance with marketing segmentation policies.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Total actual expenditure incurred for the campaign in US dollars as of the latest financial close. Compared against planned_budget_usd to track budget utilization and variance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvTargetPct rdf:type rdf:Property ;
    rdfs:label 'Acv Target Pct' ;
    rdfs:comment 'Target percentage of All Commodity Volume (ACV) distribution coverage for the campaign\'s featured products. ACV % is a standard food and beverage industry metric for measuring retail distribution breadth.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow approval state of the campaign record: pending (awaiting review), approved (cleared for execution), rejected (not approved), or under_review (in active review). Supports governance and compliance workflows.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the campaign received final business approval to proceed. Used for governance audit trails and time-to-market measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Alphanumeric business identifier for the campaign used in ERP cost tracking, trade promotion management (TPM), and cross-system reconciliation. Follows internal naming convention (e.g., \'CAMP-2024-BEV-001\').' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign, including creative concept, key messages, promotional mechanics, and strategic rationale. Used for stakeholder briefings and campaign documentation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign (e.g., \'Summer Refresh 2024 — National TV Burst\'). Used in reporting, dashboards, and stakeholder communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (in development), planned (approved, not yet live), active (currently running), paused (temporarily halted), completed (finished), or cancelled (terminated before completion).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by its primary marketing objective: awareness (brand building), trial (new consumer acquisition), loyalty (retention), trade (retailer/channel incentive), shopper (in-store activation), or influencer (creator-led). [ENUM-REF-CANDIDATE: awareness|trial|loyalty|trade|shopper|influencer|sponsorship|sampling|digital|event — promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Primary media or activation channel through which the campaign is executed (e.g., tv, digital, shopper, social, influencer, in_store). Drives channel-level spend and performance reporting. [ENUM-REF-CANDIDATE: tv|digital|shopper|social|influencer|in_store|radio|print|out_of_home|email|event — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary amounts on this campaign record (e.g., USD, EUR, GBP). Supports multi-currency reporting for global campaigns.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the campaign officially concludes and all media/activation ceases. Nullable for always-on campaigns. Used for budget reconciliation and post-campaign analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaClaimsCompliant rdf:type rdf:Property ;
    rdfs:label 'Fda Claims Compliant' ;
    rdfs:comment 'Indicates whether all product claims featured in the campaign (e.g., health claims, nutrient content claims, clean label statements) comply with FDA regulations. True = compliant; False = non-compliant or under review.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month number within the fiscal year, 1–13) in which the campaign is primarily budgeted. Used for period-level financial reporting and budget pacing in SAP S/4HANA CO.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the campaign budget is allocated and financial performance is reported (e.g., 2024). Aligns with SAP S/4HANA CO fiscal year for cost center and internal order reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftcClaimsReviewed rdf:type rdf:Property ;
    rdfs:label 'Ftc Claims Reviewed' ;
    rdfs:comment 'Indicates whether all marketing claims in this campaign have been reviewed for compliance with FTC guidelines on advertising and marketing claims (e.g., substantiation of health/nutrition claims). True = reviewed and cleared; False = not yet reviewed.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:influencerPartnership rdf:type rdf:Property ;
    rdfs:label 'Influencer Partnership' ;
    rdfs:comment 'Indicates whether this campaign includes a paid influencer or creator partnership component. True = influencer partnership present; False = no influencer component. Supports FTC disclosure compliance tracking.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP S/4HANA CO internal order number used to collect and settle campaign costs. Provides granular cost tracking at the campaign level within the ERP system.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaImpressionsTarget rdf:type rdf:Property ;
    rdfs:label 'Media Impressions Target' ;
    rdfs:comment 'Planned number of media impressions (total ad exposures) targeted for the campaign across all channels. Used as a key performance indicator (KPI) for reach planning and post-campaign evaluation against Nielsen/IRI data.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Free-text description of the primary business objective for the campaign (e.g., \'Drive 10% household penetration increase for RTD line in Q3\'). Supports brand marketing and consumer engagement planning.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Usd' ;
    rdfs:comment 'Total approved budget allocated to the campaign in US dollars at the time of planning. Used for financial planning, trade promotion management (TPM), and return on investment (ROI) analysis.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this campaign supports a private label product program rather than a branded product. True = private label campaign; False = branded campaign. Relevant for retailer co-marketing and private label program data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachTargetHouseholds rdf:type rdf:Property ;
    rdfs:label 'Reach Target Households' ;
    rdfs:comment 'Planned number of unique households targeted for campaign reach. Aligns with Nielsen household panel measurement methodology for consumer packaged goods (CPG) reach reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sfmcCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Sfmc Campaign Code' ;
    rdfs:comment 'External campaign identifier assigned by Salesforce Marketing Cloud (SFMC). Used to correlate lakehouse records with SFMC execution records for digital and email channel campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperMarketingFlag rdf:type rdf:Property ;
    rdfs:label 'Shopper Marketing Flag' ;
    rdfs:comment 'Indicates whether this campaign includes a shopper marketing activation (e.g., in-store display, planogram feature, digital coupon at point of sale). True = shopper marketing component present.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuScope rdf:type rdf:Property ;
    rdfs:label 'Sku Scope' ;
    rdfs:comment 'Comma-separated list or description of the specific SKUs (Stock Keeping Units) included in the campaign. Supports product-level performance attribution and trade promotion management (TPM) analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the campaign officially launches and media/activation begins. Used for scheduling, budget pacing, and performance window calculations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Geographic scope of the campaign (e.g., \'National US\', \'Northeast Region\', \'California DMA\'). Used for media buying, distribution alignment, and regional performance reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpTarget rdf:type rdf:Property ;
    rdfs:label 'Tdp Target' ;
    rdfs:comment 'Target Total Distribution Points (TDP) for the campaign\'s featured SKUs. TDP is a standard food and beverage metric combining distribution breadth and depth across retail accounts.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradePromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Flag' ;
    rdfs:comment 'Indicates whether this campaign includes a trade promotion component (e.g., retailer co-op, slotting fee, off-invoice discount). True = trade promotion included. Supports Trade Promotion Management (TPM) and Trade Promotion Optimization (TPO) workflows.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Unique surrogate identifier for each campaign execution record. Represents a single activation of a campaign flight across a specific channel, geography, and time period. Role: TRANSACTION_HEADER — primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignExecution .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the retail account or trade customer targeted by this execution (e.g., Walmart, Kroger). Supports shopper marketing and trade promotion alignment. PARTY_REFERENCE per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:labelApprovalId rdf:type rdf:Property ;
    rdfs:label 'Label Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_approval. Business justification: Campaign executions must use approved label versions to ensure marketing materials match approved packaging claims. Critical for FTC/FDA compliance, prevents unapproved claim usage, and links creative' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelApproval .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Foreign key linking to marketing.media_plan. Business justification: A campaign execution flight is governed by a media plan that defines the budget, channel mix, and planned reach. Linking campaign_execution to media_plan allows actual execution performance (impressio' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:nutritionLabelId rdf:type rdf:Property ;
    rdfs:label 'Nutrition Label Id' ;
    rdfs:comment 'Foreign key linking to regulatory.nutrition_label. Business justification: Campaign Execution Compliance: execution must reference the nutrition label of the SKU to ensure advertised claims match label information.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NutritionLabel .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign execution references a specific SKU; FK replaces free-text SKU and aligns marketing spend with product master.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Financial reconciliation of campaign execution spend uses the PO that funded the media buy, needed for audit and ROI reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The actual media spend incurred for this execution flight as billed by the media vendor or agency. Used for ROI calculation and budget reconciliation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The format of the advertisement deployed in this execution (e.g., banner, video, carousel, sponsored product). Supports format-level performance and creative strategy analysis. [ENUM-REF-CANDIDATE: banner|video|carousel|native|sponsored_product|story|interstitial|rich_media — promote to reference product]' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the media agency or buying partner responsible for executing this campaign flight. Used for agency performance tracking and invoice reconciliation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingType rdf:type rdf:Property ;
    rdfs:label 'Buying Type' ;
    rdfs:comment 'The media buying model used for this execution (e.g., CPM — Cost Per Thousand, CPC — Cost Per Click, CPA — Cost Per Acquisition, CPV — Cost Per View, flat fee, programmatic). Drives cost structure and performance benchmarking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPlatform rdf:type rdf:Property ;
    rdfs:label 'Channel Platform' ;
    rdfs:comment 'Specific platform or publisher within the channel type where the execution runs (e.g., Facebook, Google, Instacart, Kroger Precision Marketing, YouTube). Enables platform-level performance benchmarking.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'The marketing channel through which this execution is activated (e.g., digital, social, shopper, television). Drives channel-level spend and performance reporting. [ENUM-REF-CANDIDATE: digital|social|display|search|email|shopper|out_of_home|television|radio|print — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Compliance Status' ;
    rdfs:comment 'Regulatory compliance review status for marketing claims contained in this execution. Required when marketing_claim_flag is True. Supports FTC and FDA compliance audit trails.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'Total number of clicks recorded on the ad during this execution flight. Used to calculate click-through rate (CTR) and assess consumer engagement.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerThousandImpressions rdf:type rdf:Property ;
    rdfs:label 'Cost Per Thousand Impressions' ;
    rdfs:comment 'The cost per one thousand ad impressions for this execution, as negotiated with the media vendor. Standard media buying metric used for cross-channel efficiency benchmarking.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeVersion rdf:type rdf:Property ;
    rdfs:label 'Creative Version' ;
    rdfs:comment 'Version label of the creative asset deployed in this execution (e.g., v1.0, v2.3). Tracks which creative iteration was live during the flight for A/B testing and compliance audit.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Externally-known business identifier for this execution record, used in agency briefings, media plans, and vendor invoices. Format: CE-YYYY-NNNNNN. BUSINESS_IDENTIFIER per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle state of this campaign execution record. Tracks workflow from planning through completion. LIFECYCLE_STATUS per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'The date on which this campaign execution flight is scheduled to stop running in-market. Used for pacing, budget management, and post-campaign analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'The date on which this campaign execution flight begins running in-market. Represents the real-world activation date. BUSINESS_EVENT_TIMESTAMP per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Average number of times a unique individual was exposed to the ad during this execution flight. Calculated as impressions divided by reach. Used to manage ad fatigue and optimize media plans.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of ad impressions delivered during this execution flight. A core digital media performance metric used for reach and frequency analysis. QUANTITATIVE_RESULT per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerPartnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Influencer Partnership Flag' ;
    rdfs:comment 'Indicates whether this execution involves a paid influencer or brand ambassador partnership. Triggers FTC endorsement disclosure compliance requirements.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Claim Flag' ;
    rdfs:comment 'Indicates whether this execution contains a regulated marketing claim (e.g., health claim, nutrient content claim, environmental claim). Triggers FTC and FDA compliance review workflow.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenMarketCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Market Code' ;
    rdfs:comment 'Nielsen-defined market or DMA (Designated Market Area) code associated with the geographic target of this execution. Enables alignment with Nielsen/IRI syndicated market data for sales lift analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'The specific ad placement or ad unit name within the platform (e.g., Facebook News Feed, Google Search Top, Instacart Sponsored Product). Supports granular placement-level performance analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'The budgeted media spend allocated to this execution flight in the media plan. Used for budget pacing and variance analysis against actual spend.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Total number of unique individuals exposed to the ad during this execution flight. Distinct from impressions (which counts total exposures including repeat). Key metric for brand awareness campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceActivityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activity Code' ;
    rdfs:comment 'The native activity or journey step identifier from Salesforce Marketing Cloud corresponding to this execution record. Enables direct traceability back to the source system of record.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the planned and actual spend amounts (e.g., USD, EUR, GBP). Required for multi-market campaign financial reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'The consumer audience segment targeted by this execution (e.g., Millennial Moms, Health-Conscious Shoppers, Snack Enthusiasts). Derived from consumer insights and CRM segmentation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeographyCode rdf:type rdf:Property ;
    rdfs:label 'Target Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code representing the primary geographic market targeted by this execution. Supports geo-level spend and performance reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegion rdf:type rdf:Property ;
    rdfs:label 'Target Region' ;
    rdfs:comment 'Sub-national region or market area targeted by this execution (e.g., Northeast US, California, EMEA). Supports regional marketing performance analysis and distribution center alignment.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRetailerName rdf:type rdf:Property ;
    rdfs:label 'Target Retailer Name' ;
    rdfs:comment 'Name of the specific retailer or trade account targeted by this shopper marketing or retail media execution (e.g., Walmart, Kroger, Target). Supports trade promotion and shopper marketing alignment.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'Urchin Tracking Module (UTM) campaign parameter appended to campaign URLs for this execution. Links digital traffic back to the specific campaign for attribution reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'Urchin Tracking Module (UTM) medium parameter appended to campaign URLs for this execution (e.g., cpc, email, social). Supports digital attribution and channel performance analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'Urchin Tracking Module (UTM) source parameter appended to campaign URLs for this execution. Used for digital attribution and web analytics tracking in Google Analytics and Salesforce Marketing Cloud.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Number' ;
    rdfs:comment 'The media vendor\'s or publisher\'s order or insertion order (IO) number associated with this execution. Used for invoice matching and vendor reconciliation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Proportion of video ad views that were completed to 100% of the video duration. Expressed as a decimal (e.g., 0.65 = 65%). Key metric for video creative effectiveness.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views recorded for video ad formats during this execution flight. Applicable when ad_format is video. Supports video completion rate analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaSpendId rdf:type rdf:Property ;
    rdfs:label 'Media Spend Id' ;
    rdfs:comment 'Unique surrogate identifier for each media spend transaction record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Reference to the media partner or vendor (e.g., Google, Meta, NBC, Clear Channel) who delivered the media placement. Used for vendor performance and spend reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'Media agency commission or service fee associated with this spend record, separate from the net media cost. Enables total cost of advertising (working vs. non-working spend) analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the primary marketing claim featured in the media creative associated with this spend (e.g., health, nutrition, sustainability, taste, price, brand). Supports FTC compliance monitoring and claim substantiation tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of user clicks on the digital advertisement during the spend period. Primary engagement metric for digital and paid search media types.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Spend Amount' ;
    rdfs:comment 'Media spend amount that has been contractually committed to the vendor but not yet invoiced or paid. Represents open purchase order value for accrual and cash flow forecasting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Cost Per Click — the realized cost for each user click on the digital advertisement in the transaction currency. Primary efficiency metric for paid search and performance-based digital media.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost Per Mille (thousand impressions) — the negotiated or realized cost per 1,000 ad impressions in the transaction currency. Standard media efficiency metric for comparing cross-channel investment value.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or source from which this media spend record was ingested (e.g., SAP S/4HANA, agency billing platform, media platform API, Nielsen, IRI, manual entry). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the specific US television market where the media aired. Standard geographic unit for US broadcast media planning and spend reporting.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Compliant' ;
    rdfs:comment 'Indicates whether the associated advertising creative and claims for this media spend have been reviewed and confirmed compliant with FTC endorsement, disclosure, and advertising substantiation guidelines. Critical for regulatory audit and legal risk management.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoMarketCode rdf:type rdf:Property ;
    rdfs:label 'Geo Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code identifying the geographic market where the media ran. Supports multi-market spend consolidation and regional budget governance.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'Gross Rating Points representing the total weight of a media schedule, calculated as reach multiplied by average frequency. Standard TV and broadcast media planning metric used to measure advertising pressure.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the advertisement was served or displayed to an audience during the spend period. Primary reach metric for evaluating media delivery against contracted guarantees.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Vendor invoice reference number associated with this media spend record. Used for accounts payable matching, audit trails, and FTC compliance documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaChannel rdf:type rdf:Property ;
    rdfs:label 'Media Channel' ;
    rdfs:comment 'Specific media channel or platform within the media type (e.g., YouTube, Instagram, Google Search, NBC Primetime, Spotify, Times Square Billboard). Provides granular channel-level spend visibility beyond the media type classification.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaFormat rdf:type rdf:Property ;
    rdfs:label 'Media Format' ;
    rdfs:comment 'Creative format of the media placement (e.g., video, banner, native, audio, sponsorship, influencer, search text). Used for creative performance analysis and format-level spend allocation. [ENUM-REF-CANDIDATE: video|banner|native|audio|sponsorship|influencer|search_text|connected_tv — promote to reference product]' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'Classification of the advertising medium used for this spend record (e.g., TV, digital display, paid search, out-of-home, social, streaming). Drives channel-mix analysis and media planning optimization. [ENUM-REF-CANDIDATE: TV|digital_display|paid_search|OOH|social|streaming|print|radio — promote to reference product]' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number issued to the media vendor for this spend commitment. Enables three-way match (PO, goods receipt, invoice) in accounts payable.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiIndex rdf:type rdf:Property ;
    rdfs:label 'Roi Index' ;
    rdfs:comment 'Media ROI index score derived from marketing mix modeling or attribution analysis, representing the revenue return per unit of media spend. Sourced from Nielsen/IRI MMM outputs. Not a calculated aggregate — represents a point-in-time modeled index value assigned to this spend record.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The principal real-world business event date on which the media spend was incurred or the media ran. Used as the primary time dimension for spend reporting and period-over-period analysis.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Spend Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this media spend transaction, typically sourced from the media buying platform, agency, or SAP FI document number. Used for reconciliation with invoices and agency billing statements.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendStatus rdf:type rdf:Property ;
    rdfs:label 'Spend Status' ;
    rdfs:comment 'Current lifecycle state of the media spend record, tracking progression from planned budget through commitment, invoicing, and payment. Supports spend governance and budget control.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Defined audience segment or demographic target for this media placement (e.g., Adults 18-49, Millennial Moms, Health-Conscious Shoppers). Used for audience alignment reporting and media planning.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element code for project-based media spend tracking. Used when advertising spend is managed under a specific marketing project or new product launch initiative.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Working Media Flag' ;
    rdfs:comment 'Indicates whether this spend record represents working media (dollars directly purchasing audience exposure) as opposed to non-working spend (agency fees, production costs, research). Standard industry classification for advertising efficiency benchmarking.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionPlanId rdf:type rdf:Property ;
    rdfs:label 'Promotion Plan Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_plan. Business justification: Media planning is built around promotion plans; linking enables plan-level media budgeting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionPlan .

ind:purchaseContractId rdf:type rdf:Property ;
    rdfs:label 'Purchase Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_contract. Business justification: Media plans are executed under a media purchase contract; linking enables contract compliance and spend tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseContract .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the media plan budget received final authorization from the budget owner. Required for SOX audit trail and marketing finance controls documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'The total approved Advertising & Promotion (A&P) budget allocated to this media plan in the plan currency. This is the marketing-owned working budget — the single source of truth (SSOT) distinct from the finance General Ledger (GL). Supports brand investment governance and EBITDA impact tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or employee identifier of the marketing manager or brand director who owns and is accountable for this media plan budget. The primary point of contact for budget governance.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The difference between the approved budget and actual spend (approved_budget_amount minus actual_spend_amount). A positive value indicates underspend; negative indicates overspend. Supports marketing finance controls and budget reallocation decisions.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Budget Amount' ;
    rdfs:comment 'Budget allocated to digital media channels (display, search, programmatic, video) within this plan. Supports digital investment tracking and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic market scope of this media plan (e.g., \'National\', \'Northeast Region\', \'Top 10 DMAs\'). Supports market-level investment analysis and regional brand equity tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Media Mix Strategy' ;
    rdfs:comment 'Narrative description of the media mix strategy for this plan, including rationale for channel weighting, sequencing, and integration approach. Supports brand investment decision documentation.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oohBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Ooh Budget Amount' ;
    rdfs:comment 'Budget allocated to Out-of-Home (OOH) media (billboards, transit, digital OOH) within this plan. Supports channel-level investment tracking and media mix reporting.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The calendar date on which media activity under this plan is scheduled to conclude. Defines the flight window for budget commitment and agency delivery.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name for the media plan (e.g., \'FY25 Q1 Snacks National TV + Digital\'). Used in dashboards, approval workflows, and stakeholder communications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the media plan, used in agency briefs, purchase orders, and finance reconciliation. Format: MP- followed by 4–20 alphanumeric characters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The calendar date on which media activity under this plan is scheduled to begin. Used for flight scheduling, agency briefing timelines, and budget pacing.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the media plan within the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|paused|cancelled|closed — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the media plan by strategic purpose. Distinguishes brand-building investment from Trade Promotion Management (TPM) spend, New Product Development (NPD) launches, and shopper marketing activations. [ENUM-REF-CANDIDATE: brand_building|trade_promotion|shopper_marketing|new_product_launch|seasonal|always_on — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'The planned average number of times a member of the target audience is expected to be exposed to the media during the flight period. Used with reach to calculate GRPs and assess media weight sufficiency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrp rdf:type rdf:Property ;
    rdfs:label 'Planned Grp' ;
    rdfs:comment 'The total planned Gross Rating Points (GRPs) targeted for this media plan. GRP = Reach % × Frequency. A standard media weight metric used to evaluate TV and broadcast investment effectiveness.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReachPct rdf:type rdf:Property ;
    rdfs:label 'Planned Reach Pct' ;
    rdfs:comment 'The planned percentage of the target audience expected to be exposed to the media at least once during the flight period. A key media effectiveness metric alongside frequency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant media channel for this plan (e.g., TV, digital, social, shopper, Out-of-Home (OOH), streaming). Drives media mix strategy reporting and channel-level budget allocation analytics. [ENUM-REF-CANDIDATE: TV|digital|social|shopper|OOH|streaming|print|radio — promote to reference product]' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'Budget allocated to creative production costs (TV commercial production, digital asset creation, photography) within this plan. Part of non-working media spend.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Code' ;
    rdfs:comment 'The campaign identifier from Salesforce Marketing Cloud used to link this media plan to digital campaign execution, email journeys, and consumer engagement tracking. Supports cross-channel attribution.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Shopper Budget Amount' ;
    rdfs:comment 'Budget allocated to shopper marketing activations (in-store, retailer co-op, Point of Sale (POS) materials) within this plan. Supports trade and shopper investment governance.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Social Budget Amount' ;
    rdfs:comment 'Budget allocated to social media channels (paid social, influencer partnerships) within this plan. Supports social investment tracking and FTC endorsement compliance monitoring.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Streaming Budget Amount' ;
    rdfs:comment 'Budget allocated to streaming media platforms (audio streaming, video-on-demand, podcast) within this plan. Supports emerging channel investment tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tvBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Tv Budget Amount' ;
    rdfs:comment 'Budget allocated to television media (linear TV, connected TV) within this plan. Supports channel-level investment tracking and media mix optimization.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the media plan, incremented each time the plan is revised and resubmitted for approval. Supports plan revision history tracking and audit trail.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingMediaPct rdf:type rdf:Property ;
    rdfs:label 'Working Media Pct' ;
    rdfs:comment 'The percentage of the total approved budget allocated to working media (direct media placement costs) versus non-working media (agency fees, production costs). Industry benchmark for media efficiency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumerInsightId rdf:type rdf:Property ;
    rdfs:label 'Consumer Insight Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer research study or derived insight record. Primary key for the consumer_insight data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Insight studies are conducted on specific SKUs; linking enables the Insight-SKU Impact report used in NPD decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenRelevance rdf:type rdf:Property ;
    rdfs:label 'Allergen Relevance' ;
    rdfs:comment 'Indicates whether the study includes consumer insights related to allergen awareness, labeling preferences, or allergen-free product demand (True). Supports allergen matrix management and FDA FSMA compliance for labeling decisions.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanLabelRelevance rdf:type rdf:Property ;
    rdfs:label 'Clean Label Relevance' ;
    rdfs:comment 'Indicates whether the study includes findings relevant to clean label consumer preferences (True) — e.g., natural ingredients, no artificial additives, transparency. Supports the clean label product development pipeline and marketing claims strategy.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conceptTestScore rdf:type rdf:Property ;
    rdfs:label 'Concept Test Score' ;
    rdfs:comment 'Top-2-box purchase intent or overall concept appeal score from concept testing studies (e.g., 72.50 = 72.5% top-2-box). Null for non-concept-test study types. Key NPD go/no-go gate metric used in the innovation funnel.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'The statistical confidence level (%) at which quantitative findings are reported (e.g., 90.00, 95.00, 99.00). Null for qualitative studies. Supports data quality assessment and decision-making thresholds for NPD go/no-go gates.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Operational system of record from which this consumer insight record originated or was ingested (e.g., Salesforce Marketing Cloud, Nielsen/IRI Syndicated Data, SPINS, Veeva Vault, TraceGains, internal survey platform). Supports data lineage and Silver Layer provenance tracking. [ENUM-REF-CANDIDATE: salesforce_marketing_cloud|nielsen_iri|spins|veeva_vault|tracegains|internal_survey|external_agency|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDate rdf:type rdf:Property ;
    rdfs:label 'Deliverable Date' ;
    rdfs:comment 'The date on which the final research deliverable (report, topline, data file) was received from the vendor or published internally. Used for insight freshness tracking and NPD pipeline milestone management.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableReference rdf:type rdf:Property ;
    rdfs:label 'Deliverable Reference' ;
    rdfs:comment 'Document reference, URL, or Veeva Vault document ID pointing to the primary research deliverable (final report, topline deck, data file). Enables direct access to source documentation for audit, compliance, and deeper analysis.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldingEndDate rdf:type rdf:Property ;
    rdfs:label 'Fielding End Date' ;
    rdfs:comment 'The date on which data collection (fielding) concluded for the study. Together with fielding_start_date, defines the fieldwork window for temporal validity assessment of insights.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldingStartDate rdf:type rdf:Property ;
    rdfs:label 'Fielding Start Date' ;
    rdfs:comment 'The date on which data collection (fielding) commenced for the study. Used for timeline tracking, seasonal context analysis, and compliance with ESOMAR fieldwork documentation requirements.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic coverage of the study, expressed as country codes (ISO 3166-1 alpha-3), regions, or named markets (e.g., \'USA\', \'USA|CAN|MEX\', \'EMEA\', \'National US\'). Supports market-level filtering and cross-market insight comparison.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightAction rdf:type rdf:Property ;
    rdfs:label 'Insight Action' ;
    rdfs:comment 'The recommended business action or strategic implication derived from the key finding (e.g., \'Reformulate product X to reduce sodium\', \'Reposition Brand Y toward health-conscious millennials\'). Bridges research output to commercial decision-making.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightCategory rdf:type rdf:Property ;
    rdfs:label 'Insight Category' ;
    rdfs:comment 'Business domain classification of the primary insight derived from the study. Enables routing of insights to the correct brand, innovation, or commercial team. [ENUM-REF-CANDIDATE: brand_equity|product_innovation|packaging|pricing|consumer_segmentation|category_dynamics|shopper_behavior|advertising_effectiveness|sustainability|competitive_intelligence — promote to reference product]' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insight Expiry Date' ;
    rdfs:comment 'The date after which the insight is considered stale or no longer actionable due to market changes, product reformulation, or elapsed time. Supports insight lifecycle management and prevents outdated research from influencing current strategy.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insightPriority rdf:type rdf:Property ;
    rdfs:label 'Insight Priority' ;
    rdfs:comment 'Business priority rating assigned to the insight by the commissioning team, indicating urgency and strategic importance for action. Drives triage and resource allocation in the innovation funnel and brand planning cycle.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Key Finding Summary' ;
    rdfs:comment 'Concise narrative summary of the primary actionable insight or finding derived from the study (max ~2000 characters). This is the SSOT for the headline insight used in brand strategy decks, NPD briefs, and innovation funnel reviews.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npdPipelineFlag rdf:type rdf:Property ;
    rdfs:label 'Npd Pipeline Flag' ;
    rdfs:comment 'Indicates whether the insight is actively linked to or informing a New Product Development (NPD) initiative in the innovation pipeline (True). Enables filtering of insights that are driving active R&D and NPD gate decisions.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelRelevance rdf:type rdf:Property ;
    rdfs:label 'Private Label Relevance' ;
    rdfs:comment 'Indicates whether the study includes competitive analysis or consumer perception data related to private label products (True). Supports trade strategy, pricing, and brand differentiation decisions against private label competition.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this consumer insight record was first created in the Silver Layer lakehouse. Audit trail field for data lineage, compliance, and record provenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this consumer insight record was last modified in the Silver Layer lakehouse. Supports change tracking, data freshness monitoring, and audit compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Claim Flag' ;
    rdfs:comment 'Indicates whether the research study was conducted to substantiate a marketing or labeling claim (True) or is general consumer research (False). Critical for FTC compliance — claim substantiation studies require specific documentation and retention per FTC guidelines.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchMethodology rdf:type rdf:Property ;
    rdfs:label 'Research Methodology' ;
    rdfs:comment 'Specific research technique employed in the study (e.g., focus group, in-depth interview, online survey, sensory panel, organoleptic evaluation, ethnography, concept test, conjoint analysis, segmentation, U&A study, packaging test, pricing research, NPS survey). [ENUM-REF-CANDIDATE: focus_group|in_depth_interview|online_survey|sensory_panel|organoleptic_evaluation|concept_test|conjoint_analysis|segmentation|usage_and_attitude|packaging_test|pricing_research|nps_survey|ethnography|competitive_landscape — promote to reference product]' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchVendor rdf:type rdf:Property ;
    rdfs:label 'Research Vendor' ;
    rdfs:comment 'Name of the external research agency, syndicated data provider, or consultancy that conducted or supplied the study (e.g., Nielsen, IRI, SPINS, Ipsos, Kantar, Mintel, Numerator). Used for vendor performance tracking and contract management alignment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Total number of respondents or participants included in the study (n). Critical for assessing statistical significance, confidence intervals, and the reliability of quantitative findings. For qualitative studies, represents the number of participants.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensoryScore rdf:type rdf:Property ;
    rdfs:label 'Sensory Score' ;
    rdfs:comment 'Composite sensory or organoleptic evaluation score from sensory panel studies (e.g., overall liking score on a 9-point hedonic scale). Applicable to sensory panel and organoleptic evaluation study types. Null for non-sensory studies. Supports product reformulation and quality assurance decisions.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Salesforce Campaign ID, Nielsen Study ID, Veeva Document ID). Enables traceability back to the system of record for reconciliation and audit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Study Budget Usd' ;
    rdfs:comment 'Total approved budget for the research study in US Dollars (USD). Confidential financial data used for marketing spend tracking, COGS allocation, and ROI measurement of consumer insights investment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the research study by the commissioning team or research vendor (e.g., CI-2024-001234). Serves as the BUSINESS_IDENTIFIER for cross-system reference and vendor invoicing alignment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Full descriptive name of the consumer research study or insight initiative (e.g., \'Q3 2024 Snack Category Usage & Attitude Study — North America\'). Human-readable IDENTITY_LABEL used in reporting, presentations, and stakeholder communications.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle state of the research study: planned (scoped, not yet fielded), fielding (data collection in progress), analysis (data collected, insights being synthesized), completed (final deliverable issued), cancelled, or on_hold. LIFECYCLE_STATUS for the consumer_insight entity.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'High-level classification of the research methodology: qualitative (focus groups, ethnography), quantitative (surveys, panels), mixed_method, syndicated (Nielsen/IRI/SPINS subscriptions), or proprietary commissioned research. Drives analytical approach and data governance treatment.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRelevance rdf:type rdf:Property ;
    rdfs:label 'Sustainability Relevance' ;
    rdfs:comment 'Indicates whether the study captures consumer attitudes or behaviors related to sustainability, environmental impact, packaging recyclability, or ESG-related purchasing drivers (True). Supports sustainability reporting and EPA compliance communications.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'The consumer segment or audience profile that the study was designed to understand (e.g., \'Millennial Health-Conscious Snackers\', \'Hispanic Families 25-44\', \'Gen Z RTD Beverage Consumers\'). Aligns with brand segmentation frameworks and supports NPD pipeline targeting.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProjectCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Project Code' ;
    rdfs:comment 'The research vendor\'s own project or study reference number. Enables cross-referencing with vendor invoices, deliverable portals, and data feeds for reconciliation and audit purposes.' ;
    rdfs:domain ind:ConsumerInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicatedMarketDataId rdf:type rdf:Property ;
    rdfs:label 'Syndicated Market Data Id' ;
    rdfs:comment 'Unique surrogate primary key for each syndicated market data record ingested from Nielsen, IRI, or SPINS data feeds.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicatedMarketData .

ind:acvDistributionPct rdf:type rdf:Property ;
    rdfs:label 'Acv Distribution Pct' ;
    rdfs:comment 'The percentage of All Commodity Volume (ACV) in stores carrying the SKU. ACV-weighted distribution measures the quality of distribution by weighting store presence by store sales volume, not just store count. Key distribution health metric.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgBasePrice rdf:type rdf:Property ;
    rdfs:label 'Avg Base Price' ;
    rdfs:comment 'Average non-promoted (everyday) retail price per unit for the SKU, excluding promotional price reductions. Used to separate base demand from incremental lift driven by trade promotions in TPM/TPO analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Avg Selling Price' ;
    rdfs:comment 'Average retail selling price per unit (dollar sales divided by unit sales) for the SKU in the specified market and period. Used for price positioning analysis, price elasticity modeling, and RSP (Recommended Selling Price) compliance monitoring.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataAggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Aggregation Level' ;
    rdfs:comment 'Indicates the level of product hierarchy at which this syndicated data record is aggregated. Records may be at SKU/UPC level, brand level, subcategory, category, or manufacturer level depending on the data pull configuration.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Load Timestamp' ;
    rdfs:comment 'The timestamp when this syndicated market data record was ingested into the Databricks Silver Layer. Used for data freshness monitoring, pipeline auditing, and identifying the most recent data refresh from each syndicated data provider.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataVintageDate rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Date' ;
    rdfs:comment 'The date on which the syndicated data provider published or released this data extract. Distinct from the period_end_date (what was measured) and data_load_timestamp (when ingested). Used to track data latency and manage version conflicts when providers restate historical data.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayPct rdf:type rdf:Property ;
    rdfs:label 'Display Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU had incremental in-store display (off-shelf, end-cap, secondary placement) during the period. Measures the breadth of display support and is a key input to trade promotion optimization (TPO) models.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSales rdf:type rdf:Property ;
    rdfs:label 'Dollar Sales' ;
    rdfs:comment 'Total retail dollar sales (in USD) for the SKU/brand/category in the specified market and period as measured by the syndicated data provider. The primary revenue performance metric used in brand and category management reviews.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSalesChangePct rdf:type rdf:Property ;
    rdfs:label 'Dollar Sales Change Pct' ;
    rdfs:comment 'Year-over-year percentage change in dollar sales for the SKU/brand in the specified market and period as reported by the syndicated data provider. Used for trend analysis and brand performance reporting in category reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarSharePct rdf:type rdf:Property ;
    rdfs:label 'Dollar Share Pct' ;
    rdfs:comment 'The percentage share of total category dollar sales captured by this brand/SKU in the specified market and period. Core brand equity and competitive performance KPI reported in category management reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equivalentUnitSales rdf:type rdf:Property ;
    rdfs:label 'Equivalent Unit Sales' ;
    rdfs:comment 'Unit sales normalized to a standard equivalent unit (e.g., single-serve equivalent, ounce-equivalent) to enable cross-pack-size volume comparisons. Used in volume share and velocity benchmarking across different pack configurations.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featurePct rdf:type rdf:Property ;
    rdfs:label 'Feature Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU was featured in retailer advertising (circular, digital ad) during the period. Measures the breadth of feature support and is a key input to trade promotion optimization (TPO) models.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'The 14-digit Global Trade Item Number (GTIN) for the product SKU, conforming to GS1 standards. Used for international market data alignment and cross-market product matching beyond the US UPC standard.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOwnBrand rdf:type rdf:Property ;
    rdfs:label 'Is Own Brand' ;
    rdfs:comment 'Indicates whether this record represents a Food Beverage owned brand (True) or a competitor brand (False). Enables filtering of internal versus competitive data in brand performance dashboards and market share reports.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this record represents a private label (store brand) product (True) or a branded product (False). Used to track private label competitive pressure and category penetration in brand strategy analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the manufacturer or parent company associated with the brand as reported by the syndicated data provider. Used for competitive manufacturer-level share analysis and M&A impact tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericDistributionPct rdf:type rdf:Property ;
    rdfs:label 'Numeric Distribution Pct' ;
    rdfs:comment 'Percentage of total stores in the market carrying the SKU (stores_selling / total_stores_in_market × 100). Unweighted distribution measure used alongside ACV distribution to assess distribution breadth versus quality.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'The consumer-facing pack size descriptor for the SKU as reported by the syndicated data provider (e.g., \'12oz\', \'2L\', \'6-Pack\', \'24-Count\'). Used for price-per-unit normalization and pack-size mix analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the reporting period covered by this syndicated data record. Used as the primary time dimension for trend analysis, period-over-period comparisons, and alignment with internal sales data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the reporting period covered by this syndicated data record. Combined with period_end_date to define the exact measurement window.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceReductionPct rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Pct' ;
    rdfs:comment 'Percentage of ACV where the SKU was sold at a temporary price reduction (TPR) without feature or display support. Used to isolate the impact of price-only promotions on volume lift in trade promotion analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedDollarSales rdf:type rdf:Property ;
    rdfs:label 'Promoted Dollar Sales' ;
    rdfs:comment 'Dollar sales generated while the SKU was on promotion (feature, display, price reduction, or combination). Used to calculate promotional lift and evaluate trade promotion effectiveness in TPM analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedUnitSales rdf:type rdf:Property ;
    rdfs:label 'Promoted Unit Sales' ;
    rdfs:comment 'Unit sales generated while the SKU was on promotion. Combined with promoted_dollar_sales to calculate promotional price per unit and assess volume lift from trade promotion activities.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The aggregation period granularity of the syndicated data record as defined by the data provider. Common periods include 4-Week, 12-Week, and 52-Week rolling windows used in category management and brand performance reviews.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailChannel rdf:type rdf:Property ;
    rdfs:label 'Retail Channel' ;
    rdfs:comment 'The retail trade channel in which sales were measured (e.g., Grocery, Mass Merchandise, Drug, Club, Dollar, Convenience, Natural/Specialty, E-Commerce). Used for channel-level performance benchmarking and distribution strategy. [ENUM-REF-CANDIDATE: Grocery|Mass|Drug|Club|Dollar|Convenience|Natural|E-Commerce|Foodservice — promote to reference product]' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'The product segment within the subcategory hierarchy (e.g., \'Flavored Water\' within the Water subcategory). Represents the third level of the syndicated data category hierarchy used for competitive benchmarking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'The human-readable product description for the SKU as reported by the syndicated data provider (e.g., \'Brand X Cola 12oz Can 12-Pack\'). Used for product identification in reports and dashboards when internal product master data is unavailable.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the syndicated data provider that supplied this record. Nielsen and IRI cover conventional retail channels; SPINS (Specialty Product Intelligence) covers natural and specialty channels. Critical for reconciling overlapping market coverage and avoiding double-counting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storesSelling rdf:type rdf:Property ;
    rdfs:label 'Stores Selling' ;
    rdfs:comment 'The count of retail stores in the market that recorded at least one unit sale of the SKU during the reporting period. Used to assess numeric distribution and identify distribution gaps versus total stores in the market.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategoryName rdf:type rdf:Property ;
    rdfs:label 'Subcategory Name' ;
    rdfs:comment 'The product subcategory within the broader category hierarchy as defined by the syndicated data provider (e.g., \'Regular CSD\', \'Diet CSD\' within Carbonated Soft Drinks). Supports granular category management analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdp rdf:type rdf:Property ;
    rdfs:label 'Tdp' ;
    rdfs:comment 'Total Distribution Points (TDP) — the sum of ACV distribution percentages across all items in a brand or category. Measures the breadth of a brand\'s distribution footprint. Used in distribution gap analysis and new item launch tracking.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStoresInMarket rdf:type rdf:Property ;
    rdfs:label 'Total Stores In Market' ;
    rdfs:comment 'The total number of retail stores in the defined market universe as reported by the syndicated data provider. Used as the denominator for numeric distribution calculations and store-count-based share metrics.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitSales rdf:type rdf:Property ;
    rdfs:label 'Unit Sales' ;
    rdfs:comment 'Total consumer units sold for the SKU/brand/category in the specified market and period. Used for volume performance tracking, velocity calculations, and distribution efficiency analysis.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitSalesChangePct rdf:type rdf:Property ;
    rdfs:label 'Unit Sales Change Pct' ;
    rdfs:comment 'Year-over-year percentage change in unit sales for the SKU/brand in the specified market and period as reported by the syndicated data provider. Complements dollar sales change to reveal volume versus pricing dynamics.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitSharePct rdf:type rdf:Property ;
    rdfs:label 'Unit Share Pct' ;
    rdfs:comment 'The percentage share of total category unit sales captured by this brand/SKU in the specified market and period. Complements dollar share to reveal pricing and mix dynamics versus competitors.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The 12-digit Universal Product Code (UPC) identifying the specific SKU measured in this record. Primary product identifier used to link syndicated data to internal product master data in SAP S/4HANA MM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityPerStorePerWeek rdf:type rdf:Property ;
    rdfs:label 'Velocity Per Store Per Week' ;
    rdfs:comment 'Average dollar or unit sales per store selling per week (SPSW). Measures the rate of sale for a SKU in stores where it is distributed. Critical for evaluating item productivity and justifying shelf space in planogram negotiations.' ;
    rdfs:domain ind:SyndicatedMarketData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEquityTrackerId rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Tracker Id' ;
    rdfs:comment 'Unique surrogate identifier for each brand equity measurement record in the tracker. Primary key for the brand_equity_tracker data product.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Id' ;
    rdfs:comment 'Reference to the consumer segment (e.g., millennials, health-conscious, heavy users) for which brand equity metrics are reported. Enables segment-level brand health analysis.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:advertisingRecallPct rdf:type rdf:Property ;
    rdfs:label 'Advertising Recall Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who recall seeing or hearing advertising for the brand in the measurement period. Measures advertising effectiveness and media investment impact on brand awareness. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who recognize the brand when shown or told the brand name. Measures total brand recognition in the target market. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEquityStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Status' ;
    rdfs:comment 'Lifecycle status of this brand equity measurement record. \'preliminary\' indicates data is not yet finalized; \'final\' indicates validated and approved data; \'restated\' indicates a correction to a previously published record; \'archived\' indicates superseded records.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandHealthIndex rdf:type rdf:Property ;
    rdfs:label 'Brand Health Index' ;
    rdfs:comment 'Composite index score aggregating multiple brand equity dimensions (awareness, consideration, trial, repeat, love, NPS) into a single brand health measure. Methodology and weighting defined by the tracking study. Used for executive-level brand performance monitoring.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandLoveScore rdf:type rdf:Property ;
    rdfs:label 'Brand Love Score' ;
    rdfs:comment 'Composite score measuring the emotional affinity and loyalty consumers have toward the brand. Typically derived from survey questions on emotional connection, advocacy, and preference. Scale defined by the tracking study methodology.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPreferencePct rdf:type rdf:Property ;
    rdfs:label 'Brand Preference Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who prefer the brand over competitive alternatives in the category. Measures competitive brand positioning and differentiation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandQualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Brand Quality Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s product quality, including taste, freshness, ingredients, and overall product experience. Critical for food and beverage brand positioning and premium pricing strategy.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandTrustScore rdf:type rdf:Property ;
    rdfs:label 'Brand Trust Score' ;
    rdfs:comment 'Score measuring consumer trust in the brand, typically derived from survey questions on reliability, safety, and quality perceptions. Particularly relevant for food and beverage brands given food safety and clean label consumer expectations.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandValuePerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Brand Value Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s value for money relative to its price point. Supports Revenue Management and Pricing Strategy (RSP/EDLP) decisions and trade promotion effectiveness analysis.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanLabelPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Clean Label Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s commitment to clean label attributes (natural ingredients, no artificial additives, transparent labeling). Highly relevant in the food and beverage industry given growing consumer demand for clean label products.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSetLabel rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Label' ;
    rdfs:comment 'Label identifying the defined set of competitor brands included in the tracking study for benchmarking purposes (e.g., \'Core 5 Competitors\', \'Total Category Set\'). Ensures consistent competitive context across measurement waves.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Pct' ;
    rdfs:comment 'The margin of error (confidence interval) expressed as a percentage for the reported brand equity metrics, based on the sample size and study methodology. Typically ±2% to ±5%. Used to assess statistical significance of period-over-period changes.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationPct rdf:type rdf:Property ;
    rdfs:label 'Consideration Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who would consider purchasing the brand the next time they are in the market for the category. Measures brand relevance and purchase funnel progression. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'The primary methodology used to collect consumer survey data for this measurement wave (e.g., online panel, telephone interview, in-person interview, mobile survey). Affects comparability across waves and markets.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detractorPct rdf:type rdf:Property ;
    rdfs:label 'Detractor Pct' ;
    rdfs:comment 'Percentage of surveyed consumers classified as detractors (NPS score 0-6) who are unlikely to recommend the brand and may actively discourage others. Component of the NPS calculation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the market in which brand equity is measured (e.g., \'USA\', \'GBR\', \'DEU\'). Enables standardized cross-market reporting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement period covered by this brand equity record. Together with measurement_period_start_date, defines the tracking wave window.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement period covered by this brand equity record. Used to define the temporal window of the tracking wave (e.g., Q1 start, monthly wave start).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodOverPeriodChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Period Over Period Change Flag' ;
    rdfs:comment 'Indicates whether the brand health index change from the prior measurement period is statistically significant based on the confidence interval. True = statistically significant change detected; False = change within margin of error. Supports brand performance alerting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoterPct rdf:type rdf:Property ;
    rdfs:label 'Promoter Pct' ;
    rdfs:comment 'Percentage of surveyed consumers classified as promoters (NPS score 9-10) who are highly likely to recommend the brand. Component of the NPS calculation. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who indicate they intend to purchase the brand in the near future (typically next 30 days). A leading indicator of short-term sales performance. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatPurchasePct rdf:type rdf:Property ;
    rdfs:label 'Repeat Purchase Pct' ;
    rdfs:comment 'Percentage of consumers who have tried the brand and subsequently purchased it again. Measures brand loyalty and consumer retention. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchVendorName rdf:type rdf:Property ;
    rdfs:label 'Research Vendor Name' ;
    rdfs:comment 'Name of the third-party market research vendor or syndicated data provider that conducted the tracking study (e.g., Nielsen, IRI, SPINS, Kantar, Ipsos). Used for data lineage, vendor management, and methodology comparability.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Social Media Sentiment Score' ;
    rdfs:comment 'Composite score reflecting the overall sentiment (positive, neutral, negative) of consumer conversations about the brand on social media platforms during the measurement period. Sourced from social listening tools integrated with Salesforce Marketing Cloud.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the originating system or data provider for this brand equity measurement record. Supports data lineage tracking and multi-source reconciliation in the Databricks Silver Layer. [ENUM-REF-CANDIDATE: NIELSEN|IRI|SPINS|KANTAR|IPSOS|INTERNAL|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Perception Score' ;
    rdfs:comment 'Score measuring consumer perception of the brand\'s sustainability credentials, including environmental responsibility, ethical sourcing, and packaging sustainability. Supports the Sustainability data domain and ESG reporting.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingStudyCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Study Code' ;
    rdfs:comment 'Reference to the brand tracking study or research program that generated this measurement record. Links to the study design, methodology, and vendor details.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialPct rdf:type rdf:Property ;
    rdfs:label 'Trial Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who have ever purchased or tried the brand at least once. Measures brand penetration and new consumer acquisition effectiveness. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unaidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Unaided Awareness Pct' ;
    rdfs:comment 'Percentage of surveyed consumers who spontaneously mention the brand when asked about brands in the category, without any prompting. A key top-of-mind brand health metric. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveLabel rdf:type rdf:Property ;
    rdfs:label 'Wave Label' ;
    rdfs:comment 'Human-readable label identifying the measurement wave (e.g., \'Q1 2024\', \'Wave 3 2024\', \'Jan 2024\'). Used for reporting and trend analysis across tracking periods.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Frequency classification of the measurement wave. Indicates whether the tracking study is conducted monthly, quarterly, bi-annually, annually, or on an ad hoc basis.' ;
    rdfs:domain ind:BrandEquityTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each marketing claim record. Primary key for the marketing_claim data product. Role: MASTER_RESOURCE — this entity represents a managed business resource (a claim definition) with its own identity, lifecycle, and traceability requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claim .

ind:formulationId rdf:type rdf:Property ;
    rdfs:label 'Formulation Id' ;
    rdfs:comment 'Foreign key linking to product.formulation. Business justification: In F&B regulatory compliance, ingredient and process claims (e.g., \'made with real juice\', \'no artificial flavors\') must be substantiated by a specific approved formulation version. Claim substantiati' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulation .

ind:nutritionalPanelId rdf:type rdf:Property ;
    rdfs:label 'Nutritional Panel Id' ;
    rdfs:comment 'Foreign key linking to product.nutritional_panel. Business justification: Nutritional claims (\'good source of fiber\', \'low sodium\') on F&B packaging and marketing materials must be substantiated by the approved nutritional panel version. FDA/FTC claim compliance audits requ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NutritionalPanel .

ind:packagingSpecId rdf:type rdf:Property ;
    rdfs:label 'Packaging Spec Id' ;
    rdfs:comment 'Foreign key linking to product.packaging_spec. Business justification: Packaging claims (\'recyclable\', \'BPA-free\', \'compostable certified\') must be substantiated by the approved packaging specification. F&B regulatory and sustainability teams require direct traceability ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingSpec .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: In F&B, every marketing claim (e.g., \'low sodium\', \'high protein\', \'organic\', \'allergen-free\') must be substantiated by a product specification defining measurable criteria. Regulatory bodies (FDA, EF' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:allergenRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Related Flag' ;
    rdfs:comment 'Indicates whether this claim is related to allergen absence or management (True = allergen-related, e.g., \'Gluten-Free\', \'Peanut-Free\', \'Dairy-Free\'; False = not allergen-related). Triggers additional substantiation and HACCP review requirements per FSMA and FDA allergen labeling rules.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the third-party certification supporting this claim expires and must be renewed. Triggers renewal workflow to prevent lapse in claim validity. Null for claims without external certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certificate or license number issued by the certifying body for this claim. Used for regulatory audit trails and label compliance verification. Null for non-certified claims.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the third-party organization that issued the certification supporting this claim, where applicable (e.g., \'Non-GMO Project\', \'NSF International\', \'USDA Organic\', \'Rainforest Alliance\', \'Kosher Certification Agency\'). Null for claims not backed by external certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Marketing channel(s) on which this claim is approved for use: packaging = on-pack label; digital = website, social media, e-commerce; advertising = TV, print, radio; in_store = shelf talkers, POS displays; foodservice = menu boards, distributor materials; all = approved for all channels. Drives Salesforce Marketing Cloud campaign governance and FTC compliance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCode rdf:type rdf:Property ;
    rdfs:label 'Claim Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the marketing claim (e.g., CLM-NONGMO001). Used as the business identifier across PLM, TraceGains, and Veeva Vault systems for cross-system traceability. Aligns with BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimName rdf:type rdf:Property ;
    rdfs:label 'Claim Name' ;
    rdfs:comment 'Short, human-readable label for the marketing claim as it appears in internal systems and reporting (e.g., \'Non-GMO\', \'Gluten-Free\', \'Heart Healthy\'). Serves as the IDENTITY_LABEL for the claim resource.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the marketing claim record. Controls whether the claim may be applied to SKUs and used in marketing materials. Aligns with LIFECYCLE_STATUS category for MASTER_RESOURCE role. \'draft\' = under development; \'pending_review\' = submitted for legal/regulatory review; \'approved\' = cleared for use; \'active\' = currently in use on packaging or advertising; \'suspended\' = temporarily halted pending investigation; \'expired\' = past effective end date; \'withdrawn\' = permanently retired. [ENUM-REF-CANDIDATE: draft|pending_review|approved|active|suspended|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Full verbatim text of the claim as it appears on packaging, advertising, or digital channels (e.g., \'Made with No Artificial Colors or Flavors\'). This is the exact consumer-facing language subject to FTC and FDA review.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Flag' ;
    rdfs:comment 'Indicates whether this claim is part of the company\'s clean label strategy (True = clean label claim; False = standard marketing claim). Clean label claims include \'No Artificial Ingredients\', \'Simple Ingredients\', \'Non-GMO\', etc. Supports clean label portfolio reporting and NPD strategy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorParityFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Parity Flag' ;
    rdfs:comment 'Indicates whether this claim is being made primarily to achieve competitive parity with market competitors (True = parity claim driven by competitive intelligence; False = differentiation or proprietary claim). Supports trade marketing and category captain strategy analysis.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerResearchRef rdf:type rdf:Property ;
    rdfs:label 'Consumer Research Ref' ;
    rdfs:comment 'Reference identifier for consumer research study (e.g., sensory panel, NPS survey, focus group) that validated consumer understanding and purchase intent impact of this claim. Supports FTC \'reasonable consumer\' substantiation standard and NPD claim strategy.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which the marketing claim is no longer valid for use. Nullable for open-ended claims with no planned expiry. Aligns with EFFECTIVE_UNTIL category. Triggers claim expiry workflow and packaging update notifications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which the marketing claim is valid and may appear on packaging, advertising, or digital channels. Aligns with EFFECTIVE_FROM category. Used for claim-to-SKU applicability windows and regulatory audit trails.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Claim Flag' ;
    rdfs:comment 'Indicates whether this claim makes an environmental or sustainability assertion (True = environmental claim subject to FTC Green Guides, e.g., \'Recyclable\', \'Carbon Neutral\', \'Sustainably Sourced\'; False = non-environmental claim). Environmental claims require specific substantiation per FTC 16 CFR Part 260.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which the most recent periodic review of this claim\'s substantiation and regulatory compliance was completed. Used to calculate next_review_date and to demonstrate ongoing due diligence in regulatory audits.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Status of the legal department\'s review of this marketing claim for FTC compliance, IP considerations, and competitive claim accuracy. Distinct from regulatory approval — legal review focuses on advertising law, substantiation adequacy, and litigation risk.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the legal counsel who reviewed and approved or rejected this marketing claim. Provides accountability trail for FTC compliance and internal governance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOwner rdf:type rdf:Property ;
    rdfs:label 'Marketing Owner' ;
    rdfs:comment 'Name or employee identifier of the marketing team member responsible for managing this claim\'s lifecycle, including renewal, substantiation updates, and channel deployment. Primary business owner for claim governance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Date on which the next mandatory periodic review of this claim\'s substantiation and regulatory compliance is due. Calculated from last review date plus review_frequency_days. Triggers review workflow in Veeva Vault and notifies marketing owner and regulatory reviewer.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional context, caveats, or operational notes related to this marketing claim (e.g., \'Claim valid only for products manufactured at Facility X\', \'Pending re-certification renewal Q3 2025\', \'FTC inquiry resolved 2024-01-15\'). Not used for structured data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Claim Flag' ;
    rdfs:comment 'Indicates whether this claim involves an organic assertion (True = organic claim subject to USDA National Organic Program or equivalent; False = non-organic claim). Organic claims require USDA NOP certification and are subject to strict regulatory oversight.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingVersion rdf:type rdf:Property ;
    rdfs:label 'Packaging Version' ;
    rdfs:comment 'Specific version or revision of the packaging artwork on which this claim appears (e.g., \'v3.2\', \'PV-2024-A\'). Critical for traceability when packaging artwork is updated — ensures the claim is only associated with the correct packaging iteration. Aligns with PLM packaging version control.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority tier assigned to this claim for packaging real estate and advertising emphasis decisions: tier_1 = hero claim (front-of-pack, primary advertising message); tier_2 = supporting claim (back-of-pack, secondary messaging); tier_3 = supplementary claim (website, digital only). Supports planogram and packaging design decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Ref' ;
    rdfs:comment 'Reference number or identifier for the regulatory approval, filing, or notification associated with this claim in a specific market (e.g., FDA GRAS notification number, USDA organic certificate number, EFSA health claim authorization reference). Supports regulatory audit and labeling compliance verification.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Primary regulatory authority or standard that governs the permissibility and substantiation requirements of this claim (e.g., FDA for nutrient content claims, FTC for environmental marketing claims, USDA for organic claims). Drives compliance workflow routing and substantiation documentation requirements. [ENUM-REF-CANDIDATE: FDA|FTC|USDA|EFSA|Codex|EPA|ISO|GFSI|None — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewer rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reviewer' ;
    rdfs:comment 'Name or employee identifier of the regulatory affairs professional who reviewed this claim for compliance with FDA, USDA, EFSA, or other applicable regulations. Provides accountability trail for regulatory audit purposes.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between mandatory periodic reviews of this claim\'s substantiation and regulatory compliance. Drives automated review scheduling in Veeva Vault. Typical values: 365 (annual), 730 (biennial). Ensures claims remain substantiated and compliant over time.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemClaimCode rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Code' ;
    rdfs:comment 'The native identifier for this claim record in the originating operational system (e.g., TraceGains document ID, Veeva Vault record ID, SAP material specification number). Enables bidirectional traceability between the Silver Layer data product and the system of record.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationDocRef rdf:type rdf:Property ;
    rdfs:label 'Substantiation Doc Ref' ;
    rdfs:comment 'Reference identifier for the substantiation document stored in Veeva Vault or TraceGains that provides the scientific, regulatory, or third-party evidence supporting the claim (e.g., lab test results, certification body certificate, clinical study reference, supplier attestation). Required for FTC substantiation standard compliance.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationType rdf:type rdf:Property ;
    rdfs:label 'Substantiation Type' ;
    rdfs:comment 'Type of evidence used to substantiate the marketing claim. Determines the rigor and auditability of the claim\'s support: lab_test = analytical laboratory results; third_party_cert = certification body verification (e.g., Non-GMO Project, NSF); clinical_study = peer-reviewed or commissioned research; supplier_attestation = supplier-provided declaration; regulatory_filing = FDA/USDA submission; internal_audit = internal quality audit.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within the claim type (e.g., within \'nutritional\': \'health claim\', \'nutrient content claim\', \'structure/function claim\'; within \'environmental\': \'packaging\', \'sourcing\', \'carbon\'). Supports detailed regulatory mapping and clean label strategy analytics. [ENUM-REF-CANDIDATE: health_claim|nutrient_content_claim|structure_function_claim|allergen_free|organic|non_gmo|fair_trade|carbon_neutral|recyclable — promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for each demand plan record at the SKU/DC/time-period granularity. Primary key for the demand_plan data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_budget. Business justification: S&OP financial reconciliation: consensus demand volume is compared against the revenue budget to identify gaps. F&B IBP processes explicitly reconcile demand plans to financial budgets; finance needs ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:centerId rdf:type rdf:Property ;
    rdfs:label 'Center Id' ;
    rdfs:comment 'Reference to the Distribution Center (DC) or warehouse location for which the demand plan is generated. Supports network-level demand disaggregation across the DC network and 3PL partners.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Demand plans are bucketed by fiscal period for financial reporting alignment. F&B companies align demand planning horizons to fiscal periods for P&L forecasting and period-close demand reporting. plan' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Foreign key linking to finance.forecast. Business justification: S&OP financial reconciliation: demand plan consensus volume is reconciled against the financial forecast each planning cycle. F&B IBP practitioners explicitly link demand plans to the finance forecast' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Demand plans are created at SKU/DC/time-period granularity per the product description. demand_plan already has center_id (cross-domain to distribution.center) for the distribution center dimension. A' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:shipToLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Id' ;
    rdfs:comment 'Foreign key linking to customer.ship_to_location. Business justification: In F&B VMI and CPFR programs, demand plans are built at the customer ship-to location level (e.g., retailer DC or store). This FK enables location-level demand sensing, replenishment planning, and cus' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipToLocation .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Reference to the Sales and Operations Planning (S&OP) / Integrated Business Planning (IBP) cycle in which this demand plan record was generated or last updated. Enables traceability of demand plan versions to specific planning cycles.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Territory-level demand disaggregation is a named F&B S&OP process — demand plans are segmented by sales territory to align regional forecasts with sales targets. A domain expert expects demand_plan to' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:adjustedForecastQty rdf:type rdf:Property ;
    rdfs:label 'Adjusted Forecast Qty' ;
    rdfs:comment 'Demand forecast quantity after planner-applied manual adjustments, overrides, or market intelligence inputs on top of the statistical baseline. Reflects demand planner judgment before consensus alignment.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the demand plan record was formally approved during the S&OP consensus cycle. Supports audit trail, SLA compliance tracking, and planning cycle performance measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baselineForecastQty rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Qty' ;
    rdfs:comment 'Underlying demand forecast quantity representing the expected sell-through volume excluding any promotional uplift, new product launch effects, or extraordinary events. Used as the reference point for uplift/downlift factor calculation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusForecastQty rdf:type rdf:Property ;
    rdfs:label 'Consensus Forecast Qty' ;
    rdfs:comment 'Final agreed demand volume (in selling units) resulting from the cross-functional S&OP consensus process, incorporating inputs from Sales, Marketing, Finance, and Supply Chain. This is the primary input to supply planning and inventory optimization.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerOrderQty rdf:type rdf:Property ;
    rdfs:label 'Customer Order Qty' ;
    rdfs:comment 'Confirmed customer purchase order quantity for the SKU/DC/period, sourced from SAP S/4HANA SD or EDI order feeds. Represents committed demand and is used to override or supplement statistical forecasts in the near-term horizon.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClass rdf:type rdf:Property ;
    rdfs:label 'Demand Class' ;
    rdfs:comment 'Classification of the demand type for supply planning purposes. \'regular\' = baseline replenishment demand; \'promotional\' = trade promotion-driven demand; \'new_product\' = NPD launch demand; \'phase_out\' = end-of-life demand; \'safety_stock\' = buffer stock demand.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSensingQty rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Qty' ;
    rdfs:comment 'Near-term demand signal quantity derived from high-frequency data inputs including Point of Sale (POS) data, customer orders, and syndicated data (Nielsen/IRI). Used for daily/weekly supply execution and short-horizon replenishment decisions.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Forecast Algorithm' ;
    rdfs:comment 'Statistical or machine learning algorithm used to generate the baseline statistical forecast for this SKU/period. Used for model governance, accuracy benchmarking, and algorithm selection optimization. [ENUM-REF-CANDIDATE: exponential_smoothing|arima|moving_average|machine_learning|croston|holt_winters|causal — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConfidencePct rdf:type rdf:Property ;
    rdfs:label 'Forecast Confidence Pct' ;
    rdfs:comment 'Statistical confidence level (expressed as a percentage, 0–100) associated with the demand forecast, indicating the reliability of the forecast model output. Used to flag low-confidence forecasts for planner review and safety stock buffer sizing.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastErrorPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Error Pct' ;
    rdfs:comment 'Historical Mean Absolute Percentage Error (MAPE) of the forecasting model for this SKU/DC combination, expressed as a percentage. Used to assess forecast model accuracy, trigger model recalibration, and size safety stock buffers.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastLowerBoundQty rdf:type rdf:Property ;
    rdfs:label 'Forecast Lower Bound Qty' ;
    rdfs:comment 'Lower confidence interval bound for the demand forecast quantity, representing the low-end demand scenario. Used for inventory optimization, downside risk assessment, and supply-demand balancing.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastUom rdf:type rdf:Property ;
    rdfs:label 'Forecast Uom' ;
    rdfs:comment 'Unit of measure in which all forecast quantity fields are expressed (e.g., CS = cases, EA = each, LB = pounds, KG = kilograms). Aligns with the selling unit of measure defined in the SAP S/4HANA material master. [ENUM-REF-CANDIDATE: CS|EA|LB|KG|OZ|GAL|L|MT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastUpperBoundQty rdf:type rdf:Property ;
    rdfs:label 'Forecast Upper Bound Qty' ;
    rdfs:comment 'Upper confidence interval bound for the demand forecast quantity, representing the high-end demand scenario. Used for safety stock calculation, capacity planning, and supply risk management.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'Indicates whether the demand plan record is frozen (locked) for supply execution and cannot be modified by planners. Frozen plans are used as firm inputs to production scheduling and procurement within the planning fence horizon.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewProduct rdf:type rdf:Property ;
    rdfs:label 'Is New Product' ;
    rdfs:comment 'Indicates whether this demand plan record is for a New Product Development (NPD) / new SKU launch, where no historical sales data exists for statistical forecasting. Triggers use of analogous product forecasting or market-based estimation methods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period End Date' ;
    rdfs:comment 'The last calendar date of the planning time bucket to which this demand plan record applies. Together with plan_period_start_date, defines the demand planning horizon window.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Period Start Date' ;
    rdfs:comment 'The first calendar date of the planning time bucket (day, week, or month) to which this demand plan record applies. Used to align demand signals with supply planning and inventory replenishment cycles.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text commentary entered by the demand planner to document the rationale for manual forecast adjustments, market intelligence inputs, or exceptions. Supports audit trail and knowledge transfer within the S&OP process.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time granularity of the demand plan bucket. \'daily\' and \'weekly\' are used for near-term demand sensing and supply execution; \'monthly\' is used for S&OP and IBP cycles; \'quarterly\' for long-range planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSalesQty rdf:type rdf:Property ;
    rdfs:label 'Pos Sales Qty' ;
    rdfs:comment 'Actual Point of Sale (POS) sell-through quantity for the SKU during the plan period, sourced from retailer POS data feeds. Used as a demand sensing input signal to update near-term forecasts and detect demand shifts.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalUpliftQty rdf:type rdf:Property ;
    rdfs:label 'Promotional Uplift Qty' ;
    rdfs:comment 'Incremental demand volume (in selling units) attributed to planned trade promotions, marketing campaigns, or temporary price reductions above the baseline forecast. Sourced from Trade Promotion Management (TPM) systems and applied as an uplift factor.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Seasonal index factor for the SKU/period combination, representing the ratio of period demand to average annual demand. Values >1.0 indicate above-average seasonal demand; <1.0 indicate below-average. Used in statistical forecasting model decomposition.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensingHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Sensing Horizon Days' ;
    rdfs:comment 'Number of days into the future covered by the demand sensing signal for this plan record. Typically 1–14 days for near-term POS-driven demand sensing. Distinguishes short-horizon sensing from longer-horizon statistical forecasts.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalForecastQty rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Qty' ;
    rdfs:comment 'System-generated baseline demand forecast quantity (in selling units) produced by the statistical forecasting algorithm (e.g., exponential smoothing, ARIMA, machine learning) in SAP IBP or JDA/Blue Yonder, prior to any manual adjustment or consensus override.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upliftFactor rdf:type rdf:Property ;
    rdfs:label 'Uplift Factor' ;
    rdfs:comment 'Multiplicative factor applied to the baseline forecast to account for demand uplift (>1.0) or downlift (<1.0) from events such as trade promotions, new product launches, distribution gains/losses, or market disruptions. A value of 1.0 indicates no adjustment.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upliftReason rdf:type rdf:Property ;
    rdfs:label 'Uplift Reason' ;
    rdfs:comment 'Business reason code explaining the cause of the uplift or downlift factor applied to the baseline forecast. Used for demand decomposition analysis and post-event forecast accuracy review. [ENUM-REF-CANDIDATE: promotion|new_product_launch|distribution_gain|distribution_loss|seasonality|event|competitor_action|price_change|none — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the supply plan record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Foreign key linking to product.bill_of_materials. Business justification: MRP and IBP supply plans execute against a specific BOM version — planned_production_qty, costing_lot_size, and yield calculations depend on the active BOM. Supply planners must know which BOM revisio' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: Supply planning must honor contracted volumes; linking supply_plan to sales_contract enables the Contract-Based Production Planning process.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:financeStandardCostId rdf:type rdf:Property ;
    rdfs:label 'Finance Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_standard_cost. Business justification: Supply planning uses standard costs to value planned production quantities and calculate planned COGS. F&B supply planners reference standard cost records when evaluating make-vs-buy decisions and pro' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceStandardCost .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Reference to the manufacturing plant or production facility associated with this supply plan record. Used for SKU/plant-level planning granularity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:allocationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Required Flag' ;
    rdfs:comment 'Indicates whether supply allocation decisions are required for this SKU/DC due to constrained supply. When true, the supply plan drives allocation logic in the order management and trade management systems.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when the supply plan was formally approved by the designated S&OP approver. Null if the plan has not yet been approved. Part of IBP governance audit trail.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closingInventoryQty rdf:type rdf:Property ;
    rdfs:label 'Closing Inventory Qty' ;
    rdfs:comment 'Projected on-hand inventory quantity for the SKU at the end of the planning horizon after accounting for planned production, receipts, and shipments. Indicates supply-demand balance position.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coPackingFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packing Flag' ;
    rdfs:comment 'Indicates whether the planned production quantity for this SKU involves co-packing or toll manufacturing arrangements with a third-party contract manufacturer, affecting supply lead times and MOQ constraints.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandQty rdf:type rdf:Property ;
    rdfs:label 'Demand Qty' ;
    rdfs:comment 'Total planned demand quantity for the SKU over the planning horizon as consumed from the demand plan. Represents the demand signal used for supply-demand balancing in IBP.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSensingFlag rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Flag' ;
    rdfs:comment 'Indicates whether the demand quantity in this supply plan was derived from SAP IBP Demand Sensing (short-horizon statistical signal) rather than the standard statistical forecast. Affects plan accuracy benchmarking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:horizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Horizon End Date' ;
    rdfs:comment 'The last date of the planning horizon covered by this supply plan. Defines the end boundary for planned production, receipts, and shipment quantities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:horizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Horizon Start Date' ;
    rdfs:comment 'The first date of the planning horizon covered by this supply plan. Defines the start boundary for planned production, receipts, and shipment quantities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Total supply lead time in calendar days for the SKU from production order release to DC receipt. Used in replenishment signal timing and safety stock calculations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production lot size for the SKU at the plant, used to round planned production quantities to feasible manufacturing batch sizes in the constrained supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) constraint applied to this SKU in the supply plan. Ensures production and procurement orders meet supplier or manufacturing minimum thresholds.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Identifies the tier of the supply network node (plant, primary DC, secondary DC, 3PL, cross-dock) for which this supply plan record is generated. Supports network design analytics.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingInventoryQty rdf:type rdf:Property ;
    rdfs:label 'Opening Inventory Qty' ;
    rdfs:comment 'On-hand inventory quantity for the SKU at the start of the planning horizon. Used as the baseline for supply-demand balance position calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The real-world business event timestamp when this supply plan version was generated or published in the IBP system. Distinct from the audit record creation timestamp.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedProductionQty rdf:type rdf:Property ;
    rdfs:label 'Planned Production Qty' ;
    rdfs:comment 'Total planned production quantity for the SKU at the plant over the planning horizon, expressed in the SKU\'s base unit of measure. Key volume metric driving MES scheduling and capacity allocation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsQty rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Qty' ;
    rdfs:comment 'Total planned inbound receipts quantity for the SKU at the DC over the planning horizon, including transfers from plants and external supplier deliveries. Key volume metric for supply-demand balancing.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedShipmentsQty rdf:type rdf:Property ;
    rdfs:label 'Planned Shipments Qty' ;
    rdfs:comment 'Total planned outbound shipments quantity for the SKU from the DC over the planning horizon. Drives replenishment signals and allocation decisions when supply is constrained.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'Identifies the IBP/S&OP planning cycle (e.g., monthly-2024-06) to which this supply plan belongs. Enables cycle-over-cycle comparison and governance tracking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text reason provided by the approver when a supply plan is rejected in the IBP approval workflow. Null when plan_status is not \'rejected\'. Supports governance audit trail.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentSignalReleased rdf:type rdf:Property ;
    rdfs:label 'Replenishment Signal Released' ;
    rdfs:comment 'Indicates whether the replenishment signal derived from this supply plan has been released to the ERP or WMS for execution. Tracks plan-to-execution handoff status.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationPolicy rdf:type rdf:Property ;
    rdfs:label 'Rotation Policy' ;
    rdfs:comment 'Inventory rotation policy applied to this SKU in the supply plan. FIFO (First In First Out) and FEFO (First Expired First Out) are standard in food and beverage to minimize waste and ensure food safety compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer inventory quantity for the SKU at the DC/plant, set to protect against demand variability and supply disruptions. Drives replenishment trigger signals in IBP.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Remaining shelf life in days for the SKU as applied in this supply plan. Governs FEFO (First Expired First Out) rotation policy and constrains planned shipment sequencing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Constraint Flag' ;
    rdfs:comment 'Indicates whether this supply plan record reflects a constrained supply scenario where planned production or receipts are insufficient to fully satisfy planned demand. Triggers allocation decision workflows.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyDemandBalanceQty rdf:type rdf:Property ;
    rdfs:label 'Supply Demand Balance Qty' ;
    rdfs:comment 'Net supply-demand balance position for the SKU over the planning horizon (planned supply minus planned demand). Positive values indicate surplus; negative values indicate a supply gap requiring allocation decisions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Base unit of measure for all quantity fields in this supply plan record (e.g., CS=Case, EA=Each, KG=Kilogram). Aligns with the SKU\'s base UOM in SAP S/4HANA. [ENUM-REF-CANDIDATE: CS|EA|KG|LB|L|GAL|MT|OZ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the replenishment order record in the Silver layer lakehouse. Primary key. Entity role: TRANSACTION_HEADER — represents a discrete supply chain planning event with a full lifecycle (planned → firmed → released → received).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:approvedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier Id' ;
    rdfs:comment 'Foreign key linking to ingredient.approved_supplier. Business justification: F&B procurement policy mandates replenishment orders be placed only against approved supplier-ingredient combinations. Linking replenishment_order to approved_supplier enforces this constraint, suppor' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedSupplier .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Foreign key linking to procurement.approved_vendor_list. Business justification: F&B procurement compliance requires that replenishment orders reference the AVL record authorizing the supplier for that material. AVL status (approved, suspended) must be verified at order creation —' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendorList .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Reference to the logistics carrier or 3PL partner assigned to transport this replenishment order. Used for carrier performance tracking, freight cost allocation, and SLA compliance monitoring.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:destinationLocationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Network Node Id' ;
    rdfs:comment 'Reference to the receiving plant, Distribution Center (DC), or 3PL facility where inventory is to be delivered. Drives inbound shipment creation, receiving dock scheduling, and inventory position updates at the destination.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:destinationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Replenishment orders specify a destination storage location within the DC for WMS-directed putaway. While destination_location_network_node_id captures the node level, storage_location_id provides the' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:ediTradingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Id' ;
    rdfs:comment 'Foreign key linking to customer.edi_trading_partner. Business justification: In F&B, replenishment orders are frequently triggered and exchanged via EDI (850/855/856 transactions) with specific retail trading partners. This FK links each replenishment order to its EDI trading ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTradingPartner .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to distribution.fulfillment_order. Business justification: Replenishment orders in supply planning trigger fulfillment orders in distribution execution — this is the core supply-to-distribution handoff in F&B DC operations. Linking them enables order lifecycl' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:ingredientCostId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost Id' ;
    rdfs:comment 'Foreign key linking to ingredient.cost. Business justification: Replenishment orders for raw materials reference the approved cost record (standard/planned price) at order creation for financial commitment and purchase order valuation. F&B procurement requires cap' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cost .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Foreign key linking to supply.lane. Business justification: Replenishment orders move finished goods between network nodes along defined transportation lanes. replenishment_order.transport_mode is an execution-specific attribute (kept as it captures the actual' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:lotTraceId rdf:type rdf:Property ;
    rdfs:label 'Lot Trace Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_trace. Business justification: Replenishment orders for perishable F&B products must track lot/batch assignments to enforce FEFO rotation and support recall readiness. replenishment_order carries a denormalized batch_number; a prop' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotTrace .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Replenishment orders in F&B are fulfilled against specific PO lines (e.g., blanket PO releases). Line-level linkage enables accurate quantity tracking, shelf-life compliance per line, and invoice matc' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:primaryReplenishmentNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Network Node Id' ;
    rdfs:comment 'Reference to the originating plant, Distribution Center (DC), or 3PL facility from which inventory will be shipped or transferred. Used for network design analysis, inbound logistics planning, and supply-demand balancing across the DC network.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:productStandardCostId rdf:type rdf:Property ;
    rdfs:label 'Product Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to product.product_standard_cost. Business justification: Replenishment order financial valuation (total_order_value, unit_cost) must reference the approved standard cost record for GL posting and cost variance reporting. F&B finance teams reconcile replenis' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductStandardCost .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: DRP/MRP replenishment signals trigger make-to-replenish production orders in F&B supply chains. Linking replenishment_order to production_order enables end-to-end replenishment fulfillment tracking, p' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:rawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Id' ;
    rdfs:comment 'Reference to the finished good, raw material, or packaging material being replenished. Links to the material master for product specifications, shelf life parameters, and FIFO/FEFO rotation rules applicable to this order.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Foreign key linking to regulatory.recall_event. Business justification: When a recall is issued, replenishment orders for affected SKUs must be halted immediately. Supply planners link orders to active recall events to prevent shipment of recalled product — a mandatory FS' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:safetyStockPolicyId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Policy Id' ;
    rdfs:comment 'Foreign key linking to supply.safety_stock_policy. Business justification: replenishment_order has a safety_stock_trigger BOOLEAN flag indicating the order was triggered by a safety stock policy breach. When safety_stock_trigger=true, the specific safety_stock_policy that tr' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyStockPolicy .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Order-driven replenishment: each replenishment order is generated to satisfy a specific sales order, required for the Replenishment Execution Report.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:shelfLifeSpecId rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Spec Id' ;
    rdfs:comment 'Foreign key linking to product.shelf_life_spec. Business justification: Replenishment orders in F&B specify minimum remaining shelf life requirements (shelf_life_days_remaining field) governed by the shelf_life_spec\'s dc_receiving_standard and rotation_rule. Supply planne' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShelfLifeSpec .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Order fulfillment process tracks which inventory stock position is being replenished, enabling OTIF and inventory aging analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:storeId rdf:type rdf:Property ;
    rdfs:label 'Store Id' ;
    rdfs:comment 'Foreign key linking to sales.store. Business justification: DSD (Direct Store Delivery) and VMI replenishment orders in F&B are fulfilled to specific store locations. Store-level replenishment is a core operational process; a domain expert expects replenishmen' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Store .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: FSMA requires traceability to the specific supplier manufacturing site for each replenishment order. Site-level data (lead time, food safety cert, capacity) affects order planning. replenishment_order' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date on which goods were physically received at the destination location (goods receipt posting date). Used to calculate On Time In Full (OTIF) performance, lead time actuals, and delivery variance against requested and confirmed dates.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'The Advanced Shipping Notice (ASN) number transmitted by the supplier or source location confirming shipment of this replenishment order. Enables proactive receiving dock scheduling, WMS pre-receipt processing, and shipment tracking. Transmitted via EDI 856.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier or supplying location. May differ from requested_delivery_date. Used to calculate delivery date variance, assess OTIF risk, and trigger escalation workflows when confirmation is later than requested.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity confirmed by the supplier or supplying location as available and committed for fulfillment. May differ from ordered_quantity due to partial availability, capacity constraints, or MOQ adjustments. Used for supply-demand gap analysis and OTIF measurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The expiration or best-before date of the batch being replenished. Used to enforce FEFO rotation policy, calculate shelf_life_days_remaining, and ensure compliance with customer minimum remaining shelf life requirements. Critical for food safety and waste reduction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ibpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Ibp Plan Version' ;
    rdfs:comment 'The SAP Integrated Business Planning (IBP) plan version or S&OP cycle version under which this replenishment order was generated (e.g., \'BASELINE_2024Q3\', \'CONSENSUS_V2\'). Enables comparison of supply proposals across planning scenarios and IBP consensus cycles.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqCompliant rdf:type rdf:Property ;
    rdfs:label 'Moq Compliant' ;
    rdfs:comment 'Indicates whether the ordered_quantity meets or exceeds the Minimum Order Quantity (MOQ) requirement for this material-supplier combination. True = compliant; False = below MOQ threshold, requiring buyer review or rounding up before release.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'The Minimum Order Quantity (MOQ) applicable to this replenishment order as defined in the purchasing info record or supply planning parameters. Ensures ordered_quantity meets supplier or logistics minimum thresholds. Critical for procurement compliance and cost optimization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'The MRP controller code or planner identifier responsible for managing the replenishment of this material at the source plant. Used for workload assignment, exception management, and accountability tracking in supply planning operations.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the replenishment order was created or generated by the MRP/supply planning system. Represents the principal real-world event time for this transaction. Used for aging analysis, lead time calculation, and OTIF measurement baseline. Maps to BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known business identifier for the replenishment order as assigned by the ERP or supply planning system (e.g., SAP purchase order number, stock transport order number, or MRP planned order number). Used for cross-system traceability and communication with suppliers and logistics partners. Maps to BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the replenishment order. Tracks progression from MRP-generated planned order through firming, release to warehouse/supplier, in-transit movement, and final goods receipt. Cancelled indicates the order was voided before fulfillment. Maps to LIFECYCLE_STATUS category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the replenishment order by its procurement mechanism. Stock Transfer Order (STO) moves inventory between internal plants or DCs. Purchase Requisition is a request to procure from an external supplier. Planned Order is an MRP-generated supply proposal. Purchase Order is a confirmed external procurement. Intercompany Transfer moves goods between legal entities. [ENUM-REF-CANDIDATE: stock_transfer_order|purchase_requisition|planned_order|purchase_order|intercompany_transfer — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of material requested in the replenishment order, expressed in the base unit of measure (e.g., cases, pallets, kg). This is the gross supply proposal quantity generated by MRP or supply planning before any MOQ rounding or adjustment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Goods Issue Date' ;
    rdfs:comment 'The planned date on which goods are to be issued from the source location (outbound shipment departure). Used for outbound logistics scheduling, warehouse pick/pack planning, and lead time calculation between goods issue and goods receipt.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningRunCode rdf:type rdf:Property ;
    rdfs:label 'Planning Run Code' ;
    rdfs:comment 'Reference to the MRP or supply planning run that generated this replenishment order. Enables traceability of supply proposals back to the specific planning cycle, demand signal, and parameter set used. Supports audit of planning decisions and scenario comparison.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityHold rdf:type rdf:Property ;
    rdfs:label 'Quality Hold' ;
    rdfs:comment 'Indicates whether this replenishment order or the associated batch is subject to a quality hold that prevents goods receipt or putaway at the destination. True = quality hold active; False = no hold. Integrates with QM module and HACCP/GMP compliance processes.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of material received at the destination location upon goods receipt. Used to calculate fill rate, identify short shipments, and trigger OTIF performance measurement against the confirmed quantity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the replenishment order is required to arrive at the destination location to meet demand or safety stock targets. Drives supplier scheduling, transportation booking, and OTIF measurement. Set by supply planning based on demand signals and inventory parameters.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockTrigger rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger' ;
    rdfs:comment 'Indicates whether this replenishment order was triggered by a safety stock breach (projected inventory falling below safety stock level) rather than a standard demand-driven replenishment signal. True = safety stock replenishment; False = demand-driven or scheduled replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDaysRemaining rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days Remaining' ;
    rdfs:comment 'The number of days of remaining shelf life on the material at the time of order creation, based on the production date and expiry date of the batch being replenished. Critical for FEFO compliance, quality assurance, and ensuring product arrives at destination with sufficient remaining shelf life to meet customer requirements.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'The total monetary value of the replenishment order calculated as ordered_quantity multiplied by unit_cost. Used for procurement spend analysis, inventory investment tracking, and financial planning. Expressed in the order currency. Classified as confidential.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'The mode of transportation used to move the replenishment order from source to destination location. Drives freight cost estimation, lead time calculation, and carbon footprint reporting for sustainability compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The standard or purchase cost per unit of measure for the material in this replenishment order. Used to calculate total order value, Cost of Goods Sold (COGS) impact, and inventory valuation. Classified as confidential as it reflects procurement pricing strategy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The base unit of measure in which ordered, confirmed, and received quantities are expressed (e.g., CS=Cases, EA=Each, KG=Kilograms, LB=Pounds, PAL=Pallets, L=Liters, GAL=Gallons). Aligns with the material master UOM configuration in SAP. [ENUM-REF-CANDIDATE: CS|EA|KG|LB|PAL|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specQualitySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Spec Quality Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Safety-stock calculations depend on product specs (shelf-life, storage) defined in SPECIFICATION; required for inventory planning reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Safety stock policies in F&B are defined at the storage location level because ambient, chilled, and frozen locations have fundamentally different lead times, variability factors, and shelf-life const' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the SKU based on demand volume or revenue contribution. \'A\' items are high-value/high-velocity requiring tighter safety stock management; \'C\' items are low-velocity with broader buffers. Used to prioritize inventory management effort.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to derive the safety stock quantity. \'statistical\' uses demand variability and service level targets; \'days_of_supply\' uses a fixed days-of-supply multiplier; \'manual\' is planner-set; \'min_max\' uses min/max replenishment bands; \'demand_driven\' uses demand sensing signals from SAP IBP.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text description of the business reason for the most recent change to this safety stock policy (e.g., \'Seasonal uplift for Q4 holiday demand\', \'Supplier lead time increase\', \'Post-launch NPD recalibration\'). Required for audit and S&OP governance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Demand Horizon Days' ;
    rdfs:comment 'Number of forward-looking days of demand used in the safety stock calculation. Defines the planning horizon over which demand variability is measured for statistical safety stock methods.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandVariabilityFactor rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Factor' ;
    rdfs:comment 'Standard deviation or coefficient of variation of demand used in statistical safety stock calculations. Derived from historical demand sensing data in SAP IBP. Higher values result in larger safety stock buffers.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this safety stock policy becomes binding and governs replenishment decisions for the SKU-location combination. Aligns with IBP/S&OP planning cycle activation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ibpPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Ibp Policy Code' ;
    rdfs:comment 'Source system identifier for this safety stock policy record in SAP IBP (Integrated Business Planning). Used for cross-system traceability and reconciliation between the lakehouse Silver layer and the SAP IBP operational system.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this policy includes a promotional uplift buffer to support planned trade promotions (TPM/TPO events). When True, additional safety stock is pre-positioned at the DC ahead of promotional periods.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this safety stock policy incorporates seasonal demand adjustments. When True, the safety stock quantity and days of supply parameters are adjusted based on seasonal demand patterns from the demand planning system.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jdaPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Jda Policy Code' ;
    rdfs:comment 'Source system identifier for this safety stock policy record in JDA/Blue Yonder Supply Planning. Populated when JDA is the system of record for replenishment planning at the DC network level.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation of replenishment lead time in days. Used in statistical safety stock calculations to account for supply uncertainty. Higher variability increases the required safety stock buffer.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity for the SKU at the location. Defines the upper bound of the min/max replenishment band. Replenishment orders are sized to bring inventory up to this level.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockQty rdf:type rdf:Property ;
    rdfs:label 'Min Stock Qty' ;
    rdfs:comment 'Minimum allowable on-hand inventory quantity for the SKU at the location. Defines the lower bound of the min/max replenishment band. Replenishment is triggered when inventory falls to or below this level.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningSegment rdf:type rdf:Property ;
    rdfs:label 'Planning Segment' ;
    rdfs:comment 'Supply chain planning segment classification for the SKU-location combination. Determines the applicable replenishment and safety stock strategy. \'make_to_stock\' is most common for CPG/food and beverage finished goods.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this safety stock policy record across systems (e.g., SAP IBP, JDA/Blue Yonder). Used for cross-system reconciliation and EDI references.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name describing the safety stock policy, typically referencing the SKU, location, or planning segment it governs (e.g., \'RTD Beverage - DC East - Statistical SS\').' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock policy. \'active\' means the policy is live and governing replenishment; \'draft\' means under configuration; \'pending_review\' means awaiting S&OP approval; \'suspended\' means temporarily disabled.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of the safety stock policy record, incremented each time the policy parameters are updated. Supports policy change history tracking and audit trail requirements within the supply planning governance framework.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingShelfLifeMinPct rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Min Pct' ;
    rdfs:comment 'Minimum acceptable remaining shelf life percentage at time of receipt or shipment from the DC. Ensures safety stock inventory meets customer and retailer freshness requirements. Expressed as a percentage of total shelf life (e.g., 66.67 means at least 2/3 of shelf life must remain).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment order is triggered for the SKU at the specified location. Calculated as safety stock plus expected demand during replenishment lead time.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentQty rdf:type rdf:Property ;
    rdfs:label 'Replenishment Qty' ;
    rdfs:comment 'Standard replenishment order quantity triggered when the reorder point is reached. May be constrained by MOQ (Minimum Order Quantity) or pallet/layer rounding rules from the supplier or DC network.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'Frequency in days at which inventory position is reviewed and replenishment decisions are made. Relevant for periodic review systems. Impacts the safety stock calculation for periodic review models.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Days Of Supply' ;
    rdfs:comment 'Safety stock expressed as number of days of forward demand coverage. Used when calculation_method is \'days_of_supply\'. Provides a demand-relative buffer measure aligned with FIFO/FEFO rotation policies.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyFactor rdf:type rdf:Property ;
    rdfs:label 'Safety Factor' ;
    rdfs:comment 'Statistical safety factor (z-score) corresponding to the target service level. Applied to demand and lead time variability to compute the safety stock quantity in statistical calculation methods. Derived from the normal distribution at the specified service level target.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'Target service level (cycle service level or fill rate) expressed as a percentage (e.g., 98.5) used in statistical safety stock calculations. Drives the safety factor (z-score) applied to demand variability. Directly impacts OTIF performance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Base unit of measure in which safety stock quantities, reorder points, and replenishment quantities are expressed (e.g., CS for case, EA for each, KG for kilogram). Aligns with SAP S/4HANA material master UOM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'XYZ classification of the SKU based on demand variability. \'X\' items have stable, predictable demand; \'Y\' items have moderate variability; \'Z\' items have highly erratic demand. Combined with ABC classification to set differentiated safety stock policies.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Unique surrogate identifier for the inbound shipment record in the lakehouse Silver layer. Primary key. Entity role: TRANSACTION_HEADER — represents a discrete inbound logistics event with a full lifecycle from ASN through goods receipt and putaway.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Three-way match: inbound shipment (goods receipt) is matched against the AP invoice for payment processing. F&B procurement finance teams link GR documents to AP invoices for invoice verification; inv' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:complianceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Id' ;
    rdfs:comment 'Foreign key linking to procurement.compliance_document. Business justification: FSMA and GFSI require linking each inbound shipment to its governing compliance document (COA, food safety cert). certificate_of_analysis_ref is a denormalized text reference. A proper FK enables docu' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceDocument .

ind:destinationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Inbound shipments arrive at a specific network node (DC, manufacturing plant, co-packer). inbound_shipment.storage_location_code is a more granular bin/rack-level reference and is kept. Adding destina' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Foreign key linking to distribution.shipment. Business justification: Inbound supplier shipments (supply domain) must be reconciled with distribution.shipment records for the same physical movement. F&B DCs use this link for OTIF reconciliation, goods receipt matching, ' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:establishmentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Establishment Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.establishment_registration. Business justification: Inbound shipments must be tied to the registered facility of the supplier for FDA/USDA import compliance tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstablishmentRegistration .

ind:importExportPermitId rdf:type rdf:Property ;
    rdfs:label 'Import Export Permit Id' ;
    rdfs:comment 'Foreign key linking to regulatory.import_export_permit. Business justification: Cross-border inbound shipments require a valid import permit for customs clearance and FDA prior notice compliance. Linking each shipment to its governing import/export permit is a standard customs an' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImportExportPermit .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: INBOUND_SHIPMENT quality inspection results must be linked to INSPECTION_LOT for compliance release and traceability reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Precise timestamp when the carrier physically arrived at the receiving dock or gate. BUSINESS_EVENT_TIMESTAMP category. Used for OTIF (On Time In Full) calculation, carrier performance KPIs, and dock turnaround time analysis.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnDate rdf:type rdf:Property ;
    rdfs:label 'Asn Date' ;
    rdfs:comment 'Date the Advance Ship Notice (ASN) was transmitted by the supplier. BUSINESS_EVENT_TIMESTAMP category (day-level precision for planning). Used for lead time analysis and supplier compliance measurement against EDI 856 transmission SLAs.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Supplier-assigned or internally-generated batch or lot number assigned to the received material at goods receipt. Critical for FIFO/FEFO rotation policy enforcement, allergen matrix traceability, HACCP compliance, and FSMA lot-level traceability requirements.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO 6346 shipping container identification number for ocean or intermodal freight. Used for port customs clearance, container tracking, and import compliance documentation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the material was manufactured or processed. Required for customs declarations, USDA country-of-origin labeling (COOL) compliance, and import duty calculation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-issued delivery note or packing slip number accompanying the physical shipment. Used for goods receipt posting in SAP MM (MIGO) and for dispute resolution with suppliers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment terms indicating who bears the transportation cost for the inbound shipment. Prepaid means supplier pays; collect means Food Beverage pays at destination. Used for freight cost allocation and AP processing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Timestamp' ;
    rdfs:comment 'Timestamp when the goods receipt was formally posted in SAP MM (MIGO transaction), triggering inventory update and accounts payable (AP) posting. Critical for FIFO/FEFO lot assignment and financial period close.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the inbound shipment in kilograms, including packaging and pallets. Used for freight cost calculation, dock capacity planning, and customs documentation. QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the transfer of risk and responsibility between supplier and Food Beverage for the shipment. Determines freight cost ownership and insurance liability. Used in AP invoice validation and landed cost calculation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether the inbound shipment contains hazardous materials (e.g., cleaning chemicals, food-grade solvents) requiring special handling, labeling, and regulatory compliance under DOT/IATA regulations.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether the inbound shipment requires temperature-controlled (cold chain) transportation and storage conditions (e.g., refrigerated or frozen). Triggers cold chain compliance checks and specialized putaway routing in WMS.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date the material was manufactured by the supplier or co-packer. Used in conjunction with expiry_date for FEFO (First Expired First Out) rotation policy enforcement and shelf life management.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Boolean indicator of whether the inbound shipment was delivered On Time and In Full (OTIF) against the scheduled_arrival_date and quantity_shipped. True = OTIF achieved; False = OTIF missed. Used for supplier and carrier performance scorecards.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets included in the inbound shipment. Used for dock scheduling, labor resource planning, and warehouse space allocation at the receiving DC or plant.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number or Bill of Lading (BOL) number used to track the shipment in transit. Enables real-time inbound visibility and carrier performance tracking. Used for freight claims and dispute resolution.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Timestamp' ;
    rdfs:comment 'Timestamp when the received goods were physically placed into the designated storage location within the plant or DC. Marks completion of the inbound logistics lifecycle. Used for dock-to-stock cycle time measurement.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection lot associated with the goods receipt in SAP QM. Indicates whether the received batch has passed, failed, or is pending quality inspection before release to unrestricted stock. Supports HACCP, SQF, and GFSI compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual quantity of the material physically received and posted in SAP MM goods receipt (MIGO). May differ from quantity_shipped due to transit damage, short shipment, or over-delivery. Triggers inventory update upon posting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Total quantity of the material dispatched by the supplier as declared in the ASN. Expressed in the base unit of measure (UoM) of the material master. Used as the baseline for receipt variance calculation and supplier compliance.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure (UoM) for quantity_shipped and quantity_received fields (e.g., KG, LB, CS, EA, L, GAL). Aligns with SAP MM material master base unit of measure. Required for accurate inventory valuation and supply planning.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between quantity_shipped and quantity_received (shipped minus received). Positive value indicates short delivery; negative value indicates over-delivery. Used for receipt-vs-order reconciliation, supplier dispute management, and AP invoice matching.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptVarianceReason rdf:type rdf:Property ;
    rdfs:label 'Receipt Variance Reason' ;
    rdfs:comment 'Reason code explaining the cause of any quantity variance between quantity_shipped and quantity_received. Used for supplier dispute management, root cause analysis, and AP invoice reconciliation. [ENUM-REF-CANDIDATE: short_shipment|over_delivery|transit_damage|quality_rejection|counting_error|no_variance — promote to reference product if additional codes required]' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Expected date of physical arrival at the receiving plant or DC as communicated in the ASN or purchase order. Used for inbound dock scheduling, labor planning, and OTIF (On Time In Full) baseline measurement.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the inbound shipment. Tracks progression from in-transit through physical receipt and putaway. LIFECYCLE_STATUS category. Values: in_transit (ASN issued, goods en route), arrived (carrier confirmed delivery at gate), receiving (goods receipt in progress), received (goods receipt posted in SAP MM), putaway (goods stored in final storage location), cancelled (shipment cancelled prior to receipt).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the inbound shipment origin type. Distinguishes between direct supplier deliveries, co-packing receipts, inter-company stock transfers, 3PL-managed transfers, and toll manufacturing returns. Supports supply chain segmentation and cost allocation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRange rdf:type rdf:Property ;
    rdfs:label 'Temperature Range' ;
    rdfs:comment 'Required temperature range classification for the inbound shipment during transport and storage. Ambient (15-25°C), Chilled (0-8°C), Frozen (-18°C or below), Ultra-Frozen (-40°C or below). Used for cold chain compliance and carrier selection.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of cross-functional participants who attended the S&OP/IBP cycle meetings (demand review, supply review, pre-S&OP, and executive review combined). Used as a process maturity indicator and governance compliance metric.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Pct' ;
    rdfs:comment 'Aggregate manufacturing capacity utilization percentage (0–100) for the planning period as assessed during the supply review of this S&OP cycle. Derived from the constrained supply plan vs. available production capacity. Values above 85% typically trigger capacity escalation discussions.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDecisionSummary rdf:type rdf:Property ;
    rdfs:label 'Consensus Decision Summary' ;
    rdfs:comment 'Free-text narrative summarizing the key cross-functional decisions, trade-offs, and commitments agreed upon during this S&OP/IBP cycle. Captures the rationale for scenario selection, supply gap resolutions, and any deviations from the financial operating plan.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusDemandUom rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Uom' ;
    rdfs:comment 'Unit of measure for the consensus demand volume approved in this S&OP cycle (e.g., CS = cases, EA = each, KG = kilograms). Ensures consistent interpretation of volume figures across demand, supply, and finance teams. [ENUM-REF-CANDIDATE: CS|EA|KG|LB|L|GAL|MT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusDemandVolume rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Volume' ;
    rdfs:comment 'Total consensus demand volume (in standard cases or agreed unit of measure) approved by cross-functional teams during this S&OP cycle. Represents the agreed-upon demand signal used to drive supply planning, procurement, and manufacturing scheduling for the planning period.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Consensus Revenue Target' ;
    rdfs:comment 'Financial revenue target (in reporting currency) aligned and approved during this S&OP/IBP cycle. Represents the commercial commitment reconciled between the demand plan and the financial operating plan. Used for EBITDA tracking and financial close alignment.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cycle Close Timestamp' ;
    rdfs:comment 'Date and time when this S&OP/IBP cycle was formally closed and the approved consensus plan was locked for execution. Marks the end of the active planning window. Used for cycle duration KPI measurement and audit compliance.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleNotes rdf:type rdf:Property ;
    rdfs:label 'Cycle Notes' ;
    rdfs:comment 'Free-text field for additional commentary, risk flags, assumptions, or contextual notes recorded by the S&OP cycle owner or cross-functional team. May include references to external market events, supply disruptions, regulatory changes, or strategic initiatives impacting the planning cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Externally-known business identifier for the S&OP/IBP cycle, formatted as SOP-YYYY-MM-NNN (e.g., SOP-2024-10-001). Used in cross-functional communications, meeting agendas, and audit trails to uniquely reference a planning cycle. Maps to SAP IBP Planning Cycle ID.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cycle Open Timestamp' ;
    rdfs:comment 'Date and time when this S&OP/IBP cycle was formally opened and made active in the planning system. Serves as the principal business event timestamp marking the start of the cycle\'s active planning window. Used for SLA tracking and cycle duration analytics.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle state of the S&OP/IBP cycle. Drives workflow routing, access controls, and downstream planning system locks. Draft: cycle initiated but not yet active. In Progress: milestone reviews underway. Pending Approval: awaiting executive sign-off. Approved: consensus plan ratified. Closed: cycle archived. Cancelled: cycle voided.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the planning cycle cadence and scope. Determines which cross-functional teams participate and which decisions are in scope. Monthly S&OP covers full supply-demand balancing; weekly demand review focuses on near-term demand sensing; executive IBP covers strategic financial reconciliation. [ENUM-REF-CANDIDATE: monthly_sop|weekly_demand_review|executive_ibp|supply_review|pre_sop|demand_review — promote to reference product]' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Version' ;
    rdfs:comment 'Version identifier of the demand plan (from SAP IBP or JDA/Blue Yonder) that was reviewed and approved during this S&OP cycle. Enables traceability between the S&OP cycle record and the specific demand plan version used as input to supply planning and financial reconciliation.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandReviewDate rdf:type rdf:Property ;
    rdfs:label 'Demand Review Date' ;
    rdfs:comment 'Scheduled or actual date of the Demand Review milestone within this S&OP cycle. During the demand review, commercial and demand planning teams align on the unconstrained consensus demand forecast, incorporating statistical forecasts, market intelligence, and promotional uplifts.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveReviewDate rdf:type rdf:Property ;
    rdfs:label 'Executive Review Date' ;
    rdfs:comment 'Scheduled or actual date of the Executive S&OP or IBP review meeting where senior leadership approves the consensus plan, resolves escalated supply-demand gaps, and aligns on financial commitments and strategic trade-offs.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Reconciliation Status' ;
    rdfs:comment 'Status of the financial reconciliation between the consensus volume plan and the financial operating plan (budget/latest estimate) at the close of this S&OP cycle. Aligned: volume plan supports financial targets. Gap Identified: volume shortfall vs. financial plan. Escalated: gap referred to CFO/leadership. Resolved: gap closed via scenario or plan adjustment.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTargetDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Target Days' ;
    rdfs:comment 'Target days of supply (DOS) for finished goods inventory approved during this S&OP cycle. Reflects the inventory optimization policy balancing service level targets, working capital constraints, and shelf life (FEFO) requirements for the planning period.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this S&OP cycle\'s consensus plan has been locked for execution (True), preventing further modifications to the approved demand and supply plan. Locking triggers downstream replenishment signals, procurement purchase orders, and manufacturing schedules.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newProductItemsCount rdf:type rdf:Property ;
    rdfs:label 'New Product Items Count' ;
    rdfs:comment 'Number of new product development (NPD) SKUs included in the demand and supply plans reviewed during this S&OP cycle. Tracks the volume of innovation pipeline items requiring dedicated supply chain readiness assessment and launch planning.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openActionItemCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Item Count' ;
    rdfs:comment 'Number of open action items carried forward from this S&OP cycle at the time of cycle closure. Tracks cross-functional accountability and process discipline. A high count may indicate unresolved supply-demand gaps or escalation items requiring follow-up in the next cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'Number of months covered by the planning horizon reviewed in this S&OP cycle. Typically 18–24 months for strategic IBP cycles and 3–6 months for operational S&OP cycles in the Food and Beverage industry. Drives the time fence for supply-demand balancing decisions.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'Last calendar date of the planning horizon governed by this S&OP cycle. Together with planning_period_start_date, defines the full time fence for supply-demand balancing decisions made in this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'First calendar date of the planning horizon governed by this S&OP cycle. Defines the start boundary for demand, supply, inventory, and financial plans reviewed and approved within this cycle. Typically the first day of the planning month or week.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSopDate rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Date' ;
    rdfs:comment 'Scheduled or actual date of the Pre-S&OP (reconciliation) meeting where supply, demand, and finance teams resolve gaps between the demand plan and constrained supply plan before escalating unresolved issues to the executive S&OP review.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalVolumePct rdf:type rdf:Property ;
    rdfs:label 'Promotional Volume Pct' ;
    rdfs:comment 'Percentage of total consensus demand volume attributable to trade promotions and promotional uplifts in the planning period reviewed during this S&OP cycle. High promotional volume percentages increase demand variability and require additional safety stock and supply flexibility.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueGapAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Gap Amount' ;
    rdfs:comment 'Monetary gap (in reporting currency) between the consensus revenue plan approved in this S&OP cycle and the financial operating plan (budget or latest estimate). Positive values indicate revenue shortfall vs. financial plan. Key input for executive escalation and corrective action planning.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Review Flag' ;
    rdfs:comment 'Indicates whether safety stock parameters were formally reviewed and updated during this S&OP cycle (True) or carried forward unchanged from the prior cycle (False). Safety stock reviews are triggered by significant changes in demand variability, lead times, or service level targets.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Name or label of the supply-demand scenario approved by the executive team during this S&OP cycle (e.g., \'Base Case\', \'Upside Demand\', \'Supply Constrained\'). Identifies which planning scenario was selected as the consensus plan for execution.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Classification of the approved planning scenario for this S&OP cycle. Base Case: most likely outcome. Upside: optimistic demand/supply scenario. Downside: pessimistic scenario. Supply Constrained: demand exceeds available supply. Risk Adjusted: incorporates identified supply chain risk mitigations.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyGapVolume rdf:type rdf:Property ;
    rdfs:label 'Supply Gap Volume' ;
    rdfs:comment 'Volumetric gap (in consensus demand UOM) between the unconstrained consensus demand plan and the constrained supply plan identified during this S&OP cycle. Positive values indicate supply shortfall; negative values indicate supply surplus. Key input for executive escalation and scenario planning.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Supply Review Date' ;
    rdfs:comment 'Scheduled or actual date of the Supply Review milestone within this S&OP cycle. Supply planning teams assess capacity constraints, raw material availability, MOQ compliance, and FIFO/FEFO inventory rotation to produce a constrained supply plan.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Network nodes belong to legal entities (company codes) for statutory reporting, intercompany transfers, and tax compliance. F&B multinationals must know which legal entity owns each node for transfer ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the supply chain node facility. Used for carrier routing, ASN generation, and regulatory compliance reporting (FDA FSMA facility registration).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail (suite, building, dock number) for the supply chain node. Supports precise carrier delivery instructions and ASN routing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the supply chain node is located. Used in network design, lane definition, and geographic reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackingCapable rdf:type rdf:Property ;
    rdfs:label 'Co Packing Capable' ;
    rdfs:comment 'Indicates whether this node has co-packing or toll manufacturing capability — performing secondary packaging, kitting, or assembly operations on behalf of the brand. Relevant for NPD and promotional pack configurations.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldStorageCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Cold Storage Capacity Pallets' ;
    rdfs:comment 'Number of pallet positions dedicated to temperature-controlled (chilled or frozen) storage. Used for dairy, beverage, and perishable product inventory planning and FEFO compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the supply chain node became operationally active. Used in asset lifecycle management, network design history, and regulatory compliance tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the node is located (e.g., \'USA\', \'CAN\', \'GBR\'). Drives regulatory compliance framework selection (FDA, EFSA, USDA) and customs/trade documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockCapable rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Capable' ;
    rdfs:comment 'Indicates whether this node supports cross-docking operations — transferring inbound shipments directly to outbound without storage. Reduces handling costs and lead times for high-velocity SKUs.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBondedWarehouse rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse' ;
    rdfs:comment 'Indicates whether this node is a licensed customs bonded warehouse, allowing storage of imported goods before customs duties are paid. Relevant for international supply chain nodes and import/export operations.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the supply chain node was or is planned to be decommissioned. Nullable for active nodes. Used in network design planning, lease management, and IBP scenario modeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Number of loading/unloading dock doors at the facility. Constrains inbound and outbound throughput scheduling and carrier appointment management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdCapable rdf:type rdf:Property ;
    rdfs:label 'Dsd Capable' ;
    rdfs:comment 'Indicates whether this node supports Direct Store Delivery (DSD) operations — direct shipment from the node to retail store locations bypassing intermediate DCs. Drives route planning and trade promotion execution.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'SAP S/4HANA or Oracle ERP plant/organization code corresponding to this network node. Enables cross-system reconciliation between the supply chain network model and ERP master data.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'Total usable floor area of the node facility in square feet. Supports capacity planning, lease management, and facility benchmarking.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the node holds a current Good Manufacturing Practice (GMP) certification. Required for manufacturing and co-packing nodes under FDA, USDA, and GFSI compliance frameworks.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibpLocationCode rdf:type rdf:Property ;
    rdfs:label 'Ibp Location Code' ;
    rdfs:comment 'SAP Integrated Business Planning (IBP) location identifier for this node. Enables direct linkage between the network node master and IBP demand sensing, inventory optimization, and S&OP planning models.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Decimal latitude coordinate of the node facility. Used in network optimization models, transportation lane distance calculations, and geographic visualization in IBP.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date on which the facility lease expires for leased or 3PL-operated nodes. Drives network design risk assessment, contract renewal planning, and financial forecasting in Oracle Cloud Financials.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Decimal longitude coordinate of the node facility. Used in network optimization models, transportation lane distance calculations, and geographic visualization in IBP.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqPallets rdf:type rdf:Property ;
    rdfs:label 'Moq Pallets' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in pallet units for inbound replenishment orders to this node. Enforced during replenishment signal generation in SAP IBP and JDA to avoid sub-optimal shipments.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:n3plProviderName rdf:type rdf:Property ;
    rdfs:label 'N3pl Provider Name' ;
    rdfs:comment 'Name of the Third-Party Logistics (3PL) provider operating this node, if applicable. Used in SLA governance, contract management, and performance scorecarding.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the supply chain node across systems (e.g., SAP plant code, DC code, 3PL site code). Used in EDI transactions, ASN documents, and IBP network models.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the supply chain node (e.g., \'Chicago Regional DC\', \'Atlanta Co-Pack Facility\'). Used in reporting, planograms, and network design documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the supply chain node. Controls whether the node is eligible for demand planning, replenishment signal generation, and network design optimization in SAP IBP and JDA.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the supply chain node by its primary operational function. Drives network design rules, safety stock policy assignment, and lane definitions in IBP. [ENUM-REF-CANDIDATE: manufacturing_plant|distribution_center|3pl_warehouse|co_packer|cross_dock|forward_dc — promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily operating end time (HH:MM, 24-hour format) for the node. Used in carrier appointment scheduling, outbound dispatch windows, and transportation management.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily operating start time (HH:MM, 24-hour format) for the node. Used in carrier appointment scheduling, inbound receiving windows, and transportation management.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingModel rdf:type rdf:Property ;
    rdfs:label 'Operating Model' ;
    rdfs:comment 'Describes the ownership and operational arrangement for the node — whether the facility is company-owned, leased, operated by a 3PL partner, or used for toll manufacturing or co-packing. Drives cost allocation (COGS), SLA governance, and contract management.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'On Time In Full (OTIF) delivery performance target percentage for shipments originating from this node. Used in SLA governance, carrier scorecards, and supply chain KPI reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:palletCapacity rdf:type rdf:Property ;
    rdfs:label 'Pallet Capacity' ;
    rdfs:comment 'Maximum number of pallet positions available at the node for storage. Principal capacity metric used in inventory optimization, safety stock policy assignment, and network design in SAP IBP.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the supply chain node. Used for carrier zone determination, freight cost calculation, and geographic clustering in network design.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Standard number of days required to replenish inventory at this node from its upstream supply source. Used in safety stock calculations, demand sensing, and IBP supply-demand balancing.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Policy Code' ;
    rdfs:comment 'Code referencing the safety stock calculation policy assigned to this node (e.g., days-of-supply, statistical, min-max). Drives inventory optimization parameters in SAP IBP and JDA demand/supply planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code where the node is located (e.g., \'IL\', \'CA\', \'ON\'). Used for tax jurisdiction, regulatory compliance, and transportation lane modeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature-controlled storage capability of the node (ambient, chilled, frozen, or multi-temp). Critical for food safety compliance (HACCP, FSMA), shelf life management, and FEFO rotation policy assignment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRatePalletsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Pallets Per Day' ;
    rdfs:comment 'Maximum number of pallets the node can receive, process, and ship per day. Used in capacity planning, OTIF modeling, and supply-demand balancing in JDA and SAP IBP.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the node location (e.g., \'America/Chicago\', \'Europe/London\'). Used for scheduling inbound/outbound appointments, production shifts, and EDI transaction timestamps.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Network Node Id' ;
    rdfs:comment 'Reference to the destination network node (e.g., Distribution Center (DC), customer distribution center, retail store, or 3PL facility) to which shipments are delivered on this lane.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:laneBackupCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Backup Carrier Id' ;
    rdfs:comment 'Reference to the secondary or backup carrier assigned to this lane, activated when the primary carrier is unavailable or capacity-constrained. Supports supply chain resilience and continuity planning.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:laneCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Carrier Id' ;
    rdfs:comment 'Reference to the primary carrier assigned to this transportation lane for standard replenishment and distribution movements.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:laneNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Lane Network Node Id' ;
    rdfs:comment 'Reference to the origin network node (e.g., manufacturing plant, Distribution Center (DC), supplier facility, or 3PL warehouse) from which shipments depart on this lane.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:co2EmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Factor' ;
    rdfs:comment 'Estimated CO2 equivalent emissions per unit distance (kg CO2e per mile) for this lane based on freight mode and carrier fleet profile. Supports sustainability reporting and EPA environmental compliance.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date from which the carrier contract and associated freight rates for this lane become effective. Used for rate validity checks during shipment planning.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date on which the carrier contract and associated freight rates for this lane expire. Triggers carrier bid management and contract renewal workflows.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the freight contract or carrier rate agreement governing this lane. Links to the carrier contract management system for rate validation and audit.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether this lane crosses an international border, triggering customs documentation, import/export compliance, and regulatory reporting requirements (e.g., FDA Prior Notice for food imports).' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which deliveries are accepted at the destination node for this lane (e.g., \'Tue,Thu,Sat\'). Used for appointment scheduling and receiving window management.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the destination node\'s country (e.g., USA, CAN, MEX). Required for cross-border compliance, import duties, and regulatory reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Calculated or contracted road/rail distance between origin and destination nodes in miles. Used for freight cost estimation, carrier rate negotiation, and carbon emissions modeling.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this lane is used for Direct Store Delivery (DSD), where product is shipped directly from a manufacturing plant or DC to a retail store, bypassing the customer\'s distribution center.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCostPerLoad rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Load' ;
    rdfs:comment 'Contracted flat-rate freight cost per full truckload (TL) or equivalent load unit on this lane. Applicable primarily for TL and dedicated lanes where per-load pricing is negotiated.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostPerMile rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Mile' ;
    rdfs:comment 'Contracted or benchmark freight cost per mile for this lane, used in carrier bid management, rate benchmarking, and transportation cost modeling.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Unit' ;
    rdfs:comment 'Standard contracted freight cost per unit (case or pallet) shipped on this lane, expressed in the operating currency. Used for Cost of Goods Sold (COGS) allocation, transportation cost modeling, and network optimization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightMode rdf:type rdf:Property ;
    rdfs:label 'Freight Mode' ;
    rdfs:comment 'Transportation mode used on this lane. TL = Truckload, LTL = Less-Than-Truckload, intermodal = combined rail/truck, parcel = small package carrier, rail = dedicated rail, ocean = sea freight. Drives freight cost modeling and carrier selection. [ENUM-REF-CANDIDATE: TL|LTL|intermodal|parcel|rail|ocean|air — promote to reference product]' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightUom rdf:type rdf:Property ;
    rdfs:label 'Freight Uom' ;
    rdfs:comment 'Unit of measure used for freight cost and capacity calculations on this lane (e.g., pallet, case, lb, kg, cwt). Aligns with carrier contract terms and SAP S/4HANA MM configuration.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'Current fuel surcharge percentage applied on top of the base freight rate for this lane, expressed as a percentage. Updated periodically per carrier contract terms and fuel index benchmarks.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this lane is certified and approved for the transport of hazardous materials (e.g., cleaning chemicals, CO2 cartridges). Drives carrier certification requirements and regulatory compliance checks.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the lane, used in carrier bid management, freight contracts, and Electronic Data Interchange (EDI) communications. Unique across the network.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the lane, typically combining origin and destination node names (e.g., \'Chicago DC to Atlanta DC\'). Used in reporting and network design tools.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current operational lifecycle status of the lane. \'active\' lanes are available for replenishment routing; \'inactive\' lanes are retired; \'pending\' lanes are under carrier negotiation; \'suspended\' lanes are temporarily halted.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the lane\'s operational role. \'primary\' is the standard routing; \'backup\' is an alternate route activated when primary is unavailable; \'spot\' is used for ad-hoc shipments; \'dedicated\' is a contracted exclusive lane.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLoadCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Load Capacity' ;
    rdfs:comment 'Maximum shipment capacity per load on this lane, expressed in the freight unit of measure (e.g., pallets, cases, or weight). Used for load planning and carrier capacity management.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required to activate a shipment on this lane, expressed in the freight unit of measure. Enforced during replenishment signal generation in SAP IBP.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic or operational region classification for this lane (e.g., \'Northeast\', \'Southeast\', \'Midwest\', \'West Coast\', \'International\'). Used for network design segmentation and regional distribution analytics.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the origin node\'s country (e.g., USA, CAN, MEX). Required for cross-border compliance, customs documentation, and trade lane analytics.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupDays rdf:type rdf:Property ;
    rdfs:label 'Pickup Days' ;
    rdfs:comment 'Comma-separated list of days of the week on which carrier pickups are available at the origin node for this lane (e.g., \'Mon,Wed,Fri\'). Used for replenishment scheduling and order cut-off management.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Contracted service level for this lane defining delivery speed and reliability commitment (e.g., standard, expedited, overnight, economy). Linked to On Time In Full (OTIF) and Service Level Agreement (SLA) performance targets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyLogisticsFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Flag' ;
    rdfs:comment 'Indicates whether this lane is operated by a Third-Party Logistics (3PL) provider rather than a company-owned or dedicated carrier. Drives 3PL performance management and cost allocation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Standard transit time in calendar days from origin departure to destination receipt for this lane. Used in replenishment lead time calculation, safety stock parameterization, and SAP IBP supply planning.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Transit Variability Days' ;
    rdfs:comment 'Standard deviation or average variability in transit time in days for this lane, derived from historical shipment performance. Used in safety stock calculation and inventory optimization in SAP IBP.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityConstraintId rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Id' ;
    rdfs:comment 'Unique surrogate identifier for each capacity constraint record in the supply planning system. Primary key for the capacity_constraint data product. Entity role: MASTER_RESOURCE — represents a managed planning resource (capacity bucket) with its own identity and lifecycle.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityConstraint .

ind:haccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.haccp_plan. Business justification: S&OP capacity planning: HACCP-mandated allergen changeovers, CCP monitoring windows, and cleaning validation requirements impose scheduled downtime that creates capacity constraints. Supply planners m' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line or work center within a plant to which this capacity constraint applies. Populated only when resource_type is \'production_line\'. Links to the work center or production line master in SAP S/4HANA PP or Aveva MES.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:transportationLaneId rdf:type rdf:Property ;
    rdfs:label 'Transportation Lane Id' ;
    rdfs:comment 'Reference to the transportation lane (origin-destination pair) to which this capacity constraint applies. Populated only when resource_type is \'transportation_lane\'. Links to the lane master in JDA/Blue Yonder Transportation Management.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_center. Business justification: Capacity constraints in IBP/S&OP must be modeled at work center granularity for detailed scheduling in F&B (e.g., allergen changeover constraints, CIP cycle limits). capacity_constraint already links ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:availableCapacity rdf:type rdf:Property ;
    rdfs:label 'Available Capacity' ;
    rdfs:comment 'Total available capacity for the resource within the defined capacity bucket period, expressed in the unit of measure specified by capacity_uom (e.g., cases per day, pallet positions, labor hours, truck loads). Represents the theoretical maximum throughput or storage before any utilization. Serves as the MEASUREMENT_OR_VALUE category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bottleneckFlag rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Flag' ;
    rdfs:comment 'Indicates whether this resource is identified as a bottleneck in the current planning cycle (True = bottleneck, False = not a bottleneck). Set by the planning engine (SAP IBP or JDA) when utilization_pct exceeds utilization_ceiling_pct. Triggers network rebalancing, co-packing evaluation, or 3PL overflow decisions.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bucketEndDate rdf:type rdf:Property ;
    rdfs:label 'Bucket End Date' ;
    rdfs:comment 'The last calendar date of the capacity bucket period to which this constraint record applies. Combined with bucket_start_date, defines the exact planning window for available and utilized capacity values.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bucketStartDate rdf:type rdf:Property ;
    rdfs:label 'Bucket Start Date' ;
    rdfs:comment 'The first calendar date of the capacity bucket period to which this constraint record applies. Combined with bucket_end_date, defines the exact planning window for available and utilized capacity values.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityBucket rdf:type rdf:Property ;
    rdfs:label 'Capacity Bucket' ;
    rdfs:comment 'Time granularity of the capacity constraint record. Defines the planning horizon bucket over which available and utilized capacity are measured. \'daily\' is used for short-term finite scheduling; \'weekly\' for S&OP/IBP mid-term planning; \'monthly\' and \'quarterly\' for strategic network design.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure in which available_capacity and utilized_capacity are expressed. Varies by resource_type: production lines typically use cases or kg per day; DC storage uses pallet positions; labor uses hours; transportation uses truck loads or pallets. [ENUM-REF-CANDIDATE: cases|pallets|labor_hours|truck_loads|kg|liters|units — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Hours' ;
    rdfs:comment 'Hours allocated within the capacity bucket for product changeovers (SKU switches) on the production line, including allergen cleaning, flavor changeovers, and packaging format changes. Reduces effective throughput capacity. Tracked separately from planned_downtime_hours for root cause analysis.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintCategory rdf:type rdf:Property ;
    rdfs:label 'Constraint Category' ;
    rdfs:comment 'Business category classifying the root cause or nature of the capacity constraint. \'throughput\' relates to production or logistics flow rate; \'storage\' to physical space; \'labor\' to workforce availability; \'equipment\' to machinery or vehicle availability; \'regulatory\' to compliance-driven limits (e.g., FDA GMP, FSMA); \'seasonal\' to demand-driven temporary constraints.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the capacity constraint record, used in SAP IBP and JDA/Blue Yonder planning runs to reference this constraint. Serves as the BUSINESS_IDENTIFIER category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintName rdf:type rdf:Property ;
    rdfs:label 'Constraint Name' ;
    rdfs:comment 'Human-readable descriptive name for the capacity constraint (e.g., \'Line 3 Daily Throughput Cap\', \'DC Chicago Pallet Positions\'). Serves as the IDENTITY_LABEL category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintSource rdf:type rdf:Property ;
    rdfs:label 'Constraint Source' ;
    rdfs:comment 'Identifies the operational system of record from which this capacity constraint record originated. Enables data lineage tracking and reconciliation across planning systems. \'sap_ibp\' = SAP Integrated Business Planning; \'jda_blue_yonder\' = JDA/Blue Yonder Supply Planning; \'aveva_mes\' = Aveva/Wonderware MES; \'manual\' = planner-entered; \'erp\' = SAP S/4HANA or Oracle Cloud ERP.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the capacity constraint record. \'active\' means the constraint is live and enforced in planning runs; \'inactive\' means it has been retired or superseded; \'pending\' means it is defined but not yet effective; \'suspended\' means temporarily bypassed. Serves as the LIFECYCLE_STATUS category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Indicates whether the capacity constraint is a hard or soft limit in supply planning. \'hard\' constraints cannot be violated by the planning engine (e.g., physical line speed, dock door count); \'soft\' constraints can be overridden with a penalty cost or planner approval (e.g., preferred utilization ceiling, labor overtime threshold).' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorsAvailable rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Available' ;
    rdfs:comment 'Number of dock doors available at the DC for inbound and/or outbound operations within the capacity bucket. DC-specific metric used to plan ASN (Advanced Shipping Notice) scheduling, carrier appointments, and DSD (Direct Store Delivery) operations. Null when resource_type is not \'dock_door\' or \'dc_throughput\'.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsUtilized rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Utilized' ;
    rdfs:comment 'Number of dock doors actually scheduled or utilized within the capacity bucket period. Used alongside dock_doors_available to compute dock door utilization rate and identify scheduling bottlenecks at the DC.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveCapacity rdf:type rdf:Property ;
    rdfs:label 'Effective Capacity' ;
    rdfs:comment 'Net usable capacity after applying OEE, planned downtime, changeover time, and other efficiency factors to the theoretical available_capacity. Represents the realistic throughput ceiling used in constrained supply planning runs. Expressed in capacity_uom.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursAvailable rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Available' ;
    rdfs:comment 'Total labor hours available for production or DC operations within the capacity bucket, accounting for scheduled shifts, headcount, and planned absences. Used in labor capacity planning and S&OP cycles. Null when resource_type is not \'labor\'.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursUtilized rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Utilized' ;
    rdfs:comment 'Actual or planned labor hours consumed within the capacity bucket period. Used to assess workforce loading against available labor hours and identify overtime or underutilization scenarios.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Oee Target Pct' ;
    rdfs:comment 'Target OEE (Overall Equipment Effectiveness) percentage for the production line or equipment resource within this capacity bucket. OEE = Availability × Performance × Quality. Used to set realistic effective capacity expectations in finite scheduling and SAP IBP planning runs. Applicable only when resource_type is \'production_line\'.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Risk Flag' ;
    rdfs:comment 'Indicates whether this capacity constraint poses a risk to OTIF (On Time In Full) delivery performance (True = OTIF risk present). Set when the constraint is projected to cause order fulfillment shortfalls within the bucket period. Used to prioritize constraint resolution and escalation.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overflowAction rdf:type rdf:Property ;
    rdfs:label 'Overflow Action' ;
    rdfs:comment 'Recommended or approved action to resolve a capacity overload when bottleneck_flag is True. \'co_pack\' triggers co-packing or toll manufacturing evaluation; \'3pl_overflow\' routes excess volume to a 3PL partner; \'demand_defer\' defers lower-priority demand; \'interplant_transfer\' reallocates production to another plant; \'none\' means no action required.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPositions rdf:type rdf:Property ;
    rdfs:label 'Pallet Positions' ;
    rdfs:comment 'Total number of pallet storage positions available at the DC or warehouse for this capacity bucket. DC-specific metric used in warehouse capacity management and network design. Null when resource_type is not \'storage\' or \'dc_throughput\'.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Hours of scheduled downtime within the capacity bucket for maintenance, sanitation (GMP/HACCP compliance), changeovers, or regulatory inspections. Reduces effective_capacity from available_capacity. Critical for food and beverage manufacturing where sanitation windows are mandated by GMP and FSMA.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'Identifier for the SAP IBP or JDA planning version or scenario to which this capacity constraint record belongs (e.g., \'BASELINE\', \'SCENARIO_A\', \'CONSENSUS\'). Enables multi-scenario capacity analysis and S&OP cycle management.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this capacity constraint is driven by a regulatory hold or compliance requirement (True = regulatory-driven constraint). Examples include FDA FSMA inspection holds, USDA audit shutdowns, or GMP sanitation mandates that reduce available production capacity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Categorizes the type of supply chain resource to which this capacity constraint applies. Drives how the constraint is interpreted in finite capacity planning: production_line (manufacturing throughput), dc_throughput (Distribution Center inbound/outbound volume), transportation_lane (carrier/lane capacity), dock_door (DC dock door availability), labor (workforce hours), storage (pallet positions or cubic volume). Serves as the CLASSIFICATION_OR_TYPE category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockImpact rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Impact' ;
    rdfs:comment 'Quantity of safety stock that cannot be replenished due to this capacity constraint within the bucket period, expressed in capacity_uom. Used in inventory optimization to quantify the risk exposure created by constrained capacity and inform safety stock parameter adjustments in SAP IBP.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationCeilingPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Ceiling Pct' ;
    rdfs:comment 'Maximum acceptable utilization percentage for this resource before the constraint is flagged as a bottleneck or overload. Typically set below 100% to preserve buffer capacity (e.g., 85% for production lines to allow for changeovers and maintenance, 90% for DC throughput). Used in SAP IBP and JDA planning to trigger alerts and rebalancing.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:comment 'Ratio of utilized_capacity to available_capacity expressed as a percentage (0–100). Calculated field stored for planning visibility: utilization_pct = (utilized_capacity / available_capacity) * 100. Used to identify bottleneck resources and trigger network rebalancing decisions. Values above the utilization_ceiling_pct indicate an overload condition.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacity rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity' ;
    rdfs:comment 'Actual or planned capacity consumed within the bucket period, expressed in the same unit of measure as available_capacity (capacity_uom). Used to compute utilization rate and identify bottlenecks. In constrained planning runs, this reflects the sum of all planned orders or shipments assigned to this resource.' ;
    rdfs:domain ind:CapacityConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Primary key for inbound_receipt' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Supply inbound_receipt and procurement goods_receipt represent the same physical receiving event from two domain perspectives. Linking them enables cross-domain audit trail reconciliation and FSMA tra' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Goods receipt posting automatically generates a journal entry (inventory debit, GR/IR credit). F&B finance teams trace inbound receipts to their accounting documents for audit and period-close reconci' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to ingredient.lot. Business justification: Posting an inbound receipt creates or references an ingredient lot for FSMA traceability and quality management. F&B receiving processes require linking the physical receipt event to the lot record. s' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:receivingNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Inbound receipts occur at specific network nodes (DCs, manufacturing plants, co-packer facilities). inbound_receipt has plant_id (cross-domain to manufacturing.plant) for manufacturing plants, but net' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued bill of lading number for the inbound shipment. Serves as the legal contract of carriage and is required for freight claims, customs clearance, and 3PL reconciliation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Reference number of the supplier-provided Certificate of Analysis accompanying the shipment. Documents quality test results (microbiological, chemical, physical) for the received batch. Required for GFSI, SQF, and HACCP compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the physical delivery document or packing slip (BLDAT) as provided by the supplier. May differ from posting_date when receipts are backdated or processed with delay.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Expiration or best-before date of the received batch. Governs FEFO inventory rotation, shelf life compliance, and eligibility for distribution. Mandatory for perishable food and beverage products per FDA and EFSA regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNote rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Note' ;
    rdfs:comment 'Free-text notes entered by the receiving clerk at time of goods receipt. Captures exceptions, damage observations, temperature deviations, or other relevant receiving conditions not captured in structured fields.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'INCOTERMS code from the purchase order defining the point of title transfer and risk for the inbound shipment (e.g., FOB, CIF, DDP, EXW). Determines when inventory ownership transfers to Food Beverage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsignment rdf:type rdf:Property ;
    rdfs:label 'Is Consignment' ;
    rdfs:comment 'Indicates whether the received goods are consignment stock (supplier-owned inventory held at Food Beverage\'s facility). True = consignment; False = standard purchased stock. Affects accounts payable timing and inventory ownership.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Return Delivery' ;
    rdfs:comment 'Indicates whether this goods receipt represents a return delivery from a customer or a reversal of a prior outbound delivery being returned to stock. True = return; False = standard inbound receipt.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year (MJAHR) associated with the SAP material document number. Required in combination with material_document_number to uniquely identify the document in SAP S/4HANA.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code (BWART) classifying the nature of the goods movement (e.g., 101 = GR for PO, 103 = GR into blocked stock, 105 = GR from blocked stock, 501 = receipt without PO). Drives inventory account determination and stock type posting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poOrderedQty rdf:type rdf:Property ;
    rdfs:label 'Po Ordered Qty' ;
    rdfs:comment 'Original quantity ordered on the purchase order line item. Compared against received_qty to calculate receipt variance and identify short-shipments or over-deliveries for supplier performance management.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting posting date (BUDAT) on which the goods receipt is recorded in SAP, triggering inventory update and accounts payable accrual. Determines the fiscal period for financial reporting. BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number (PRUEFLOS) created automatically upon goods receipt for materials subject to quality inspection. Links the receipt to the quality inspection results and usage decision in Veeva Vault or SAP QM.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityUsageDecision rdf:type rdf:Property ;
    rdfs:label 'Quality Usage Decision' ;
    rdfs:comment 'Outcome of the quality inspection usage decision for the received batch. \'accepted\' = released to unrestricted stock; \'rejected\' = returned to vendor or destroyed; \'conditional_release\' = released with deviations noted; \'pending\' = inspection in progress; \'waived\' = skip-lot or pre-approved supplier.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. \'posted\' = inventory updated; \'reversed\' = full reversal posted; \'blocked\' = held pending quality or compliance review; \'in_quality_inspection\' = under QM usage decision; \'partially_reversed\' = partial quantity reversed; \'cancelled\' = voided before posting. LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: posted|reversed|blocked|in_quality_inspection|partially_reversed|cancelled — promote to reference product]' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods were physically received and scanned at the dock door or receiving bay. Used for OTIF calculation, lead time analysis, and dock scheduling.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQty rdf:type rdf:Property ;
    rdfs:label 'Received Qty' ;
    rdfs:comment 'Actual quantity of material physically received and posted to inventory (MENGE). Expressed in the base unit of measure. Used for inventory reconciliation, fill rate calculation, and OTIF measurement.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPlantType rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Type' ;
    rdfs:comment 'Classification of the receiving location type. Distinguishes between manufacturing plants, distribution centers (DC), co-packer facilities, 3PL warehouses, and cross-dock points. Drives putaway rules and inventory ownership.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Number of days remaining between the receipt posting date and the expiration date at time of receipt. Used to enforce minimum remaining shelf life (MRSL) thresholds for customer acceptance and distribution eligibility.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'SAP stock type (INSMK) into which the received quantity is posted. \'unrestricted\' = available for use/sale; \'quality_inspection\' = under QM hold; \'blocked\' = not available; \'restricted\' = batch-restricted; \'returns\' = returned goods stock. Governs FIFO/FEFO rotation eligibility.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReceiptValue rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Value' ;
    rdfs:comment 'Total inventory value posted for this receipt (valuation_price × received_qty) in local currency. Drives the accounts payable accrual entry and inventory balance update in SAP FI/CO.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Unit price at which the received material is valuated in inventory (DMBTR/MENGE). Used for inventory valuation, COGS calculation, and accounts payable accrual. Reflects moving average price or standard price per material master. MONETARY_TRIPLET category.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each OTIF performance record in the supply chain service measurement dataset. Entity role: TRANSACTION_HEADER — represents a discrete supply chain service measurement event with a clear lifecycle.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: OTIF failures result in retailer deductions applied against AR invoices. Finance teams link OTIF penalty assessments to the specific AR invoice being deducted for dispute resolution, deduction managem' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:promotionEventId rdf:type rdf:Property ;
    rdfs:label 'Promotion Event Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_event. Business justification: Retailer OTIF scorecards in F&B are measured specifically during promotional event windows. Linking OTIF performance records to the promotion event enables post-promotion OTIF analysis, retailer penal' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionEvent .

ind:retailerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retailer Agreement Id' ;
    rdfs:comment 'Foreign key linking to trade.retailer_agreement. Business justification: OTIF penalties and service-level compliance are contractually governed by retailer agreements in F&B. Linking OTIF performance directly to the retailer agreement enables automated penalty exposure cal' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailerAgreement .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the shipment record associated with this OTIF performance measurement. Links to the outbound delivery or shipment entity in the supply chain execution system.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:caseFillRate rdf:type rdf:Property ;
    rdfs:label 'Case Fill Rate' ;
    rdfs:comment 'Ratio of cases shipped to cases ordered, expressed as a decimal (e.g., 0.9750 = 97.50%). Measures the degree to which the order was fulfilled at the case level. Key metric for supply chain customer service performance.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysEarlyLate rdf:type rdf:Property ;
    rdfs:label 'Days Early Late' ;
    rdfs:comment 'Signed integer representing the number of days the shipment arrived relative to the required delivery date. Negative values indicate early delivery; positive values indicate late delivery; zero indicates on-time delivery. Used for trend analysis and carrier performance management.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredQty rdf:type rdf:Property ;
    rdfs:label 'Delivered Qty' ;
    rdfs:comment 'Total quantity of the SKU confirmed as received by the customer or retailer, which may differ from shipped quantity due to transit damage, short receipt, or carrier discrepancies.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known outbound delivery document number from the ERP or WMS system (e.g., SAP delivery number). Serves as the primary business identifier for this OTIF performance record and is used in retailer dispute resolution and carrier communications.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackorder rdf:type rdf:Property ;
    rdfs:label 'Is Backorder' ;
    rdfs:comment 'Boolean flag indicating whether any portion of the order was placed on backorder due to insufficient inventory at time of shipment. True = backorder exists; False = no backorder.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInFull rdf:type rdf:Property ;
    rdfs:label 'Is In Full' ;
    rdfs:comment 'Boolean flag indicating whether the shipment met the in-full delivery threshold as defined by the retailer or customer OTIF policy (typically 100% or a defined fill rate threshold). True = in-full; False = short shipment.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'Boolean flag indicating whether the shipment was delivered on or before the required delivery date per the retailer or customer OTIF policy. True = on-time delivery; False = late delivery.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtif rdf:type rdf:Property ;
    rdfs:label 'Is Otif' ;
    rdfs:comment 'Boolean composite flag indicating whether the shipment satisfied BOTH the on-time AND in-full criteria simultaneously. True = OTIF compliant; False = OTIF non-compliant. Primary KPI for retailer scorecard reporting.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPenaltyAssessed rdf:type rdf:Property ;
    rdfs:label 'Is Penalty Assessed' ;
    rdfs:comment 'Boolean flag indicating whether a retailer OTIF fine or chargeback has been formally assessed and invoiced against this shipment. True = penalty assessed; False = no penalty assessed or still under review.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubstitution rdf:type rdf:Property ;
    rdfs:label 'Is Substitution' ;
    rdfs:comment 'Boolean flag indicating whether an alternative SKU was substituted for the originally ordered SKU due to supply shortage or product unavailability. True = substitution occurred; False = original SKU shipped.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineFillRate rdf:type rdf:Property ;
    rdfs:label 'Line Fill Rate' ;
    rdfs:comment 'Ratio of order lines shipped complete to total order lines, expressed as a decimal (e.g., 0.9500 = 95.00%). Measures fulfillment completeness at the order line level, distinct from case fill rate.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The principal business event date on which this OTIF performance record was evaluated or scored. Typically aligned with the actual delivery date or the retailer scorecard reporting date.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderedQty rdf:type rdf:Property ;
    rdfs:label 'Ordered Qty' ;
    rdfs:comment 'Total quantity of the SKU ordered by the customer on the purchase order, expressed in the order unit of measure. Used as the denominator for in-full compliance calculation.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Otif Policy Version' ;
    rdfs:comment 'Version identifier of the retailer or customer OTIF compliance policy applied to this performance record. Tracks policy changes over time to ensure accurate historical compliance measurement.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Composite OTIF compliance score for this shipment record, expressed as a decimal between 0 and 1 (e.g., 0.9800 = 98.00%). Calculated as the product of on-time rate and in-full rate per retailer scorecard methodology. Primary KPI for retailer compliance reporting.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the retailer penalty exposure amount (e.g., USD, EUR, GBP). Supports multi-currency financial exposure reporting.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyExposureAmt rdf:type rdf:Property ;
    rdfs:label 'Penalty Exposure Amt' ;
    rdfs:comment 'Estimated monetary value of retailer OTIF fines or chargebacks associated with this non-compliant shipment, expressed in the transaction currency. Used for financial exposure tracking and trade compliance management.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyUom rdf:type rdf:Property ;
    rdfs:label 'Qty Uom' ;
    rdfs:comment 'Unit of measure used for ordered, shipped, and delivered quantity fields (e.g., CS=Case, EA=Each, LB=Pound, KG=Kilogram, PL=Pallet, TI=Tier). Ensures consistent quantity comparison across the OTIF calculation.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerScorecardWindow rdf:type rdf:Property ;
    rdfs:label 'Retailer Scorecard Window' ;
    rdfs:comment 'The retailer-defined measurement window or compliance period (e.g., \'Walmart W2024-Q1\', \'Target FY2024-P03\') to which this OTIF performance record is attributed. Aligns internal tracking with external retailer scorecard reporting cycles.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorized root cause classification for OTIF failures. Used for corrective action prioritization and supply chain performance improvement. [ENUM-REF-CANDIDATE: supply_shortage|carrier_delay|dc_error|customer_change|forecast_miss|weather_event|system_error|other — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetail rdf:type rdf:Property ;
    rdfs:label 'Root Cause Detail' ;
    rdfs:comment 'Free-text description providing additional detail on the root cause of an OTIF failure beyond the root cause category. Captures specific circumstances such as ingredient shortage, carrier equipment failure, or DC picking error for corrective action documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'The date the shipment physically departed the Distribution Center (DC) or manufacturing facility. Used to assess carrier transit time and identify DC-side delays contributing to OTIF failures.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedQty rdf:type rdf:Property ;
    rdfs:label 'Shipped Qty' ;
    rdfs:comment 'Total quantity of the SKU actually shipped to the customer, expressed in the order unit of measure. Used as the numerator for in-full and case fill rate compliance calculations.' ;
    rdfs:domain ind:OtifPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'SAP S/4HANA vendor account group code (LFA1-KTOKK) that controls the field selection, number range, and partner functions applicable to this supplier. Distinguishes between one-time vendors, regular vendors, and intercompany suppliers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenControlProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Program Flag' ;
    rdfs:comment 'Indicates whether the supplier has a documented and audited allergen control program in place at their manufacturing facility. Critical for managing allergen cross-contact risk in the Food Beverage supply chain per FSMA Preventive Controls requirements.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedVendorListFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Flag' ;
    rdfs:comment 'Indicates whether the supplier is currently on the Approved Vendor List (AVL), meaning they have passed all required quality, food safety, and compliance assessments and are authorized to supply materials or services to Food Beverage.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Categorical outcome of the most recent supplier audit. A \'conditional_pass\' requires corrective action within a defined timeframe. A \'fail\' triggers supplier suspension pending remediation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numeric score (0–100) from the most recent supplier quality or food safety audit. Drives supplier risk tier assignment and determines re-audit frequency. Sourced from TraceGains or Veeva Vault quality management records.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the supplier was deactivated or blocked in the vendor master, preventing new purchase orders from being issued. Null for currently active suppliers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Supplier diversity category indicating ownership classification for ESG reporting and supplier diversity program tracking. Used to measure spend with diverse suppliers as required by corporate sustainability commitments and certain customer contracts.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet Data Universal Numbering System (DUNS) nine-digit identifier for the supplier legal entity. Used for supplier financial risk screening, credit assessment, and global supplier deduplication.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether the supplier is capable of exchanging Electronic Data Interchange (EDI) transactions (e.g., EDI 850 Purchase Order, EDI 856 ASN, EDI 810 Invoice) with Food Beverage\'s procurement systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foodSafetyCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Food Safety Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the supplier\'s primary food safety certification. Triggers automated re-certification alerts in TraceGains and may result in supplier suspension if not renewed before expiry.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foodSafetyCertification rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification' ;
    rdfs:comment 'Primary GFSI-recognized food safety certification held by the supplier (e.g., SQF, BRC, FSSC 22000, IFS, ISO 22000, HACCP). Mandatory for direct material suppliers under Food Beverage\'s supplier qualification program. Sourced from TraceGains document management. [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|IFS|ISO_22000|HACCP|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) — 13-digit identifier uniquely identifying the supplier\'s physical or legal location in the global supply chain. Used in EDI transactions (ASN, invoices) and GS1 traceability programs.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent quality or food safety audit conducted at the supplier\'s facility by Food Beverage\'s quality assurance team or a third-party auditor. Used to track audit frequency compliance and supplier qualification status.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the supplier master record in the source system. Used for incremental data pipeline processing, change detection, and audit trail maintenance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure applicable to the MOQ field (e.g., KG, LB, CS, EA, L). Aligns with SAP S/4HANA base unit of measure for the purchasing info record.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the supplier was formally approved and activated in the Food Beverage vendor master, completing the onboarding process including quality qualification, legal review, and financial setup.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle state of the supplier in the onboarding and vendor management workflow. Controls whether purchase orders can be issued. Sourced from SAP S/4HANA MM vendor master blocking indicators and TraceGains onboarding workflow status.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Flag' ;
    rdfs:comment 'Indicates whether the supplier holds a valid USDA National Organic Program (NOP) or equivalent organic certification. Required for sourcing certified organic ingredients for Food Beverage\'s clean label and organic product lines.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which invoices from this supplier are settled. Drives foreign exchange exposure tracking and multi-currency accounts payable processing.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key defining the agreed payment schedule with the supplier (e.g., NET30, 2/10NET30). Governs accounts payable processing, cash discount eligibility, and working capital management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalRegistrationFlag rdf:type rdf:Property ;
    rdfs:label 'Portal Registration Flag' ;
    rdfs:comment 'Indicates whether the supplier has completed self-registration in Food Beverage\'s supplier portal (SAP Ariba or equivalent), enabling self-service document submission, invoice tracking, and compliance certificate uploads.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact at the supplier. Used for purchase order transmission, compliance document requests, and supplier communication workflows.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the supplier organization responsible for managing the commercial relationship with Food Beverage. Used for purchase order communications and escalations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number of the primary contact at the supplier. Used for urgent procurement communications, quality escalations, and supply disruption notifications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'SAP S/4HANA purchasing organization code (EKORG) to which this supplier is assigned. Determines which procurement team manages the supplier relationship and which contracts and pricing conditions apply.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region or state/province of the supplier\'s primary business location. Used for supply chain risk mapping, logistics planning, and regional compliance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall supply chain risk rating assigned to the supplier based on food safety audit results, financial stability, geographic risk, single-source dependency, and regulatory compliance history. Used to prioritize supplier monitoring and contingency planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the sole approved source for one or more critical raw materials or ingredients. Single-source suppliers require enhanced risk monitoring, safety stock buffers, and business continuity planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Supplier Flag' ;
    rdfs:comment 'Indicates whether the supplier is classified as a strategic partner under Food Beverage\'s supplier relationship management (SRM) program, warranting executive-level engagement, joint business planning, and preferred sourcing status.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Strategic tier classification indicating the supplier\'s position in the supply chain hierarchy. Tier 1 suppliers have a direct commercial relationship with Food Beverage; Tier 2 and Tier 3 are sub-suppliers providing materials or services to Tier 1 suppliers.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier by the nature of goods or services provided. Direct material suppliers provide ingredients and packaging; co-packers and toll manufacturers produce finished goods; 3PL/logistics providers handle distribution; service providers cover indirect spend. [ENUM-REF-CANDIDATE: direct_material|indirect_material|co_packer|toll_manufacturer|3pl_logistics|service_provider — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Numeric sustainability performance score (0–100) based on environmental, social, and governance (ESG) criteria including carbon footprint, water usage, labor practices, and packaging recyclability. Sourced from third-party ESG assessments or TraceGains sustainability questionnaires.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN, VAT registration number, GST number) for the supplier legal entity. Required for tax compliance, 1099/W-9 reporting, and accounts payable regulatory filings.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracegainsSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Tracegains Supplier Code' ;
    rdfs:comment 'Unique supplier identifier assigned within the TraceGains supplier compliance and document management platform. Used to cross-reference food safety certifications, specification documents, and audit records between SAP and TraceGains.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or commercial trade name of the supplier, which may differ from the legal entity name. Used in commercial communications, purchase orders, and supplier-facing documents.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Externally-known alphanumeric vendor account number assigned in SAP S/4HANA MM (LFA1-LIFNR). Used as the cross-system business identifier for the supplier across ERP, EDI, and procurement workflows.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualProductionCapacity rdf:type rdf:Property ;
    rdfs:label 'Annual Production Capacity' ;
    rdfs:comment 'Declared annual production or throughput capacity of the supplier site in the site\'s primary unit of measure. Used for supply assurance assessments, dual-sourcing decisions, and demand planning stress tests.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVendorListStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Status' ;
    rdfs:comment 'Indicates the site\'s standing on the Approved Vendor List (AVL). Only sites with \'approved\' status are eligible for standard purchase order creation. \'conditional\' or \'probationary\' may require additional quality oversight.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the annual_production_capacity field (e.g., MT for metric tonnes, KG, L, CS). Ensures correct interpretation of capacity data across procurement and supply planning systems.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'FDA-assigned facility registration number for the supplier site, required under FSMA for domestic and foreign food facilities. Used to verify regulatory standing and support FSVP compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gfsiScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme' ;
    rdfs:comment 'Specific GFSI-benchmarked certification scheme held by this site. Distinct from the broader food_safety_certification field — captures the exact scheme name for regulatory and customer audit reporting. [ENUM-REF-CANDIDATE: SQF|FSSC_22000|BRC_GSFS|IFS_Food|GLOBALG.A.P.|PRIMUS_GFS|none — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether the supplier site holds a current Hazard Analysis Critical Control Points (HACCP) certification. Required for sites supplying direct food ingredients or food-contact packaging.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halalCertified rdf:type rdf:Property ;
    rdfs:label 'Halal Certified' ;
    rdfs:comment 'Indicates whether the supplier site holds a current Halal certification from a recognized certifying body. Required for ingredient sourcing for Halal-labeled product lines in applicable markets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertified rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified' ;
    rdfs:comment 'Indicates whether the supplier site holds a current Kosher certification from a recognized certifying agency. Relevant for ingredient sourcing for Kosher-labeled product lines.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditScore rdf:type rdf:Property ;
    rdfs:label 'Last Audit Score' ;
    rdfs:comment 'Numeric score achieved by the supplier site in the most recent quality or food safety audit, expressed as a percentage (0.00–100.00). Used in supplier performance scorecards and AVL status decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure applicable to the MOQ field (e.g., KG, LB, CS, PAL, EA). Ensures correct interpretation of the MOQ value in procurement planning and ERP order creation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled due date for the next quality or food safety audit at this supplier site. Calculated based on audit frequency policy, risk tier, and last audit date. Managed in TraceGains.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityContactName rdf:type rdf:Property ;
    rdfs:label 'Quality Contact Name' ;
    rdfs:comment 'Full name of the quality or food safety contact at the supplier site. Used for HACCP documentation requests, corrective action plan (CAP) communications, and audit coordination.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Procurement risk classification for the supplier site based on factors including food safety criticality, single-source dependency, geographic risk, and spend concentration. Drives audit frequency, safety stock levels, and contingency sourcing plans.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this supplier site, used in purchase orders, EDI transactions, and ASN communications. Corresponds to the vendor sub-range or delivery address code in SAP MM.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteEmail rdf:type rdf:Property ;
    rdfs:label 'Site Email' ;
    rdfs:comment 'Primary email address for the supplier site, used for purchase order transmission, ASN notifications, and compliance document requests via TraceGains.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the supplier site (e.g., \'Acme Ingredients — Chicago Plant\', \'Global Packaging — Rotterdam DC\'). Used in procurement documents, scorecards, and audit reports.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitePhone rdf:type rdf:Property ;
    rdfs:label 'Site Phone' ;
    rdfs:comment 'Primary telephone number for the supplier site, used for procurement communications, quality escalations, and logistics coordination.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the supplier site record. Controls whether the site is eligible for purchase order creation and sourcing. \'suspended\' indicates a temporary hold pending audit or corrective action.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the supplier site by its primary operational function. Drives sourcing decisions, compliance requirements, and audit frequency. [ENUM-REF-CANDIDATE: manufacturing_plant|warehouse|distribution_hub|co_packer|toll_manufacturer|service_delivery|laboratory|office — promote to reference product]' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Usda Establishment Number' ;
    rdfs:comment 'USDA-assigned establishment number for supplier sites involved in meat, poultry, or egg product processing. Required for USDA FSIS-regulated facilities and used in regulatory traceability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Reference to the supplier/vendor master record. Identifies the approved supplier entity in this AVL entry.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:supplierQualityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quality Assessment Id' ;
    rdfs:comment 'Foreign key linking to quality.supplier_quality_assessment. Business justification: AVL approval in F&B is directly driven by supplier quality assessment outcomes (SQF/BRC/FSSC scores). The AVL record must reference the qualifying SQA for audit trail, requalification scheduling, and ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualityAssessment .

ind:allergenApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Approved Flag' ;
    rdfs:comment 'Indicates whether the supplier has been specifically assessed and approved for allergen management controls relevant to this material. Supports allergen matrix compliance and FSMA preventive controls.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text field capturing conditions, restrictions, or rationale associated with the approval decision. For example, conditional approvals may specify required corrective actions or usage limitations.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Sourcing tier designation for this supplier-material combination. \'primary\' = preferred first-source supplier; \'secondary\' = qualified backup supplier; \'contingency\' = emergency-use only supplier activated during supply disruptions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee ID of the quality or procurement professional who formally approved this supplier-material combination for the AVL. Supports audit trail and regulatory accountability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the most recent audit conducted for this supplier-material combination. \'first_party\' = self-assessment; \'second_party\' = customer-conducted; \'third_party\' = independent certification body; \'remote\' = virtual audit; \'desk_audit\' = document review only.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the AVL record, formatted as AVL-XXXXXXXX. Used for cross-system referencing between SAP MM and TraceGains.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsvpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fsvp Required Flag' ;
    rdfs:comment 'Indicates whether this supplier-material combination is subject to FSMA Foreign Supplier Verification Program requirements due to the material being imported from outside the United States.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Verified Flag' ;
    rdfs:comment 'Indicates whether the supplier has been verified as having an implemented and validated HACCP plan for this material, as required under FSMA preventive controls and GFSI standards.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Requalification Date' ;
    rdfs:comment 'Date of the most recent supplier requalification assessment for this material. Used to track compliance with periodic requalification requirements under FSMA and GFSI.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Date' ;
    rdfs:comment 'Scheduled date for the next supplier requalification review. Calculated based on requalification frequency policy and last requalification date. Drives procurement compliance calendar.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonGmoVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Verified Flag' ;
    rdfs:comment 'Indicates whether the supplier\'s material has been verified as non-GMO (Genetically Modified Organism), supporting clean label and non-GMO product claims.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds USDA National Organic Program (NOP) certification for this material. Required for organic product formulations and clean label claims.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code (WERKS) indicating the manufacturing or distribution facility for which this supplier-material approval is valid. Null indicates approval is valid across all plants in the purchasing organization.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is designated as the preferred (first-choice) source for this material within its approval tier. Used in automated purchase order source determination.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationBasis rdf:type rdf:Property ;
    rdfs:label 'Qualification Basis' ;
    rdfs:comment 'The primary quality and regulatory basis on which the supplier approval was granted. Indicates the type of evidence used to qualify the supplier for this material. [ENUM-REF-CANDIDATE: audit|certificate|questionnaire|third_party_cert|historical_performance|regulatory_approval — promote to reference product]' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInfoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Info Record Number' ;
    rdfs:comment 'SAP MM Purchasing Info Record number (EINE-INFNR) linking this AVL entry to the corresponding purchasing conditions and pricing data in SAP S/4HANA.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for this material, representing a single-source supply risk. Triggers supply risk alerts and dual-sourcing initiatives.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceListIndicator rdf:type rdf:Property ;
    rdfs:label 'Source List Indicator' ;
    rdfs:comment 'Indicates whether this supplier-material combination is included in the SAP MM Source List (EORD), making it eligible for automatic source determination in purchase requisitions and orders.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierRiskTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Risk Tier' ;
    rdfs:comment 'Risk classification assigned to this supplier-material combination based on food safety hazard severity, supply criticality, and supplier performance history. Drives frequency of verification activities under FSMA.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason code or description explaining why the supplier-material approval was suspended or revoked. Populated when approval_status is \'suspended\' or \'revoked\'. Supports CAPA (Corrective and Preventive Action) tracking.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracegainsDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Tracegains Document Code' ;
    rdfs:comment 'Reference to the primary compliance document (e.g., supplier specification, audit report, certificate of analysis) stored in TraceGains Document Management that supports this AVL approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Purchase orders must specify delivery destination for receiving operations, warehouse capacity planning, and dock scheduling. Critical for coordinating inbound logistics with warehouse operations. No ' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:fsmaRecordId rdf:type rdf:Property ;
    rdfs:label 'Fsma Record Id' ;
    rdfs:comment 'Foreign key linking to regulatory.fsma_record. Business justification: Order processing records the associated FSMA compliance record for the supplier’s facility to support food safety audits.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FsmaRecord .

ind:blanketPoValueLimit rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Value Limit' ;
    rdfs:comment 'Maximum cumulative value authorized for release against a blanket purchase order or framework agreement. Applicable only when po_type = \'blanket_release\'. Used for spend control and contract compliance monitoring. Maps to SAP EKKO-KTWRT.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP or Oracle company code representing the legal entity issuing the purchase order. Determines the accounting ledger, currency, and fiscal year variant for financial postings. Maps to SAP EKKO-BUKRS.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign currency exchange rate applied at the time of PO creation to convert the PO currency to the company code local currency. Used for financial reporting and spend analytics in local currency. Maps to SAP EKKO-WKURS.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyHoldIndicator rdf:type rdf:Property ;
    rdfs:label 'Food Safety Hold Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order or its associated materials are currently under a food safety hold pending quality inspection, allergen verification, or HACCP review. When True, goods receipt and production use are blocked until cleared by QA. Supports FSMA and HACCP compliance.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether a goods receipt (GR) is required before invoice verification for this purchase order. When True, the three-way match (PO-GR-Invoice) is enforced. When False, two-way match (PO-Invoice) applies. Maps to SAP EKPO-WEPOS.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether any item on this purchase order is classified as a hazardous material requiring special handling, labeling, or transport documentation under DOT, IATA, or IMDG regulations. Relevant for chemical ingredients, cleaning agents, and certain food additives.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code (e.g., \'Port of Los Angeles\' for FOB, \'Buyer Warehouse Chicago\' for DDP). Required to fully define the delivery obligation under Incoterms 2020. Maps to SAP EKKO-INCO2.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Indicator' ;
    rdfs:comment 'Flag indicating whether invoice-based verification (LIV - Logistics Invoice Verification) is required for this PO. When False, evaluated receipt settlement (ERS) may apply. Maps to SAP EKPO-REPOS.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Commodity or material group classification code for the primary category of goods or services on this PO (e.g., raw ingredients, packaging materials, indirect MRO, co-packing services). Used for spend analytics by category and supplier segmentation. Maps to SAP EKPO-MATKL.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Total net value of the purchase order after discounts but before tax, in the PO currency. This is the principal financial commitment amount used in spend analytics, budget tracking, and COGS reporting. Part of the MONETARY_TRIPLET net total component. Maps to SAP EKKO-NETWR.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Po Gross Amount' ;
    rdfs:comment 'Total gross value of the purchase order before discounts, taxes, and freight charges, expressed in the PO currency. Represents the sum of all line-level extended prices. Part of the MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known alphanumeric purchase order number assigned by the ERP system (SAP S/4HANA or Oracle Cloud Procurement) and communicated to the supplier on the PO document. This is the BUSINESS_IDENTIFIER used in supplier correspondence, EDI transactions, and ASN matching. Maps to SAP EKKO-EBELN.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. \'draft\' = created but not submitted; \'pending_approval\' = in approval workflow; \'approved\' = approved and transmitted to supplier; \'open\' = active with outstanding delivery; \'partially_received\' = goods receipt posted for some lines; \'closed\' = fully received and invoiced; \'cancelled\' = voided before fulfillment. LIFECYCLE_STATUS canonical category. Maps to SAP EKKO processing status. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|partially_received|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement strategy. \'standard\' = one-time discrete PO; \'blanket_release\' = release against a blanket/framework agreement; \'subcontracting\' = toll manufacturing or co-packing arrangement where components are supplied to the vendor; \'service\' = service entry sheet-based PO for indirect services; \'consignment\' = vendor-managed inventory replenishment. Maps to SAP EKKO-BSART document type.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the buyer or purchasing group (commodity team) within the purchasing organization responsible for this PO. Used for spend analytics by buyer, workload management, and supplier relationship ownership. Maps to SAP EKKO-EKGRP.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPoKey rdf:type rdf:Property ;
    rdfs:label 'Source System Po Key' ;
    rdfs:comment 'The native primary key or document number of the purchase order in the originating source system (e.g., SAP EKKO-EBELN or Oracle PO header ID). Used for cross-system reconciliation, data lineage tracing, and support ticket resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the purchase order (e.g., VAT, GST, sales tax) in the PO currency. Part of the MONETARY_TRIPLET adjustment component. Maps to SAP EKKO tax conditions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Ordered' ;
    rdfs:comment 'Total quantity of goods or services ordered across all lines of this purchase order, expressed in the base unit of measure (uom_code). Used for inventory planning, receiving, and OTIF measurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityReceived rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Received' ;
    rdfs:comment 'Cumulative quantity of goods received against this purchase order as of the latest goods receipt posting, expressed in the base unit of measure. Used to calculate open PO quantity, OTIF fill rate, and goods receipt variance.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tracegainsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tracegains Compliance Status' ;
    rdfs:comment 'Compliance status of the supplier for this purchase order as tracked in TraceGains, the supplier compliance and document management platform. Reflects whether required supplier documents (COA, SQF certificate, allergen declaration, FSMA compliance) are current and approved. \'compliant\' = all documents valid; \'non_compliant\' = missing or expired documents; \'pending_review\' = documents submitted but under review; \'not_required\' = compliance check not applicable.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Determines how the procurement cost is assigned in financial accounting (e.g., to a cost center for indirect materials, to a production order for direct ingredients, to a project for capital expenditure). Critical for COGS and EBITDA reporting.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether the material being procured on this line contains or may contain one or more regulated allergens (e.g., peanuts, tree nuts, milk, eggs, wheat, soy, fish, shellfish). Triggers allergen matrix validation and segregated storage requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Required' ;
    rdfs:comment 'Indicates whether batch management is required for this material upon goods receipt, enabling lot traceability for food safety compliance (HACCP, FSMA). When true, a batch number must be assigned at goods receipt.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Indicates whether this purchase order line has been marked for deletion in the source ERP system. Soft-delete flag used to exclude cancelled or obsolete lines from active procurement reporting while retaining audit history.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date on which delivery of the material or service is requested at the receiving plant or distribution center. Drives production scheduling, inventory planning, and OTIF (On Time In Full) performance measurement.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of the material actually received against this purchase order line, expressed in the order unit of measure. Used to calculate open quantity, delivery completeness, and three-way match for invoice verification.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Indicates whether an invoice is expected for this purchase order line. When false, the system may use evaluated receipt settlement (ERS/self-billing) for high-volume ingredient suppliers.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier against this purchase order line. Used in three-way match (PO quantity vs. GR quantity vs. invoice quantity) for accounts payable processing and accrual management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP item category code defining the procurement type for this line (e.g., standard stock material, subcontracting for toll manufacturing/co-packing, consignment, service). Determines goods receipt and invoice verification behavior.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this purchase order line in the source ERP system. Supports change detection for incremental data loads and audit compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent purchase order, as assigned by the ERP system (e.g., 10, 20, 30 in SAP). Used for ordering and referencing individual line items within a PO. Satisfies TRANSACTION_LINE category: LINE_SEQUENCE.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of the purchase order line item reflecting its fulfillment lifecycle. Drives procurement workflow, goods receipt matching, and accounts payable processing. [ENUM-REF-CANDIDATE: open|partially_delivered|fully_delivered|invoiced|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'ERP-assigned alphanumeric code uniquely identifying the raw material, ingredient, or packaging material being procured. Aligns with the material master and Bill of Materials (BOM) for ingredient traceability and COGS tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short descriptive name of the raw material, ingredient, or packaging item as defined in the material master. Supports procurement reporting, invoice matching, and supplier communication.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net monetary value of this purchase order line, calculated as (ordered_quantity / price_unit) × unit_price. Represents the committed spend for this line item and feeds into COGS and procurement spend analytics.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which the ordered quantity is expressed (e.g., KG, LB, L, EA, CS, MT). Must align with the material master order unit for accurate goods receipt and invoice verification.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the supplier may over-deliver against the ordered quantity without triggering a purchase order amendment. Common in bulk ingredient procurement where exact quantities are difficult to control.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity base for which the unit price is quoted (e.g., price per 100 KG, price per 1000 units). Required for accurate net value calculation when pricing is expressed per multiple units, as is common in bulk ingredient procurement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection is required for this material upon goods receipt, per HACCP, GMP, or SQF requirements. When true, the material is placed in quality inspection stock until released by the QM team.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the specific storage location within the plant where the received material will be placed (e.g., raw material warehouse, cold storage, dry goods). Supports FIFO/FEFO inventory management and WMS integration.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the supplier may under-deliver against the ordered quantity and still have the line considered fully delivered. Prevents unnecessary open PO lines for minor quantity shortfalls.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Agreed net price per unit of measure for this purchase order line as negotiated with the supplier or derived from a pricing contract. Core input for COGS calculation and raw material cost tracking. Satisfies TRANSACTION_LINE category: LINE_VALUE_OR_RESULT.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclarationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided allergen declaration was received with the goods. Critical for allergen matrix management and food safety compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The supplier-provided batch or lot number for the received material. Critical for lot traceability, FSMA compliance, recall management, and FEFO inventory rotation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'The date until which the received material maintains optimal quality characteristics. Used for inventory prioritization and customer service level management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfAnalysisReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided certificate of analysis was received with the goods. Required for raw material release and TraceGains compliance documentation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether the received material met cold chain temperature requirements during transportation and receipt. Non-compliance triggers quality hold and supplier corrective action.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which the goods were physically received at the plant or distribution center. This is the principal business event timestamp for the receipt transaction and triggers inventory valuation and FEFO/FIFO aging calculations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The externally-known business identifier for this goods receipt transaction. Used for cross-system reconciliation, three-way match with invoice, and audit trails.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'The current lifecycle status of the goods receipt transaction. Tracks the receipt through posting, quality inspection, approval, and final disposition workflows.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which the received material was manufactured or produced by the supplier. Used for shelf life calculation and FEFO inventory management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this goods receipt record was last modified in the system. Tracks changes for audit compliance and data quality monitoring.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'The quality management inspection lot number assigned to this goods receipt for quality testing and approval. Links to quality inspection results and certificate of analysis.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received material requires quality inspection before being released to unrestricted inventory. Triggers quality management workflows per GMP and HACCP requirements.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving clerk documenting any observations, damage, discrepancies, or special handling instructions for the received goods.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction code applied to this goods receipt for sales and use tax calculation. Used for tax compliance and invoice verification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt C' ;
    rdfs:comment 'The temperature of the received material at the time of receipt, measured in degrees Celsius. Critical for cold chain compliance and temperature-sensitive ingredient quality verification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The total monetary value of the goods receipt, calculated as received quantity multiplied by unit price. Used for inventory accounting and financial reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'The specific dock or unloading bay at the plant or distribution center where the goods were received. Supports warehouse operations and receiving efficiency analytics.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The inventory valuation method applied to this goods receipt for financial accounting. Determines how the received material cost is recorded in inventory and COGS.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultDeliveryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Default Delivery Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Blanket contracts specify default delivery locations for automated PO generation and logistics planning. Reduces manual data entry, ensures consistent routing, and supports vendor-managed inventory pr' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:allergenHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Requirements' ;
    rdfs:comment 'Specific allergen control and handling requirements stipulated in the contract to ensure compliance with allergen labeling and cross-contamination prevention (e.g., dedicated lines, allergen-free facility).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews for an additional term unless either party provides termination notice.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed contract document stored in the document management system.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the purchase contract, used in procurement documents and supplier communications.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the purchase contract. Active contracts are in force; suspended contracts are temporarily paused; expired contracts have passed their end date; terminated contracts were ended early.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the procurement contract structure. Value contracts specify total value with flexible quantities; quantity contracts commit to specific volumes; scheduling agreements include delivery schedules; framework agreements establish terms for multiple purchase orders.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleType rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Type' ;
    rdfs:comment 'Type of delivery arrangement under this contract. Scheduled deliveries follow a fixed calendar; just-in-time aligns with production schedules; vendor-managed inventory allows supplier to manage stock levels.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether this contract includes exclusivity terms requiring the buyer to source specified materials exclusively from this supplier, or vice versa.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foodSafetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Required' ;
    rdfs:comment 'Food safety certifications that the supplier must maintain to fulfill this contract (e.g., SQF Level 2, FSSC 22000, BRC, GFSI-recognized standard).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Text describing the force majeure provisions that excuse performance due to unforeseeable circumstances (natural disasters, pandemics, war, government actions).' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered per purchase order or delivery under this contract. Critical for production planning and supplier efficiency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms code defining the payment schedule and conditions (e.g., Net 30, Net 60, 2/10 Net 30 for early payment discounts).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Mechanism' ;
    rdfs:comment 'Method by which contract prices may be adjusted over time. Index-linked ties to commodity indices; cost-plus adjusts based on supplier cost changes; fixed prices remain constant; periodic reviews allow renegotiation.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'Name of the commodity or inflation index used for price escalation (e.g., USDA Dairy Index, CPI, PPI, CME Corn Futures). Applicable when price_adjustment_mechanism is index_linked.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'Date until which the pricing conditions remain valid. After this date, prices may be renegotiated or adjusted per escalation clauses.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Date from which the pricing conditions in this contract become effective.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the buyer or procurement team responsible for managing this contract and related purchase orders.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Code or name of the purchasing organization or business unit responsible for this contract within the enterprise.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Flag' ;
    rdfs:comment 'Indicates whether this contract includes volume-based rebate or discount tiers that provide retroactive price reductions when volume thresholds are met.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate applied when volume commitments or spend thresholds are achieved. May be tiered based on volume levels.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to contract expiration that termination notice must be provided to prevent automatic renewal.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for early termination of the contract by either party.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum monetary value committed under this contract across all line items and purchase orders. For value contracts, this is the spending limit; for quantity contracts, this is the estimated total value.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Quantity' ;
    rdfs:comment 'Total quantity committed to be purchased over the contract period. Used for volume-based pricing tiers and rebate calculations.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the volume commitment quantity.' ;
    rdfs:domain ind:PurchaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierScorecardId rdf:type rdf:Property ;
    rdfs:label 'Supplier Scorecard Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier performance scorecard record. Primary key. Entity role: TRANSACTION_HEADER — a periodic business event capturing quantitative KPI snapshots across quality, delivery, service, cost, and compliance dimensions for a supplier.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergenComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Allergen Compliance Rate' ;
    rdfs:comment 'Percentage of shipments where the supplier\'s allergen matrix declarations matched the received product\'s actual allergen profile during the evaluation period. Critical food safety KPI under FDA FSMA and EU Food Information Regulation.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'Current status of the supplier on the Approved Vendor List (AVL) as determined by this scorecard evaluation. Approved: cleared for procurement; Conditional: approved with restrictions; Suspended: temporarily blocked pending corrective action; Removed: delisted.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Rate' ;
    rdfs:comment 'Percentage of inbound shipments accompanied by a valid, specification-compliant Certificate of Analysis (CoA) during the evaluation period. Mandatory for food-grade raw materials and ingredients under FDA FSMA and GFSI requirements.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text narrative field capturing qualitative observations, context for score deviations, notable supplier improvements, or escalation notes from the evaluator. Supports supplier development conversations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Weighted performance score for the regulatory and food safety compliance dimension, incorporating audit results, certificate currency, FSMA/HACCP documentation completeness, and allergen matrix accuracy. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the supplier must submit or complete the corrective action plan (CAP) in response to scorecard findings. Null when corrective_action_required is False.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan (CAP) has been triggered as a result of this scorecard evaluation. True when overall score or any critical dimension falls below the defined threshold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costScore rdf:type rdf:Property ;
    rdfs:label 'Cost Score' ;
    rdfs:comment 'Weighted performance score for the cost dimension, incorporating invoice accuracy, pricing compliance against contract, and cost reduction contribution. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Critical Nonconformance Count' ;
    rdfs:comment 'Number of non-conformances classified as critical severity (e.g., food safety risk, allergen contamination, HACCP critical control point failure) during the evaluation period. Critical NCRs may trigger immediate supplier suspension.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRatePpm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Ppm' ;
    rdfs:comment 'Number of defective or rejected units per one million units received from the supplier during the evaluation period. Industry-standard quality metric (PPM). Sourced from SAP QM goods receipt inspection results.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Score' ;
    rdfs:comment 'Weighted performance score for the delivery dimension, incorporating On Time In Full (OTIF) rate and fill rate. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'Last calendar date of the performance measurement window covered by this scorecard. Defines the inclusive end of the data aggregation period for all KPI calculations.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'First calendar date of the performance measurement window covered by this scorecard. Defines the inclusive start of the data aggregation period for all KPI calculations.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Frequency classification of the scorecard evaluation cycle. Quarterly scorecards are standard for strategic suppliers; annual for approved vendor list (AVL) renewal; ad-hoc for corrective action follow-up.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity actually delivered by the supplier during the evaluation period. Measures supply availability and capacity reliability. Calculated as (quantity delivered / quantity ordered) × 100.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyAuditResult rdf:type rdf:Property ;
    rdfs:label 'Food Safety Audit Result' ;
    rdfs:comment 'Outcome of the most recent food safety audit conducted against the supplier during or immediately preceding the evaluation period. Audits may be conducted under GFSI-benchmarked schemes (SQF, BRC, FSSC 22000) or internal GMP standards.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertificationScheme rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Scheme' ;
    rdfs:comment 'GFSI-benchmarked or regulatory food safety certification scheme under which the supplier is currently certified. Determines the rigor of the supplier\'s food safety management system and influences AVL approval status. [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|ISO_22000|HACCP|GMP|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of supplier invoices that matched the corresponding purchase order and goods receipt without discrepancy during the evaluation period. Sourced from SAP FI three-way match results.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimePerformanceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Performance Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier met the agreed lead time (from PO issuance to confirmed delivery) during the evaluation period. Complements OTIF by isolating the lead time adherence component.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count' ;
    rdfs:comment 'Total number of non-conformance reports (NCRs) raised against this supplier during the evaluation period. Includes quality deviations, specification failures, and food safety non-conformances logged in SAP QM or TraceGains.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifRate rdf:type rdf:Property ;
    rdfs:label 'Otif Rate' ;
    rdfs:comment 'Percentage of purchase order lines delivered both on time and in full quantity during the evaluation period. Industry-standard KPI for supply chain reliability. Calculated as (OTIF deliveries / total deliveries) × 100.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite weighted performance score for the supplier across all evaluation dimensions (quality, delivery, service, cost, compliance) for the evaluation period. Expressed as a percentage (0.00–100.00). Drives supplier tiering and AVL renewal decisions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceRate rdf:type rdf:Property ;
    rdfs:label 'Price Variance Rate' ;
    rdfs:comment 'Percentage deviation of actual invoiced prices from contracted purchase prices during the evaluation period. Positive values indicate supplier overcharging; negative values indicate favorable pricing. Sourced from SAP MM/FI purchase price variance analysis.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Weighted performance score for the quality dimension, incorporating defect/rejection rate (PPM), non-conformance count and severity, and certificate of analysis (CoA) compliance rate. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Qualitative-to-quantitative score (0.00–100.00) measuring the supplier\'s speed and quality of response to inquiries, issue escalations, corrective action requests, and change notifications during the evaluation period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Date' ;
    rdfs:comment 'The principal business event date on which the scorecard was formally issued or generated. Distinct from the evaluation period dates and from audit timestamps.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Externally-known business identifier for the scorecard document, formatted as SC-{YYYY}-{NNNNNN}. Used for cross-referencing in SAP MM supplier evaluation reports and TraceGains compliance documents.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current workflow lifecycle state of the scorecard. Draft: data being compiled; In Review: under procurement/quality review; Approved: signed off by category manager; Published: shared with supplier; Archived: superseded by newer period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScore rdf:type rdf:Property ;
    rdfs:label 'Service Score' ;
    rdfs:comment 'Weighted performance score for the service dimension, incorporating responsiveness score, issue resolution time, and communication quality. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Compliance Rate' ;
    rdfs:comment 'Percentage of inbound shipments meeting the minimum remaining shelf life requirement at time of receipt, as defined in the supplier specification and procurement contract. Supports FEFO inventory management.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the supplier has formally acknowledged receipt and acceptance of the scorecard results. Required for closed-loop supplier performance management and dispute resolution.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Classification of the supplier by the type of goods or services procured. Drives which KPI weights and thresholds apply in the scorecard model. Co-packer and toll manufacturer categories are specific to food and beverage outsourced production. [ENUM-REF-CANDIDATE: raw_material|ingredient|packaging|indirect|co_packer|toll_manufacturer|service — promote to reference product]' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Letter-grade rating of the supplier\'s environmental, social, and governance (ESG) performance, including carbon footprint, water usage, ethical sourcing, and packaging recyclability. Increasingly required for Scope 3 emissions reporting and retailer sustainability mandates.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseOrders rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders' ;
    rdfs:comment 'Total number of purchase orders (POs) issued to this supplier during the evaluation period. Provides volume context for interpreting rate-based KPIs such as OTIF rate and invoice accuracy rate.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total procurement spend with this supplier during the evaluation period in the reporting currency. Used for spend analytics, strategic sourcing prioritization, and COGS impact assessment.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Id' ;
    rdfs:comment 'Unique identifier for the supplier audit record. Primary key for the supplier audit entity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAudit .

ind:auditedStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Audited Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Supplier audits occur at specific facilities (supplier warehouses, co-packer sites). Audit scope, findings, and CAPA are location-specific. Essential for GFSI compliance, AVL management, and risk-base' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:auditClosureDate rdf:type rdf:Property ;
    rdfs:label 'Audit Closure Date' ;
    rdfs:comment 'Date on which the audit and all associated Corrective Action and Preventive Action (CAPA) activities were formally closed, indicating all findings have been satisfactorily resolved.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the audit was conducted at the supplier facility. Primary business event timestamp for the audit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit End Timestamp' ;
    rdfs:comment 'Precise date and time when the audit was concluded.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required frequency of audits for this supplier in months (e.g., 12 for annual, 24 for biennial), based on risk assessment and regulatory requirements.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Letter grade or qualitative rating assigned to the audit outcome based on the score and findings (e.g., A, B, C, D, F or excellent, good, acceptable, needs improvement, unacceptable). [ENUM-REF-CANDIDATE: A|B|C|D|F|excellent|good|acceptable|needs_improvement|unacceptable — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or context related to the audit that do not fit into structured fields.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'External business identifier for the audit, used for tracking and communication with suppliers and auditors.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific processes, product categories, facility areas, and compliance standards evaluated during the audit.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Start Timestamp' ;
    rdfs:comment 'Precise date and time when the on-site or remote audit commenced.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Tracks progression from scheduling through completion and closure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorCertification rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification' ;
    rdfs:comment 'Professional certification or accreditation held by the auditor (e.g., GFSI-recognized, ISO 22000 Lead Auditor, HACCP Certified).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the third-party auditing organization or certification body that performed the audit (e.g., NSF, SGS, Bureau Veritas, Intertek).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Capa Approval Date' ;
    rdfs:comment 'Date on which the submitted Corrective Action and Preventive Action (CAPA) plan was reviewed and approved by the quality assurance team.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Date by which the supplier must submit their Corrective Action and Preventive Action (CAPA) response for all audit findings.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Boolean indicator of whether Corrective Action and Preventive Action (CAPA) is required based on audit findings. True if any findings require formal CAPA response.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date on which the supplier submitted their Corrective Action and Preventive Action (CAPA) response documentation.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Date' ;
    rdfs:comment 'Date on which the effectiveness of the implemented Corrective Action and Preventive Action (CAPA) was verified.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Method' ;
    rdfs:comment 'Method used to verify that the supplier has effectively implemented the Corrective Action and Preventive Action (CAPA) plan (e.g., document review, follow-up audit, remote verification, supplier self-assessment, photographic evidence, test results).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Status' ;
    rdfs:comment 'Current status of the Corrective Action and Preventive Action (CAPA) verification process (e.g., pending, verified effective, verified ineffective, requires additional action, closed).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current certification status of the supplier facility based on the audit outcome (e.g., certified, not certified, certification suspended, certification withdrawn, recertification required).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Total number of critical non-conformances identified during the audit. Critical findings represent immediate food safety or quality risks requiring urgent corrective action.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this audit satisfies Food Safety Modernization Act (FSMA) supplier verification requirements for the associated supplier.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Gfsi Recognized Flag' ;
    rdfs:comment 'Boolean indicator of whether this audit was conducted under a Global Food Safety Initiative (GFSI)-recognized certification scheme (e.g., SQF, BRC, FSSC 22000, IFS).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Total number of major non-conformances identified during the audit. Major findings represent significant deviations from standards that could lead to food safety or quality issues.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Total number of minor non-conformances identified during the audit. Minor findings represent low-risk deviations that should be addressed but do not pose immediate threats.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Planned date for the next scheduled audit of this supplier facility, based on audit frequency requirements and previous audit outcomes.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Total number of observations or opportunities for improvement noted during the audit that do not constitute non-conformances but represent best practice recommendations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall pass or fail determination for the audit. Conditional pass indicates minor findings that must be addressed within a specified timeframe.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentMasterId rdf:type rdf:Property ;
    rdfs:label 'Equipment Master Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.equipment_master. Business justification: GMP/regulatory equipment certification tracking: F&B compliance documents include calibration certificates, equipment sanitation certifications, and pressure vessel certifications tied to specific equ' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentMaster .

ind:supersededDocumentComplianceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Compliance Document Id' ;
    rdfs:comment 'Identifier of the previous version of the compliance document that this document replaces. Null if this is the first version.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceDocument .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions for the compliance document.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalNonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Critical Non Conformance Count' ;
    rdfs:comment 'Number of critical or major non-conformances identified during an audit that require immediate corrective action. Null for non-audit documents.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level classification grouping the compliance document by its primary business function or regulatory domain. [ENUM-REF-CANDIDATE: regulatory|quality|safety|sustainability|ethical_sourcing|allergen|nutritional|specification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique business identifier or control number assigned to the compliance document by the supplier or issuing authority.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the compliance document indicating its approval state and validity for use in procurement and manufacturing operations. [ENUM-REF-CANDIDATE: draft|pending_review|approved|rejected|expired|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Descriptive title or name of the compliance document as provided by the supplier or issuing authority.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the compliance document indicating its purpose and regulatory or quality function. Types include Certificate of Analysis (CoA), Certificate of Conformance (CoC), allergen declarations, GMO (Genetically Modified Organism) status declarations, Kosher/Halal certificates, organic certificates, GFSI (Global Food Safety Initiative) audit certificates, FDA (Food and Drug Administration) registration, USDA (United States Department of Agriculture) inspection records, SDS (Safety Data Sheet) sheets, nutritional specifications, ingredient specifications, packaging specifications, third-party audit reports, and supplier questionnaires. [ENUM-REF-CANDIDATE: certificate_of_analysis|certificate_of_conformance|allergen_declaration|gmo_status_declaration|kosher_certificate|halal_certificate|organic_certificate|gfsi_audit_certificate|fda_registration|usda_inspection_record|sds_sheet|nutritional_specification|ingredient_specification|packaging_specification|third_party_audit_report|supplier_questionnaire — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format or extension of the compliance document (e.g., PDF, DOCX, XLSX, JPG). [ENUM-REF-CANDIDATE: pdf|docx|xlsx|jpg|png|xml|csv — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the digital file containing the compliance document as stored in the document management system.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI path where the compliance document file is stored in the document management system or cloud storage.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the compliance document file in kilobytes.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the compliance document was issued or published by the supplier or certifying authority.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the organization, certification body, or regulatory agency that issued or certified the compliance document (e.g., FDA, USDA, third-party auditor, supplier laboratory).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority License Number' ;
    rdfs:comment 'License, accreditation, or registration number of the issuing authority demonstrating their authorization to certify or audit.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO language code indicating the primary language in which the compliance document is written.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Specific production lot or batch number that this compliance document applies to. Used for lot-specific Certificates of Analysis. Null for general certificates.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Number of non-conformances, deficiencies, or findings identified during an audit or inspection. Null for non-audit documents.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory standard, certification scheme, or compliance framework that this document satisfies (e.g., FSMA, GFSI, ISO 22000, Organic NOP, Non-GMO Project).' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the compliance document must be retained to meet regulatory, legal, or business requirements.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Identifier of the approval workflow instance governing this purchase requisition, tracking routing and approval steps.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the purchase requisition was converted to a purchase order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full delivery address where the materials or services should be delivered, if different from the plant default address.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition, calculated as quantity requested multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of measure for the requested material or service, used for budgeting and approval workflows.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Boolean flag indicating whether the purchase requisition has been logically deleted or marked for archival.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of the purchase requisition indicating urgency of procurement need.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'High-level category classifying the type of procurement: raw materials, ingredients, packaging, indirect materials, services, or capital equipment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the material or service requested in the purchase requisition, expressed in the base unit of measure.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the requestor for communication and notifications regarding the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who requested the procurement.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials or services must be delivered to meet operational or production requirements.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted by the requestor.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows. Typically 10-character alphanumeric code from SAP MM.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_converted|fully_converted|cancelled|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer between plants, service procurement, or third-party direct delivery.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional instructions or notes provided by the requestor regarding handling, delivery, quality requirements, or other special considerations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccountId rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Id' ;
    rdfs:comment 'Reference to the house bank account associated with this GL account, applicable for bank GL accounts. Links the GL account to the physical bank account for cash management and bank reconciliation. Corresponds to SAP SKB1.HBKID + HKTID. Used in treasury and cash management for F&B global banking relationships.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'High-level categorization indicating whether the account is a balance sheet account (carries forward balances) or a profit and loss account (cleared at year-end). Statistical and memo accounts are used for internal tracking without impacting financial statements. Drives year-end closing procedures and EBITDA reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Account Created By' ;
    rdfs:comment 'User ID or name of the person who created the GL account master record. Supports audit trail requirements and Sarbanes-Oxley (SOX) internal controls over financial reporting. Corresponds to SAP SKA1.ERNAM.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreationDate rdf:type rdf:Property ;
    rdfs:label 'Account Creation Date' ;
    rdfs:comment 'The date on which the GL account master record was originally created in the chart of accounts. Used for audit trail, account lifecycle management, and compliance reporting. Corresponds to SAP SKA1.ERDAT.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountHierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Node' ;
    rdfs:comment 'The node identifier within the GL account hierarchy (e.g., SAP Financial Statement Version node, Oracle account hierarchy node) to which this account is assigned. Enables roll-up reporting from individual accounts to subtotals and totals in financial statements. Supports EBITDA reporting, segment reporting, and management reporting structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name of the GL account providing full business context beyond the short name. Used in detailed financial reporting, account reconciliation documentation, and audit trails. Corresponds to SAP SKA1.TXT50.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Human-readable short description / name of the GL account as it appears in financial reports, journal entry screens, and the chart of accounts. Corresponds to SAP SKA1.TXT20 (short text) or Oracle account description.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known GL account code as defined in the chart of accounts (e.g., SAP G/L account number, Oracle natural account segment). This is the business identifier used in all journal entries, cost allocations, and financial postings across ERP systems. Aligns to SAP SKA1.SAKNR / Oracle COA segment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account master record. Active accounts accept postings; blocked accounts are temporarily restricted; accounts marked for deletion are pending archival. Drives posting validation in ERP systems and financial close processes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'Further classification of the GL account within its primary account type, providing granular categorization for financial reporting and analytics. Examples: for assets — current_asset, fixed_asset, intangible_asset; for expenses — cogs, selling_expense, admin_expense, rd_expense, trade_spend. Supports COGS calculation, EBITDA reporting, and trade promotion management (TPM) accrual tracking in F&B. [ENUM-REF-CANDIDATE: current_asset|fixed_asset|intangible_asset|current_liability|long_term_liability|cogs|gross_revenue|net_revenue|trade_spend|selling_expense|admin_expense|rd_expense — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Fundamental classification of the GL account indicating its role in financial statements. Determines whether the account appears on the balance sheet (asset, liability, equity) or income statement (revenue, expense). Corresponds to SAP SKA1.KTOKS account group classification and Oracle account type. Critical for P&L vs. balance sheet segregation and EBITDA reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for local statutory reporting or group consolidation mapping. Enables mapping between the operating chart of accounts and a group/country chart of accounts. Corresponds to SAP SKB1.ALTKT. Supports multi-GAAP and consolidation reporting for global F&B operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether this account is a balance sheet account whose balance carries forward to the next fiscal year without being closed. Balance sheet accounts represent assets, liabilities, and equity. Used in financial close processes, intercompany reconciliation, and fixed asset reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier of the chart of accounts to which this GL account belongs. In SAP, this is the KTOPL field (e.g., \'INT\', \'CAUS\'). Enterprises may maintain multiple charts of accounts for different legal entities or reporting frameworks (GAAP, IFRS). Drives account assignment and financial statement version mapping.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagement rdf:type rdf:Property ;
    rdfs:label 'Commitment Management' ;
    rdfs:comment 'Indicates whether commitment management (funds commitment tracking) is active for this GL account. When true, purchase orders and other commitments are tracked against budget for this account. Relevant for capital expenditure accounts and trade promotion spend management in F&B. Corresponds to SAP SKB1 commitment management indicator.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyCodePostingBlock rdf:type rdf:Property ;
    rdfs:label 'Company Code Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are blocked at the company code level (as opposed to the chart of accounts level). Allows selective blocking for specific legal entities while keeping the account active in others. Corresponds to SAP SKB1.XSPEB.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classifies the GL account as a primary cost element (originating from FI postings, e.g., material costs, labor), secondary cost element (internal allocations only, e.g., overhead rates, activity allocations), or not applicable (balance sheet accounts). In SAP S/4HANA, primary cost elements are unified with GL accounts. Drives COGS calculation, variance analysis, and cost center accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'Numeric type code classifying the cost element behavior in controlling (CO). Examples: 1=primary costs/cost-reducing revenues, 3=accrual/deferral per surcharge, 4=accrual/deferral per debit=actual, 11=revenues, 12=sales deductions, 22=external settlement. Corresponds to SAP CSKA.KATYP. Drives cost allocation, variance analysis, and profitability reporting. [ENUM-REF-CANDIDATE: 1|3|4|11|12|22|41|42|43|50|51|61 — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this GL account has been flagged for deletion and is pending archival. Accounts flagged for deletion cannot receive new postings and will be removed during the next archiving run. Corresponds to SAP SKA1.XLOEV. Supports master data lifecycle management and chart of accounts housekeeping.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Controls which fields are required, optional, or suppressed when posting to this GL account. Determines the entry screen layout for journal entries. Corresponds to SAP SKB1.FSTAG. Critical for enforcing data quality on financial postings (e.g., requiring cost center on expense accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'The financial statement version (FSV) to which this account is assigned for statutory and management reporting. Controls how the account is grouped and displayed in balance sheets and income statements. In SAP, corresponds to the VERSN field in T011T. Supports parallel reporting under GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Classifies the GL account by business function for cost-of-sales accounting and segment reporting (e.g., manufacturing/COGS, sales and distribution, general and administrative, research and development, marketing). Enables income statement reporting by function of expense per IFRS IAS 1. Critical for F&B P&L reporting by function. Corresponds to SAP FKBER.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflationIndex rdf:type rdf:Property ;
    rdfs:label 'Inflation Index' ;
    rdfs:comment 'Reference to the inflation index used for inflation accounting adjustments on this GL account. Applicable in high-inflation economies where F&B operations require IAS 29 (Financial Reporting in Hyperinflationary Economies) compliance. Corresponds to SAP SKB1 inflation index assignment.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Indicator' ;
    rdfs:comment 'Indicator controlling whether and how interest is calculated on balances in this GL account. Used for intercompany loan accounts, overdue receivables, and cash pool accounts. Corresponds to SAP SKB1.ZINRT. Supports intercompany transaction management and treasury operations in F&B.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Boolean flag indicating whether this GL account is designated as a reconciliation account for a subledger (AP, AR, or fixed assets). When true, direct manual postings are blocked and all entries must originate from the corresponding subledger. Supports subledger-to-GL reconciliation controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'The date on which the GL account master record was last changed. Supports change management tracking, audit trail, and SOX compliance for master data governance. Corresponds to SAP SKA1.LAEDA.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayed for this GL account. When true, users can drill down to individual postings. Required for accounts subject to audit or detailed reconciliation. Corresponds to SAP SKB1.XKRES. Impacts storage requirements and reporting granularity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlyBalancesInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Only Balances In Local Currency' ;
    rdfs:comment 'When true, the system only manages balances in local (company code) currency for this account, suppressing foreign currency balance management. Typically set for cash and bank accounts. Corresponds to SAP SKB1.XSALH. Impacts foreign currency revaluation processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account. When true, individual line items remain open until cleared against an offsetting entry (e.g., GR/IR clearing accounts, bank clearing accounts). Essential for reconciliation of goods receipt/invoice receipt accounts in F&B procurement. Corresponds to SAP SKB1.XOPVW.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Indicates the level at which financial planning and budgeting is performed for this account (e.g., cost center level, profit center level, company code level). Drives integration with SAP IBP and budgeting tools for demand planning, COGS forecasting, and trade spend budgeting in F&B operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are currently blocked at the chart of accounts level. When true, no journal entries can be posted to this account across all company codes. Used during account restructuring, period-end controls, or when an account is being retired. Corresponds to SAP SKA1.XSPEB.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Profit Center Default' ;
    rdfs:comment 'Default profit center assigned to this GL account for automatic profit center derivation during posting. Ensures that balance sheet items and certain P&L items are assigned to the correct profit center for segment reporting. Corresponds to SAP SKB1.PRCTR. Supports F&B brand/category P&L reporting and IFRS 8 segment disclosure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitLossStatementAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Statement Account' ;
    rdfs:comment 'Indicates whether this account is a profit and loss (income statement) account. P&L accounts are closed to retained earnings at fiscal year-end. Complements account_category for explicit P&L identification used in EBITDA reporting, trade spend accruals, and revenue management analytics.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Indicates whether this GL account serves as a reconciliation account for a subledger (accounts payable, accounts receivable, fixed assets) or is a standard posting account. Reconciliation accounts cannot be posted to directly; postings flow through the subledger. Corresponds to SAP SKB1.MITKZ. Critical for AP/AR and fixed asset subledger integrity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationIndicator rdf:type rdf:Property ;
    rdfs:label 'Revaluation Indicator' ;
    rdfs:comment 'Indicates whether this GL account is subject to foreign currency revaluation at period-end. When true, open items or balances in foreign currency are revalued to the current exchange rate. Critical for F&B companies with multi-currency operations. Corresponds to SAP SKB1 revaluation settings. Supports IFRS IAS 21 and GAAP ASC 830 compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Defines the field used to populate the allocation field in line items posted to this account, enabling sorting and grouping of line items in account statements. Common values: \'001\' (posting date), \'012\' (document number), \'031\' (material number). Corresponds to SAP SKB1.ZUAWA. Supports efficient account analysis and reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Specifies the tax category applicable to this GL account, controlling which tax codes can be used when posting to this account. Blank indicates no tax is applicable. Values such as \'+\' (all tax codes allowed), \'-\' (only input tax), or specific tax category codes. Critical for VAT/GST compliance in F&B operations across jurisdictions. Corresponds to SAP SKB1.MWSKZ. [ENUM-REF-CANDIDATE: input_tax|output_tax|all|none|input_only|output_only — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Assigns the GL account to a tolerance group that defines acceptable payment difference limits for clearing open items. Controls automatic write-off of small differences during payment processing and account clearing. Corresponds to SAP SKB1.TOGRU. Relevant for AR/AP clearing in F&B trade management.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Primary activity type code associated with this cost center, representing the unit of output used for direct activity allocation (e.g., machine hours, labor hours, production runs). Used in standard costing and variance analysis. Maps to SAP CO activity type (LSTAR).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects (orders, products, other cost centers). Drives COGS calculation accuracy and variance analysis. \'direct_activity\' uses activity types; \'assessment\' and \'distribution\' use cycle-based allocation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Approved annual budget for this cost center in the cost center currency for the current fiscal year. Used as the baseline for budget vs. actual variance reporting and EBITDA forecasting. Sourced from SAP CO budget planning (KPF6).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2025) to which the budget_amount applies. Enables multi-year budget tracking and year-over-year variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP business area code representing a distinct area of operations or responsibility within the company for internal balance sheet and P&L reporting. Supports segment-level financial reporting across legal entities. Maps to SAP field GSBER.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUser rdf:type rdf:Property ;
    rdfs:label 'Changed By User' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center master record in SAP CO. Supports change audit trail and Sarbanes-Oxley internal control documentation. Maps to SAP field AENAM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRelevant rdf:type rdf:Property ;
    rdfs:label 'Cogs Relevant' ;
    rdfs:comment 'Indicates whether costs incurred by this cost center are included in COGS calculation (True) or classified as operating expenses (False). Production and quality cost centers are typically COGS-relevant; administrative and marketing cost centers are not.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling (CO) area code that governs this cost center. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same chart of accounts and fiscal year variant. Maps to SAP field KOKRS.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Functional classification of the cost center indicating its primary business activity. Drives COGS allocation methodology and EBITDA reporting segmentation. Maps to SAP field KOSAR (Cost Center Category). CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code uniquely identifying the cost center within the controlling area, as assigned in SAP CO. Used in journal entries, purchase orders, and COGS allocation. Maps to SAP field KOSTL (Cost Center). BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Long-form description of the cost center\'s business purpose, scope of operations, and organizational context. Provides additional detail beyond the short name for reporting and governance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable short name of the cost center (e.g., \'Chicago Snack Plant\', \'R&D Lab - Beverages\', \'North America Sales Region\'). Maps to SAP field KTEXT. IDENTITY_LABEL category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle state of the cost center record. \'locked\' prevents new postings; \'pending_deletion\' marks records flagged for archival after period close. Maps to SAP deletion flag and lock indicators. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Operational classification distinguishing how costs flow: \'direct\' cost centers incur costs directly attributable to production (e.g., production lines); \'indirect\' and \'overhead\' centers accumulate shared costs for allocation; \'service\' centers provide internal services charged to other cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'SAP cost element group associated with this cost center, defining the set of cost elements (G/L accounts) that can be posted to it. Supports cost reporting by cost element category (material, labor, overhead, depreciation).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP user ID of the person who created this cost center master record in SAP CO. Supports audit trail and change management governance. Maps to SAP field ERNAM.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department code to which this cost center belongs (e.g., \'MFG-OPS\', \'FIN-CTRL\', \'MKT-BRAND\'). Supports departmental cost rollup reporting and aligns with HR organizational structure from Workday HCM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal calendar applicable to this cost center (e.g., \'K4\' for calendar year, \'V3\' for April–March). Governs period-end close and budget cycle alignment. Maps to SAP field GJAHR variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP functional area code classifying the cost center by business function (e.g., manufacturing, sales, administration, R&D) for cost-of-sales accounting and functional income statement reporting. Maps to SAP field FKBER.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region associated with this cost center (e.g., \'North America\', \'Europe\', \'Asia Pacific\'). Supports regional P&L reporting, trade spend analysis, and sales region cost allocation. [ENUM-REF-CANDIDATE: north_america|europe|asia_pacific|latin_america|middle_east_africa|global — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node identifier within the standard cost center hierarchy (SAP standard hierarchy) to which this cost center belongs. Enables hierarchical cost rollup reporting from individual cost centers to plant, region, and enterprise levels. Maps to SAP field KHINR.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this cost center participates in intercompany cost allocations (True), meaning costs may be charged across legal entities. Triggers intercompany elimination processes during financial consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Indicates whether this cost center is locked (True) to prevent new actual cost postings, typically applied during period-end close or when a cost center is being restructured. Maps to SAP CO lock indicator (SPERRK).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (True) used only for informational reporting without actual cost postings, or a real cost center (False) that receives actual cost allocations. Maps to SAP CO statistical indicator.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Key' ;
    rdfs:comment 'SAP overhead key assigned to this cost center, determining the overhead surcharge rates applied during product costing. Links to overhead costing sheets used in standard cost estimates for manufactured goods. Maps to SAP field ZUORD.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Reporting segment code (e.g., \'SNACKS-NA\', \'BEVERAGES-EU\', \'DAIRY-APAC\') to which this cost center contributes. Enables EBITDA reporting by business segment per IFRS 8 operating segment disclosure requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source Record Key' ;
    rdfs:comment 'The natural key of this cost center record in the originating source system (e.g., the concatenation of controlling area and cost center code in SAP CO: \'A000/CC1001\'). Enables traceability from the Silver Layer back to the operational system of record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'Planned cost rate per unit of activity for this cost center, used in standard costing to value production orders and calculate COGS. Expressed in the cost center currency per activity unit. Variances between standard and actual rates are reported in period-end variance analysis. MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center is active and available for cost postings. Supports time-dependent master data management and ensures costs are only allocated to active cost centers. Maps to SAP field DATAB. EFFECTIVE_FROM category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date after which this cost center is no longer active for cost postings. A null or far-future date (e.g., 9999-12-31) indicates an open-ended cost center. Maps to SAP field DATBI. EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'Work Breakdown Structure element code linking this cost center to a specific capital project or R&D initiative in SAP PS (Project System). Relevant for NPD project cost tracking and capital expenditure allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Budget Period End' ;
    rdfs:comment 'End date of the current active budget period for this profit center. Defines the boundary for budget vs. actual comparisons, financial close processes, and period-end accruals for trade spend and COGS.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start' ;
    rdfs:comment 'Start date of the current active budget period for this profit center. Used in budgeting, forecasting, and EBITDA variance analysis to align actuals against planned financial targets within the correct fiscal window.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dummyProfitCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Dummy Profit Center Flag' ;
    rdfs:comment 'Indicates whether this is the SAP dummy profit center used to capture postings that cannot be assigned to a real profit center (e.g., balance sheet items, unassigned transactions). The dummy profit center is a standard SAP CO-PCA construct and must be identifiable for exclusion from P&L reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether transactions posted to this profit center are subject to intercompany elimination during group consolidation. When true, revenues and costs are eliminated in consolidated financial statements to avoid double-counting. Critical for IFRS 10 group reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Code representing the geographic region (e.g., NA, EMEA, APAC, LATAM) associated with this profit center when the profit center represents a regional P&L segment. Enables regional EBITDA decomposition, cross-border intercompany reconciliation, and regulatory compliance reporting by jurisdiction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP GL account group associated with the profit center, defining the range of general ledger accounts that can post to this profit center. Ensures correct account assignment for revenue, COGS, trade spend accruals, and intercompany transactions.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the standard hierarchy node in SAP CO-PCA to which this profit center is assigned. Defines the position of the profit center within the enterprise profit center hierarchy, enabling roll-up reporting from individual profit centers to business units, divisions, and corporate level.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether the profit center is locked for financial postings in SAP CO-PCA. When true, no new journal entries, cost allocations, or revenue postings can be made to this profit center. Used during period-end close, organizational restructuring, or audit holds.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code of the product line (e.g., RTD beverages, RTE snacks, dairy) associated with this profit center when the profit center represents a product-line-level P&L segment. Supports product-line-level revenue management, pricing strategy (RSP/EDLP), and COGS variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the profit center within the SAP CO-PCA controlling area. This is the business-facing identifier used in financial reporting, journal entries, and intercompany allocations (e.g., PC_SNACKS_NA, PC_BEV_EMEA). Serves as the BUSINESS_IDENTIFIER category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Free-text long description of the profit center\'s business purpose, scope, and organizational context. Provides additional context beyond the short name for financial analysts, auditors, and data stewards. Sourced from SAP CO-PCA long text field.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Center Group' ;
    rdfs:comment 'SAP profit center group to which this profit center belongs, enabling grouped reporting and planning across related profit centers (e.g., all beverage profit centers grouped under \'GRP_BEVERAGES\'). Used in planning layouts, report painter reports, and EBITDA roll-up structures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Profit Center Level' ;
    rdfs:comment 'Numeric level of the profit center within the enterprise profit center hierarchy (e.g., 1 = corporate, 2 = division, 3 = brand/channel, 4 = sub-brand). Enables hierarchical roll-up queries and drill-down analysis in EBITDA reporting and financial dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center as defined in SAP CO-PCA (e.g., \'North America Snacks\', \'EMEA Beverages\', \'DTC Channel\'). Used as the IDENTITY_LABEL in financial dashboards, EBITDA reports, and brand-level P&L decomposition.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center in SAP CO-PCA. \'active\' — operational and accepting postings; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings (e.g., during restructuring); \'in_planning\' — set up for future fiscal year; \'archived\' — decommissioned and closed. Serves as the LIFECYCLE_STATUS category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by the dimension it represents for internal P&L reporting. Supports brand-level (e.g., a specific snack brand), product-line-level (e.g., RTD beverages), geographic-region-level (e.g., LATAM), or channel-level (e.g., retail, foodservice, DTC) EBITDA decomposition. Serves as the CLASSIFICATION_OR_TYPE category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center is subject to external regulatory financial reporting requirements (e.g., FDA facility-level reporting, USDA program reporting, SEC segment disclosures). When true, additional data governance controls and audit trails are applied.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapProfitCenterKey rdf:type rdf:Property ;
    rdfs:label 'Sap Profit Center Key' ;
    rdfs:comment 'The natural composite key from SAP CO-PCA combining controlling area and profit center code (e.g., \'1000/PC_SNACKS_NA\'). Preserved in the Silver Layer for traceability back to the source system and for cross-system reconciliation with Oracle Cloud ERP or other financial systems.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the profit center used in space-constrained reporting interfaces, planogram layouts, and financial dashboards (e.g., \'NA Snacks\', \'EMEA Bev\'). Sourced from SAP CO-PCA short text field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostingEnabled rdf:type rdf:Property ;
    rdfs:label 'Standard Costing Enabled' ;
    rdfs:comment 'Indicates whether standard costing is activated for this profit center. When true, product costs are valued at standard cost and variances (price, quantity, efficiency) are tracked against actuals. Critical for COGS calculation, margin analysis, and manufacturing variance reporting in F&B operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilitySegment rdf:type rdf:Property ;
    rdfs:label 'Sustainability Segment' ;
    rdfs:comment 'Classification of the profit center\'s product portfolio or operations by sustainability commitment level. Supports ESG reporting, sustainability-linked financial targets, and green revenue tracking. \'sustainable\' — meets defined sustainability criteria; \'transitioning\' — in progress toward sustainability targets; \'conventional\' — standard operations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code associated with the profit center\'s primary operating location. Used for indirect tax (VAT/GST) determination, transfer pricing compliance, and regulatory reporting to tax authorities (IRS, HMRC, etc.). Aligns with SAP tax configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Method' ;
    rdfs:comment 'Method used for intercompany transfer pricing when goods or services are exchanged between profit centers. \'cost_plus\' — cost plus a markup; \'market_price\' — prevailing market rate; \'negotiated\' — bilaterally agreed price; \'none\' — no intercompany transfers. Required for intercompany reconciliation and tax compliance.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this profit center is valid and active for financial postings in SAP CO-PCA. Supports time-dependent master data management and ensures correct period assignment during financial close and historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date until which this profit center is valid for financial postings. After this date, the profit center is locked for new postings. Null indicates an open-ended validity. Used for decommissioning profit centers during organizational restructuring or brand divestitures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The primary accounting standard under which this company code prepares its statutory financial statements. Determines recognition, measurement, and disclosure rules for revenue, inventory (COGS/FIFO), fixed assets, and trade spend accruals. Drives parallel ledger configuration in SAP.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCity rdf:type rdf:Property ;
    rdfs:label 'Address City' ;
    rdfs:comment 'City of the registered office of the legal entity. Used in statutory filings, regulatory submissions, and legal correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered office of the legal entity. Used for tax jurisdiction determination, regulatory filings, and statutory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressRegion rdf:type rdf:Property ;
    rdfs:label 'Address Region' ;
    rdfs:comment 'State, province, or region of the registered office. Used for sub-national tax jurisdiction determination, state-level regulatory compliance (e.g., California Prop 65 for food labeling), and regional statutory reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStreet rdf:type rdf:Property ;
    rdfs:label 'Address Street' ;
    rdfs:comment 'Street address of the registered office of the legal entity as recorded in the official company registry. Used for statutory correspondence, regulatory filings with FDA/USDA/EFSA, and legal notices. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code representing the operational division or segment within the Food Beverage group (e.g., North America Snacks, EMEA Beverages, APAC Dairy). Used for segment-level financial reporting, cross-company-code balance sheet preparation, and divisional P&L analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The SAP chart of accounts key assigned to this company code, defining the general ledger account structure used for financial postings. Governs the GL account hierarchy, COGS account assignments, revenue accounts, and trade spend accrual accounts. Maps to SAP KTOPL field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'The four-character alphanumeric SAP FI company code that uniquely identifies the legal entity within the ERP system. This is the externally-known business identifier used across all SAP modules (FI, CO, MM, SD, PP) and in intercompany transactions, statutory reporting, and financial consolidation. Maps directly to the BUKRS field in SAP.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code within the Food Beverage group. Controls whether the entity is available for posting, planning, and reporting. Inactive or dormant entities are excluded from operational processes but retained for historical audit and statutory purposes.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Company Registration Number' ;
    rdfs:comment 'Official company registration number issued by the national company registry (e.g., Companies House in the UK, SEC in the US, Handelsregister in Germany). Used for statutory filings, regulatory submissions, and legal entity verification in trade agreements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation group or reporting unit to which this company code belongs within the Food Beverage group financial consolidation structure. Used in SAP Group Reporting or BPC to aggregate financial results for segment reporting, EBITDA roll-ups, and statutory consolidated accounts.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationIndicator rdf:type rdf:Property ;
    rdfs:label 'Consolidation Indicator' ;
    rdfs:comment 'Flag indicating whether this company code is included in the Food Beverage group consolidated financial statements. Entities with this flag set to false (e.g., dormant shells, entities below materiality threshold) are excluded from group EBITDA reporting and multi-entity consolidation runs.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP Controlling (CO) area to which this company code is assigned. The controlling area defines the organizational unit for management accounting, cost center accounting, profit center accounting, COGS variance analysis, and standard costing. A single controlling area may span multiple company codes for cross-entity cost allocation. Maps to SAP KOKRS field.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area assigned to this company code, governing customer credit limit management, accounts receivable exposure monitoring, and credit risk controls for trade customers. Relevant for revenue management and trade spend credit exposure. Maps to SAP KKBER field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity within the Food Beverage corporate group structure. Drives consolidation treatment, intercompany elimination rules, and statutory reporting obligations. [ENUM-REF-CANDIDATE: subsidiary|joint_venture|holding|branch|associate|operating_entity — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemInstance rdf:type rdf:Property ;
    rdfs:label 'Erp System Instance' ;
    rdfs:comment 'Identifier of the SAP S/4HANA or Oracle Cloud ERP system instance from which this company code record is sourced. Relevant for Food Beverage entities that operate across multiple ERP landscapes (e.g., post-acquisition entities not yet migrated to the central SAP instance). Supports data lineage and source system traceability.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Food Safety License Number' ;
    rdfs:comment 'Regulatory license or registration number issued by the applicable food safety authority (e.g., FDA Food Facility Registration Number, USDA Establishment Number, EFSA authorization number) for this legal entity. Required for manufacturing, importing, or distributing food and beverage products. Critical for FSMA compliance and GFSI certification tracking.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyIndicator rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Indicator' ;
    rdfs:comment 'Flag indicating whether the local currency of this company code is also its functional currency as defined under IFRS IAS 21. When false, a separate functional currency determination is required, impacting foreign currency translation adjustments in the consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiCertificationScheme rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Scheme' ;
    rdfs:comment 'The GFSI-benchmarked food safety certification scheme held by this legal entity. Indicates the food safety management standard under which the entity operates (e.g., SQF, BRC, FSSC 22000). Used for supplier qualification, customer compliance requirements, and regulatory audit readiness. [ENUM-REF-CANDIDATE: SQF|BRC|FSSC_22000|IFS|GlobalGAP|not_certified — promote to reference product]' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the Food Beverage group reporting currency used in consolidated financial statements, EBITDA reporting, and multi-entity consolidation. Typically USD or EUR for global food and beverage groups. Enables currency translation for intercompany eliminations.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gstApplicable rdf:type rdf:Property ;
    rdfs:label 'Gst Applicable' ;
    rdfs:comment 'Flag indicating whether Goods and Services Tax (GST) or equivalent consumption tax applies to transactions of this company code. Relevant for entities operating in GST jurisdictions (e.g., Australia, Canada, India, Singapore). Drives tax code determination in SAP SD and MM for food and beverage product sales.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was formally incorporated and registered with the relevant national company registry. Used for entity age calculations, statutory anniversary filings, and historical financial consolidation scope determination.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this company code participates in intercompany transactions within the Food Beverage group. When true, the entity is subject to intercompany elimination rules during group consolidation, transfer pricing policies, and intercompany billing processes. Maps to SAP intercompany configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageKey rdf:type rdf:Property ;
    rdfs:label 'Language Key' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the primary language used for correspondence, statutory documents, and regulatory filings for this company code. Drives language-specific output for invoices, financial statements, and FDA/EFSA regulatory submissions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'SAP ledger group assigned to this company code, enabling parallel accounting under multiple accounting standards (e.g., IFRS and local GAAP simultaneously). Supports multi-GAAP reporting requirements for Food Beverage entities operating across jurisdictions with different statutory requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'SAP posting period variant that controls which fiscal periods are open or closed for financial postings in this company code. Governs the financial close process, period-end accruals, and trade spend accrual postings. Maps to SAP XVPER field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandard rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard' ;
    rdfs:comment 'Default SAP profit center assigned to this company code for management accounting purposes. Profit centers align to business units (e.g., Snacks, Beverages, Dairy) and are used for internal P&L reporting, EBITDA analysis by segment, and revenue management reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) or equivalent national tax identification number assigned to the legal entity by the relevant tax authority. Used for statutory tax filings, payroll tax reporting, and regulatory submissions to FDA and USDA.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD-approved transfer pricing method applied to intercompany transactions involving this company code. Governs how intercompany prices are set for goods (e.g., finished snacks, beverages transferred between manufacturing and distribution entities) and services. Critical for tax compliance and EBITDA integrity across the group. [ENUM-REF-CANDIDATE: CUP|resale_price|cost_plus|TNMM|profit_split|not_applicable — promote to reference product]' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) registration number issued by the tax authority of the country of incorporation. Required for EU VAT compliance, cross-border trade invoicing, and regulatory reporting to EFSA and national tax authorities. Used in intercompany billing and trade documentation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-text or structured assignment field used for sorting and matching open items (e.g., invoice number, payment reference, purchase order number). Critical for automated payment clearing, dunning, and accounts payable/receivable reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP cost center code identifying the organizational unit responsible for cost incurrence (e.g., a manufacturing plant, distribution center, or functional department). Drives COGS allocation, overhead absorption, and variance analysis in the CO module.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level providing business context for the posting (e.g., \'Monthly COGS accrual — Plant 1001\', \'Trade spend settlement Q3\', \'Intercompany recharge — Snacks Division\'). Supports audit review and financial close commentary.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the journal entry record was created in the system. Distinct from posting_date (accounting effect) and document_date (source document). Used for audit trail and data lineage.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General Ledger account number from the chart of accounts to which the journal entry is posted. Determines the financial statement line (P&L or balance sheet) affected. Drives trial balance, COGS calculation, trade spend accruals, and regulatory reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP internal order number used to collect costs for a specific project, campaign, or temporary cost object (e.g., a new product launch, capital project, or trade promotion). Enables granular cost tracking beyond cost center level for NPD and trade spend management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryType rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Type' ;
    rdfs:comment 'Business classification of the journal entry by its accounting purpose. \'standard\' = regular transaction posting; \'accrual\' = period-end accrual; \'reversal\' = offset of prior posting; \'recurring\' = periodic template-based entry; \'statistical\' = non-financial reporting entry; \'intercompany\' = cross-entity transaction. Drives financial close workflow and EBITDA reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory financial reporting in the country of the legal entity. Enables translation of document-currency amounts to local currency for balance sheet and P&L.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit SAP posting key controlling the debit/credit indicator, account type, and field selection for the journal entry. Standard values include 40 (GL debit), 50 (GL credit), 31 (vendor credit), 21 (vendor debit), 01 (customer debit), 11 (customer credit). Drives account determination and field status.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Period Status' ;
    rdfs:comment 'Status of the fiscal period to which this journal entry belongs at the time of analysis. \'open\' = period accepting postings; \'closed\' = period locked after financial close; \'blocked\' = temporarily restricted; \'future\' = not yet open. Supports period-end close monitoring and financial reporting integrity.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP profit center code identifying the organizational unit responsible for revenue and cost accountability (e.g., a brand, product line, or geographic market). Enables profitability analysis, brand-level P&L, and EBITDA reporting by business unit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the originating source document (e.g., vendor invoice number, purchase order number, sales order number, or EDI transaction reference). Enables cross-referencing between the journal entry and upstream operational documents for audit and reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Accounting document number of the corresponding reversal or reversed document. Populated when reversal_indicator is True (this is the reversal) or when this document has been reversed by another. Enables bidirectional audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal document (True) or an original posting (False). Reversal entries offset prior postings for corrections, accrual reversals, or period-end adjustments. Critical for audit trail integrity and financial close accuracy.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code identifying the business reason for reversing the journal entry (e.g., \'01\'=Reversal in current period, \'02\'=Reversal in next period, \'03\'=Accrual reversal, \'04\'=Error correction). Supports financial close governance and SOX control documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of all credit line item amounts in the document currency for this journal entry. Must equal total_debit_amount for a balanced entry. Used for trial balance validation, financial statement generation, and double-entry integrity checks.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmountLc rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount Lc' ;
    rdfs:comment 'Sum of all credit line item amounts translated to the company code\'s local (functional) currency. Paired with total_debit_amount_lc for local-currency trial balance and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit line item amounts in the document currency for this journal entry. Must equal total_credit_amount for a balanced entry (double-entry bookkeeping). Used for trial balance validation, financial statement generation, and EBITDA reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmountLc rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount Lc' ;
    rdfs:comment 'Sum of all debit line item amounts translated to the company code\'s local (functional) currency. Used for statutory financial reporting, local GAAP compliance, and country-level P&L and balance sheet preparation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Company code of the intercompany trading partner when intercompany_indicator is True. Used for intercompany elimination during group consolidation, transfer pricing documentation, and intercompany reconciliation processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: AP invoices are settled via a specific corporate bank account. Linking ap_invoice to bank_account enables cash flow forecasting, bank reconciliation, and payment run analysis by bank account. The exis' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'The reason code explaining why an invoice has been placed on payment hold (e.g., price variance, quantity variance, quality hold, missing GR, duplicate invoice). Used for dispute management and supplier performance tracking. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|quality_hold|missing_gr|duplicate|missing_po|terms_dispute — promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the invoice was cleared in the AP subledger, confirming full settlement. Used for DPO calculation, working capital reporting, and financial close reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Indicates whether the invoice has been fully cleared (paid and matched), partially cleared, or remains open in the AP subledger. \'reversed\' indicates a posting reversal. Used for AP aging analysis and period-end close.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount available if payment is made by the discount_due_date. Represents the financial benefit of early payment programs. Tracked for ROI analysis of working capital optimization initiatives.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountCaptured rdf:type rdf:Property ;
    rdfs:label 'Discount Captured' ;
    rdfs:comment 'Indicates whether the early payment discount was successfully captured at time of payment. Used to measure discount capture rate KPI and evaluate treasury performance against working capital targets.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The deadline by which payment must be made to capture the early payment discount offered by the vendor (e.g., 2% if paid within 10 days). Used for dynamic discounting and working capital optimization programs.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Calculated from invoice_date and payment_terms_code. Critical for cash flow forecasting and working capital management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Reference' ;
    rdfs:comment 'The EDI transaction identifier for invoices received electronically via EDI 810 (Invoice) transaction set. Used for automated invoice matching, EDI reconciliation, and supplier EDI compliance tracking in F&B procurement.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the invoice before tax deductions and discounts, as stated on the vendor invoice. Part of the MONETARY_TRIPLET required for TRANSACTION_HEADER role. Used for COGS accruals, cash flow forecasting, and working capital analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor\'s invoice document, representing the principal business event date of the invoice. Used for payment terms calculation, aging analysis, and cash flow forecasting. Satisfies BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceText rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Text' ;
    rdfs:comment 'Free-text reference or description field from the vendor invoice or AP clerk entry (SAP BKPF.BKTXT). May contain delivery note numbers, contract references, or service period descriptions. Used for invoice search and dispute resolution.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the AP invoice through the payables workflow. Satisfies LIFECYCLE_STATUS category for TRANSACTION_HEADER role. \'blocked\' indicates a hold pending resolution (price, quantity, or quality discrepancy).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. \'credit_memo\' represents vendor credits for returns or adjustments. \'intercompany\' covers transactions between legal entities within the Food Beverage group. Drives accounting treatment and workflow routing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this invoice is part of a recurring payment schedule (e.g., monthly 3PL service fees, lease payments, SaaS subscriptions). Used for automated accrual management and cash flow forecasting.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The net invoice amount translated to the company code local currency (e.g., USD for US entities) using the exchange rate at posting date. Used for consolidated financial reporting and EBITDA calculation.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Indicates the result of the three-way match process comparing the purchase order, goods receipt, and vendor invoice. \'three_way_matched\' confirms all three documents align within tolerance. Critical for invoice approval and COGS accuracy.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which payment was executed and funds were disbursed to the vendor. Used for Days Payable Outstanding (DPO) calculation, cash flow actuals, and supplier payment compliance reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The SAP FI accounting document number generated when the payment was executed (clearing document). Links the invoice to its payment for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument used to settle this invoice (ACH electronic transfer, wire transfer, check, virtual card, or direct debit). Drives payment run configuration and bank reconciliation processes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI accounting document number assigned upon invoice posting (BKPF.BELNR). Used for cross-referencing with general ledger entries and financial close processes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccount rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'The vendor\'s bank account identifier used for payment execution (masked/tokenized for security). Required for ACH and wire payment processing. Classified as confidential financial data per PCI DSS and internal treasury controls.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number as printed on the vendor\'s invoice document. Used for vendor reconciliation, dispute resolution, and audit trail. Satisfies BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sales Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: The AR invoice is the financial representation of the sales invoice in F&B ERP systems. Linking ar_invoice to sales.invoice enables AR-to-billing reconciliation, dispute resolution, and deduction mana' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:billingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Company Code' ;
    rdfs:comment 'SAP company code of the legal entity issuing the invoice. Required for intercompany reconciliation, statutory reporting, and multi-entity financial consolidation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Externally-known SAP SD billing document number (VBELN) that uniquely identifies this invoice in the source system and on customer-facing documents. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number (AUGBL) assigned when the invoice is fully or partially cleared against a payment or credit memo. Null for open items.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Dollar value of customer-taken deductions against this invoice (e.g., promotional allowances, freight claims, shortage claims). Central to F&B deduction management and trade spend reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Code' ;
    rdfs:comment 'Standardized code classifying the reason for a customer deduction (e.g., promotional allowance, freight claim, shortage, pricing dispute). Enables deduction analytics and recovery tracking. [ENUM-REF-CANDIDATE: promo_allowance|freight_claim|shortage|pricing_dispute|quality_claim|early_pay_discount|other — promote to reference product]' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text or coded description of the reason the customer has disputed this invoice (e.g., pricing discrepancy, quantity shortage, quality issue). Supports root cause analysis and deduction recovery.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any customer dispute raised against this invoice. Enables dispute management workflow tracking and deduction resolution reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP distribution channel code (VTWEG) indicating the route-to-market for this invoice (e.g., wholesale, DSD, e-commerce). Supports channel profitability and trade spend analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice sent to the customer for this invoice. Used to schedule next dunning action and track collections activity.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections escalation) level assigned to this invoice in SAP FI-AR, ranging from 0 (no dunning) to the maximum configured level. Drives collections workflow and customer communication.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Amount' ;
    rdfs:comment 'Monetary value of the cash discount available to the customer if payment is received by the early payment discount date. Used for discount accrual and deduction validation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Date' ;
    rdfs:comment 'Last date by which the customer may pay to qualify for the early payment (cash) discount defined in the payment terms (e.g., the \'10\' in 2/10NET30). Supports cash discount accrual and working capital optimization.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Status' ;
    rdfs:comment 'Transmission status of the invoice via EDI (Electronic Data Interchange) or customer portal. Tracks whether the invoice was successfully delivered electronically to the customer, supporting straight-through processing and dispute prevention.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'Identifier of the bank lockbox processing batch in which this invoice\'s payment was received. Enables reconciliation between bank lockbox files and SAP FI-AR cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice after applying all payments, credits, and deductions. Drives DSO calculation, aging bucket reporting, and dunning level determination.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount of cash received and applied to this invoice. May differ from net_amount due to short payments, deductions, or partial payments.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Document Number' ;
    rdfs:comment 'Customer-provided remittance advice document number accompanying the payment, used to match incoming cash to open invoices during cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in the general ledger per FASB ASC 606 / IFRS 15 five-step model. May differ from invoice_date for consignment, bill-and-hold, or multi-element arrangements.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP sales organization (VKORG) responsible for the sale, defining the selling entity, pricing procedures, and revenue assignment for this invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Short Payment Amount' ;
    rdfs:comment 'Amount by which the customer\'s remittance falls short of the invoiced net amount, excluding valid deductions. Triggers deduction investigation and collections follow-up.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Contractual trade discount applied to the gross invoice amount, reflecting negotiated off-invoice allowances, promotional pricing, or volume rebates. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Base unit of measure for the standard cost (e.g., EA for each, KG for kilogram, LB for pound, CS for case). Must match the material master base UOM for consistency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackingCost rdf:type rdf:Property ;
    rdfs:label 'Co Packing Cost' ;
    rdfs:comment 'Standard cost component for third-party co-packing or toll manufacturing services per unit. Applicable when production is outsourced to contract manufacturers or co-packers.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Change Amount' ;
    rdfs:comment 'Absolute change in standard cost per unit from previous to current period. Positive indicates cost increase; negative indicates cost reduction. Drives inventory revaluation and margin impact analysis.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Change Percentage' ;
    rdfs:comment 'Percentage change in standard cost from previous to current period. Key metric for cost inflation tracking, procurement performance, and pricing strategy decisions.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costComponentStructure rdf:type rdf:Property ;
    rdfs:label 'Cost Component Structure' ;
    rdfs:comment 'Configuration key defining the cost component split schema (e.g., which cost elements roll into raw material, labor, overhead categories). Ensures consistent cost classification across products and plants.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'Unique identifier for the detailed cost estimate calculation that produced this standard cost. Links to the itemized cost roll-up with BOM explosion, routing operations, and overhead allocation details.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Status' ;
    rdfs:comment 'Lifecycle status of the cost estimate. Only released estimates are activated as standard costs for inventory valuation. Created and calculated are preliminary; marked for deletion are superseded.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'Production lot size used as the basis for standard cost calculation. Fixed costs are spread across this quantity. Larger lot sizes reduce per-unit fixed overhead; smaller lots increase it, creating lot-size variance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingVariant rdf:type rdf:Property ;
    rdfs:label 'Costing Variant' ;
    rdfs:comment 'Costing methodology variant used for standard cost calculation (e.g., PPC1 for product costing, PC01 for material ledger). Determines valuation approach, cost component structure, and overhead allocation rules.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'Version number for the standard cost estimate. Allows multiple cost scenarios (current, planned, simulated) to coexist for comparison and what-if analysis before release.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directLaborCost rdf:type rdf:Property ;
    rdfs:label 'Direct Labor Cost' ;
    rdfs:comment 'Standard cost component for direct production labor per unit. Calculated from routing operation times multiplied by labor rates. Includes line operators, batch mixers, and packaging crew.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Fixed Overhead Cost' ;
    rdfs:comment 'Standard cost component for fixed manufacturing overhead per unit. Includes depreciation, plant supervision, property taxes, insurance, and fixed maintenance allocated based on normal capacity utilization.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInCost rdf:type rdf:Property ;
    rdfs:label 'Freight In Cost' ;
    rdfs:comment 'Standard cost component for inbound freight and logistics per unit. Includes transportation of raw materials and packaging to the manufacturing plant, allocated to finished goods.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Cost' ;
    rdfs:comment 'Standard cost component for primary, secondary, and tertiary packaging materials per unit. Includes bottles, cans, cartons, labels, shrink wrap, pallets, and shipping materials.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Price' ;
    rdfs:comment 'Prior period standard cost per unit before the current cost roll. Used to calculate cost change impact, revaluation amounts, and year-over-year cost trend analysis.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Valuation method indicator: S for standard price (predetermined cost), V for moving average price (actual cost). Food and beverage finished goods typically use standard price; raw materials may use moving average.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'Standard cost component for raw materials and ingredients per unit. Derived from BOM (Bill of Materials) quantities multiplied by component standard prices. Largest cost driver in food and beverage manufacturing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the cost estimate was released and activated as the official standard cost. Marks the transition from preliminary to production-ready cost. Critical for audit trail and variance analysis cutover.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasedByUser rdf:type rdf:Property ;
    rdfs:label 'Released By User' ;
    rdfs:comment 'User ID of the cost accountant or controller who released the standard cost estimate. Provides accountability for cost master changes and supports SOX (Sarbanes-Oxley) compliance audit requirements.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Price Per Unit' ;
    rdfs:comment 'Total standard cost per base unit of measure. Used for inventory valuation, COGS (Cost of Goods Sold) calculation, and gross margin reporting. Sum of all cost component splits.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Material valuation class determining GL (General Ledger) account assignment for inventory and COGS postings. Links material type to chart of accounts for financial reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Variable Overhead Cost' ;
    rdfs:comment 'Standard cost component for variable manufacturing overhead per unit. Includes utilities, indirect materials, consumables, and variable maintenance that scale with production volume.' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary value of the variance (actual cost minus standard cost). Positive variance indicates unfavorable (actual higher than standard); negative indicates favorable (actual lower than standard). Aggregated for EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Classification of manufacturing variance type. Price variance: material cost differences. Quantity variance: usage differences. Scrap variance: waste. Mix variance: recipe substitution. Yield variance: output differences. Lot-size variance: volume impact on fixed costs. Overhead variance: absorption differences. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|scrap_variance|mix_variance|yield_variance|lot_size_variance|overhead_variance|resource_usage_variance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinanceStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance amount expressed as a percentage of standard cost. Used for materiality assessment, exception reporting, and operational performance scorecards. Thresholds trigger management review.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The planned budget amount for the specified fiscal period, cost center, and GL account. Represents the financial target or allocation in the budget currency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Categorization of the budget planning approach. ANNUAL = Annual fixed budget, ROLLING = Rolling forecast budget, SUPPLEMENTAL = Additional budget allocation, CONTINGENCY = Reserve or contingency budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by financial category. OPEX = Operating Expenses, CAPEX = Capital Expenditures, REVENUE = Revenue Budget, HEADCOUNT = Workforce Budget, COGS = Cost of Goods Sold, TRADE_SPEND = Trade Promotion and Marketing Spend.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCarryForward rdf:type rdf:Property ;
    rdfs:label 'Is Carry Forward' ;
    rdfs:comment 'Boolean flag indicating whether this budget line represents a carry-forward from a previous fiscal period. True = Carry-forward budget, False = New budget allocation.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Planned quantity associated with the budget (e.g., headcount, production volume, units sold). Used for non-monetary budget planning such as workforce or production capacity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the budget quantity (e.g., FTE for headcount, MT for metric tons, EA for each). Provides context for the budget_quantity field.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Code identifying the version of the budget (e.g., ORIGINAL, REVISED, LE1, LE2, FORECAST). Enables tracking of budget iterations and revisions throughout the fiscal year.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Descriptive name for the budget version (e.g., Original Budget, Q2 Revised Budget, Latest Estimate). Provides human-readable context for the version code.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'High-level business unit or division code (e.g., Snacks, Beverages, Dairy). Used for executive-level reporting and strategic planning.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentary rdf:type rdf:Property ;
    rdfs:label 'Commentary' ;
    rdfs:comment 'Free-text narrative explaining key assumptions, risks, opportunities, or changes from prior forecast. Provides qualitative context for quantitative projections.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Subjective confidence rating assigned by the forecast owner. Indicates reliability and risk associated with the forecast estimate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverType rdf:type rdf:Property ;
    rdfs:label 'Driver Type' ;
    rdfs:comment 'Primary business driver or assumption category underlying the forecast (e.g., volume growth, pricing action, product mix shift, foreign exchange impact). Enables driver-based planning and variance explanation. [ENUM-REF-CANDIDATE: volume|price|mix|fx|inflation|productivity|investment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The date when this forecast version was created or submitted. Represents the as-of date for the forecast snapshot.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record. Tracks progression from draft through approval to publication.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by planning horizon and frequency. Rolling forecasts are continuously updated; annual/quarterly/monthly are fixed-period; reforecast is a mid-cycle update; flash is a rapid preliminary estimate.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Amount' ;
    rdfs:comment 'The projected financial value for this forecast line in the specified currency. Represents the current best estimate of revenue, cost, or profit for the period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCategory rdf:type rdf:Property ;
    rdfs:label 'Gl Account Category' ;
    rdfs:comment 'High-level financial statement line item category for the forecasted amount. Enables aggregation and variance analysis by P&L component. [ENUM-REF-CANDIDATE: revenue|cogs|gross_profit|operating_expense|ebitda|depreciation|ebit|interest|tax|net_income — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the forecast owner for display and reporting purposes.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Amount' ;
    rdfs:comment 'The forecasted amount from the previous forecast version for the same period and account. Enables trend analysis and revision tracking.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the forecast was published to executive dashboards and investor relations. Indicates availability for external guidance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Planning scenario for the forecast (e.g., base case, upside, downside). Supports scenario planning and risk assessment for investor guidance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Budget Amount' ;
    rdfs:comment 'The difference between the forecasted amount and the budget amount (forecasted_amount - budget_amount). Positive values indicate favorable variance for revenue, unfavorable for costs.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast Amount' ;
    rdfs:comment 'The difference between the current forecast and the prior forecast (forecasted_amount - prior_forecast_amount). Tracks forecast revision magnitude.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key for the fixed asset entity. Inferred role: MASTER_RESOURCE.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since the asset was placed in service. Calculated as the sum of all periodic depreciation postings.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date the asset was acquired or placed in service. Used as the starting point for depreciation calculation and useful life tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code that categorizes the asset type (e.g., manufacturing equipment, building, vehicle, IT hardware). Determines depreciation rules, useful life, and GL account assignment in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset, including make, model, capacity, and distinguishing characteristics (e.g., \'High-Speed Bottling Line - Line 3 - 600 BPM\').' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Detailed physical location of the asset within the plant or facility (e.g., \'Production Floor - Line 3 - Bay 12\'). Used for asset tracking, maintenance scheduling, and physical inventory.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique business identifier for the fixed asset, typically assigned by the ERP system (SAP FI-AA asset master number). Used for asset tracking, reporting, and cross-system reference.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Active assets are in service and depreciating; under construction assets are capitalized but not yet depreciating; retired/disposed assets are no longer in use.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical barcode or RFID tag number affixed to the asset for inventory tracking and physical verification during asset audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was capitalized on the balance sheet. May differ from acquisition date for assets under construction (AUC) that are capitalized upon completion.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger account number for accumulated depreciation (contra-asset account, e.g., 1509 - Accumulated Depreciation - Machinery). Used for balance sheet presentation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate periodic depreciation expense. Straight-line is most common for F&B manufacturing assets; units of production may be used for high-utilization equipment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date the asset was physically disposed, sold, or scrapped. May differ from retirement date if there is a lag between decommissioning and disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal (proceeds minus net book value).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Expense Gl Account Code' ;
    rdfs:comment 'General ledger account number for depreciation expense postings (e.g., 6800 - Depreciation Expense). Used for income statement reporting and COGS allocation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized on the asset when its recoverable amount falls below net book value. Recorded as a write-down and reduces the carrying value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'Date the impairment loss was recognized. Triggers adjustment to net book value and may affect future depreciation calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering the asset against loss, damage, or theft. Used for risk management and claims processing.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date the asset was last physically verified during a fixed asset inventory audit. Used to ensure asset register accuracy and compliance with SOX controls.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model or part number for the asset. Used for technical specifications, spare parts identification, and maintenance planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset on the balance sheet, calculated as original cost minus accumulated depreciation. Represents the remaining capitalized value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'Initial acquisition or construction cost of the asset at capitalization, including purchase price, freight, installation, and directly attributable costs. Represents the gross book value before depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Number of years remaining in the assets useful life as of the current reporting period. Calculated as useful life minus elapsed time since capitalization.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date the asset was retired from service or disposed. Triggers final depreciation calculation and removal from active asset register.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Depreciation is calculated on (original cost - salvage value). Often zero for F&B manufacturing equipment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetKey rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Key' ;
    rdfs:comment 'Composite key from SAP FI-AA (company code + asset number + sub-number) used for exact source system reconciliation and traceability.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique equipment identifier for the asset. Used for warranty tracking, maintenance history, and asset verification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected economic useful life of the asset in years, as determined by asset class and business policy. Used to calculate straight-line depreciation rate (1 / useful life).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the vendor or supplier from whom the asset was purchased. Used for vendor performance tracking and warranty claims.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty expires. Used to determine whether repairs are covered under warranty or must be expensed.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Posting Status' ;
    rdfs:comment 'Posting authorization status for asset account types (fixed assets, depreciation). Controls whether asset transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Boolean flag indicating whether detailed audit logging is enabled for all transactions posted in this fiscal period for compliance and forensic purposes.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceSheetReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Reconciliation Status' ;
    rdfs:comment 'Status of balance sheet account reconciliation process for this period, ensuring all balance sheet accounts are substantiated and reconciled to sub-ledgers.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Blocked Close Tasks' ;
    rdfs:comment 'Count of close tasks that are currently blocked due to unmet dependencies or issues requiring resolution.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeActualDate rdf:type rdf:Property ;
    rdfs:label 'Close Actual Date' ;
    rdfs:comment 'The actual calendar date when the financial close process was completed and certified.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeCycleName rdf:type rdf:Property ;
    rdfs:label 'Close Cycle Name' ;
    rdfs:comment 'Descriptive name of the financial close cycle for this period (e.g., January 2024 Close, Q1 2024 Close, FY2024 Year-End Close).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDelayDays rdf:type rdf:Property ;
    rdfs:label 'Close Delay Days' ;
    rdfs:comment 'Number of calendar days by which the close process exceeded the target date. Zero or negative if close was on time or early.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeSlaMet rdf:type rdf:Property ;
    rdfs:label 'Close Sla Met' ;
    rdfs:comment 'Boolean indicator of whether the close process met the target SLA (True if actual close date is on or before target date, False otherwise).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeStartDate rdf:type rdf:Property ;
    rdfs:label 'Close Start Date' ;
    rdfs:comment 'The calendar date when the financial close process for this period was initiated.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Overall status of the period-end close process: not_started (close not initiated), in_progress (tasks underway), complete (all tasks finished), certified (final sign-off and SOX attestation complete).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTargetDate rdf:type rdf:Property ;
    rdfs:label 'Close Target Date' ;
    rdfs:comment 'The planned target date by which the financial close process should be completed, per the close calendar and SLA (Service Level Agreement).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Completed Close Tasks' ;
    rdfs:comment 'Count of close tasks that have been marked as complete for this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Status' ;
    rdfs:comment 'Status of cost center and internal order allocation cycles (assessment, distribution, overhead allocation) for this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRunStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Status' ;
    rdfs:comment 'Status of the periodic depreciation calculation and posting run for fixed assets in this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expensePostingStatus rdf:type rdf:Property ;
    rdfs:label 'Expense Posting Status' ;
    rdfs:comment 'Posting authorization status for expense account types (COGS, operating expenses). Controls whether expense transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Status' ;
    rdfs:comment 'Status of financial statement preparation and approval workflow for this period: not_started, draft (in preparation), review (under management review), approved (signed off), published (externally released).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year. Regular periods are 1-12; special adjustment periods are 13-16 for year-end close activities.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Reconciliation Status' ;
    rdfs:comment 'Status of intercompany transaction reconciliation for this period: not_started, in_progress, reconciled (balanced), or variance (unresolved differences requiring investigation).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Liability Posting Status' ;
    rdfs:comment 'Posting authorization status for liability account types (accounts payable, accrued expenses). Controls whether liability transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Overall status of the fiscal period controlling whether any posting activity is allowed: not_opened (future period), open (active posting), closed (period-end complete), locked (archived, no changes).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the fiscal period: regular (monthly operating periods 1-12), special (adjustment periods 13-16), year_end (final close period), or opening (initial balance period).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAuthorityOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Posting Authority Override Allowed' ;
    rdfs:comment 'Boolean flag indicating whether authorized users can override posting restrictions for this period (typically False for closed periods to maintain data integrity).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleController rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller' ;
    rdfs:comment 'Name or identifier of the financial controller or accounting manager responsible for overseeing the close process for this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Status' ;
    rdfs:comment 'Posting authorization status for revenue account types (sales revenue, other income). Controls whether revenue transactions can be posted in this period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The calendar date when the sign-off owner provided final certification for this fiscal period close.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffOwner rdf:type rdf:Property ;
    rdfs:label 'Sign Off Owner' ;
    rdfs:comment 'Name or identifier of the executive (CFO, Controller, VP Finance) who provides final certification and sign-off for this fiscal period close.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Status' ;
    rdfs:comment 'Status of SOX internal control certification for this period: not_required (non-SOX entity), pending (awaiting sign-off), certified (controls attested), exception (control deficiency identified).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCloseTasks rdf:type rdf:Property ;
    rdfs:label 'Total Close Tasks' ;
    rdfs:comment 'Total count of close tasks defined for this fiscal period across all task types and responsible teams.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique identifier for the tax transaction record. Primary key for the tax_record product.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reverseChargeIndicator rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction is subject to reverse charge VAT mechanism, where the buyer (not the seller) accounts for VAT. True if reverse charge applies, False otherwise.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The tax amount converted to the company code local currency using the exchange rate. Used for statutory tax reporting and consolidation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the tax authority or regulatory body to which this tax is remitted. Examples: IRS (US), HMRC (UK), Bundeszentralamt für Steuern (Germany), Direction Générale des Finances Publiques (France).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Tax Document Date' ;
    rdfs:comment 'The date of the source document (invoice date, receipt date) that triggered the tax transaction. Used for tax point determination and VAT reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'The unique document number assigned to this tax transaction in the source ERP system (SAP FI tax module). This is the externally-known identifier for audit and reconciliation purposes.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The certificate or authorization number issued by the tax authority granting exemption for this transaction. Required for audit trail when tax_exemption_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction qualifies for tax exemption under applicable regulations. True if exempt, False otherwise. Examples: export sales (zero-rated VAT), essential food items (sales tax exempt).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason Code' ;
    rdfs:comment 'The code representing the legal basis for tax exemption. Examples: EXP (export), ESS (essential goods), RES (resale), GOV (government entity). Populated only when tax_exemption_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Line Item Number' ;
    rdfs:comment 'Line item sequence number within the parent financial document, distinguishing multiple tax postings on a single invoice or journal entry.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxPostingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Date' ;
    rdfs:comment 'The date on which the tax transaction was posted to the general ledger. This is the accounting date for tax liability or receivable recognition.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate applied to the taxable base amount, expressed as a percentage. Examples: 20.00 (UK VAT standard rate), 19.00 (German VAT), 5.50 (reduced rate), 0.00 (zero-rated).' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'The company code tax registration number or VAT identification number registered with the tax authority. Examples: VAT number (EU), EIN (US), GST number (India). Business-confidential identifier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The tax authority reporting period to which this transaction belongs. Format varies by jurisdiction: YYYY-MM (monthly VAT), YYYY-QQ (quarterly sales tax), YYYY (annual excise duty). Examples: 2024-03, 2024-Q1, 2024.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current lifecycle status of the tax transaction. Posted: initial posting complete. Cleared: tax liability settled or input tax recovered. Reversed: transaction reversed due to credit note or correction. Adjusted: manual adjustment applied. Under_audit: flagged for tax authority audit. Disputed: under dispute with tax authority.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax transaction by tax category: input VAT (recoverable tax on purchases), output VAT (tax collected on sales), sales tax, excise duty (alcohol, tobacco, fuel), sugar levy (sugar content tax on beverages), customs duty, withholding tax, use tax, or reverse charge VAT. [ENUM-REF-CANDIDATE: input_vat|output_vat|sales_tax|excise_duty|sugar_levy|customs_duty|withholding_tax|use_tax|reverse_charge — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The net amount on which the tax is calculated, before tax is applied. This is the invoice line total or cost base subject to taxation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany tax transactions. Populated only when intercompany_indicator is True.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.product_hierarchy. Business justification: Each SKU belongs to a node in the product hierarchy, enabling classification and reporting. Adding product_hierarchy_id FK eliminates redundant category fields.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Required for SKU-level supplier assignment used in sourcing decisions, cost modeling, and supplier scorecard reporting.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:abv rdf:type rdf:Property ;
    rdfs:label 'Abv' ;
    rdfs:comment 'Alcohol by volume percentage for alcoholic beverage products. Null for non-alcoholic products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenMatrix rdf:type rdf:Property ;
    rdfs:label 'Allergen Matrix' ;
    rdfs:comment 'Comprehensive list of major food allergens present in or potentially cross-contaminating the product (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brixTarget rdf:type rdf:Property ;
    rdfs:label 'Brix Target' ;
    rdfs:comment 'Target Brix measurement representing sugar content percentage for beverages and fruit products. Used for quality control and formulation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caloriesPerServing rdf:type rdf:Property ;
    rdfs:label 'Calories Per Serving' ;
    rdfs:comment 'Total caloric content per serving as declared on the nutritional panel.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit European Article Number barcode identifier used internationally for retail product identification.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flavorVariety rdf:type rdf:Property ;
    rdfs:label 'Flavor Variety' ;
    rdfs:comment 'Specific flavor, variety, or variant of the product (e.g., Original, Chocolate, Strawberry, Spicy, Mild).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form and preparation state of the product (Ready to Eat, Ready to Drink, Concentrate, Powder, Frozen, Refrigerated, Shelf Stable, Fresh). [ENUM-REF-CANDIDATE: ready to eat|ready to drink|concentrate|powder|frozen|refrigerated|shelf stable|fresh — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glutenFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Flag' ;
    rdfs:comment 'Indicates whether the product meets gluten-free labeling requirements (less than 20 ppm gluten).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether the product is certified halal by a recognized halal certification body.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether the product is certified kosher by a recognized kosher certification agency.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netVolume rdf:type rdf:Property ;
    rdfs:label 'Net Volume' ;
    rdfs:comment 'Net volume of the product contents for liquid or pourable products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Net weight of the product contents excluding packaging.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonGmoFlag rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Flag' ;
    rdfs:comment 'Indicates whether the product is verified as non-genetically modified organism (Non-GMO Project Verified or equivalent).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Primary packaging format and material (e.g., Bottle, Can, Pouch, Box, Bag, Jar, Tray, Carton).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phMax rdf:type rdf:Property ;
    rdfs:label 'Ph Max' ;
    rdfs:comment 'Maximum acceptable pH level (acidity measure) for the product. Critical for food safety and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMin rdf:type rdf:Property ;
    rdfs:label 'Ph Min' ;
    rdfs:comment 'Minimum acceptable pH level (acidity measure) for the product. Critical for food safety and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmStage rdf:type rdf:Property ;
    rdfs:label 'Plm Stage' ;
    rdfs:comment 'Current stage in the Product Lifecycle Management process (Concept, Development, Validation, Commercialization, Growth, Maturity, Decline). [ENUM-REF-CANDIDATE: concept|development|validation|commercialization|growth|maturity|decline — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the product including key features, ingredients, and usage occasions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Product line or sub-brand classification within the brand portfolio (e.g., Premium, Organic, Kids, Family Size).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Full marketing name of the finished good product as it appears on packaging and in consumer-facing materials.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the SKU (Active, Discontinued, On Hold, Seasonal, Pending Launch, Phase Out).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether the primary packaging is recyclable through standard municipal recycling programs.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servingSize rdf:type rdf:Property ;
    rdfs:label 'Serving Size' ;
    rdfs:comment 'Standard serving size as declared on the nutritional panel with unit of measure (e.g., 1 cup (240ml), 28g, 1 bottle).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingsPerContainer rdf:type rdf:Property ;
    rdfs:label 'Servings Per Container' ;
    rdfs:comment 'Number of servings contained in the package as declared on the nutritional panel.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Business identifier code for the SKU used across systems and operations. Alphanumeric code typically 6-20 characters.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMax rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max' ;
    rdfs:comment 'Maximum storage temperature in Celsius required to maintain product quality and safety.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMin rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min' ;
    rdfs:comment 'Minimum storage temperature in Celsius required to maintain product quality and safety.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code barcode identifier used primarily in North America for retail scanning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veganFlag rdf:type rdf:Property ;
    rdfs:label 'Vegan Flag' ;
    rdfs:comment 'Indicates whether the product contains no animal-derived ingredients or by-products.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vegetarianFlag rdf:type rdf:Property ;
    rdfs:label 'Vegetarian Flag' ;
    rdfs:comment 'Indicates whether the product is suitable for vegetarian diets (no meat, poultry, fish, or slaughter by-products).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentNodeHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Hierarchy Id' ;
    rdfs:comment 'Reference to the parent node in the hierarchy structure. Null for top-level Division nodes. Enables recursive hierarchy traversal and roll-up reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:allergenCategory rdf:type rdf:Property ;
    rdfs:label 'Allergen Category' ;
    rdfs:comment 'High-level allergen classification for products in this hierarchy node (e.g., \'Contains Dairy\', \'Gluten-Free\', \'Nut-Free Facility\'). Used for allergen matrix management and regulatory labeling compliance. [ENUM-REF-CANDIDATE: contains_milk|contains_eggs|contains_fish|contains_shellfish|contains_tree_nuts|contains_peanuts|contains_wheat|contains_soybeans|allergen_free — promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwner rdf:type rdf:Property ;
    rdfs:label 'Brand Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the brand or product line represented by this hierarchy node. Used for financial reporting, royalty tracking, and portfolio management.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCaptainFlag rdf:type rdf:Property ;
    rdfs:label 'Category Captain Flag' ;
    rdfs:comment 'Indicates whether this brand or product line holds category captain status with key retail partners. Category captains lead category management initiatives and planogram optimization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Strategy' ;
    rdfs:comment 'Primary distribution channel strategy for products in this hierarchy node. Retail includes grocery and mass merchandisers; DSD is Direct Store Delivery; foodservice includes restaurants and institutions; ecommerce includes online retail; convenience includes c-stores and gas stations; club includes warehouse clubs; natural includes natural/organic specialty stores. [ENUM-REF-CANDIDATE: retail|foodservice|dsd|ecommerce|convenience|club|natural|specialty — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depth rdf:type rdf:Property ;
    rdfs:label 'Depth' ;
    rdfs:comment 'Numeric depth of this node in the hierarchy tree, with Division=1, Category=2, etc. Used for hierarchy navigation and reporting level filtering.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of this hierarchy node. Active nodes are in use for classification and reporting; inactive nodes are historical; pending nodes are planned but not yet launched; discontinued nodes represent retired product lines.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationPlatformFlag rdf:type rdf:Property ;
    rdfs:label 'Innovation Platform Flag' ;
    rdfs:comment 'Indicates whether this hierarchy node represents an innovation platform for New Product Development (NPD). Innovation platforms receive priority for R&D investment and accelerated commercialization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iriCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iri Category Code' ;
    rdfs:comment 'IRI syndicated data category code mapping for this hierarchy node. Enables integration with IRI panel data and assortment analytics. Aligns with IRI category taxonomy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelCode rdf:type rdf:Property ;
    rdfs:label 'Level Code' ;
    rdfs:comment 'Code indicating the level of this node within the product hierarchy structure. Defines whether this node represents a Division, Category, Sub-Category, Brand, Sub-Brand, Product Line, Variant, or Pack Size. [ENUM-REF-CANDIDATE: DIVISION|CATEGORY|SUBCATEGORY|BRAND|SUBBRAND|PRODUCTLINE|VARIANT|PACKSIZE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this hierarchy node record. Used for audit trail and accountability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Category Code' ;
    rdfs:comment 'Nielsen syndicated data category code mapping for this hierarchy node. Enables integration with Nielsen market tracking data and competitive benchmarking. Aligns with Nielsen category taxonomy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Detailed description of this hierarchy node, including its scope, purpose, and business context within the product portfolio.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full hierarchical path from root to this node, typically formatted as slash-delimited string (e.g., \'/Beverages/RTD/Premium Cola/Diet/12oz\'). Enables efficient ancestor queries and reporting roll-ups.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Tier' ;
    rdfs:comment 'Strategic portfolio classification for this hierarchy node. Core brands receive sustained investment; growth brands receive accelerated investment; emerging brands are in test-and-learn phase; harvest brands are managed for cash flow; divest brands are planned for exit.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'FDA or USDA regulatory category for products in this hierarchy node (e.g., \'Conventional Food\', \'Dietary Supplement\', \'Meat Product\', \'Beverage - Non-Alcoholic\'). Determines applicable regulatory requirements and labeling standards.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort sequence for displaying this node among its siblings at the same hierarchy level. Used for consistent ordering in reports, planograms, and user interfaces.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether products under this hierarchy node carry third-party sustainability certifications (Rainforest Alliance, Fair Trade, B Corp, etc.). Used for ESG reporting and marketing claims.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.routing. Business justification: In F&B ERP/MES (SAP, Oracle), BOM and Routing are the two master data objects that together define how to manufacture a product. BOM defines WHAT materials are needed; Routing defines HOW and WHERE to' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Comma-separated list of major food allergens present in this formulation. Derived from ingredient specifications and used for labeling compliance. Examples: milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The standard batch size or production quantity for which this BOM is defined. All ingredient quantities in the BOM line items are expressed relative to this base quantity. Typically represents one production batch or one unit of finished good.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMaximum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Maximum' ;
    rdfs:comment 'The largest production batch size that can be manufactured using this BOM. Driven by equipment capacity, mixing vessel size, or quality control limits.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Minimum' ;
    rdfs:comment 'The smallest production batch size that can be manufactured using this BOM. Driven by equipment constraints, minimum order quantities (MOQ) for ingredients, or quality requirements.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, externally known and used across manufacturing, procurement, and quality systems. Unique within the manufacturing site or globally depending on business rules.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Draft BOMs are under development, pending approval BOMs are awaiting PLM or quality sign-off, approved BOMs have passed review, active BOMs are in production use, inactive BOMs are temporarily suspended, and obsolete BOMs are retired.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM based on its manufacturing context. Production BOMs are for standard in-house manufacturing, co-pack BOMs are for third-party co-packing arrangements, toll manufacturing BOMs are for contract manufacturing, rework BOMs are for reprocessing, sample BOMs are for R&D samples, and trial BOMs are for new product development trials.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsGmoFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Gmo Flag' ;
    rdfs:comment 'Indicates whether this formulation contains genetically modified ingredients. Used for labeling compliance and consumer transparency.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Amount' ;
    rdfs:comment 'Estimated cost of goods sold (COGS) for producing one base quantity of this BOM. Calculated from ingredient costs, packaging costs, and manufacturing overhead. Used for pricing, margin analysis, and product profitability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost estimate amount. Typically the local currency of the manufacturing plant.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Critical Flag' ;
    rdfs:comment 'Indicates whether this BOM contains HACCP critical control points that require monitoring and documentation during production. Used for food safety management and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plm Approval Date' ;
    rdfs:comment 'The date when the BOM received final PLM approval. Nullable for BOMs that have not yet been approved.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Plm Approval Status' ;
    rdfs:comment 'Approval status from the PLM system indicating whether this BOM has passed cross-functional review by R&D, quality, regulatory, and operations teams. Required before a BOM can be activated for production.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this formulation requires pre-market regulatory approval or notification before production and sale. Applicable for novel ingredients, health claims, or regulated product categories.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date when this BOM revision was created or last modified. Used for audit trails and change tracking.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version identifier for the BOM. Incremented each time the formulation is changed. Supports traceability and change history for regulatory compliance and quality management.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the finished product to maintain quality and safety throughout its shelf life. Examples: ambient, refrigerated 2-8C, frozen below -18C, protect from light, keep dry.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Expected production yield as a percentage of input materials. Accounts for normal manufacturing losses, evaporation, spillage, and waste. Used for material planning and cost calculations. A yield of 95.00 means 95% of input materials result in finished product.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:primaryBomSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Supplier Id' ;
    rdfs:comment 'Foreign key reference to the primary or preferred supplier for this component, used for procurement planning and vendor management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Specific allergen classification if critical_allergen_flag is true (e.g., milk, eggs, peanuts, tree nuts, soy, wheat, fish, shellfish, sesame). Multiple allergens separated by semicolon.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'The base unit of measure for the component quantity (e.g., KG, LB, L, GAL, EA, M, FT).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line (active, inactive, pending approval, obsolete).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'The engineering change order or product lifecycle management (PLM) change number that authorized this BOM line modification, used for traceability and compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCategory rdf:type rdf:Property ;
    rdfs:label 'Component Category' ;
    rdfs:comment 'Classification of the component type within the BOM structure (e.g., raw material, ingredient, packaging, label, co-product). [ENUM-REF-CANDIDATE: raw_material|ingredient|flavoring|preservative|packaging|label|co_product|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the component cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Standard cost per base unit of measure for this component, used for Cost of Goods Sold (COGS) calculation and variance analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalAllergenFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or is derived from a major food allergen (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame) requiring allergen matrix tracking and labeling compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this component is classified as a hazardous material requiring special handling, storage, and disposal procedures.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before production start that this component must be available, used for procurement planning and scheduling.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeMultiple rdf:type rdf:Property ;
    rdfs:label 'Lot Size Multiple' ;
    rdfs:comment 'The lot size increment in which this component must be ordered (e.g., multiples of 100 units), used for procurement planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPerBaseUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Base Uom' ;
    rdfs:comment 'The quantity of this component required to produce one unit of the parent finished good, expressed in the base unit of measure.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'The expected scrap or waste percentage for this component during production, used to adjust procurement quantities.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition for this component (e.g., ambient, refrigerated, frozen, controlled temperature, dry) to maintain quality and safety.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Factor Percent' ;
    rdfs:comment 'The expected yield percentage for this component, representing the usable output relative to input quantity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Standard production batch size for this formulation in kilograms or liters. Used for scaling ingredient quantities and production planning.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit' ;
    rdfs:comment 'Unit of measure for batch size: kg (kilogram), L (liter), gal (gallon), lb (pound).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Clean Label Compliant Flag' ;
    rdfs:comment 'Indicates whether this formulation meets clean label criteria (no artificial ingredients, preservatives, or additives). True if compliant, False otherwise.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingTemperature rdf:type rdf:Property ;
    rdfs:label 'Cooling Temperature' ;
    rdfs:comment 'Target cooling temperature in degrees Celsius after thermal processing. Critical for product safety and quality preservation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this formulation specification. Used across R&D, PLM, and manufacturing systems.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable name or title of the formulation specification. Typically includes product name and variant descriptor.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Status' ;
    rdfs:comment 'Current lifecycle status of the formulation: draft (in development), under_review (pending approval), approved (ready for use), active (in production), obsolete (no longer used), superseded (replaced by newer version).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Classification of the formulation stage: bench (lab-scale R&D), pilot (pilot plant trial), commercial (approved for production), experimental (early research), prototype (concept validation), scale_up (transitioning to commercial scale).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingTime rdf:type rdf:Property ;
    rdfs:label 'Holding Time' ;
    rdfs:comment 'Required holding time in minutes at specified temperature or condition before next processing step. Critical for chemical reactions, flavor development, or safety.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homogenizationPressure rdf:type rdf:Property ;
    rdfs:label 'Homogenization Pressure' ;
    rdfs:comment 'Target homogenization pressure in pounds per square inch (PSI) for emulsion stability and particle size reduction. Critical for dairy and beverage products.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingSpeed rdf:type rdf:Property ;
    rdfs:label 'Mixing Speed' ;
    rdfs:comment 'Target mixing speed in revolutions per minute (RPM) for blending operations. Critical for achieving proper dispersion and emulsification.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingTime rdf:type rdf:Property ;
    rdfs:label 'Mixing Time' ;
    rdfs:comment 'Required mixing or blending time in minutes to achieve homogeneous formulation. Critical process parameter for quality consistency.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentTarget rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Target' ;
    rdfs:comment 'Target moisture content as percentage of total weight. Critical for shelf life, texture, and microbial stability in dry and semi-moist products.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pasteurizationTemperature rdf:type rdf:Property ;
    rdfs:label 'Pasteurization Temperature' ;
    rdfs:comment 'Target pasteurization temperature in degrees Celsius for thermal processing. Critical control point (CCP) under HACCP for pathogen elimination.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pasteurizationTime rdf:type rdf:Property ;
    rdfs:label 'Pasteurization Time' ;
    rdfs:comment 'Target pasteurization hold time in seconds at specified temperature. Critical control point (CCP) under HACCP for achieving required lethality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory approval was granted for this formulation. Required for compliance tracking and audit trails.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary regulatory authority that approved this formulation: FDA (US Food and Drug Administration), USDA (US Department of Agriculture), EFSA (European Food Safety Authority), FSANZ (Food Standards Australia New Zealand), Health_Canada, ANVISA (Brazil).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBrix rdf:type rdf:Property ;
    rdfs:label 'Target Brix' ;
    rdfs:comment 'Target sugar content measurement in degrees Brix for this formulation. Critical quality parameter for beverages and sweet products. Measured as percentage of dissolved solids.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhMax rdf:type rdf:Property ;
    rdfs:label 'Target Ph Max' ;
    rdfs:comment 'Maximum acceptable pH (acidity/alkalinity) level for this formulation. Critical for food safety, shelf life, and organoleptic properties. Scale 0-14.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhMin rdf:type rdf:Property ;
    rdfs:label 'Target Ph Min' ;
    rdfs:comment 'Minimum acceptable pH (acidity/alkalinity) level for this formulation. Critical for food safety, shelf life, and organoleptic properties. Scale 0-14.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetViscosity rdf:type rdf:Property ;
    rdfs:label 'Target Viscosity' ;
    rdfs:comment 'Target viscosity measurement for this formulation in centipoise (cP). Critical for product texture, mouthfeel, and processing characteristics.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityUnit rdf:type rdf:Property ;
    rdfs:label 'Viscosity Unit' ;
    rdfs:comment 'Unit of measure for viscosity specification: cP (centipoise), mPa·s (millipascal-second), Pa·s (pascal-second).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterActivityAw rdf:type rdf:Property ;
    rdfs:label 'Water Activity Aw' ;
    rdfs:comment 'Target water activity (Aw) level for this formulation. Scale 0.0-1.0. Critical food safety parameter controlling microbial growth. Values below 0.85 inhibit most pathogens.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addedSugarsDvPercent rdf:type rdf:Property ;
    rdfs:label 'Added Sugars Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for added sugars per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addedSugarsGrams rdf:type rdf:Property ;
    rdfs:label 'Added Sugars Grams' ;
    rdfs:comment 'Added sugar content per serving, expressed in grams. Required under updated FDA regulations (2016+).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenStatement rdf:type rdf:Property ;
    rdfs:label 'Allergen Statement' ;
    rdfs:comment 'Full allergen declaration statement as it appears on the nutritional panel or label (e.g., Contains: Milk, Soy, Wheat). Critical for food safety and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calciumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Calcium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for calcium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calciumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Calcium Milligrams' ;
    rdfs:comment 'Calcium content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caloriesFromFat rdf:type rdf:Property ;
    rdfs:label 'Calories From Fat' ;
    rdfs:comment 'Calories derived from fat per serving. Required in some jurisdictions (e.g., older FDA format), optional in others.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cholesterolDvPercent rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for cholesterol per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cholesterolMilligrams rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Milligrams' ;
    rdfs:comment 'Cholesterol content per serving, expressed in milligrams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dietaryFiberDvPercent rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for dietary fiber per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dietaryFiberGrams rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber Grams' ;
    rdfs:comment 'Dietary fiber content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the FDA submission or notification associated with this nutritional panel. Critical for FSMA compliance and audit trail.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientStatement rdf:type rdf:Property ;
    rdfs:label 'Ingredient Statement' ;
    rdfs:comment 'Full ingredient list as it appears on the nutritional panel or label, in descending order of predominance by weight.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironDvPercent rdf:type rdf:Property ;
    rdfs:label 'Iron Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for iron per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMilligrams rdf:type rdf:Property ;
    rdfs:label 'Iron Milligrams' ;
    rdfs:comment 'Iron content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Reference' ;
    rdfs:comment 'Reference number or identifier for the third-party laboratory analysis report that substantiates the nutritional values declared on this panel.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monounsaturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Monounsaturated Fat Grams' ;
    rdfs:comment 'Monounsaturated fat content per serving, expressed in grams. Voluntary declaration in most jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelFormatStandard rdf:type rdf:Property ;
    rdfs:label 'Panel Format Standard' ;
    rdfs:comment 'The regulatory format standard that this nutritional panel follows (e.g., FDA Nutrition Facts, EU Nutrition Declaration, Health Canada Nutrition Facts).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the nutritional panel record (draft, pending approval, approved, active, superseded, retired).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelVersion rdf:type rdf:Property ;
    rdfs:label 'Panel Version' ;
    rdfs:comment 'Version number of the nutritional panel to track changes over time due to formulation updates or regulatory changes. Format: major.minor (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyunsaturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Polyunsaturated Fat Grams' ;
    rdfs:comment 'Polyunsaturated fat content per serving, expressed in grams. Voluntary declaration in most jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Potassium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for potassium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Potassium Milligrams' ;
    rdfs:comment 'Potassium content per serving, expressed in milligrams. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinDvPercent rdf:type rdf:Property ;
    rdfs:label 'Protein Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for protein per serving. Optional unless a protein claim is made.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinGrams rdf:type rdf:Property ;
    rdfs:label 'Protein Grams' ;
    rdfs:comment 'Protein content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Country or regulatory jurisdiction for which this nutritional panel is formatted and compliant. Uses ISO 3166-1 alpha-3 country codes. [ENUM-REF-CANDIDATE: USA|CAN|MEX|BRA|GBR|DEU|FRA|ITA|ESP|AUS|JPN|CHN|IND — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'The rounding methodology applied to nutritional values per regulatory requirements (e.g., FDA Standard, EU Standard, Custom).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturatedFatDvPercent rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for saturated fat per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatGrams rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat Grams' ;
    rdfs:comment 'Saturated fat content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSizeGrams rdf:type rdf:Property ;
    rdfs:label 'Serving Size Grams' ;
    rdfs:comment 'Numeric serving size expressed in grams for standardized analysis and comparison across products.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumDvPercent rdf:type rdf:Property ;
    rdfs:label 'Sodium Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for sodium per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Sodium Milligrams' ;
    rdfs:comment 'Sodium content per serving, expressed in milligrams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sugarAlcoholsGrams rdf:type rdf:Property ;
    rdfs:label 'Sugar Alcohols Grams' ;
    rdfs:comment 'Sugar alcohol content per serving, expressed in grams. Voluntary declaration unless a sugar-related claim is made.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateDvPercent rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for total carbohydrate per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateGrams rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate Grams' ;
    rdfs:comment 'Total carbohydrate content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatDvPercent rdf:type rdf:Property ;
    rdfs:label 'Total Fat Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for total fat per serving, based on a 2,000 calorie diet (FDA) or reference intake (EU).' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatGrams rdf:type rdf:Property ;
    rdfs:label 'Total Fat Grams' ;
    rdfs:comment 'Total fat content per serving, expressed in grams.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsGrams rdf:type rdf:Property ;
    rdfs:label 'Total Sugars Grams' ;
    rdfs:comment 'Total sugar content per serving, expressed in grams. Includes naturally occurring and added sugars.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatGrams rdf:type rdf:Property ;
    rdfs:label 'Trans Fat Grams' ;
    rdfs:comment 'Trans fat content per serving, expressed in grams. Must be declared even if no daily value is established.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usdaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Usda Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the USDA submission or approval associated with this nutritional panel, applicable for meat, poultry, and egg products.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminAIu rdf:type rdf:Property ;
    rdfs:label 'Vitamin A Iu' ;
    rdfs:comment 'Vitamin A content per serving, expressed in international units. Voluntary under updated FDA regulations but may be required in other jurisdictions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminCMilligrams rdf:type rdf:Property ;
    rdfs:label 'Vitamin C Milligrams' ;
    rdfs:comment 'Vitamin C content per serving, expressed in milligrams. Voluntary under updated FDA regulations but may be required in other jurisdictions.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDDvPercent rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Dv Percent' ;
    rdfs:comment 'Percentage of the daily value for Vitamin D per serving.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMicrograms rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Micrograms' ;
    rdfs:comment 'Vitamin D content per serving, expressed in micrograms. Mandatory nutrient under updated FDA regulations.' ;
    rdfs:domain ind:NutritionalPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingComplianceId rdf:type rdf:Property ;
    rdfs:label 'Packaging Compliance Id' ;
    rdfs:comment 'Foreign key linking to regulatory.packaging_compliance. Business justification: Packaging compliance verification requires each packaging spec to reference the compliance record for material and recycling regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingCompliance .

ind:barrierProperties rdf:type rdf:Property ;
    rdfs:label 'Barrier Properties' ;
    rdfs:comment 'Description of the packaging barrier characteristics (oxygen barrier, moisture barrier, light barrier, gas barrier) critical for shelf life preservation.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioBasedContentPercent rdf:type rdf:Property ;
    rdfs:label 'Bio Based Content Percent' ;
    rdfs:comment 'Percentage of bio-based or renewable material content in the packaging, supporting clean label and sustainability initiatives.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bpaFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Bpa Free Flag' ;
    rdfs:comment 'Indicates whether the packaging is free from Bisphenol A (BPA), supporting clean label and consumer health claims.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casesPerLayer rdf:type rdf:Property ;
    rdfs:label 'Cases Per Layer' ;
    rdfs:comment 'Number of cases in one horizontal layer on a pallet, used for pallet pattern optimization and warehouse slotting.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childResistantFlag rdf:type rdf:Property ;
    rdfs:label 'Child Resistant Flag' ;
    rdfs:comment 'Indicates whether the packaging meets child-resistant packaging standards per CPSC regulations (applicable for certain products).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure or sealing mechanism (e.g., screw cap, snap lid, pull tab, peel seal, twist-off, cork, pump dispenser).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compostableCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compostable Certified Flag' ;
    rdfs:comment 'Indicates whether the packaging is certified compostable per ASTM D6400 or EN 13432 standards.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Specific form of the packaging container (e.g., bottle, can, pouch, jar, tray, carton, bag, tube).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthMm rdf:type rdf:Property ;
    rdfs:label 'Depth Mm' ;
    rdfs:comment 'Depth of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Diameter of cylindrical packaging containers in millimeters (applicable for bottles, cans, jars).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Ml' ;
    rdfs:comment 'Nominal fill volume of liquid or semi-liquid products in milliliters, as declared on the label.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodContactApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Food Contact Approved Flag' ;
    rdfs:comment 'Indicates whether the packaging material is approved for direct food contact per FDA and EU regulations.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freezerSafeFlag rdf:type rdf:Property ;
    rdfs:label 'Freezer Safe Flag' ;
    rdfs:comment 'Indicates whether the packaging is suitable for freezer storage without material degradation or product quality loss.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossWeightG rdf:type rdf:Property ;
    rdfs:label 'Gross Weight G' ;
    rdfs:comment 'Total weight including product and packaging in grams, used for freight cost calculation and logistics planning.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Height of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelPanelCount rdf:type rdf:Property ;
    rdfs:label 'Label Panel Count' ;
    rdfs:comment 'Number of distinct label panels on the packaging (front, back, side panels) used for regulatory compliance and marketing content.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:layersPerPallet rdf:type rdf:Property ;
    rdfs:label 'Layers Per Pallet' ;
    rdfs:comment 'Number of vertical layers stacked on a standard pallet, used for pallet pattern optimization and transportation planning.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Primary material composition of the packaging component (e.g., PET, HDPE, glass, aluminum, paperboard, flexible film). [ENUM-REF-CANDIDATE: PET|HDPE|LDPE|PP|PS|PVC|glass|aluminum|steel|paperboard|corrugated|flexible_film|multi_layer_laminate|biodegradable — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microwaveSafeFlag rdf:type rdf:Property ;
    rdfs:label 'Microwave Safe Flag' ;
    rdfs:comment 'Indicates whether the packaging is certified safe for microwave heating, relevant for Ready-to-Eat (RTE) products.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightG rdf:type rdf:Property ;
    rdfs:label 'Net Weight G' ;
    rdfs:comment 'Net weight of the product content excluding packaging in grams, as declared on the nutritional panel.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date when this packaging specification was or will be retired from active use.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'Hierarchical level of packaging: primary (consumer unit), secondary (case/carton), tertiary (pallet), or display (shelf-ready packaging).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingSpecStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Spec Status' ;
    rdfs:comment 'Current lifecycle status of the packaging specification in the Product Lifecycle Management (PLM) system.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPattern rdf:type rdf:Property ;
    rdfs:label 'Pallet Pattern' ;
    rdfs:comment 'Description of the case arrangement pattern on the pallet (e.g., column stack, interlocked, pinwheel) for load stability and cube optimization.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletTiHi rdf:type rdf:Property ;
    rdfs:label 'Pallet Ti Hi' ;
    rdfs:comment 'Pallet configuration expressed as Ti (cases per layer) x Hi (layers per pallet), standard logistics notation.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrContentPercent rdf:type rdf:Property ;
    rdfs:label 'Pcr Content Percent' ;
    rdfs:comment 'Percentage of post-consumer recycled material in the packaging, used for sustainability reporting and environmental compliance.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recyclabilityCode rdf:type rdf:Property ;
    rdfs:label 'Recyclability Code' ;
    rdfs:comment 'Resin identification code (1-7) indicating the material recyclability classification per ISO 1043 and local recycling standards.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Unique business identifier for the packaging specification used in Product Lifecycle Management (PLM) and Manufacturing Execution System (MES).' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specVersion rdf:type rdf:Property ;
    rdfs:label 'Spec Version' ;
    rdfs:comment 'Version number of the packaging specification to track revisions and changes over time.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:srpConfiguration rdf:type rdf:Property ;
    rdfs:label 'Srp Configuration' ;
    rdfs:comment 'Configuration type for shelf-ready packaging that allows direct placement on retail shelves without additional unpacking.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidentFlag rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Flag' ;
    rdfs:comment 'Indicates whether the packaging includes tamper-evident features (e.g., safety seal, breakable cap, shrink band) per FDA requirements.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tareWeightG rdf:type rdf:Property ;
    rdfs:label 'Tare Weight G' ;
    rdfs:comment 'Weight of the empty packaging material in grams, used for sustainability reporting and material cost analysis.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsPerCase rdf:type rdf:Property ;
    rdfs:label 'Units Per Case' ;
    rdfs:comment 'Number of consumer units (primary packages) contained in one secondary case or carton.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Width of the packaging container in millimeters, used for logistics cube optimization and planogram design.' ;
    rdfs:domain ind:PackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceleratedTestingFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Testing Flag' ;
    rdfs:comment 'Indicates whether the shelf life was determined using accelerated shelf life testing methods rather than real-time aging studies.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether uninterrupted cold chain (refrigerated or frozen) is required from production through distribution to maintain shelf life and safety.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerDateFormat rdf:type rdf:Property ;
    rdfs:label 'Consumer Date Format' ;
    rdfs:comment 'Format pattern for the consumer-facing date label (e.g., MM/DD/YYYY, DD-MMM-YYYY). Must comply with regional open-dating regulations.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerDateLabelType rdf:type rdf:Property ;
    rdfs:label 'Consumer Date Label Type' ;
    rdfs:comment 'Type of date label printed on consumer packaging. Best By indicates peak quality date, Use By indicates safety date, Sell By is for retailer inventory management, Expires On indicates absolute expiration.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Date Calculation Method' ;
    rdfs:comment 'Method used to calculate the best-by or use-by date. Manufacture_plus_offset adds shelf life days to manufacture date, fixed_calendar uses a predetermined calendar date, batch_specific requires manual entry per batch.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcReceivingStandard rdf:type rdf:Property ;
    rdfs:label 'Dc Receiving Standard' ;
    rdfs:comment 'Specific receiving standard or policy that distribution centers must enforce when accepting this product (e.g., minimum remaining shelf life percentage, temperature verification requirements).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frozenShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Frozen Shelf Life Days' ;
    rdfs:comment 'Shelf life in days when product is stored in frozen conditions. Null if product is not suitable for freezing.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsma204TraceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma 204 Traceability Flag' ;
    rdfs:comment 'Indicates whether this product is subject to FSMA 204 enhanced traceability requirements for foods on the Food Traceability List.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent periodic review of this shelf life specification. Specifications should be reviewed regularly to ensure continued validity.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightSensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Light Sensitivity Flag' ;
    rdfs:comment 'Indicates whether the product is sensitive to light exposure and requires storage in dark or light-protected conditions.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrslDays rdf:type rdf:Property ;
    rdfs:label 'Mrsl Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at the time of shipment to customers or distribution centers. Used to enforce retailer receiving standards (e.g., Walmart 2/3 life remaining policy).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openDatingRegulation rdf:type rdf:Property ;
    rdfs:label 'Open Dating Regulation' ;
    rdfs:comment 'Reference to the specific open-dating regulation that governs date labeling for this product (e.g., state-level US requirements, EU 1169/2011 Article 9). May vary by jurisdiction.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postOpeningShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Post Opening Shelf Life Days' ;
    rdfs:comment 'Number of days the product remains safe and of acceptable quality after the package is opened by the consumer. Null if not applicable or if product is single-serve.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityHoldThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Threshold Days' ;
    rdfs:comment 'Number of days before expiration at which inventory should be placed on quality hold for review or disposition. Used to prevent shipment of short-dated product.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailerComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Retailer Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting specific retailer requirements or compliance considerations (e.g., Walmart 2/3 life remaining policy, Target temperature monitoring requirements).' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationRule rdf:type rdf:Property ;
    rdfs:label 'Rotation Rule' ;
    rdfs:comment 'Inventory rotation method to be applied. FIFO (First In First Out) rotates by receipt date, FEFO (First Expired First Out) rotates by expiration date, LIFO (Last In First Out) is rarely used in food and beverage.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeSpecStatus rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Spec Status' ;
    rdfs:comment 'Current lifecycle status of the shelf life specification. Draft specifications are under development, active specifications are in use, superseded specifications have been replaced by newer versions, and obsolete specifications are no longer valid.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTestingProtocol rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Testing Protocol' ;
    rdfs:comment 'Reference to the laboratory testing protocol or study used to establish the shelf life specification. Links to quality assurance documentation.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of this shelf life specification, incremented when specification parameters change.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Percent' ;
    rdfs:comment 'Maximum relative humidity percentage allowed during storage to prevent product degradation. Null if humidity control is not required.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Min Percent' ;
    rdfs:comment 'Minimum relative humidity percentage required during storage to prevent product degradation. Null if humidity control is not required.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required to maintain product quality and safety throughout shelf life. Exceeding this temperature may compromise product integrity.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain product quality and safety throughout shelf life. Critical for cold chain integrity.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionToleranceHours rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Tolerance Hours' ;
    rdfs:comment 'Maximum number of hours the product can tolerate temperature excursions outside the specified range without compromising safety or quality. Null if no tolerance is allowed.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Life Days' ;
    rdfs:comment 'Total number of days from manufacture date to end of shelf life (best-by or use-by date). Critical for FEFO inventory rotation and retailer compliance.' ;
    rdfs:domain ind:ShelfLifeSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelSpecId rdf:type rdf:Property ;
    rdfs:label 'Label Spec Id' ;
    rdfs:comment 'Unique identifier for the label specification record. Primary key for the label specification entity.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adhesiveType rdf:type rdf:Property ;
    rdfs:label 'Adhesive Type' ;
    rdfs:comment 'Type of adhesive used on the label. Critical for packaging line performance and consumer experience, especially for refrigerated or frozen products.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenWarningText rdf:type rdf:Property ;
    rdfs:label 'Allergen Warning Text' ;
    rdfs:comment 'Mandatory allergen declaration text listing major food allergens present in the product or manufacturing facility. Required by FSMA (Food Safety Modernization Act) and FALCPA (Food Allergen Labeling and Consumer Protection Act).' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Artwork Approval Date' ;
    rdfs:comment 'Date when the label artwork received final approval and was released for production use.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:artworkApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Artwork Approval Status' ;
    rdfs:comment 'Current approval status of the label artwork in the PLM workflow. Tracks progression through legal, regulatory, and quality reviews before production release. [ENUM-REF-CANDIDATE: draft|pending_review|legal_review|regulatory_review|approved|rejected|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkFilePath rdf:type rdf:Property ;
    rdfs:label 'Artwork File Path' ;
    rdfs:comment 'File system path or URI to the approved digital artwork file for this label specification. Used by printing vendors and packaging lines.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'Type of barcode symbology used on the label for product identification and traceability. Must align with retail and supply chain scanning requirements.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeValue rdf:type rdf:Property ;
    rdfs:label 'Barcode Value' ;
    rdfs:comment 'Numeric value encoded in the barcode. Typically the GTIN (Global Trade Item Number), UPC (Universal Product Code), or EAN (European Article Number) for the SKU.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelHeightMm rdf:type rdf:Property ;
    rdfs:label 'Label Height Mm' ;
    rdfs:comment 'Physical height of the label in millimeters. Critical for printing specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Classification of the label by its position and purpose on the product packaging. Determines which regulatory and marketing content is required. [ENUM-REF-CANDIDATE: front_panel|back_panel|nutrition_panel|ingredient_panel|neck_label|cap_label|case_label|pallet_label|promotional_sticker — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version identifier for the label specification. Tracks revisions and updates to label artwork, claims, or regulatory text. Incremented with each approved change.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelWidthMm rdf:type rdf:Property ;
    rdfs:label 'Label Width Mm' ;
    rdfs:comment 'Physical width of the label in millimeters. Critical for printing specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandatoryClaimText rdf:type rdf:Property ;
    rdfs:label 'Mandatory Claim Text' ;
    rdfs:comment 'Legally required text that must appear on the label per regulatory jurisdiction. Includes statements mandated by FDA, USDA, EFSA, or other governing bodies.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Physical address of the manufacturer or distributor. Required on label for consumer contact and regulatory traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuantityStatement rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Statement' ;
    rdfs:comment 'Regulatory-compliant statement of the net quantity of contents in the package. Must include both metric and US customary units where required by jurisdiction.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printVendorCode rdf:type rdf:Property ;
    rdfs:label 'Print Vendor Code' ;
    rdfs:comment 'Identifier for the approved printing vendor responsible for producing this label. Used for vendor management and quality traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeUrl rdf:type rdf:Property ;
    rdfs:label 'Qr Code Url' ;
    rdfs:comment 'URL encoded in the QR code on the label. Typically links to product information, traceability data, or consumer engagement content.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingInstructions rdf:type rdf:Property ;
    rdfs:label 'Recycling Instructions' ;
    rdfs:comment 'Consumer-facing instructions for proper disposal and recycling of the package and label. Required in many jurisdictions for environmental compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Instructions for special handling, storage, or preparation of the product. Examples include refrigeration requirements, shake before use, or heating instructions.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Substrate Material' ;
    rdfs:comment 'Type of material used for the label substrate. Impacts sustainability reporting, recycling instructions, and environmental compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityClaimText rdf:type rdf:Property ;
    rdfs:label 'Sustainability Claim Text' ;
    rdfs:comment 'Marketing claims related to sustainability, environmental impact, or corporate social responsibility. Must be substantiated per FTC (Federal Trade Commission) Green Guides.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copackerTollFee rdf:type rdf:Property ;
    rdfs:label 'Copacker Toll Fee' ;
    rdfs:comment 'Third-party manufacturing fee per unit when production is outsourced to a co-packer or toll manufacturer. Includes processing fee, packaging service, and contract manufacturing markup. Zero for internally manufactured SKUs.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Lifecycle status of the cost record: draft (under development), approved (validated but not yet active), active (currently in use for valuation), superseded (replaced by newer version), or archived (historical record).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Per Unit' ;
    rdfs:comment 'Difference between current standard cost per unit and prior period cost per unit. Positive values indicate cost increases; negative values indicate cost reductions. Key metric for cost management and margin protection.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage change in standard cost per unit compared to prior period. Calculated as (cost_variance_per_unit / prior_period_cost_per_unit) * 100. Used for executive dashboards and cost escalation alerts.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'Identifies the type of cost record: current standard (active production cost), prior year (historical comparison), budget (annual plan), forecast (updated projection), planned (future state), or actual (realized cost). Enables variance analysis and cost trend tracking.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'Inventory valuation method applied to this SKU: standard (predetermined cost), average (moving average), First In First Out (FIFO), Last In First Out (LIFO), or weighted average. Determines how inventory is valued on the balance sheet.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingRunDate rdf:type rdf:Property ;
    rdfs:label 'Costing Run Date' ;
    rdfs:comment 'The date on which the cost estimate was executed and this standard cost was calculated. Supports cost history tracking and regulatory compliance for cost substantiation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Overhead Cost' ;
    rdfs:comment 'Allocated manufacturing overhead per unit including utilities, equipment depreciation, plant supervision, maintenance, quality assurance, and facility costs. Allocated based on cost center rates and activity drivers per Good Manufacturing Practice (GMP) standards.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Total cost of all packaging materials per unit including primary packaging (bottles, pouches, wrappers), secondary packaging (cartons, trays), and tertiary packaging (pallets, shrink wrap). Sourced from BOM packaging line items.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Prior Period Cost Per Unit' ;
    rdfs:comment 'Total standard cost per unit from the previous costing period. Enables period-over-period variance analysis and cost trend tracking for Earnings Before Interest Taxes Depreciation and Amortization (EBITDA) reporting.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardCostPerCase rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost Per Case' ;
    rdfs:comment 'Fully-loaded standard cost per case or shipping unit. Calculated as total_standard_cost_per_unit multiplied by units per case. Primary cost metric for trade promotion Return on Investment (ROI) analysis and Distribution Center (DC) valuation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost Per Unit' ;
    rdfs:comment 'Fully-loaded standard cost per individual unit (e.g., per bottle, per pouch, per bar). Sum of raw material, packaging, direct labor, manufacturing overhead, co-packer fee, and freight-in costs. Used for unit-level profitability analysis and Recommended Selling Price (RSP) calculation.' ;
    rdfs:domain ind:ProductStandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityHaccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Quality Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.haccp_plan. Business justification: Raw material hazard categories are incorporated into HACCP plans; FK supports hazard-based control documentation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:qualitySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Raw material specification management requires linking each raw material to its quality specification for compliance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:allergenEggs rdf:type rdf:Property ;
    rdfs:label 'Allergen Eggs' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from eggs. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenFish rdf:type rdf:Property ;
    rdfs:label 'Allergen Fish' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from fish. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenMilk rdf:type rdf:Property ;
    rdfs:label 'Allergen Milk' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from milk. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenPeanuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Peanuts' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from peanuts. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSesame rdf:type rdf:Property ;
    rdfs:label 'Allergen Sesame' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from sesame. Required for FDA FASTER Act allergen labeling compliance (effective 2023).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenShellfish rdf:type rdf:Property ;
    rdfs:label 'Allergen Shellfish' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from crustacean shellfish. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSoybeans rdf:type rdf:Property ;
    rdfs:label 'Allergen Soybeans' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from soybeans. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTreeNuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Tree Nuts' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from tree nuts. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenWheat rdf:type rdf:Property ;
    rdfs:label 'Allergen Wheat' ;
    rdfs:comment 'Indicates the ingredient contains or is derived from wheat. Required for FDA FALCPA allergen labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by Chemical Abstracts Service to every chemical substance. Critical for regulatory compliance and supplier specifications.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL1 rdf:type rdf:Property ;
    rdfs:label 'Category L1' ;
    rdfs:comment 'Top-level hierarchical category classification (e.g., Dairy, Sweeteners, Proteins, Fats & Oils, Spices & Seasonings). First tier of ingredient taxonomy.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL2 rdf:type rdf:Property ;
    rdfs:label 'Category L2' ;
    rdfs:comment 'Second-level hierarchical category classification providing more granular segmentation within L1 class (e.g., under Dairy: Milk Powders, Whey Products, Cheese Cultures).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryL3 rdf:type rdf:Property ;
    rdfs:label 'Category L3' ;
    rdfs:comment 'Third-level hierarchical category classification providing most specific ingredient type within L2 sub-class (e.g., under Milk Powders: Skim Milk Powder, Whole Milk Powder, Buttermilk Powder).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanLabelEligible rdf:type rdf:Property ;
    rdfs:label 'Clean Label Eligible' ;
    rdfs:comment 'Indicates whether the ingredient meets clean-label criteria (recognizable, simple ingredients without artificial additives). Key attribute for consumer-facing product claims and NPD.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eNumber rdf:type rdf:Property ;
    rdfs:label 'E Number' ;
    rdfs:comment 'EU-assigned code for food additives approved for use in the European Economic Area. Required for EU labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairTradeCertified rdf:type rdf:Property ;
    rdfs:label 'Fair Trade Certified' ;
    rdfs:comment 'Indicates the ingredient has been sourced under fair trade standards, ensuring ethical labor practices and fair compensation to producers.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glutenFree rdf:type rdf:Property ;
    rdfs:label 'Gluten Free' ;
    rdfs:comment 'Indicates the ingredient is free from gluten proteins (wheat, barley, rye, triticale). Required for gluten-free product formulation and FDA gluten-free labeling compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoClassification rdf:type rdf:Property ;
    rdfs:label 'Gmo Classification' ;
    rdfs:comment 'Classification of the ingredients GMO status. Critical for regulatory compliance, labeling requirements, and consumer transparency.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Gmo Verification Method' ;
    rdfs:comment 'Method used to verify the GMO status of the ingredient. Documents the rigor of GMO status validation for compliance and audit purposes.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityPreserved rdf:type rdf:Property ;
    rdfs:label 'Identity Preserved' ;
    rdfs:comment 'Indicates the ingredient has been kept segregated throughout the supply chain to maintain its specific identity characteristics (e.g., non-GMO, organic, specific variety). Critical for premium ingredient sourcing and traceability.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciName rdf:type rdf:Property ;
    rdfs:label 'Inci Name' ;
    rdfs:comment 'Standardized INCI name for the ingredient, used for regulatory labeling and international ingredient identification.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientClass rdf:type rdf:Property ;
    rdfs:label 'Ingredient Class' ;
    rdfs:comment 'High-level classification of the ingredient type. Primary categorical segmentation for procurement, formulation, and regulatory purposes. [ENUM-REF-CANDIDATE: raw material|flavor|preservative|colorant|packaging component|additive|processing aid|nutrient fortification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the raw material in the PLM system. Governs availability for new formulations and procurement authorization.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name of the raw material, additive, flavor, preservative, or packaging component. Primary identity label for business users.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureSensitive rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitive' ;
    rdfs:comment 'Indicates the ingredient is sensitive to moisture and requires special handling or packaging to prevent degradation. Impacts storage, handling, and packaging specifications.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialColors rdf:type rdf:Property ;
    rdfs:label 'No Artificial Colors' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic or artificial color additives. Supports clean-label and natural product positioning.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialFlavors rdf:type rdf:Property ;
    rdfs:label 'No Artificial Flavors' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic or artificial flavor compounds. Critical for natural and clean-label claims.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noArtificialPreservatives rdf:type rdf:Property ;
    rdfs:label 'No Artificial Preservatives' ;
    rdfs:comment 'Indicates the ingredient is free from synthetic preservatives. Supports clean-label and natural product claims.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonGmoProjectVerified rdf:type rdf:Property ;
    rdfs:label 'Non Gmo Project Verified' ;
    rdfs:comment 'Indicates the ingredient has been verified by the Non-GMO Project, the leading third-party verification program for non-GMO products in North America.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertificationBody rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Body' ;
    rdfs:comment 'Name of the organization that issued the organic certification (e.g., USDA, EU Organic, IFOAM). Required for organic claim substantiation and audit trails.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Source origin classification of the raw material. Critical for dietary compliance, allergen management, and clean-label positioning.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantBased rdf:type rdf:Property ;
    rdfs:label 'Plant Based' ;
    rdfs:comment 'Indicates the ingredient is derived from plant sources. Supports plant-based product positioning and consumer trend alignment.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRestrictionProfile rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Profile' ;
    rdfs:comment 'Summary of regulatory restrictions or usage limitations by jurisdiction (e.g., banned in EU, restricted use levels in US, requires warning label in CA). Critical for global product formulation and compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryAppearance rdf:type rdf:Property ;
    rdfs:label 'Sensory Appearance' ;
    rdfs:comment 'Standard sensory profile description for visual appearance characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryAroma rdf:type rdf:Property ;
    rdfs:label 'Sensory Aroma' ;
    rdfs:comment 'Standard sensory profile description for aroma characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryColor rdf:type rdf:Property ;
    rdfs:label 'Sensory Color' ;
    rdfs:comment 'Standard sensory profile description for color characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryFlavor rdf:type rdf:Property ;
    rdfs:label 'Sensory Flavor' ;
    rdfs:comment 'Standard sensory profile description for flavor characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensoryTexture rdf:type rdf:Property ;
    rdfs:label 'Sensory Texture' ;
    rdfs:comment 'Standard sensory profile description for texture and mouthfeel characteristics. Used by sensory panels and quality control for organoleptic evaluation.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegan rdf:type rdf:Property ;
    rdfs:label 'Vegan' ;
    rdfs:comment 'Indicates the ingredient contains no animal-derived components or by-products. Essential for vegan product formulation and certification.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiCertificationId rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Id' ;
    rdfs:comment 'Foreign key linking to regulatory.gfsi_certification. Business justification: GFSI certification (BRC, SQF, FSSC 22000) is a mandatory requirement for supplier approval in F&B. approved_supplier currently stores gfsi_certificate_number, gfsi_certificate_expiry_date, gfsi_certif' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GfsiCertification .

ind:primaryApprovedIngredientRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Ingredient Raw Material Id' ;
    rdfs:comment 'Unique identifier for the approved supplier-ingredient relationship record. Primary key for the approved supplier list entry.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:allergenDeclarationOnFile rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration On File' ;
    rdfs:comment 'Indicates whether a current allergen declaration document is on file for this supplier-ingredient combination. Critical for FSMA compliance and allergen management programs.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis (COA) must be provided with each shipment of this ingredient from this supplier. COAs verify ingredient specifications and quality parameters.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmoStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Status' ;
    rdfs:comment 'The GMO (Genetically Modified Organism) status of the ingredient from this supplier. GMO = contains genetically modified material; Non-GMO = does not contain GMO; Non-GMO Verified = third-party verified; Organic = certified organic (inherently non-GMO).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'The unit of measure for the minimum order quantity, such as kg, lbs, liters, gallons, cases, pallets. Must align with supplier pricing and ordering systems.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUom rdf:type rdf:Property ;
    rdfs:label 'Price Per Uom' ;
    rdfs:comment 'The negotiated price per unit of measure for this ingredient from this supplier. Used for cost estimation and procurement decisions. Business-confidential pricing information.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'The unit of measure basis for the price, such as per kg, per lb, per liter, per case. Must be clearly defined for accurate cost calculations.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reapprovalDueDate rdf:type rdf:Property ;
    rdfs:label 'Reapproval Due Date' ;
    rdfs:comment 'The date by which the supplier must be re-evaluated and re-approved for continued authorization. Ensures periodic review of supplier compliance and quality performance.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierItemCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Code' ;
    rdfs:comment 'The unique item code or SKU (Stock Keeping Unit) that the supplier uses to identify this ingredient in their catalog. Used for purchase orders and supplier communication.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierItemDescription rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Description' ;
    rdfs:comment 'The suppliers description of the ingredient item, which may differ from internal nomenclature. Provides supplier-specific product naming and specification details.' ;
    rdfs:domain ind:ApprovedSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedSkuId rdf:type rdf:Property ;
    rdfs:label 'Consumed Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: FSMA 204 and recall management require tracing ingredient lots to the finished product SKU they were consumed in during production. Role-prefix \'consumed\' distinguishes this from lot\'s own identity — ' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: FSMA traceability: link ingredient lot to sales order to identify which orders contain the lot for recall and compliance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:coaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Document Number' ;
    rdfs:comment 'Document number of the Certificate of Analysis provided by the supplier, containing test results and quality parameters.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Coa Received Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was received from the supplier.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Reason for the current disposition status of the lot (e.g., failed specification, expired, contamination risk).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fefo Sequence Number' ;
    rdfs:comment 'Sequence number used to prioritize lot consumption based on expiry date, ensuring oldest lots are used first.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date when a quality hold or quarantine status was released, allowing the lot to be used in production.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalLotNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Lot Number' ;
    rdfs:comment 'Company-assigned unique lot number for internal traceability and inventory management. Primary business identifier for the lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the ingredient lot indicating its availability for production use.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Organic Certificate Number' ;
    rdfs:comment 'Certificate number from the organic certification body if the lot is organic certified.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current available quantity of the ingredient lot after consumption, adjustments, and reservations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the lot is under quarantine pending quality inspection and approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the ingredient lot was physically received at the plant or distribution center.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional notes, observations, or special handling instructions related to the ingredient lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date when the ingredient lot must be retested to confirm continued compliance with specifications before further use.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'GS1 Serial Shipping Container Code for pallet or container-level traceability in the supply chain.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'Lot or batch number assigned by the supplier, used for backward traceability to supplier production records.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceipt rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt' ;
    rdfs:comment 'Measured temperature of the ingredient lot at the time of receipt, critical for temperature-sensitive materials.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traceabilityLotCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Lot Code' ;
    rdfs:comment 'Extended traceability code used for FSMA compliance, enabling forward and backward traceability through the supply chain.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Status' ;
    rdfs:comment 'Certification status of the supplier at the time this lot was received, indicating compliance with company quality standards.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenId rdf:type rdf:Property ;
    rdfs:label 'Allergen Id' ;
    rdfs:comment 'Primary key for allergen' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allergen .

ind:crossContactRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Cross Contact Risk Level' ;
    rdfs:comment 'Assessment of the risk that the ingredient may be cross-contaminated with the allergen during manufacturing, processing, or transportation. Used to determine may-contain declarations.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationBasis rdf:type rdf:Property ;
    rdfs:label 'Declaration Basis' ;
    rdfs:comment 'The method or source used to determine the allergen status. Indicates whether the declaration is based on ingredient formulation, supplier-provided documentation, laboratory testing, or facility risk assessment.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the allergen declaration record. Tracks the approval workflow and validity state.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'The nature of the allergen declaration indicating whether the allergen is intentionally present, potentially present due to cross-contact, or absent from the ingredient.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitPpm rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Ppm' ;
    rdfs:comment 'The minimum concentration level in parts per million at which the allergen can be reliably detected by the test method. Applicable only when declaration is based on laboratory testing.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The country or regulatory region for which this allergen declaration is applicable. Different jurisdictions have different allergen labeling requirements. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|AUS|NZL|JPN|CHN|BRA|ARG|IND — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement' ;
    rdfs:comment 'The specific precautionary allergen labeling statement to be used on finished goods (e.g., \'May contain traces of peanuts\', \'Processed in a facility that also processes milk\'). Used for label generation.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Equipment Flag' ;
    rdfs:comment 'Indicates whether the ingredient is processed on equipment that is also used for allergen-containing products. True if shared equipment is used, False otherwise.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Facility Flag' ;
    rdfs:comment 'Indicates whether the ingredient is manufactured in a facility that also processes allergen-containing products. True if shared facility, False otherwise.' ;
    rdfs:domain ind:Allergen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'The specific analytical method or protocol used if the allergen declaration is based on laboratory testing (e.g., ELISA, PCR, mass spectrometry). Empty if not lab-tested.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationLineId rdf:type rdf:Property ;
    rdfs:label 'Formulation Line Id' ;
    rdfs:comment 'Primary key for formulation_line' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishedGoodSkuId rdf:type rdf:Property ;
    rdfs:label 'Finished Good Sku Id' ;
    rdfs:comment 'Reference to the finished good or intermediate product SKU that this BOM line contributes to. Enables traceability from raw material to final product.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryFormulationSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Formulation Supplier Id' ;
    rdfs:comment 'Reference to the approved supplier for this ingredient in this formulation. Links to the approved vendor list (AVL) for procurement and traceability.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:additionSequence rdf:type rdf:Property ;
    rdfs:label 'Addition Sequence' ;
    rdfs:comment 'The order in which this ingredient is added within its phase of addition. Ensures proper sequencing for recipe execution and quality control.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier for the BOM formulation. Tracks changes to formulations over time for product lifecycle management (PLM) and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed description of the change made to this BOM line item. Provides context for formulation modifications and supports regulatory documentation.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'The business reason for creating or modifying this BOM line item. Supports change management and audit trail for formulation changes.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAllergen rdf:type rdf:Property ;
    rdfs:label 'Is Allergen' ;
    rdfs:comment 'Indicates whether this ingredient is a declared allergen or contains allergen components. Used for allergen matrix management and labeling compliance.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalIngredient rdf:type rdf:Property ;
    rdfs:label 'Is Critical Ingredient' ;
    rdfs:comment 'Indicates whether this ingredient is critical to product safety, quality, or regulatory compliance. Critical ingredients require enhanced traceability and certificate of analysis (COA) verification.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmo rdf:type rdf:Property ;
    rdfs:label 'Is Gmo' ;
    rdfs:comment 'Indicates whether this ingredient is genetically modified or contains GMO components. Required for clean-label claims and regulatory compliance in certain jurisdictions.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalal rdf:type rdf:Property ;
    rdfs:label 'Is Halal' ;
    rdfs:comment 'Indicates whether this ingredient is halal certified. Supports halal product formulation and labeling for Muslim consumers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosher rdf:type rdf:Property ;
    rdfs:label 'Is Kosher' ;
    rdfs:comment 'Indicates whether this ingredient is kosher certified. Supports kosher product formulation and labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicCertified rdf:type rdf:Property ;
    rdfs:label 'Is Organic Certified' ;
    rdfs:comment 'Indicates whether this ingredient is certified organic. Required for organic product labeling and USDA National Organic Program (NOP) compliance.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemSequence rdf:type rdf:Property ;
    rdfs:label 'Line Item Sequence' ;
    rdfs:comment 'Sequential ordering of the BOM line item within the parent BOM header. Determines the order of ingredient addition in manufacturing processes.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseOfAddition rdf:type rdf:Property ;
    rdfs:label 'Phase Of Addition' ;
    rdfs:comment 'The manufacturing phase or stage at which this ingredient is added to the formulation (e.g., mixing, blending, coating, filling). Critical for manufacturing execution system (MES) scheduling and process control.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerBatch rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Batch' ;
    rdfs:comment 'The quantity of raw material required per production batch of the finished good. Used for material requirements planning (MRP) and cost of goods sold (COGS) calculation.' ;
    rdfs:domain ind:FormulationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalProfileId rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile Id' ;
    rdfs:comment 'Primary key for nutritional_profile' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNutritionalRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Nutritional Raw Material Id' ;
    rdfs:comment 'Foreign key reference to the ingredient master record for which this nutritional profile is defined.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:addedSugarsG rdf:type rdf:Property ;
    rdfs:label 'Added Sugars G' ;
    rdfs:comment 'Added sugar content in grams per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'Date when the nutritional analysis was performed by the laboratory or R&D team.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Analytical Method' ;
    rdfs:comment 'Laboratory analytical method or protocol used to determine the nutritional composition. Examples include AOAC methods, wet chemistry, NIR spectroscopy, or chromatography techniques.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calciumMg rdf:type rdf:Property ;
    rdfs:label 'Calcium Mg' ;
    rdfs:comment 'Calcium content in milligrams per serving size. Essential mineral for bone health and mandatory FDA declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cholesterolMg rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Mg' ;
    rdfs:comment 'Cholesterol content in milligrams per serving size. Required for FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis document that contains the detailed nutritional test results for this ingredient batch or lot.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryFiberG rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber G' ;
    rdfs:comment 'Dietary fiber content in grams per serving size. Includes soluble and insoluble fiber components.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyKcal rdf:type rdf:Property ;
    rdfs:label 'Energy Kcal' ;
    rdfs:comment 'Energy content expressed in kilocalories (kcal) per serving size. Required for FDA Nutrition Facts Panel and EU nutritional declaration.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyKj rdf:type rdf:Property ;
    rdfs:label 'Energy Kj' ;
    rdfs:comment 'Energy content expressed in kilojoules (kJ) per serving size. Required for EU nutritional declaration and optional for FDA labeling.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMg rdf:type rdf:Property ;
    rdfs:label 'Iron Mg' ;
    rdfs:comment 'Iron content in milligrams per serving size. Essential mineral for blood health and mandatory FDA declaration.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the laboratory or testing facility that performed the nutritional analysis. May be internal R&D lab or third-party accredited laboratory.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile Status' ;
    rdfs:comment 'Current lifecycle status of the nutritional profile record. Indicates whether the data is draft, approved for use in finished goods labeling, under regulatory review, expired, or superseded by a newer version.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potassiumMg rdf:type rdf:Property ;
    rdfs:label 'Potassium Mg' ;
    rdfs:comment 'Potassium content in milligrams per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinG rdf:type rdf:Property ;
    rdfs:label 'Protein G' ;
    rdfs:comment 'Protein content in grams per serving size. Essential macronutrient for nutritional labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat G' ;
    rdfs:comment 'Saturated fatty acid content in grams per serving size. Required nutrient declaration for cardiovascular health labeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSizeUom rdf:type rdf:Property ;
    rdfs:label 'Serving Size Uom' ;
    rdfs:comment 'Unit of measure for the serving size. Common values include grams (g), milliliters (ml), ounces (oz), or standardized serving units. [ENUM-REF-CANDIDATE: g|ml|oz|cup|tbsp|tsp|serving — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeValue rdf:type rdf:Property ;
    rdfs:label 'Serving Size Value' ;
    rdfs:comment 'Numeric value representing the serving size for which nutritional values are declared. Typically expressed per 100g or per defined serving unit.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Mg' ;
    rdfs:comment 'Sodium content in milligrams per serving size. Critical for cardiovascular health and regulatory compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateG rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate G' ;
    rdfs:comment 'Total carbohydrate content in grams per serving size, including sugars, starches, and dietary fiber.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatG rdf:type rdf:Property ;
    rdfs:label 'Total Fat G' ;
    rdfs:comment 'Total fat content in grams per serving size. Includes all fatty acids and lipid components.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsG rdf:type rdf:Property ;
    rdfs:label 'Total Sugars G' ;
    rdfs:comment 'Total sugar content in grams per serving size, including naturally occurring and added sugars.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatG rdf:type rdf:Property ;
    rdfs:label 'Trans Fat G' ;
    rdfs:comment 'Trans fatty acid content in grams per serving size. Mandatory declaration under FDA and many international regulations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminAMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin A Mcg' ;
    rdfs:comment 'Vitamin A content in micrograms per serving size, expressed as retinol activity equivalents (RAE).' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminCMg rdf:type rdf:Property ;
    rdfs:label 'Vitamin C Mg' ;
    rdfs:comment 'Vitamin C (ascorbic acid) content in milligrams per serving size.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Mcg' ;
    rdfs:comment 'Vitamin D content in micrograms per serving size. Mandatory declaration under updated FDA Nutrition Facts Panel.' ;
    rdfs:domain ind:NutritionalProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Primary key for test_result' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: In-process quality testing: ingredient test results generated during manufacturing (e.g., in-process checks at point of ingredient use) must reference the batch_record they support. Drives batch relea' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:ingredientLotId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Lot Id' ;
    rdfs:comment 'Reference to the specific ingredient lot that was tested. Links to the raw material batch received from supplier.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:originalTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Id' ;
    rdfs:comment 'Reference to the original test result record if this is a retest. Null for initial tests.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:coaDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Coa Document Url' ;
    rdfs:comment 'Link to the digital COA document stored in the document management system.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Unique certificate of analysis document number issued by the testing laboratory or supplier. Primary business identifier for the test result.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether the test result triggered a quality deviation or non-conformance requiring investigation.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Reference number of the quality deviation or non-conformance record if the test failed specification.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Release Status' ;
    rdfs:comment 'Current disposition status of the ingredient lot based on test results. Determines whether lot can be used in production.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation' ;
    rdfs:comment 'Accreditation standard or certification held by the testing laboratory (e.g., ISO 17025, A2LA, UKAS).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system that created this test result record (e.g., SAP QM, TraceGains, Veeva Vault, LIMS).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this test is mandated by regulatory authority (FDA, USDA, EFSA) versus internal quality control.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test result is a retest of a previously failed or inconclusive test.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the test result was reviewed and approved by quality assurance.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the quality assurance reviewer who verified and approved the test result.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date when the sample was collected from the ingredient lot for laboratory testing.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationMax rdf:type rdf:Property ;
    rdfs:label 'Specification Max' ;
    rdfs:comment 'Maximum acceptable value for the test parameter as defined in the ingredient specification. Null if no upper limit applies.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationMin rdf:type rdf:Property ;
    rdfs:label 'Specification Min' ;
    rdfs:comment 'Minimum acceptable value for the test parameter as defined in the ingredient specification. Null if no lower limit applies.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationTarget rdf:type rdf:Property ;
    rdfs:label 'Specification Target' ;
    rdfs:comment 'Target or nominal value for the test parameter. Represents the ideal value within the acceptable range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the laboratory test was completed and results were finalized.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testCost rdf:type rdf:Property ;
    rdfs:label 'Test Cost' ;
    rdfs:comment 'Cost incurred for performing the laboratory test. Used for quality cost tracking and analysis.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Test Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the test cost amount.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the laboratory test was performed. Principal business event timestamp for the test result.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'Specific characteristic or property being measured (e.g., Total Plate Count, pH, Moisture Content, Brix, Salmonella, Aflatoxin).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPriority rdf:type rdf:Property ;
    rdfs:label 'Test Priority' ;
    rdfs:comment 'Priority level assigned to the test based on business urgency or regulatory requirement.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultValue rdf:type rdf:Property ;
    rdfs:label 'Test Result Value' ;
    rdfs:comment 'Measured value or observation from the laboratory test. May be numeric, qualitative (detected/not detected), or descriptive depending on test type.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Category of laboratory test performed on the ingredient lot. Classifies the analytical method domain. [ENUM-REF-CANDIDATE: microbiological|chemical|physical|sensory|nutritional|allergen|contaminant|shelf_life — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the laboratory that performed the test (internal lab or third-party contract lab).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costId rdf:type rdf:Property ;
    rdfs:label 'Cost Id' ;
    rdfs:comment 'Primary key for cost' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityIndexReference rdf:type rdf:Property ;
    rdfs:label 'Commodity Index Reference' ;
    rdfs:comment 'Reference to the commodity market index used for index-linked pricing (e.g., CME Corn Futures, ICE Sugar No. 11, CBOT Wheat). Applies when price_type is index_linked.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Duty Cost Per Unit' ;
    rdfs:comment 'Import duty or tariff cost per unit of measure for this ingredient. Applies to imported raw materials and contributes to landed cost.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexMultiplier rdf:type rdf:Property ;
    rdfs:label 'Index Multiplier' ;
    rdfs:comment 'Multiplier applied to the commodity index value to calculate the index-linked price. Used in formula: price = index_value * index_multiplier + base_adjustment.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicePrice rdf:type rdf:Property ;
    rdfs:label 'Invoice Price' ;
    rdfs:comment 'Actual invoiced price per unit of measure from the supplier invoice. Represents the final settled price including any adjustments.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentCost rdf:type rdf:Property ;
    rdfs:label 'Is Current Cost' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active cost record for the ingredient-supplier-plant-purchasing_org combination. True for the most recent active record, False for historical records.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landedCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Per Unit' ;
    rdfs:comment 'Total landed cost per unit of measure including base price, freight, duty, and other procurement-related costs. Represents the true total cost of the ingredient delivered to the plant.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'The most recent actual purchase price per unit of measure paid for this ingredient from this supplier.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Rolling moving average price per unit of measure calculated from historical purchase transactions. Used for valuation in moving average price materials.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPrice rdf:type rdf:Property ;
    rdfs:label 'Planned Price' ;
    rdfs:comment 'Forecasted or budgeted price per unit of measure for future procurement planning and cost modeling.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the cost record indicating the pricing mechanism: standard (standard cost estimate), contract (negotiated contract price), spot (market spot price), index_linked (commodity index-based price), moving_average (rolling average price), planned (forecasted future price), or historical (actual past purchase price). [ENUM-REF-CANDIDATE: standard|contract|spot|index_linked|moving_average|planned|historical — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Variance Percentage' ;
    rdfs:comment 'Percentage variance between current and prior period price, calculated as ((current_price - prior_price) / prior_price) * 100. Expressed as a decimal (e.g., 5.25 for 5.25%).' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceVsPriorPeriod rdf:type rdf:Property ;
    rdfs:label 'Price Variance Vs Prior Period' ;
    rdfs:comment 'Variance between the current period price and the prior period price for the same ingredient and supplier. Used for trend analysis and price escalation tracking.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderLineItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Item' ;
    rdfs:comment 'Line item number within the purchase order for this ingredient. Five-digit line item number.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotPrice rdf:type rdf:Property ;
    rdfs:label 'Spot Price' ;
    rdfs:comment 'Current market spot price per unit of measure for the ingredient. Applies when price_type is spot.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The standard cost per unit of measure as defined in the cost estimate. Used as the baseline for Cost of Goods Sold (COGS) calculation and variance analysis.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updateReason rdf:type rdf:Property ;
    rdfs:label 'Update Reason' ;
    rdfs:comment 'Business reason or justification for the cost update or change (e.g., annual contract renewal, commodity price increase, supplier negotiation, standard cost cycle update).' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceVsStandard rdf:type rdf:Property ;
    rdfs:label 'Variance Vs Standard' ;
    rdfs:comment 'Variance between the actual cost (invoice_price or last_purchase_price) and the standard_cost. Positive values indicate unfavorable variance (actual > standard), negative values indicate favorable variance.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of this cost record for the same ingredient-supplier-plant-purchasing_org combination. Increments with each update to maintain full historical lineage.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaTraceabilityId rdf:type rdf:Property ;
    rdfs:label 'Fsma Traceability Id' ;
    rdfs:comment 'Primary key for fsma_traceability' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishedSkuId rdf:type rdf:Property ;
    rdfs:label 'Finished Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: FSMA 204 Critical Tracking Event records must identify the finished product SKU an ingredient was used in, enabling forward traceability from ingredient receipt to finished goods. product_description ' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.location. Business justification: FSMA 204 Critical Tracking Events require linking each CTE to a structured facility record. fsma_traceability.location_description is a denormalized plain-text representation of distribution.location.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:productRecallId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Id' ;
    rdfs:comment 'Foreign key linking to quality.product_recall. Business justification: FSMA 204 traceability records are the primary data source for determining recall scope and FDA notification. Linking fsma_traceability→product_recall enables recall coordinators to pull all traceabili' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this traceability record against FSMA Section 204 requirements. Indicates whether all required KDEs are present and accurate.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingDate rdf:type rdf:Property ;
    rdfs:label 'Cooling Date' ;
    rdfs:comment 'Date when the ingredient was cooled (for produce and other temperature-sensitive items). Required KDE for certain FTL items.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cteDate rdf:type rdf:Property ;
    rdfs:label 'Cte Date' ;
    rdfs:comment 'Date when the Critical Tracking Event occurred. Required Key Data Element (KDE) for FSMA 204 compliance. Must enable 24-hour FDA traceability response.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cte Timestamp' ;
    rdfs:comment 'Precise timestamp when the Critical Tracking Event occurred, including time zone. Provides granular traceability for time-sensitive food safety investigations.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cteType rdf:type rdf:Property ;
    rdfs:label 'Cte Type' ;
    rdfs:comment 'Type of Critical Tracking Event as defined by FSMA Section 204. Receiving CTE is owned by ingredient domain; transformation and shipping CTEs are owned by manufacturing and distribution domains respectively.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason for exemption from FSMA 204 traceability requirements, if applicable. Certain small businesses and specific food types may be exempt.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlClassification rdf:type rdf:Property ;
    rdfs:label 'Ftl Classification' ;
    rdfs:comment 'Classification of the ingredient according to the FDA Food Traceability List. Identifies which FTL category the ingredient belongs to (e.g., leafy greens, fresh-cut fruit, shell eggs, nut butters, finfish, crustaceans, mollusks, prepared ready-to-eat deli salads, tropical tree fruits, cheeses).' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlItemCode rdf:type rdf:Property ;
    rdfs:label 'Ftl Item Code' ;
    rdfs:comment 'Standardized code identifying the specific FTL item. Used for consistent classification across the supply chain.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growingLocation rdf:type rdf:Property ;
    rdfs:label 'Growing Location' ;
    rdfs:comment 'Geographic location where the ingredient was grown or harvested. Required KDE for certain FTL items to enable rapid source tracing during outbreaks.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harvestDate rdf:type rdf:Property ;
    rdfs:label 'Harvest Date' ;
    rdfs:comment 'Date when the ingredient was harvested (for agricultural products). Required KDE for certain FTL items such as leafy greens and fresh produce.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingDate rdf:type rdf:Property ;
    rdfs:label 'Packing Date' ;
    rdfs:comment 'Date when the ingredient was initially packed. Required KDE for certain FTL items to track the packing CTE.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document supporting this traceability record. Examples include Bill of Lading (BOL), Purchase Order (PO), Advanced Shipping Notice (ASN), production record, or Certificate of Analysis (COA). [ENUM-REF-CANDIDATE: BOL|PO|ASN|production_record|COA|receiving_report|batch_record|shipping_manifest — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlcSource rdf:type rdf:Property ;
    rdfs:label 'Tlc Source' ;
    rdfs:comment 'Origin of the traceability lot code. Indicates whether the TLC was assigned by the supplier, internally generated, or provided by the original grower/processor.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlcSourceReference rdf:type rdf:Property ;
    rdfs:label 'Tlc Source Reference' ;
    rdfs:comment 'Reference identifier linking the TLC to the source system or document where it was originally assigned. Enables upstream traceability to the immediate previous source.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Traceability Plan Version' ;
    rdfs:comment 'Version identifier of the FSMA traceability plan under which this record was created. Enables audit trail of traceability process changes.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when this traceability record was last verified for accuracy and completeness. Supports audit readiness for FDA inspections.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of data verification for this traceability record. Indicates whether the record has been validated against source documents and supplier data.' ;
    rdfs:domain ind:FsmaTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:religiousCertId rdf:type rdf:Property ;
    rdfs:label 'Religious Cert Id' ;
    rdfs:comment 'Primary key for religious_cert' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformanceId rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Id' ;
    rdfs:comment 'Foreign key linking to quality.non_conformance. Business justification: A lapsed or failed halal/kosher certification triggers a non-conformance if product was produced using non-certified ingredients. Linking religious_cert→non_conformance enables QA to trace which certi' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonConformance .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean indicator of whether this certified ingredient from this supplier is approved for use in production. True indicates approval; False indicates the certification exists but ingredient is not yet approved for use (e.g., pending internal review).' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the digital copy of the certification certificate stored in the document management system. Enables traceability and audit support.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) or hyperlink to access the digital certificate document. May point to internal document management system or external certifying body portal.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number or identifier issued by the certifying body. This is the externally-known business identifier for the certification.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The specific religious dietary standard or guideline under which the certification was granted. May reference specific Halal standards (e.g., MS 1500, SMIIC) or Kosher standards (e.g., OU standards, Star-K guidelines).' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of religious dietary certification. Halal certifies compliance with Islamic dietary law. Kosher certifications include Pareve (neutral, contains no meat or dairy), Dairy (contains dairy or dairy equipment), Meat (contains meat or meat equipment), and Passover (meets additional Passover requirements).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedIngredientName rdf:type rdf:Property ;
    rdfs:label 'Certified Ingredient Name' ;
    rdfs:comment 'The ingredient name as it appears on the religious certification certificate. May differ slightly from internal ingredient naming conventions.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedScope rdf:type rdf:Property ;
    rdfs:label 'Certified Scope' ;
    rdfs:comment 'Description of what is covered under this certification. May include specific production facilities, processes, product forms, or lot ranges that are certified.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyCode rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Code' ;
    rdfs:comment 'Standardized code or abbreviation for the certifying body. Examples: OU, OK, STAR-K, IFANCA, MUI, JAKIM. Used for efficient filtering and reporting.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or special conditions related to the religious certification. May include audit findings, special handling requirements, or restrictions.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next audit or inspection by the certifying body. Used for planning and ensuring continuous compliance.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceDetails rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Details' ;
    rdfs:comment 'Description of any non-compliance issues, deviations, or corrective actions required. Populated when non_compliance_flag is True.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether any non-compliance issues have been identified with this certification. True indicates non-compliance detected; False indicates no issues. Triggers investigation and corrective action.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionRegion rdf:type rdf:Property ;
    rdfs:label 'Production Region' ;
    rdfs:comment 'Geographic region or facility where the certified ingredient is produced. May include state, province, or specific production site information.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date on which the certification was last renewed or is scheduled for renewal. Used for tracking renewal cycles and planning.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Status of the certification renewal process. Tracks whether renewal is required, underway, completed, or overdue. Critical for maintaining continuous certification coverage.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'Unique traceability identifier linking this certification to supply chain traceability systems. Enables end-to-end tracking from raw material to finished goods for recall and compliance purposes.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person or role who performed the most recent verification of the certification. Supports audit trail and accountability.' ;
    rdfs:domain ind:ReligiousCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Co Packer Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Co-packer supplier must be recorded for FDA/HACCP traceability and allergen control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when production execution was completed and final confirmation posted. Captured from MES or CO11N transaction.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'SAP PP confirmation document number generated by CO11N transaction. Links to detailed confirmation records including time, quantity, and goods movements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the production confirmation was posted in SAP PP via CO11N transaction.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Type of production confirmation: partial (interim confirmation during production run) or final (completion confirmation closing the order).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoLotConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Lot Consumption Flag' ;
    rdfs:comment 'Boolean flag indicating whether raw material lot consumption for this order followed FEFO inventory management rules (consuming lots with nearest expiration first). True if FEFO was enforced, False otherwise. Critical for perishable food and beverage ingredients.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoLotConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Lot Consumption Flag' ;
    rdfs:comment 'Boolean flag indicating whether raw material lot consumption for this order followed FIFO inventory management rules. True if FIFO was enforced, False otherwise.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this production order was executed in full compliance with GMP requirements. True if all GMP critical control points were met and documented, False if any deviations occurred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsMovementDocument rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Document' ;
    rdfs:comment 'SAP MM material document number for the goods receipt posting (MIGO 101 movement type) that moved confirmed quantity into finished goods inventory.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpLogReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Log Reference' ;
    rdfs:comment 'Reference identifier to the HACCP CCP monitoring log for this production order. Links to detailed records of critical control point measurements (temperature, pH, time, etc.) taken during production.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesWorkOrderReference rdf:type rdf:Property ;
    rdfs:label 'Mes Work Order Reference' ;
    rdfs:comment 'Work order identifier from Aveva/Wonderware MES system. Provides linkage between SAP PP production order and detailed MES execution records including real-time process data, equipment performance, and operator actions.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity to be produced as specified in the production order header. Measured in base unit of measure for the SKU.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkDisposition rdf:type rdf:Property ;
    rdfs:label 'Rework Disposition' ;
    rdfs:comment 'Final disposition of reworked material: reprocessed (successfully reworked to original spec), downgraded (reworked to lower-grade product), scrapped (could not be salvaged), returned_to_vendor (raw material defect). Applicable only when order_type is rework.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework or reprocessing. This quantity is typically moved to a rework order for corrective processing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rework Reason Code' ;
    rdfs:comment 'Code identifying the reason for rework when order_type is rework. Examples: quality defect, packaging error, labeling error, contamination, off-spec product. Null for non-rework orders.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version identifier of the production routing or recipe used for this order. Defines the sequence of operations and process parameters.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned completion date for production order execution as determined by production scheduling or SAP IBP.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned start date for production order execution as determined by production scheduling or SAP IBP.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of product scrapped or discarded during production due to quality defects, process failures, or other non-conformances. Measured in base unit of measure.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Shift during which the production order was executed: day, evening, night, or weekend shift.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturerName rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturer Name' ;
    rdfs:comment 'Name of the toll manufacturing partner when order_type is toll. In toll arrangements, the customer provides raw materials and the toll manufacturer provides processing services. Null for non-toll orders.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Percentage' ;
    rdfs:comment 'Variance between planned and actual yield, calculated as (actual_yield - planned_yield) / planned_yield * 100. Positive values indicate over-yield, negative values indicate under-yield.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'The actual quantity of finished goods produced and approved from this batch. May differ from batch size due to process losses, quality rejections, or overproduction.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNotes rdf:type rdf:Property ;
    rdfs:label 'Batch Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special instructions related to this batch. May include process notes, quality observations, equipment issues, or other relevant information not captured in structured fields.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'The planned or target quantity of finished goods to be produced in this batch. Represents the theoretical yield based on the formulation and production order.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch record. Tracks the batch through manufacturing execution, quality approval, and release stages. In-process indicates active manufacturing; pending QA indicates awaiting quality approval; released indicates approved for distribution; rejected indicates failed quality checks; quarantine indicates isolated pending investigation; on hold indicates regulatory or quality hold.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPackerFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packer Flag' ;
    rdfs:comment 'Indicates whether this batch was manufactured by a third-party co-packer (contract manufacturer) rather than in-house. True indicates co-packer production; False indicates internal manufacturing. Critical for supply chain visibility and quality accountability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'The total number of manufacturing deviations, exceptions, or non-conformances recorded during batch execution. Includes process parameter excursions, equipment failures, and procedural deviations. Zero indicates perfect execution. Used for quality trending and CAPA analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glutenFreeClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Claim Flag' ;
    rdfs:comment 'Indicates whether this batch carries a gluten-free claim on the label. True indicates gluten-free claim present; False indicates no claim. Must meet FDA gluten-free standard of less than 20 ppm gluten. Requires testing and validation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Haccp Signoff Status' ;
    rdfs:comment 'Status of HACCP critical control point verification and approval for this batch. Indicates whether all critical control points were monitored and within acceptable limits. Pending indicates awaiting review; approved indicates all CCPs passed; rejected indicates CCP failure; not applicable for products not requiring HACCP.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certification Flag' ;
    rdfs:comment 'Indicates whether this batch is certified halal per Islamic dietary law. True indicates halal certified; False indicates not certified. Requires halal certificate and compliance documentation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certification Flag' ;
    rdfs:comment 'Indicates whether this batch is certified kosher by a recognized kosher certification agency. True indicates kosher certified; False indicates not certified. Requires kosher certificate and supervision records.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'The date and time when batch manufacturing execution was completed. Marks the completion of all processing steps and final packaging. Used for cycle time analysis and OEE calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'The date and time when batch manufacturing execution began. Marks the start of raw material dispensing and processing. Critical for shelf life calculation and FIFO/FEFO inventory management.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Description of the primary and secondary packaging used for this batch. Includes package type, size, and material. Examples: 12oz PET bottle 24-pack, 500g stand-up pouch, 1L Tetra Pak carton. Links to packaging specification.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Number' ;
    rdfs:comment 'The batch number of the original batch from which reworked material was sourced. Populated only when rework_flag is True. Maintains traceability chain for reworked batches.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Timestamp' ;
    rdfs:comment 'The date and time when the quality assurance reviewer approved this batch for release to distribution. Marks the transition from pending QA to released status.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Free-text description of the reason for regulatory hold. Populated only when regulatory_hold_flag is True. Documents the specific regulatory concern, investigation, or pending approval.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this batch includes reworked material from a previous batch. True indicates rework present; False indicates all new material. Rework must be documented per GMP requirements.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterilizationMethod rdf:type rdf:Property ;
    rdfs:label 'Sterilization Method' ;
    rdfs:comment 'The thermal or non-thermal sterilization process applied to this batch. Pasteurization indicates low-temperature short-time treatment; UHT indicates ultra-high temperature; retort indicates in-container sterilization; aseptic indicates sterile processing and packaging; none indicates no sterilization (e.g., dry goods); other for alternative methods. Critical for food safety and shelf life.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturingFlag rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturing Flag' ;
    rdfs:comment 'Indicates whether this batch was produced under a toll manufacturing arrangement where the company provides raw materials and the toll manufacturer provides processing services. True indicates toll manufacturing; False indicates standard production. Distinct from co-packing where the manufacturer may source materials.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stagingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Staging Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Each work center has an associated WIP staging storage location for materials in process (standard in SAP as production storage location per work center). Inventory managers and production planners us' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when this work center became operational and available for production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when this work center was decommissioned or taken out of service. Null for currently active work centers.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergenCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Capable Flag' ;
    rdfs:comment 'Indicates whether this work center is capable of processing products containing major food allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans). Critical for allergen control and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of specific allergen types that this work center is approved to handle (e.g., milk, peanuts, tree nuts, soy). Empty if allergen_capable_flag is false. [ENUM-REF-CANDIDATE: milk|eggs|fish|shellfish|tree_nuts|peanuts|wheat|soybeans|sesame|sulfites — promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center based on shift pattern and planned maintenance windows.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Total time in minutes required to switch from one product or SKU to another, including teardown, cleaning, setup, and validation. Key metric for production efficiency and scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cip Cycle Time Minutes' ;
    rdfs:comment 'Standard duration in minutes for a complete CIP cleaning cycle on this work center. Null if CIP is not required.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cipRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Required Flag' ;
    rdfs:comment 'Indicates whether this work center requires automated clean-in-place procedures between production runs. Critical for liquid processing, dairy, and beverage lines.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coPackingApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Co Packing Approved Flag' ;
    rdfs:comment 'Indicates whether this work center is approved for co-packing or toll manufacturing operations for third-party brands.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP hygiene classification level of the work center determining the sanitation, personnel, and environmental control requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Flag' ;
    rdfs:comment 'Indicates whether this work center contains one or more HACCP critical control points requiring continuous monitoring and documentation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance or major service performed on this work center.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the work center by its primary production process type. Determines the type of operations and products that can be manufactured on this line. [ENUM-REF-CANDIDATE: mixing|filling|packaging|pasteurization|fermentation|extrusion|co-packing|blending|bottling|canning — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRunSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Run Size' ;
    rdfs:comment 'Maximum production quantity that can be manufactured on this work center in a single run due to equipment, storage, or process constraints.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesAssetTag rdf:type rdf:Property ;
    rdfs:label 'Mes Asset Tag' ;
    rdfs:comment 'Unique asset identifier used by the MES system (Aveva/Wonderware) to track real-time production data, OEE metrics, and equipment performance for this work center.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRunSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Run Size' ;
    rdfs:comment 'Minimum production quantity that can be economically manufactured on this work center in a single run. Used to enforce MOQ constraints in production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance shutdown for this work center. Used for production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this work center representing the product of availability, performance, and quality rates. Industry benchmark for world-class manufacturing is 85%.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionArea rdf:type rdf:Property ;
    rdfs:label 'Production Area' ;
    rdfs:comment 'Physical production area or zone within the plant where the work center is located (e.g., Mixing Room, Filling Hall, Packaging Wing, Cold Storage).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Units Per Hour' ;
    rdfs:comment 'Maximum theoretical production capacity of the work center expressed in units per hour under optimal operating conditions. Used for production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runSizeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Run Size Unit Of Measure' ;
    rdfs:comment 'Unit of measure for minimum and maximum run sizes. [ENUM-REF-CANDIDATE: cases|bottles|cans|pounds|kilograms|liters|gallons|batches — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to prepare the work center for a production run, including equipment configuration, material staging, and pre-operational checks.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard operating shift pattern for this work center determining its available production hours per day.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to produce one unit or batch on this work center under normal operating conditions. Used for production scheduling and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean, sanitize, and restore the work center after a production run. Critical for GMP compliance and allergen control.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'High-level categorization of the work center by its functional role in the manufacturing process.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Business identifier code for the work center used in production planning and scheduling systems. Typically alphanumeric code assigned by manufacturing operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed description of the work center including its purpose, capabilities, and operational characteristics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Descriptive name of the work center for human identification and reporting purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center indicating its availability for production scheduling and execution.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedIngredientLotId rdf:type rdf:Property ;
    rdfs:label 'Planned Ingredient Lot Id' ;
    rdfs:comment 'Foreign key linking to ingredient.lot. Business justification: MRP/production planning process: schedulers confirm specific ingredient lot availability (FEFO sequencing) before releasing a schedule. lot_number_planned is a plain text field; a proper FK enables ma' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:allergenChangeoverRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Changeover Required' ;
    rdfs:comment 'Flag indicating whether allergen-related line clearance and deep cleaning is required before this production run due to allergen matrix considerations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Batch Size Target' ;
    rdfs:comment 'Target batch size for this production run, expressed in the same UOM as planned quantity. Used for batch manufacturing and Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned utilization percentage of the work center\'s available capacity for this schedule entry. Used for capacity planning and bottleneck analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewSizeRequired rdf:type rdf:Property ;
    rdfs:label 'Crew Size Required' ;
    rdfs:comment 'Number of operators or crew members required to execute this production schedule entry. Used for labor capacity planning.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Completion Timestamp' ;
    rdfs:comment 'The date and time when the actual production execution for this schedule entry was completed and confirmed by the MES. Used for schedule vs. actual performance analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'The forecasted demand quantity that this schedule entry is intended to fulfill. Used for demand-driven planning and forecast accuracy tracking.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frozenZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Frozen Zone Flag' ;
    rdfs:comment 'Flag indicating whether this schedule entry falls within the frozen planning horizon where changes are restricted to maintain schedule stability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCcpApplicable rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Applicable' ;
    rdfs:comment 'Flag indicating whether this production schedule entry involves HACCP Critical Control Points that require monitoring and documentation per food safety regulations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReplanningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Replanning Timestamp' ;
    rdfs:comment 'The date and time when this schedule entry was last revised or replanned. Used for tracking schedule stability and replanning frequency.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotNumberPlanned rdf:type rdf:Property ;
    rdfs:label 'Lot Number Planned' ;
    rdfs:comment 'Pre-assigned lot number for traceability purposes. Enables First In First Out (FIFO) and First Expired First Out (FEFO) inventory consumption tracking and lot genealogy.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Material Availability Status' ;
    rdfs:comment 'Status indicating whether all required raw materials and ingredients are available for this scheduled production. Confirmed indicates full availability; partial indicates some materials available; pending indicates materials not yet checked; shortage indicates insufficient inventory.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetDate rdf:type rdf:Property ;
    rdfs:label 'Otif Target Date' ;
    rdfs:comment 'The target delivery date for On Time In Full (OTIF) performance measurement. Used to track schedule adherence and customer service level.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the planned quantity (e.g., cases, kilograms, liters, pallets). Aligns with SKU base UOM.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Business priority level assigned to this schedule entry. Critical indicates customer-committed or regulatory deadline; high indicates tight inventory; normal indicates standard planning; low indicates buffer or make-to-stock.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedToMesTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released To Mes Timestamp' ;
    rdfs:comment 'The date and time when this schedule entry was released to the Manufacturing Execution System (MES) for execution. Marks the transition from planning to execution.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replanningReason rdf:type rdf:Property ;
    rdfs:label 'Replanning Reason' ;
    rdfs:comment 'Business reason for the most recent replanning event (e.g., demand change, material shortage, equipment breakdown, customer request). Used for root cause analysis of schedule instability.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockTarget rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target' ;
    rdfs:comment 'Target safety stock level that this production schedule entry is intended to maintain or replenish. Used for inventory optimization.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or comments from the planner regarding special considerations, constraints, or instructions for this schedule entry.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Origin system or method that generated this schedule entry. MRP indicates Material Requirements Planning; manual indicates planner override; IBP indicates Integrated Business Planning system; demand_sensing indicates real-time demand signal; optimization indicates algorithmic sequencing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule entry. Draft indicates preliminary planning; firmed indicates committed plan; released indicates sent to MES for execution; executed indicates production completed; cancelled indicates schedule entry voided.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the production schedule. Allows tracking of schedule revisions and replanning iterations (e.g., V1, V2, V2.1).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Minutes' ;
    rdfs:comment 'Total planned production duration in minutes, including run time but excluding changeover time. Used for Overall Equipment Effectiveness (OEE) baseline calculations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'The planned date and time when production for this schedule entry is expected to be completed. Used for capacity planning and On Time In Full (OTIF) tracking.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'The planned date and time when production for this schedule entry is expected to begin. Used for capacity planning and sequencing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The order position of this schedule entry within the work center\'s production sequence for the planning period. Used for sequencing optimization and changeover minimization.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupInstructions rdf:type rdf:Property ;
    rdfs:label 'Setup Instructions' ;
    rdfs:comment 'Special setup or configuration instructions for the work center to execute this schedule entry. May reference standard operating procedures (SOPs) or work instructions.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Identifier for the production shift during which this schedule entry is planned (e.g., Day, Night, Swing). Used for labor planning and shift performance analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCcpLogId rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Log Id' ;
    rdfs:comment 'Unique identifier for the HACCP critical control point monitoring log entry. Primary key for the log record.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalControlPointId rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Id' ;
    rdfs:comment 'Foreign key linking to quality.critical_control_point. Business justification: A CCP log entry records a monitoring event at a specific CCP. Linking to quality.critical_control_point identifies which CCP (with its defined limits and hazard type) was monitored — the core HACCP co' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CriticalControlPoint .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Foreign key linking to inventory.quarantine_hold. Business justification: When a HACCP CCP log records a critical limit deviation (regulatory_hold_triggered_flag=true), a quarantine hold is immediately placed on affected inventory. Food safety regulations require direct tra' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuarantineHold .

ind:ccpIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ccp Identifier' ;
    rdfs:comment 'The unique code or identifier for the critical control point as defined in the HACCP plan (e.g., CCP-1, CCP-2-PASTEURIZE).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpName rdf:type rdf:Property ;
    rdfs:label 'Ccp Name' ;
    rdfs:comment 'The descriptive name of the critical control point being monitored (e.g., Pasteurization Temperature, Metal Detection, pH Check, Brix Measurement, Allergen Verification).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a corrective action is required based on the CCP monitoring result (True = corrective action needed, False = no action needed).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Detailed description of the corrective action(s) taken in response to a CCP deviation. Documents the specific steps taken to bring the process back into control and disposition of affected product.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitLower rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Lower' ;
    rdfs:comment 'The minimum acceptable value for this CCP as defined in the HACCP plan. Values below this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Upper' ;
    rdfs:comment 'The maximum acceptable value for this CCP as defined in the HACCP plan. Values above this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationSeverity rdf:type rdf:Property ;
    rdfs:label 'Deviation Severity' ;
    rdfs:comment 'Classification of the severity of the CCP deviation if one occurred (minor = slight deviation with low risk, major = significant deviation requiring investigation, critical = severe deviation with immediate food safety risk).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'The category of food safety hazard that this CCP is designed to control (biological, chemical, physical, or allergen).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inLimitFlag rdf:type rdf:Property ;
    rdfs:label 'In Limit Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value falls within the defined critical limits (True = within limits, False = out of specification).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual measured or observed value at the critical control point (e.g., temperature reading, pH level, Brix degree, metal detector sensitivity test result).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'The required frequency of monitoring for this CCP as defined in the HACCP plan (e.g., continuous, every 15 minutes, every batch, hourly).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'The method or procedure used to monitor this CCP (e.g., calibrated thermometer, pH meter, metal detector test, visual inspection, laboratory analysis).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'The exact date and time when the CCP measurement or observation was recorded. Critical for establishing real-time compliance and traceability.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'The final disposition decision for product affected by this CCP monitoring event (released = approved for distribution, rework = reprocessed to meet specifications, reprocess = returned to earlier production step, destroyed = disposed of, quarantine = held pending investigation).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Modified Timestamp' ;
    rdfs:comment 'The date and time when this CCP log record was last modified. Critical for audit trail and data integrity compliance.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryHoldTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Triggered Flag' ;
    rdfs:comment 'Boolean indicator of whether this CCP deviation triggered a regulatory hold on the batch, preventing release until investigation and disposition are complete (True = hold triggered, False = no hold).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'The date and time when the supervisor or quality manager completed their review of this CCP log entry.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisorReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this CCP log entry requires supervisor or quality manager review due to deviation or other exceptional circumstances (True = review required, False = no review needed).' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the CCP monitoring record was verified and signed off by the responsible operator or quality personnel.' ;
    rdfs:domain ind:HaccpCcpLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Lot Consumption Id' ;
    rdfs:comment 'Unique identifier for the lot consumption transaction record. Primary key for the lot consumption entity.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption was automatically backflushed based on production confirmation (True) or manually posted (False). Backflushing automates material consumption based on BOM and production output.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomQuantity rdf:type rdf:Property ;
    rdfs:label 'Bom Quantity' ;
    rdfs:comment 'The planned or standard quantity of this material specified in the Bill of Materials for the production order. Used to calculate consumption variance.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'The current status of the consumption transaction in the system workflow: confirmed (posted to inventory), pending (awaiting approval), rejected (not accepted), or reversed (cancelled after posting).' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumption Quantity' ;
    rdfs:comment 'The quantity of material consumed from the specified lot during production. Recorded in the unit of measure specified in the unit_of_measure field.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The precise date and time when the material lot was consumed in the production process. Critical for FIFO/FEFO compliance and production timeline tracking.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consumptionType rdf:type rdf:Property ;
    rdfs:label 'Consumption Type' ;
    rdfs:comment 'Classification of the consumption event indicating the purpose or nature of material usage: standard production, rework/reprocessing, trial run, quality sample, or waste/scrap.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoFefoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fifo Fefo Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order in which lots were consumed according to FIFO or FEFO inventory management rules. Lower numbers indicate earlier consumption priority.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lot Expiry Date' ;
    rdfs:comment 'The expiration or best-before date of the consumed lot. Used to enforce FEFO consumption rules and ensure materials are used before expiration.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'The unique document number generated by the ERP system for this goods movement transaction. Used for audit trail and transaction traceability.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'The material reservation document number that allocated this lot for consumption against the production order. Links consumption to the planned material requirement.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the consumed quantity, calculated as consumption_quantity * unit_cost. Represents the material cost component of the production order.' ;
    rdfs:domain ind:LotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between actual consumption quantity and the BOM planned quantity. Positive values indicate over-consumption; negative values indicate under-consumption.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'The storage location or warehouse from which the material lot was withdrawn for consumption. Links to the warehouse management system location master.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingSupplierId rdf:type rdf:Property ;
    rdfs:label 'Routing Supplier Id' ;
    rdfs:comment 'Reference to the third-party co-packing supplier if this routing represents externally manufactured production. Null for internal production.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:routingTollManufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Routing Toll Manufacturer Supplier Id' ;
    rdfs:comment 'Reference to the toll manufacturing supplier if this routing represents production where the company provides raw materials and the supplier provides processing. Null for internal or co-packed production.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allergenHandlingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Required Flag' ;
    rdfs:comment 'Indicates whether this routing requires special allergen handling procedures, such as line changeover cleaning or dedicated equipment, to prevent cross-contact.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether this routing has been validated for GMP compliance. True means all operations meet GMP documentation, training, and control requirements.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'The minimum production lot size for which this routing is valid. Supports lot-size-dependent routing selection.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'The maximum production lot size for which this routing is valid. Null indicates no upper limit.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'The largest production quantity that can be produced in a single batch using this routing, constrained by equipment capacity or process limits.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'The smallest production quantity that can be economically or technically produced using this routing, expressed in the base UOM.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'The total number of sequential operations (work center steps) defined in this routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Allowed Flag' ;
    rdfs:comment 'Indicates whether non-conforming product from this routing can be reworked through a defined rework operation sequence.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Free-text description of the routing, typically summarizing the production method or key process characteristics (e.g., \'High-speed aseptic filling line\', \'Manual batch mixing and packaging\').' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. The externally-known unique code used to reference this routing in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production order creation; draft and under-review routings are in development; inactive and obsolete routings are no longer used.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing. Standard routings are the default production method; alternative routings provide flexibility for capacity or material constraints; trial routings support NPD; co-packing and toll manufacturing routings reflect external production arrangements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'The expected percentage of material loss or waste across all operations in this routing, used for material planning and costing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Standard Production Time Minutes' ;
    rdfs:comment 'The sum of all operation standard times (setup, machine, labor) across the routing, expressed in minutes. Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'The business purpose for which this routing is maintained. Production routings drive MES execution; costing routings feed standard cost calculations; maintenance and quality inspection routings support non-production work orders.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the plant location including street number and name.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building number, suite, or floor.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum daily production capacity of the plant measured in standard production units per day. Used for capacity planning, demand allocation, and OEE (Overall Equipment Effectiveness) calculations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the plant was permanently closed and ceased all production operations. Null for active facilities.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gfsiCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gfsi Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the current GFSI certification requiring renewal to maintain compliance and customer approval status.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Boolean indicator of whether the plant holds current GMP (Good Manufacturing Practice) certification required for food and beverage manufacturing quality standards.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesSiteCode rdf:type rdf:Property ;
    rdfs:label 'Mes Site Code' ;
    rdfs:comment 'Site or facility identifier used in the Manufacturing Execution System (Aveva/Wonderware MES) for production scheduling, batch management, and OEE tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines or manufacturing lines within the plant used for production scheduling and line allocation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Standard number of operating days per week for the plant (typically 5, 6, or 7) used for production planning and capacity calculations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Per Day' ;
    rdfs:comment 'Standard operating hours per day for the plant used for capacity planning and OEE calculations. Typically 8, 16, or 24 hours depending on shift structure.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCertifyingBody rdf:type rdf:Property ;
    rdfs:label 'Organic Certifying Body' ;
    rdfs:comment 'Name of the accredited organic certification body that issued the organic certification (e.g., QAI, CCOF, Oregon Tilth, Ecocert).' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Official business name of the manufacturing plant or production facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantStatus rdf:type rdf:Property ;
    rdfs:label 'Plant Status' ;
    rdfs:comment 'Current operational status of the plant in its lifecycle. Active indicates full production operations, idle indicates temporarily not producing but maintained, decommissioned indicates permanently closed, under construction indicates new facility being built, and temporarily closed indicates short-term shutdown for maintenance or seasonal operations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the facility type indicating ownership and operational model. Owned manufacturing indicates company-operated production facilities, co-packer indicates third-party contract manufacturing, toll manufacturer indicates facilities where the company provides ingredients and the manufacturer provides processing, pilot plant indicates small-scale testing facilities, R&D facility indicates research and development sites, and distribution center indicates warehousing and logistics hubs.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Product Category' ;
    rdfs:comment 'Primary product category or product line manufactured at this plant (e.g., beverages, snacks, dairy, bakery, confectionery) used for portfolio planning and specialization tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Warehouse Capacity Pallets' ;
    rdfs:comment 'Total warehouse storage capacity at the plant site measured in standard pallet positions for finished goods and raw material inventory management.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or total capitalized cost of acquiring and installing the equipment, used for asset valuation and depreciation calculations.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenHandlingCapability rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Capability' ;
    rdfs:comment 'Description of allergen types this equipment is qualified to handle, or designation as allergen-free equipment. Critical for allergen control and production scheduling to prevent cross-contamination.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Asset Owner Department' ;
    rdfs:comment 'Department or business unit responsible for the ownership, budgeting, and strategic decisions related to this equipment asset.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the most recent calibration certificate documenting the equipment\'s measurement accuracy and compliance with specifications.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Number of days between required calibration activities as defined by regulatory requirements, manufacturer specifications, or internal quality standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cipCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cip Capable Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment is designed for automated clean-in-place sanitation without disassembly, enabling efficient changeover and sanitation cycles.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality classification of the equipment based on its impact to production continuity, safety, and quality. Critical equipment requires highest priority maintenance and monitoring.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business justification or reason for decommissioning the equipment (e.g., end of life, obsolescence, facility closure, technology upgrade).' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionRatingKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Rating Kwh' ;
    rdfs:comment 'Rated or average energy consumption of the equipment per operating hour, used for sustainability tracking and operational cost analysis.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level grouping of equipment by operational category for reporting and analysis purposes.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable descriptive name of the equipment asset (e.g., \'Line 3 Filling Machine\', \'Pasteurizer Unit A\').' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTagNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to the equipment asset for operational tracking and maintenance purposes. This is the externally-known business identifier used in MES systems, work orders, and maintenance schedules.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the equipment by its primary production function within the manufacturing process. [ENUM-REF-CANDIDATE: filling_machine|mixer|blender|pasteurizer|extruder|packaging_line|labeler|metal_detector|checkweigher|cip_system|oven|cooler|conveyor|palletizer|wrapper|sealer — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodContactSurfaceFlag rdf:type rdf:Property ;
    rdfs:label 'Food Contact Surface Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment has surfaces that come into direct contact with food products, requiring specific sanitation and material compliance standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this equipment is classified as GMP-critical, requiring enhanced documentation, validation, and change control procedures.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the equipment was physically installed at the manufacturing facility.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the equipment was last calibrated or verified for measurement accuracy, applicable to equipment requiring calibration per GMP or quality standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration or verification activity to maintain equipment qualification status.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeBaselineTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Baseline Target Percent' ;
    rdfs:comment 'Target OEE percentage established as the performance baseline for this equipment, used for monitoring and continuous improvement initiatives. OEE measures availability, performance, and quality.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the equipment indicating its availability for production use.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMaintenanceScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Schedule Code' ;
    rdfs:comment 'Reference code linking this equipment to its preventive maintenance plan schedule defining frequency and tasks for routine maintenance activities.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'Maximum production capacity of the equipment as specified by the manufacturer or validated during commissioning, expressed in the unit of measure appropriate to the equipment type.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Code' ;
    rdfs:comment 'Reference code or identifier for safety certifications held by this equipment (e.g., UL, CE, CSA), documenting compliance with electrical and mechanical safety standards.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Document Code' ;
    rdfs:comment 'Reference identifier for the technical specification document containing detailed engineering specifications, operating parameters, and maintenance procedures for this equipment.' ;
    rdfs:domain ind:EquipmentMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Ambient Zone Flag' ;
    rdfs:comment 'Indicates whether the distribution center has ambient temperature storage zones for dry goods and shelf-stable products.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centerName rdf:type rdf:Property ;
    rdfs:label 'Center Name' ;
    rdfs:comment 'Official business name of the distribution center facility.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Primary contact email address for the distribution center facility for operational communications and coordination.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary contact phone number for the distribution center facility for operational coordination and emergency contact.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Capable Flag' ;
    rdfs:comment 'Indicates whether the distribution center has cross-docking capabilities to transfer products directly from inbound to outbound without storage.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cubicCapacity rdf:type rdf:Property ;
    rdfs:label 'Cubic Capacity' ;
    rdfs:comment 'Total cubic footage storage capacity of the distribution center for volumetric capacity planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems and external communications. Typically alphanumeric facility code.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directStoreDeliveryHubFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Store Delivery Hub Flag' ;
    rdfs:comment 'Indicates whether the distribution center serves as a hub for Direct Store Delivery operations to retail locations.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecommerceFulfillmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Fulfillment Flag' ;
    rdfs:comment 'Indicates whether the distribution center handles direct-to-consumer e-commerce order fulfillment and last-mile delivery.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the distribution center based on primary storage and handling capability. Ambient for dry goods, refrigerated for chilled products, frozen for sub-zero storage, multi-temperature for mixed zones, cross-dock for flow-through operations, consolidation for order aggregation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified Flag' ;
    rdfs:comment 'Indicates whether the distribution center has HACCP certification for food safety management. Required for facilities handling high-risk food products.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to receiving inbound shipments from suppliers and manufacturing plants.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the distribution center has ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays (Monday-Friday) in format HH:MM-HH:MM (e.g., 06:00-22:00). Used for scheduling and service level planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends (Saturday-Sunday) in format HH:MM-HH:MM. Nullable if facility does not operate on weekends.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date when the distribution center began operational activities and started processing inventory and shipments.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to shipping outbound orders to customers, retail stores, and distribution points.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Ownership and operational control model for the distribution center. Company-owned for internal facilities, third-party logistics (3PL) for outsourced operations, leased for rented facilities with internal operations, co-managed for hybrid arrangements.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPositionCapacity rdf:type rdf:Property ;
    rdfs:label 'Pallet Position Capacity' ;
    rdfs:comment 'Maximum number of pallet positions available for storage in the distribution center. Key metric for inventory capacity planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refrigeratedZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Zone Flag' ;
    rdfs:comment 'Indicates whether the distribution center has refrigerated storage zones for chilled products requiring cold chain management.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Storage Square Footage' ;
    rdfs:comment 'Square footage dedicated to product storage areas excluding staging, dock, and administrative space.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZoneCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Count' ;
    rdfs:comment 'Number of distinct temperature-controlled zones within the distribution center for managing products with different storage requirements.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyLogisticsProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Provider' ;
    rdfs:comment 'Name of the third-party logistics provider managing the facility if ownership model is 3PL or co-managed. Null for company-owned facilities.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total building square footage of the distribution center facility including all storage, staging, and administrative areas.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twentyFourSevenOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Operation Flag' ;
    rdfs:comment 'Indicates whether the distribution center operates 24 hours a day, 7 days a week for continuous fulfillment operations.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wmsSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Wms System Identifier' ;
    rdfs:comment 'Identifier for the Warehouse Management System instance managing this distribution center. Used for system integration and data reconciliation.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal name of the transportation carrier organization as registered with regulatory authorities.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier in the approved carrier network. Controls eligibility for load assignment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of carrier business model: asset-based (owns equipment), non-asset-based (brokerage), third-party logistics provider, private fleet (company-owned), or Direct Store Delivery fleet.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio Percentage' ;
    rdfs:comment 'Percentage of shipments resulting in damage, loss, or shortage claims over the past 12 months. Used for carrier risk assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable Flag' ;
    rdfs:comment 'Indicates whether the carrier has temperature-controlled equipment and processes certified for transporting refrigerated and frozen food products.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedRateTier rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Tier' ;
    rdfs:comment 'Rate tier classification based on contracted pricing agreement. Tier 1 represents preferred pricing, spot market represents non-contracted rates.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPhone rdf:type rdf:Property ;
    rdfs:label 'Dispatch Phone' ;
    rdfs:comment '24/7 dispatch phone number for load tendering, driver coordination, and real-time shipment tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier issued by the US Department of Transportation Federal Motor Carrier Safety Administration for interstate commercial carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediProtocol rdf:type rdf:Property ;
    rdfs:label 'Edi Protocol' ;
    rdfs:comment 'Technical protocol used for electronic data interchange with the carrier: ANSI X12, EDIFACT, API integration, or none.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Total number of power units (tractors, trucks) operated by the carrier. Used for capacity planning and carrier capability assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fsmaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Certification Date' ;
    rdfs:comment 'Date when the carrier received FSMA Sanitary Transportation compliance certification. Used to track recertification cycles.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fsmaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma Compliant Flag' ;
    rdfs:comment 'Indicates whether the carrier meets FSMA Sanitary Transportation of Human and Animal Food requirements including temperature control, equipment sanitation, and training documentation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fsmaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Fsma Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers FSMA Sanitary Transportation compliance certification. Triggers recertification workflow.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'Primary street address line for the carriers corporate headquarters location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carriers corporate headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the carriers headquarters location (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the carriers corporate headquarters location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province code where the carriers corporate headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number for the carriers liability and cargo insurance certificate on file. Required for carrier qualification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total liability coverage amount in USD provided by the carriers insurance policy. Must meet minimum threshold for carrier approval.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers current insurance policy. Carrier status automatically suspended if insurance lapses.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by FMCSA for for-hire interstate carriers. Required for carriers transporting regulated commodities.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Percentage' ;
    rdfs:comment 'Rolling 12-month percentage of shipments delivered on-time and in-full without damage or shortage. Key performance indicator for carrier evaluation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days from invoice date for carrier freight charges (e.g., Net 30, Net 45).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification based on On-Time In-Full (OTIF) delivery, claims ratio, and service quality metrics. Determines load allocation priority.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Flag' ;
    rdfs:comment 'Indicates whether the carrier is designated as a preferred partner with priority load allocation and strategic relationship status.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Federal Motor Carrier Safety Administration safety rating based on compliance review. Satisfactory rating required for carrier approval.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association (NMFTA) for transportation companies. Used in EDI transactions and shipping documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCoverageRegion rdf:type rdf:Property ;
    rdfs:label 'Service Coverage Region' ;
    rdfs:comment 'Geographic regions where the carrier provides transportation services. Free-text description of coverage area (e.g., US Midwest, Eastern Seaboard, National).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Primary mode of transportation service offered by the carrier. Defines equipment type and service level capability. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|intermodal|refrigerated|dry_van|flatbed|tanker — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature in Celsius that the carriers refrigerated equipment can maintain. Critical for chilled food distribution.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature in Celsius that the carriers refrigerated equipment can maintain. Critical for frozen food distribution.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryRouteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Id' ;
    rdfs:comment 'Unique identifier for the delivery route. Primary key for the delivery route entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryRoute .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: In F&B pre-sell DSD operations, delivery routes are coordinated with assigned sales reps who pre-sell the route stops. Linking route to rep enables rep-level route performance reporting, commission ca' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:actualMileage rdf:type rdf:Property ;
    rdfs:label 'Actual Mileage' ;
    rdfs:comment 'Actual total mileage driven during route execution, captured from vehicle telematics or odometer readings. Used for cost analysis and route optimization.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesDelivered rdf:type rdf:Property ;
    rdfs:label 'Cases Delivered' ;
    rdfs:comment 'Total number of product cases successfully delivered to customers during route execution. Used for fill rate calculation and revenue recognition.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesLoaded rdf:type rdf:Property ;
    rdfs:label 'Cases Loaded' ;
    rdfs:comment 'Total number of product cases loaded onto the vehicle at route start. Used for inventory reconciliation and load planning analysis.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casesRefused rdf:type rdf:Property ;
    rdfs:label 'Cases Refused' ;
    rdfs:comment 'Total number of product cases refused by customers during delivery due to quality issues, order discrepancies, or receiving problems. Subset of cases_returned.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casesReturned rdf:type rdf:Property ;
    rdfs:label 'Cases Returned' ;
    rdfs:comment 'Total number of product cases returned to the distribution center undelivered. Includes unsold inventory from DSD routes and refused deliveries.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashCollected rdf:type rdf:Property ;
    rdfs:label 'Cash Collected' ;
    rdfs:comment 'Total cash payments collected from customers during route execution. Applicable primarily to DSD routes with cash-on-delivery transactions. Used for cash reconciliation.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkCollected rdf:type rdf:Property ;
    rdfs:label 'Check Collected' ;
    rdfs:comment 'Total check payments collected from customers during route execution. Applicable primarily to DSD routes. Used for accounts receivable reconciliation.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this route requires temperature-controlled (refrigerated or frozen) transportation to maintain product quality and food safety compliance. True if any stop requires cold chain.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Actual timestamp when the driver returned to the distribution center and completed route execution. Used for route duration analysis and driver shift management.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Planned total duration for route completion in minutes, including drive time, stop time, and loading/unloading. Used for driver scheduling and shift planning.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedMileage rdf:type rdf:Property ;
    rdfs:label 'Estimated Mileage' ;
    rdfs:comment 'Planned total mileage for the route in miles, based on stop sequence and routing optimization. Used for cost estimation and vehicle assignment.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The specific date on which this route instance was executed. For route execution records, this is the primary business event date. For route master records, this field may be null.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fillRatePct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Pct' ;
    rdfs:comment 'Percentage of ordered cases that were successfully delivered on this route. Calculated as (cases_delivered / cases_loaded) * 100. Key metric for order fulfillment performance.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumedGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Gallons' ;
    rdfs:comment 'Total fuel consumed during route execution in gallons. Captured from vehicle telematics or fuel card transactions. Used for cost allocation and sustainability reporting.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handheldDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Handheld Device Code' ;
    rdfs:comment 'Identifier of the mobile handheld device (scanner, tablet, or mobile computer) used by the driver for proof of delivery, order capture, and route tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether this route transports hazardous materials requiring special handling, placarding, and driver certification per DOT regulations.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifPerformancePct rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Pct' ;
    rdfs:comment 'Percentage of deliveries on this route that met both on-time and in-full criteria. Key performance indicator for distribution service level. Calculated as (on-time and in-full deliveries / total planned deliveries) * 100.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Business identifier for the route, used for operational reference and scheduling. Typically alphanumeric code assigned by transportation management system.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Route Completion Status' ;
    rdfs:comment 'Overall completion status of the route execution instance. COMPLETED indicates all planned stops were attempted, PARTIAL indicates some stops were skipped, CANCELLED indicates route was aborted, IN_PROGRESS indicates route is currently being executed, NOT_STARTED indicates route has not yet begun.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the route, often including geographic or customer references (e.g., \'Downtown Chicago Loop\', \'Northeast Territory A\').' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the route template. ACTIVE routes are in regular operation, INACTIVE are temporarily not in use, SUSPENDED are on hold pending review, PLANNED are designed but not yet operational, RETIRED are permanently discontinued.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on delivery model. DSD (Direct Store Delivery) for direct-to-retail routes, DC_TO_RETAIL for distribution center to retail, FOODSERVICE for restaurant/institutional delivery, DTC for direct-to-consumer, CROSS_DOCK for cross-docking operations, BACKHAUL for return logistics.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Days Of Week' ;
    rdfs:comment 'Comma-separated list of days when route is scheduled to run (e.g., \'MON,WED,FRI\'). Applicable for WEEKLY and BIWEEKLY frequency routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Actual timestamp when the driver departed the distribution center to begin route execution. Used for OTIF (On Time In Full) performance tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopCount rdf:type rdf:Property ;
    rdfs:label 'Stop Count' ;
    rdfs:comment 'Number of planned delivery stops on this route. Used for route complexity assessment and driver workload planning.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Stops Completed' ;
    rdfs:comment 'Number of delivery stops successfully completed during this route execution. Used to calculate route completion rate and identify service failures.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Stops Planned' ;
    rdfs:comment 'Number of delivery stops planned for this route execution instance. Used to calculate route completion rate.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRangeMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max F' ;
    rdfs:comment 'Maximum acceptable temperature in Fahrenheit for cold chain routes. Used for temperature monitoring and compliance verification. Null for non-cold-chain routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min F' ;
    rdfs:comment 'Minimum acceptable temperature in Fahrenheit for cold chain routes. Used for temperature monitoring and compliance verification. Null for non-cold-chain routes.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Type of vehicle required to execute this route based on cargo volume, weight, and special handling requirements. Determines vehicle assignment from fleet.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billToLocationId rdf:type rdf:Property ;
    rdfs:label 'Bill To Location Id' ;
    rdfs:comment 'Foreign key linking to customer.bill_to_location. Business justification: Order-to-invoice matching in F&B requires linking fulfillment orders to the bill-to entity at order creation. Retail chains use centralized billing (bill-to differs from ship-to). Enables invoice gene' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillToLocation .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date the order shipped from the distribution center. Used for OTIF performance measurement and variance analysis against planned and requested dates.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Timestamp' ;
    rdfs:comment 'The date and time the Advanced Shipping Notice was transmitted to the customer. Used for EDI compliance tracking and customer service level measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order is designated for cross-docking operations, where goods move directly from receiving to shipping without intermediate storage. True indicates cross-dock handling; false indicates standard warehouse flow with putaway and storage.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The precise date and time the order was delivered to the customer. Captured from proof of delivery or carrier tracking. Used for OTIF measurement and service level compliance.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying the type of exception or disruption encountered during fulfillment execution. Examples include inventory shortage, damaged product, carrier delay, address error, or customer request change. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of the exception or disruption encountered during fulfillment. Provides context for resolution actions and root cause investigation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Status' ;
    rdfs:comment 'Current status of exception resolution efforts. Open indicates exception has been identified but not yet addressed; in_progress indicates resolution actions are underway; resolved indicates exception has been successfully resolved; escalated indicates exception requires management intervention.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'The percentage of the order quantity that was successfully fulfilled and shipped. Calculated as shipped quantity divided by ordered quantity. Used for service level measurement and inventory availability analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The business channel through which this order is being fulfilled. Determines handling requirements, service level expectations, and routing logic. Retail represents traditional grocery and mass merchandiser channels; foodservice represents restaurant and institutional channels; direct-to-consumer (DTC) represents online orders shipped to individual consumers; direct store delivery (DSD) represents orders delivered directly to retail stores bypassing DC consolidation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Business-readable unique identifier for the fulfillment order. Used for operational tracking, communication with warehouse staff, and customer service inquiries.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle status of the fulfillment order within the distribution execution process. Released indicates order is available for wave assignment; wave_assigned indicates order is assigned to a picking wave; picking indicates order is actively being picked; picked indicates picking is complete; packing indicates order is being packed; packed indicates packing is complete; staged indicates order is staged for loading; loaded indicates order is loaded on carrier vehicle; shipped indicates order has departed the DC; in_transit indicates order is en route to destination; delivered indicates order has been received by customer; exception indicates order has encountered a problem requiring intervention; cancelled indicates order has been cancelled. [ENUM-REF-CANDIDATE: released|wave_assigned|picking|picked|packing|packed|staged|loaded|shipped|in_transit|delivered|exception|cancelled — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Release Timestamp' ;
    rdfs:comment 'The date and time the fulfillment order was released from the order management system to the warehouse management system for execution. Marks the start of the fulfillment lifecycle.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Target Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order is included in On-Time In-Full performance measurement. True indicates order is subject to OTIF service level agreements; false indicates order is excluded from OTIF metrics (e.g., sample orders, internal transfers).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Complete Timestamp' ;
    rdfs:comment 'The date and time when all picking operations were completed for this fulfillment order. Used for cycle time analysis and throughput measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Start Timestamp' ;
    rdfs:comment 'The date and time when picking operations began for this fulfillment order. Used for cycle time analysis and warehouse productivity measurement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The date the distribution center plans to ship the order based on capacity, inventory availability, and carrier schedules. May differ from requested ship date due to operational constraints.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date committed to the customer for delivery of the order. Used for On-Time In-Full (OTIF) performance measurement and customer service level tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date the customer or sales order requested the order to ship from the distribution center. Used for planning and scheduling warehouse operations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'The precise date and time the order departed the distribution center. Used for transit time calculation and carrier performance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCases rdf:type rdf:Property ;
    rdfs:label 'Total Order Cases' ;
    rdfs:comment 'The total number of cases or cartons in the fulfillment order. Used for warehouse productivity measurement, handling cost allocation, and load planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderLines rdf:type rdf:Property ;
    rdfs:label 'Total Order Lines' ;
    rdfs:comment 'The total number of distinct line items or SKUs in the fulfillment order. Used for picking complexity assessment and labor planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderPallets rdf:type rdf:Property ;
    rdfs:label 'Total Order Pallets' ;
    rdfs:comment 'The total number of pallets in the fulfillment order, including partial pallets expressed as decimal values. Used for transportation planning, dock scheduling, and freight cost calculation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'The total cubic volume of the fulfillment order in cubic meters. Used for warehouse space planning, vehicle capacity utilization, and freight cost calculation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'The total gross weight of the fulfillment order in kilograms, including product and packaging. Used for carrier selection, freight cost calculation, and load planning.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for shipment visibility and proof of delivery. Used for customer service inquiries and delivery status monitoring.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Line Id' ;
    rdfs:comment 'Unique identifier for the fulfillment order line item. Primary key for this entity.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionLineId rdf:type rdf:Property ;
    rdfs:label 'Promotion Line Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_line. Business justification: Each order line may be driven by a specific promotion line; linking enables accurate promotion ROI and claim reconciliation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionLine .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when inventory was allocated to this line. Marks the beginning of the fulfillment process.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether unfulfilled quantity from this line was placed on backorder for future fulfillment. Used for backorder management and customer service.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Number of cartons or cases used to fulfill this line. Used for packaging and freight calculation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catchWeightActual rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Actual' ;
    rdfs:comment 'Actual weight for catch-weight items where weight varies by unit. Used for variable-weight products like fresh produce, meat, or cheese.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightUom rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Uom' ;
    rdfs:comment 'Unit of measure for catch weight. Defines whether weight is expressed in pounds, kilograms, ounces, or grams.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoPickFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Pick Flag' ;
    rdfs:comment 'Indicates whether this line was picked using FEFO logic to ensure oldest expiration dates are shipped first. Critical for perishable food and beverage products.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value for this line (quantity × unit price). Used for order value calculation and financial reporting.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'Original SKU that was ordered if a substitution was made. Null if no substitution occurred.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'Date and time when the line was packed for shipment. Used for packing efficiency and order completion tracking.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse zone or area where the product was picked. Used for labor planning and zone-based picking strategies.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'Date and time when the line was physically picked from warehouse inventory. Used for pick productivity and cycle time analysis.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date the product was manufactured or packaged. Used for shelf life calculation and quality tracking.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Trade promotion or discount code applied to this line. Used for TPM tracking and promotional effectiveness analysis.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Flag' ;
    rdfs:comment 'Indicates whether this line underwent quality inspection before shipment. Used for quality assurance and food safety compliance.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity of the SKU shipped to the customer. Final quantity that left the distribution center.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when the line was shipped from the distribution center. Used for OTIF calculation and ASN generation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code explaining why the line was short-shipped or not fully fulfilled. Used for fill rate analysis and root cause investigation.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal stock keeping unit code identifying the specific product variant being fulfilled. Used for inventory tracking and warehouse operations.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether a product substitution was made for this line due to stockout or customer approval. Used for substitution rate tracking.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Specific warehouse bin or location from which the product was picked. Used for inventory accuracy and slotting optimization.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.location. Business justification: The domain description for the location product explicitly states it is \'Referenced by ship_from_location_id\', confirming this FK is intentionally designed. shipment already has ship_to_location_id → ' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:actualDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Datetime' ;
    rdfs:comment 'Actual date and time when the shipment was delivered to the destination location, used for OTIF and SLA compliance tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Datetime' ;
    rdfs:comment 'Actual date and time when the carrier picked up the shipment from the origin DC, used for OTIF performance tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Datetime' ;
    rdfs:comment 'Date and time when the ASN was transmitted to the customer, used for EDI compliance and customer notification tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnSentFlag rdf:type rdf:Property ;
    rdfs:label 'Asn Sent Flag' ;
    rdfs:comment 'Indicates whether an EDI 856 Advanced Shipping Notice has been transmitted to the customer or receiving facility.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Total number of cases or cartons included in the shipment across all pallets.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Code indicating any delivery exception or issue encountered during shipment (e.g., damaged product, refused delivery, address error, weather delay).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Notes' ;
    rdfs:comment 'Free-text notes describing any delivery exceptions, issues, or special circumstances encountered during shipment execution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Flag' ;
    rdfs:comment 'Indicates whether this shipment is part of a DSD route where products are delivered directly to retail stores, bypassing retailer DCs.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight cost charged by the carrier for this shipment, used for freight spend analysis and accrual.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight cost amount.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingSequence rdf:type rdf:Property ;
    rdfs:label 'Loading Sequence' ;
    rdfs:comment 'Instructions or sequence identifier for how pallets should be loaded into the trailer to optimize delivery route and unloading efficiency.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for the shipment to maintain product quality and safety during transit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for the shipment to maintain product quality and safety during transit.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment met OTIF performance criteria (delivered on time and with complete order quantity), a key supply chain KPI.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'Name of the person who signed for the delivery at the destination location, captured as part of proof of delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time when the proof of delivery was captured, typically matching or closely following the actual delivery datetime.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proofOfDeliveryReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received Flag' ;
    rdfs:comment 'Indicates whether proof of delivery documentation (signature, photo, or electronic confirmation) has been received from the carrier or customer.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Datetime' ;
    rdfs:comment 'Planned date and time when the shipment is scheduled to arrive at the destination location.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledPickupDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Datetime' ;
    rdfs:comment 'Planned date and time when the carrier is scheduled to pick up the shipment from the origin DC.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the trailer or container to ensure tamper-evidence and cargo integrity during transit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known business identifier for the shipment, used for tracking and communication with carriers and customers.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequence rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence' ;
    rdfs:comment 'The sequence number of this delivery stop within the overall route, used for route planning and driver instructions.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Temperature control requirement for the shipment to maintain cold chain compliance and product quality (ambient, refrigerated, frozen, or controlled).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZoneSegregationFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Segregation Flag' ;
    rdfs:comment 'Indicates whether the shipment contains products requiring segregation into multiple temperature zones within the same trailer.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cube M3' ;
    rdfs:comment 'Total volumetric cube of the shipment in cubic meters, used for load planning and carrier billing.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including product, packaging, and pallets.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'The trailer, container, or vehicle identification number assigned to this shipment for physical transport.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of trailer or container capacity utilized by this shipment, calculated based on weight or cube constraints.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Unique identifier for the proof of delivery record.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProofOfDelivery .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Reference to the delivery order fulfilled by this delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: POD confirmation triggers invoice release for payment in F&B AR processes. The proof_of_delivery has an invoice_matched boolean flag but no FK to the actual invoice record. Accounts receivable teams m' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the delivery was completed and goods were received, critical for OTIF measurement and invoice matching.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:casesDeliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Delivered Quantity' ;
    rdfs:comment 'Actual number of cases successfully delivered and accepted by the receiver, used for fill rate calculation.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesOrderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Ordered Quantity' ;
    rdfs:comment 'Total number of cases that were originally ordered and scheduled for delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casesRefusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cases Refused Quantity' ;
    rdfs:comment 'Number of cases refused or rejected by the receiver at the time of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainCompliant rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant' ;
    rdfs:comment 'Indicates whether the delivery met cold chain temperature requirements throughout transit and at delivery, ensuring food safety and quality for perishable products.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryConditionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition Code' ;
    rdfs:comment 'Standardized code indicating the overall condition of the delivered goods at the time of receipt.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition Notes' ;
    rdfs:comment 'Free-text notes describing the condition of the delivered goods, including any damage, quality concerns, or packaging issues observed at delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPhotoCaptured rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Captured' ;
    rdfs:comment 'Indicates whether photographic evidence of the delivery was captured via mobile device or ePOD system.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Url' ;
    rdfs:comment 'URL or storage path to the delivery photo image file, used for proof of delivery and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the delivery in its lifecycle workflow.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaised rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised' ;
    rdfs:comment 'Indicates whether a delivery dispute has been raised by the customer or carrier regarding this proof of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time of delivery, used for delivery verification and route optimization analytics.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time of delivery, used for delivery verification and route optimization analytics.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the full ordered quantity was delivered without shortages, used for fill rate and in-full delivery KPI measurement.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceMatched rdf:type rdf:Property ;
    rdfs:label 'Invoice Matched' ;
    rdfs:comment 'Indicates whether the proof of delivery has been successfully matched to the corresponding invoice for three-way matching (PO, receipt, invoice).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the delivery was completed within the scheduled time window, used for on-time delivery KPI measurement.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifCompliant rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant' ;
    rdfs:comment 'Indicates whether the delivery met On Time In Full (OTIF) performance criteria: delivered on scheduled date within time window and with full ordered quantity.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'Method used to capture the proof of delivery: electronic POD device, paper scan, EDI 214 Transportation Carrier Shipment Status Message, mobile application, or no signature required.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'Externally-known unique business identifier for the proof of delivery document, used for tracking and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'Full name of the individual who received and signed for the delivery at the customer location.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature Captured' ;
    rdfs:comment 'Indicates whether a digital or physical signature was captured from the receiver as proof of receipt.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiverTitle rdf:type rdf:Property ;
    rdfs:label 'Receiver Title' ;
    rdfs:comment 'Job title or role of the individual who received the delivery (e.g., Store Manager, Receiving Clerk, Warehouse Supervisor).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for refusal or rejection of delivered goods. [ENUM-REF-CANDIDATE: damaged|expired|wrong_product|overage|quality_issue|no_order|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusalReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional detail about the reason for refusal, used for dispute resolution and quality investigation.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for the delivery, used for On Time In Full (OTIF) measurement and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window End' ;
    rdfs:comment 'End of the scheduled delivery time window, used for precise delivery appointment tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window Start' ;
    rdfs:comment 'Start of the scheduled delivery time window, used for precise delivery appointment tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or storage path to the digital signature image file captured via electronic Proof of Delivery (ePOD) device.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Sequential stop number on the delivery route, used for route optimization and last-mile logistics tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureAtDeliveryCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Delivery Celsius' ;
    rdfs:comment 'Recorded temperature of the delivery at the time of receipt, critical for cold chain compliance and food safety verification for refrigerated and frozen products.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion (deviation from acceptable range) occurred during transit or at delivery, requiring quality review.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainEventId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Event Id' ;
    rdfs:comment 'Unique identifier for the cold chain monitoring event record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColdChainEvent .

ind:originLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.location. Business justification: cold_chain_event.origin_location_code is a STRING field representing the origin facility of a cold chain event. The location table is the master reference for distribution locations (with location_cod' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:alertNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether an automated alert notification was sent to responsible personnel when the excursion was detected (True if sent, False if not sent).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertRecipientList rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user IDs that received the temperature excursion alert notification.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Asset Identifier' ;
    rdfs:comment 'Unique identifier or code for the specific cold chain asset (e.g., trailer number, zone code, reefer unit serial number).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Type of cold chain asset being monitored (trailer, distribution center zone, reefer unit, container, warehouse room, or transport vehicle).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brixMeasurement rdf:type rdf:Property ;
    rdfs:label 'Brix Measurement' ;
    rdfs:comment 'Sugar content measurement in degrees Brix if applicable to the product being monitored (primarily for beverages and fruit products).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when corrective action was initiated in response to the temperature excursion.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Final disposition decision for the product following temperature excursion review (approved for sale, rejected, quarantined, pending review, or destroyed).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the temperature monitoring event was recorded in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the temperature remained outside the acceptable range during the excursion event.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Boolean indicator of whether the recorded temperature exceeded the acceptable range (True if excursion occurred, False if within range).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'Classification of the temperature excursion severity based on duration and deviation magnitude (minor, moderate, major, or critical).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cold chain asset at the time of the temperature reading.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cold chain asset at the time of the temperature reading.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the cold chain event monitoring and response met HACCP critical control point requirements (True if compliant, False if non-compliant).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage in the cold chain environment if monitored alongside temperature.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMeasurement rdf:type rdf:Property ;
    rdfs:label 'Ph Measurement' ;
    rdfs:comment 'Acidity or alkalinity measurement on the pH scale if applicable to the product being monitored (critical for food safety and quality).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level category of food or beverage product being transported or stored in the cold chain asset. [ENUM-REF-CANDIDATE: dairy|beverage|frozen|fresh_produce|meat|seafood|prepared_foods — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether the product was placed on quality hold due to the temperature excursion (True if on hold, False if released).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordedTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Recorded Temperature Celsius' ;
    rdfs:comment 'Actual temperature reading captured by the sensor in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Recorded Temperature Fahrenheit' ;
    rdfs:comment 'Actual temperature reading captured by the sensor in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the temperature excursion severity requires reporting to regulatory authorities such as FDA or USDA (True if reporting required, False if not required).' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report was submitted to the appropriate governing body if required.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Unique identifier for the temperature monitoring sensor or device that captured the reading.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature threshold for the cold chain asset in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMaxFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max Fahrenheit' ;
    rdfs:comment 'Maximum acceptable temperature threshold for the cold chain asset in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature threshold for the cold chain asset in degrees Celsius.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min Fahrenheit' ;
    rdfs:comment 'Minimum acceptable temperature threshold for the cold chain asset in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRecordId rdf:type rdf:Property ;
    rdfs:label 'Otif Record Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtifRecord .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer account for which OTIF performance is being measured.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:casesOrdered rdf:type rdf:Property ;
    rdfs:label 'Cases Ordered' ;
    rdfs:comment 'The total number of cases ordered by the customer in the fulfillment order.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackReference rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reference' ;
    rdfs:comment 'Reference number for the retailer chargeback or deduction associated with this OTIF failure.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when this OTIF record was closed after resolution or penalty payment.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Window End' ;
    rdfs:comment 'The end of the delivery time window committed to the customer, used to determine on-time performance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Window Start' ;
    rdfs:comment 'The start of the delivery time window committed to the customer, used to determine on-time performance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference to the corrective action plan or ticket created to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDestinationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination Type' ;
    rdfs:comment 'The type of destination location for the delivery (e.g., retail store, distribution center, foodservice, direct-to-consumer).' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether this OTIF failure has been escalated to senior management due to severity or repeat occurrence.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Otif Composite Score' ;
    rdfs:comment 'The composite OTIF performance score, typically expressed as a percentage (0-100), representing the combined on-time and in-full achievement.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyFineAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Fine Amount' ;
    rdfs:comment 'The monetary penalty or fine amount assessed by the retailer for OTIF non-compliance.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the OTIF record (e.g., created, under investigation, resolved, penalty paid, closed). [ENUM-REF-CANDIDATE: created|under_investigation|root_cause_identified|corrective_action_assigned|resolved|penalty_paid|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational unit or individual responsible for managing this OTIF record and corrective actions.' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the OTIF miss (e.g., carrier delay, DC late release, inventory shortage, weather event). [ENUM-REF-CANDIDATE: carrier_delay|dc_late_release|inventory_short|weather|traffic|equipment_failure|labor_shortage|system_error|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtifRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause analysis for the OTIF failure.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether cold chain temperature requirements were maintained throughout delivery (True = compliant, False = breach).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSegregationFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Segregation Flag' ;
    rdfs:comment 'Indicates whether the stock contains major allergens and requires physical segregation to prevent cross-contamination.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryStatus rdf:type rdf:Property ;
    rdfs:label 'Expiry Status' ;
    rdfs:comment 'Classification of the stock based on remaining shelf life. Valid indicates sufficient shelf life; near-expiry indicates approaching expiration threshold; expired indicates past SLED; no-expiry indicates shelf-stable products without expiration date.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent goods movement transaction affecting this stock position (receipt, issue, transfer, or adjustment).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotTraceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Code' ;
    rdfs:comment 'External lot or batch code used for supply chain traceability and recall management. May differ from internal lot ID.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBlocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Blocked' ;
    rdfs:comment 'Quantity restricted from use due to quality issues, regulatory holds, or pending disposition (rework, scrap, return to vendor).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Quantity currently in movement between locations (plant-to-DC, DC-to-DC, or inbound from supplier) but not yet received at destination.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Total physical quantity of the material/lot currently present at the storage location, regardless of availability status.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Quantity Quality Inspection' ;
    rdfs:comment 'Quantity under quality inspection hold pending QA release. Cannot be used until inspection results are approved.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity allocated to specific sales orders, production orders, or transfer orders but not yet physically moved.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether the stock is subject to an active product recall and must be segregated and disposed per recall procedures.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Flag' ;
    rdfs:comment 'Indicates whether this stock position is designated as safety stock buffer to protect against demand variability and supply disruptions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Date after which the product should not be sold or consumed. Critical for FEFO lot management and food safety compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Classification for non-standard stock ownership or purpose. Consignment is vendor-owned stock at customer location; customer-owned is stock held on behalf of customer; project is allocated to specific project; sample is for testing; promotional is for marketing programs. [ENUM-REF-CANDIDATE: consignment|customer_owned|vendor_owned|project|sample|promotional|standard — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAgeDays rdf:type rdf:Property ;
    rdfs:label 'Stock Age Days' ;
    rdfs:comment 'Number of days since the stock was received at the storage location. Used for slow-moving and obsolete inventory analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of stock status indicating availability and restrictions. On-hand is total physical stock; available is unrestricted and not reserved; reserved is allocated to orders; in-transit is goods in movement; quality-inspection is under QA hold; blocked is restricted due to quality or regulatory issues.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total monetary value of the stock position calculated using the applicable valuation method (standard cost, moving average, FIFO). Used for inventory accounting and financial reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the valuation amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorLotNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Lot Number' ;
    rdfs:comment 'Supplier-provided lot or batch number for raw materials and co-packed products. Used for upstream traceability.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenSegregationClass rdf:type rdf:Property ;
    rdfs:label 'Allergen Segregation Class' ;
    rdfs:comment 'Allergen segregation classification for the storage location. Ensures physical separation of allergen-containing products to prevent cross-contamination. [ENUM-REF-CANDIDATE: none|peanut|tree_nut|dairy|gluten|soy|shellfish|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions available in this storage location. Key metric for warehouse slotting and inventory planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Total storage capacity of the location measured in cubic meters. Used for space utilization analytics and capacity planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms. Critical for structural safety and load planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Erp Storage Location' ;
    rdfs:comment 'Storage location code as defined in the ERP system (e.g., SAP S/4HANA storage location). Used for financial valuation and inventory accounting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FEFO lot rotation based on expiration dates is enforced at this storage location. Critical for perishable goods management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FIFO lot rotation is enforced at this storage location. True if FIFO rules are active.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the storage location is certified to store hazardous materials. True if HAZMAT certification is active.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent quality or safety inspection of the storage location. Used for compliance tracking and audit readiness.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier for the storage location used in warehouse management systems and operational documents. Typically follows plant-site-aisle-bin hierarchy (e.g., PLT01-DC01-A12-B05).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the storage location (e.g., \'Chicago DC Frozen Zone A\', \'Plant 3 Raw Material Staging\').' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location by its primary operational purpose within the supply chain network. [ENUM-REF-CANDIDATE: plant|distribution_center|3pl_warehouse|cold_storage|staging_area|quarantine_zone|finished_goods|raw_material — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required inspection of the storage location. Supports proactive compliance management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Max' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for this storage location. Exceeding this threshold triggers quality alerts.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Min' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for this storage location. Used for cold chain monitoring and compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Wms Location Code' ;
    rdfs:comment 'External location identifier used by the warehouse management system. Enables integration with WMS for real-time inventory tracking.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Unique identifier for the goods movement transaction. Primary key for this entity. Serves as the immutable reference for all inventory state changes across the enterprise.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsMovement .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: goods_movement records inventory state changes between locations. The source_storage_location field is a denormalized STRING. Adding source_storage_location_id FK to storage_location normalizes the so' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_transfer_order. Business justification: In SAP WM/EWM-aligned inventory operations, goods movements are posted against stock transfer orders. Linking goods_movement to stock_transfer_order enables full operational traceability from planned ' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransferOrder .

ind:amountLc rdf:type rdf:Property ;
    rdfs:label 'Amount Lc' ;
    rdfs:comment 'The financial value of the movement in the local currency of the plant. Calculated as quantity × standard cost or moving average price. Positive for receipts, negative for issues. Used for COGS posting and inventory valuation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer identifier for goods issue movements to external customers or for customer returns. Nullable for internal movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'For transfer movements, the plant to which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'For transfer movements, the storage location to which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The system timestamp when the goods movement was posted in the ERP system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Distinct from posting_date which is the financial effective date.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Item' ;
    rdfs:comment 'Line item number within the material document. Allows multiple movements to be grouped under a single document header.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'High-level classification of the movement direction and purpose. Receipt increases stock, issue decreases stock, transfer moves between locations, adjustment corrects quantity or value, reversal cancels a prior posting, reclassification changes stock type without location change.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Business reason for the movement. Examples: production consumption, customer return, quality rejection, cycle count adjustment, obsolescence, damage, theft, donation, sample. Used for root cause analysis and variance reporting.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'Line item number within the reference document. Nullable for document types without line items.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The material document number of the original posting that this movement reverses. Nullable if reversal_indicator is false.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Year' ;
    rdfs:comment 'The fiscal year of the original posting that this movement reverses. Nullable if reversal_indicator is false.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'For transfer movements, the plant from which the material is being moved. Nullable for non-transfer movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The storage location within the plant where the material is physically located. Sub-division of plant for inventory management.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Storage Location Id' ;
    rdfs:comment 'Identifier of the receiving location to which stock is being transferred. May reference plant, distribution center, or third-party logistics (3PL) facility.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryStockStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Storage Location Id' ;
    rdfs:comment 'Identifier of the originating location from which stock is being transferred. May reference plant, distribution center, or third-party logistics (3PL) facility.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date when stock was received at the destination location. Captured at goods receipt posting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Shipment Date' ;
    rdfs:comment 'Actual date when stock was shipped from the source location. Captured at goods issue posting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancelledReason rdf:type rdf:Property ;
    rdfs:label 'Cancelled Reason' ;
    rdfs:comment 'Free-text explanation for why this transfer order was cancelled. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Maximum Temperature C' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for this transfer. Used for cold chain monitoring and compliance verification.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Minimum Temperature C' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for this transfer. Used for cold chain monitoring and compliance verification.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTransferDate rdf:type rdf:Property ;
    rdfs:label 'Planned Transfer Date' ;
    rdfs:comment 'Target date for initiating the stock transfer. Used for planning warehouse resources, transportation capacity, and inventory positioning.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Planned quantity to be transferred as specified in the transfer order. Represents the target amount for the transfer.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeRemainingDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Remaining Days' ;
    rdfs:comment 'Number of days of shelf life remaining at the time of transfer initiation. Critical for FEFO (First Expired First Out) inventory management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Special handling requirements for this transfer. Determines warehouse handling procedures, packaging requirements, and transportation mode.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this transfer requires temperature-controlled transportation and handling. Critical for perishable food and beverage products.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Cost Amount' ;
    rdfs:comment 'Total cost associated with this stock transfer including transportation, handling, and administrative costs. Used for supply chain cost analysis.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-known business identifier for the stock transfer order. Used for tracking and reference across systems and documents.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason or trigger for the stock transfer. Used for analytics, cost allocation, and supply chain optimization.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the stock transfer order. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer based on source and destination location types. Determines routing, handling requirements, and approval workflows.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Calculated inventory accuracy percentage for this cycle count, representing the ratio of items counted correctly to total items counted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCountDate rdf:type rdf:Property ;
    rdfs:label 'Actual Count Date' ;
    rdfs:comment 'Actual date when the physical count was performed. May differ from scheduled date due to operational constraints.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date when audit review of the cycle count was completed and findings documented. Null if no audit required or not yet completed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this cycle count is subject to internal or external audit review due to materiality or compliance requirements. True if audit required, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Completion Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count activity was completed and all items were counted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Count Duration Minutes' ;
    rdfs:comment 'Total duration in minutes from count start to count completion. Used for labor efficiency analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used to perform the physical count: manual (paper-based), barcode scan (handheld scanner), RFID (radio frequency identification), automated system (WMS-driven), blind count (no system quantity shown), or guided count (system quantity visible).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countPlanReference rdf:type rdf:Property ;
    rdfs:label 'Count Plan Reference' ;
    rdfs:comment 'Reference to the master cycle count plan or schedule that triggered this count event. Used for planned cycle counts.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count activity was initiated. Used to track count duration and labor efficiency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Type of inventory count being performed: full physical inventory (complete stock take), cycle count (scheduled rotation), spot check (ad-hoc verification), wall-to-wall (complete facility count), ABC cycle (frequency based on value), or perpetual inventory (continuous counting).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterAssigned rdf:type rdf:Property ;
    rdfs:label 'Counter Assigned' ;
    rdfs:comment 'Name or employee ID of the warehouse worker or team assigned to perform the physical count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count: planned (scheduled but not started), in-progress (counting underway), completed (count finished, awaiting reconciliation), reconciled (variances resolved and posted), cancelled (count aborted), or on-hold (temporarily suspended).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze End Timestamp' ;
    rdfs:comment 'Timestamp when inventory freeze was lifted and normal operations resumed. Null if no freeze applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freezeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze Start Timestamp' ;
    rdfs:comment 'Timestamp when inventory movements were frozen for the count. Null if no freeze applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryFreezeFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Freeze Flag' ;
    rdfs:comment 'Indicates whether inventory movements were frozen during the count to ensure accuracy. True if frozen, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotTraceabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Required Flag' ;
    rdfs:comment 'Indicates whether lot-level traceability is required for items in this cycle count due to FSMA or food safety regulations. True if lot tracking required, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalInventoryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document Number' ;
    rdfs:comment 'SAP physical inventory document number generated for this cycle count event. Maps to SAP MI01/MI04 document.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when inventory variances were reconciled and adjustments posted to the general ledger and inventory records.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes documenting the reconciliation process, root cause analysis of variances, and corrective actions taken.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Recount Completion Date' ;
    rdfs:comment 'Date when the recount was completed, if a recount was required. Null if no recount performed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to variances exceeding threshold or data quality concerns. True if recount needed, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the cycle count to be performed. Set during count planning phase.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorAssigned rdf:type rdf:Property ;
    rdfs:label 'Supervisor Assigned' ;
    rdfs:comment 'Name or employee ID of the supervisor responsible for overseeing and validating the cycle count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Items Counted' ;
    rdfs:comment 'Total number of distinct SKUs or line items included in this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceItems rdf:type rdf:Property ;
    rdfs:label 'Total Variance Items' ;
    rdfs:comment 'Number of items where physical count differed from book inventory, exceeding the variance threshold.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'Total financial value of inventory variances identified during the cycle count, calculated using standard cost or moving average price.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of book quantity before a recount or investigation is triggered.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Quantity' ;
    rdfs:comment 'Acceptable variance threshold in quantity units before a recount or investigation is triggered. Set based on item value and criticality.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'System-generated unique identifier for the inventory adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentReclassTargetLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reclass Target Location Storage Location Id' ;
    rdfs:comment 'Destination location identifier for inventory reclassification adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:adjustmentReclassTargetMaterialSkuId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reclass Target Material Sku Id' ;
    rdfs:comment 'Destination material (SKU) identifier for reclassification adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:adjustmentSkuId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Sku Id' ;
    rdfs:comment 'Identifier of the material (SKU) being adjusted.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:adjustmentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Storage Location Id' ;
    rdfs:comment 'Warehouse, distribution center, or 3PL location where the adjustment took place.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'Identifier of the financial document generated by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'Quantity change resulting from the adjustment (positive for increase, negative for decrease).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value Amount' ;
    rdfs:comment 'Monetary value of the quantity adjustment before accounting postings.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business identifier assigned to the adjustment (e.g., posting number).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Date and time when the adjustment event occurred in the business process.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Category of the inventory adjustment indicating the nature of the change.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAccount rdf:type rdf:Property ;
    rdfs:label 'Credit Account' ;
    rdfs:comment 'General ledger account credited by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAccount rdf:type rdf:Property ;
    rdfs:label 'Debit Account' ;
    rdfs:comment 'General ledger account debited by the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier linking to an external system record (e.g., EDI message).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Net monetary impact of the adjustment after accounting entries.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Valuation method applied to the inventory at the time of adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isManualAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Manual Adjustment' ;
    rdfs:comment 'True if the adjustment was entered manually rather than generated by an automated process.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQualityHold rdf:type rdf:Property ;
    rdfs:label 'Is Quality Hold' ;
    rdfs:comment 'True if the inventory is placed on quality hold as part of the adjustment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityHoldReason rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason' ;
    rdfs:comment 'Reason why the inventory was placed on quality hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level category grouping of adjustment reasons.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the adjustment reason.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the originating event (e.g., cycle count document).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'Type of the originating document that triggered the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxImplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Implication Flag' ;
    rdfs:comment 'Indicates whether the adjustment has tax consequences.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'System-generated unique identifier for each inventory valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustments applied during valuation (e.g., price variance, revaluation).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Code that groups materials for accounting purposes (e.g., raw material, finished goods).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Valuation Amount' ;
    rdfs:comment 'Total value before any adjustments (quantity_on_hand * unit_cost).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or Global Trade Item Number (GTIN) of the material.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Net Valuation Amount' ;
    rdfs:comment 'Final valuation amount after adjustments (gross - adjustments).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Difference between standard cost and actual cost for the material.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Amount added or subtracted to align inventory value with current market or cost changes.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Costing method used for the valuation (Standard Cost, Moving Average, FIFO, LIFO).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Number' ;
    rdfs:comment 'External reference number assigned to the valuation transaction for audit and traceability.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current processing state of the valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valuation Timestamp' ;
    rdfs:comment 'Date and time when the inventory valuation was performed.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downstreamLotRefs rdf:type rdf:Property ;
    rdfs:label 'Downstream Lot Refs' ;
    rdfs:comment 'Identifiers of finished-goods or shipment lots derived from this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsmaOneUpOneDownFlag rdf:type rdf:Property ;
    rdfs:label 'Fsma One Up One Down Flag' ;
    rdfs:comment 'True when the lot must satisfy FSMA one-up/one-down traceability.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCostAmount rdf:type rdf:Property ;
    rdfs:label 'Lot Cost Amount' ;
    rdfs:comment 'Monetary cost attributed to the lot (e.g., material cost).' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Creation Timestamp' ;
    rdfs:comment 'Date-time when the lot traceability record was first created.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotOwner rdf:type rdf:Property ;
    rdfs:label 'Lot Owner' ;
    rdfs:comment 'Name of the party that owns or supplied the lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Category indicating whether the lot is raw material, intermediate, finished good, or packaging.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Result of the most recent quality check performed on the lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Traceability Status' ;
    rdfs:comment 'Indicates the one-up/one-down traceability configuration for the lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationEventCode rdf:type rdf:Property ;
    rdfs:label 'Transformation Event Code' ;
    rdfs:comment 'Identifier of the manufacturing or co-packing event that transformed upstream lots into this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upstreamLotRefs rdf:type rdf:Property ;
    rdfs:label 'Upstream Lot Refs' ;
    rdfs:comment 'Identifiers of ingredient or packaging lots that were combined to create this lot.' ;
    rdfs:domain ind:LotTrace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision taken after review of the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Review Timestamp' ;
    rdfs:comment 'Planned date and time for the hold to be reviewed or resolved.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdInitiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiation Timestamp' ;
    rdfs:comment 'Date and time when the quarantine hold was placed on inventory.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'External reference number used by quality teams to track the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Free-text description providing detailed justification for the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the hold was officially released (nullable if not yet released).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Hold Source System' ;
    rdfs:comment 'Name of the source system that originated the hold record (e.g., SAP QM).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the hold.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Category of the hold indicating the underlying reason such as quality inspection, regulatory, allergen cross-contact, recall, or supplier deviation.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalItem rdf:type rdf:Property ;
    rdfs:label 'Is Critical Item' ;
    rdfs:comment 'True if the held inventory is classified as a critical item for production or supply.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'Amount of inventory (in the unit defined by unit_of_measure) placed under quarantine.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryLotStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lot Status' ;
    rdfs:comment 'Regulatory classification of the lot (e.g., approved, restricted, under review).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the regulatory notice or compliance document (e.g., FDA recall notice).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Primary key for reservation' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reservation .

ind:requestingPartyCode rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Code' ;
    rdfs:comment 'Identifier of the internal or external party that initiated the reservation (e.g., production planner, sales representative, customer).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'Date by which the reserved inventory must be available for the downstream process.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationSource rdf:type rdf:Property ;
    rdfs:label 'Reservation Source' ;
    rdfs:comment 'Origin of the reservation request indicating whether it was generated by a system process, entered manually, or received via an API.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation indicating whether it is still being planned, has been allocated, completed, or terminated.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'The exact date and time when the reservation was created or became effective in the business process.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classifies the purpose of the reservation such as production order, sales order, promotional allocation, maintenance, or stock transfer.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the material that is earmarked for the reservation, expressed in the unit of measure.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Reserved Value Amount' ;
    rdfs:comment 'Monetary value of the reserved quantity based on current cost or price.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.credit_profile. Business justification: Credit information is detailed in credit_profile; moving credit_rating and payment_terms to credit_profile normalizes credit data.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Preferred Supplier Assignment process links each key account to its primary supplier for contract negotiation and service level management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primarySupplierEstablishmentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Establishment Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.establishment_registration. Business justification: Retailers and distributors must verify their primary supplier facilities hold valid FDA/USDA establishment registrations for food safety compliance, supply chain audits, and customer assurance program' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstablishmentRegistration .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Identifier of the sales territory responsible for the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Revenue range band for the account (e.g., <$1M, $1-5M, $5-10M, >$10M).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstOrderDate rdf:type rdf:Property ;
    rdfs:label 'First Order Date' ;
