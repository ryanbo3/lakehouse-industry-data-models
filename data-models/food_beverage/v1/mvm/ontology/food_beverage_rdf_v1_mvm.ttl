ind:coverageTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Broker coverage is defined by territory; replacing free-text field with FK improves consistency and enables territory-level reporting.' ;
