    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Exact timestamp when the accrual was recognized in the financial system.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'True if the accrual has been reversed or cancelled; otherwise False.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionId rdf:type rdf:Property ;
    rdfs:label 'Deduction Id' ;
    rdfs:comment 'System-generated unique identifier for the trade deduction record.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deduction .

ind:promotionClaimId rdf:type rdf:Property ;
    rdfs:label 'Promotion Claim Id' ;
    rdfs:comment 'Foreign key linking to trade.promotion_claim. Business justification: In trade promotion management, retailers take deductions against invoices and submit promotion claims to justify them. Linking deduction to promotion_claim enables deduction-to-claim matching, which i' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionClaim .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the audit log entry capturing change history for this deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackRatePercent rdf:type rdf:Property ;
    rdfs:label 'Chargeback Rate Percent' ;
    rdfs:comment 'Percentage rate applied for chargeback calculations.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCategory rdf:type rdf:Property ;
    rdfs:label 'Deduction Category' ;
    rdfs:comment 'High-level category classifying the nature of the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionDate rdf:type rdf:Property ;
    rdfs:label 'Deduction Date' ;
    rdfs:comment 'Date the deduction was recorded or became effective.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionDescription rdf:type rdf:Property ;
    rdfs:label 'Deduction Description' ;
    rdfs:comment 'Free-text description providing additional context for the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Number' ;
    rdfs:comment 'External business identifier assigned to the deduction by the retailer or distributor.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionStatus rdf:type rdf:Property ;
    rdfs:label 'Deduction Status' ;
    rdfs:comment 'Current processing status of the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionType rdf:type rdf:Property ;
    rdfs:label 'Deduction Type' ;
    rdfs:comment 'Category describing why the deduction was recorded.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the deduction is currently under dispute.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Freight cost component related to the deduction.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Fee Amount' ;
    rdfs:comment 'Handling fee component associated with the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isManualEntry rdf:type rdf:Property ;
    rdfs:label 'Is Manual Entry' ;
    rdfs:comment 'True if the deduction was entered manually rather than via automated feed.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Timestamp when the deduction was processed in the downstream system.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Number' ;
    rdfs:comment 'Reference to external documentation (e.g., claim form) that supports the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.food_safety_audit. Business justification: Retailer trading agreements in F&B routinely require current food safety certifications (BRC, SQF, FSSC) as a compliance condition. Trade compliance managers must link the qualifying audit to the agre' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyAudit .

ind:primaryRetailerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Retailer Account Id' ;
    rdfs:comment 'FK to customer.account' ;
    rdfs:domain ind:RetailerAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the retailer agreement for easy reference.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'External business identifier assigned to the agreement (e.g., contract number).' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Category of the agreement defining the primary commercial mechanism.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Monetary bonus awarded for exceeding performance thresholds.' ;
    rdfs:domain ind:RetailerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusClause rdf:type rdf:Property ;
    rdfs:label 'Bonus Clause' ;
    rdfs:comment 'Text describing bonuses for exceeding performance thresholds.' ;
    rdfs:domain ind:RetailerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coOpAdvertisingAllowance rdf:type rdf:Property ;
    rdfs:label 'Co Op Advertising Allowance' ;
    rdfs:comment 'Monetary allowance for cooperative advertising activities.' ;
    rdfs:domain ind:RetailerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceMeasureMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Measure Method' ;
    rdfs:comment 'Method used to verify retailer compliance with agreement terms.' ;
    rdfs:domain ind:RetailerAgreement ;
    rdf:type owl:DatatypeProperty ;
