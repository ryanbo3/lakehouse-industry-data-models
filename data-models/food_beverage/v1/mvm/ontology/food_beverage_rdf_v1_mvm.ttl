ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Calendar date when the inspection was performed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Method used to conduct the inspection (e.g., visual, laboratory, sensor, taste, microbial).' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCreationDate rdf:type rdf:Property ;
    rdfs:label 'Lot Creation Date' ;
    rdfs:comment 'Date when the material lot was originally created.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotDisposition rdf:type rdf:Property ;
    rdfs:label 'Lot Disposition' ;
    rdfs:comment 'Final disposition of the lot after inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Aggregated outcome of the inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInspected rdf:type rdf:Property ;
    rdfs:label 'Quantity Inspected' ;
    rdfs:comment 'Total quantity of material inspected, expressed in the unit of measure.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material represented by the sample.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Sample Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the sampled quantity.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Reference to the sampling plan applied for this inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Status' ;
    rdfs:comment 'Result of the stock posting operation after inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRecorded rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded' ;
    rdfs:comment 'Temperature measured during inspection, expressed in degrees Celsius.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Decision on whether the inspected material can be used, rejected, or held.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.customer_complaint. Business justification: Customer complaints frequently trigger formal non-conformance investigations. Adding customer_complaint_id to non_conformance provides direct traceability from the NCR back to the originating complain' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:microTestResultId rdf:type rdf:Property ;
    rdfs:label 'Micro Test Result Id' ;
    rdfs:comment 'Foreign key linking to quality.micro_test_result. Business justification: A non-conformance event can be directly triggered by a failed microbiological test result (e.g., Listeria or Salmonella detection). Adding micro_test_result_id to non_conformance provides direct trace' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MicroTestResult .

ind:batchExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Batch Expiration Date' ;
    rdfs:comment 'Calculated expiration date for the batch based on shelf-life.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchProductionDate rdf:type rdf:Property ;
    rdfs:label 'Batch Production Date' ;
    rdfs:comment 'Date on which the batch was manufactured.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity' ;
    rdfs:comment 'Number of units produced in the batch linked to the non-conformance.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Category of the consumer or customer complaint associated with the non-conformance. [ENUM-REF-CANDIDATE: safety|quality|labeling|packaging|taste|odor|appearance — promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintChannel rdf:type rdf:Property ;
    rdfs:label 'Complaint Channel' ;
    rdfs:comment 'Channel through which the complaint was received.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Free-text description of the issue reported by the customer or internal stakeholder.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the cost impact amount.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the non-conformance (e.g., rework, scrap, recall costs).' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Primary classification of the defect causing the non-conformance. [ENUM-REF-CANDIDATE: contamination|label_error|packaging|taste|appearance|foreign_body|microbial|chemical|physical|texture — promote to reference product]' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDurationDays rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Days' ;
    rdfs:comment 'Planned duration of the hold in days.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdLocation rdf:type rdf:Property ;
    rdfs:label 'Hold Location' ;
    rdfs:comment 'Warehouse or storage location where the product is held.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the root cause investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Business identifier assigned to the non-conformance event, used for tracking and reporting.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Quality Metric Unit' ;
    rdfs:comment 'Unit of measure for the quality metric value.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMetricValue rdf:type rdf:Property ;
    rdfs:label 'Quality Metric Value' ;
    rdfs:comment 'Measured value of the primary quality metric (e.g., CFU count, pH).' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Type' ;
    rdfs:comment 'Specific regulatory reporting mechanism applicable to the event.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether the event must be reported to a regulatory authority.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Overall outcome status of the non-conformance handling process.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Risk severity assigned to the non-conformance based on impact and likelihood.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Numeric severity rating (1-5) where higher values indicate greater risk.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin of the non-conformance event, indicating how it was detected.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'System-generated unique identifier for the Corrective and Preventive Action record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when the CAPA actions were actually completed.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attachedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Attached Document Count' ;
    rdfs:comment 'Number of supporting documents attached to the CAPA record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-visible CAPA reference number assigned by quality management (e.g., CAPA-2023-001).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the record is a corrective action or a preventive action.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccnNumber rdf:type rdf:Property ;
    rdfs:label 'Ccn Number' ;
    rdfs:comment 'Identifier of the critical control point (CCP) related to the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the CAPA record was formally closed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action to be implemented.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business department responsible for the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'Method used to verify that the CAPA was effective.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Result' ;
    rdfs:comment 'Result of the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Indicates whether the CAPA record is closed (true) or still open (false).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEffective rdf:type rdf:Property ;
    rdfs:label 'Is Effective' ;
    rdfs:comment 'Indicates whether the CAPA was determined to be effective (true) or not (false).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive action to avoid recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numeric score representing the risk level associated with the issue, used for prioritization.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Method' ;
    rdfs:comment 'Methodology used to determine the root cause (e.g., 5-Why, Fishbone).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level assigned to the issue addressed by the CAPA.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the CAPA actions should be completed.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationResponsible rdf:type rdf:Property ;
    rdfs:label 'Verification Responsible' ;
    rdfs:comment 'Name of the person who performed the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Indicates whether the laboratory is accredited for the test method.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Name of the laboratory analyst who performed the test.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustody rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody' ;
    rdfs:comment 'Record of custody transfers for the sample from collection to analysis.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date the sample was collected from the source.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionLocation rdf:type rdf:Property ;
    rdfs:label 'Collection Location' ;
    rdfs:comment 'Facility, line, or site where the sample was obtained.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Exact date-time when the sample was taken, including time zone.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlSampleType rdf:type rdf:Property ;
    rdfs:label 'Control Sample Type' ;
    rdfs:comment 'Type of control sample used (positive, negative, or blank).' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'Analytical detection limit for the test method.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Unit' ;
    rdfs:comment 'Unit of measure for the detection limit.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incubationTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature C' ;
    rdfs:comment 'Temperature at which the sample was incubated.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incubationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Time Hours' ;
    rdfs:comment 'Duration of incubation for the test.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isControlSample rdf:type rdf:Property ;
    rdfs:label 'Is Control Sample' ;
    rdfs:comment 'True if the sample is a quality control (positive/negative) sample.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFail rdf:type rdf:Property ;
    rdfs:label 'Pass Fail' ;
    rdfs:comment 'Overall pass/fail determination based on result criteria.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'True if the test result meets applicable regulatory criteria (e.g., FSMA limits).' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultInterpretation rdf:type rdf:Property ;
    rdfs:label 'Result Interpretation' ;
    rdfs:comment 'Narrative interpretation of the test outcome by the analyst.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Reported Timestamp' ;
    rdfs:comment 'Timestamp when the test result was officially reported to the requesting party.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the result value.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Quantitative test outcome (e.g., CFU count).' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCondition rdf:type rdf:Property ;
    rdfs:label 'Sample Condition' ;
    rdfs:comment 'Physical condition of the sample at collection.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSource rdf:type rdf:Property ;
    rdfs:label 'Sample Source' ;
    rdfs:comment 'Origin of the sample (e.g., supplier, in-house production, field collection).' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Category of the sample (e.g., raw material, work-in-process, finished goods, environmental swab, water).' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganism rdf:type rdf:Property ;
    rdfs:label 'Target Organism' ;
    rdfs:comment 'Microbial organism or indicator targeted by the test.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current processing status of the test.' ;
    rdfs:domain ind:MicroTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'Date when the audit fieldwork concluded.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier assigned to the audit (e.g., internal audit reference).' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'Date when the audit fieldwork began.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditTitle rdf:type rdf:Property ;
    rdfs:label 'Audit Title' ;
    rdfs:comment 'Human-readable title or name of the audit.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Organization that performed the audit (e.g., SGS, Bureau Veritas).' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date on which the certification expires.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Certification Outcome' ;
    rdfs:comment 'Result of the audit regarding certification status.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScheme rdf:type rdf:Property ;
    rdfs:label 'Certification Scheme' ;
    rdfs:comment 'Food safety certification scheme applied to the audit (e.g., SQF, BRC).' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Overall status of corrective action closure for the audit.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLibraryPath rdf:type rdf:Property ;
    rdfs:label 'Document Library Path' ;
    rdfs:comment 'File system or DMS path to the audit’s supporting documents.' ;
