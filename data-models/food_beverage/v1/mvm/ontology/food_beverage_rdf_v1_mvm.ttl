ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Business code used to reference the trade fund in external systems and contracts.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Description' ;
    rdfs:comment 'Free-form description providing context or notes about the fund.' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'Descriptive name of the trade fund for reporting and analysis.' ;
    rdfs:domain ind:Fund ;
