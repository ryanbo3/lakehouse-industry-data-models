ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'Last calendar date of the period for which the accrual is calculated.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'First calendar date of the period for which the accrual is calculated.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingReference rdf:type rdf:Property ;
    rdfs:label 'Posting Reference' ;
    rdfs:comment 'Reference identifier for the GL posting transaction generated from this accrual.' ;
