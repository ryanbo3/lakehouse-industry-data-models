ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier who last modified the promotion event record.' ;
    rdfs:domain ind:FoodBeverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicType rdf:type rdf:Property ;
    rdfs:label 'Mechanic Type' ;
    rdfs:comment 'Type of promotional mechanic deployed for the event.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned end date of the promotion as per the promotion plan.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned start date of the promotion as per the promotion plan.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Event Status' ;
    rdfs:comment 'Current lifecycle status of the promotion event.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionObjective rdf:type rdf:Property ;
    rdfs:label 'Promotion Objective' ;
    rdfs:comment 'Primary business objective of the promotion.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalMaterialsDelivered rdf:type rdf:Property ;
    rdfs:label 'Promotional Materials Delivered' ;
    rdfs:comment 'Flag indicating if promotional materials were delivered to the store.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalMaterialsQuantity rdf:type rdf:Property ;
    rdfs:label 'Promotional Materials Quantity' ;
    rdfs:comment 'Quantity of promotional materials delivered.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalMaterialsType rdf:type rdf:Property ;
    rdfs:label 'Promotional Materials Type' ;
    rdfs:comment 'Type of promotional materials used for the event.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalSpendDiscount rdf:type rdf:Property ;
    rdfs:label 'Promotional Spend Discount' ;
    rdfs:comment 'Total discount or chargeback amount applied to the promotional spend.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalSpendGross rdf:type rdf:Property ;
    rdfs:label 'Promotional Spend Gross' ;
    rdfs:comment 'Gross promotional spend amount before any deductions.' ;
