ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Amount accrued based on spend that has been recognized but not yet paid.' ;
    rdfs:domain ind:Trade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationScope rdf:type rdf:Property ;
    rdfs:label 'Allocation Scope' ;
    rdfs:comment 'Level at which the fund is allocated (e.g., retailer, sales territory, brand/category).' ;
    rdfs:domain ind:Fund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'High-level category of the fund purpose (e.g., marketing, price promotion, slotting).' ;
