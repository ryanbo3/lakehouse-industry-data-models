    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalSpendNet rdf:type rdf:Property ;
    rdfs:label 'Promotional Spend Net' ;
    rdfs:comment 'Net promotional spend after discounts and chargebacks.' ;
