    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount' ;
    rdfs:comment 'Total monetary funding for the promotion line (derived from volume and per-unit funding).' ;
