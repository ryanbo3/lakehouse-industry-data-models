    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuList rdf:type rdf:Property ;
    rdfs:label 'Sku List' ;
    rdfs:comment 'Comma-separated list of SKUs included in the promotion.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
