    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the category in external systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed textual description of the category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the product category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the category (e.g., Food, Beverage).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPerishable rdf:type rdf:Property ;
    rdfs:label 'Is Perishable' ;
    rdfs:comment 'Indicates whether items in this category are perishable (true) or non-perishable (false).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Consumer-facing description used in marketing materials.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalProfile rdf:type rdf:Property ;
    rdfs:label 'Nutritional Profile' ;
    rdfs:comment 'Standard nutritional characteristics for the category (e.g., high protein, low sugar).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory classification governing the category (e.g., GRAS, FDA approved).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStoreCoverageId rdf:type rdf:Property ;
    rdfs:label 'Contract Store Coverage Id' ;
    rdfs:comment 'System-generated unique identifier for this contract-store coverage record.' ;
    rdfs:domain ind:ContractStoreCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of this store\'s coverage under the contract (active, pending, suspended, terminated). Allows per-store status management independent of the master contract status.' ;
    rdfs:domain ind:ContractStoreCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignClaimUsageId rdf:type rdf:Property ;
    rdfs:label 'Campaign Claim Usage Id' ;
    rdfs:comment 'Unique surrogate identifier for each campaign-claim usage record. Primary key for the association.' ;
    rdfs:domain ind:CampaignClaimUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceStatusForCampaign rdf:type rdf:Property ;
    rdfs:label 'Compliance Status For Campaign' ;
    rdfs:comment 'Legal and regulatory compliance status of this claim specifically within this campaign context. Values: approved (legal cleared for use), pending_review (awaiting marketing legal review), rejected (not approved for this campaign), conditional (approved with restrictions), expired (approval lapsed). Tracks campaign-specific compliance state.' ;
    rdfs:domain ind:CampaignClaimUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Free-text field for campaign-specific usage instructions, restrictions, or context for this claim deployment (e.g., must appear with disclaimer, only for SKU X, regional restrictions). Supports operational guidance for creative teams.' ;
    rdfs:domain ind:CampaignClaimUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountItemId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Item Id' ;
    rdfs:comment 'Unique identifier for the cycle count line item. Primary key for this association.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'Reference to the goods movement document number generated when the variance adjustment was posted (SAP MIGO document).' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment for this line item variance has been posted to the general ledger.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current status of this specific line item within the cycle count: not_started, in_progress, counted, recounted, variance_approved, posted, cancelled.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Timestamp when this specific stock position was physically counted by the warehouse worker.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse worker during the cycle count event. May differ from system quantity.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterEmployeeCode rdf:type rdf:Property ;
    rdfs:label 'Counter Employee Code' ;
    rdfs:comment 'Employee ID of the warehouse worker who performed the physical count for this line item. May differ from the cycle count header if multiple counters are assigned.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count verification for this stock position. Used to track count frequency and accuracy. [Moved from stock_position: This attribute in stock_position represents the date of the most recent cycle count for this stock position. This is derivable from the cycle_count_item association (MAX(count_timestamp) where stock_position_id = X). It should not be denormalized on stock_position in a normalized model, as it creates update anomalies when new counts occur.]' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCountVariance rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance' ;
    rdfs:comment 'Difference between system quantity and physical count quantity from the most recent cycle count. Positive indicates overage; negative indicates shortage. [Moved from stock_position: This attribute in stock_position represents the variance from the most recent cycle count. This is derivable from the cycle_count_item association (variance_quantity from the most recent count). It should not be denormalized on stock_position, as it creates update anomalies and loses historical variance tracking.]' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemNotes rdf:type rdf:Property ;
    rdfs:label 'Line Item Notes' ;
    rdfs:comment 'Free-text notes specific to this line item count, such as observed damage, location discrepancies, or count challenges.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether this specific line item required a recount due to variance exceeding threshold or count discrepancy.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recount Timestamp' ;
    rdfs:comment 'Timestamp when this line item was recounted, if recount was required. Null if no recount performed.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The quantity recorded in the system at the time the cycle count was initiated. Represents the book inventory before physical verification.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Reason code for the variance identified during root cause analysis: shrinkage, damage, system_error, receiving_error, picking_error, etc.' ;
    rdfs:domain ind:CycleCountItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpPlanSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Specification Id' ;
    rdfs:comment 'Primary key for the HACCP plan specification linkage record' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Scope of how this specification applies to the HACCP plan (e.g., critical limit, monitoring parameter, verification requirement). Identified in detection phase relationship data.' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitReference rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Reference' ;
    rdfs:comment 'Reference to the specific critical limit parameter in the specification (e.g., pH, temperature, microbial count) that this HACCP plan monitors. Identified in detection phase relationship data.' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategoryMapping rdf:type rdf:Property ;
    rdfs:label 'Hazard Category Mapping' ;
    rdfs:comment 'Mapping of which hazard categories (biological, chemical, physical, radiological) from the HACCP plan are controlled by this specification. Identified in detection phase relationship data.' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageStatus rdf:type rdf:Property ;
    rdfs:label 'Linkage Status' ;
    rdfs:comment 'Current status of this HACCP plan-specification linkage (active, superseded, under review, deprecated)' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedBy rdf:type rdf:Property ;
    rdfs:label 'Linked By' ;
    rdfs:comment 'Name or ID of the food safety professional who established this linkage' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Linked Timestamp' ;
    rdfs:comment 'Timestamp when this HACCP plan-specification linkage was created' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory requirement (FDA FSMA, USDA FSIS, Codex) that mandates this linkage' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionAtPlanApproval rdf:type rdf:Property ;
    rdfs:label 'Version At Plan Approval' ;
    rdfs:comment 'Version number of the specification that was in effect when the HACCP plan was approved. Critical for regulatory audit trail. Identified in detection phase relationship data.' ;
    rdfs:domain ind:HaccpPlanSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
