ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'System-generated unique identifier for the accrual record.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Business identifier assigned to the accrual, used in reporting and audit trails.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the accrual record.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Mechanism by which the accrual is calculated (e.g., off-invoice, bill-back, scan-back, lump-sum).' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
