    rdfs:comment 'Indicates whether hazardous chemicals, reagents, or materials are used or stored in this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major capital upgrade or expansion project for this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Per Day' ;
    rdfs:comment 'Planned operating hours per day for this process area, accounting for scheduled maintenance windows.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processMethod rdf:type rdf:Property ;
    rdfs:label 'Process Method' ;
    rdfs:comment 'Specific processing technology or method employed in this area (e.g., SAG mill, HPGR, flotation, leaching, SX-EW).' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processType rdf:type rdf:Property ;
    rdfs:label 'Process Type' ;
    rdfs:comment 'High-level classification of the process area by its primary function in the mineral processing value chain.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSizeP80Microns rdf:type rdf:Property ;
    rdfs:label 'Product Size P80 Microns' ;
    rdfs:comment 'Target product particle size distribution P80 (80th percentile) in microns for material exiting this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProductGradePercent rdf:type rdf:Property ;
    rdfs:label 'Target Product Grade Percent' ;
    rdfs:comment 'Target concentrate or product grade for output from this process area, expressed as percentage of valuable mineral content.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRecoveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Target Recovery Rate Percent' ;
    rdfs:comment 'Target mineral recovery rate for this process area expressed as a percentage, aligned with LOM plan targets.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFlowRateTph rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate Tph' ;
    rdfs:comment 'Designed or nameplate flow rate capacity of the stream measured in tonnes per hour as per engineering specifications.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designGradePct rdf:type rdf:Property ;
    rdfs:label 'Design Grade Pct' ;
    rdfs:comment 'Target grade or concentration of the valuable mineral in the stream expressed as weight percentage.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designParticleSizeP80Microns rdf:type rdf:Property ;
    rdfs:label 'Design Particle Size P80 Microns' ;
    rdfs:comment 'Target particle size distribution where 80% of particles pass through, measured in microns, as per process design specifications.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designSolidsConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Design Solids Concentration Pct' ;
    rdfs:comment 'Target solids concentration by weight percentage for slurry streams as specified in process design.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Destination Equipment Id' ;
    rdfs:comment 'Reference to the equipment unit to which this stream flows.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether this stream requires environmental compliance monitoring for discharge or emissions.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Flow Measurement Method' ;
    rdfs:comment 'Technology or method used to measure the flow rate of this stream.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeOfMinePlanId rdf:type rdf:Property ;
    rdfs:label 'Life Of Mine Plan Id' ;
    rdfs:comment 'Reference to the life of mine plan version against which this stream design and targets are aligned.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:massBalanceNodeFlag rdf:type rdf:Property ;
    rdfs:label 'Mass Balance Node Flag' ;
    rdfs:comment 'Indicates whether this stream is a key node in plant-wide mass balance reconciliation calculations.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialClassification rdf:type rdf:Property ;
    rdfs:label 'Material Classification' ;
    rdfs:comment 'Primary classification of the material type flowing through this stream.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalPipeDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Nominal Pipe Diameter Mm' ;
    rdfs:comment 'Nominal internal diameter of the pipe or conduit carrying this stream, measured in millimeters.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ph Control Required Flag' ;
    rdfs:comment 'Indicates whether pH monitoring and control is required for this stream as part of process chemistry management.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipingInstrumentationDiagramReference rdf:type rdf:Property ;
