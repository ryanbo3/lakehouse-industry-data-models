    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipingSpecification rdf:type rdf:Property ;
    rdfs:label 'Piping Specification' ;
    rdfs:comment 'Engineering specification reference for the piping or conveyance system used for this stream.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowDiagramReference rdf:type rdf:Property ;
